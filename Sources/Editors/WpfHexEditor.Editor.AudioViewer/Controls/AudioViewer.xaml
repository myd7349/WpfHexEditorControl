<UserControl x:Class="WpfHexEditor.Editor.AudioViewer.Controls.AudioViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="clr-namespace:WpfHexEditor.Editor.AudioViewer.Controls"
             xmlns:pb="clr-namespace:WpfHexEditor.ProgressBar.Controls;assembly=WpfHexEditor.ProgressBar"
             Background="{DynamicResource TE_Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="22"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border x:Name="ToolbarBorder"
                Grid.Row="0"
                Style="{DynamicResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="True">

                <!-- Right: always-visible (nothing for now, reserved) -->
                <StackPanel x:Name="ToolbarRightPanel"
                            Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center"/>

                <!-- Overflow button — shown only when groups are collapsed -->
                <Button x:Name="ToolbarOverflowButton"
                        DockPanel.Dock="Right"
                        Visibility="Collapsed"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        ToolTip="More options"
                        Click="OnOverflowButtonClick">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowContextMenu" Opened="OnOverflowMenuOpened"/>
                    </Button.ContextMenu>
                </Button>

                <!-- Format info label (LastChildFill) -->
                <TextBlock x:Name="FormatInfoLabel"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           FontSize="12"
                           Text="Audio"/>
            </DockPanel>
        </Border>

        <!-- Waveform area -->
        <Border Grid.Row="1"
                Background="{DynamicResource TE_Background}">
            <av:WaveformDrawingCanvas x:Name="WaveCanvas"
                                      Cursor="Hand"
                                      HoverChanged="OnWaveHoverChanged"
                                      OffsetRequested="OnWaveOffsetRequested"/>
        </Border>

        <!-- Transport bar (Row 2) — hidden when format does not support playback -->
        <Border x:Name="TransportBar"
                Grid.Row="2"
                Visibility="Collapsed"
                Background="{DynamicResource TE_LineNumberBackground}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                Height="30">
            <DockPanel Margin="6,0" LastChildFill="True">

                <!-- Play/Pause toggle -->
                <Button x:Name="PlayPauseBtn"
                        DockPanel.Dock="Left"
                        Width="26" Height="22"
                        Margin="0,0,2,0"
                        ToolTip="Play / Pause (Space)"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Click="OnPlayPauseClicked">
                    <TextBlock x:Name="PlayPauseGlyph"
                               Text="&#xE768;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </Button>

                <!-- Stop -->
                <Button x:Name="StopBtn"
                        DockPanel.Dock="Left"
                        Width="26" Height="22"
                        Margin="0,0,6,0"
                        ToolTip="Stop"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Click="OnStopClicked">
                    <TextBlock Text="&#xE71A;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </Button>

                <!-- Current position label -->
                <TextBlock x:Name="PositionLabel"
                           DockPanel.Dock="Left"
                           Text="0:00"
                           FontSize="11"
                           VerticalAlignment="Center"
                           MinWidth="34"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           Margin="0,0,4,0"/>

                <!-- Duration label -->
                <TextBlock x:Name="DurationLabel"
                           DockPanel.Dock="Right"
                           Text="0:00"
                           FontSize="11"
                           VerticalAlignment="Center"
                           MinWidth="34"
                           TextAlignment="Right"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           Margin="4,0,0,0"/>

                <!-- Seek slider (fills remaining space) -->
                <Slider x:Name="SeekSlider"
                        VerticalAlignment="Center"
                        Minimum="0" Maximum="1"
                        SmallChange="0.01"
                        LargeChange="0.05"
                        IsMoveToPointEnabled="True"
                        Thumb.DragStarted="OnSeekDragStarted"
                        Thumb.DragCompleted="OnSeekDragCompleted"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource TE_LineNumberBackground}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource Panel_ToolbarForegroundBrush}">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       Text="Open an audio file"/>
        </Border>

        <!-- Busy overlay -->
        <Grid x:Name="BusyOverlay"
              Grid.Row="1"
              Visibility="Collapsed">
            <pb:LinearProgressBar IsIndeterminate="True"
                                    BarHeight="2"
                                    Height="2"
                                    VerticalAlignment="Top"/>
            <TextBlock Text="Analyzing…"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       FontSize="12"
                       Opacity="0.6"/>
        </Grid>
    </Grid>
</UserControl>

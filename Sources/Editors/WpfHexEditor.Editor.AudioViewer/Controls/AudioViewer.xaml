<UserControl x:Class="WpfHexEditor.Editor.AudioViewer.Controls.AudioViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="clr-namespace:WpfHexEditor.Editor.AudioViewer.Controls"
             Background="{DynamicResource TE_Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="22"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border x:Name="ToolbarBorder"
                Grid.Row="0"
                Style="{DynamicResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="True">

                <!-- Right: always-visible (nothing for now, reserved) -->
                <StackPanel x:Name="ToolbarRightPanel"
                            Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center"/>

                <!-- Overflow button — shown only when groups are collapsed -->
                <Button x:Name="ToolbarOverflowButton"
                        DockPanel.Dock="Right"
                        Visibility="Collapsed"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        ToolTip="More options"
                        Click="OnOverflowButtonClick">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowContextMenu" Opened="OnOverflowMenuOpened"/>
                    </Button.ContextMenu>
                </Button>

                <!-- Format info label (LastChildFill) -->
                <TextBlock x:Name="FormatInfoLabel"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           FontSize="12"
                           Text="Audio"/>
            </DockPanel>
        </Border>

        <!-- Waveform area -->
        <Border Grid.Row="1"
                Background="{DynamicResource TE_Background}">
            <av:WaveformDrawingCanvas x:Name="WaveCanvas"
                                      Cursor="Hand"
                                      HoverChanged="OnWaveHoverChanged"
                                      OffsetRequested="OnWaveOffsetRequested"/>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource TE_LineNumberBackground}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource Panel_ToolbarForegroundBrush}">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       Text="Open an audio file"/>
        </Border>

        <!-- Busy overlay -->
        <Grid x:Name="BusyOverlay"
              Grid.Row="1"
              Visibility="Collapsed">
            <ProgressBar IsIndeterminate="True"
                         Height="2"
                         VerticalAlignment="Top"
                         Foreground="{DynamicResource TE_LineNumberForeground}"/>
            <TextBlock Text="Analyzing…"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       FontSize="12"
                       Opacity="0.6"/>
        </Grid>
    </Grid>
</UserControl>

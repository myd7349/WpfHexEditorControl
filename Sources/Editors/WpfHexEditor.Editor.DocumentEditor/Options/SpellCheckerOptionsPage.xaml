<!--
    Project: WpfHexEditor.Editor.DocumentEditor
    File: Options/SpellCheckerOptionsPage.xaml
    Description:
        Options page for the Document Editor spell checker.
        Shown under Tools > Options > Document Editor > Spell Checker.
        Allows enable/disable, language selection, dictionary install/remove,
        and user dictionary editing.
-->
<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Options.SpellCheckerOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:docSvc="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Services"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             Padding="12">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <docSvc:DocumentEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="IdeButtonStyle" TargetType="Button">
                <Setter Property="Background"      Value="{DynamicResource Panel_ToolbarBrush}"/>
                <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2">
                                <Border x:Name="Overlay" Background="Transparent" CornerRadius="2">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"
                                                      RecognizesAccessKey="True"/>
                                </Border>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Overlay" Property="Background" Value="#20FFFFFF"/>
                                    <Setter TargetName="Root"    Property="BorderBrush" Value="{DynamicResource DockAccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Overlay" Property="Background" Value="#40FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>

        <!-- Enable toggle -->
        <CheckBox x:Name="ChkEnabled"
                  Content="{StaticResource SpellCheck_Enable}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  FontSize="13"
                  Margin="0,0,0,12"
                  Checked="OnEnabledChanged"
                  Unchecked="OnEnabledChanged"/>

        <!-- Section header -->
        <TextBlock Text="{StaticResource SpellCheck_DictSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <!-- Dictionary list -->
        <Border BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="1"
                CornerRadius="2"
                Margin="0,0,0,8">
            <DataGrid x:Name="DictGrid"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="False"
                      GridLinesVisibility="Horizontal"
                      RowBackground="{DynamicResource DockWindowBackgroundBrush}"
                      AlternatingRowBackground="{DynamicResource DockMenuBackgroundBrush}"
                      Background="{DynamicResource DockWindowBackgroundBrush}"
                      BorderThickness="0"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      FontSize="12"
                      MaxHeight="320"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource DockMenuBackgroundBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="FontSize" Value="11"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DockAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DockMenuBackgroundBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <!-- Active radio -->
                    <DataGridTemplateColumn Width="36">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <RadioButton IsChecked="{Binding IsActive, Mode=TwoWay}"
                                             GroupName="ActiveLang"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             IsEnabled="{Binding IsInstalled}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Language name -->
                    <DataGridTextColumn Header="{StaticResource SpellCheck_ColLanguage}"
                                        Binding="{Binding DisplayName}"
                                        Width="*"
                                        IsReadOnly="True"/>
                    <!-- Status badge -->
                    <DataGridTemplateColumn Header="{StaticResource SpellCheck_ColStatus}" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3"
                                        Padding="6,2"
                                        HorizontalAlignment="Left"
                                        Background="{Binding StatusColor}">
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="White"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Progress -->
                    <DataGridTemplateColumn Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ProgressBar Value="{Binding InstallProgress}"
                                             Minimum="0" Maximum="100"
                                             Height="8"
                                             Visibility="{Binding ProgressVisible}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Actions -->
                    <DataGridTemplateColumn Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2">
                                    <!-- Download button (when not installed) -->
                                    <Button Content="{StaticResource SpellCheck_Download}"
                                            Style="{StaticResource IdeButtonStyle}"
                                            Padding="6,2"
                                            FontSize="10"
                                            Margin="0,0,4,0"
                                            Visibility="{Binding DownloadVisible}"
                                            IsEnabled="{Binding IsNotInstalling}"
                                            Click="OnDownloadClick"/>
                                    <!-- Browse button -->
                                    <Button Content="{StaticResource SpellCheck_Browse}"
                                            Style="{StaticResource IdeButtonStyle}"
                                            Padding="6,2"
                                            FontSize="10"
                                            Margin="0,0,4,0"
                                            Visibility="{Binding BrowseVisible}"
                                            Click="OnBrowseClick"/>
                                    <!-- Remove button (when installed) -->
                                    <Button Content="{StaticResource SpellCheck_Remove}"
                                            Style="{StaticResource IdeButtonStyle}"
                                            Padding="6,2"
                                            FontSize="10"
                                            Visibility="{Binding RemoveVisible}"
                                            Click="OnRemoveClick"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

        <!-- User dictionary -->
        <TextBlock Text="{StaticResource SpellCheck_UserDictSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="TxtUserDictPath"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_SubTextBrush}"
                       FontSize="11"
                       Margin="0,0,8,0"/>
            <Button Content="{StaticResource SpellCheck_EditUserDict}"
                    Style="{StaticResource IdeButtonStyle}"
                    Padding="8,3"
                    FontSize="11"
                    Click="OnEditUserDictClick"/>
        </StackPanel>

        <!-- Ignored words list -->
        <TextBlock Text="{StaticResource SpellCheck_IgnoredWordsSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,12,0,6"/>

        <Border BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="1"
                CornerRadius="2"
                Margin="0,0,0,4">
            <ListBox x:Name="LstIgnoredWords"
                     MaxHeight="120"
                     Background="{DynamicResource DockWindowBackgroundBrush}"
                     Foreground="{DynamicResource PFP_TextBrush}"
                     FontSize="12"
                     BorderThickness="0"
                     SelectionMode="Single"/>
        </Border>
        <Button Content="{StaticResource SpellCheck_RemoveIgnoredWord}"
                Style="{StaticResource IdeButtonStyle}"
                Padding="8,3"
                FontSize="11"
                HorizontalAlignment="Left"
                Margin="0,0,0,4"
                Click="OnRemoveIgnoredWordClick"/>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,8,0,8"/>

        <!-- Behavior section -->
        <TextBlock Text="{StaticResource SpellCheck_BehaviorSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,8"/>

        <CheckBox x:Name="ChkMultiLanguage"
                  Content="{StaticResource SpellCheck_MultiLanguageMode}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  FontSize="12"
                  Margin="0,0,0,4"
                  Checked="OnMultiLanguageChanged"
                  Unchecked="OnMultiLanguageChanged"/>

        <TextBlock Text="{StaticResource SpellCheck_MultiLanguageModeHint}"
                   Foreground="{DynamicResource PFP_SubTextBrush}"
                   FontSize="11"
                   Margin="20,0,0,10"
                   TextWrapping="Wrap"/>

        <!-- Analysis delay -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{StaticResource SpellCheck_AnalysisDelay}"
                       Foreground="{DynamicResource PFP_TextBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Slider x:Name="SldrDebounce"
                        Minimum="100" Maximum="5000"
                        TickFrequency="100"
                        IsSnapToTickEnabled="True"
                        Width="160"
                        VerticalAlignment="Center"
                        ValueChanged="OnDebounceChanged"
                        Thumb.DragCompleted="OnSliderDragCompleted"/>
                <TextBlock x:Name="TxtDebounceValue"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="11"
                           Width="52"
                           TextAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Max suggestions -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{StaticResource SpellCheck_MaxSuggestions}"
                       Foreground="{DynamicResource PFP_TextBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"/>
            <Slider x:Name="SldrMaxSuggestions"
                    Grid.Column="1"
                    Minimum="1" Maximum="20"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    Width="160"
                    VerticalAlignment="Center"
                    ValueChanged="OnMaxSuggestionsChanged"
                    Thumb.DragCompleted="OnSliderDragCompleted"/>
        </Grid>
        <TextBlock x:Name="TxtMaxSuggestionsValue"
                   Foreground="{DynamicResource PFP_SubTextBrush}"
                   FontSize="11"
                   HorizontalAlignment="Right"
                   Margin="0,-6,0,8"/>

        <!-- Detection confidence -->
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{StaticResource SpellCheck_DetectionConfidence}"
                       Foreground="{DynamicResource PFP_TextBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Slider x:Name="SldrConfidence"
                        Minimum="1" Maximum="50"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Width="160"
                        VerticalAlignment="Center"
                        ValueChanged="OnConfidenceChanged"
                        Thumb.DragCompleted="OnSliderDragCompleted"/>
                <TextBlock x:Name="TxtConfidenceValue"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="11"
                           Width="40"
                           TextAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,8,0,8"/>

        <!-- Advanced section -->
        <TextBlock Text="{StaticResource SpellCheck_AdvancedSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,8"/>

        <!-- Mirror URL -->
        <TextBlock Text="{StaticResource SpellCheck_MirrorUrl}"
                   Foreground="{DynamicResource PFP_TextBrush}"
                   FontSize="12"
                   Margin="0,0,0,4"/>
        <TextBox x:Name="TxtMirrorUrl"
                 FontSize="11"
                 Padding="4,3"
                 Margin="0,0,0,10"
                 Background="{DynamicResource DockWindowBackgroundBrush}"
                 Foreground="{DynamicResource PFP_TextBrush}"
                 BorderBrush="{DynamicResource PFP_BorderBrush}"
                 BorderThickness="1"
                 LostFocus="OnMirrorUrlChanged"/>

        <!-- Dictionaries path -->
        <TextBlock Text="{StaticResource SpellCheck_DictPath}"
                   Foreground="{DynamicResource PFP_TextBrush}"
                   FontSize="12"
                   Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtDictPath"
                     Grid.Column="0"
                     FontSize="11"
                     Padding="4,3"
                     Margin="0,0,6,0"
                     Background="{DynamicResource DockWindowBackgroundBrush}"
                     Foreground="{DynamicResource PFP_TextBrush}"
                     BorderBrush="{DynamicResource PFP_BorderBrush}"
                     BorderThickness="1"
                     LostFocus="OnDictPathChanged"/>
            <Button Grid.Column="1"
                    Content="{StaticResource SpellCheck_Browse}"
                    Style="{StaticResource IdeButtonStyle}"
                    Padding="8,3"
                    FontSize="11"
                    Click="OnBrowseDictPathClick"/>
        </Grid>

        <!-- Reset to defaults -->
        <Button Content="{StaticResource SpellCheck_ResetDefaults}"
                Style="{StaticResource IdeButtonStyle}"
                Padding="10,4"
                FontSize="11"
                HorizontalAlignment="Left"
                Click="OnResetAdvancedClick"/>

    </StackPanel>
</UserControl>

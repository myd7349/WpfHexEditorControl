<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentEditorHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Controls"
             Background="{DynamicResource DE_TextPaneBackground}"
             Foreground="{DynamicResource DE_TextPaneForeground}">
    <UserControl.Resources>
        <!-- Design-time fallbacks -->
        <SolidColorBrush x:Key="DE_TextPaneBackground_Fallback"  Color="#1E1E1E"/>
        <SolidColorBrush x:Key="DE_TextPaneForeground_Fallback"  Color="#D4D4D4"/>

        <!-- Toolbar toggle-button style (radio-like, checked = active) -->
        <Style x:Key="DocViewToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding"      Value="7,4"/>
            <Setter Property="Height"       Value="26"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Plain action button style (save, export, metadata) -->
        <Style x:Key="DocActionButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding"      Value="7,4"/>
            <Setter Property="Height"       Value="26"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar separator -->
        <Style x:Key="DocToolbarSeparatorStyle" TargetType="Separator">
            <Setter Property="Width"          Value="1"/>
            <Setter Property="Margin"         Value="4,4"/>
            <Setter Property="Background"     Value="{DynamicResource DE_ToolbarBorderBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="PART_ToolbarRow"    Height="Auto"/>  <!-- Row 0: Toolbar -->
            <RowDefinition x:Name="PART_BreadcrumbRow" Height="Auto"/>  <!-- Row 1: Breadcrumb bar -->
            <RowDefinition                              Height="*"/>     <!-- Row 2: Content panes -->
            <RowDefinition x:Name="PART_MiniMapRow"    Height="Auto"/>  <!-- Row 3: MiniMap strip -->
            <RowDefinition x:Name="PART_StatusBarRow"  Height="Auto"/>  <!-- Row 4: Status bar -->
        </Grid.RowDefinitions>

        <!-- ══ Row 0: Toolbar ═════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource DE_ToolbarBackground}"
                BorderBrush="{DynamicResource DE_ToolbarBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="4,2" LastChildFill="False">

                <!-- Group 1 — View mode (radio-like toggles) -->
                <ToggleButton x:Name="PART_TextModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              ToolTip="Text view"
                              Click="OnTextModeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text=" Text" FontSize="12" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="PART_SplitModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Split view (text + hex)"
                              Click="OnSplitModeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C4;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text=" Split" FontSize="12" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="PART_HexModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Hex view"
                              Click="OnHexModeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F4;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text=" Hex" FontSize="12" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="PART_StructModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Structure tree view"
                              Click="OnStructureModeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C9;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text=" Structure" FontSize="12" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="PART_FullModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Full view (text + structure + hex)"
                              Click="OnFullModeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D9;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text=" Full" FontSize="12" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="PART_FocusModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Focus mode — zen writing (Ctrl+Shift+F)"
                              Click="OnFocusModeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8D4;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text=" Focus" FontSize="12" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 1b — Render mode (Page / Draft / Outline) -->
                <ToggleButton x:Name="PART_PageModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Page view — paginated A4/Letter cards"
                              Click="OnPageModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A8;" FontSize="13" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_DraftModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Draft view — continuous scroll, compact margins"
                              Click="OnDraftModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E9;" FontSize="13" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_OutlineModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Outline view — structure tree centred"
                              Click="OnOutlineModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F1;" FontSize="13" VerticalAlignment="Center"/>
                </ToggleButton>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 2 — Forensic mode -->
                <ToggleButton x:Name="PART_ForensicBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              ToolTip="Forensic analysis mode"
                              Click="OnForensicModeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C3;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text=" Forensic" FontSize="12" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 5 — Text formatting (Phase 14) -->
                <ToggleButton x:Name="PART_BoldBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Bold (Ctrl+B)"
                              Click="OnBoldClicked">
                    <TextBlock FontFamily="Segoe UI" Text="B" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_ItalicBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Italic (Ctrl+I)"
                              Click="OnItalicClicked">
                    <TextBlock FontFamily="Segoe UI" Text="I" FontSize="13" FontStyle="Italic" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_UnderlineBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Underline (Ctrl+U)"
                              Click="OnUnderlineClicked">
                    <TextBlock FontFamily="Segoe UI" Text="U" FontSize="13"
                               TextDecorations="Underline" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_StrikethroughBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="Strikethrough"
                              Click="OnStrikethroughClicked">
                    <TextBlock FontFamily="Segoe UI" Text="S" FontSize="13"
                               TextDecorations="Strikethrough" VerticalAlignment="Center"/>
                </ToggleButton>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 6 — Paragraph formatting (Phase 15) -->
                <ComboBox x:Name="PART_StyleDropdown"
                          DockPanel.Dock="Left"
                          Width="80"
                          Height="22"
                          FontSize="11"
                          Margin="2,0"
                          SelectionChanged="OnStyleDropdownChanged"
                          ToolTip="Paragraph style">
                    <ComboBoxItem Content="Normal"  IsSelected="True"/>
                    <ComboBoxItem Content="H1"/>
                    <ComboBoxItem Content="H2"/>
                    <ComboBoxItem Content="H3"/>
                    <ComboBoxItem Content="H4"/>
                    <ComboBoxItem Content="H5"/>
                    <ComboBoxItem Content="H6"/>
                    <ComboBoxItem Content="Quote"/>
                    <ComboBoxItem Content="Code"/>
                </ComboBox>

                <Button x:Name="PART_AlignLeftBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        ToolTip="Align left"
                        Click="OnAlignLeftClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E4;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_AlignCenterBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        ToolTip="Align center"
                        Click="OnAlignCenterClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E3;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_AlignRightBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        ToolTip="Align right"
                        Click="OnAlignRightClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E2;" FontSize="13"/>
                </Button>

                <!-- Group 7 — Styles panel (Phase 18) -->
                <Button x:Name="PART_StylesBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        ToolTip="Paragraph styles (Ctrl+Alt+S)"
                        Click="OnStylesBtnClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8EC;" FontSize="13"/>
                </Button>

                <Popup x:Name="PART_StylesPopup"
                       PlacementTarget="{Binding ElementName=PART_StylesBtn}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource DockBackgroundBrush}"
                            BorderBrush="{DynamicResource DockBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="4">
                        <local:DocumentStylesPanel x:Name="PART_StylesPanel"
                                                   StyleSelected="OnStylesPanelStyleSelected"/>
                    </Border>
                </Popup>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 3b — Page Setup -->
                <Button x:Name="PART_PageSetupBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        ToolTip="Page setup (paper size, margins, columns…)"
                        Click="OnPageSetupBtnClick">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="13"/>
                </Button>

                <Popup x:Name="PART_PageSetupPopup"
                       PlacementTarget="{Binding ElementName=PART_PageSetupBtn}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <local:DocumentPageSettingsPanel
                        x:Name="PART_PageSettingsPanel"
                        SettingsApplied="OnPageSettingsApplied"
                        Cancelled="OnPageSettingsCancelled"/>
                </Popup>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 3 — Zoom controls -->
                <Button x:Name="PART_ZoomOutBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Padding="6,4"
                        ToolTip="Zoom out"
                        Click="OnZoomOutClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71F;" FontSize="13"/>
                </Button>

                <TextBlock x:Name="PART_ZoomLabel"
                           DockPanel.Dock="Left"
                           Text="100%"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="4,0"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           MinWidth="38"
                           TextAlignment="Center"/>

                <Button x:Name="PART_ZoomInBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Padding="6,4"
                        ToolTip="Zoom in"
                        Click="OnZoomInClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A3;" FontSize="13"/>
                </Button>

                <!-- Group 4 — Right-aligned actions -->
                <!-- Lock icon — visible only in read-only mode -->
                <TextBlock x:Name="PART_LockIcon"
                           DockPanel.Dock="Right"
                           FontFamily="Segoe MDL2 Assets"
                           Text="&#xE72E;"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Foreground="{DynamicResource DE_ForensicBadgeWarnBg}"
                           ToolTip="Read Only"
                           Visibility="Collapsed"/>

                <Button x:Name="PART_MetadataBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Right"
                        Margin="0,0,2,0"
                        ToolTip="Document metadata"
                        Click="OnMetadataClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="13"/>
                </Button>

                <Popup x:Name="PART_MetadataPopup"
                       PlacementTarget="{Binding ElementName=PART_MetadataBtn}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                            BorderThickness="1"
                            Padding="12"
                            MinWidth="260">
                        <Grid x:Name="PART_MetadataGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Row 0: Title -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Title" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="PART_Meta_Title" TextWrapping="Wrap"/>
                            <!-- Row 1: Author -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Author" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="PART_Meta_Author" Margin="0,4,0,0"/>
                            <!-- Row 2: Format -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Format" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="PART_Meta_Format" Margin="0,4,0,0"/>
                            <!-- Row 3: MIME -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="MIME" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="PART_Meta_Mime" Margin="0,4,0,0"/>
                            <!-- Row 4: Created -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Created" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" x:Name="PART_Meta_Created" Margin="0,4,0,0"/>
                            <!-- Row 5: Modified -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Modified" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="5" Grid.Column="2" x:Name="PART_Meta_Modified" Margin="0,4,0,0"/>
                            <!-- Row 6: Macros badge -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Macros" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="6" Grid.Column="2" x:Name="PART_Meta_Macros" Margin="0,4,0,0"/>
                        </Grid>
                    </Border>
                </Popup>

                <Button x:Name="PART_ExportBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Right"
                        Margin="0,0,2,0"
                        ToolTip="Export document"
                        Click="OnExportClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEDE1;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_SaveBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Right"
                        Margin="0,0,2,0"
                        ToolTip="Save"
                        Click="OnSaveClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;" FontSize="13"/>
                </Button>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Right"/>

            </DockPanel>
        </Border>

        <!-- ══ Row 1: Breadcrumb bar ══════════════════════════════════════════ -->
        <local:DocumentBreadcrumb x:Name="PART_Breadcrumb"
                                  Grid.Row="1"
                                  BlockSelected="OnBreadcrumbBlockSelected"/>

        <!-- ══ Row 2: Content grid (3 panes + splitters) ══════════════════════ -->
        <Grid x:Name="PART_ContentGrid" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="PART_TextCol"      Width="2*"  MinWidth="100"/>
                <ColumnDefinition x:Name="PART_Splitter1Col" Width="4"/>
                <ColumnDefinition x:Name="PART_StructCol"    Width="0"   MinWidth="0"/>
                <ColumnDefinition x:Name="PART_Splitter2Col" Width="0"/>
                <ColumnDefinition x:Name="PART_HexCol"       Width="*"   MinWidth="100"/>
            </Grid.ColumnDefinitions>

            <!-- Text pane (col 0) -->
            <local:DocumentTextPane x:Name="PART_TextPane"
                                    Grid.Column="0"
                                    SelectedBlockChanged="OnTextPaneSelectedBlockChanged"
                                    PopToolbarRequested="OnPopToolbarRequested"/>

            <!-- Splitter 1 (col 1) -->
            <GridSplitter x:Name="PART_Splitter1"
                          Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"/>

            <!-- Structure pane (col 2) — hidden unless Structure mode -->
            <local:DocumentStructurePane x:Name="PART_StructurePane"
                                         Grid.Column="2"
                                         Visibility="Collapsed"
                                         BlockNavigated="OnStructureBlockNavigated"/>

            <!-- Splitter 2 (col 3) — hidden by default -->
            <GridSplitter x:Name="PART_Splitter2"
                          Grid.Column="3"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"
                          Visibility="Collapsed"/>

            <!-- Hex pane (col 4) -->
            <local:DocumentHexPane x:Name="PART_HexPane"
                                   Grid.Column="4"/>

            <!-- Pop-toolbar popup (anchored to content grid) -->
            <Popup x:Name="PART_PopToolbar"
                   AllowsTransparency="True"
                   PlacementTarget="{Binding ElementName=PART_TextPane}"
                   Placement="RelativePoint"
                   StaysOpen="False"
                   PopupAnimation="Fade">
                <local:DocumentPopToolbar x:Name="PART_PopToolbarContent"
                                          FormatRequested="OnPopToolbarFormat"
                                          CopyTextRequested="OnPopToolbarCopyText"
                                          CopyHexRequested="OnPopToolbarCopyHex"
                                          InspectRequested="OnPopToolbarInspect"
                                          JumpHexRequested="OnPopToolbarJumpHex"/>
            </Popup>
        </Grid>

        <!-- ══ Row 3: MiniMap strip ════════════════════════════════════════════ -->
        <local:DocumentMiniMap x:Name="PART_MiniMap"
                               Grid.Row="3"
                               Height="14"/>

        <!-- ══ Row 4: Status bar ════════════════════════════════════════════════ -->
        <local:DocumentStatusBar x:Name="PART_StatusBar"
                                 Grid.Row="4"
                                 ForensicBadgeClicked="OnStatusBarForensicClicked"
                                 ZoomChanged="OnStatusBarZoomChanged"/>
    </Grid>
</UserControl>

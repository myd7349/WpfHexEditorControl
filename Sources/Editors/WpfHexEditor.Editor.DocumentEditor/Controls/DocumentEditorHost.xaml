<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentEditorHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:docSvc="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Services"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Controls"
             Background="{DynamicResource DE_TextPaneBackground}"
             Foreground="{DynamicResource DE_TextPaneForeground}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <docSvc:DocumentEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>

        <!-- Design-time fallbacks -->
        <SolidColorBrush x:Key="DE_TextPaneBackground_Fallback"  Color="#1E1E1E"/>
        <SolidColorBrush x:Key="DE_TextPaneForeground_Fallback"  Color="#D4D4D4"/>

        <!-- Toolbar toggle-button style (radio-like, checked = active) -->
        <Style x:Key="DocViewToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding"      Value="7,4"/>
            <Setter Property="Height"       Value="26"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Plain action button style (save, export, metadata) -->
        <Style x:Key="DocActionButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding"      Value="7,4"/>
            <Setter Property="Height"       Value="26"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar separator -->
        <Style x:Key="DocToolbarSeparatorStyle" TargetType="Separator">
            <Setter Property="Width"          Value="1"/>
            <Setter Property="Margin"         Value="4,4"/>
            <Setter Property="Background"     Value="{DynamicResource DE_ToolbarBorderBrush}"/>
        </Style>
            </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="PART_ToolbarRow"    Height="Auto"/>  <!-- Row 0: Toolbar -->
            <RowDefinition x:Name="PART_BreadcrumbRow" Height="Auto"/>  <!-- Row 1: Breadcrumb bar -->
            <RowDefinition                              Height="*"/>     <!-- Row 2: Content panes -->
            <RowDefinition x:Name="PART_MiniMapRow"    Height="0"/>     <!-- Row 3: unused (MiniMap moved to right column) -->
            <RowDefinition x:Name="PART_StatusBarRow"  Height="Auto"/>  <!-- Row 4: Status bar -->
        </Grid.RowDefinitions>

        <!-- ══ Row 0: Toolbar ═════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource DE_ToolbarBackground}"
                BorderBrush="{DynamicResource DE_ToolbarBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="4,2" LastChildFill="False">
                <DockPanel.Resources>
                    <!-- Toolbar buttons must not steal focus from the document renderer -->
                    <Style TargetType="Button"       BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Focusable" Value="False"/>
                    </Style>
                    <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                        <Setter Property="Focusable" Value="False"/>
                    </Style>
                </DockPanel.Resources>

                <!-- Group 1 — View mode (radio-like toggles) -->
                <ToggleButton x:Name="PART_TextModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              ToolTip="{StaticResource DocEditorHost_TextViewToolTip}"
                              Click="OnTextModeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{StaticResource DocEditorHost_LabelText}" FontSize="12" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="PART_StructModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="{StaticResource DocEditorHost_StructureViewToolTip}"
                              Click="OnStructureModeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C9;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{StaticResource DocEditorHost_LabelStructure}" FontSize="12" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="PART_FocusModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="{StaticResource DocEditorHost_FocusModeToolTip}"
                              Click="OnFocusModeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8D4;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{StaticResource DocEditorHost_LabelFocus}" FontSize="12" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 1b — Render mode (Page / Draft / Outline) -->
                <ToggleButton x:Name="PART_PageModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="{StaticResource DocEditorHost_PageViewToolTip}"
                              Click="OnPageModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A8;" FontSize="13" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_DraftModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="{StaticResource DocEditorHost_DraftViewToolTip}"
                              Click="OnDraftModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E9;" FontSize="13" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_OutlineModeBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              ToolTip="{StaticResource DocEditorHost_OutlineViewToolTip}"
                              Click="OnOutlineModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F1;" FontSize="13" VerticalAlignment="Center"/>
                </ToggleButton>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 2 — Forensic mode -->
                <ToggleButton x:Name="PART_ForensicBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              ToolTip="{StaticResource DocEditorHost_ForensicModeToolTip}"
                              Click="OnForensicModeClicked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C3;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{StaticResource DocEditorHost_LabelForensic}" FontSize="12" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 5 — Text formatting (Phase 14) -->
                <ToggleButton x:Name="PART_BoldBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              Focusable="False"
                              ToolTip="{StaticResource DocEditorHost_BoldToolTip}"
                              Click="OnBoldClicked">
                    <TextBlock FontFamily="Segoe UI" Text="B" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_ItalicBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              Focusable="False"
                              ToolTip="{StaticResource DocEditorHost_ItalicToolTip}"
                              Click="OnItalicClicked">
                    <TextBlock FontFamily="Segoe UI" Text="I" FontSize="13" FontStyle="Italic" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_UnderlineBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              Focusable="False"
                              ToolTip="{StaticResource DocEditorHost_UnderlineToolTip}"
                              Click="OnUnderlineClicked">
                    <TextBlock FontFamily="Segoe UI" Text="U" FontSize="13"
                               TextDecorations="Underline" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_StrikethroughBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              Focusable="False"
                              ToolTip="{StaticResource DocEditorHost_StrikethroughToolTip}"
                              Click="OnStrikethroughClicked">
                    <TextBlock FontFamily="Segoe UI" Text="S" FontSize="13"
                               TextDecorations="Strikethrough" VerticalAlignment="Center"/>
                </ToggleButton>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 5b — Font family (Wave F) -->
                <ComboBox x:Name="PART_FontFamilyDropdown"
                          DockPanel.Dock="Left"
                          Width="130"
                          Height="22"
                          FontSize="11"
                          Margin="2,0"
                          IsEditable="True"
                          ToolTip="{StaticResource DocEditorHost_FontFamilyToolTip}"
                          SelectionChanged="OnFontFamilyChanged"
                          KeyDown="OnFontFamilyKeyDown"
                          LostFocus="OnFontFamilyLostFocus">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="{Binding}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Group 5c — Font size (Wave F) -->
                <ComboBox x:Name="PART_FontSizeDropdown"
                          DockPanel.Dock="Left"
                          Width="56"
                          Height="22"
                          FontSize="11"
                          Margin="2,0"
                          IsEditable="True"
                          ToolTip="{StaticResource DocEditorHost_FontSizeToolTip}"
                          SelectionChanged="OnFontSizeChanged"
                          LostFocus="OnFontSizeCommit">
                    <ComboBoxItem Content="8"  Tag="8"/>
                    <ComboBoxItem Content="9"  Tag="9"/>
                    <ComboBoxItem Content="10" Tag="10"/>
                    <ComboBoxItem Content="11" Tag="11"/>
                    <ComboBoxItem Content="12" Tag="12" IsSelected="True"/>
                    <ComboBoxItem Content="14" Tag="14"/>
                    <ComboBoxItem Content="16" Tag="16"/>
                    <ComboBoxItem Content="18" Tag="18"/>
                    <ComboBoxItem Content="20" Tag="20"/>
                    <ComboBoxItem Content="24" Tag="24"/>
                    <ComboBoxItem Content="28" Tag="28"/>
                    <ComboBoxItem Content="36" Tag="36"/>
                    <ComboBoxItem Content="48" Tag="48"/>
                    <ComboBoxItem Content="72" Tag="72"/>
                </ComboBox>

                <!-- Group 5d — Text color (Wave F) -->
                <Button x:Name="PART_TextColorBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_TextColorToolTip}"
                        Click="OnTextColorBtnClicked">
                    <Grid Width="18" Height="18">
                        <TextBlock Text="A" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Rectangle x:Name="PART_ColorStripe"
                                   Height="3"
                                   VerticalAlignment="Bottom"
                                   Fill="#FF0000"
                                   Margin="0,0,0,1"/>
                    </Grid>
                </Button>

                <Popup x:Name="PART_ColorPickerPopup"
                       PlacementTarget="{Binding ElementName=PART_TextColorBtn}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource DockBackgroundBrush}"
                            BorderBrush="{DynamicResource DockBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="6">
                        <UniformGrid x:Name="PART_ColorSwatches"
                                     Columns="8"
                                     Rows="2"
                                     Width="136"
                                     Height="34"/>
                    </Border>
                </Popup>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 6 — Paragraph formatting (Phase 15) -->
                <ComboBox x:Name="PART_StyleDropdown"
                          DockPanel.Dock="Left"
                          Width="80"
                          Height="22"
                          FontSize="11"
                          Margin="2,0"
                          SelectionChanged="OnStyleDropdownChanged"
                          ToolTip="{StaticResource DocEditorHost_StyleDropdownToolTip}">
                    <ComboBoxItem Content="{StaticResource DocEditorHost_StyleNormal}"  IsSelected="True"/>
                    <ComboBoxItem Content="{StaticResource DocEditorHost_StyleH1}"/>
                    <ComboBoxItem Content="{StaticResource DocEditorHost_StyleH2}"/>
                    <ComboBoxItem Content="{StaticResource DocEditorHost_StyleH3}"/>
                    <ComboBoxItem Content="{StaticResource DocEditorHost_StyleH4}"/>
                    <ComboBoxItem Content="{StaticResource DocEditorHost_StyleH5}"/>
                    <ComboBoxItem Content="{StaticResource DocEditorHost_StyleH6}"/>
                    <ComboBoxItem Content="{StaticResource DocEditorHost_StyleQuote}"/>
                    <ComboBoxItem Content="{StaticResource DocEditorHost_StyleCode}"/>
                </ComboBox>

                <Button x:Name="PART_AlignLeftBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_AlignLeftToolTip}"
                        Click="OnAlignLeftClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E4;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_AlignCenterBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_AlignCenterToolTip}"
                        Click="OnAlignCenterClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E3;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_AlignRightBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_AlignRightToolTip}"
                        Click="OnAlignRightClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E2;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_AlignJustifyBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_AlignJustifyToolTip}"
                        Click="OnAlignJustifyClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E5;" FontSize="13"/>
                </Button>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 6b — Lists and indentation -->
                <ToggleButton x:Name="PART_BulletListBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              Focusable="False"
                              ToolTip="{StaticResource DocEditorHost_BulletListToolTip}"
                              Click="OnBulletListClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FD;" FontSize="13"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_NumberedListBtn"
                              Style="{StaticResource DocViewToggleStyle}"
                              DockPanel.Dock="Left"
                              Margin="2,0,0,0"
                              Focusable="False"
                              ToolTip="{StaticResource DocEditorHost_NumberedListToolTip}"
                              Click="OnNumberedListClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FE;" FontSize="13"/>
                </ToggleButton>

                <Button x:Name="PART_IndentLessBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_IndentLessToolTip}"
                        Click="OnIndentLessClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FF;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_IndentMoreBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_IndentMoreToolTip}"
                        Click="OnIndentMoreClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE900;" FontSize="13"/>
                </Button>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 6c — Insert operations -->
                <Button x:Name="PART_InsertTableBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_InsertTableToolTip}"
                        Click="OnInsertTableClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D2;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_InsertHyperlinkBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_InsertHyperlinkToolTip}"
                        Click="OnInsertHyperlinkClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71B;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_InsertPageBreakBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_InsertPageBreakToolTip}"
                        Click="OnInsertPageBreakClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_PageStyleBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_PageStyleToolTip}"
                        Click="OnPageStyleClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C3;" FontSize="13"/>
                </Button>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 7 — Styles panel (Phase 18) -->
                <Button x:Name="PART_StylesBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        Focusable="False"
                        ToolTip="{StaticResource DocEditorHost_StylesPanelToolTip}"
                        Click="OnStylesBtnClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8EC;" FontSize="13"/>
                </Button>

                <Popup x:Name="PART_StylesPopup"
                       PlacementTarget="{Binding ElementName=PART_StylesBtn}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource DockBackgroundBrush}"
                            BorderBrush="{DynamicResource DockBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="4">
                        <local:DocumentStylesPanel x:Name="PART_StylesPanel"
                                                   StyleSelected="OnStylesPanelStyleSelected"/>
                    </Border>
                </Popup>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 3b — Page Setup -->
                <Button x:Name="PART_PageSetupBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="2,0,0,0"
                        ToolTip="{StaticResource DocEditorHost_PageSetupToolTip}"
                        Click="OnPageSetupBtnClick">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="13"/>
                </Button>

                <Popup x:Name="PART_PageSetupPopup"
                       PlacementTarget="{Binding ElementName=PART_PageSetupBtn}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <local:DocumentPageSettingsPanel
                        x:Name="PART_PageSettingsPanel"
                        SettingsApplied="OnPageSettingsApplied"
                        Cancelled="OnPageSettingsCancelled"/>
                </Popup>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Left"/>

                <!-- Group 3 — Zoom controls -->
                <Button x:Name="PART_ZoomOutBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Padding="6,4"
                        ToolTip="{StaticResource DocEditorHost_ZoomOutToolTip}"
                        Click="OnZoomOutClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71F;" FontSize="13"/>
                </Button>

                <TextBlock x:Name="PART_ZoomLabel"
                           DockPanel.Dock="Left"
                           Text="100%"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="4,0"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           MinWidth="38"
                           TextAlignment="Center"/>

                <Button x:Name="PART_ZoomInBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Left"
                        Padding="6,4"
                        ToolTip="{StaticResource DocEditorHost_ZoomInToolTip}"
                        Click="OnZoomInClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A3;" FontSize="13"/>
                </Button>

                <!-- Group 4 — Right-aligned actions -->
                <!-- Lock icon — visible only in read-only mode -->
                <TextBlock x:Name="PART_LockIcon"
                           DockPanel.Dock="Right"
                           FontFamily="Segoe MDL2 Assets"
                           Text="&#xE72E;"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Foreground="{DynamicResource DE_ForensicBadgeWarnBg}"
                           ToolTip="{StaticResource DocEditorHost_ReadOnlyToolTip}"
                           Visibility="Collapsed"/>

                <Button x:Name="PART_DiffBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Right"
                        Margin="0,0,2,0"
                        ToolTip="{StaticResource DocEditorHost_DiffToolTip}"
                        Click="OnDiffClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F5;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_EmbeddedBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Right"
                        Margin="0,0,2,0"
                        ToolTip="{StaticResource DocEditorHost_EmbeddedToolTip}"
                        Click="OnEmbeddedClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7B8;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_MetadataBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Right"
                        Margin="0,0,2,0"
                        ToolTip="{StaticResource DocEditorHost_MetadataToolTip}"
                        Click="OnMetadataClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="13"/>
                </Button>

                <Popup x:Name="PART_MetadataPopup"
                       PlacementTarget="{Binding ElementName=PART_MetadataBtn}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                            BorderThickness="1"
                            Padding="12"
                            MinWidth="260">
                        <Grid x:Name="PART_MetadataGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Row 0: Title -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource DocEditorHost_MetaTitle}" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="PART_Meta_Title" TextWrapping="Wrap"/>
                            <!-- Row 1: Author -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource DocEditorHost_MetaAuthor}" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="PART_Meta_Author" Margin="0,4,0,0"/>
                            <!-- Row 2: Format -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource DocEditorHost_MetaFormat}" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="PART_Meta_Format" Margin="0,4,0,0"/>
                            <!-- Row 3: MIME -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{StaticResource DocEditorHost_MetaMime}" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="PART_Meta_Mime" Margin="0,4,0,0"/>
                            <!-- Row 4: Created -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{StaticResource DocEditorHost_MetaCreated}" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" x:Name="PART_Meta_Created" Margin="0,4,0,0"/>
                            <!-- Row 5: Modified -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{StaticResource DocEditorHost_MetaModified}" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="5" Grid.Column="2" x:Name="PART_Meta_Modified" Margin="0,4,0,0"/>
                            <!-- Row 6: Macros badge -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{StaticResource DocEditorHost_MetaMacros}" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="6" Grid.Column="2" x:Name="PART_Meta_Macros" Margin="0,4,0,0"/>
                            <!-- Row 8: Anonymize action (forensic strip) -->
                            <Button Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3"
                                    x:Name="PART_AnonymizeBtn"
                                    Content="{StaticResource DocEditorHost_AnonymizeBtn}"
                                    ToolTip="{StaticResource DocEditorHost_AnonymizeToolTip}"
                                    HorizontalAlignment="Stretch"
                                    Padding="8,4"
                                    Click="OnAnonymizeClicked"/>
                        </Grid>
                    </Border>
                </Popup>

                <Button x:Name="PART_PrintBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Right"
                        Margin="0,0,2,0"
                        ToolTip="{StaticResource DocEditorHost_PrintToolTip}"
                        Click="OnPrintClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE749;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_ExportBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Right"
                        Margin="0,0,2,0"
                        ToolTip="{StaticResource DocEditorHost_ExportToolTip}"
                        Click="OnExportClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEDE1;" FontSize="13"/>
                </Button>

                <Button x:Name="PART_SaveBtn"
                        Style="{StaticResource DocActionButtonStyle}"
                        DockPanel.Dock="Right"
                        Margin="0,0,2,0"
                        ToolTip="{StaticResource DocEditorHost_SaveToolTip}"
                        Click="OnSaveClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;" FontSize="13"/>
                </Button>

                <Separator Style="{StaticResource DocToolbarSeparatorStyle}" DockPanel.Dock="Right"/>

            </DockPanel>
        </Border>

        <!-- ══ Row 1: Breadcrumb bar ══════════════════════════════════════════ -->
        <local:DocumentBreadcrumb x:Name="PART_Breadcrumb"
                                  Grid.Row="1"
                                  BlockSelected="OnBreadcrumbBlockSelected"/>

        <!-- ══ Row 2: Content grid (text + optional structure pane + minimap) ══ -->
        <Grid x:Name="PART_ContentGrid" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="PART_TextCol"      Width="*"/>
                <ColumnDefinition x:Name="PART_Splitter1Col" Width="0"/>
                <ColumnDefinition x:Name="PART_StructCol"    Width="0"/>
                <ColumnDefinition x:Name="PART_MiniMapCol"   Width="80"/>
            </Grid.ColumnDefinitions>

            <!-- Text pane (col 0) -->
            <local:DocumentTextPane x:Name="PART_TextPane"
                                    Grid.Column="0"
                                    SelectedBlockChanged="OnTextPaneSelectedBlockChanged"
                                    PopToolbarRequested="OnPopToolbarRequested"/>

            <!-- Splitter (col 1) — visible in Structure mode -->
            <GridSplitter x:Name="PART_Splitter1"
                          Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"
                          Visibility="Collapsed"/>

            <!-- Structure pane (col 2) — hidden unless Structure mode -->
            <local:DocumentStructurePane x:Name="PART_StructurePane"
                                         Grid.Column="2"
                                         Visibility="Collapsed"
                                         BlockNavigated="OnStructureBlockNavigated"/>

            <!-- MiniMap — vertical right panel (col 3) -->
            <local:DocumentMiniMap x:Name="PART_MiniMap"
                                   Grid.Column="3"
                                   ScrollRequested="OnMiniMapScrollRequested"/>

            <!-- Scroll-marker overlay — floats over the right edge of the text pane (col 0),
                 aligned to the vertical scrollbar track (17px wide). Click-through. -->
            <Border x:Name="PART_ScrollMarkerHost"
                    Grid.Column="0"
                    Width="17"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="False"
                    Panel.ZIndex="20"
                    Background="Transparent"/>

            <!-- Pop-toolbar popup (anchored to content grid) -->
            <Popup x:Name="PART_PopToolbar"
                   AllowsTransparency="True"
                   PlacementTarget="{Binding ElementName=PART_TextPane}"
                   Placement="RelativePoint"
                   StaysOpen="False"
                   PopupAnimation="Fade">
                <local:DocumentPopToolbar x:Name="PART_PopToolbarContent"
                                          FormatRequested="OnPopToolbarFormat"
                                          CopyTextRequested="OnPopToolbarCopyText"
                                          CopyHexRequested="OnPopToolbarCopyHex"
                                          InspectRequested="OnPopToolbarInspect"
                                          JumpHexRequested="OnPopToolbarJumpHex"/>
            </Popup>
        </Grid>

        <!-- MiniMap is in PART_ContentGrid col 3 (see below) -->

        <!-- ══ Row 4: Status bar ════════════════════════════════════════════════ -->
        <local:DocumentStatusBar x:Name="PART_StatusBar"
                                 Grid.Row="4"
                                 ForensicBadgeClicked="OnStatusBarForensicClicked"
                                 ZoomChanged="OnStatusBarZoomChanged"/>
    </Grid>
</UserControl>

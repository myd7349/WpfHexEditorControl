<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:docSvc="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Services"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Controls"
             Background="{DynamicResource DE_StatusBarBackground}"
             Height="22">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <docSvc:DocumentEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Thin vertical separator between status items -->
        <Style x:Key="StatusSepStyle" TargetType="Separator">
            <Setter Property="Width"      Value="1"/>
            <Setter Property="Margin"     Value="6,3"/>
            <Setter Property="Background" Value="{DynamicResource DE_StatusBarBorderBrush}"/>
        </Style>

        <!-- Status text block -->
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground"       Value="{DynamicResource DE_StatusBarForeground}"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Compact toggle button for view mode chips in status bar -->
        <Style x:Key="StatusViewToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource DE_StatusBarForeground}"/>
            <Setter Property="Padding"         Value="5,1"/>
            <Setter Property="Height"          Value="16"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Focusable"       Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
            </ResourceDictionary>
    </UserControl.Resources>

    <Border BorderBrush="{DynamicResource DE_StatusBarBorderBrush}"
            BorderThickness="0,1,0,0">
        <DockPanel Margin="6,0" LastChildFill="False">

            <!-- ── Left group ──────────────────────────────────────── -->

            <!-- Format chip (pill) -->
            <Border x:Name="PART_FormatChip"
                    DockPanel.Dock="Left"
                    CornerRadius="3"
                    Padding="6,2"
                    Margin="0,3,0,3"
                    Background="{DynamicResource DE_FormatChipBackground}"
                    ToolTip="{Binding FormatTooltip, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}">
                <TextBlock x:Name="PART_FormatText"
                           Text="{Binding FormatName, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"
                           Foreground="{DynamicResource DE_FormatChipForeground}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Border>

            <Separator Style="{StaticResource StatusSepStyle}" DockPanel.Dock="Left"/>

            <!-- Page X / Y -->
            <TextBlock x:Name="PART_PageText"
                       Style="{StaticResource StatusTextStyle}"
                       DockPanel.Dock="Left"
                       Text="{Binding PageText, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"
                       ToolTip="{StaticResource DocStatusBar_TooltipPageCount}"/>

            <Separator Style="{StaticResource StatusSepStyle}" DockPanel.Dock="Left"/>

            <!-- Word count -->
            <TextBlock x:Name="PART_WordText"
                       Style="{StaticResource StatusTextStyle}"
                       DockPanel.Dock="Left"
                       Text="{Binding WordCountText, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"
                       ToolTip="{StaticResource DocStatusBar_TooltipWordCount}"/>

            <!-- ── Right group ─────────────────────────────────────── -->

            <!-- Render mode chips (Page / Draft / Outline) -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,0">
                <ToggleButton x:Name="PART_SB_PageModeBtn"
                              Style="{StaticResource StatusViewToggleStyle}"
                              ToolTip="{StaticResource DocEditorHost_PageViewToolTip}"
                              Click="OnSBPageModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A8;" FontSize="11" VerticalAlignment="Center"/>
                </ToggleButton>
                <ToggleButton x:Name="PART_SB_DraftModeBtn"
                              Style="{StaticResource StatusViewToggleStyle}"
                              ToolTip="{StaticResource DocEditorHost_DraftViewToolTip}"
                              Click="OnSBDraftModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E9;" FontSize="11" VerticalAlignment="Center"/>
                </ToggleButton>
                <ToggleButton x:Name="PART_SB_OutlineModeBtn"
                              Style="{StaticResource StatusViewToggleStyle}"
                              ToolTip="{StaticResource DocEditorHost_OutlineViewToolTip}"
                              Click="OnSBOutlineModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F1;" FontSize="11" VerticalAlignment="Center"/>
                </ToggleButton>
            </StackPanel>

            <Separator Style="{StaticResource StatusSepStyle}" DockPanel.Dock="Right"/>

            <!-- View mode chips (Text / Structure / Focus) -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,0">
                <ToggleButton x:Name="PART_SB_TextModeBtn"
                              Style="{StaticResource StatusViewToggleStyle}"
                              ToolTip="{StaticResource DocEditorHost_TextViewToolTip}"
                              Click="OnSBTextModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="11" VerticalAlignment="Center"/>
                </ToggleButton>
                <ToggleButton x:Name="PART_SB_StructModeBtn"
                              Style="{StaticResource StatusViewToggleStyle}"
                              ToolTip="{StaticResource DocEditorHost_StructureViewToolTip}"
                              Click="OnSBStructModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C9;" FontSize="11" VerticalAlignment="Center"/>
                </ToggleButton>
                <ToggleButton x:Name="PART_SB_FocusModeBtn"
                              Style="{StaticResource StatusViewToggleStyle}"
                              ToolTip="{StaticResource DocEditorHost_FocusModeToolTip}"
                              Click="OnSBFocusModeClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8D4;" FontSize="11" VerticalAlignment="Center"/>
                </ToggleButton>
            </StackPanel>

            <Separator Style="{StaticResource StatusSepStyle}" DockPanel.Dock="Right"/>

            <!-- Zoom: slider + label -->
            <TextBlock x:Name="PART_ZoomText"
                       Style="{StaticResource StatusTextStyle}"
                       DockPanel.Dock="Right"
                       MinWidth="36"
                       TextAlignment="Right"
                       Text="{Binding ZoomText, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"/>

            <Slider x:Name="PART_ZoomSlider"
                    DockPanel.Dock="Right"
                    Width="80"
                    Minimum="50" Maximum="200"
                    Value="{Binding ZoomPercent, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}, Mode=TwoWay}"
                    VerticalAlignment="Center"
                    TickFrequency="10"
                    SmallChange="10"
                    LargeChange="25"
                    Margin="4,0"
                    ToolTip="{StaticResource DocStatusBar_TooltipZoomLevel}"
                    ValueChanged="OnSliderValueChanged">
                <Slider.Resources>
                    <Style TargetType="Thumb">
                        <Setter Property="Background" Value="{DynamicResource DE_ZoomSliderThumbBrush}"/>
                        <Setter Property="Width"  Value="10"/>
                        <Setter Property="Height" Value="10"/>
                    </Style>
                </Slider.Resources>
            </Slider>

            <Separator Style="{StaticResource StatusSepStyle}" DockPanel.Dock="Right"/>

            <!-- Forensic alert badge (red/orange pill, hidden if 0 alerts) -->
            <Border x:Name="PART_ForensicBadge"
                    DockPanel.Dock="Right"
                    CornerRadius="3"
                    Padding="5,2"
                    Margin="0,3,0,3"
                    Cursor="Hand"
                    ToolTip="{StaticResource DocStatusBar_TooltipForensicPanel}"
                    Background="{Binding ForensicBadgeBrush, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"
                    Visibility="{Binding HasForensicAlerts, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar},
                                 Converter={StaticResource BoolToVis}}"
                    MouseLeftButtonUp="OnForensicBadgeClicked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C3;"
                               FontSize="10" Foreground="White" VerticalAlignment="Center" Margin="0,0,3,0"/>
                    <TextBlock x:Name="PART_ForensicCount"
                               Text="{Binding ForensicAlertCount, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Separator Style="{StaticResource StatusSepStyle}" DockPanel.Dock="Right"/>

        </DockPanel>
    </Border>
</UserControl>

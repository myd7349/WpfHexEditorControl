<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Controls"
             Background="{DynamicResource DE_StatusBarBackground}"
             Height="22">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Thin vertical separator between status items -->
        <Style x:Key="StatusSepStyle" TargetType="Separator">
            <Setter Property="Width"      Value="1"/>
            <Setter Property="Margin"     Value="6,3"/>
            <Setter Property="Background" Value="{DynamicResource DE_StatusBarBorderBrush}"/>
        </Style>

        <!-- Status text block -->
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground"       Value="{DynamicResource DE_StatusBarForeground}"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="{DynamicResource DE_StatusBarBorderBrush}"
            BorderThickness="0,1,0,0">
        <DockPanel Margin="6,0" LastChildFill="False">

            <!-- ── Left group ──────────────────────────────────────── -->

            <!-- Format chip (pill) -->
            <Border x:Name="PART_FormatChip"
                    DockPanel.Dock="Left"
                    CornerRadius="3"
                    Padding="6,2"
                    Margin="0,3,0,3"
                    Background="{DynamicResource DE_FormatChipBackground}"
                    ToolTip="{Binding FormatTooltip, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}">
                <TextBlock x:Name="PART_FormatText"
                           Text="{Binding FormatName, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"
                           Foreground="{DynamicResource DE_FormatChipForeground}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Border>

            <Separator Style="{StaticResource StatusSepStyle}" DockPanel.Dock="Left"/>

            <!-- Page X / Y -->
            <TextBlock x:Name="PART_PageText"
                       Style="{StaticResource StatusTextStyle}"
                       DockPanel.Dock="Left"
                       Text="{Binding PageText, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"
                       ToolTip="Page count"/>

            <Separator Style="{StaticResource StatusSepStyle}" DockPanel.Dock="Left"/>

            <!-- Word count -->
            <TextBlock x:Name="PART_WordText"
                       Style="{StaticResource StatusTextStyle}"
                       DockPanel.Dock="Left"
                       Text="{Binding WordCountText, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"
                       ToolTip="Word count"/>

            <!-- ── Right group ─────────────────────────────────────── -->

            <!-- View mode label -->
            <TextBlock x:Name="PART_ViewModeText"
                       Style="{StaticResource StatusTextStyle}"
                       DockPanel.Dock="Right"
                       Margin="0,0,4,0"
                       Text="{Binding ViewModeText, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"/>

            <Separator Style="{StaticResource StatusSepStyle}" DockPanel.Dock="Right"/>

            <!-- Zoom: slider + label -->
            <TextBlock x:Name="PART_ZoomText"
                       Style="{StaticResource StatusTextStyle}"
                       DockPanel.Dock="Right"
                       MinWidth="36"
                       TextAlignment="Right"
                       Text="{Binding ZoomText, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"/>

            <Slider x:Name="PART_ZoomSlider"
                    DockPanel.Dock="Right"
                    Width="80"
                    Minimum="50" Maximum="200"
                    Value="{Binding ZoomPercent, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}, Mode=TwoWay}"
                    VerticalAlignment="Center"
                    TickFrequency="10"
                    SmallChange="10"
                    LargeChange="25"
                    Margin="4,0"
                    ToolTip="Zoom level"
                    ValueChanged="OnSliderValueChanged">
                <Slider.Resources>
                    <Style TargetType="Thumb">
                        <Setter Property="Background" Value="{DynamicResource DE_ZoomSliderThumbBrush}"/>
                        <Setter Property="Width"  Value="10"/>
                        <Setter Property="Height" Value="10"/>
                    </Style>
                </Slider.Resources>
            </Slider>

            <Separator Style="{StaticResource StatusSepStyle}" DockPanel.Dock="Right"/>

            <!-- Forensic alert badge (red/orange pill, hidden if 0 alerts) -->
            <Border x:Name="PART_ForensicBadge"
                    DockPanel.Dock="Right"
                    CornerRadius="3"
                    Padding="5,2"
                    Margin="0,3,0,3"
                    Cursor="Hand"
                    ToolTip="Click to open forensic panel"
                    Background="{Binding ForensicBadgeBrush, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"
                    Visibility="{Binding HasForensicAlerts, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar},
                                 Converter={StaticResource BoolToVis}}"
                    MouseLeftButtonUp="OnForensicBadgeClicked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C3;"
                               FontSize="10" Foreground="White" VerticalAlignment="Center" Margin="0,0,3,0"/>
                    <TextBlock x:Name="PART_ForensicCount"
                               Text="{Binding ForensicAlertCount, RelativeSource={RelativeSource AncestorType=local:DocumentStatusBar}}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Separator Style="{StaticResource StatusSepStyle}" DockPanel.Dock="Right"/>

        </DockPanel>
    </Border>
</UserControl>

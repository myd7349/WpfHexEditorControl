<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentPageSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="380">
    <UserControl.Resources>
        <!-- Panel background uses docking theme tokens -->
        <Style x:Key="PnlLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"      Value="0,0,6,0"/>
        </Style>
        <Style x:Key="PnlInput" TargetType="TextBox">
            <Setter Property="Width"       Value="54"/>
            <Setter Property="Height"      Value="22"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Padding"     Value="3,1"/>
            <Setter Property="Background"  Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="Margin"      Value="0,0,10,0"/>
        </Style>
        <Style x:Key="PnlCheck" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"      Value="0,4,0,0"/>
        </Style>
        <Style x:Key="PnlCombo" TargetType="ComboBox">
            <Setter Property="Height"      Value="22"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,0,10,0"/>
        </Style>
        <Style x:Key="PnlGroupLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,10,0,4"/>
        </Style>
        <Style x:Key="PnlSepLine" TargetType="Separator">
            <Setter Property="Background"  Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="Height"      Value="1"/>
            <Setter Property="Margin"      Value="0,4,0,6"/>
        </Style>
        <Style x:Key="ColToggleBtn" TargetType="ToggleButton">
            <Setter Property="Width"  Value="30"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DE_ToolbarButtonActiveBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height"    Value="24"/>
            <Setter Property="MinWidth"  Value="70"/>
            <Setter Property="FontSize"  Value="12"/>
            <Setter Property="Padding"   Value="12,2"/>
            <Setter Property="Cursor"    Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource DockBackgroundBrush}"
            BorderBrush="{DynamicResource DockBorderBrush}"
            BorderThickness="1"
            CornerRadius="3"
            Padding="12,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- TabControl -->
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>   <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- ── Tabs ─────────────────────────────────────────────────────── -->
            <TabControl Grid.Row="0"
                        x:Name="PART_Tabs"
                        Background="Transparent"
                        BorderBrush="{DynamicResource DockBorderBrush}"
                        FontSize="12">

                <!-- ── Tab: Page ──────────────────────────────────────────── -->
                <TabItem Header="Page">
                    <StackPanel Margin="4,8,4,4">

                        <!-- Paper format -->
                        <TextBlock Style="{StaticResource PnlGroupLabel}" Text="Paper format"/>
                        <WrapPanel>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="Format:"/>
                            <ComboBox x:Name="PART_PageSizeCombo"
                                      Style="{StaticResource PnlCombo}"
                                      Width="160"
                                      SelectionChanged="OnPageSizeChanged">
                                <ComboBoxItem Content="A4  (21 × 29.7 cm)"    Tag="A4"/>
                                <ComboBoxItem Content="A3  (29.7 × 42 cm)"    Tag="A3"/>
                                <ComboBoxItem Content="A5  (14.8 × 21 cm)"    Tag="A5"/>
                                <ComboBoxItem Content="Letter (8.5 × 11 in)"  Tag="Letter"/>
                                <ComboBoxItem Content="Legal  (8.5 × 14 in)"  Tag="Legal"/>
                                <ComboBoxItem Content="Custom"                Tag="Custom"/>
                            </ComboBox>
                        </WrapPanel>

                        <!-- Orientation -->
                        <WrapPanel Margin="0,6,0,0">
                            <TextBlock Style="{StaticResource PnlLabel}" Text="Orientation:"/>
                            <RadioButton x:Name="PART_PortraitRadio"
                                         Content="Portrait"
                                         IsChecked="True"
                                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                                         FontSize="12"
                                         Margin="0,0,12,0"
                                         VerticalAlignment="Center"/>
                            <RadioButton x:Name="PART_LandscapeRadio"
                                         Content="Landscape"
                                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                                         FontSize="12"
                                         VerticalAlignment="Center"/>
                        </WrapPanel>

                        <!-- Custom size (visible only when Custom selected) -->
                        <WrapPanel x:Name="PART_CustomSizeRow" Visibility="Collapsed" Margin="0,6,0,0">
                            <TextBlock Style="{StaticResource PnlLabel}" Text="Width (px):"/>
                            <TextBox x:Name="PART_CustomWidthBox"  Style="{StaticResource PnlInput}" Text="794"/>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="Height (px):"/>
                            <TextBox x:Name="PART_CustomHeightBox" Style="{StaticResource PnlInput}" Text="1122"/>
                        </WrapPanel>

                        <Separator Style="{StaticResource PnlSepLine}"/>

                        <!-- Margins -->
                        <TextBlock Style="{StaticResource PnlGroupLabel}" Text="Margins (px)"/>
                        <WrapPanel>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="Top:"/>
                            <TextBox x:Name="PART_MarginTopBox"    Style="{StaticResource PnlInput}" Text="40"/>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="Bottom:"/>
                            <TextBox x:Name="PART_MarginBottomBox" Style="{StaticResource PnlInput}" Text="56"/>
                        </WrapPanel>
                        <WrapPanel Margin="0,4,0,0">
                            <TextBlock x:Name="PART_MarginLeftLabel"  Style="{StaticResource PnlLabel}" Text="Left:"/>
                            <TextBox x:Name="PART_MarginLeftBox"      Style="{StaticResource PnlInput}" Text="56"/>
                            <TextBlock x:Name="PART_MarginRightLabel" Style="{StaticResource PnlLabel}" Text="Right:"/>
                            <TextBox x:Name="PART_MarginRightBox"     Style="{StaticResource PnlInput}" Text="56"/>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="Gutter:"/>
                            <TextBox x:Name="PART_MarginGutterBox"    Style="{StaticResource PnlInput}" Text="0"/>
                        </WrapPanel>
                        <CheckBox x:Name="PART_MirrorMarginsCheck"
                                  Style="{StaticResource PnlCheck}"
                                  Content="Mirror margins (inside/outside)"
                                  Checked="OnMirrorMarginsChanged"
                                  Unchecked="OnMirrorMarginsChanged"/>
                    </StackPanel>
                </TabItem>

                <!-- ── Tab: Columns ────────────────────────────────────────── -->
                <TabItem Header="Columns">
                    <StackPanel Margin="4,8,4,4">
                        <TextBlock Style="{StaticResource PnlGroupLabel}" Text="Number of columns"/>
                        <WrapPanel>
                            <ToggleButton x:Name="PART_Col1Btn" Style="{StaticResource ColToggleBtn}"
                                          Content="1" IsChecked="True" Click="OnColumnCountClicked" Tag="1"/>
                            <ToggleButton x:Name="PART_Col2Btn" Style="{StaticResource ColToggleBtn}"
                                          Content="2" Click="OnColumnCountClicked" Tag="2"/>
                            <ToggleButton x:Name="PART_Col3Btn" Style="{StaticResource ColToggleBtn}"
                                          Content="3" Click="OnColumnCountClicked" Tag="3"/>
                            <ToggleButton x:Name="PART_Col4Btn" Style="{StaticResource ColToggleBtn}"
                                          Content="4" Click="OnColumnCountClicked" Tag="4"/>
                            <ToggleButton x:Name="PART_Col5Btn" Style="{StaticResource ColToggleBtn}"
                                          Content="5" Click="OnColumnCountClicked" Tag="5"/>
                        </WrapPanel>

                        <Separator Style="{StaticResource PnlSepLine}"/>

                        <CheckBox x:Name="PART_EqualColWidthsCheck"
                                  Style="{StaticResource PnlCheck}"
                                  Content="Equal column widths"
                                  IsChecked="True"/>

                        <WrapPanel Margin="0,8,0,0">
                            <TextBlock Style="{StaticResource PnlLabel}" Text="Column spacing (px):"/>
                            <TextBox x:Name="PART_ColGapBox" Style="{StaticResource PnlInput}" Text="20"/>
                        </WrapPanel>

                        <CheckBox x:Name="PART_ColSeparatorCheck"
                                  Style="{StaticResource PnlCheck}"
                                  Content="Show separator line between columns"/>
                    </StackPanel>
                </TabItem>

                <!-- ── Tab: Header / Footer ────────────────────────────────── -->
                <TabItem Header="Header/Footer">
                    <StackPanel Margin="4,8,4,4">

                        <!-- Header group -->
                        <GroupBox Header="Header"
                                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                                  BorderBrush="{DynamicResource DockBorderBrush}"
                                  Padding="8,4">
                            <StackPanel>
                                <CheckBox x:Name="PART_HeaderEnabledCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="Enable header"
                                          Checked="OnHeaderEnabledChanged"
                                          Unchecked="OnHeaderEnabledChanged"/>
                                <WrapPanel x:Name="PART_HeaderOptionsRow" IsEnabled="False" Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource PnlLabel}" Text="Height (px):"/>
                                    <TextBox x:Name="PART_HeaderHeightBox"  Style="{StaticResource PnlInput}" Text="38"/>
                                    <TextBlock Style="{StaticResource PnlLabel}" Text="Margin (px):"/>
                                    <TextBox x:Name="PART_HeaderMarginBox"  Style="{StaticResource PnlInput}" Text="10"/>
                                </WrapPanel>
                                <CheckBox x:Name="PART_HeaderDiffFirstCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="Different content on first page"
                                          IsEnabled="False"/>
                                <CheckBox x:Name="PART_HeaderSameLRCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="Same header on left/right pages"
                                          IsChecked="True"
                                          IsEnabled="False"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Footer group -->
                        <GroupBox Header="Footer"
                                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                                  BorderBrush="{DynamicResource DockBorderBrush}"
                                  Padding="8,4"
                                  Margin="0,8,0,0">
                            <StackPanel>
                                <CheckBox x:Name="PART_FooterEnabledCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="Enable footer"
                                          Checked="OnFooterEnabledChanged"
                                          Unchecked="OnFooterEnabledChanged"/>
                                <WrapPanel x:Name="PART_FooterOptionsRow" IsEnabled="False" Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource PnlLabel}" Text="Height (px):"/>
                                    <TextBox x:Name="PART_FooterHeightBox"  Style="{StaticResource PnlInput}" Text="38"/>
                                    <TextBlock Style="{StaticResource PnlLabel}" Text="Margin (px):"/>
                                    <TextBox x:Name="PART_FooterMarginBox"  Style="{StaticResource PnlInput}" Text="10"/>
                                </WrapPanel>
                                <CheckBox x:Name="PART_FooterDiffFirstCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="Different content on first page"
                                          IsEnabled="False"/>
                                <CheckBox x:Name="PART_FooterSameLRCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="Same footer on left/right pages"
                                          IsChecked="True"
                                          IsEnabled="False"/>
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </TabItem>

                <!-- ── Tab: Border ─────────────────────────────────────────── -->
                <TabItem Header="Border">
                    <StackPanel Margin="4,8,4,4">
                        <TextBlock Style="{StaticResource PnlGroupLabel}" Text="Page border style"/>
                        <StackPanel>
                            <RadioButton x:Name="PART_BorderNoneRadio"
                                         Content="None"
                                         IsChecked="True"
                                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                                         FontSize="12" Margin="0,2"/>
                            <RadioButton x:Name="PART_BorderBoxRadio"
                                         Content="Box"
                                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                                         FontSize="12" Margin="0,2"/>
                            <RadioButton x:Name="PART_BorderShadowRadio"
                                         Content="Shadow"
                                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                                         FontSize="12" Margin="0,2"/>
                        </StackPanel>

                        <Separator Style="{StaticResource PnlSepLine}"/>

                        <WrapPanel Margin="0,4,0,0">
                            <TextBlock Style="{StaticResource PnlLabel}" Text="Color (hex):"/>
                            <TextBox x:Name="PART_BorderColorBox"
                                     Style="{StaticResource PnlInput}"
                                     Width="80"
                                     Text="#000000"/>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="Width (px):"/>
                            <TextBox x:Name="PART_BorderWidthBox"
                                     Style="{StaticResource PnlInput}"
                                     Text="1"/>
                        </WrapPanel>
                        <WrapPanel Margin="0,4,0,0">
                            <TextBlock Style="{StaticResource PnlLabel}" Text="Distance from text (px):"/>
                            <TextBox x:Name="PART_BorderPaddingBox"
                                     Style="{StaticResource PnlInput}"
                                     Text="8"/>
                        </WrapPanel>
                    </StackPanel>
                </TabItem>

            </TabControl>

            <!-- ── Action buttons ─────────────────────────────────────────────── -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="PART_CancelBtn"
                        Style="{StaticResource ActionBtn}"
                        Content="Cancel"
                        Click="OnCancelClicked"
                        Margin="0,0,8,0"/>
                <Button x:Name="PART_ApplyBtn"
                        Style="{StaticResource ActionBtn}"
                        Content="Apply"
                        Click="OnApplyClicked"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

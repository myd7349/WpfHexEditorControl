<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentPageSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:docSvc="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Services"
             Width="380">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <docSvc:DocumentEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>

        <!-- Panel background uses docking theme tokens -->
        <Style x:Key="PnlLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"      Value="0,0,6,0"/>
        </Style>
        <Style x:Key="PnlInput" TargetType="TextBox">
            <Setter Property="Width"       Value="54"/>
            <Setter Property="Height"      Value="22"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Padding"     Value="3,1"/>
            <Setter Property="Background"  Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="Margin"      Value="0,0,10,0"/>
        </Style>
        <Style x:Key="PnlCheck" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"      Value="0,4,0,0"/>
        </Style>
        <Style x:Key="PnlCombo" TargetType="ComboBox">
            <Setter Property="Height"      Value="22"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,0,10,0"/>
        </Style>
        <Style x:Key="PnlGroupLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,10,0,4"/>
        </Style>
        <Style x:Key="PnlSepLine" TargetType="Separator">
            <Setter Property="Background"  Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="Height"      Value="1"/>
            <Setter Property="Margin"      Value="0,4,0,6"/>
        </Style>
        <Style x:Key="ColToggleBtn" TargetType="ToggleButton">
            <Setter Property="Width"  Value="30"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DE_ToolbarButtonActiveBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height"    Value="24"/>
            <Setter Property="MinWidth"  Value="70"/>
            <Setter Property="FontSize"  Value="12"/>
            <Setter Property="Padding"   Value="12,2"/>
            <Setter Property="Cursor"    Value="Hand"/>
        </Style>
            </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource DockBackgroundBrush}"
            BorderBrush="{DynamicResource DockBorderBrush}"
            BorderThickness="1"
            CornerRadius="3"
            Padding="12,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- TabControl -->
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>   <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- ── Tabs ─────────────────────────────────────────────────────── -->
            <TabControl Grid.Row="0"
                        x:Name="PART_Tabs"
                        Background="Transparent"
                        BorderBrush="{DynamicResource DockBorderBrush}"
                        FontSize="12">

                <!-- ── Tab: Page ──────────────────────────────────────────── -->
                <TabItem Header="{StaticResource DocPageSettings_TabPage}">
                    <StackPanel Margin="4,8,4,4">

                        <!-- Paper format -->
                        <TextBlock Style="{StaticResource PnlGroupLabel}" Text="{StaticResource DocPageSettings_PaperFormat}"/>
                        <WrapPanel>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_FormatLabel}"/>
                            <ComboBox x:Name="PART_PageSizeCombo"
                                      Style="{StaticResource PnlCombo}"
                                      Width="160"
                                      SelectionChanged="OnPageSizeChanged">
                                <ComboBoxItem Content="{StaticResource DocPageSettings_SizeA4}"     Tag="A4"/>
                                <ComboBoxItem Content="{StaticResource DocPageSettings_SizeA3}"     Tag="A3"/>
                                <ComboBoxItem Content="{StaticResource DocPageSettings_SizeA5}"     Tag="A5"/>
                                <ComboBoxItem Content="{StaticResource DocPageSettings_SizeLetter}" Tag="Letter"/>
                                <ComboBoxItem Content="{StaticResource DocPageSettings_SizeLegal}"  Tag="Legal"/>
                                <ComboBoxItem Content="{StaticResource DocPageSettings_SizeCustom}" Tag="Custom"/>
                            </ComboBox>
                        </WrapPanel>

                        <!-- Orientation -->
                        <WrapPanel Margin="0,6,0,0">
                            <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_Orientation}"/>
                            <RadioButton x:Name="PART_PortraitRadio"
                                         Content="{StaticResource DocPageSettings_Portrait}"
                                         IsChecked="True"
                                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                                         FontSize="12"
                                         Margin="0,0,12,0"
                                         VerticalAlignment="Center"/>
                            <RadioButton x:Name="PART_LandscapeRadio"
                                         Content="{StaticResource DocPageSettings_Landscape}"
                                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                                         FontSize="12"
                                         VerticalAlignment="Center"/>
                        </WrapPanel>

                        <!-- Custom size (visible only when Custom selected) -->
                        <WrapPanel x:Name="PART_CustomSizeRow" Visibility="Collapsed" Margin="0,6,0,0">
                            <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_WidthPx}"/>
                            <TextBox x:Name="PART_CustomWidthBox"  Style="{StaticResource PnlInput}" Text="794"/>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_HeightPx}"/>
                            <TextBox x:Name="PART_CustomHeightBox" Style="{StaticResource PnlInput}" Text="1122"/>
                        </WrapPanel>

                        <Separator Style="{StaticResource PnlSepLine}"/>

                        <!-- Margins -->
                        <TextBlock Style="{StaticResource PnlGroupLabel}" Text="{StaticResource DocPageSettings_MarginsPx}"/>
                        <WrapPanel>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_Top}"/>
                            <TextBox x:Name="PART_MarginTopBox"    Style="{StaticResource PnlInput}" Text="40"/>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_Bottom}"/>
                            <TextBox x:Name="PART_MarginBottomBox" Style="{StaticResource PnlInput}" Text="56"/>
                        </WrapPanel>
                        <WrapPanel Margin="0,4,0,0">
                            <TextBlock x:Name="PART_MarginLeftLabel"  Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_Left}"/>
                            <TextBox x:Name="PART_MarginLeftBox"      Style="{StaticResource PnlInput}" Text="56"/>
                            <TextBlock x:Name="PART_MarginRightLabel" Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_Right}"/>
                            <TextBox x:Name="PART_MarginRightBox"     Style="{StaticResource PnlInput}" Text="56"/>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_Gutter}"/>
                            <TextBox x:Name="PART_MarginGutterBox"    Style="{StaticResource PnlInput}" Text="0"/>
                        </WrapPanel>
                        <CheckBox x:Name="PART_MirrorMarginsCheck"
                                  Style="{StaticResource PnlCheck}"
                                  Content="{StaticResource DocPageSettings_MirrorMargins}"
                                  Checked="OnMirrorMarginsChanged"
                                  Unchecked="OnMirrorMarginsChanged"/>
                    </StackPanel>
                </TabItem>

                <!-- ── Tab: Columns ────────────────────────────────────────── -->
                <TabItem Header="{StaticResource DocPageSettings_TabColumns}">
                    <StackPanel Margin="4,8,4,4">
                        <TextBlock Style="{StaticResource PnlGroupLabel}" Text="{StaticResource DocPageSettings_NumColumns}"/>
                        <WrapPanel>
                            <ToggleButton x:Name="PART_Col1Btn" Style="{StaticResource ColToggleBtn}"
                                          Content="1" IsChecked="True" Click="OnColumnCountClicked" Tag="1"/>
                            <ToggleButton x:Name="PART_Col2Btn" Style="{StaticResource ColToggleBtn}"
                                          Content="2" Click="OnColumnCountClicked" Tag="2"/>
                            <ToggleButton x:Name="PART_Col3Btn" Style="{StaticResource ColToggleBtn}"
                                          Content="3" Click="OnColumnCountClicked" Tag="3"/>
                            <ToggleButton x:Name="PART_Col4Btn" Style="{StaticResource ColToggleBtn}"
                                          Content="4" Click="OnColumnCountClicked" Tag="4"/>
                            <ToggleButton x:Name="PART_Col5Btn" Style="{StaticResource ColToggleBtn}"
                                          Content="5" Click="OnColumnCountClicked" Tag="5"/>
                        </WrapPanel>

                        <Separator Style="{StaticResource PnlSepLine}"/>

                        <CheckBox x:Name="PART_EqualColWidthsCheck"
                                  Style="{StaticResource PnlCheck}"
                                  Content="{StaticResource DocPageSettings_EqualColWidths}"
                                  IsChecked="True"/>

                        <WrapPanel Margin="0,8,0,0">
                            <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_ColSpacing}"/>
                            <TextBox x:Name="PART_ColGapBox" Style="{StaticResource PnlInput}" Text="20"/>
                        </WrapPanel>

                        <CheckBox x:Name="PART_ColSeparatorCheck"
                                  Style="{StaticResource PnlCheck}"
                                  Content="{StaticResource DocPageSettings_ShowSeparator}"/>
                    </StackPanel>
                </TabItem>

                <!-- ── Tab: Header / Footer ────────────────────────────────── -->
                <TabItem Header="{StaticResource DocPageSettings_TabHeaderFooter}">
                    <StackPanel Margin="4,8,4,4">

                        <!-- Header group -->
                        <GroupBox Header="{StaticResource DocPageSettings_GroupHeader}"
                                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                                  BorderBrush="{DynamicResource DockBorderBrush}"
                                  Padding="8,4">
                            <StackPanel>
                                <CheckBox x:Name="PART_HeaderEnabledCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="{StaticResource DocPageSettings_EnableHeader}"
                                          Checked="OnHeaderEnabledChanged"
                                          Unchecked="OnHeaderEnabledChanged"/>
                                <WrapPanel x:Name="PART_HeaderOptionsRow" IsEnabled="False" Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_HeightPx}"/>
                                    <TextBox x:Name="PART_HeaderHeightBox"  Style="{StaticResource PnlInput}" Text="38"/>
                                    <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_MarginPx}"/>
                                    <TextBox x:Name="PART_HeaderMarginBox"  Style="{StaticResource PnlInput}" Text="10"/>
                                </WrapPanel>
                                <CheckBox x:Name="PART_HeaderDiffFirstCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="{StaticResource DocPageSettings_DiffFirstPage}"
                                          IsEnabled="False"/>
                                <CheckBox x:Name="PART_HeaderSameLRCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="{StaticResource DocPageSettings_SameHeaderLR}"
                                          IsChecked="True"
                                          IsEnabled="False"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Footer group -->
                        <GroupBox Header="{StaticResource DocPageSettings_GroupFooter}"
                                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                                  BorderBrush="{DynamicResource DockBorderBrush}"
                                  Padding="8,4"
                                  Margin="0,8,0,0">
                            <StackPanel>
                                <CheckBox x:Name="PART_FooterEnabledCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="{StaticResource DocPageSettings_EnableFooter}"
                                          Checked="OnFooterEnabledChanged"
                                          Unchecked="OnFooterEnabledChanged"/>
                                <WrapPanel x:Name="PART_FooterOptionsRow" IsEnabled="False" Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_HeightPx}"/>
                                    <TextBox x:Name="PART_FooterHeightBox"  Style="{StaticResource PnlInput}" Text="38"/>
                                    <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_MarginPx}"/>
                                    <TextBox x:Name="PART_FooterMarginBox"  Style="{StaticResource PnlInput}" Text="10"/>
                                </WrapPanel>
                                <CheckBox x:Name="PART_FooterDiffFirstCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="{StaticResource DocPageSettings_DiffFirstPage}"
                                          IsEnabled="False"/>
                                <CheckBox x:Name="PART_FooterSameLRCheck"
                                          Style="{StaticResource PnlCheck}"
                                          Content="{StaticResource DocPageSettings_SameFooterLR}"
                                          IsChecked="True"
                                          IsEnabled="False"/>
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </TabItem>

                <!-- ── Tab: Border ─────────────────────────────────────────── -->
                <TabItem Header="{StaticResource DocPageSettings_TabBorder}">
                    <StackPanel Margin="4,8,4,4">
                        <TextBlock Style="{StaticResource PnlGroupLabel}" Text="{StaticResource DocPageSettings_BorderStyle}"/>
                        <StackPanel>
                            <RadioButton x:Name="PART_BorderNoneRadio"
                                         Content="{StaticResource DocPageSettings_BorderNone}"
                                         IsChecked="True"
                                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                                         FontSize="12" Margin="0,2"/>
                            <RadioButton x:Name="PART_BorderBoxRadio"
                                         Content="{StaticResource DocPageSettings_BorderBox}"
                                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                                         FontSize="12" Margin="0,2"/>
                            <RadioButton x:Name="PART_BorderShadowRadio"
                                         Content="{StaticResource DocPageSettings_BorderShadow}"
                                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                                         FontSize="12" Margin="0,2"/>
                        </StackPanel>

                        <Separator Style="{StaticResource PnlSepLine}"/>

                        <WrapPanel Margin="0,4,0,0">
                            <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_ColorHex}"/>
                            <TextBox x:Name="PART_BorderColorBox"
                                     Style="{StaticResource PnlInput}"
                                     Width="80"
                                     Text="#000000"/>
                            <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_WidthPx}"/>
                            <TextBox x:Name="PART_BorderWidthBox"
                                     Style="{StaticResource PnlInput}"
                                     Text="1"/>
                        </WrapPanel>
                        <WrapPanel Margin="0,4,0,0">
                            <TextBlock Style="{StaticResource PnlLabel}" Text="{StaticResource DocPageSettings_DistanceFromText}"/>
                            <TextBox x:Name="PART_BorderPaddingBox"
                                     Style="{StaticResource PnlInput}"
                                     Text="8"/>
                        </WrapPanel>
                    </StackPanel>
                </TabItem>

            </TabControl>

            <!-- ── Action buttons ─────────────────────────────────────────────── -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="PART_CancelBtn"
                        Style="{StaticResource ActionBtn}"
                        Content="{StaticResource DocPageSettings_Cancel}"
                        Click="OnCancelClicked"
                        Margin="0,0,8,0"/>
                <Button x:Name="PART_ApplyBtn"
                        Style="{StaticResource ActionBtn}"
                        Content="{StaticResource DocPageSettings_Apply}"
                        Click="OnApplyClicked"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

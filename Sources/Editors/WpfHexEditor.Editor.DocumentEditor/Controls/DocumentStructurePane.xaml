<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentStructurePane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:docSvc="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Services"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Controls"
             Background="{DynamicResource DockBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <docSvc:DocumentEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:ResourceKeyToBrushConverter x:Key="ResourceKeyToBrushConverter"/>

        <!-- Per-Kind chip backgrounds (semi-transparent so they read on any theme).
             Resolved by ResourceKeyToBrushConverter via DocumentBlockNode.KindBrushKey. -->
        <SolidColorBrush x:Key="DE_StructureChipHeadingBrush" Color="#5040A0FF"/>
        <SolidColorBrush x:Key="DE_StructureChipListBrush"    Color="#4040C060"/>
        <SolidColorBrush x:Key="DE_StructureChipTableBrush"   Color="#50FF8040"/>
        <SolidColorBrush x:Key="DE_StructureChipImageBrush"   Color="#50FFC040"/>
        <SolidColorBrush x:Key="DE_StructureChipLinkBrush"    Color="#5020C0C0"/>
        <SolidColorBrush x:Key="DE_StructureChipTagBrush"     Color="#50C0A0FF"/>
        <SolidColorBrush x:Key="DE_StructureChipDefaultBrush" Color="#30808080"/>

        <!-- Small icon button style -->
        <Style x:Key="StructToolBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="2"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SE_HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Same VS-style icon button look but for ToggleButton (a sibling of Button
             via ButtonBase, but the Button template above does not auto-apply to it). -->
        <Style x:Key="StructToolToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" CornerRadius="2"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SE_HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
            </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header + toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Search box -->
            <RowDefinition Height="*"/>     <!-- Tree -->
        </Grid.RowDefinitions>

        <!-- ── Header + toolbar ──────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource DockBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,3">
            <!-- LastChildFill=False so the rightmost docked button doesn't expand
                 to fill the remaining space (which made the Outline ToggleButton
                 squat the entire toolbar before this fix). -->
            <DockPanel LastChildFill="False">
                <!-- Title + block count -->
                <TextBlock x:Name="PART_Header"
                           DockPanel.Dock="Left"
                           Text="{StaticResource DocStructure_Header}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DE_StructureNodeFg}"/>

                <TextBlock x:Name="PART_CountLabel"
                           DockPanel.Dock="Left"
                           Margin="6,0,0,0"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Opacity="0.6"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>

                <!-- Right-side toolbar buttons. DockPanel docks them in declaration
                     order toward the right edge: the FIRST one ends up rightmost.
                     Order chosen so toggles (Outline / ShowRuns) sit next to the
                     count label, action buttons (Expand / Collapse) on the far right. -->
                <Button x:Name="PART_CollapseAllBtn"
                        Style="{StaticResource StructToolBtnStyle}"
                        DockPanel.Dock="Right"
                        ToolTip="{StaticResource DocStructure_CollapseAllToolTip}"
                        Click="OnCollapseAllClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70D;" FontSize="11"/>
                </Button>

                <Button x:Name="PART_ExpandAllBtn"
                        Style="{StaticResource StructToolBtnStyle}"
                        DockPanel.Dock="Right"
                        ToolTip="{StaticResource DocStructure_ExpandAllToolTip}"
                        Click="OnExpandAllClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70E;" FontSize="11"/>
                </Button>

                <Border DockPanel.Dock="Right"
                        Width="1"
                        Margin="3,3"
                        Background="{DynamicResource DockBorderBrush}"
                        Opacity="0.4"/>

                <ToggleButton x:Name="PART_OutlineBtn"
                              Style="{StaticResource StructToolToggleStyle}"
                              DockPanel.Dock="Right"
                              ToolTip="{StaticResource DocStructure_OutlineModeToolTip}"
                              Checked="OnOutlineModeToggled"
                              Unchecked="OnOutlineModeToggled">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71D;" FontSize="11"/>
                </ToggleButton>

                <ToggleButton x:Name="PART_ShowRunsBtn"
                              Style="{StaticResource StructToolToggleStyle}"
                              DockPanel.Dock="Right"
                              ToolTip="{StaticResource DocStructure_ShowRunsToggleToolTip}"
                              Checked="OnShowRunsToggled"
                              Unchecked="OnShowRunsToggled">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7BA;" FontSize="11"/>
                </ToggleButton>
            </DockPanel>
        </Border>

        <!-- ── Search box ────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource DockBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Kind filter (All / Headings / Lists / Tables / Images) -->
                <ComboBox x:Name="PART_KindFilter"
                          Grid.Column="0"
                          Width="100"
                          Height="22"
                          Margin="0,0,4,0"
                          FontSize="11"
                          Background="{DynamicResource DockBackgroundBrush}"
                          Foreground="{DynamicResource DockMenuForegroundBrush}"
                          BorderBrush="{DynamicResource DockBorderBrush}"
                          ToolTip="{StaticResource DocStructure_KindFilterToolTip}"
                          SelectionChanged="OnKindFilterChanged"
                          SelectedIndex="0">
                    <ComboBoxItem Tag="all"       Content="{StaticResource DocStructure_KindFilter_All}"/>
                    <ComboBoxItem Tag="heading"   Content="{StaticResource DocStructure_KindFilter_HeadingsOnly}"/>
                    <ComboBoxItem Tag="list-item" Content="{StaticResource DocStructure_KindFilter_ListsOnly}"/>
                    <ComboBoxItem Tag="table"     Content="{StaticResource DocStructure_KindFilter_TablesOnly}"/>
                    <ComboBoxItem Tag="image"     Content="{StaticResource DocStructure_KindFilter_ImagesOnly}"/>
                </ComboBox>

                <TextBox x:Name="PART_SearchBox"
                         Grid.Column="1"
                         Background="{DynamicResource DockBackgroundBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         CaretBrush="{DynamicResource DockMenuForegroundBrush}"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         Padding="4,2"
                         FontSize="12"
                         TextChanged="OnSearchTextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Resources>
                                <VisualBrush x:Key="HintBrush" Stretch="None" AlignmentX="Left">
                                    <VisualBrush.Visual>
                                        <TextBlock Text="{StaticResource DocStructure_FilterPlaceholder}"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                   Opacity="0.4"
                                                   FontSize="12"
                                                   Margin="5,2"/>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Style.Resources>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button x:Name="PART_ClearSearchBtn"
                        Grid.Column="2"
                        Style="{StaticResource StructToolBtnStyle}"
                        Width="20" Height="20"
                        Margin="2,0,0,0"
                        ToolTip="{StaticResource DocStructure_ClearFilterToolTip}"
                        Click="OnClearSearchClicked"
                        Visibility="{Binding Text.Length, ElementName=PART_SearchBox,
                                     Converter={StaticResource BoolToVis}}">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" FontSize="10"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── Structure tree ────────────────────────────────────────── -->
        <TreeView x:Name="PART_Tree"
                  Grid.Row="2"
                  Background="Transparent"
                  BorderThickness="0"
                  SelectedItemChanged="OnTreeSelectedItemChanged">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type local:DocumentBlockNode}"
                                          ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Forensic badge dot: shows the highest severity present on this
                             node OR any descendant, so a collapsed parent still surfaces a
                             buried alert. The tooltip falls back to the parent's own message
                             when no direct alert is set. -->
                        <Border x:Name="PART_ForensicBadge"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAggregateAlert, Converter={StaticResource BoolToVis}}"
                                Background="{Binding AggregateAlertBrushKey, Converter={StaticResource ResourceKeyToBrushConverter}}"
                                ToolTip="{Binding AlertMessage}"/>

                        <!-- Kind chip: semantic icon + 3-letter label, color-coded by Kind -->
                        <Border CornerRadius="2"
                                Padding="4,0,5,0"
                                Margin="0,0,4,0"
                                Background="{Binding KindBrushKey, Converter={StaticResource ResourceKeyToBrushConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding KindGlyph}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           Margin="0,0,3,0"
                                           Foreground="{DynamicResource DE_StructureKindFg}"/>
                                <TextBlock Text="{Binding KindLabel}"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource DE_StructureKindFg}"/>
                            </StackPanel>
                        </Border>

                        <!-- Text preview -->
                        <TextBlock Text="{Binding Preview}"
                                   Foreground="{DynamicResource DE_StructureNodeFg}"
                                   FontSize="12"/>

                        <!-- Offset badge: monospace + 8-digit hex so siblings align vertically -->
                        <TextBlock Text="{Binding OffsetText}"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   FontSize="10"
                                   Opacity="0.5"
                                   MinWidth="80"
                                   TextAlignment="Right"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}"/>
                    <Setter Property="Background"   Value="Transparent"/>
                    <Setter Property="IsExpanded"   Value="True"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource SE_HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource DE_SelectedBlockBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="PART_MenuNavigate"
                              Header="{StaticResource DocStructure_NavigateMenuHeader}"
                              Click="OnMenuNavigateClicked">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="PART_MenuJumpHex"
                              Header="{StaticResource DocStructure_JumpHexMenuHeader}"
                              Click="OnMenuJumpHexClicked">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C4;" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="PART_MenuCopyText"
                              Header="{StaticResource DocStructure_CopyTextMenuHeader}"
                              Click="OnMenuCopyTextClicked">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="PART_MenuCopyOffset"
                              Header="{StaticResource DocStructure_CopyOffsetMenuHeader}"
                              Click="OnMenuCopyOffsetClicked">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F4;" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>
    </Grid>
</UserControl>

<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentBreadcrumb"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Controls"
             Background="{DynamicResource DE_BreadcrumbBackground}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <!-- Hidden when no path segments -->
    <Border BorderBrush="{DynamicResource DE_ToolbarBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="6,3"
            Visibility="{Binding HasPath, RelativeSource={RelativeSource AncestorType=local:DocumentBreadcrumb},
                         Converter={StaticResource BoolToVis}}">
        <ItemsControl x:Name="PART_Items"
                      ItemsSource="{Binding Segments, RelativeSource={RelativeSource AncestorType=local:DocumentBreadcrumb}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type local:BreadcrumbSegment}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Segment button -->
                        <Border x:Name="SegBd"
                                CornerRadius="2"
                                Padding="4,1"
                                Cursor="Hand"
                                Background="Transparent"
                                MouseLeftButtonUp="OnSegmentClicked"
                                Tag="{Binding}">
                            <StackPanel Orientation="Horizontal">
                                <!-- Kind chip -->
                                <Border CornerRadius="2"
                                        Padding="3,0"
                                        Margin="0,0,4,0"
                                        Background="{DynamicResource DE_ToolbarButtonActiveBrush}">
                                    <TextBlock Text="{Binding KindLabel}"
                                               FontSize="10"
                                               Foreground="{DynamicResource DE_BreadcrumbForeground}"
                                               Opacity="0.8"/>
                                </Border>
                                <TextBlock Text="{Binding Label}"
                                           FontSize="12"
                                           Foreground="{DynamicResource DE_BreadcrumbForeground}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Chevron separator -->
                        <TextBlock Text="›"
                                   FontSize="14"
                                   Margin="2,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource DE_BreadcrumbSeparatorBrush}"
                                   Visibility="{Binding IsLast, Converter={StaticResource BoolToVis}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLast}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <DataTemplate.Triggers>
                        <Trigger SourceName="SegBd" Property="IsMouseOver" Value="True">
                            <Setter TargetName="SegBd" Property="Background"
                                    Value="{DynamicResource DE_BreadcrumbHoverBrush}"/>
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</UserControl>

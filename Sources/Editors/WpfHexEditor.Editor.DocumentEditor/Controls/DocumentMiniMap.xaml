<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentMiniMap"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="60"
             Background="{DynamicResource DE_MiniMapBg}">
    <!-- Two side-by-side DrawingVisual canvases rendered in code-behind -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>    <!-- text condensed lines -->
            <ColumnDefinition Width="4"/>    <!-- separator -->
            <ColumnDefinition Width="*"/>    <!-- binary block colors + entropy -->
        </Grid.ColumnDefinitions>

        <!-- Text strip (rendered via DrawingVisual) -->
        <Canvas x:Name="PART_TextStrip"  Grid.Column="0" ClipToBounds="True"/>

        <!-- Separator -->
        <Rectangle Grid.Column="1" Fill="{DynamicResource DockBorderBrush}"/>

        <!-- Binary strip (rendered via DrawingVisual) -->
        <Canvas x:Name="PART_BinaryStrip" Grid.Column="2" ClipToBounds="True"/>
    </Grid>
</UserControl>

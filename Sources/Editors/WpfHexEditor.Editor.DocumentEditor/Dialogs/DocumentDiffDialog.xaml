<ec:ThemedDialog x:Class="WpfHexEditor.Editor.DocumentEditor.Dialogs.DocumentDiffDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        xmlns:docSvc="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Services"
        Title="{DynamicResource DocDiffDlg_Title}"
        Width="900" Height="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}"
        Foreground="{DynamicResource DockMenuForegroundBrush}">
    <ec:ThemedDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <docSvc:DocumentEditorLocalizedDictionary/>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="DiffAddedBg"    Color="#3340C060"/>
            <SolidColorBrush x:Key="DiffRemovedBg"  Color="#33E04040"/>
            <SolidColorBrush x:Key="DiffModifiedBg" Color="#33FFC040"/>
        </ResourceDictionary>
    </ec:ThemedDialog.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F5;"
                       FontSize="18" VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="0,0,8,0"/>
            <TextBlock Text="{DynamicResource DocDiffDlg_Title}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
        </StackPanel>

        <!-- Left/Right path bar -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource DocDiffDlg_LabelLeft}"  FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" x:Name="PART_LeftPath"  TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="{DynamicResource DocDiffDlg_LabelRight}" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="6" x:Name="PART_RightPath" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
            <Button    Grid.Column="8" x:Name="PART_PickRightBtn"
                       Content="{DynamicResource DocDiffDlg_PickRight}" Padding="8,2"
                       Click="OnPickRightClicked"/>
        </Grid>

        <!-- Diff grid -->
        <ListView Grid.Row="4" x:Name="PART_List"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderBrush="{DynamicResource DockBorderBrush}"
                  BorderThickness="1">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Kind}" Value="Added">
                            <Setter Property="Background" Value="{StaticResource DiffAddedBg}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="Removed">
                            <Setter Property="Background" Value="{StaticResource DiffRemovedBg}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="Modified">
                            <Setter Property="Background" Value="{StaticResource DiffModifiedBg}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header=""                                       Width="24"  DisplayMemberBinding="{Binding KindGlyph}"/>
                    <GridViewColumn Header="{DynamicResource DocDiffDlg_ColKind}"   Width="100" DisplayMemberBinding="{Binding BlockKind}"/>
                    <GridViewColumn Header="{DynamicResource DocDiffDlg_ColChange}" Width="80"  DisplayMemberBinding="{Binding Kind}"/>
                    <GridViewColumn Header="{DynamicResource DocDiffDlg_ColText}"   Width="640" DisplayMemberBinding="{Binding Text}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Buttons -->
        <DockPanel Grid.Row="6">
            <TextBlock x:Name="PART_SummaryLabel"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Opacity="0.7"
                       FontSize="11"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <Button DockPanel.Dock="Right"
                    Content="{DynamicResource DocDiffDlg_Close}"
                    Width="80" IsCancel="True" IsDefault="True"
                    Click="OnCloseClicked"/>
        </DockPanel>
    </Grid>
</ec:ThemedDialog>

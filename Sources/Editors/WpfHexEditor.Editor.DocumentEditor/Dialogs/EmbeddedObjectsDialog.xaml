<ec:ThemedDialog x:Class="WpfHexEditor.Editor.DocumentEditor.Dialogs.EmbeddedObjectsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        xmlns:docSvc="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Services"
        Title="{DynamicResource EmbeddedDlg_Title}"
        Width="820" Height="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}"
        Foreground="{DynamicResource DockMenuForegroundBrush}">
    <ec:ThemedDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <docSvc:DocumentEditorLocalizedDictionary/>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ec:ThemedDialog.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>  <!-- source-file hash row -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7B8;"
                       FontSize="18" VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="0,0,8,0"/>
            <StackPanel>
                <TextBlock Text="{StaticResource EmbeddedDlg_Title}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <TextBlock x:Name="PART_Subtitle"
                           FontSize="11" Opacity="0.7"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- Source-file SHA-256 row (forensic provenance) -->
        <Border Grid.Row="2"
                Background="{DynamicResource DockBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{StaticResource EmbeddedDlg_SourceSha}"
                           FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <TextBlock Grid.Column="2" x:Name="PART_SourceSha"
                           FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <Button Grid.Column="4" x:Name="PART_CopyShaBtn"
                        Width="24" Height="22" Padding="0"
                        ToolTip="{StaticResource EmbeddedDlg_CopySha}"
                        Click="OnCopyShaClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- List of embeddings -->
        <ListView Grid.Row="4" x:Name="PART_List"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderBrush="{DynamicResource DockBorderBrush}"
                  BorderThickness="1"
                  MouseDoubleClick="OnItemDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{StaticResource EmbeddedDlg_ColKind}"   Width="80"  DisplayMemberBinding="{Binding Kind}"/>
                    <GridViewColumn Header="{StaticResource EmbeddedDlg_ColName}"   Width="180" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="{StaticResource EmbeddedDlg_ColSize}"   Width="80"  DisplayMemberBinding="{Binding SizeText}"/>
                    <GridViewColumn Header="{StaticResource EmbeddedDlg_ColSource}" Width="160" DisplayMemberBinding="{Binding Source}"/>
                    <GridViewColumn Header="SHA-256"                                 Width="260" DisplayMemberBinding="{Binding Sha256}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Buttons -->
        <DockPanel Grid.Row="6">
            <TextBlock x:Name="PART_CountLabel"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Opacity="0.7"
                       FontSize="11"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="PART_HashAllBtn"
                        Content="{StaticResource EmbeddedDlg_HashAll}"
                        Width="120" Margin="0,0,8,0"
                        ToolTip="{StaticResource EmbeddedDlg_HashAllToolTip}"
                        Click="OnHashAllClicked"/>
                <Button x:Name="PART_ExtractBtn"
                        Content="{StaticResource EmbeddedDlg_Extract}"
                        Width="120" Margin="0,0,8,0"
                        ToolTip="{StaticResource EmbeddedDlg_ExtractToolTip}"
                        Click="OnExtractClicked"/>
                <Button x:Name="PART_OpenHexBtn"
                        Content="{StaticResource EmbeddedDlg_OpenHex}"
                        Width="120" Margin="0,0,8,0"
                        ToolTip="{StaticResource EmbeddedDlg_OpenHexToolTip}"
                        Click="OnOpenInHexClicked"/>
                <Button Content="{StaticResource EmbeddedDlg_Close}"
                        Width="80" IsCancel="True" IsDefault="True"
                        Click="OnCloseClicked"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</ec:ThemedDialog>

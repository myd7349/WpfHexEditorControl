<ec:ThemedDialog x:Class="WpfHexEditor.Editor.DocumentEditor.Dialogs.EmbeddedObjectsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        xmlns:docSvc="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Services"
        Title="{DynamicResource EmbeddedDlg_Title}"
        Width="640" Height="440"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}"
        Foreground="{DynamicResource DockMenuForegroundBrush}">
    <ec:ThemedDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <docSvc:DocumentEditorLocalizedDictionary/>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ec:ThemedDialog.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7B8;"
                       FontSize="18" VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="0,0,8,0"/>
            <StackPanel>
                <TextBlock Text="{DynamicResource EmbeddedDlg_Title}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <TextBlock x:Name="PART_Subtitle"
                           FontSize="11" Opacity="0.7"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- List of embeddings -->
        <ListView Grid.Row="2" x:Name="PART_List"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderBrush="{DynamicResource DockBorderBrush}"
                  BorderThickness="1"
                  MouseDoubleClick="OnItemDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{DynamicResource EmbeddedDlg_ColKind}"   Width="100" DisplayMemberBinding="{Binding Kind}"/>
                    <GridViewColumn Header="{DynamicResource EmbeddedDlg_ColName}"   Width="220" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="{DynamicResource EmbeddedDlg_ColSize}"   Width="90"  DisplayMemberBinding="{Binding SizeText}"/>
                    <GridViewColumn Header="{DynamicResource EmbeddedDlg_ColSource}" Width="180" DisplayMemberBinding="{Binding Source}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Buttons -->
        <DockPanel Grid.Row="4">
            <TextBlock x:Name="PART_CountLabel"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Opacity="0.7"
                       FontSize="11"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="PART_ExtractBtn"
                        Content="{DynamicResource EmbeddedDlg_Extract}"
                        Width="120" Margin="0,0,8,0"
                        ToolTip="{DynamicResource EmbeddedDlg_ExtractToolTip}"
                        Click="OnExtractClicked"/>
                <Button x:Name="PART_OpenHexBtn"
                        Content="{DynamicResource EmbeddedDlg_OpenHex}"
                        Width="120" Margin="0,0,8,0"
                        ToolTip="{DynamicResource EmbeddedDlg_OpenHexToolTip}"
                        Click="OnOpenInHexClicked"/>
                <Button Content="{DynamicResource EmbeddedDlg_Close}"
                        Width="80" IsCancel="True" IsDefault="True"
                        Click="OnCloseClicked"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</ec:ThemedDialog>

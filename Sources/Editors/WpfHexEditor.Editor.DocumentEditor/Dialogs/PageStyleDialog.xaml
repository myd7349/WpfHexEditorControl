<Window x:Class="WpfHexEditor.Editor.DocumentEditor.Dialogs.PageStyleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:docSvc="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Services"
        Title="{DynamicResource PageStyleDlg_Title}"
        Width="480" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <docSvc:DocumentEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="SectionLabel" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="0,8,0,4"/>
            </Style>
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
            </Style>
            <Style x:Key="NumBox" TargetType="TextBox">
                <Setter Property="Width"  Value="70"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="8,8,8,0">

            <!-- ── Tab 1: Page ─────────────────────────────────────────────── -->
            <TabItem Header="{StaticResource PageStyleDlg_TabPage}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Style="{StaticResource SectionLabel}"
                                   Text="{StaticResource PageStyleDlg_PaperFormat}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                       Text="{StaticResource PageStyleDlg_Format}"/>
                            <ComboBox  Grid.Row="0" Grid.Column="2" x:Name="PART_PageFormat" Width="140"
                                       HorizontalAlignment="Left" SelectionChanged="OnPageFormatChanged">
                                <ComboBoxItem Tag="A4"     Content="A4"/>
                                <ComboBoxItem Tag="A3"     Content="A3"/>
                                <ComboBoxItem Tag="A5"     Content="A5"/>
                                <ComboBoxItem Tag="Letter" Content="Letter"/>
                                <ComboBoxItem Tag="Legal"  Content="Legal"/>
                                <ComboBoxItem Tag="Custom" Content="Custom"/>
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                       Text="{StaticResource PageStyleDlg_Orientation}"/>
                            <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                                <RadioButton x:Name="PART_Portrait"
                                             Content="{StaticResource PageStyleDlg_Portrait}"
                                             GroupName="Orientation" IsChecked="True" Margin="0,0,12,0"/>
                                <RadioButton x:Name="PART_Landscape"
                                             Content="{StaticResource PageStyleDlg_Landscape}"
                                             GroupName="Orientation"/>
                            </StackPanel>

                            <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}"
                                           Text="{StaticResource PageStyleDlg_Width}"/>
                                <TextBox   Grid.Column="2" x:Name="PART_PageWidth" Style="{StaticResource NumBox}"/>
                                <TextBlock Grid.Column="4" Style="{StaticResource FieldLabel}"
                                           Text="{StaticResource PageStyleDlg_Height}"/>
                                <TextBox   Grid.Column="6" x:Name="PART_PageHeight" Style="{StaticResource NumBox}"/>
                            </Grid>
                        </Grid>

                        <TextBlock Style="{StaticResource SectionLabel}"
                                   Text="{StaticResource PageStyleDlg_Margins}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                       Text="{StaticResource PageStyleDlg_MarginLeft}"/>
                            <TextBox   Grid.Row="0" Grid.Column="2" x:Name="PART_MarginLeft" Style="{StaticResource NumBox}"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Style="{StaticResource FieldLabel}"
                                       Text="{StaticResource PageStyleDlg_MarginRight}"/>
                            <TextBox   Grid.Row="0" Grid.Column="6" x:Name="PART_MarginRight" Style="{StaticResource NumBox}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                       Text="{StaticResource PageStyleDlg_MarginTop}"/>
                            <TextBox   Grid.Row="2" Grid.Column="2" x:Name="PART_MarginTop" Style="{StaticResource NumBox}"/>
                            <TextBlock Grid.Row="2" Grid.Column="4" Style="{StaticResource FieldLabel}"
                                       Text="{StaticResource PageStyleDlg_MarginBottom}"/>
                            <TextBox   Grid.Row="2" Grid.Column="6" x:Name="PART_MarginBottom" Style="{StaticResource NumBox}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Tab 2: Background ───────────────────────────────────────── -->
            <TabItem Header="{StaticResource PageStyleDlg_TabBackground}">
                <StackPanel Margin="12">
                    <TextBlock Style="{StaticResource SectionLabel}"
                               Text="{StaticResource PageStyleDlg_BgColor}"/>
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="PART_BgColorPreview"
                                Width="32" Height="24"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                Background="White"
                                Margin="0,0,8,0"/>
                        <Button Content="…" Width="30" Click="OnPickBgColorClicked"/>
                        <Button Content="✕" Width="30" Margin="4,0,0,0" Click="OnClearBgColorClicked"
                                ToolTip="Remove background color"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- ── Tab 3: Header ───────────────────────────────────────────── -->
            <TabItem Header="{StaticResource PageStyleDlg_TabHeader}">
                <StackPanel Margin="12">
                    <CheckBox x:Name="PART_HeaderEnabled"
                              Content="{StaticResource PageStyleDlg_EnableHeader}"
                              Margin="0,0,0,8"
                              Checked="OnHeaderEnabledChanged" Unchecked="OnHeaderEnabledChanged"/>
                    <Grid x:Name="PART_HeaderOptions" IsEnabled="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{StaticResource PageStyleDlg_HdrHeight}"/>
                        <TextBox   Grid.Row="0" Grid.Column="2" x:Name="PART_HdrHeight" Style="{StaticResource NumBox}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{StaticResource PageStyleDlg_HdrMargin}"/>
                        <TextBox   Grid.Row="2" Grid.Column="2" x:Name="PART_HdrMargin" Style="{StaticResource NumBox}"/>
                        <CheckBox  Grid.Row="4" Grid.ColumnSpan="3" x:Name="PART_HdrDiffFirst"
                                   Content="{StaticResource PageStyleDlg_HdrDiffFirst}"/>
                        <CheckBox  Grid.Row="6" Grid.ColumnSpan="3" x:Name="PART_HdrSameLR"
                                   Content="{StaticResource PageStyleDlg_HdrSameLR}"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- ── Tab 4: Footer ───────────────────────────────────────────── -->
            <TabItem Header="{StaticResource PageStyleDlg_TabFooter}">
                <StackPanel Margin="12">
                    <CheckBox x:Name="PART_FooterEnabled"
                              Content="{StaticResource PageStyleDlg_EnableFooter}"
                              Margin="0,0,0,8"
                              Checked="OnFooterEnabledChanged" Unchecked="OnFooterEnabledChanged"/>
                    <Grid x:Name="PART_FooterOptions" IsEnabled="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{StaticResource PageStyleDlg_HdrHeight}"/>
                        <TextBox   Grid.Row="0" Grid.Column="2" x:Name="PART_FtrHeight" Style="{StaticResource NumBox}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{StaticResource PageStyleDlg_HdrMargin}"/>
                        <TextBox   Grid.Row="2" Grid.Column="2" x:Name="PART_FtrMargin" Style="{StaticResource NumBox}"/>
                        <CheckBox  Grid.Row="4" Grid.ColumnSpan="3" x:Name="PART_FtrDiffFirst"
                                   Content="{StaticResource PageStyleDlg_HdrDiffFirst}"/>
                        <CheckBox  Grid.Row="6" Grid.ColumnSpan="3" x:Name="PART_FtrSameLR"
                                   Content="{StaticResource PageStyleDlg_HdrSameLR}"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- ── Tab 5: Border ───────────────────────────────────────────── -->
            <TabItem Header="{StaticResource PageStyleDlg_TabBorder}">
                <StackPanel Margin="12">
                    <TextBlock Style="{StaticResource SectionLabel}"
                               Text="{StaticResource PageStyleDlg_BorderStyle}"/>
                    <ComboBox x:Name="PART_BorderStyle" Width="140" HorizontalAlignment="Left">
                        <ComboBoxItem Tag="None"   Content="{StaticResource PageStyleDlg_BorderNone}"   IsSelected="True"/>
                        <ComboBoxItem Tag="Box"    Content="{StaticResource PageStyleDlg_BorderBox}"/>
                        <ComboBoxItem Tag="Shadow" Content="{StaticResource PageStyleDlg_BorderShadow}"/>
                    </ComboBox>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{StaticResource PageStyleDlg_BorderColor}"/>
                        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                            <Border x:Name="PART_BorderColorPreview"
                                    Width="32" Height="24"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                    Background="Black"
                                    Margin="0,0,8,0"/>
                            <Button Content="…" Width="30" Click="OnPickBorderColorClicked"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{StaticResource PageStyleDlg_BorderWidth}"/>
                        <TextBox   Grid.Row="2" Grid.Column="2" x:Name="PART_BorderWidth" Style="{StaticResource NumBox}"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- ── Tab 6: Columns ──────────────────────────────────────────── -->
            <TabItem Header="{StaticResource PageStyleDlg_TabColumns}">
                <StackPanel Margin="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{StaticResource PageStyleDlg_ColCount}"/>
                        <ComboBox  Grid.Row="0" Grid.Column="2" x:Name="PART_ColCount" Width="60"
                                   HorizontalAlignment="Left">
                            <ComboBoxItem Content="1" IsSelected="True"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="5"/>
                        </ComboBox>
                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                   Text="{StaticResource PageStyleDlg_ColGap}"/>
                        <TextBox   Grid.Row="2" Grid.Column="2" x:Name="PART_ColGap" Style="{StaticResource NumBox}"/>
                    </Grid>
                    <CheckBox x:Name="PART_ColSeparator"
                              Content="{StaticResource PageStyleDlg_ColSeparator}"
                              Margin="0,10,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Bottom button bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="8,8,8,8">
            <Button Content="{StaticResource PageStyleDlg_Apply}"
                    Width="80" Margin="0,0,8,0" Click="OnApplyClicked"/>
            <Button Content="{StaticResource PageStyleDlg_OK}"
                    Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnOkClicked"/>
            <Button Content="{StaticResource PageStyleDlg_Cancel}"
                    Width="80" IsCancel="True" Click="OnCancelClicked"/>
        </StackPanel>
    </Grid>
</Window>

<UserControl x:Class="WpfHexEditor.HexEditor.Controls.ProgressOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:pb="clr-namespace:WpfHexEditor.ProgressBar.Controls;assembly=WpfHexEditor.ProgressBar"
             xmlns:pbc="clr-namespace:WpfHexEditor.ProgressBar.Converters;assembly=WpfHexEditor.ProgressBar"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <!-- Semi-transparent backdrop -->
    <Border Background="#AA000000">
        <Border Background="{DynamicResource ProgressOverlay_DialogBackground}"
                CornerRadius="6"
                Padding="24"
                MaxWidth="450"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{DynamicResource ProgressOverlay_DialogBorder}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.4"/>
            </Border.Effect>

            <StackPanel>
                <!-- Operation Title -->
                <TextBlock Text="{Binding OperationTitle}"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="{DynamicResource ProgressOverlay_TitleForeground}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="13"
                           Foreground="{DynamicResource ProgressOverlay_TextForeground}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14"
                           MinHeight="18"/>

                <!-- Progress Bar -->
                <pb:LinearProgressBar
                    Progress="{Binding ProgressPercentage,
                               Converter={x:Static pbc:ValueToProgressConverter.Instance},
                               ConverterParameter=100}"
                    BarHeight="20"
                    Height="20"
                    Margin="0,0,0,8"
                    IsIndeterminate="{Binding IsIndeterminate}"
                    ShowPercentage="True"/>

                <!-- Progress Text -->
                <TextBlock Text="{Binding ProgressText}"
                           FontSize="12"
                           Foreground="{DynamicResource ProgressOverlay_TextForeground}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,14"/>

                <!-- Cancel Button -->
                <Button Content="{DynamicResource ProgressButtonCancel}"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibilityConverter}}"
                        Padding="20,6"
                        MinWidth="100"
                        HorizontalAlignment="Center"
                        Background="{DynamicResource ProgressOverlay_ButtonBackground}"
                        BorderBrush="{DynamicResource ProgressOverlay_ButtonBorder}"
                        Foreground="{DynamicResource ProgressOverlay_TitleForeground}"
                        BorderThickness="1">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ProgressOverlay_ButtonHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Border>
</UserControl>

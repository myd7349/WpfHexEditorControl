<ec:ThemedDialog x:Class="WpfHexEditor.HexEditor.Search.Views.FindReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pb="clr-namespace:WpfHexEditor.ProgressBar.Controls;assembly=WpfHexEditor.ProgressBar"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfHexEditor.HexEditor.Search.Views"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        xmlns:hexSvc="clr-namespace:WpfHexEditor.HexEditor.Services"
        mc:Ignorable="d"
        Title="{DynamicResource FindAndReplaceDialogTitle}" Height="400" Width="600"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <hexSvc:HexEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        <!-- Value Converters -->
        <local:SearchModeToVisibilityConverter x:Key="SearchModeToVisibilityConverter"/>
        <local:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Local derived brushes for theme adaptation -->
        <SolidColorBrush x:Key="LocalButtonBackgroundBrush" Color="{DynamicResource BackgroundColor}" Opacity="0.9"/>
        <SolidColorBrush x:Key="LocalButtonBorderBrush" Color="{DynamicResource BackgroundColor}" Opacity="0.5"/>
        <SolidColorBrush x:Key="LocalButtonHoverBrush" Color="{DynamicResource AccentColor}" Opacity="0.2"/>
        <SolidColorBrush x:Key="LocalButtonPressedBrush" Color="{DynamicResource AccentColor}" Opacity="0.4"/>

        <!-- Button style -->
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="{DynamicResource LocalButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LocalButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource LocalButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource LocalButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Find Section -->
        <GroupBox Grid.Row="0" Header="{StaticResource FindGroupHeader}" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Find input row -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource FindTextLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" VerticalContentAlignment="Center"
                         Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Text}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding FindNextCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding SearchHex, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" VerticalContentAlignment="Center"
                         Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Hex}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding FindNextCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                    <RadioButton Content="{StaticResource TextModeLabel}" IsChecked="{Binding SelectedSearchMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Text}" Margin="0,0,10,0"/>
                    <RadioButton Content="{StaticResource HexModeLabel}" IsChecked="{Binding SelectedSearchMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Hex}"/>
                </StackPanel>

                <!-- Find options row -->
                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Vertical" Margin="0,10,0,0">
                    <CheckBox Content="{StaticResource CaseSensitiveCheckbox}" IsChecked="{Binding CaseSensitive}" Margin="0,0,0,5"
                              Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Text}"/>
                    <CheckBox Content="{StaticResource WildcardCheckbox}" IsChecked="{Binding UseWildcard}" Margin="0,0,0,5"
                              Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Hex}"/>
                    <CheckBox Content="{StaticResource WrapAroundString}" IsChecked="{Binding WrapAround}" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0"
                                Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Text}">
                        <TextBlock Text="{StaticResource EncodingLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding AvailableEncodings}"
                                  SelectedItem="{Binding SelectedEncoding}"
                                  Width="180"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Replace Section -->
        <GroupBox Grid.Row="1" Header="{StaticResource ReplaceGroupHeader}" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource ReplaceTextLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" VerticalContentAlignment="Center"
                         Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Text}"/>

                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding ReplaceHex, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" VerticalContentAlignment="Center"
                         Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Hex}"/>

                <CheckBox Grid.Row="1" Grid.Column="1"
                          Content="{StaticResource TruncateReplacementString}"
                          IsChecked="{Binding TruncateReplacement}"
                          Margin="0,10,0,0"/>
            </Grid>
        </GroupBox>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button Content="{StaticResource FindNextButtonLabel}" Command="{Binding FindNextCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="{StaticResource FindPreviousButtonLabel}" Command="{Binding FindPreviousCommand}" Style="{StaticResource DialogButtonStyle}"/>
            <Button Content="{StaticResource FindAllButton}" Command="{Binding FindAllCommand}" Style="{StaticResource DialogButtonStyle}"/>
            <Button Content="{StaticResource ReplaceButton}" Command="{Binding ReplaceNextCommand}" Style="{StaticResource DialogButtonStyle}"/>
            <Button Content="{StaticResource ReplaceAllButton}" Command="{Binding ReplaceAllCommand}" Style="{StaticResource DialogButtonStyle}"/>
        </StackPanel>

        <!-- Results Section -->
        <GroupBox Grid.Row="3" Header="{StaticResource HE_ResultsHeader}" Padding="5" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Results header -->
                <Grid Grid.Row="0" Background="#F0F0F0" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding CurrentMatchText}" Margin="5" FontWeight="Bold"/>
                    <Button Grid.Column="1" Content="{StaticResource ClearString}" Command="{Binding ClearResultsCommand}"
                            Style="{StaticResource DialogButtonStyle}" Height="22" MinWidth="60"/>
                </Grid>

                <!-- Results list -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding SearchResults}"
                         SelectedIndex="{Binding CurrentMatchIndex}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{StaticResource PositionString}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Position, StringFormat=0x{0:X8}}"/>
                                <TextBlock Text="{StaticResource LengthString}" Margin="10,0,0,0" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Length}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        <!-- Status Bar -->
        <StatusBar Grid.Row="4" Height="26" Margin="0,0,0,10">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding ReplaceCount, StringFormat='Replacements: {0}'}" FontWeight="Bold"
                           Visibility="{Binding ReplaceCount, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{StaticResource CloseDialogButton}" Click="CloseButton_Click" Style="{StaticResource DialogButtonStyle}" IsCancel="True"/>
        </StackPanel>

        <!-- Progress indicator -->
        <pb:LinearProgressBar Grid.Row="0" Grid.RowSpan="6"
                              IsIndeterminate="True"
                              BarHeight="3" Height="3"
                              VerticalAlignment="Bottom"
                              Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</ec:ThemedDialog>

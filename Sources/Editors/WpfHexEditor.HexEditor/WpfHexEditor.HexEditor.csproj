<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>WpfHexEditor.HexEditor</RootNamespace>
    <AssemblyName>WpfHexEditor.HexEditor</AssemblyName>
    <LangVersion>preview</LangVersion>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <NeutralLanguage>en-US</NeutralLanguage>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591;NU5100</NoWarn>

    <!-- NuGet package metadata -->
    <PackageId>WPFHexaEditor</PackageId>
    <Version>3.3.2</Version>
    <AssemblyVersion>3.3.2.0</AssemblyVersion>
    <FileVersion>3.3.2</FileVersion>
    <Authors>Derek Tremblay</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Product>WpfHexEditorControl</Product>
    <Title>WPFHexaEditor - WPF Hex Editor UserControl</Title>
    <Description>A full-featured WPF hex editor UserControl for .NET 8. View and edit binary files with syntax coloring, format detection (799 .whfmt definitions via whfmt.FileFormatCatalog), column/row highlighting, undo/redo (HexByteUndoEntry / IUndoAwareEditor), advanced search, synchronized split-view (HexEditorSplitHost), auto-generated settings panel, themed dialogs (IdeMessageBox / IDialogService), and 28 UI locales. Drop-in replacement for WPFHexaEditor 2.x — completely rewritten for performance and modularity.</Description>
    <Copyright>GNU AGPL v3.0 - 2016-2026</Copyright>
    <PackageTags>hexeditor;hex;binary;wpf;usercontrol;editor;byte;viewer;format-detection;undo-redo</PackageTags>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorIDE</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorIDE</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReadmeFile>PACKAGE_README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReleaseNotes>3.3.2 — Fix XamlParseException on startup: HexEditorLocalizedDictionary is now wired into UserControl.Resources so all loc StaticResource keys resolve across the full visual tree (not only inside ContextMenu). 3.3.1 — Split-view polish: focus border hidden when split closed, breadcrumb sync in secondary pane, all mutation types + initial paint + standalone split sync, return singleton panels (match Solution Explorer pattern). Updated to whfmt.FileFormatCatalog 1.3.2 (799 definitions, schema v3). 3.3.0 — HexEditorSplitHost (synchronized split-view, standalone-safe); HexEditorSettings auto-generated settings panel; IParsedFieldsPanel integration API (GetByteProvider, FindSelect, ConnectParsedFieldsPanel); themed IdeMessageBox / IDialogService; +10 new localizations (uk-UA, cs-CZ, vi-VN, hu-HU, ro-RO, id-ID, th-TH, el-GR, da-DK, fi-FI).</PackageReleaseNotes>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>

    <!-- SourceLink: enables step-through debugging for NuGet consumers -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <!-- Profile-Guided Optimization (PGO) Configuration for .NET 8.0+ -->
  <PropertyGroup Condition="'$(Configuration)'=='Release' and '$(TargetFramework)'=='net8.0-windows'">
    <TieredCompilation>true</TieredCompilation>
    <TieredPGO>true</TieredPGO>
    <PublishReadyToRun>true</PublishReadyToRun>
    <DebugType>embedded</DebugType>
    <Optimize>true</Optimize>
  </PropertyGroup>

  <ItemGroup>
    <None Include="PACKAGE_README.md" Pack="true" PackagePath="\" />
    <None Include="WPFHexaEditor-guide.md" Pack="true" PackagePath="\" />
    <None Include="icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.*" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core\WpfHexEditor.Core.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.Localization\WpfHexEditor.Core.Localization.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Controls\WpfHexEditor.ColorPicker\WpfHexEditor.ColorPicker.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Controls\WpfHexEditor.HexBox\WpfHexEditor.HexBox.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Controls\WpfHexEditor.ProgressBar\WpfHexEditor.ProgressBar.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\WpfHexEditor.Editor.Core\WpfHexEditor.Editor.Core.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.Definitions\WpfHexEditor.Core.Definitions.csproj" PrivateAssets="all" />
  </ItemGroup>

  <!-- Bundle only the explicitly required dependency DLLs — whitelist prevents transitive
       assemblies from unrelated solution projects polluting the package. -->
  <PropertyGroup>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);CopyProjectReferencesToPackage</TargetsForTfmSpecificBuildOutput>
  </PropertyGroup>
  <Target Name="CopyProjectReferencesToPackage" DependsOnTargets="ResolveReferences">
    <ItemGroup>
      <!--
        _ResolvedProjectReferencePaths contains PrivateAssets="all" project refs; ReferenceCopyLocalPaths does not.
        We pull DLLs directly from each referenced project's output directory.
      -->
      <_BundledProjectDll Include="
        $(OutputPath)WpfHexEditor.Core.dll;
        $(OutputPath)WpfHexEditor.Core.BinaryAnalysis.dll;
        $(OutputPath)WpfHexEditor.Core.Contracts.dll;
        $(OutputPath)WpfHexEditor.Core.Definitions.dll;
        $(OutputPath)WpfHexEditor.Core.Localization.dll;
        $(OutputPath)WpfHexEditor.Editor.Core.dll;
        $(OutputPath)WpfHexEditor.ColorPicker.dll;
        $(OutputPath)WpfHexEditor.HexBox.dll;
        $(OutputPath)WpfHexEditor.ProgressBar.dll" />

      <BuildOutputInPackage Include="@(_BundledProjectDll)" Condition="Exists('%(Identity)')" />

      <!-- XML IntelliSense docs -->
      <BuildOutputInPackage Include="@(_BundledProjectDll->'%(RootDir)%(Directory)%(Filename).xml')"
                            Condition="Exists('%(RootDir)%(Directory)%(Filename).xml')" />
    </ItemGroup>
  </Target>

  <!--
    Satellite assemblies: glob each culture subfolder in OutputPath — only the whitelisted
    assembly satellites land in those subfolders when building this project standalone.
  -->
  <Target Name="IncludeSatelliteAssembliesInPackage" AfterTargets="CopyProjectReferencesToPackage">
    <ItemGroup>
      <!-- Glob all satellites then filter: keep only the whitelisted assembly names.
           Single glob avoids NU5118 (NuGet collision on same %(RecursiveDir) across multiple items). -->
      <_AllSatellites Include="$(OutputPath)*\*.resources.dll" />
      <_AllSatellites Remove="$(OutputPath)*\WpfHexEditor.HexEditor.resources.dll" />
      <TfmSpecificPackageFile Include="@(_AllSatellites)"
                              Condition="'%(Filename)' == 'WpfHexEditor.Core.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Core.BinaryAnalysis.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Core.Contracts.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Core.Definitions.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Core.Localization.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Editor.Core.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.ColorPicker.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.HexBox.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.ProgressBar.resources'"
                              PackagePath="%(RecursiveDir)%(Filename)%(Extension)" />
    </ItemGroup>
  </Target>

</Project>

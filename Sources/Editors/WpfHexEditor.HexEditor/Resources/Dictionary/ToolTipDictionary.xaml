<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hexSvc="clr-namespace:WpfHexEditor.HexEditor.Services"
    xmlns:p="clr-namespace:WpfHexEditor.Core.Properties;assembly=WpfHexEditor.Core">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="./MiscelanousDictionary.xaml" />
        <hexSvc:HexEditorLocalizedDictionary/>
    </ResourceDictionary.MergedDictionaries>

    <!--  USED FOR TOOLTIP OF IBYTECONTROL  -->
    <ToolTip x:Key="ByteToolTip">
        <ToolTip.RenderTransform>
            <ScaleTransform ScaleX="0.7" ScaleY="0.7" />
        </ToolTip.RenderTransform>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label
                    Width="120"
                    Content="{StaticResource ValueString}"
                    FontWeight="Bold" />
                <Label
                    Width="50"
                    Content="{StaticResource ByteString}"
                    FontWeight="Bold" />
                <Label Width="70" Content="{Binding Byte.LongText, UpdateSourceTrigger=PropertyChanged}" />
                <Label Content="{StaticResource HexString}" FontWeight="Bold" />
                <Label Content="{Binding Byte.LongText, Converter={StaticResource LongHexConverter}, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label
                    Width="120"
                    Content="{StaticResource PositionString}"
                    FontWeight="Bold" />
                <Label
                    Width="50"
                    Content="{StaticResource LongString}"
                    FontWeight="Bold" />
                <Label Width="70" Content="{Binding BytePositionInStream, UpdateSourceTrigger=PropertyChanged}" />
                <Label Content="{StaticResource HexString}" FontWeight="Bold" />
                <Label Content="{Binding BytePositionInStream, Converter={StaticResource LongHexConverter}, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <Separator />
            <StackPanel Orientation="Horizontal">
                <Label
                    Width="120"
                    Content="{StaticResource ByteActionString}"
                    FontWeight="Bold" />
                <Label Content="{Binding Action, UpdateSourceTrigger=PropertyChanged}" />
                <Label Content="{Binding OriginByte, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <Separator />
            <StackPanel Orientation="Horizontal">
                <Label
                    Width="120"
                    Content="{StaticResource DescriptionString}"
                    FontWeight="Bold" />
                <Label Content="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </StackPanel>
    </ToolTip>

    <!--  USED FOR TOOLTIP OF SCROLL MARKER  -->
    <ToolTip x:Key="ScrollMarkerSearchToolTip">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label
                    Width="120"
                    Content="{StaticResource PositionString}"
                    FontWeight="Bold" />
                <Label Content="{StaticResource LongString}" FontWeight="Bold" />
                <Label Content="{Binding BytePositionInStream, UpdateSourceTrigger=PropertyChanged}" />
                <Label Content="{StaticResource HexString}" FontWeight="Bold" />
                <Label Content="{Binding BytePositionInStream, Converter={StaticResource LongHexConverter}, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label
                    Width="120"
                    Content="{StaticResource DescriptionString}"
                    FontWeight="Bold" />
                <Label Content="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <Separator />
            <StackPanel Orientation="Horizontal">
                <Label Content="{StaticResource ClickToGoAtPositionString}" FontWeight="Bold" />
            </StackPanel>
        </StackPanel>
    </ToolTip>
</ResourceDictionary>

<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Tabs.VariablesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls"
             Background="{DynamicResource TE_Background}"
             xmlns:structSvc="clr-namespace:WpfHexEditor.Editor.StructureEditor.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <structSvc:StructureEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- description -->
            <RowDefinition Height="Auto"/>  <!-- filter -->
            <RowDefinition Height="*"/>     <!-- grid -->
            <RowDefinition Height="Auto"/>  <!-- add button -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{StaticResource StructureEditor_VarsDescription}"
                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                   Foreground="{DynamicResource TE_LineNumberForeground}"/>

        <!-- Filter -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                       FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{DynamicResource TE_LineNumberForeground}"/>
            <TextBox   Grid.Column="1" FontSize="11" Padding="4,2" BorderThickness="1"
                       Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                       Background="{DynamicResource TE_Background}"
                       Foreground="{DynamicResource TE_Foreground}"
                       ToolTip="{StaticResource StructureEditor_VarsFilterToolTip}"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  x:Name="VarsGrid"
                  ItemsSource="{Binding FilteredItems}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionUnit="FullRow"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  Background="{DynamicResource TE_Background}"
                  RowBackground="{DynamicResource TE_Background}"
                  AlternatingRowBackground="{DynamicResource TE_LineNumberBackground}"
                  Foreground="{DynamicResource TE_Foreground}"
                  BorderThickness="1"
                  FontSize="11">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource TE_LineNumberBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TE_LineNumberForeground}"/>
                    <Setter Property="Padding"    Value="4,2"/>
                    <Setter Property="FontSize"   Value="11"/>
                </Style>
                <!-- Themed ComboBox for the Type column -->
                <Style x:Key="TypeCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                    <Setter Property="FontSize"        Value="11"/>
                    <Setter Property="Padding"         Value="2,1"/>
                    <Setter Property="Background"      Value="{DynamicResource TE_Background}"/>
                    <Setter Property="Foreground"      Value="{DynamicResource TE_Foreground}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
                <!-- Shared TextBox style for value cells -->
                <Style x:Key="ValBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                    <Setter Property="FontFamily"      Value="Consolas"/>
                    <Setter Property="FontSize"        Value="11"/>
                    <Setter Property="Padding"         Value="4,2"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Background"      Value="Transparent"/>
                    <Setter Property="Foreground"      Value="{DynamicResource TE_Foreground}"/>
                </Style>

                <!-- ── Value cell templates (display) ──────────────────── -->
                <DataTemplate x:Key="ValBoolDisplay">
                    <CheckBox IsChecked="{Binding BoolValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                              VerticalAlignment="Center" Margin="4,0"
                              Foreground="{DynamicResource TE_Foreground}"/>
                </DataTemplate>
                <DataTemplate x:Key="ValIntDisplay">
                    <TextBox Style="{StaticResource ValBox}"
                             ctrl:InputFilter.NumericOnly="True"
                             Text="{Binding Value, UpdateSourceTrigger=LostFocus}"/>
                </DataTemplate>
                <DataTemplate x:Key="ValFloatDisplay">
                    <TextBox Style="{StaticResource ValBox}"
                             ctrl:InputFilter.DecimalOnly="True"
                             Text="{Binding Value, UpdateSourceTrigger=LostFocus}"/>
                </DataTemplate>
                <DataTemplate x:Key="ValHexDisplay">
                    <TextBox Style="{StaticResource ValBox}"
                             ctrl:InputFilter.HexOnly="True"
                             Text="{Binding Value, UpdateSourceTrigger=LostFocus}"
                             ToolTip="{StaticResource SE_TipHexDigitsOnly}"/>
                </DataTemplate>
                <DataTemplate x:Key="ValStringDisplay">
                    <TextBox Style="{StaticResource ValBox}"
                             Text="{Binding Value, UpdateSourceTrigger=LostFocus}"/>
                </DataTemplate>

                <!-- ── Template selector ───────────────────────────────── -->
                <ctrl:VariableValueTemplateSelector x:Key="ValueSelector"
                    BoolTemplate="{StaticResource ValBoolDisplay}"
                    IntTemplate="{StaticResource ValIntDisplay}"
                    FloatTemplate="{StaticResource ValFloatDisplay}"
                    HexTemplate="{StaticResource ValHexDisplay}"
                    StringTemplate="{StaticResource ValStringDisplay}"/>
            </DataGrid.Resources>

            <DataGrid.Columns>

                <!-- Variable Name -->
                <DataGridTextColumn Header="{StaticResource StructureEditor_VarsColName}" Width="160" MinWidth="120"
                                    Binding="{Binding Key, UpdateSourceTrigger=LostFocus}"
                                    FontFamily="Consolas"/>

                <!-- Type -->
                <DataGridTemplateColumn Header="{StaticResource StructureEditor_VarsColType}" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Type}" FontSize="11" Padding="4,2"
                                       Foreground="{DynamicResource TE_Foreground}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox Style="{StaticResource TypeCombo}"
                                      ItemsSource="{Binding TypeOptions}"
                                      SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Initial Value — control varies by Type -->
                <DataGridTemplateColumn Header="{StaticResource StructureEditor_VarsColInitialValue}" Width="120"
                                        CellTemplateSelector="{StaticResource ValueSelector}"/>

                <!-- Description -->
                <DataGridTextColumn Header="{StaticResource StructureEditor_VarsColDescription}" Width="*"
                                    Binding="{Binding Description, UpdateSourceTrigger=LostFocus}"/>

                <!-- Delete -->
                <DataGridTemplateColumn Width="28">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Command="{Binding RemoveCommand}"
                                    Style="{DynamicResource PM_RemoveButtonStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3" Content="{StaticResource StructureEditor_VarsAddButton}" x:Name="AddVarBtn" Click="OnAddVariable"
                Style="{DynamicResource PM_LinkButtonStyle}" Padding="6,3" Margin="0,6,0,0"/>
    </Grid>
</UserControl>

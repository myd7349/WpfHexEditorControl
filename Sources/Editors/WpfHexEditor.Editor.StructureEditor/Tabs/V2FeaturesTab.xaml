<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Tabs.V2FeaturesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls"
             xmlns:cp="clr-namespace:WpfHexEditor.ColorPicker.Controls;assembly=WpfHexEditor.ColorPicker"
             Background="{DynamicResource TE_Background}"
             xmlns:structSvc="clr-namespace:WpfHexEditor.Editor.StructureEditor.Services">


    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <structSvc:StructureEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        <Style x:Key="Sec" TargetType="Expander">
            <Setter Property="Margin"           Value="0,4,0,0"/>
            <Setter Property="Background"       Value="{DynamicResource TE_LineNumberBackground}"/>
            <Setter Property="Foreground"       Value="{DynamicResource TE_LineNumberForeground}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="IsExpanded"       Value="False"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,2,8,2"/>
            <Setter Property="MinWidth"          Value="100"/>
            <Setter Property="Foreground"        Value="{DynamicResource TE_LineNumberForeground}"/>
        </Style>
        <Style x:Key="Fld" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"          Value="0,2,0,2"/>
            <Setter Property="Background"      Value="{DynamicResource TE_Background}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TE_Foreground}"/>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="4,2"/>
            <Setter Property="Margin"     Value="0,2,4,2"/>
            <Setter Property="Background" Value="{DynamicResource TE_Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
        </Style>
        <Style x:Key="AddBtn" TargetType="Button" BasedOn="{StaticResource PM_LinkButtonStyle}">
            <Setter Property="Padding" Value="6,2"/>
        </Style>
        <Style x:Key="RemBtn" TargetType="Button" BasedOn="{StaticResource PM_RemoveButtonStyle}"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8" x:Name="Root">

            <!-- ── Assertions ──────────────────────────────────────── -->
            <Expander Header="{StaticResource StructureEditor_V2AssertionsHeader}" Style="{StaticResource Sec}">
                <StackPanel Margin="8,4">
                    <ItemsControl x:Name="AssertionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="{DynamicResource TE_LineNumberBackground}"
                                        Padding="0,4" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Style="{StaticResource Fld}" Margin="0,0,4,0"
                                                 Text="{Binding AssertionName, UpdateSourceTrigger=PropertyChanged}" ToolTip="{StaticResource SE_PropName}"/>
                                        <ctrl:ExpressionTextBox Grid.Column="1" Margin="0,2,4,2"
                                                 Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}"
                                                 Placeholder="{DynamicResource StructureEditor_V2AssertionPlaceholder}"
                                                 ToolTip="{StaticResource StructureEditor_V2AssertionToolTip}"/>
                                        <ComboBox Grid.Column="2" Style="{StaticResource Combo}"
                                                  ItemsSource="{Binding SeverityOptions}"
                                                  SelectedItem="{Binding Severity}"/>
                                        <Button Grid.Column="3" Style="{StaticResource RemBtn}"
                                                Command="{Binding RemoveCommand}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Style="{StaticResource AddBtn}" Content="{StaticResource SE_AddAssertion}"
                            x:Name="AddAssertionBtn" Click="OnAddAssertion"/>
                </StackPanel>
            </Expander>

            <!-- ── Checksums ────────────────────────────────────────── -->
            <Expander Header="{StaticResource StructureEditor_V2ChecksumsHeader}" Style="{StaticResource Sec}">
                <StackPanel Margin="8,4">
                    <ItemsControl x:Name="ChecksumsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="{DynamicResource TE_LineNumberBackground}"
                                        Padding="0,4" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Style="{StaticResource Fld}" Margin="0,0,4,0"
                                                 Text="{Binding ChecksumName, UpdateSourceTrigger=PropertyChanged}" ToolTip="{StaticResource SE_PropName}"/>
                                        <ComboBox Grid.Column="1" Style="{StaticResource Combo}"
                                                  ItemsSource="{Binding AlgorithmOptions}"
                                                  SelectedItem="{Binding Algorithm}"/>
                                        <ComboBox Grid.Column="2" Style="{StaticResource Combo}"
                                                  ItemsSource="{Binding SeverityOptions}"
                                                  SelectedItem="{Binding Severity}"/>
                                        <Button Grid.Column="3" Style="{StaticResource RemBtn}"
                                                Command="{Binding RemoveCommand}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Style="{StaticResource AddBtn}" Content="{StaticResource SE_AddChecksum}"
                            x:Name="AddChecksumBtn" Click="OnAddChecksum"/>
                </StackPanel>
            </Expander>

            <!-- ── Versioning ───────────────────────────────────────── -->
            <Expander Header="{StaticResource StructureEditor_V2VersioningHeader}" Style="{StaticResource Sec}">
                <StackPanel Margin="8,4" x:Name="VersioningPanel">
                    <!-- Field binding done in code-behind via x:Name=VersioningPanel -->
                </StackPanel>
            </Expander>

            <!-- ── Imports ($ref) ───────────────────────────────────── -->
            <Expander Header="{StaticResource StructureEditor_V2ImportsHeader}" Style="{StaticResource Sec}">
                <StackPanel Margin="8,4">
                    <TextBlock Text="{StaticResource StructureEditor_V2ImportsDescription}"
                               FontSize="10" Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <ItemsControl x:Name="ImportsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Style="{StaticResource Fld}" Margin="0,0,4,0"
                                             Text="{Binding Ref, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="{StaticResource StructureEditor_V2ImportRefToolTip}"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource Fld}" Margin="0,0,4,0"
                                             Text="{Binding As, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="{StaticResource StructureEditor_V2ImportAliasToolTip}"/>
                                    <Button Grid.Column="2" Style="{StaticResource RemBtn}"
                                            Command="{Binding RemoveCommand}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Style="{StaticResource AddBtn}" Content="{StaticResource StructureEditor_V2AddImportButton}"
                            x:Name="AddImportBtn" Click="OnAddImport"/>
                </StackPanel>
            </Expander>

            <!-- ── Forensic ─────────────────────────────────────────── -->
            <Expander Header="{StaticResource StructureEditor_V2ForensicHeader}" Style="{StaticResource Sec}" x:Name="ForensicExpander">
                <StackPanel Margin="8,4" x:Name="ForensicPanel"/>
            </Expander>

            <!-- ── Navigation ───────────────────────────────────────── -->
            <Expander Header="{StaticResource StructureEditor_V2NavBookmarksHeader}" Style="{StaticResource Sec}">
                <StackPanel Margin="8,4">
                    <ItemsControl x:Name="BookmarksList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBox Style="{StaticResource Fld}" Width="120" Margin="0,0,4,0"
                                             Text="{Binding BookmarkName, UpdateSourceTrigger=PropertyChanged}" ToolTip="{StaticResource SE_PropName}"/>
                                    <ctrl:ExpressionTextBox Width="120" Margin="0,2,4,2"
                                             Text="{Binding OffsetVar, UpdateSourceTrigger=PropertyChanged}"
                                             Placeholder="{DynamicResource StructureEditor_V2BookmarkPlaceholder}"
                                             ToolTip="{StaticResource StructureEditor_V2BookmarkToolTip}"/>
                                    <cp:ColorPicker ShowAlphaChannel="False" Margin="0,0,4,0"
                                                    SelectedColor="{Binding BookmarkColor, Converter={x:Static ctrl:HexStringToColorConverter.Instance}, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Style="{StaticResource RemBtn}" Command="{Binding RemoveCommand}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Style="{StaticResource AddBtn}" Content="{StaticResource StructureEditor_V2AddBookmarkButton}"
                            x:Name="AddBookmarkBtn" Click="OnAddBookmark"/>
                </StackPanel>
            </Expander>

            <!-- ── Inspector ────────────────────────────────────────── -->
            <Expander Header="{StaticResource StructureEditor_V2InspectorLayoutHeader}" Style="{StaticResource Sec}" x:Name="InspectorExpander">
                <StackPanel Margin="8,4" x:Name="InspectorPanel"/>
            </Expander>

            <!-- ── Export Templates ─────────────────────────────────── -->
            <Expander Header="{StaticResource StructureEditor_V2ExportTemplatesHeader}" Style="{StaticResource Sec}">
                <StackPanel Margin="8,4">
                    <ItemsControl x:Name="ExportsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="{DynamicResource TE_LineNumberBackground}"
                                        Padding="4" Margin="0,4">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Style="{StaticResource Fld}" Width="120" Margin="0,0,4,0"
                                                     Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}" ToolTip="{StaticResource SE_TipTemplateName}"/>
                                            <ComboBox Style="{StaticResource Combo}" Width="100"
                                                      ItemsSource="{Binding FormatOptions}"
                                                      SelectedItem="{Binding Format}"/>
                                            <TextBox Style="{StaticResource Fld}" Width="100" Margin="0,0,4,0"
                                                     Text="{Binding StructName, UpdateSourceTrigger=PropertyChanged}" ToolTip="{StaticResource SE_TipStructName}"/>
                                            <Button Style="{StaticResource RemBtn}" Command="{Binding RemoveCommand}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Style="{StaticResource AddBtn}" Content="{StaticResource StructureEditor_V2AddTemplateButton}"
                            x:Name="AddExportBtn" Click="OnAddExport"/>
                </StackPanel>
            </Expander>

            <!-- ── AI Hints ──────────────────────────────────────────── -->
            <Expander Header="{StaticResource StructureEditor_V2AIHintsHeader}" Style="{StaticResource Sec}" x:Name="AiExpander">
                <StackPanel Margin="8,4" x:Name="AiPanel"/>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>

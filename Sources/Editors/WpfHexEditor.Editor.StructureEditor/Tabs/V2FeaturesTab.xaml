<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Tabs.V2FeaturesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls"
             xmlns:cp="clr-namespace:WpfHexEditor.ColorPicker.Controls;assembly=WpfHexEditor.ColorPicker"
             Background="{DynamicResource TE_Background}">

    <UserControl.Resources>
        <Style x:Key="Sec" TargetType="Expander">
            <Setter Property="Margin"           Value="0,4,0,0"/>
            <Setter Property="Background"       Value="{DynamicResource TE_LineNumberBackground}"/>
            <Setter Property="Foreground"       Value="{DynamicResource TE_LineNumberForeground}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="IsExpanded"       Value="False"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,2,8,2"/>
            <Setter Property="MinWidth"          Value="100"/>
            <Setter Property="Foreground"        Value="{DynamicResource TE_LineNumberForeground}"/>
        </Style>
        <Style x:Key="Fld" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"          Value="0,2,0,2"/>
            <Setter Property="Background"      Value="{DynamicResource TE_Background}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TE_Foreground}"/>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="4,2"/>
            <Setter Property="Margin"     Value="0,2,4,2"/>
            <Setter Property="Background" Value="{DynamicResource TE_Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
        </Style>
        <Style x:Key="AddBtn" TargetType="Button" BasedOn="{StaticResource PM_LinkButtonStyle}">
            <Setter Property="Padding" Value="6,2"/>
        </Style>
        <Style x:Key="RemBtn" TargetType="Button" BasedOn="{StaticResource PM_RemoveButtonStyle}"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8" x:Name="Root">

            <!-- ── Assertions ──────────────────────────────────────── -->
            <Expander Header="Assertions" Style="{StaticResource Sec}">
                <StackPanel Margin="8,4">
                    <ItemsControl x:Name="AssertionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="{DynamicResource TE_LineNumberBackground}"
                                        Padding="0,4" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Style="{StaticResource Fld}" Margin="0,0,4,0"
                                                 Text="{Binding AssertionName, UpdateSourceTrigger=PropertyChanged}" ToolTip="Name"/>
                                        <ctrl:ExpressionTextBox Grid.Column="1" Margin="0,2,4,2"
                                                 Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}"
                                                 Placeholder="var:name equals 0 or calc:expr"
                                                 ToolTip="Boolean expression — Ctrl+Space for functions and variables"/>
                                        <ComboBox Grid.Column="2" Style="{StaticResource Combo}"
                                                  ItemsSource="{Binding SeverityOptions}"
                                                  SelectedItem="{Binding Severity}"/>
                                        <Button Grid.Column="3" Style="{StaticResource RemBtn}"
                                                Command="{Binding RemoveCommand}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Style="{StaticResource AddBtn}" Content="＋ Add Assertion"
                            x:Name="AddAssertionBtn" Click="OnAddAssertion"/>
                </StackPanel>
            </Expander>

            <!-- ── Checksums ────────────────────────────────────────── -->
            <Expander Header="Checksums" Style="{StaticResource Sec}">
                <StackPanel Margin="8,4">
                    <ItemsControl x:Name="ChecksumsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="{DynamicResource TE_LineNumberBackground}"
                                        Padding="0,4" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="24"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Style="{StaticResource Fld}" Margin="0,0,4,0"
                                                 Text="{Binding ChecksumName, UpdateSourceTrigger=PropertyChanged}" ToolTip="Name"/>
                                        <ComboBox Grid.Column="1" Style="{StaticResource Combo}"
                                                  ItemsSource="{Binding AlgorithmOptions}"
                                                  SelectedItem="{Binding Algorithm}"/>
                                        <ComboBox Grid.Column="2" Style="{StaticResource Combo}"
                                                  ItemsSource="{Binding SeverityOptions}"
                                                  SelectedItem="{Binding Severity}"/>
                                        <Button Grid.Column="3" Style="{StaticResource RemBtn}"
                                                Command="{Binding RemoveCommand}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Style="{StaticResource AddBtn}" Content="＋ Add Checksum"
                            x:Name="AddChecksumBtn" Click="OnAddChecksum"/>
                </StackPanel>
            </Expander>

            <!-- ── Forensic ─────────────────────────────────────────── -->
            <Expander Header="Forensic" Style="{StaticResource Sec}" x:Name="ForensicExpander">
                <StackPanel Margin="8,4" x:Name="ForensicPanel"/>
            </Expander>

            <!-- ── Navigation ───────────────────────────────────────── -->
            <Expander Header="Navigation Bookmarks" Style="{StaticResource Sec}">
                <StackPanel Margin="8,4">
                    <ItemsControl x:Name="BookmarksList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBox Style="{StaticResource Fld}" Width="120" Margin="0,0,4,0"
                                             Text="{Binding BookmarkName, UpdateSourceTrigger=PropertyChanged}" ToolTip="Name"/>
                                    <ctrl:ExpressionTextBox Width="120" Margin="0,2,4,2"
                                             Text="{Binding OffsetVar, UpdateSourceTrigger=PropertyChanged}"
                                             Placeholder="variableName"
                                             ToolTip="Variable holding the byte offset — Ctrl+Space for suggestions"/>
                                    <cp:ColorPicker ShowAlphaChannel="False" Margin="0,0,4,0"
                                                    SelectedColor="{Binding BookmarkColor, Converter={x:Static ctrl:HexStringToColorConverter.Instance}, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Style="{StaticResource RemBtn}" Command="{Binding RemoveCommand}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Style="{StaticResource AddBtn}" Content="＋ Add Bookmark"
                            x:Name="AddBookmarkBtn" Click="OnAddBookmark"/>
                </StackPanel>
            </Expander>

            <!-- ── Inspector ────────────────────────────────────────── -->
            <Expander Header="Inspector Layout" Style="{StaticResource Sec}" x:Name="InspectorExpander">
                <StackPanel Margin="8,4" x:Name="InspectorPanel"/>
            </Expander>

            <!-- ── Export Templates ─────────────────────────────────── -->
            <Expander Header="Export Templates" Style="{StaticResource Sec}">
                <StackPanel Margin="8,4">
                    <ItemsControl x:Name="ExportsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="{DynamicResource TE_LineNumberBackground}"
                                        Padding="4" Margin="0,4">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Style="{StaticResource Fld}" Width="120" Margin="0,0,4,0"
                                                     Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}" ToolTip="Template Name"/>
                                            <ComboBox Style="{StaticResource Combo}" Width="100"
                                                      ItemsSource="{Binding FormatOptions}"
                                                      SelectedItem="{Binding Format}"/>
                                            <TextBox Style="{StaticResource Fld}" Width="100" Margin="0,0,4,0"
                                                     Text="{Binding StructName, UpdateSourceTrigger=PropertyChanged}" ToolTip="Struct name (C struct)"/>
                                            <Button Style="{StaticResource RemBtn}" Command="{Binding RemoveCommand}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Style="{StaticResource AddBtn}" Content="＋ Add Template"
                            x:Name="AddExportBtn" Click="OnAddExport"/>
                </StackPanel>
            </Expander>

            <!-- ── AI Hints ──────────────────────────────────────────── -->
            <Expander Header="AI Hints" Style="{StaticResource Sec}" x:Name="AiExpander">
                <StackPanel Margin="8,4" x:Name="AiPanel"/>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>

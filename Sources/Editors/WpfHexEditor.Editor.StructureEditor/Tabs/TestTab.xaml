    Description: Test Panel tab — run the current format definition against a binary file
                 and display a per-block result grid.
-->

<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Tabs.TestTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Editor.StructureEditor.ViewModels"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.StructureEditor.Tabs"
             Background="{DynamicResource TE_Background}"
             Foreground="{DynamicResource TE_Foreground}">

    <UserControl.Resources>

        <!-- Converts Offset=-1 to "—" for skipped/summary blocks -->
        <local:NegativeOffsetConverter x:Key="OffsetConverter"/>

        <!-- Status → foreground colour (keeps readable on row selection) -->
        <Style x:Key="StatusCell" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="6,3"/>
            <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="OK">
                    <Setter Property="Foreground" Value="#4EC94E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Warning">
                    <Setter Property="Foreground" Value="{DynamicResource SE_ValidationWarningBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Error">
                    <Setter Property="Foreground" Value="{DynamicResource SE_ValidationErrorBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Skipped">
                    <Setter Property="Foreground" Value="{DynamicResource TE_LineNumberForeground}"/>
                </DataTrigger>
                <!-- Keep readable on row selection -->
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Summary/branch rows italic -->
        <Style x:Key="SummaryCell" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="6,3"/>
            <Setter Property="FontStyle"  Value="Italic"/>
            <Setter Property="Foreground" Value="{DynamicResource TE_LineNumberForeground}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridBtn" TargetType="Button">
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="Background"      Value="{DynamicResource TE_LineNumberBackground}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TE_Foreground}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <Style x:Key="FilterCheck" TargetType="CheckBox">
            <Setter Property="FontSize"           Value="11"/>
            <Setter Property="Margin"             Value="0,0,14,0"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="Foreground"         Value="{DynamicResource TE_Foreground}"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- file picker -->
            <RowDefinition Height="Auto"/>   <!-- summary bar -->
            <RowDefinition Height="Auto"/>   <!-- filter bar -->
            <RowDefinition Height="*"/>      <!-- results grid -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="Test Format Against File"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TE_Foreground}"
                   Margin="0,0,0,10"/>

        <!-- ── File picker row ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="FilePathBox"
                     Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="11" FontFamily="Consolas"
                     Padding="6,4"
                     Background="{DynamicResource TE_LineNumberBackground}"
                     Foreground="{DynamicResource TE_Foreground}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     BorderThickness="1"
                     ToolTip="Path to the binary file to test"
                     VerticalContentAlignment="Center"/>

            <Button Grid.Column="1" Content="Browse…"
                    Style="{StaticResource GridBtn}"
                    Margin="6,0,0,0"
                    Command="{Binding BrowseCommand}"/>

            <Button Grid.Column="2" Content="▶ Run Test"
                    Style="{StaticResource GridBtn}"
                    Margin="6,0,0,0"
                    x:Name="RunBtn"
                    Click="OnRunClicked"
                    IsEnabled="{Binding RunCommand.CanExecute}"/>

            <Button Grid.Column="3" Content="📋"
                    Style="{StaticResource GridBtn}"
                    Margin="6,0,0,0"
                    ToolTip="Copy results to clipboard (TSV)"
                    Click="OnCopyClicked"/>
        </Grid>

        <!-- ── Summary bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource TE_LineNumberBackground}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1" CornerRadius="3"
                Padding="8,4" Margin="0,0,0,6"
                x:Name="SummaryBar"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Summary}"
                           FontSize="11"
                           Foreground="{DynamicResource TE_Foreground}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <TextBlock Text="{Binding OkCount,    StringFormat='✓ {0}'}" Foreground="#4EC94E"  FontSize="11" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding WarnCount,  StringFormat='⚠ {0}'}" Foreground="{DynamicResource SE_ValidationWarningBrush}" FontSize="11" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding ErrorCount, StringFormat='✕ {0}'}" Foreground="{DynamicResource SE_ValidationErrorBrush}"   FontSize="11" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding SkipCount,  StringFormat='⊘ {0}'}" Foreground="{DynamicResource TE_LineNumberForeground}"   FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Filter bar ──────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Show:" FontSize="11" VerticalAlignment="Center"
                       Foreground="{DynamicResource TE_LineNumberForeground}" Margin="0,0,10,0"/>
            <CheckBox Content="✓ OK"      Style="{StaticResource FilterCheck}" IsChecked="{Binding ShowOk}"/>
            <CheckBox Content="⚠ Warning" Style="{StaticResource FilterCheck}" IsChecked="{Binding ShowWarning}"/>
            <CheckBox Content="✕ Error"   Style="{StaticResource FilterCheck}" IsChecked="{Binding ShowError}"/>
            <CheckBox Content="⊘ Skipped" Style="{StaticResource FilterCheck}" IsChecked="{Binding ShowSkipped}"/>
        </StackPanel>

        <!-- ── Results grid ────────────────────────────────────────────────── -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding Results}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  FontSize="11" FontFamily="Consolas"
                  Background="{DynamicResource TE_Background}"
                  Foreground="{DynamicResource TE_Foreground}"
                  BorderBrush="{DynamicResource DockBorderBrush}"
                  BorderThickness="1"
                  RowBackground="{DynamicResource TE_Background}"
                  AlternatingRowBackground="{DynamicResource TE_LineNumberBackground}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource DockBorderBrush}"
                  HeadersVisibility="Column"
                  RowHeight="22">

            <!-- Tooltip on each row shows the full Note + force foreground on selection -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="ToolTip" Value="{Binding Note}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
                        </Trigger>
                        <!-- Italic for summary/branch rows -->
                        <DataTrigger Binding="{Binding IsSummary}" Value="True">
                            <Setter Property="FontStyle" Value="Italic"/>
                            <Setter Property="Opacity"   Value="0.85"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"      Value="{DynamicResource TE_LineNumberBackground}"/>
                    <Setter Property="Foreground"      Value="{DynamicResource TE_LineNumberForeground}"/>
                    <Setter Property="FontSize"        Value="10"/>
                    <Setter Property="FontWeight"      Value="SemiBold"/>
                    <Setter Property="Padding"         Value="6,3"/>
                    <Setter Property="BorderBrush"     Value="{DynamicResource DockBorderBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>

                <DataGridTemplateColumn Header="Status" Width="68" SortMemberPath="Status">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status}" Style="{StaticResource StatusCell}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Block Name" Width="170" SortMemberPath="BlockName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding BlockName}" Padding="6,3" FontSize="11"
                                       Foreground="{DynamicResource TE_Foreground}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                                <Setter Property="FontStyle" Value="Italic"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TE_LineNumberForeground}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Type" Binding="{Binding BlockType}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"    Value="6,3"/>
                            <Setter Property="FontSize"   Value="11"/>
                            <Setter Property="Foreground" Value="{DynamicResource TE_LineNumberForeground}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Offset" Width="76" SortMemberPath="Offset">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Offset, Converter={StaticResource OffsetConverter}}"
                                       Padding="6,3" FontSize="11"
                                       Foreground="{DynamicResource SE_ValidationInfoBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Len" Binding="{Binding Length}" Width="42">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"  Value="6,3"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Raw (hex)" Binding="{Binding RawHex}" Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"    Value="6,3"/>
                            <Setter Property="FontSize"   Value="10"/>
                            <Setter Property="Foreground" Value="{DynamicResource TE_LineNumberForeground}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Parsed Value" Binding="{Binding ParsedValue}" Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"  Value="6,3"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Note column: single line, full text in row tooltip -->
                <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"              Value="6,3"/>
                            <Setter Property="FontSize"             Value="10"/>
                            <Setter Property="Foreground"           Value="{DynamicResource TE_LineNumberForeground}"/>
                            <Setter Property="TextTrimming"         Value="CharacterEllipsis"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>

            <!-- Empty state -->
            <DataGrid.Style>
                <Style TargetType="DataGrid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Results.Count}" Value="0">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGrid">
                                        <Border Background="{DynamicResource TE_LineNumberBackground}"
                                                BorderBrush="{DynamicResource DockBorderBrush}"
                                                BorderThickness="1" CornerRadius="3">
                                            <TextBlock Text="Select a file and click ▶ Run Test to test the current format definition."
                                                       FontSize="12" FontStyle="Italic"
                                                       Foreground="{DynamicResource TE_LineNumberForeground}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Style>

        </DataGrid>

    </Grid>
</UserControl>

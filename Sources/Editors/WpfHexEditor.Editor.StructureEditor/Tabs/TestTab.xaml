    Description: Test Panel tab — run the current format definition against a binary file
                 and display a per-block result grid.
-->

<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Tabs.TestTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Editor.StructureEditor.ViewModels"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.StructureEditor.Tabs"
             Background="{DynamicResource TE_Background}"
             Foreground="{DynamicResource TE_Foreground}">

    <UserControl.Resources>

        <!-- Status → foreground colour converter (inline style triggers) -->
        <Style x:Key="StatusCell" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="OK">
                    <Setter Property="Foreground" Value="#4EC94E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Warning">
                    <Setter Property="Foreground" Value="{DynamicResource SE_ValidationWarningBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Error">
                    <Setter Property="Foreground" Value="{DynamicResource SE_ValidationErrorBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Skipped">
                    <Setter Property="Foreground" Value="{DynamicResource TE_LineNumberForeground}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridBtn" TargetType="Button">
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="Background"      Value="{DynamicResource TE_LineNumberBackground}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TE_Foreground}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="Test Format Against File"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TE_Foreground}"
                   Margin="0,0,0,10"/>

        <!-- ── File picker row ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="FilePathBox"
                     Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="11" FontFamily="Consolas"
                     Padding="6,4"
                     Background="{DynamicResource TE_LineNumberBackground}"
                     Foreground="{DynamicResource TE_Foreground}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     BorderThickness="1"
                     ToolTip="Path to the binary file to test"
                     VerticalContentAlignment="Center"/>

            <Button Grid.Column="1" Content="Browse…"
                    Style="{StaticResource GridBtn}"
                    Margin="6,0,0,0"
                    Command="{Binding BrowseCommand}"/>

            <Button Grid.Column="2" Content="▶ Run Test"
                    Style="{StaticResource GridBtn}"
                    Margin="6,0,0,0"
                    x:Name="RunBtn"
                    Click="OnRunClicked"
                    IsEnabled="{Binding RunCommand.CanExecute}"/>
        </Grid>

        <!-- ── Summary bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource TE_LineNumberBackground}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1" CornerRadius="3"
                Padding="8,4" Margin="0,0,0,8"
                x:Name="SummaryBar">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Summary}"
                           FontSize="11"
                           Foreground="{DynamicResource TE_Foreground}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <TextBlock Text="{Binding OkCount,    StringFormat='✓ {0}'}" Foreground="#4EC94E"  FontSize="11" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding WarnCount,  StringFormat='⚠ {0}'}" Foreground="{DynamicResource SE_ValidationWarningBrush}" FontSize="11" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding ErrorCount, StringFormat='✕ {0}'}" Foreground="{DynamicResource SE_ValidationErrorBrush}"   FontSize="11" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding SkipCount,  StringFormat='⊘ {0}'}" Foreground="{DynamicResource TE_LineNumberForeground}"   FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Results grid ────────────────────────────────────────────────── -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Results}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  FontSize="11" FontFamily="Consolas"
                  Background="{DynamicResource TE_Background}"
                  Foreground="{DynamicResource TE_Foreground}"
                  BorderBrush="{DynamicResource DockBorderBrush}"
                  BorderThickness="1"
                  RowBackground="{DynamicResource TE_Background}"
                  AlternatingRowBackground="{DynamicResource TE_LineNumberBackground}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource DockBorderBrush}"
                  HeadersVisibility="Column">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"  Value="{DynamicResource TE_LineNumberBackground}"/>
                    <Setter Property="Foreground"  Value="{DynamicResource TE_LineNumberForeground}"/>
                    <Setter Property="FontSize"    Value="10"/>
                    <Setter Property="FontWeight"  Value="SemiBold"/>
                    <Setter Property="Padding"     Value="6,3"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>

                <DataGridTemplateColumn Header="Status" Width="60" SortMemberPath="Status">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status}" Style="{StaticResource StatusCell}" Padding="6,3"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Block Name" Binding="{Binding BlockName}" Width="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"   Value="6,3"/>
                            <Setter Property="FontSize"  Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Type" Binding="{Binding BlockType}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"   Value="6,3"/>
                            <Setter Property="FontSize"  Value="11"/>
                            <Setter Property="Foreground" Value="{DynamicResource TE_LineNumberForeground}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Offset" Binding="{Binding Offset, StringFormat='0x{0:X}'}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"   Value="6,3"/>
                            <Setter Property="FontSize"  Value="11"/>
                            <Setter Property="Foreground" Value="{DynamicResource SE_ValidationInfoBrush}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Len" Binding="{Binding Length}" Width="45">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"   Value="6,3"/>
                            <Setter Property="FontSize"  Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Raw (hex)" Binding="{Binding RawHex}" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"   Value="6,3"/>
                            <Setter Property="FontSize"  Value="10"/>
                            <Setter Property="Foreground" Value="{DynamicResource TE_LineNumberForeground}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Parsed Value" Binding="{Binding ParsedValue}" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"   Value="6,3"/>
                            <Setter Property="FontSize"  Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding"   Value="6,3"/>
                            <Setter Property="FontSize"  Value="10"/>
                            <Setter Property="Foreground" Value="{DynamicResource TE_LineNumberForeground}"/>
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>

            <!-- Empty state -->
            <DataGrid.Style>
                <Style TargetType="DataGrid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Results.Count}" Value="0">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGrid">
                                        <Border Background="{DynamicResource TE_LineNumberBackground}"
                                                BorderBrush="{DynamicResource DockBorderBrush}"
                                                BorderThickness="1" CornerRadius="3">
                                            <TextBlock Text="Select a file and click ▶ Run Test to test the current format definition."
                                                       FontSize="12" FontStyle="Italic"
                                                       Foreground="{DynamicResource TE_LineNumberForeground}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Style>

        </DataGrid>

    </Grid>
</UserControl>

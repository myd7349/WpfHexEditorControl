<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Tabs.QualityMetricsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource TE_Background}">

    <UserControl.Resources>
        <Style x:Key="SH" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,12,0,6"/>
            <Setter Property="Foreground" Value="{DynamicResource TE_LineNumberForeground}"/>
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,4,8,4"/>
            <Setter Property="MinWidth"          Value="140"/>
            <Setter Property="Foreground"        Value="{DynamicResource TE_LineNumberForeground}"/>
        </Style>
        <Style x:Key="Val" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"        Value="{DynamicResource TE_Foreground}"/>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="4,2"/>
            <Setter Property="Margin"     Value="0,2,0,2"/>
            <Setter Property="Background" Value="{DynamicResource TE_Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel Margin="12,8">

            <!-- ── Computed metrics ─────────────────────────────────── -->
            <TextBlock Text="Computed Metrics" Style="{StaticResource SH}"/>

            <!-- Block Coverage -->
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Block Coverage"  Style="{StaticResource Lbl}"/>
                <ProgressBar Grid.Column="1" Minimum="0" Maximum="100"
                             Value="{Binding BlockCoverage, Mode=OneWay}"
                             Height="12" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Margin="6,0,0,0"
                           Style="{StaticResource Val}"
                           Text="{Binding BlockCoverage, StringFormat={}{0}%}"/>
            </Grid>

            <!-- Completeness Score -->
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Completeness Score" Style="{StaticResource Lbl}"/>
                <ProgressBar Grid.Column="1" Minimum="0" Maximum="100"
                             Value="{Binding CompletenessScore, Mode=OneWay}"
                             Height="12" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Margin="6,0,0,0"
                           Style="{StaticResource Val}"
                           Text="{Binding CompletenessScore, StringFormat={}{0}%}"/>
            </Grid>

            <!-- Type Distribution -->
            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Type Distribution" Style="{StaticResource Lbl}"/>
                <ItemsControl Grid.Column="1" ItemsSource="{Binding TypeDistribution}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Margin="0,2,4,2" Padding="5,2"
                                    Background="{DynamicResource SE_ValidationInfoBrush}">
                                <TextBlock FontSize="10" Foreground="White"
                                           Text="{Binding Badge}"
                                           ToolTip="{Binding Type}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Stats row: Blocks / Depth / Variables -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Border CornerRadius="3" Padding="8,3" Margin="0,0,8,0"
                        Background="{DynamicResource TE_LineNumberBackground}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Blocks  " Style="{StaticResource Lbl}" Margin="0" MinWidth="0"/>
                        <TextBlock Style="{StaticResource Val}" FontWeight="SemiBold"
                                   Text="{Binding BlocksDefined}"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="3" Padding="8,3" Margin="0,0,8,0"
                        Background="{DynamicResource TE_LineNumberBackground}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Depth  " Style="{StaticResource Lbl}" Margin="0" MinWidth="0"/>
                        <TextBlock Style="{StaticResource Val}" FontWeight="SemiBold"
                                   Text="{Binding MaxNestingDepth}"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="3" Padding="8,3" Margin="0,0,8,0"
                        Background="{DynamicResource TE_LineNumberBackground}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Variables  " Style="{StaticResource Lbl}" Margin="0" MinWidth="0"/>
                        <TextBlock Style="{StaticResource Val}" FontWeight="SemiBold"
                                   Text="{Binding VariableCount}"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="3" Padding="8,3"
                        Background="{DynamicResource TE_LineNumberBackground}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Rules  " Style="{StaticResource Lbl}" Margin="0" MinWidth="0"/>
                        <TextBlock Style="{StaticResource Val}" FontWeight="SemiBold"
                                   Text="{Binding ValidationRulesCount}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ── Metadata ──────────────────────────────────────────── -->
            <TextBlock Text="Metadata" Style="{StaticResource SH}"/>

            <!-- Documentation Level -->
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Documentation Level" Style="{StaticResource Lbl}"/>
                <ComboBox  Grid.Column="1" Style="{StaticResource Combo}"
                           ItemsSource="{Binding DocumentationLevelOptions}"
                           SelectedItem="{Binding DocumentationLevel}"/>
            </Grid>

            <!-- Last Updated -->
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Last Updated" Style="{StaticResource Lbl}"/>
                <TextBox   Grid.Column="1" FontSize="11" Padding="4,2" BorderThickness="1"
                           Text="{Binding LastUpdated, UpdateSourceTrigger=PropertyChanged}"
                           Background="{DynamicResource TE_Background}"
                           Foreground="{DynamicResource TE_Foreground}"
                           ToolTip="Format: YYYY-MM-DD (auto-filled on save)"/>
            </Grid>

            <!-- Priority Format -->
            <CheckBox Content="Priority Format (top 100)"
                      IsChecked="{Binding PriorityFormat}"
                      Foreground="{DynamicResource TE_Foreground}"
                      FontSize="11" Margin="0,6,0,4"/>

            <!-- Auto Refined (read-only) -->
            <CheckBox Content="Auto-refined (enriched by script — read-only)"
                      IsChecked="{Binding AutoRefined, Mode=OneWay}"
                      IsEnabled="False"
                      Foreground="{DynamicResource TE_LineNumberForeground}"
                      FontSize="11" Margin="0,2,0,12"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

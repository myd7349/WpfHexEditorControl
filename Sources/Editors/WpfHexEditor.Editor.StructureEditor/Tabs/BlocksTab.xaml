<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Tabs.BlocksTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.StructureEditor.Tabs"
             xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls"
             Background="{DynamicResource TE_Background}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorShared.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.Simple.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.Control.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.V2.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <ctrl:BlockEditorTemplateSelector x:Key="BlockEditorTemplateSelector"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="160" MaxWidth="500"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: search + tree -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search box -->
            <TextBox Grid.Row="0" x:Name="SearchBox"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="11" Padding="4,3"
                     Background="{DynamicResource TE_LineNumberBackground}"
                     Foreground="{DynamicResource TE_Foreground}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     BorderThickness="0,0,0,1"
                     ToolTip="Filter blocks by name"/>

            <!-- Block Tree -->
            <TreeView Grid.Row="1"
                      x:Name="BlockTree"
                      ItemsSource="{Binding BlockTree}"
                      Background="{DynamicResource TE_Background}"
                      Foreground="{DynamicResource TE_Foreground}"
                      BorderThickness="0,0,1,0"
                      BorderBrush="{DynamicResource TE_LineNumberBackground}"
                      FontFamily="Consolas" FontSize="11"
                      SelectedItemChanged="OnTreeSelectionChanged">
                <TreeView.ContextMenu>
                    <ContextMenu Background="{DynamicResource TE_LineNumberBackground}"
                                 Foreground="{DynamicResource TE_Foreground}"
                                 BorderBrush="{DynamicResource DockBorderBrush}">
                        <MenuItem Header="Add Block..." Click="OnAddBlock"/>
                        <Separator/>
                        <MenuItem Header="Duplicate" Command="{Binding DuplicateCommand}" InputGestureText="Ctrl+D"/>
                        <MenuItem Header="Remove" Command="{Binding RemoveCommand}" InputGestureText="Del"/>
                        <Separator/>
                        <MenuItem Header="Move Up" Command="{Binding MoveUpCommand}" InputGestureText="Ctrl+Up"/>
                        <MenuItem Header="Move Down" Command="{Binding MoveDownCommand}" InputGestureText="Ctrl+Down"/>
                        <Separator/>
                        <MenuItem Header="Copy as JSON" Command="{Binding CopyBlockCommand}" InputGestureText="Ctrl+C"/>
                        <MenuItem Header="Paste Block" Command="{Binding PasteBlockCommand}" InputGestureText="Ctrl+V"/>
                    </ContextMenu>
                </TreeView.ContextMenu>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                        <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="2,1">
                            <!-- Type color indicator -->
                            <Rectangle Width="6" Height="14" RadiusX="2" RadiusY="2"
                                       Fill="{Binding ColorBrush}" Margin="0,0,5,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                       Foreground="{DynamicResource TE_Foreground}"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource TE_LineNumberBackground}"
                      ResizeDirection="Columns"/>

        <!-- Contextual block editor -->
        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      x:Name="EditorScroll">
            <ContentControl x:Name="BlockEditor"
                            Content="{Binding SelectedBlock}"
                            ContentTemplateSelector="{StaticResource BlockEditorTemplateSelector}"
                            Margin="8"/>
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock Grid.Column="2"
                   x:Name="EmptyHint"
                   Text="Select a block in the tree to edit its properties.&#x0a;Right-click for more options."
                   FontSize="12"
                   Foreground="{DynamicResource TE_LineNumberForeground}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   Visibility="Visible"/>
    </Grid>
</UserControl>

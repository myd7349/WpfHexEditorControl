<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Tabs.BlocksTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.StructureEditor.Tabs"
             xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls"
             Background="{DynamicResource TE_Background}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorShared.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.Simple.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.Control.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.V2.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <ctrl:BlockEditorTemplateSelector x:Key="BlockEditorTemplateSelector"/>
            <ctrl:BlockTypeBadgeConverter x:Key="BlockTypeBadge"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" MinWidth="200" MaxWidth="600"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: search + tree -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search box -->
            <TextBox Grid.Row="0" x:Name="SearchBox"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="11" Padding="4,3"
                     Background="{DynamicResource TE_LineNumberBackground}"
                     Foreground="{DynamicResource TE_Foreground}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     BorderThickness="0,0,0,1"
                     ToolTip="Filter blocks by name"/>

            <!-- Block Tree -->
            <TreeView Grid.Row="1"
                      x:Name="BlockTree"
                      ItemsSource="{Binding FilteredBlockTree}"
                      Background="{DynamicResource TE_Background}"
                      Foreground="{DynamicResource TE_Foreground}"
                      BorderThickness="0,0,1,0"
                      BorderBrush="{DynamicResource TE_LineNumberBackground}"
                      FontFamily="Consolas" FontSize="11"
                      AllowDrop="True"
                      SelectedItemChanged="OnTreeSelectionChanged"
                      PreviewMouseLeftButtonDown="OnBlockDragStart"
                      PreviewMouseMove="OnBlockDragMove"
                      Drop="OnBlockDrop"
                      DragOver="OnBlockDragOver"
                      DragLeave="OnBlockDragLeave">
                <TreeView.ContextMenu>
                    <ContextMenu Background="{DynamicResource TE_LineNumberBackground}"
                                 Foreground="{DynamicResource TE_Foreground}"
                                 BorderBrush="{DynamicResource DockBorderBrush}">
                        <MenuItem Header="Add Block..." Click="OnAddBlock" InputGestureText="Ctrl+N"/>
                        <Separator/>
                        <MenuItem Header="Duplicate" Command="{Binding DuplicateCommand}" InputGestureText="Ctrl+D"/>
                        <MenuItem Header="Remove" Command="{Binding RemoveCommand}" InputGestureText="Del"/>
                        <Separator/>
                        <MenuItem Header="Move Up" Command="{Binding MoveUpCommand}" InputGestureText="Ctrl+Up"/>
                        <MenuItem Header="Move Down" Command="{Binding MoveDownCommand}" InputGestureText="Ctrl+Down"/>
                        <Separator/>
                        <MenuItem Header="Copy as JSON" Command="{Binding CopyBlockCommand}" InputGestureText="Ctrl+C"/>
                        <MenuItem Header="Paste Block" Command="{Binding PasteBlockCommand}" InputGestureText="Ctrl+V"/>
                    </ContextMenu>
                </TreeView.ContextMenu>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                        <Setter Property="IsExpanded" Value="True"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="2,1">
                            <!-- 2-char type badge chip with block color as background -->
                            <Border CornerRadius="2" Width="22" Height="14"
                                    Background="{Binding ColorBrush}" Margin="0,0,5,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding BlockType, Converter={StaticResource BlockTypeBadge}}"
                                           FontSize="8" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                       Foreground="{DynamicResource TE_Foreground}"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource TE_LineNumberBackground}"
                      ResizeDirection="Columns"/>

        <!-- Contextual block editor -->
        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      x:Name="EditorScroll">
            <ContentControl x:Name="BlockEditor"
                            Content="{Binding SelectedBlock}"
                            ContentTemplateSelector="{StaticResource BlockEditorTemplateSelector}"
                            Margin="8"/>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Column="2"
                    x:Name="EmptyHint"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Visible">
            <TextBlock Text="Select a block to edit its properties,"
                       FontSize="12" TextAlignment="Center"
                       Foreground="{DynamicResource TE_LineNumberForeground}"/>
            <TextBlock Text="or press Ctrl+N / right-click to add a new block."
                       FontSize="11" TextAlignment="Center" Margin="0,4,0,0"
                       Foreground="{DynamicResource TE_LineNumberForeground}"/>
        </StackPanel>
    </Grid>
</UserControl>

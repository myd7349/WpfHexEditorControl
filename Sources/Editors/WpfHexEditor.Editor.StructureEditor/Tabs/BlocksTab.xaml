<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Tabs.BlocksTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.StructureEditor.Tabs"
             xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls"
             Background="{DynamicResource TE_Background}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorShared.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.Simple.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.Control.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.V2.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <ctrl:BlockEditorTemplateSelector x:Key="BlockEditorTemplateSelector"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>      <!-- Tree + Editor -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ────────────────────────────────────────────────────── -->
        <ToolBar Grid.Row="0"
                 Background="{DynamicResource TE_LineNumberBackground}"
                 ToolBarTray.IsLocked="True">
            <Button x:Name="AddBtn"      Content="＋ Add"   ToolTip="Add a new block" Click="OnAddBlock"   Padding="6,2"/>
            <Button x:Name="RemoveBtn"   Content="✕ Remove" ToolTip="Remove selected" Click="OnRemoveBlock" Padding="6,2"
                    Command="{Binding RemoveCommand}"/>
            <Separator/>
            <Button x:Name="MoveUpBtn"   Content="↑" Width="28"
                    Command="{Binding MoveUpCommand}"/>
            <Button x:Name="MoveDownBtn" Content="↓" Width="28"
                    Command="{Binding MoveDownCommand}"/>
            <Separator/>
            <Button x:Name="DupBtn"      Content="⧉ Duplicate" Padding="6,2"
                    Command="{Binding DuplicateCommand}"/>
        </ToolBar>

        <!-- ── Tree + Editor ──────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="160" MaxWidth="500"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Block Tree -->
            <TreeView Grid.Column="0"
                      x:Name="BlockTree"
                      ItemsSource="{Binding BlockTree}"
                      Background="{DynamicResource TE_Background}"
                      Foreground="{DynamicResource TE_Foreground}"
                      BorderThickness="0,0,1,0"
                      BorderBrush="{DynamicResource TE_LineNumberBackground}"
                      FontFamily="Consolas" FontSize="11"
                      SelectedItemChanged="OnTreeSelectionChanged">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                        <Setter Property="Foreground" Value="{DynamicResource TE_Foreground}"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="2,1">
                            <!-- Type color indicator -->
                            <Rectangle Width="6" Height="14" RadiusX="2" RadiusY="2"
                                       Fill="{Binding ColorBrush}" Margin="0,0,5,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                       Foreground="{DynamicResource TE_Foreground}"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource TE_LineNumberBackground}"
                          ResizeDirection="Columns"/>

            <!-- Contextual block editor -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          x:Name="EditorScroll">
                <ContentControl x:Name="BlockEditor"
                                Content="{Binding SelectedBlock}"
                                ContentTemplateSelector="{StaticResource BlockEditorTemplateSelector}"
                                Margin="8"/>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock Grid.Column="2"
                       x:Name="EmptyHint"
                       Text="Select a block in the tree to edit its properties."
                       FontSize="12"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Visible"/>
        </Grid>
    </Grid>
</UserControl>

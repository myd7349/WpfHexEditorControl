<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:structSvc="clr-namespace:WpfHexEditor.Editor.StructureEditor.Services"
                    xmlns:vm="clr-namespace:WpfHexEditor.Editor.StructureEditor.ViewModels"
                    xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls">

    <ResourceDictionary.MergedDictionaries>
        <structSvc:StructureEditorLocalizedDictionary/>
        <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorShared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ── conditional ────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Conditional" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">

            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>

            <!-- Condition -->
            <TextBlock Text="{StaticResource SE_BE_Condition}" Style="{StaticResource SectionHeader}"/>
            <ctrl:ConditionEditorRow DataContext="{Binding Condition}" Margin="0,0,0,4"/>

            <!-- Labels -->
            <TextBlock Text="{StaticResource SE_BE_BranchLabels}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_TrueLabel}"  Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding TrueLabel, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_FalseLabel}" Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding FalseLabel, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <TextBlock Text="{StaticResource SE_BE_BranchHint}"
                       FontSize="10" Margin="0,6,0,0"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       FontStyle="Italic"/>
        </StackPanel>
    </DataTemplate>

    <!-- ── loop ───────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Loop" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">

            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>

            <!-- Condition -->
            <TextBlock Text="{StaticResource SE_BE_LoopCondition}" Style="{StaticResource SectionHeader}"/>
            <ctrl:ConditionEditorRow DataContext="{Binding Condition}" Margin="0,0,0,4"/>

            <!-- Count / MaxIterations / IndexVar -->
            <TextBlock Text="{StaticResource SE_BE_Bounds}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_Count}"          Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                           Text="{Binding CountText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer or var:name"
                           ToolTip="{StaticResource SE_BE_Tip_LoopCount}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_MaxIterations}" Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource PropField}"
                           ctrl:InputFilter.NumericOnly="True"
                           Text="{Binding MaxIterations, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="{StaticResource SE_BE_Tip_LoopMaxCap}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource SE_BE_IndexVar}"      Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                           Text="{Binding IndexVar, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="i"
                           ToolTip="{StaticResource SE_BE_Tip_LoopIdxStore}"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="{StaticResource SE_BE_StoreAs}"       Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="3" Grid.Column="1" Margin="0,2"
                           Text="{Binding StoreAs, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"
                           ToolTip="{StaticResource SE_BE_Tip_LoopCountStore}"/>
            </Grid>

            <TextBlock Text="{StaticResource SE_BE_LoopBodyHint}"
                       FontSize="10" Margin="0,6,0,0"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       FontStyle="Italic"/>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:structSvc="clr-namespace:WpfHexEditor.Editor.StructureEditor.Services"
                    xmlns:vm="clr-namespace:WpfHexEditor.Editor.StructureEditor.ViewModels"
                    xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls">

    <ResourceDictionary.MergedDictionaries>
        <structSvc:StructureEditorLocalizedDictionary/>
        <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorShared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ── field / signature ────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Field" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">

            <!-- Common header -->
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>

            <!-- Offset / Length / ValueType -->
            <TextBlock Text="{StaticResource SE_BE_PositionSize}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_Offset}"       Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                           Text="{Binding OffsetText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer, var:name or calc:expr"
                           ToolTip="{StaticResource SE_BE_Tip_OffsetAuto}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_OffsetFrom}"  Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                           Text="{Binding OffsetFrom, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"
                           ToolTip="{StaticResource SE_BE_Tip_OffsetFromVar}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource SE_BE_OffsetAdd}"   Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                           Text="{Binding OffsetAddText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer or var:name"
                           ToolTip="{StaticResource SE_BE_Tip_OffsetAddBytes}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="{StaticResource SE_BE_Length}"       Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="3" Grid.Column="1" Margin="0,2"
                           Text="{Binding LengthText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer, var:name or calc:expr"
                           ToolTip="{StaticResource SE_BE_Tip_LengthAuto}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="{StaticResource SE_BE_ValueType}"   Style="{StaticResource PropLabel}"/>
                <ComboBox  Grid.Row="4" Grid.Column="1" Style="{StaticResource PropCombo}"
                           IsEditable="True"
                           ItemsSource="{Binding ValueTypes}"
                           Text="{Binding ValueType, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Storage -->
            <TextBlock Text="{StaticResource SE_BE_Storage}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_StoreAs}"            Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                           Text="{Binding StoreAs, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"
                           ToolTip="{StaticResource SE_BE_Tip_StoreParsed}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_MappedStoreAs}"     Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                           Text="{Binding MappedValueStoreAs, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"
                           ToolTip="{StaticResource SE_BE_Tip_StoreMapped}"/>
            </Grid>

            <!-- ValueMap -->
            <TextBlock Text="{StaticResource SE_BE_ValueMap}" Style="{StaticResource SectionHeader}"/>
            <ItemsControl ItemsSource="{Binding ValueMapItems}" Margin="0,0,0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200" Style="{StaticResource PropField}" Margin="0,0,4,0"
                                     FontFamily="Consolas" FontSize="10"
                                     ToolTip="{StaticResource SE_BE_Tip_RawDisplayMap}"/>
                            <Button Content="✕" FontSize="10" Padding="3,1"
                                    Command="{Binding RemoveCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TE_LineNumberForeground}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="{StaticResource SE_BE_AddValueMapEntry}" Style="{StaticResource AddLinkBtn}"
                    Command="{Binding AddValueMapCommand}"/>

            <!-- Bitfields -->
            <TextBlock Text="{StaticResource SE_BE_Bitfields}" Style="{StaticResource SectionHeader}"/>
            <ItemsControl ItemsSource="{Binding Bitfields}" Margin="0,0,0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:BitfieldViewModel}">
                        <Border BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource TE_LineNumberBackground}"
                                Margin="0,2" Padding="0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_Name}"    Style="{StaticResource PropLabel}"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox Style="{StaticResource PropField}" MinWidth="120"
                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Content="✕" FontSize="10" Padding="4,1" Margin="6,0,0,0"
                                            Command="{Binding RemoveCommand}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource TE_LineNumberForeground}"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_Bits}"   Style="{StaticResource PropLabel}"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource PropField}"
                                           Text="{Binding Bits, UpdateSourceTrigger=PropertyChanged}"
                                           ToolTip="{StaticResource SE_BE_Tip_BitRange}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource SE_BE_StoreAs}" Style="{StaticResource PropLabel}"/>
                                <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource PropField}"
                                           Text="{Binding StoreAs, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="{StaticResource SE_BE_AddBitfield}" Style="{StaticResource AddLinkBtn}"
                    Command="{Binding AddBitfieldCommand}"/>

            <!-- Sentinel (Until) -->
            <Expander Header="{StaticResource SE_BE_SentinelUntil}" Margin="0,8,0,0"
                      Background="{DynamicResource TE_LineNumberBackground}"
                      Foreground="{DynamicResource TE_LineNumberForeground}">
                <Grid Style="{StaticResource PropGrid}" Margin="8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_Until}"          Style="{StaticResource PropLabel}"/>
                    <ctrl:ExpressionTextBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                               Text="{Binding UntilText, UpdateSourceTrigger=PropertyChanged}"
                               Placeholder="00  or  var:endMarker  or  504B0102"
                               ToolTip="{StaticResource SE_BE_Tip_UntilPattern}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_MaxLength}"     Style="{StaticResource PropLabel}"/>
                    <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource PropField}"
                               ctrl:InputFilter.NumericOnly="True"
                               Text="{Binding MaxLength, UpdateSourceTrigger=PropertyChanged}"
                               ToolTip="{StaticResource SE_BE_Tip_UntilSafetyCap}"/>
                    <CheckBox  Grid.Row="2" Grid.Column="1" Margin="0,4"
                               Content="{StaticResource SE_BE_UntilInclusive}"
                               IsChecked="{Binding UntilInclusive, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Expander>

            <!-- Validation Rules -->
            <Expander Header="{StaticResource SE_BE_ValidationRules}" Margin="0,8,0,0"
                      Background="{DynamicResource TE_LineNumberBackground}"
                      Foreground="{DynamicResource TE_LineNumberForeground}">
                <StackPanel DataContext="{Binding ValidationRules}" Margin="8,4">
                    <Grid Style="{StaticResource PropGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_MinValue}"       Style="{StaticResource PropLabel}"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource PropField}"
                                   ctrl:InputFilter.NumericOnly="True"
                                   Text="{Binding MinValue, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_MaxValue}"       Style="{StaticResource PropLabel}"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource PropField}"
                                   ctrl:InputFilter.NumericOnly="True"
                                   Text="{Binding MaxValue, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource SE_BE_PatternRegex}"  Style="{StaticResource PropLabel}"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource PropField}"
                                   FontFamily="Consolas"
                                   Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{StaticResource SE_BE_ErrorMessage}"   Style="{StaticResource PropLabel}"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" Style="{StaticResource PropField}"
                                   Text="{Binding ErrorMessage, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>
            </Expander>
        </StackPanel>
    </DataTemplate>

    <!-- ── metadata ─────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Metadata" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="{StaticResource SE_BE_Variable}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{StaticResource SE_BE_VariableName}" Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding Variable, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="{StaticResource SE_BE_Tip_MetaVarName}"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- ── group ─────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Group" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="{StaticResource SE_BE_Group}" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="{StaticResource SE_BE_GroupHint}"
                       TextWrapping="Wrap" Opacity="0.6" FontSize="10" Margin="0,0,0,6"/>
            <TextBlock Text="{StaticResource SE_BE_ChildrenInTreeHint}"
                       TextWrapping="Wrap" Opacity="0.5" FontSize="10" FontStyle="Italic"/>
        </StackPanel>
    </DataTemplate>

    <!-- ── header ────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Header" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="{StaticResource SE_BE_Position}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_Offset}"      Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                           Text="{Binding OffsetText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer, var:name or calc:expr"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_OffsetFrom}" Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                           Text="{Binding OffsetFrom, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource SE_BE_Length}"      Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                           Text="{Binding LengthText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer or var:name"/>
            </Grid>
            <TextBlock Text="{StaticResource SE_BE_ChildFieldsHint}"
                       TextWrapping="Wrap" Opacity="0.5" FontSize="10" FontStyle="Italic" Margin="0,4,0,0"/>
        </StackPanel>
    </DataTemplate>

    <!-- ── data ──────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Data" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="{StaticResource SE_BE_RawDataRegion}" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="{StaticResource SE_BE_RawDataDescription}"
                       TextWrapping="Wrap" Opacity="0.6" FontSize="10" Margin="0,0,0,6"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_Offset}"      Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                           Text="{Binding OffsetText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer, var:name or calc:expr"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_OffsetFrom}" Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                           Text="{Binding OffsetFrom, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource SE_BE_Length}"      Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                           Text="{Binding LengthText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer or var:name"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:structSvc="clr-namespace:WpfHexEditor.Editor.StructureEditor.Services"
                    xmlns:vm="clr-namespace:WpfHexEditor.Editor.StructureEditor.ViewModels"
                    xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls"
                    xmlns:cp="clr-namespace:WpfHexEditor.ColorPicker.Controls;assembly=WpfHexEditor.ColorPicker">

    <ResourceDictionary.MergedDictionaries>
        <structSvc:StructureEditorLocalizedDictionary/>
        <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorShared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ── action ─────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Action" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="{StaticResource SE_BE_Action}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_Action}"   Style="{StaticResource PropLabel}"/>
                <ComboBox  Grid.Row="0" Grid.Column="1" Style="{StaticResource PropCombo}"
                           ItemsSource="{Binding ActionOptions}"
                           SelectedItem="{Binding Action, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_Variable}" Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                           Text="{Binding ActionVariable, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"
                           ToolTip="{StaticResource SE_BE_Tip_VarName}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource SE_BE_Value}"    Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                           Text="{Binding ActionValue, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer or var:name"
                           ToolTip="{StaticResource SE_BE_Tip_VarValue}"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- ── computeFromVariables ───────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Compute" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="{StaticResource SE_BE_Computation}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_Expression}" Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                           Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="calc:width * height / 2"
                           ToolTip="{StaticResource SE_BE_Tip_Expression}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_StoreAs}" Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                           Text="{Binding StoreAs, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"
                           ToolTip="{StaticResource SE_BE_Tip_StoreExpr}"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- ── repeating ──────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Repeating" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>

            <!-- Position -->
            <TextBlock Text="{StaticResource SE_BE_Position}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_Offset}"      Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                           Text="{Binding OffsetText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer, var:name or calc:expr"
                           ToolTip="{StaticResource SE_BE_Tip_ArrayOffset}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_OffsetFrom}" Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                           Text="{Binding OffsetFrom, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"
                           ToolTip="{StaticResource SE_BE_Tip_ArrayBaseVar}"/>
            </Grid>

            <!-- Array -->
            <TextBlock Text="{StaticResource SE_BE_Array}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_Count}"      Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                           Text="{Binding CountText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer or var:name"
                           ToolTip="{StaticResource SE_BE_Tip_EntryCount}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_EntrySize}" Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                           Text="{Binding EntrySizeText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer or var:name"
                           ToolTip="{StaticResource SE_BE_Tip_EntrySize}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource SE_BE_IndexVar}"  Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                           Text="{Binding IndexVar, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="i"
                           ToolTip="{StaticResource SE_BE_Tip_LoopIndex}"/>
            </Grid>

            <!-- Color cycle -->
            <TextBlock Text="{StaticResource SE_BE_ColorCycle}" Style="{StaticResource SectionHeader}"/>
            <ItemsControl ItemsSource="{Binding ColorCycle}" Margin="0,0,0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <cp:ColorPicker ShowAlphaChannel="False" Margin="0,0,4,0"
                                            SelectedColor="{Binding Value, Converter={x:Static ctrl:HexStringToColorConverter.Instance}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="✕" FontSize="10" Padding="3,1"
                                    Command="{Binding RemoveCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TE_LineNumberForeground}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="{StaticResource SE_BE_AddColor}" Style="{StaticResource AddLinkBtn}"
                    Command="{Binding AddColorCycleCommand}"/>

            <TextBlock Text="{StaticResource SE_BE_EntryFieldsHint}"
                       FontSize="10" Margin="0,8,0,0"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       FontStyle="Italic"/>
        </StackPanel>
    </DataTemplate>

    <!-- ── union ──────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Union" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="{StaticResource SE_BE_Union}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{StaticResource SE_BE_Discriminant}" Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Column="1" Margin="0,2"
                           Text="{Binding UnionCondition, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"
                           ToolTip="{StaticResource SE_BE_Tip_VariantVar}"/>
            </Grid>

            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{StaticResource SE_BE_Variants}" Style="{StaticResource SectionHeader}"/>
                <Button   DockPanel.Dock="Right" Content="+ Add variant"
                          Command="{Binding AddUnionVariantCommand}"
                          Margin="0,4,0,2" Padding="6,1" FontSize="11"/>
            </DockPanel>
            <DataGrid ItemsSource="{Binding UnionVariants}" AutoGenerateColumns="False"
                      Margin="0,0,0,4" FontSize="11" CanUserAddRows="False"
                      Background="{DynamicResource TE_Background}"
                      Foreground="{DynamicResource TE_Foreground}"
                      BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="1"
                      RowBackground="{DynamicResource TE_Background}"
                      AlternatingRowBackground="{DynamicResource TE_LineNumberBackground}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Key"         Binding="{Binding Key}"         Width="80"/>
                    <DataGridTextColumn Header="{StaticResource SE_BE_Length}" Binding="{Binding Length}" Width="60"/>
                    <DataGridTextColumn Header="ValueType"   Binding="{Binding ValueType}"   Width="*"/>
                    <DataGridTextColumn Header="Color"       Binding="{Binding Color}"       Width="80"/>
                    <DataGridTextColumn Header="Opacity"     Binding="{Binding Opacity}"     Width="60"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    <DataGridTemplateColumn Header="" Width="28">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                        Command="{Binding RemoveCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="Remove variant"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </DataTemplate>

    <!-- ── nested ─────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Nested" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="{StaticResource SE_BE_NestedStruct}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{StaticResource SE_BE_StructRef}" Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding StructRef, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="{StaticResource SE_BE_Tip_FormatPath}"/>
                <Button    Grid.Column="2" Content="{StaticResource SE_BE_Browse}" FontSize="11" Margin="4,2,0,2"
                           Padding="6,2"
                           Background="{DynamicResource TE_LineNumberBackground}"
                           Foreground="{DynamicResource TE_LineNumberForeground}"
                           BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="1"
                           Command="{Binding BrowseStructRefCommand}"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- ── pointer ────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Pointer" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>

            <!-- Where the pointer value is stored in the file -->
            <TextBlock Text="{StaticResource SE_BE_PointerLocation}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_Offset}"      Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                           Text="{Binding OffsetText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="integer or var:name"
                           ToolTip="{StaticResource SE_BE_Tip_PtrOffset}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_OffsetFrom}" Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                           Text="{Binding OffsetFrom, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"
                           ToolTip="{StaticResource SE_BE_Tip_PtrBaseVar}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource SE_BE_Length}"      Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="2" Grid.Column="1" Margin="0,2"
                           Text="{Binding LengthText, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="4"
                           ToolTip="{StaticResource SE_BE_Tip_PtrSize}"/>
            </Grid>

            <!-- Target + storage -->
            <TextBlock Text="{StaticResource SE_BE_TargetStorage}" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource SE_BE_TargetVar}" Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="0" Grid.Column="1" Margin="0,2"
                           Text="{Binding TargetVar, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"
                           ToolTip="{StaticResource SE_BE_Tip_PtrTargetVar}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource SE_BE_StoreAs}"   Style="{StaticResource PropLabel}"/>
                <ctrl:ExpressionTextBox Grid.Row="1" Grid.Column="1" Margin="0,2"
                           Text="{Binding StoreAs, UpdateSourceTrigger=PropertyChanged}"
                           Placeholder="variableName"
                           ToolTip="{StaticResource SE_BE_Tip_PtrStoreRaw}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource SE_BE_Label}"      Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="{StaticResource SE_BE_Tip_PtrLabel}"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>

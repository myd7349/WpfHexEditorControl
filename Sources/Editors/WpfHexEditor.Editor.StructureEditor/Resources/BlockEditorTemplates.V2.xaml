<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:WpfHexEditor.Editor.StructureEditor.ViewModels">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorShared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ── action ─────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Action" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="Action" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Action"   Style="{StaticResource PropLabel}"/>
                <ComboBox  Grid.Row="0" Grid.Column="1" Style="{StaticResource PropCombo}"
                           ItemsSource="{Binding ActionOptions}"
                           SelectedItem="{Binding Action, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Variable" Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding ActionVariable, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Name of the variable to act on"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Value"    Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding ActionValue, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Value to set / amount to add or subtract"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- ── computeFromVariables ───────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Compute" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="Computation" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Expression" Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource PropField}"
                           AcceptsReturn="True" MinHeight="50"
                           TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                           Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Math expression referencing variables e.g. width * height / 2"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Store As" Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding StoreAs, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Variable name to store the computed result"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- ── repeating ──────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Repeating" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="Array" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Count"      Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding CountText, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Number of entries — integer or var:name"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Entry Size" Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding EntrySizeText, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Size of each entry in bytes — integer or var:name"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Index Var"  Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding IndexVar, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Loop index variable name e.g. i"/>
            </Grid>

            <!-- Color cycle -->
            <TextBlock Text="Color Cycle" Style="{StaticResource SectionHeader}"/>
            <ItemsControl ItemsSource="{Binding ColorCycle}" Margin="0,0,0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     Width="120" Style="{StaticResource PropField}" Margin="0,0,4,0"
                                     ToolTip="CSS hex color e.g. #4488FF"/>
                            <Button Content="✕" FontSize="10" Padding="3,1"
                                    Command="{Binding RemoveCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TE_LineNumberForeground}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="＋ Add Color" Style="{StaticResource AddLinkBtn}"
                    Command="{Binding AddColorCycleCommand}"/>

            <TextBlock Text="Entry fields are shown as children in the tree."
                       FontSize="10" Margin="0,8,0,0"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       FontStyle="Italic"/>
        </StackPanel>
    </DataTemplate>

    <!-- ── union ──────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Union" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="Union" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Discriminant" Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding UnionCondition, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Variable that drives the variant selection"/>
            </Grid>

            <TextBlock Text="Variants" Style="{StaticResource SectionHeader}"/>
            <DataGrid ItemsSource="{Binding UnionVariants}" AutoGenerateColumns="False"
                      Margin="0,0,0,4" FontSize="11" CanUserAddRows="True"
                      Background="{DynamicResource TE_Background}"
                      Foreground="{DynamicResource TE_Foreground}"
                      BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="1"
                      RowBackground="{DynamicResource TE_Background}"
                      AlternatingRowBackground="{DynamicResource TE_LineNumberBackground}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Key"       Binding="{Binding Key}"       Width="80"/>
                    <DataGridTextColumn Header="Length"    Binding="{Binding Length}"     Width="60"/>
                    <DataGridTextColumn Header="ValueType" Binding="{Binding ValueType}"  Width="*"/>
                    <DataGridTextColumn Header="Color"     Binding="{Binding Color}"      Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </DataTemplate>

    <!-- ── nested ─────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Nested" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="Nested Struct" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Struct Ref" Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding StructRef, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Format name or relative path to the .whfmt file"/>
                <Button    Grid.Column="2" Content="Browse…" FontSize="11" Margin="4,2,0,2"
                           Padding="6,2"
                           Background="{DynamicResource TE_LineNumberBackground}"
                           Foreground="{DynamicResource TE_LineNumberForeground}"
                           BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="1"
                           Command="{Binding BrowseStructRefCommand}"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- ── pointer ────────────────────────────────────────────────────────── -->
    <DataTemplate x:Key="BlockTemplate_Pointer" DataType="{x:Type vm:BlockViewModel}">
        <StackPanel Style="{StaticResource BlockPanel}">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource BlockCommonHeader}"/>
            <TextBlock Text="Pointer" Style="{StaticResource SectionHeader}"/>
            <Grid Style="{StaticResource PropGrid}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Target Var" Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding TargetVar, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Variable holding the target offset"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Label"      Style="{StaticResource PropLabel}"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Style="{StaticResource PropField}"
                           Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                           ToolTip="Annotation label shown in the hex view"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>

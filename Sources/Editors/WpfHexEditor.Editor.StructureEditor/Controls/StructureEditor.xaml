<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Controls.StructureEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls"
             xmlns:tabs="clr-namespace:WpfHexEditor.Editor.StructureEditor.Tabs"
             Background="{DynamicResource TE_Background}"
             Focusable="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorShared.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.Simple.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.Control.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.V2.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <ctrl:SeverityToBrushConverter x:Key="SeverityToBrushConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>     <!-- TabControl -->
            <RowDefinition Height="Auto"/>  <!-- ValidationBar -->
            <RowDefinition Height="22"/>    <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── TabControl ────────────────────────────────────────────────── -->
        <TabControl Grid.Row="0"
                    x:Name="MainTabs"
                    Background="{DynamicResource TE_Background}"
                    Foreground="{DynamicResource TE_Foreground}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="0,1,0,0">

            <TabItem Header="_Metadata">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <tabs:MetadataTab x:Name="MetadataTabCtrl"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="_Detection">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <tabs:DetectionTab x:Name="DetectionTabCtrl"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="_Blocks">
                <tabs:BlocksTab x:Name="BlocksTabCtrl"/>
            </TabItem>

            <TabItem Header="_Variables">
                <tabs:VariablesTab x:Name="VariablesTabCtrl"/>
            </TabItem>

            <TabItem Header="v2.0 _Features">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <tabs:V2FeaturesTab x:Name="V2TabCtrl"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="_Quality">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <tabs:QualityMetricsTab x:Name="QualityTabCtrl"/>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Pop-toolbar trigger zone (invisible, top-right) ────────── -->
        <Border Grid.Row="0"
                x:Name="PopToolbarTrigger"
                Height="36" Width="200"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                IsHitTestVisible="True"
                MouseEnter="OnPopTriggerMouseEnter"/>

        <!-- ── Pop-toolbar popup ──────────────────────────────────────── -->
        <Popup x:Name="PopToolbarPopup"
               PlacementTarget="{Binding ElementName=PopToolbarTrigger}"
               Placement="Bottom"
               HorizontalOffset="-40"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               StaysOpen="False">
            <ctrl:StructurePopToolbar x:Name="PopToolbar"
                                      MouseLeave="OnPopToolbarMouseLeave"/>
        </Popup>

        <!-- ── Dirty indicator (floating, top-left of tab area) ──────── -->
        <TextBlock x:Name="DirtyIndicator" Text="●" FontSize="14"
                   Grid.Row="0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="8,6,0,0"
                   Foreground="{DynamicResource ET_AccentBrush}"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"
                   ToolTip="Unsaved changes"/>

        <!-- ── Validation bar ────────────────────────────────────────── -->
        <ctrl:ValidationBar Grid.Row="1"
                            x:Name="ValBar"
                            Visibility="Collapsed"/>

        <!-- ── Status bar ────────────────────────────────────────────── -->
        <StatusBar Grid.Row="2"
                   Background="{DynamicResource TE_LineNumberBackground}"
                   Foreground="{DynamicResource TE_LineNumberForeground}"
                   Height="22">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="—" Padding="4,0" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</UserControl>

<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Controls.StructureEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls"
             xmlns:tabs="clr-namespace:WpfHexEditor.Editor.StructureEditor.Tabs"
             Background="{DynamicResource TE_Background}"
             Focusable="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorShared.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.Simple.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.Control.xaml"/>
                <ResourceDictionary Source="/WpfHexEditor.Editor.StructureEditor;component/Resources/BlockEditorTemplates.V2.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <ctrl:SeverityToBrushConverter x:Key="SeverityToBrushConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- TabControl -->
            <RowDefinition Height="Auto"/>  <!-- ValidationBar -->
            <RowDefinition Height="22"/>    <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ───────────────────────────────────────────────────── -->
        <ToolBar Grid.Row="0"
                 Background="{DynamicResource TE_LineNumberBackground}"
                 Foreground="{DynamicResource TE_LineNumberForeground}"
                 ToolBarTray.IsLocked="True">
            <Button Content="💾 Save" ToolTip="Save (Ctrl+S)"
                    Click="OnSaveClick" x:Name="SaveBtn"
                    IsEnabled="False" Padding="6,2"/>
            <Separator/>
            <Button Content="✓ Validate" ToolTip="Validate format definition"
                    Click="OnValidateClick" Padding="6,2"/>
            <Separator/>
            <TextBlock x:Name="DirtyIndicator" Text="●" FontSize="14"
                       VerticalAlignment="Center" Margin="4,0"
                       Foreground="{DynamicResource ET_AccentBrush}"
                       Visibility="Collapsed"
                       ToolTip="Unsaved changes"/>
        </ToolBar>

        <!-- ── TabControl ────────────────────────────────────────────────── -->
        <TabControl Grid.Row="1"
                    x:Name="MainTabs"
                    Background="{DynamicResource TE_Background}"
                    Foreground="{DynamicResource TE_Foreground}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="0,1,0,0">

            <TabItem Header="Metadata">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <tabs:MetadataTab x:Name="MetadataTabCtrl"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Detection">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <tabs:DetectionTab x:Name="DetectionTabCtrl"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Blocks">
                <tabs:BlocksTab x:Name="BlocksTabCtrl"/>
            </TabItem>

            <TabItem Header="Variables">
                <tabs:VariablesTab x:Name="VariablesTabCtrl"/>
            </TabItem>

            <TabItem Header="v2.0 Features">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <tabs:V2FeaturesTab x:Name="V2TabCtrl"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Quality">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <tabs:QualityMetricsTab x:Name="QualityTabCtrl"/>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Validation bar ────────────────────────────────────────────── -->
        <ctrl:ValidationBar Grid.Row="2"
                            x:Name="ValBar"
                            Visibility="Collapsed"/>

        <!-- ── Status bar ────────────────────────────────────────────────── -->
        <StatusBar Grid.Row="3"
                   Background="{DynamicResource TE_LineNumberBackground}"
                   Foreground="{DynamicResource TE_LineNumberForeground}"
                   Height="22">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="—" Padding="4,0" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</UserControl>

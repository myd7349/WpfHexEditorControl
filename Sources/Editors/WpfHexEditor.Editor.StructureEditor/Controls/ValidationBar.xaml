<UserControl x:Class="WpfHexEditor.Editor.StructureEditor.Controls.ValidationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Editor.StructureEditor.ViewModels"
             xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.StructureEditor.Controls"
             Visibility="Collapsed">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <ctrl:SeverityToBrushConverter x:Key="SeverityToBrushConverter"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource TE_LineNumberBackground}"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource TE_LineNumberBackground}"
            MaxHeight="80">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ItemsControl Grid.Column="0"
                          x:Name="ItemsPanel"
                          Margin="4,2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ValidationSummaryItem}">
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <!-- Severity icon (Segoe MDL2) -->
                            <TextBlock Text="{Binding Glyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"
                                       Foreground="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}"/>
                            <!-- Message -->
                            <TextBlock Text="{Binding Message}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TE_Foreground}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="500"/>
                            <!-- Line:Col -->
                            <TextBlock FontSize="10"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"
                                       Foreground="{DynamicResource TE_LineNumberForeground}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="({0}:{1})">
                                        <Binding Path="Line"/>
                                        <Binding Path="Column"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Error/Warning counts -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="8,0">
                <TextBlock x:Name="ErrorCountText"
                           FontSize="11"
                           Foreground="OrangeRed"
                           Margin="0,0,8,0"/>
                <TextBlock x:Name="WarningCountText"
                           FontSize="11"
                           Foreground="Orange"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

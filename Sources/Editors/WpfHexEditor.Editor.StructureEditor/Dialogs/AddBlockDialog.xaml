<Window x:Class="WpfHexEditor.Editor.StructureEditor.Dialogs.AddBlockDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Block"
        Width="380" Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource TE_Background}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Block Type" FontSize="11" VerticalAlignment="Center"
                   Foreground="{DynamicResource TE_LineNumberForeground}"/>
        <ComboBox  Grid.Row="0" Grid.Column="1"
                   x:Name="TypeCombo"
                   FontSize="11" Margin="0,4"
                   SelectionChanged="OnTypeChanged"/>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Name" FontSize="11" VerticalAlignment="Center"
                   Foreground="{DynamicResource TE_LineNumberForeground}"/>
        <TextBox   Grid.Row="1" Grid.Column="1"
                   x:Name="NameBox"
                   FontSize="11" Padding="4,2" Margin="0,4"
                   Background="{DynamicResource TE_Background}"
                   Foreground="{DynamicResource TE_Foreground}"
                   KeyDown="OnNameKeyDown"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="HintText"
                   FontSize="10" Margin="0,4"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TE_LineNumberForeground}"/>

        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Add"    Width="70" Margin="0,0,8,0"
                    IsDefault="True" Click="OnAdd"
                    Foreground="{DynamicResource TE_Foreground}"/>
            <Button Content="Cancel" Width="70"
                    IsCancel="True"
                    Foreground="{DynamicResource TE_Foreground}"/>
        </StackPanel>
    </Grid>
</Window>

<UserControl x:Class="WpfHexEditor.Editor.DisassemblyViewer.Controls.DisassemblyViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dv="clr-namespace:WpfHexEditor.Editor.DisassemblyViewer.Controls"
             Background="{DynamicResource TE_Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border x:Name="ToolbarBorder"
                Grid.Row="0"
                Style="{DynamicResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="True">
                <!-- Right: always-visible (Refresh) -->
                <StackPanel x:Name="ToolbarRightPanel"
                            Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="RefreshButton"
                            Style="{DynamicResource PanelIconButtonStyle}"
                            Content="&#xE72C;"
                            ToolTip="Decompile again"
                            Click="OnRefreshClick"/>
                </StackPanel>

                <!-- Overflow button — shown only when groups are collapsed -->
                <Button x:Name="ToolbarOverflowButton"
                        DockPanel.Dock="Right"
                        Visibility="Collapsed"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        ToolTip="More options"
                        Click="OnOverflowButtonClick">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowContextMenu" Opened="OnOverflowMenuOpened">
                            <!-- TbgDisasmActions items -->
                            <MenuItem Header="Copy All"
                                      Tag="TbgDisasmActions"
                                      Click="OnCopyAllClick"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Group: TbgDisasmActions [0] (only collapsible group) -->
                <StackPanel x:Name="TbgDisasmActions"
                            Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="CopyAllButton"
                            Style="{DynamicResource PanelIconButtonStyle}"
                            Content="&#xE8C8;"
                            ToolTip="Copy all"
                            Click="OnCopyAllClick"/>
                </StackPanel>

                <!-- ArchLabel fills remaining space (LastChildFill) -->
                <TextBlock x:Name="ArchLabel"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- Output — structured canvas (IStructuredDisassembler) -->
        <ScrollViewer x:Name="CanvasScroller"
                      Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="Collapsed"
                      Background="{DynamicResource TE_Background}">
            <dv:DisassemblyLineCanvas x:Name="LineCanvas"
                                      Cursor="Arrow"
                                      OffsetRequested="OnCanvasOffsetRequested"/>
        </ScrollViewer>

        <!-- Output — plain TextBox fallback (plain IDecompiler) -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="OutputBox"
                     IsReadOnly="True"
                     Background="Transparent"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="12"
                     Foreground="{DynamicResource TE_LineNumberForeground}"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True"
                     Padding="8"
                     IsTabStop="False"
                     Visibility="Collapsed"/>
        </ScrollViewer>

        <!-- No decompiler overlay -->
        <StackPanel x:Name="NoDecompilerOverlay"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Opacity="0.45"
                    Visibility="Collapsed">
            <TextBlock Text="&#xE9D9;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="32"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TE_LineNumberForeground}"/>
            <TextBlock x:Name="NoDecompilerText"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Busy overlay -->
        <Grid x:Name="BusyOverlay"
              Grid.Row="1"
              Visibility="Collapsed">
            <ProgressBar IsIndeterminate="True"
                         Height="2"
                         VerticalAlignment="Top"
                         Foreground="{DynamicResource TE_LineNumberForeground}"/>
            <TextBlock Text="Decompiling…"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       FontSize="12"
                       Opacity="0.6"/>
        </Grid>
    </Grid>
</UserControl>

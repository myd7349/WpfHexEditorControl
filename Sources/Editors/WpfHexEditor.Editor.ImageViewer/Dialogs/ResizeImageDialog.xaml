Created: 2026-03-06
Description:
    Themed dialog for non-destructive image resize.
    Exposes TargetWidth, TargetHeight, LockAspectRatio,
    and Algorithm for consumption by ImageViewer.

Architecture Notes:
    Extends ThemedDialog (custom chrome, DynamicResource theming).
    Theme keys: DockWindowBackgroundBrush, DockMenuForegroundBrush,
    DockMenuHighlightBrush, DockMenuBorderBrush from active theme.
==========================================================
-->
<ec:ThemedDialog
    x:Class="WpfHexEditor.Editor.ImageViewer.Dialogs.ResizeImageDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
    Title="Resize Image"
    Width="340"
    SizeToContent="Height"
    ResizeMode="NoResize"
    Background="{DynamicResource DockWindowBackgroundBrush}">

    <Grid Margin="16,12,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Current size hint -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   x:Name="CurrentSizeHint"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.6"
                   FontSize="11"
                   Text="Current size: — × —"/>

        <!-- Width -->
        <Label Grid.Row="2" Grid.Column="0"
               Content="_Width (px):"
               VerticalAlignment="Center"
               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
        <TextBox Grid.Row="2" Grid.Column="1"
                 x:Name="WidthBox"
                 Height="24" Padding="4,2"
                 TextChanged="OnWidthChanged"
                 PreviewTextInput="OnNumericOnly"
                 DataObject.Pasting="OnNumericPaste"/>

        <!-- Height -->
        <Label Grid.Row="4" Grid.Column="0"
               Content="_Height (px):"
               VerticalAlignment="Center"
               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
        <TextBox Grid.Row="4" Grid.Column="1"
                 x:Name="HeightBox"
                 Height="24" Padding="4,2"
                 TextChanged="OnHeightChanged"
                 PreviewTextInput="OnNumericOnly"
                 DataObject.Pasting="OnNumericPaste"/>

        <!-- Lock aspect ratio -->
        <CheckBox Grid.Row="6" Grid.ColumnSpan="2"
                  x:Name="LockRatioCheck"
                  Content="Lock aspect _ratio"
                  IsChecked="True"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"/>

        <!-- Algorithm -->
        <Label Grid.Row="8" Grid.Column="0"
               Content="_Algorithm:"
               VerticalAlignment="Center"
               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
        <ComboBox Grid.Row="8" Grid.Column="1"
                  x:Name="AlgorithmBox"
                  Height="24"
                  SelectedIndex="1">
            <ComboBoxItem Content="Nearest Neighbor"/>
            <ComboBoxItem Content="Bilinear (recommended)"/>
            <ComboBoxItem Content="Bicubic (high quality)"/>
        </ComboBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="10" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="OK"
                    IsDefault="True" IsEnabled="False"
                    Click="OnOk" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True"/>
        </StackPanel>
    </Grid>

</ec:ThemedDialog>

<!--
==========================================================
Project: WpfHexEditor.Editor.ImageViewer
File: Controls/ImageViewer.xaml
Author: Derek Tremblay (derektremblay666@gmail.com)
Contributors: Claude Sonnet 4.6
Created: 2026-03-06
Description:
    Read-only image viewer with non-destructive transform pipeline.
    Supports zoom, pan, rotate, flip, crop selection overlay,
    resize, and Save As. Integrates with the App's Image menu,
    toolbar contributions, and status bar.

Architecture Notes:
    Theme keys: TE_Background (viewer bg), AccentBrush,
    DockMenuBackgroundBrush, DockMenuForegroundBrush,
    DockMenuBorderBrush, DockMenuHighlightBrush.
    Context menu uses IV_ContextMenuStyle (Office-like, left accent band).
    Crop overlay: Canvas above Image, shown only in CropMode.
==========================================================
-->
<UserControl x:Class="WpfHexEditor.Editor.ImageViewer.Controls.ImageViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource TE_Background}"
             Focusable="True"
             KeyDown="ImageViewer_KeyDown">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.Editor.ImageViewer;component/Themes/ImageContextMenu.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Office-like context menu — visible only when right-clicking on this control -->
    <UserControl.ContextMenu>
        <ContextMenu Style="{StaticResource IV_ContextMenuStyle}">

            <!-- TRANSFORM group -->
            <MenuItem Header="TRANSFORM" Style="{StaticResource IV_GroupHeaderStyle}"/>
            <MenuItem x:Name="CmRotateRight"
                      Header="Rotate Right"
                      InputGestureText="Ctrl+R"
                      Click="OnContextRotateRight">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE7AD;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="CmRotateLeft"
                      Header="Rotate Left"
                      InputGestureText="Ctrl+Shift+R"
                      Click="OnContextRotateLeft">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE7AE;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="CmFlipH"
                      Header="Flip Horizontal"
                      InputGestureText="Ctrl+H"
                      Click="OnContextFlipH">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="CmFlipV"
                      Header="Flip Vertical"
                      InputGestureText="Ctrl+Shift+H"
                      Click="OnContextFlipV">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8B0;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator Style="{StaticResource IV_GroupSeparatorStyle}"/>

            <!-- CROP & RESIZE group -->
            <MenuItem Header="CROP &amp; RESIZE" Style="{StaticResource IV_GroupHeaderStyle}"/>
            <MenuItem x:Name="CmCropMode"
                      Header="Crop Mode"
                      InputGestureText="Ctrl+K"
                      Click="OnContextCropMode">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE7A8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="CmResize"
                      Header="Resize..."
                      InputGestureText="Ctrl+Shift+Z"
                      Click="OnContextResize">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator Style="{StaticResource IV_GroupSeparatorStyle}"/>

            <!-- EXPORT group -->
            <MenuItem Header="EXPORT" Style="{StaticResource IV_GroupHeaderStyle}"/>
            <MenuItem x:Name="CmSaveAs"
                      Header="Export..."
                      InputGestureText="Ctrl+Shift+S"
                      Click="OnContextSaveAs">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="CmCopy"
                      Header="Copy to Clipboard"
                      InputGestureText="Ctrl+C"
                      Click="OnContextCopy">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator Style="{StaticResource IV_GroupSeparatorStyle}"/>

            <!-- Reset -->
            <MenuItem x:Name="CmResetTransforms"
                      Header="Reset to Original Image"
                      Click="OnContextResetTransforms">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </MenuItem.Icon>
            </MenuItem>

        </ContextMenu>
    </UserControl.ContextMenu>

    <Grid>
        <ScrollViewer x:Name="ImageScroll"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource TE_Background}"
                      PreviewMouseWheel="ImageScroll_PreviewMouseWheel"
                      MouseMove="ImageScroll_MouseMove"
                      MouseDown="ImageScroll_MouseDown"
                      MouseUp="ImageScroll_MouseUp">

            <!-- Outer grid: checkerboard + image + crop overlay -->
            <Grid x:Name="ImageContainer">
                <Grid.Background>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,16,16" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="#CCCCCC">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,16,16"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="#AAAAAA">
                                    <GeometryDrawing.Geometry>
                                        <GeometryGroup>
                                            <RectangleGeometry Rect="0,0,8,8"/>
                                            <RectangleGeometry Rect="8,8,8,8"/>
                                        </GeometryGroup>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Grid.Background>

                <!-- Image display -->
                <Image x:Name="ImageDisplay"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Stretch="None"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="16"/>

                <!-- Crop selection overlay — only shown in CropMode -->
                <Canvas x:Name="CropOverlay"
                        Visibility="Collapsed"
                        Background="Transparent"
                        IsHitTestVisible="True"
                        MouseLeftButtonDown="CropOverlay_MouseLeftButtonDown"
                        MouseMove="CropOverlay_MouseMove"
                        MouseLeftButtonUp="CropOverlay_MouseLeftButtonUp"
                        Cursor="Cross">

                    <!-- 4 veil regions surrounding the crop selection (darken cropped-out areas) -->
                    <Rectangle x:Name="VeilTop"    Fill="#CC000000" IsHitTestVisible="False"/>
                    <Rectangle x:Name="VeilBottom" Fill="#CC000000" IsHitTestVisible="False"/>
                    <Rectangle x:Name="VeilLeft"   Fill="#CC000000" IsHitTestVisible="False"/>
                    <Rectangle x:Name="VeilRight"  Fill="#CC000000" IsHitTestVisible="False"/>

                    <!-- Selection rectangle with dashed border -->
                    <Rectangle x:Name="CropSelection"
                               Visibility="Collapsed"
                               Fill="#20FFFFFF"
                               IsHitTestVisible="False">
                        <Rectangle.Stroke>
                            <SolidColorBrush Color="White"/>
                        </Rectangle.Stroke>
                        <Rectangle.StrokeThickness>1.5</Rectangle.StrokeThickness>
                        <Rectangle.StrokeDashArray>4 2</Rectangle.StrokeDashArray>
                    </Rectangle>

                    <!-- 8 crop resize handles (corners + edge midpoints) -->
                    <Rectangle x:Name="CropHandleTL" Width="9" Height="9" Fill="{DynamicResource ImageViewer_CropHandleFill}" Stroke="{DynamicResource ImageViewer_CropHandleStroke}" StrokeThickness="1"
                               Cursor="SizeNWSE" Visibility="Collapsed" Panel.ZIndex="10"
                               MouseLeftButtonDown="CropHandle_MouseLeftButtonDown"
                               MouseMove="CropHandle_MouseMove"
                               MouseLeftButtonUp="CropHandle_MouseLeftButtonUp"/>
                    <Rectangle x:Name="CropHandleTC" Width="9" Height="9" Fill="{DynamicResource ImageViewer_CropHandleFill}" Stroke="{DynamicResource ImageViewer_CropHandleStroke}" StrokeThickness="1"
                               Cursor="SizeNS" Visibility="Collapsed" Panel.ZIndex="10"
                               MouseLeftButtonDown="CropHandle_MouseLeftButtonDown"
                               MouseMove="CropHandle_MouseMove"
                               MouseLeftButtonUp="CropHandle_MouseLeftButtonUp"/>
                    <Rectangle x:Name="CropHandleTR" Width="9" Height="9" Fill="{DynamicResource ImageViewer_CropHandleFill}" Stroke="{DynamicResource ImageViewer_CropHandleStroke}" StrokeThickness="1"
                               Cursor="SizeNESW" Visibility="Collapsed" Panel.ZIndex="10"
                               MouseLeftButtonDown="CropHandle_MouseLeftButtonDown"
                               MouseMove="CropHandle_MouseMove"
                               MouseLeftButtonUp="CropHandle_MouseLeftButtonUp"/>
                    <Rectangle x:Name="CropHandleML" Width="9" Height="9" Fill="{DynamicResource ImageViewer_CropHandleFill}" Stroke="{DynamicResource ImageViewer_CropHandleStroke}" StrokeThickness="1"
                               Cursor="SizeWE" Visibility="Collapsed" Panel.ZIndex="10"
                               MouseLeftButtonDown="CropHandle_MouseLeftButtonDown"
                               MouseMove="CropHandle_MouseMove"
                               MouseLeftButtonUp="CropHandle_MouseLeftButtonUp"/>
                    <Rectangle x:Name="CropHandleMR" Width="9" Height="9" Fill="{DynamicResource ImageViewer_CropHandleFill}" Stroke="{DynamicResource ImageViewer_CropHandleStroke}" StrokeThickness="1"
                               Cursor="SizeWE" Visibility="Collapsed" Panel.ZIndex="10"
                               MouseLeftButtonDown="CropHandle_MouseLeftButtonDown"
                               MouseMove="CropHandle_MouseMove"
                               MouseLeftButtonUp="CropHandle_MouseLeftButtonUp"/>
                    <Rectangle x:Name="CropHandleBL" Width="9" Height="9" Fill="{DynamicResource ImageViewer_CropHandleFill}" Stroke="{DynamicResource ImageViewer_CropHandleStroke}" StrokeThickness="1"
                               Cursor="SizeNESW" Visibility="Collapsed" Panel.ZIndex="10"
                               MouseLeftButtonDown="CropHandle_MouseLeftButtonDown"
                               MouseMove="CropHandle_MouseMove"
                               MouseLeftButtonUp="CropHandle_MouseLeftButtonUp"/>
                    <Rectangle x:Name="CropHandleBC" Width="9" Height="9" Fill="{DynamicResource ImageViewer_CropHandleFill}" Stroke="{DynamicResource ImageViewer_CropHandleStroke}" StrokeThickness="1"
                               Cursor="SizeNS" Visibility="Collapsed" Panel.ZIndex="10"
                               MouseLeftButtonDown="CropHandle_MouseLeftButtonDown"
                               MouseMove="CropHandle_MouseMove"
                               MouseLeftButtonUp="CropHandle_MouseLeftButtonUp"/>
                    <Rectangle x:Name="CropHandleBR" Width="9" Height="9" Fill="{DynamicResource ImageViewer_CropHandleFill}" Stroke="{DynamicResource ImageViewer_CropHandleStroke}" StrokeThickness="1"
                               Cursor="SizeNWSE" Visibility="Collapsed" Panel.ZIndex="10"
                               MouseLeftButtonDown="CropHandle_MouseLeftButtonDown"
                               MouseMove="CropHandle_MouseMove"
                               MouseLeftButtonUp="CropHandle_MouseLeftButtonUp"/>

                </Canvas>

            </Grid>
        </ScrollViewer>

        <!-- Crop mode instruction banner -->
        <Border x:Name="CropInstructionBanner"
                Visibility="Collapsed"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,8,0,0"
                Padding="12,5"
                CornerRadius="4"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1">
            <TextBlock Foreground="{DynamicResource DockMenuForegroundBrush}"
                       FontSize="11"
                       Text="Crop Mode — Draw a selection, then press Enter to apply or Escape to cancel"/>
        </Border>
    </Grid>
</UserControl>

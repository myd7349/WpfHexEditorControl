<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <!-- Office-like ContextMenu styles for the ImageViewer.
             Provides IV_ContextMenuStyle, IV_GroupHeaderStyle, IV_GroupSeparatorStyle.
             All colors resolved via DynamicResource (AccentBrush, DockMenu*Brush). -->
        <ResourceDictionary Source="/WpfHexEditor.Editor.ImageViewer;component/Themes/ImageContextMenu.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Fallback values for TE_* keys used by ImageViewer.
         Overridden by the host application's theme ResourceDictionary.
         If WpfHexEditor.Editor.TextEditor is also referenced, that project's
         Generic.xaml provides identical defaults — merging both is safe. -->

    <SolidColorBrush x:Key="TE_Background"           Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TE_LineNumberBackground" Color="#252526"/>
    <SolidColorBrush x:Key="TE_LineNumberForeground" Color="#6E7681"/>

    <!-- Fallback accent brush (overridden by active Docking.Wpf theme) -->
    <SolidColorBrush x:Key="AccentBrush"             Color="#007ACC"/>

    <!-- Fallback DockMenu keys for standalone use without Docking.Wpf theme -->
    <SolidColorBrush x:Key="DockMenuBackgroundBrush"      Color="#2D2D30"/>
    <SolidColorBrush x:Key="DockMenuForegroundBrush"      Color="#F1F1F1"/>
    <SolidColorBrush x:Key="DockMenuBorderBrush"          Color="#333337"/>
    <SolidColorBrush x:Key="DockMenuHighlightBrush"       Color="#3E3E40"/>
    <SolidColorBrush x:Key="DockWindowBackgroundBrush"    Color="#252526"/>

</ResourceDictionary>

<UserControl x:Class="WpfHexEditor.Editor.CodeEditor.Options.CodeEditorOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.CodeEditor.Options"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="500"
             Background="{DynamicResource DockMenuBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}">

    <!-- Code Editor Options Page — IDE global theme compliant -->

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{DynamicResource DockMenuBackgroundBrush}">
        <StackPanel Margin="12,10,12,16" >

            <!-- ── Font ─────────────────────────────────────────────── -->
            <TextBlock Text="Font"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Text="Font family:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <TextBox   Grid.Column="1"
                           Text="{Binding FontFamily, UpdateSourceTrigger=PropertyChanged}"
                           Background="{DynamicResource DockMenuBackgroundBrush}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           BorderBrush="{DynamicResource DockBorderBrush}" />

                <TextBlock Grid.Column="3" Text="Size:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <TextBox   Grid.Column="4"
                           Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}"
                           Background="{DynamicResource DockMenuBackgroundBrush}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           BorderBrush="{DynamicResource DockBorderBrush}" />
            </Grid>

            <Separator Margin="0,4,0,10" Background="{DynamicResource DockBorderBrush}" />

            <!-- ── Indentation ──────────────────────────────────────── -->
            <TextBlock Text="Indentation"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Tab size:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <TextBox   Grid.Column="1"
                           Text="{Binding TabSize, UpdateSourceTrigger=PropertyChanged}"
                           Background="{DynamicResource DockMenuBackgroundBrush}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           BorderBrush="{DynamicResource DockBorderBrush}" />
            </Grid>

            <CheckBox Content="Convert tabs to spaces"
                      IsChecked="{Binding ConvertTabsToSpaces}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <Grid Margin="0,6,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Auto-indent:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <ComboBox  Grid.Column="1"
                           SelectedItem="{Binding AutoIndentMode}"
                           Background="{DynamicResource DockMenuBackgroundBrush}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           BorderBrush="{DynamicResource DockBorderBrush}">
                    <local:AutoIndentMode>None</local:AutoIndentMode>
                    <local:AutoIndentMode>KeepIndent</local:AutoIndentMode>
                    <local:AutoIndentMode>Smart</local:AutoIndentMode>
                </ComboBox>
            </Grid>

            <Separator Margin="0,8,0,10" Background="{DynamicResource DockBorderBrush}" />

            <!-- ── Display ──────────────────────────────────────────── -->
            <TextBlock Text="Display"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="Show line numbers"
                      IsChecked="{Binding ShowLineNumbers}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Show whitespace:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <ComboBox  Grid.Column="2"
                           SelectedItem="{Binding WhitespaceMode}"
                           Background="{DynamicResource DockMenuBackgroundBrush}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           BorderBrush="{DynamicResource DockBorderBrush}"
                           MinWidth="120">
                    <local:WhitespaceDisplayMode>None</local:WhitespaceDisplayMode>
                    <local:WhitespaceDisplayMode>Selection</local:WhitespaceDisplayMode>
                    <local:WhitespaceDisplayMode>Always</local:WhitespaceDisplayMode>
                </ComboBox>
            </Grid>

            <CheckBox Content="Enable code folding"
                      IsChecked="{Binding EnableFolding}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="Toggle fold regions on double-click"
                      IsChecked="{Binding FoldToggleOnDoubleClick}"
                      Margin="16,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="Show scope guides"
                      IsChecked="{Binding ShowScopeGuides}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <Separator Margin="0,8,0,10" Background="{DynamicResource DockBorderBrush}" />

            <!-- ── Features ─────────────────────────────────────────── -->
            <TextBlock Text="Features"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="Enable SmartComplete"
                      IsChecked="{Binding EnableSmartComplete}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="Enable snippets"
                      IsChecked="{Binding EnableSnippets}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="Enable multi-caret editing (Alt+Click)"
                      IsChecked="{Binding EnableMultiCaret}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="Enable Find All References (Shift+F12)"
                      IsChecked="{Binding EnableFindAllReferences}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Requires an active Language Server (LSP) for the current file type" />

            <CheckBox Content="Show Code Lens (inline reference counts)"
                      IsChecked="{Binding ShowInlineHints}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Shows reference count above each declaration. Click the hint to open the References popup." />

            <CheckBox Content="Highlight word under caret"
                      IsChecked="{Binding EnableWordHighlight}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Highlights all occurrences of the word under the cursor and shows tick marks on the scroll bar" />

            <CheckBox Content="Bracket pair colorization"
                      IsChecked="{Binding BracketPairColorization}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Colors brackets with CE_Bracket_1/2/3/4 based on nesting depth (requires bracketPairs in the language's whfmt)" />

            <CheckBox Content="Color swatch preview"
                      IsChecked="{Binding ColorSwatchPreview}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Shows a 12×12 color swatch next to color literals (e.g. #FF5733) in CSS, XAML, C# files" />

            <CheckBox Content="Format on Save (Ctrl+S)"
                      IsChecked="{Binding FormatOnSave}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Automatically formats the document when saving. Uses LSP formatting if available, otherwise applies whfmt indentation rules." />

            <Separator Margin="0,8,0,10" Background="{DynamicResource DockBorderBrush}" />

            <!-- ── Code Formatting (overrides .whfmt) ───────────────── -->
            <TextBlock Text="Code Formatting"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <TextBlock Text="These settings override the language .whfmt defaults. Leave unchecked checkboxes at their default (indeterminate) state to inherit the language rules."
                       TextWrapping="Wrap"
                       FontSize="11"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.65" />

            <CheckBox Content="Trim trailing whitespace"
                      IsThreeState="True"
                      IsChecked="{Binding TrimTrailingWhitespace}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Remove trailing spaces/tabs on each line. Indeterminate = use .whfmt language default." />

            <CheckBox Content="Insert final newline"
                      IsThreeState="True"
                      IsChecked="{Binding InsertFinalNewline}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Ensure the file ends with exactly one newline. Indeterminate = use .whfmt language default." />

            <CheckBox Content="Space after keywords (if, for, while)"
                      IsThreeState="True"
                      IsChecked="{Binding SpaceAfterKeywords}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Insert a space between control keywords and opening paren: if (...) vs if(...). Indeterminate = .whfmt default." />

            <CheckBox Content="Space around binary operators"
                      IsThreeState="True"
                      IsChecked="{Binding SpaceAroundBinaryOperators}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Insert spaces around +, -, *, /, ==, etc. Indeterminate = .whfmt default." />

            <CheckBox Content="Space after commas"
                      IsThreeState="True"
                      IsChecked="{Binding SpaceAfterComma}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Insert a space after commas in argument/parameter lists. Indeterminate = .whfmt default." />

            <CheckBox Content="Indent case/when labels"
                      IsThreeState="True"
                      IsChecked="{Binding IndentCaseLabels}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Add one indent level to case/when labels inside switch. Indeterminate = .whfmt default." />

            <CheckBox Content="Organize imports on format"
                      IsThreeState="True"
                      IsChecked="{Binding OrganizeImports}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Sort using/import directives alphabetically when formatting. Indeterminate = .whfmt default." />

            <Separator Margin="0,8,0,10" Background="{DynamicResource DockBorderBrush}" />

            <!-- ── Syntax Colors ─────────────────────────────────────── -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Syntax Colors"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <Button   Grid.Column="1"
                          x:Name="BtnResetColors"
                          Content="Reset to theme"
                          Padding="8,2"
                          Background="{DynamicResource DockMenuBackgroundBrush}"
                          Foreground="{DynamicResource DockMenuForegroundBrush}"
                          BorderBrush="{DynamicResource DockBorderBrush}"
                          Click="OnResetColorsClick" />
            </Grid>

            <!-- Token color rows — populated from code-behind via SyntaxColorRows ItemsSource -->
            <ItemsControl x:Name="SyntaxColorRowsList"
                          Background="Transparent">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Each item: SyntaxColorRow (label, swatch, pick button, popup) -->
                        <Grid Margin="0,3,0,3" Height="26">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="52" />
                            </Grid.ColumnDefinitions>

                            <!-- Token kind label -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Label}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

                            <!-- Color swatch (filled with current color) -->
                            <Border Grid.Column="1"
                                    Width="20" Height="16"
                                    CornerRadius="2"
                                    BorderBrush="{DynamicResource DockBorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    Background="{Binding SwatchBrush}" />

                            <!-- Hex value text -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding HexText}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

                            <!-- Pick button — opens the ColorPicker popup -->
                            <Button Grid.Column="3"
                                    Content="Pick"
                                    Padding="4,2"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource DockMenuBackgroundBrush}"
                                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                                    BorderBrush="{DynamicResource DockBorderBrush}"
                                    Tag="{Binding}"
                                    Click="OnPickColorClick" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>

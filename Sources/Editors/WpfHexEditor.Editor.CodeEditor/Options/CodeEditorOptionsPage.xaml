<UserControl x:Class="WpfHexEditor.Editor.CodeEditor.Options.CodeEditorOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.CodeEditor.Options"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="500"
             Background="{DynamicResource DockMenuBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}"
             xmlns:codeSvc="clr-namespace:WpfHexEditor.Editor.CodeEditor.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <codeSvc:CodeEditorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <!-- Code Editor Options Page — IDE global theme compliant -->

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{DynamicResource DockMenuBackgroundBrush}">
        <StackPanel Margin="12,10,12,16" >

            <!-- ── Font ─────────────────────────────────────────────── -->
            <TextBlock Text="{StaticResource CodeEditorOptions_FontSection}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Text="{StaticResource CodeEditorOptions_FontFamilyLabel}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <TextBox   Grid.Column="1"
                           Text="{Binding FontFamily, UpdateSourceTrigger=PropertyChanged}"
                           Background="{DynamicResource DockMenuBackgroundBrush}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           BorderBrush="{DynamicResource DockBorderBrush}" />

                <TextBlock Grid.Column="3" Text="{StaticResource CodeEditorOptions_FontSizeLabel}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <TextBox   Grid.Column="4"
                           Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}"
                           Background="{DynamicResource DockMenuBackgroundBrush}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           BorderBrush="{DynamicResource DockBorderBrush}" />
            </Grid>

            <Separator Margin="0,4,0,10" Background="{DynamicResource DockBorderBrush}" />

            <!-- ── Indentation ──────────────────────────────────────── -->
            <TextBlock Text="{StaticResource CodeEditorOptions_IndentationSection}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{StaticResource CodeEditorOptions_TabSizeLabel}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <TextBox   Grid.Column="1"
                           Text="{Binding TabSize, UpdateSourceTrigger=PropertyChanged}"
                           Background="{DynamicResource DockMenuBackgroundBrush}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           BorderBrush="{DynamicResource DockBorderBrush}" />
            </Grid>

            <CheckBox Content="{StaticResource CodeEditorOptions_ConvertTabsContent}"
                      IsChecked="{Binding ConvertTabsToSpaces}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <Grid Margin="0,6,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{StaticResource CodeEditorOptions_AutoIndentLabel}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <ComboBox  Grid.Column="1"
                           SelectedItem="{Binding AutoIndentMode}"
                           Background="{DynamicResource DockMenuBackgroundBrush}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           BorderBrush="{DynamicResource DockBorderBrush}">
                    <local:AutoIndentMode>None</local:AutoIndentMode>
                    <local:AutoIndentMode>KeepIndent</local:AutoIndentMode>
                    <local:AutoIndentMode>Smart</local:AutoIndentMode>
                </ComboBox>
            </Grid>

            <Separator Margin="0,8,0,10" Background="{DynamicResource DockBorderBrush}" />

            <!-- ── Display ──────────────────────────────────────────── -->
            <TextBlock Text="{StaticResource CodeEditorOptions_DisplaySection}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_ShowLineNumbersContent}"
                      IsChecked="{Binding ShowLineNumbers}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <Grid Margin="0,2,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{StaticResource CodeEditorOptions_ShowWhitespaceLabel}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <ComboBox  Grid.Column="2"
                           SelectedItem="{Binding WhitespaceMode}"
                           Background="{DynamicResource DockMenuBackgroundBrush}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           BorderBrush="{DynamicResource DockBorderBrush}"
                           MinWidth="120">
                    <local:WhitespaceDisplayMode>None</local:WhitespaceDisplayMode>
                    <local:WhitespaceDisplayMode>Selection</local:WhitespaceDisplayMode>
                    <local:WhitespaceDisplayMode>Always</local:WhitespaceDisplayMode>
                </ComboBox>
            </Grid>

            <CheckBox Content="{StaticResource CodeEditorOptions_CodeFoldingContent}"
                      IsChecked="{Binding EnableFolding}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_FoldToggleContent}"
                      IsChecked="{Binding FoldToggleOnDoubleClick}"
                      Margin="16,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_ScopeGuidesContent}"
                      IsChecked="{Binding ShowScopeGuides}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <Separator Margin="0,8,0,10" Background="{DynamicResource DockBorderBrush}" />

            <!-- ── Features ─────────────────────────────────────────── -->
            <TextBlock Text="{StaticResource CodeEditorOptions_FeaturesSection}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_SmartCompleteContent}"
                      IsChecked="{Binding EnableSmartComplete}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_SnippetsContent}"
                      IsChecked="{Binding EnableSnippets}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_MultiCaretContent}"
                      IsChecked="{Binding EnableMultiCaret}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_FindAllRefsContent}"
                      IsChecked="{Binding EnableFindAllReferences}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_FindAllRefsToolTip}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_CodeLensContent}"
                      IsChecked="{Binding ShowInlineHints}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_CodeLensToolTip}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_WordHighlightContent}"
                      IsChecked="{Binding EnableWordHighlight}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_WordHighlightToolTip}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_BracketColorizeContent}"
                      IsChecked="{Binding BracketPairColorization}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_BracketColorizeToolTip}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_ColorSwatchContent}"
                      IsChecked="{Binding ColorSwatchPreview}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_ColorSwatchToolTip}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_FormatOnSaveContent}"
                      IsChecked="{Binding FormatOnSave}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_FormatOnSaveToolTip}" />

            <Separator Margin="0,8,0,10" Background="{DynamicResource DockBorderBrush}" />

            <!-- ── Code Formatting (overrides .whfmt) ───────────────── -->
            <TextBlock Text="{StaticResource CodeEditorOptions_CodeFormattingSection}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

            <TextBlock Text="{StaticResource CodeEditorOptions_CodeFormattingInfo}"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Margin="0,0,0,8"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.65" />

            <CheckBox Content="{StaticResource CodeEditorOptions_TrimTrailingContent}"
                      IsThreeState="True"
                      IsChecked="{Binding TrimTrailingWhitespace}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_TrimTrailingToolTip}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_InsertFinalNewlineContent}"
                      IsThreeState="True"
                      IsChecked="{Binding InsertFinalNewline}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_InsertFinalNewlineToolTip}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_SpaceAfterKeywordsContent}"
                      IsThreeState="True"
                      IsChecked="{Binding SpaceAfterKeywords}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_SpaceAfterKeywordsToolTip}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_SpaceAroundOpsContent}"
                      IsThreeState="True"
                      IsChecked="{Binding SpaceAroundBinaryOperators}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_SpaceAroundOpsToolTip}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_SpaceAfterCommaContent}"
                      IsThreeState="True"
                      IsChecked="{Binding SpaceAfterComma}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_SpaceAfterCommaToolTip}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_IndentCaseLabelsContent}"
                      IsThreeState="True"
                      IsChecked="{Binding IndentCaseLabels}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_IndentCaseLabelsToolTip}" />

            <CheckBox Content="{StaticResource CodeEditorOptions_OrganizeImportsContent}"
                      IsThreeState="True"
                      IsChecked="{Binding OrganizeImports}"
                      Margin="0,2,0,2"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="{StaticResource CodeEditorOptions_OrganizeImportsToolTip}" />

            <Separator Margin="0,8,0,10" Background="{DynamicResource DockBorderBrush}" />

            <!-- ── Syntax Colors ─────────────────────────────────────── -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{StaticResource CodeEditorOptions_SyntaxColorsSection}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <Button   Grid.Column="1"
                          x:Name="BtnResetColors"
                          Content="{StaticResource CodeEditorOptions_ResetColorsButton}"
                          Padding="8,2"
                          Background="{DynamicResource DockMenuBackgroundBrush}"
                          Foreground="{DynamicResource DockMenuForegroundBrush}"
                          BorderBrush="{DynamicResource DockBorderBrush}"
                          Click="OnResetColorsClick" />
            </Grid>

            <!-- Token color rows — populated from code-behind via SyntaxColorRows ItemsSource -->
            <ItemsControl x:Name="SyntaxColorRowsList"
                          Background="Transparent">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Each item: SyntaxColorRow (label, swatch, pick button, popup) -->
                        <Grid Margin="0,3,0,3" Height="26">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="52" />
                            </Grid.ColumnDefinitions>

                            <!-- Token kind label -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Label}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

                            <!-- Color swatch (filled with current color) -->
                            <Border Grid.Column="1"
                                    Width="20" Height="16"
                                    CornerRadius="2"
                                    BorderBrush="{DynamicResource DockBorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    Background="{Binding SwatchBrush}" />

                            <!-- Hex value text -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding HexText}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}" />

                            <!-- Pick button — opens the ColorPicker popup -->
                            <Button Grid.Column="3"
                                    Content="{StaticResource CodeEditorOptions_ColorPickButton}"
                                    Padding="4,2"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource DockMenuBackgroundBrush}"
                                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                                    BorderBrush="{DynamicResource DockBorderBrush}"
                                    Tag="{Binding}"
                                    Click="OnPickColorClick" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>

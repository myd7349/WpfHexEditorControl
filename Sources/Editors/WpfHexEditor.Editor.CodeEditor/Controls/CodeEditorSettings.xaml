<UserControl x:Class="WpfHexEditor.Editor.CodeEditor.Controls.CodeEditorSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Background="{DynamicResource TE_Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8"
                TextElement.Foreground="{DynamicResource Panel_ToolbarForegroundBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ResetButton" Content="ðŸ”„ Reset to Defaults" Padding="8,4" Margin="0,0,5,0"
                        ToolTip="Reset all settings to default values"
                        Click="ResetButton_Click"/>
                <Button x:Name="ExportButton" Content="ðŸ’¾ Export Settings" Padding="8,4" Margin="0,0,5,0"
                        ToolTip="Export settings to JSON file"
                        Click="ExportButton_Click"/>
                <Button x:Name="ImportButton" Content="ðŸ“‚ Import Settings" Padding="8,4"
                        ToolTip="Import settings from JSON file"
                        Click="ImportButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Main Content: Split between Settings and Preview -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Settings Panel (Left) -->
            <ScrollViewer x:Name="SettingsScrollViewer" Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource TE_Background}">
                <!-- Content will be generated dynamically via DynamicSettingsGenerator -->
            </ScrollViewer>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockSplitterBrush}"/>

            <!-- Preview Pane (Right) -->
            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                    BorderThickness="1,0,0,0"
                    Background="{DynamicResource TE_Background}">
                <DockPanel>
                    <!-- Preview Header -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource SE_GroupHeaderBrush}"
                            BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8">
                        <TextBlock Text="ðŸ“ Live Preview"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Border>

                    <!-- Preview Content -->
                    <Grid>
                        <Border x:Name="PreviewBorder"
                                Margin="10"
                                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                                BorderThickness="1">
                            <!-- CodeEditor preview will be added here programmatically -->
                            <TextBlock x:Name="PreviewPlaceholder"
                                       Text="Preview will appear here when a CodeEditor is connected"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource PFP_SubTextBrush}"
                                       FontStyle="Italic"/>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

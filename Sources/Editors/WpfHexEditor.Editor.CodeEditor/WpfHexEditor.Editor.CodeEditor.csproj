<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>WpfHexEditor.Editor.CodeEditor</RootNamespace>
    <AssemblyName>WpfHexEditor.Editor.CodeEditor</AssemblyName>
    <NeutralLanguage>en-US</NeutralLanguage>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- NuGet package metadata -->
    <PackageId>WpfCodeEditor</PackageId>
    <Version>0.10.0.0</Version>
    <AssemblyVersion>0.10.0.0</AssemblyVersion>
    <FileVersion>0.10.0.0</FileVersion>
    <Authors>Derek Tremblay</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Product>WpfCodeEditor</Product>
    <Title>WpfCodeEditor - WPF Code Editor UserControl</Title>
    <Description>A full-featured WPF code editor UserControl for .NET 8. Syntax highlighting for 57+ languages via .whfmt syntaxDefinition (consumed from whfmt.FileFormatCatalog), Roslyn-powered IntelliSense + analyzers + refactorings, code folding, multi-caret editing, dynamic snippets with variable expansion, LSP semantic token colorization, Ctrl+Click navigation, inline hints / reference counts, debug data-tips, search and replace, split view, line numbers, minimap, and more. Zero external dependencies (no AvalonEdit / ICSharpCode).</Description>
    <Copyright>GNU AGPL v3.0 - 2016-2026</Copyright>
    <PackageTags>codeeditor;code;editor;wpf;usercontrol;syntax-highlighting;lsp;autocomplete;folding;minimap</PackageTags>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorIDE</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorIDE</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReadmeFile>PACKAGE_README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReleaseNotes>0.10.0.0 — Embedded language injection: <script>/</script> blocks in HTML files are now syntax-highlighted as JavaScript, and <style>/</style> blocks as CSS. Runtime-generic: any language can declare embeddedLanguages[] zones in its .whfmt — PHP-in-HTML, Vue SFC, Svelte, Markdown fences are supported with zero additional runtime changes. New public types: EmbeddedSyntaxHighlighter, EmbeddedRangeClassifier (WpfHexEditor.Core.ProjectSystem). 0.9.9.0 — Phase 9 Inline Code Actions (Ctrl+. / lightbulb) with CodeActionRegistry + 3 mechanical fixers + Suppress-here; Refactor ▶ context menu + preview dialog + orchestrator (UI1-UI5); Phase 10B Duplication tab redesign (master/detail + side-by-side diff); Dynamic Snippets with variable expansion + user snippet store (#88); Phase 1 Debugger integration (Data Tips, Autos, edit-in-place, Run to Cursor); IDebugValueProvider + DebugValueHintsLayer contract; +10 new localizations (uk-UA, cs-CZ, vi-VN, hu-HU, ro-RO, id-ID, th-TH, el-GR, da-DK, fi-FI). 0.9.8.0 — LSP semantic token colorization; zoom snap-to-pixel; IReferenceCountProvider inline hints; Ctrl+Click links/emails; minimap scroll fix; SourceLink + satellite assemblies now correctly bundled.</PackageReleaseNotes>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591;NU5100</NoWarn>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>

    <!-- SourceLink: enables step-through debugging for NuGet consumers -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <DebugType>embedded</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>WpfHexEditor.Editor.CodeEditor.Tests</_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>WpfHexEditor.App</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <None Include="PACKAGE_README.md" Pack="true" PackagePath="\" />
    <None Include="WpfCodeEditor-guide.md" Pack="true" PackagePath="\" />
    <None Include="icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.*" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Plugins\WpfHexEditor.SDK\WpfHexEditor.SDK.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.Events\WpfHexEditor.Core.Events.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core\WpfHexEditor.Core.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\WpfHexEditor.Editor.Core\WpfHexEditor.Editor.Core.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\WpfHexEditor.Editor.TextEditor\WpfHexEditor.Editor.TextEditor.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.Definitions\WpfHexEditor.Core.Definitions.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.ProjectSystem\WpfHexEditor.Core.ProjectSystem.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Controls\WpfHexEditor.ColorPicker\WpfHexEditor.ColorPicker.csproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.Localization\WpfHexEditor.Core.Localization.csproj" PrivateAssets="all" />
  </ItemGroup>

  <!-- Bundle only the explicitly required dependency DLLs into the NuGet package.
       Whitelist approach prevents transitive assemblies from unrelated projects
       (ResxEditor, Debugger, Diff, Docking, etc.) polluting the package when the
       solution is built and all output lands in the same bin folder. -->
  <PropertyGroup>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);CopyProjectReferencesToPackage</TargetsForTfmSpecificBuildOutput>
  </PropertyGroup>
  <Target Name="CopyProjectReferencesToPackage" DependsOnTargets="ResolveReferences">
    <ItemGroup>
      <_BundledProjectDll Include="
        $(OutputPath)WpfHexEditor.SDK.dll;
        $(OutputPath)WpfHexEditor.Core.Events.dll;
        $(OutputPath)WpfHexEditor.Core.dll;
        $(OutputPath)WpfHexEditor.Core.BinaryAnalysis.dll;
        $(OutputPath)WpfHexEditor.Core.Contracts.dll;
        $(OutputPath)WpfHexEditor.Core.Definitions.dll;
        $(OutputPath)WpfHexEditor.Core.Localization.dll;
        $(OutputPath)WpfHexEditor.Core.ProjectSystem.dll;
        $(OutputPath)WpfHexEditor.Editor.Core.dll;
        $(OutputPath)WpfHexEditor.Editor.TextEditor.dll;
        $(OutputPath)WpfHexEditor.ColorPicker.dll" />

      <BuildOutputInPackage Include="@(_BundledProjectDll)" Condition="Exists('%(Identity)')" />

      <BuildOutputInPackage Include="@(_BundledProjectDll->'%(RootDir)%(Directory)%(Filename).xml')"
                            Condition="Exists('%(RootDir)%(Directory)%(Filename).xml')" />
    </ItemGroup>
  </Target>

  <!--
    Satellite assemblies: glob each culture subfolder in OutputPath.
  -->
  <Target Name="IncludeSatelliteAssembliesInPackage" AfterTargets="CopyProjectReferencesToPackage">
    <ItemGroup>
      <_AllSatellites Include="$(OutputPath)*\*.resources.dll" />
      <_AllSatellites Remove="$(OutputPath)*\WpfHexEditor.Editor.CodeEditor.resources.dll" />
      <TfmSpecificPackageFile Include="@(_AllSatellites)"
                              Condition="'%(Filename)' == 'WpfHexEditor.SDK.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Core.Events.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Core.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Core.BinaryAnalysis.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Core.Contracts.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Core.Definitions.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Core.Localization.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Core.ProjectSystem.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Editor.Core.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.Editor.TextEditor.resources'
                                      Or '%(Filename)' == 'WpfHexEditor.ColorPicker.resources'"
                              PackagePath="%(RecursiveDir)%(Filename)%(Extension)" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <Compile Update="Properties\CodeEditorResources.Designer.cs">
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
      <DependentUpon>CodeEditorResources.resx</DependentUpon>
      <DesignTime>True</DesignTime>
    </Compile>
    <EmbeddedResource Update="Properties\CodeEditorResources.resx">
      <SubType>Designer</SubType>
      <LastGenOutput>CodeEditorResources.Designer.cs</LastGenOutput>
      <Generator>ResXFileCodeGenerator</Generator>
    </EmbeddedResource>
  </ItemGroup>
</Project>

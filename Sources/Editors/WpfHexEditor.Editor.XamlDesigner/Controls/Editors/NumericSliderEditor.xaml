<UserControl x:Class="WpfHexEditor.Editor.XamlDesigner.Controls.Editors.NumericSliderEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="22">

    <!-- ==========================================================
         File: NumericSliderEditor.xaml
         Created: 2026-03-17
         Description: Inline numeric editor with a TextBox and a mini slider.
                      Used for double/float/int properties.
         ========================================================== -->

    <StackPanel Orientation="Horizontal">
        <TextBox x:Name="TbValue" Width="52" Height="18" FontSize="11"
                 Text="{Binding DisplayValue, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=LostFocus}"
                 Background="Transparent"
                 Foreground="{DynamicResource XD_PropertyValueForeground}"
                 BorderBrush="{DynamicResource DockBorderBrush}"
                 BorderThickness="1"
                 VerticalContentAlignment="Center" Padding="2,0"
                 Margin="0,0,4,0"/>
        <Slider x:Name="SliderValue"
                Width="80" VerticalAlignment="Center"
                Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Value="{Binding Value,     RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                SmallChange="{Binding SmallChange, RelativeSource={RelativeSource AncestorType=UserControl}}"
                LargeChange="{Binding LargeChange, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </StackPanel>
</UserControl>

<UserControl x:Class="WpfHexEditor.Editor.EntropyViewer.Controls.EntropyViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ev="clr-namespace:WpfHexEditor.Editor.EntropyViewer.Controls"
             Background="{DynamicResource TE_Background}"
             Focusable="True"
             xmlns:evSvc="clr-namespace:WpfHexEditor.Editor.EntropyViewer.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <evSvc:EntropyViewerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Background="{DynamicResource TE_LineNumberBackground}">
            <TextBlock Text="{StaticResource EntropyViewer_WindowLabel}" VerticalAlignment="Center" Padding="4,0"
                       Foreground="{DynamicResource TE_LineNumberForeground}"/>
            <ComboBox x:Name="WindowSizeCombo" Width="80"
                      SelectionChanged="OnWindowSizeChanged">
                <ComboBoxItem Content="{StaticResource EntropyViewer_256B}"   Tag="256"  />
                <ComboBoxItem Content="{StaticResource EntropyViewer_512B}"   Tag="512"  />
                <ComboBoxItem Content="{StaticResource EntropyViewer_1KB}"    Tag="1024" IsSelected="True"/>
                <ComboBoxItem Content="{StaticResource EntropyViewer_4KB}"    Tag="4096" />
                <ComboBoxItem Content="{StaticResource EntropyViewer_16KB}"   Tag="16384"/>
            </ComboBox>
            <Separator/>
            <CheckBox x:Name="ShowRegionsCheck" Content="{StaticResource EntropyViewer_Regions}"
                      IsChecked="True"
                      VerticalAlignment="Center" Margin="2,0"
                      Foreground="{DynamicResource TE_LineNumberForeground}"
                      Checked="OnShowRegionsChanged" Unchecked="OnShowRegionsChanged"/>
            <CheckBox x:Name="ShowThresholdCheck" Content="{StaticResource EntropyViewer_Threshold}"
                      IsChecked="True"
                      VerticalAlignment="Center" Margin="2,0"
                      Foreground="{DynamicResource TE_LineNumberForeground}"
                      Checked="OnShowThresholdChanged" Unchecked="OnShowThresholdChanged"/>
            <Separator/>
            <TextBlock x:Name="EntropyText" Text="—" VerticalAlignment="Center" Padding="4,0"
                       Foreground="{DynamicResource TE_LineNumberForeground}"/>
        </ToolBar>

        <!-- Charts area -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource TE_Background}">
            <StackPanel>
                <!-- Entropy chart header -->
                <TextBlock Text="{StaticResource EntropyViewer_RegionChart}"
                           Margin="8,8,8,2"
                           Foreground="{DynamicResource TE_LineNumberForeground}"
                           FontSize="11"/>
                <Border Margin="8,0,8,0" BorderThickness="1"
                        BorderBrush="{DynamicResource TE_LineNumberBackground}">
                    <ev:EntropyBarCanvas x:Name="EntropyCanvas" Height="100"
                                         Cursor="Hand"
                                         HoverChanged="OnEntropyHoverChanged"
                                         OffsetRequested="OnEntropyOffsetRequested"/>
                </Border>

                <!-- Byte distribution header -->
                <TextBlock Text="{StaticResource EntropyViewer_ByteDist}" Margin="8,10,8,2"
                           Foreground="{DynamicResource TE_LineNumberForeground}"
                           FontSize="11"/>
                <Border Margin="8,0,8,0" BorderThickness="1"
                        BorderBrush="{DynamicResource TE_LineNumberBackground}">
                    <ev:ByteFreqCanvas x:Name="FreqCanvas" Height="100"/>
                </Border>

                <!-- Statistics text -->
                <TextBlock x:Name="StatsText" Margin="8,10,8,8"
                           Foreground="{DynamicResource TE_Foreground}"
                           FontFamily="Consolas, Courier New"
                           FontSize="11"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <StatusBar Grid.Row="2"
                   Background="{DynamicResource TE_LineNumberBackground}"
                   Foreground="{DynamicResource TE_LineNumberForeground}"
                   Height="22">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="—" Padding="4,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>

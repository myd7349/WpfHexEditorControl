<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>WpfHexEditor.Editor.EntropyViewer</RootNamespace>
    <AssemblyName>WpfHexEditor.Editor.EntropyViewer</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- NuGet packaging -->
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>WpfHexEditor.Editor.EntropyViewer</PackageId>
    <Version>1.0.0</Version>
    <Authors>WpfHexEditor Contributors</Authors>
    <Description>Entropy and byte-distribution analyser for WpfHexEditor — implements IDocumentEditor. Zero WPF-Core dependency.</Description>
    <PackageTags>wpf;hex;editor;entropy;analysis;binary</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorControl</RepositoryUrl>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\WpfHexEditor.Editor.Core\WpfHexEditor.Editor.Core.csproj" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.BinaryAnalysis\WpfHexEditor.Core.BinaryAnalysis.csproj" />
  </ItemGroup>

</Project>

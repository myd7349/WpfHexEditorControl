    Description:
        Main grid-based RESX editor UserControl.
        No embedded toolbar — all editing commands exposed via
        IEditorToolbarContributor and IDocumentEditor so the
        host can wire them into its own toolbar/menu surface.
-->

<UserControl x:Class="WpfHexEditor.Editor.ResxEditor.Controls.ResxEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.ResxEditor.Controls"
             xmlns:vm="clr-namespace:WpfHexEditor.Editor.ResxEditor.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource RES_BackgroundBrush}"
             Foreground="{DynamicResource RES_ForegroundBrush}"
             KeyDown="UserControl_KeyDown">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- DataGrid column header style -->
        <Style x:Key="ResxColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"                 Value="{DynamicResource RES_HeaderBackgroundBrush}"/>
            <Setter Property="Foreground"                 Value="{DynamicResource RES_HeaderForegroundBrush}"/>
            <Setter Property="BorderBrush"                Value="{DynamicResource RES_SeparatorBrush}"/>
            <Setter Property="BorderThickness"            Value="0,0,1,1"/>
            <Setter Property="Padding"                    Value="6,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="SeparatorVisibility"        Value="Collapsed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border x:Name="HeaderBd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGridCell style — overrides system highlight colour -->
        <Style x:Key="ResxCellStyle" TargetType="DataGridCell">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource RES_ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="True" Margin="4,2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RES_SelectedRowBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource RES_SelectedRowForegroundBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RES_HoverRowBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGridRow style — alternating rows + duplicate highlight -->
        <Style x:Key="ResxRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource RES_RowAlternateBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding HasValidationError}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RES_DuplicateKeyBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Type badge pill style -->
        <Style x:Key="TypeBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius"  Value="3"/>
            <Setter Property="Padding"       Value="5,1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Cell templates for Value column -->

        <!-- String template (default) -->
        <DataTemplate x:Key="StringCellTemplate">
            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource RES_ForegroundBrush}"
                     VerticalAlignment="Center"
                     AcceptsReturn="False"
                     TextWrapping="NoWrap"/>
        </DataTemplate>

        <!-- Image thumbnail template -->
        <DataTemplate x:Key="ImageCellTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🖼" FontSize="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Value}" Foreground="{DynamicResource RES_CommentForegroundBrush}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
            </StackPanel>
        </DataTemplate>

        <!-- Binary / byte array template -->
        <DataTemplate x:Key="BinaryCellTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="▦" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource RES_BinaryTypeBadgeBrush}"/>
                <TextBlock Foreground="{DynamicResource RES_CommentForegroundBrush}"
                           VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} bytes">
                            <Binding Path="Value.Length"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- File reference template -->
        <DataTemplate x:Key="FileRefCellTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🗄" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Value}" Foreground="{DynamicResource RES_CommentForegroundBrush}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="240"/>
            </StackPanel>
        </DataTemplate>

        <!-- Resource-key → Brush converter for type badges -->
        <local:ResourceKeyToBrushConverter x:Key="BrushKeyConverter"/>

        <!-- Cell template selector -->
        <local:ResxCellTemplateSelector x:Key="CellSelector"
            StringTemplate="{StaticResource StringCellTemplate}"
            ImageTemplate="{StaticResource ImageCellTemplate}"
            BinaryTemplate="{StaticResource BinaryCellTemplate}"
            FileRefTemplate="{StaticResource FileRefCellTemplate}"/>

    </UserControl.Resources>

    <Grid>

        <!-- Main entry DataGrid -->
        <DataGrid
                  x:Name="EntriesGrid"
                  ItemsSource="{Binding FilteredEntries}"
                  SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  SelectionMode="Single"
                  AlternationCount="2"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  RowStyle="{StaticResource ResxRowStyle}"
                  CellStyle="{StaticResource ResxCellStyle}"
                  ColumnHeaderStyle="{StaticResource ResxColumnHeaderStyle}"
                  Background="{DynamicResource RES_BackgroundBrush}"
                  Foreground="{DynamicResource RES_ForegroundBrush}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource RES_SeparatorBrush}"
                  BorderThickness="0"
                  RowHeight="24"
                  FontSize="12"
                  SelectionChanged="EntriesGrid_SelectionChanged"
                  CellEditEnding="EntriesGrid_CellEditEnding"
                  LoadingRow="EntriesGrid_LoadingRow">

            <DataGrid.Columns>

                <!-- Key (Name) column -->
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                    Width="200"
                                    MinWidth="80"/>

                <!-- Type badge column (read-only) -->
                <DataGridTemplateColumn Header="Type" Width="80" MinWidth="60" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource TypeBadgeStyle}"
                                    Background="{Binding TypeBadgeBrushKey, Converter={StaticResource BrushKeyConverter}, TargetNullValue=Transparent}">
                                <TextBlock Text="{Binding TypeBadgeLabel}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Value column — type-aware template -->
                <DataGridTemplateColumn Header="Value"
                                        Width="2*" MinWidth="120"
                                        CellTemplateSelector="{StaticResource CellSelector}">
                </DataGridTemplateColumn>

                <!-- Comment column — inline editable -->
                <DataGridTemplateColumn Header="Comment"
                                        Width="*" MinWidth="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource RES_CommentForegroundBrush}"
                                     VerticalAlignment="Center"
                                     AcceptsReturn="False"
                                     TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>

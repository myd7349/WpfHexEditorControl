<!--
==========================================================
Project: WpfHexEditor.Editor.MarkdownEditor
File: Themes/MdContextMenu.xaml
Author: Derek Tremblay (derektremblay666@gmail.com)
Contributors: Claude Sonnet 4.6
Created: 2026-03-22
Description:
    Office-like ContextMenu styles for the MarkdownEditor.
    Provides a 4px colored accent band on the left edge of the
    popup, plus non-interactive group-header labels between
    logical sections.

Architecture Notes:
    All colors resolved via DynamicResource — adapts automatically
    to all application themes without modification.
    Keys used (same tokens as ImageViewer):
      AccentBrush               — 4px left accent band
      DockMenuBackgroundBrush   — popup background
      DockMenuForegroundBrush   — item text
      DockMenuBorderBrush       — outer border + separator line
      DockMenuHighlightBrush    — hover background
      DockMenuHighlightBorderBrush — hover border (light themes only)

    MD_ContextMenuStyle    — ContextMenu popup with left accent band
    MD_GroupHeaderStyle    — Non-interactive section label
    MD_GroupSeparatorStyle — Thin horizontal line above each header
==========================================================
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================================
         MD_ContextMenuStyle
         ContextMenu popup with a 4px AccentBrush left band and drop shadow.
         =================================================================== -->
    <Style x:Key="MD_ContextMenuStyle" TargetType="{x:Type ContextMenu}">
        <Setter Property="Background"  Value="{DynamicResource DockMenuBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DockMenuBorderBrush}"/>
        <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="Padding"     Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <!-- Outer margin reserves room for the drop shadow on all sides -->
                    <Grid Margin="6">
                        <!-- Layer 1: shadow backing -->
                        <Border CornerRadius="4"
                                Background="{DynamicResource DockMenuBackgroundBrush}">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="10"
                                                  ShadowDepth="0" Opacity="0.45"/>
                            </Border.Effect>
                        </Border>

                        <!-- Layer 2: clipped content with accent band -->
                        <Border CornerRadius="4"
                                Background="{DynamicResource DockMenuBackgroundBrush}"
                                BorderBrush="{DynamicResource DockMenuBorderBrush}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- 4px accent band -->
                                    <ColumnDefinition Width="4"/>
                                    <!-- items area -->
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Accent band -->
                                <Border Grid.Column="0"
                                        Background="{DynamicResource AccentBrush}"
                                        CornerRadius="4,0,0,4"/>

                                <!-- Items -->
                                <Grid Grid.Column="1" Grid.IsSharedSizeScope="True">
                                    <ItemsPresenter Margin="0,2"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================================================================
         MD_GroupHeaderStyle
         Non-interactive uppercase section label — acts as a visual divider.
         Use as: <MenuItem Header="VIEW" Style="{StaticResource MD_GroupHeaderStyle}"/>
         =================================================================== -->
    <Style x:Key="MD_GroupHeaderStyle" TargetType="{x:Type MenuItem}">
        <Setter Property="IsHitTestVisible"  Value="False"/>
        <Setter Property="IsEnabled"         Value="False"/>
        <Setter Property="Foreground"        Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="Background"        Value="Transparent"/>
        <Setter Property="BorderThickness"   Value="0"/>
        <Setter Property="Focusable"         Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border Padding="8,5,8,3" Background="Transparent">
                        <TextBlock Text="{TemplateBinding Header}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.55"
                                   Foreground="{TemplateBinding Foreground}"
                                   SnapsToDevicePixels="True"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================================================================
         MD_GroupSeparatorStyle
         Thin separator used between logical sections in the context menu.
         =================================================================== -->
    <Style x:Key="MD_GroupSeparatorStyle" TargetType="{x:Type Separator}">
        <Setter Property="Background" Value="{DynamicResource DockMenuBorderBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Height="1" Margin="4,2" Background="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

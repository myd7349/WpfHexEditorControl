     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude Sonnet 4.6
     Created: 2026-03-19
     Description:
         WPF host for the WebView2 Chromium-based Markdown preview.
         Displays a fallback message when the WebView2 runtime is absent.

     Theme: Applies MD_PreviewBackground / MD_PreviewBorder tokens.
     ========================================================== -->
<UserControl x:Class="WpfHexEditor.Editor.MarkdownEditor.Controls.MarkdownPreviewPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.Editor.MarkdownEditor;component/Themes/MdContextMenu.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Context menu is built in code-behind (BuildContextMenu) so Fullscreen
         item can be updated dynamically when fullscreen state changes. -->

    <Grid>
        <!-- WebView2 (WinForms) inside WindowsFormsHost — Stretch ensures the HWND fills its Grid cell.
             Margin="1" keeps the HWND 1 px away from the panel edge so the docking selection
             border (drawn in WPF below the HWND) is not occluded by the Win32 airspace surface. -->
        <WindowsFormsHost x:Name="_webViewHost"
                          Visibility="Collapsed"
                          Margin="2"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

        <!-- Shown while WebView2 is initializing -->
        <Border x:Name="_loadingOverlay"
                Background="{DynamicResource MD_PreviewBackground}">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       FontSize="12"
                       Text="Initializing preview…" />
        </Border>

        <!-- Fallback: shown when WebView2 runtime is not installed -->
        <Border x:Name="_fallback"
                Visibility="Collapsed"
                Background="{DynamicResource MD_PreviewBackground}"
                BorderBrush="{DynamicResource MD_PreviewBorder}"
                BorderThickness="1">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="24">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           TextAlignment="Center"
                           Text="WebView2 Runtime Not Found" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="320"
                           Text="The Markdown preview requires Microsoft Edge WebView2 Runtime. Download it from microsoft.com/edge/webview2." />
            </StackPanel>
        </Border>
    </Grid>

</UserControl>

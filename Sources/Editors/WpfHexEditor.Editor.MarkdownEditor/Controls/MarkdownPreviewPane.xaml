     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude Sonnet 4.6
     Created: 2026-03-19
     Description:
         WPF host for the WebView2 Chromium-based Markdown preview.
         Displays a fallback message when the WebView2 runtime is absent.

     Theme: Applies MD_PreviewBackground / MD_PreviewBorder tokens.
     ========================================================== -->
<UserControl x:Class="WpfHexEditor.Editor.MarkdownEditor.Controls.MarkdownPreviewPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.Editor.MarkdownEditor;component/Themes/MdContextMenu.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.ContextMenu>
        <ContextMenu Style="{StaticResource MD_ContextMenuStyle}">
            <!-- VIEW group -->
            <MenuItem Header="VIEW" Style="{StaticResource MD_GroupHeaderStyle}"/>
            <MenuItem Header="Source Only"   InputGestureText="Ctrl+1" Click="OnCtxSourceOnly"/>
            <MenuItem Header="Split View"    InputGestureText="Ctrl+2" Click="OnCtxSplitView"/>
            <MenuItem Header="Preview Only"  InputGestureText="Ctrl+3" Click="OnCtxPreviewOnly"/>
            <Separator Style="{StaticResource MD_GroupSeparatorStyle}"/>
            <!-- ACTIONS group -->
            <MenuItem Header="ACTIONS" Style="{StaticResource MD_GroupHeaderStyle}"/>
            <MenuItem Header="Refresh Preview"  InputGestureText="F9"            Click="OnCtxRefresh"/>
            <MenuItem Header="Cycle Layout"     InputGestureText="Ctrl+Shift+L"  Click="OnCtxCycleLayout"/>
        </ContextMenu>
    </UserControl.ContextMenu>

    <Grid>
        <!-- WebView2 — hidden until initialized to avoid white flash -->
        <wv2:WebView2 x:Name="_webView"
                      Visibility="Collapsed" />

        <!-- Shown while WebView2 is initializing -->
        <Border x:Name="_loadingOverlay"
                Background="{DynamicResource MD_PreviewBackground}">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       FontSize="12"
                       Text="Initializing preview…" />
        </Border>

        <!-- Fallback: shown when WebView2 runtime is not installed -->
        <Border x:Name="_fallback"
                Visibility="Collapsed"
                Background="{DynamicResource MD_PreviewBackground}"
                BorderBrush="{DynamicResource MD_PreviewBorder}"
                BorderThickness="1">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="24">
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           TextAlignment="Center"
                           Text="WebView2 Runtime Not Found" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="320"
                           Text="The Markdown preview requires Microsoft Edge WebView2 Runtime. Download it from microsoft.com/edge/webview2." />
            </StackPanel>
        </Border>
    </Grid>

</UserControl>

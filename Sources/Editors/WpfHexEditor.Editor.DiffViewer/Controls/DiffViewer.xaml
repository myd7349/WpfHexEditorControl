<UserControl x:Class="WpfHexEditor.Editor.DiffViewer.Controls.DiffViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource TE_Background}"
             Focusable="True"
             xmlns:dvSvc="clr-namespace:WpfHexEditor.Editor.DiffViewer.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <dvSvc:DiffViewerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Background="{DynamicResource TE_LineNumberBackground}">
            <Button x:Name="BtnPrevDiff" Content="{StaticResource DiffViewer_PrevButton}" ToolTip="{StaticResource DiffViewer_PrevDiff}"
                    Click="BtnPrevDiff_Click" Padding="8,3" IsEnabled="False"/>
            <Button x:Name="BtnNextDiff" Content="{StaticResource DiffViewer_NextButton}" ToolTip="{StaticResource DiffViewer_NextDiff}"
                    Click="BtnNextDiff_Click" Padding="8,3" IsEnabled="False"/>
            <Separator/>
            <TextBlock x:Name="DiffCountText" Text="&#x2014;" VerticalAlignment="Center" Padding="4,0"
                       Foreground="{DynamicResource TE_LineNumberForeground}"/>
            <Separator/>
            <Border x:Name="ChipModified" CornerRadius="3" Background="{DynamicResource DiffViewer_ModifiedBrush}" Padding="6,2" Margin="2,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="ModifiedText" Text="{StaticResource DiffViewer_ModifiedChip}" Foreground="{DynamicResource DiffViewer_BadgeForeground}" FontSize="11"/>
            </Border>
            <Border x:Name="ChipAdded" CornerRadius="3" Background="{DynamicResource DiffViewer_AddedBrush}" Padding="6,2" Margin="2,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="AddedText" Text="{StaticResource DiffViewer_AddedChip}" Foreground="{DynamicResource DiffViewer_BadgeForeground}" FontSize="11"/>
            </Border>
            <Border x:Name="ChipDeleted" CornerRadius="3" Background="{DynamicResource DiffViewer_DeletedBrush}" Padding="6,2" Margin="2,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="DeletedText" Text="{StaticResource DiffViewer_DeletedChip}" Foreground="{DynamicResource DiffViewer_BadgeForeground}" FontSize="11"/>
            </Border>
            <Separator/>
            <ToggleButton x:Name="BtnDiffList" Content="{StaticResource DiffViewer_DiffList}" Padding="8,3" ToolTip="{StaticResource DiffViewer_ShowHideDiffList}"
                          Checked="OnDiffListToggled" Unchecked="OnDiffListToggled"/>
            <Separator/>
            <Button x:Name="BtnExportPatch" Content="{StaticResource DiffViewer_ExportPatch}"
                    ToolTip="{StaticResource DiffViewer_ExportPatchTooltip}"
                    Click="BtnExportPatch_Click" Padding="8,3" IsEnabled="False"/>
            <Separator x:Name="MergeToolbarSep" Visibility="Collapsed"/>
            <Button x:Name="BtnOpenBase" Content="{StaticResource DiffViewer_MergeOpenBase}"
                    ToolTip="{StaticResource DiffViewer_MergeOpenBaseTooltip}"
                    Click="BtnOpenBase_Click" Padding="8,3" Visibility="Collapsed"/>
            <Button x:Name="BtnPrevConflict" Content="◄" ToolTip="{StaticResource DiffViewer_MergePrevConflict}"
                    Click="BtnPrevConflict_Click" Padding="8,3" IsEnabled="False" Visibility="Collapsed"/>
            <Button x:Name="BtnNextConflict" Content="►" ToolTip="{StaticResource DiffViewer_MergeNextConflict}"
                    Click="BtnNextConflict_Click" Padding="8,3" IsEnabled="False" Visibility="Collapsed"/>
            <Border x:Name="ChipConflicts" CornerRadius="3" Background="{DynamicResource DiffViewer_ModifiedBrush}"
                    Padding="6,2" Margin="2,0" Visibility="Collapsed">
                <TextBlock x:Name="ConflictsText" Foreground="{DynamicResource DiffViewer_BadgeForeground}" FontSize="11"/>
            </Border>
            <Button x:Name="BtnSaveMerged" Content="{StaticResource DiffViewer_MergeSave}"
                    ToolTip="{StaticResource DiffViewer_MergeSaveTooltip}"
                    Click="BtnSaveMerged_Click" Padding="8,3" IsEnabled="False" Visibility="Collapsed"/>
        </ToolBar>

        <!-- Tab: Hex / Text -->
        <TabControl x:Name="ViewTabControl" Grid.Row="1"
                    Background="{DynamicResource TE_Background}"
                    BorderThickness="0"
                    SelectionChanged="OnViewTabChanged">

            <!-- ── Hex tab ── -->
            <TabItem Header="{StaticResource DiffViewer_TabHex}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="LeftHeader" Grid.Row="0"
                                   Text="{StaticResource DiffViewer_LeftLabel}"
                                   Background="{DynamicResource TE_LineNumberBackground}"
                                   Foreground="{DynamicResource TE_LineNumberForeground}"
                                   Padding="6,3" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        <ScrollViewer x:Name="LeftScroll" Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="{DynamicResource TE_Background}">
                            <Canvas x:Name="LeftCanvas" Background="{DynamicResource TE_Background}"/>
                        </ScrollViewer>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="4"
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource TE_LineNumberBackground}"/>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="RightHeader" Grid.Row="0"
                                   Text="{StaticResource DiffViewer_RightLabel}"
                                   Background="{DynamicResource TE_LineNumberBackground}"
                                   Foreground="{DynamicResource TE_LineNumberForeground}"
                                   Padding="6,3" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        <ScrollViewer x:Name="RightScroll" Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="{DynamicResource TE_Background}">
                            <Canvas x:Name="RightCanvas" Background="{DynamicResource TE_Background}"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ── Text tab ── -->
            <TabItem Header="{StaticResource DiffViewer_TabText}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left text panel -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="TextLeftHeader" Grid.Row="0"
                                   Background="{DynamicResource TE_LineNumberBackground}"
                                   Foreground="{DynamicResource TE_LineNumberForeground}"
                                   Padding="6,3" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        <ScrollViewer x:Name="TextLeftScroll" Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Visible"
                                      Background="{DynamicResource TE_Background}"
                                      ScrollChanged="OnTextScrollChanged">
                            <ItemsControl x:Name="TextLeftList"
                                          Background="{DynamicResource TE_Background}"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="4"
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource TE_LineNumberBackground}"/>

                    <!-- Right text panel -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="TextRightHeader" Grid.Row="0"
                                   Background="{DynamicResource TE_LineNumberBackground}"
                                   Foreground="{DynamicResource TE_LineNumberForeground}"
                                   Padding="6,3" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        <ScrollViewer x:Name="TextRightScroll" Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Visible"
                                      Background="{DynamicResource TE_Background}"
                                      ScrollChanged="OnTextScrollChanged">
                            <ItemsControl x:Name="TextRightList"
                                          Background="{DynamicResource TE_Background}"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ── Merge tab ── -->
            <TabItem Header="{StaticResource DiffViewer_TabMerge}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ours (left) panel -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="MergeOursHeader" Grid.Row="0"
                                   Background="{DynamicResource TE_LineNumberBackground}"
                                   Foreground="{DynamicResource TE_LineNumberForeground}"
                                   Padding="6,3" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        <ScrollViewer x:Name="MergeOursScroll" Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Visible"
                                      Background="{DynamicResource TE_Background}"
                                      ScrollChanged="OnMergeScrollChanged">
                            <ItemsControl x:Name="MergeOursList"
                                          Background="{DynamicResource TE_Background}"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource TE_LineNumberBackground}"/>

                    <!-- Base (middle) panel -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="MergeBaseHeader" Grid.Row="0"
                                   Background="{DynamicResource TE_LineNumberBackground}"
                                   Foreground="{DynamicResource TE_LineNumberForeground}"
                                   Padding="6,3" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        <ScrollViewer x:Name="MergeBaseScroll" Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Visible"
                                      Background="{DynamicResource TE_Background}"
                                      ScrollChanged="OnMergeScrollChanged">
                            <ItemsControl x:Name="MergeBaseList"
                                          Background="{DynamicResource TE_Background}"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource TE_LineNumberBackground}"/>

                    <!-- Theirs (right) panel -->
                    <Grid Grid.Column="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="MergeTheirsHeader" Grid.Row="0"
                                   Background="{DynamicResource TE_LineNumberBackground}"
                                   Foreground="{DynamicResource TE_LineNumberForeground}"
                                   Padding="6,3" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        <ScrollViewer x:Name="MergeTheirsScroll" Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Visible"
                                      Background="{DynamicResource TE_Background}"
                                      ScrollChanged="OnMergeScrollChanged">
                            <ItemsControl x:Name="MergeTheirsList"
                                          Background="{DynamicResource TE_Background}"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Diff list panel (collapsible via BtnDiffList toggle) -->
        <Grid x:Name="DiffListPanel" Grid.Row="2" Visibility="Collapsed" MaxHeight="200">
            <Grid.RowDefinitions>
                <RowDefinition Height="4"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <GridSplitter Grid.Row="0" Height="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource TE_LineNumberBackground}" ResizeBehavior="PreviousAndNext"/>
            <DataGrid x:Name="DiffListGrid" Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="{DynamicResource TE_Background}"
                      Foreground="{DynamicResource TE_LineNumberForeground}"
                      RowBackground="{DynamicResource TE_Background}"
                      AlternatingRowBackground="{DynamicResource TE_LineNumberBackground}"
                      BorderThickness="0"
                      SelectionChanged="OnDiffListSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{StaticResource DiffViewer_ColType}"        Binding="{Binding TypeLabel}"    Width="90"/>
                    <DataGridTextColumn Header="{StaticResource Common_ColOffset}"      Binding="{Binding OffsetHex}"    Width="110"/>
                    <DataGridTextColumn Header="{StaticResource DiffViewer_ColLength}"      Binding="{Binding LengthStr}"    Width="80"/>
                    <DataGridTextColumn Header="{StaticResource DiffViewer_ColLeftBytes}"  Binding="{Binding LeftPreview}"  Width="*"/>
                    <DataGridTextColumn Header="{StaticResource DiffViewer_ColRightBytes}" Binding="{Binding RightPreview}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="3"
                   Background="{DynamicResource TE_LineNumberBackground}"
                   Foreground="{DynamicResource TE_LineNumberForeground}"
                   Height="22">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="{StaticResource DiffViewer_OpenFilesHint}" Padding="4,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>

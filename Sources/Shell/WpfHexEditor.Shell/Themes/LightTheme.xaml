<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: LightTheme.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-23
     Description:
         Light theme entry point for the WpfHexEditor IDE.
         Merges Light/Colors.xaml, Light/Menu.xaml, Light/TabControl.xaml,
         Light/ContentControls.xaml, and PanelCommon.xaml from WpfHexEditor.Docking.Wpf.

     Architecture Notes:
         ResourceDictionary. Follows the same composition pattern as DarkTheme.xaml.
         All resources live in WpfHexEditor.Docking.Wpf; Shell acts as the aggregator.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme for WpfHexEditor.Docking -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Light/Colors.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Light/Menu.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Light/TabControl.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Light/ContentControls.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/PanelCommon.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>

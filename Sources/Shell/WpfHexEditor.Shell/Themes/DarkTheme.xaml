<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: DarkTheme.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-06
     Description:
         Dark theme entry point for the WpfHexEditor.Docking system.
         Merges Dark/Colors.xaml (VS2022 Dark inspired palette), Dark/Menu.xaml,
         Dark/TabControl.xaml, Dark/ContentControls.xaml, and PanelCommon.xaml.

     Architecture Notes:
         ResourceDictionary. Reuses shared control templates from the Dark/ subfolder
         with VS2022-inspired dark color values. Apply by setting
         DockControl.ThemeSource to this dictionary's URI.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme for WpfHexEditor.Docking (VS2022 Dark inspired) -->
    <!-- Split into composable sub-files for maintainability -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Dark/Colors.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Dark/Menu.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Dark/TabControl.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Dark/ContentControls.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/PanelCommon.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>

<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.WhfmtCatalogDocument"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Shell.Panels.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Toolbar -->
            <RowDefinition Height="*"/>         <!-- DataGrid + Detail -->
            <RowDefinition Height="Auto"/>      <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ========================================================== -->
        <!-- Toolbar                                                      -->
        <!-- ========================================================== -->
        <ToolBar Grid.Row="0" ToolBarTray.IsLocked="True" Padding="2">
            <TextBox x:Name="SearchBox"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="200" VerticalContentAlignment="Center" Padding="4,2"
                     ToolTip="Filter by name, category, extension or author"/>
            <Separator/>
            <Button Content="Open Selected"   Command="{Binding OpenSelectedCommand}"   Padding="8,3"/>
            <Button Content="Export Selected" Command="{Binding ExportSelectedCommand}" Padding="8,3"/>
            <Separator/>
            <Button Content="Add Format…"     Command="{Binding AddFormatCommand}"      Padding="8,3"/>
            <Button Content="Refresh"         Command="{Binding RefreshCommand}"        Padding="8,3"/>
        </ToolBar>

        <!-- ========================================================== -->
        <!-- Main: DataGrid + Detail                                      -->
        <!-- ========================================================== -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="200" MinHeight="100"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="CatalogGrid" Grid.Row="0"
                      ItemsSource="{Binding FilteredView}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      SelectionChanged="OnGridSelectionChanged"
                      MouseDoubleClick="OnGridDoubleClick">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"       Binding="{Binding Name}"             Width="200" SortMemberPath="Name"/>
                    <DataGridTextColumn Header="Category"   Binding="{Binding Category}"          Width="110" SortMemberPath="Category"/>
                    <DataGridTextColumn Header="Extensions" Binding="{Binding ExtensionsDisplay}" Width="120" SortMemberPath="ExtensionsDisplay"/>
                    <DataGridTextColumn Header="Version"    Binding="{Binding Version}"           Width="70"  SortMemberPath="Version"/>
                    <DataGridTemplateColumn Header="Quality" Width="80" SortMemberPath="QualityScore">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:WhfmtFormatItemVm}">
                                <Grid>
                                    <ProgressBar Minimum="0" Maximum="100" Height="8"
                                                 Value="{Binding QualityScore}" Foreground="#4C9BE8"
                                                 Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVisibility}}">
                                        <ProgressBar.Style>
                                            <Style TargetType="ProgressBar">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ProgressBar.Style>
                                    </ProgressBar>
                                    <TextBlock Text="⚠" Foreground="#DDAA2222" VerticalAlignment="Center"
                                               HorizontalAlignment="Center" FontSize="11"
                                               Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Author"  Binding="{Binding Author}"      Width="120" SortMemberPath="Author"/>
                    <DataGridTextColumn Header="Source"  Binding="{Binding SourceLabel}" Width="70"  SortMemberPath="SourceLabel"/>
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                <Setter Property="Foreground" Value="#DDAA2222"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="4"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <!-- Detail panel at bottom -->
            <local:WhfmtFormatDetailPanel Grid.Row="2" DataContext="{Binding Detail}"
                                          xmlns:local="clr-namespace:WpfHexEditor.Shell.Panels.Panels"/>
        </Grid>

        <!-- ========================================================== -->
        <!-- Status bar                                                   -->
        <!-- ========================================================== -->
        <StatusBar Grid.Row="2" Padding="4,1">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="10" Opacity="0.7"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>

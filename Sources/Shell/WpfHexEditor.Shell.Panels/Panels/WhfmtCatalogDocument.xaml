<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.WhfmtCatalogDocument"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:WpfHexEditor.Shell.Panels.Services"
             xmlns:vm="clr-namespace:WpfHexEditor.Shell.Panels.ViewModels"
             xmlns:local="clr-namespace:WpfHexEditor.Shell.Panels.Panels"
             Background="{DynamicResource SE_BackgroundBrush}"
             Foreground="{DynamicResource SE_ForegroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <svc:ShellPanelsLocalizedDictionary/>
                <ResourceDictionary Source="WhfmtPanelStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

            <!-- Column header templates (DynamicResource works inside DataTemplate visual tree) -->
            <DataTemplate x:Key="ColHdr_Name">
                <TextBlock Text="{StaticResource WhfmtCatalog_NameHeader}" FontSize="11" FontWeight="SemiBold"/>
            </DataTemplate>
            <DataTemplate x:Key="ColHdr_Category">
                <TextBlock Text="{StaticResource WhfmtCatalog_CategoryHeader}" FontSize="11" FontWeight="SemiBold"/>
            </DataTemplate>
            <DataTemplate x:Key="ColHdr_Extensions">
                <TextBlock Text="{StaticResource WhfmtCatalog_ExtensionsHeader}" FontSize="11" FontWeight="SemiBold"/>
            </DataTemplate>
            <DataTemplate x:Key="ColHdr_Version">
                <TextBlock Text="{StaticResource WhfmtCatalog_VersionHeader}" FontSize="11" FontWeight="SemiBold"/>
            </DataTemplate>
            <DataTemplate x:Key="ColHdr_Quality">
                <TextBlock Text="{StaticResource WhfmtCatalog_QualityHeader}" FontSize="11" FontWeight="SemiBold"/>
            </DataTemplate>
            <DataTemplate x:Key="ColHdr_Author">
                <TextBlock Text="{StaticResource WhfmtCatalog_AuthorHeader}" FontSize="11" FontWeight="SemiBold"/>
            </DataTemplate>
            <DataTemplate x:Key="ColHdr_Source">
                <TextBlock Text="{StaticResource WhfmtCatalog_SourceHeader}" FontSize="11" FontWeight="SemiBold"/>
            </DataTemplate>

        <!-- DataGrid theme overrides -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="{DynamicResource SE_BackgroundBrush}"/>
            <Setter Property="Foreground"               Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource SE_SeparatorBrush}"/>
            <Setter Property="RowBackground"            Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#1A1A1A"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource SE_GroupHeaderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SE_SeparatorBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="24"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource Panel_ItemSelectedForegroundBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Panel_WarningTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Padding"         Value="4,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Root: content + QuickSearchBar overlay -->
    <Grid>

        <!-- ── QuickSearch overlay (Ctrl+F) ── -->
        <Canvas x:Name="SearchBarCanvas"
                Panel.ZIndex="5"
                IsHitTestVisible="False"
                Background="Transparent"/>

        <!-- ================================================================ -->
        <!-- Main: DataGrid + Detail                                           -->
        <!-- ================================================================ -->
        <Grid x:Name="ContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="0"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="0"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="CatalogGrid" Grid.Column="0" Grid.Row="0"
                      Margin="4,4,0,4"
                      ItemsSource="{Binding FilteredView}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      CanUserSortColumns="True"
                      HeadersVisibility="Column"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      SelectionChanged="OnGridSelectionChanged"
                      MouseDoubleClick="OnGridDoubleClick">

                <!-- Row context menu with pop-toolbar actions -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu Background="{DynamicResource SE_BackgroundBrush}"
                                             Foreground="{DynamicResource SE_ForegroundBrush}">
                                    <MenuItem Header="{StaticResource WhfmtCatalog_Open}"              Command="{Binding OpenCommand}"/>
                                    <MenuItem Header="{StaticResource WhfmtCatalog_OpenReadOnly}" Command="{Binding OpenReadOnlyCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="{StaticResource WhfmtCatalog_ExportToFile}"   Command="{Binding ExportToFileCommand}"/>
                                    <MenuItem Header="{StaticResource WhfmtCatalog_ViewJson}"         Command="{Binding ViewJsonCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="{StaticResource WhfmtCatalog_RevealInExplorer}" Command="{Binding RevealInExplorerCommand}"/>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn HeaderTemplate="{StaticResource ColHdr_Name}"
                                        Binding="{Binding Name}"
                                        Width="200" SortMemberPath="Name"/>

                    <DataGridTextColumn HeaderTemplate="{StaticResource ColHdr_Category}"
                                        Binding="{Binding Category}"
                                        Width="110" SortMemberPath="Category"/>

                    <DataGridTextColumn HeaderTemplate="{StaticResource ColHdr_Extensions}"
                                        Binding="{Binding ExtensionsDisplay}"
                                        Width="110" SortMemberPath="ExtensionsDisplay"/>

                    <DataGridTextColumn HeaderTemplate="{StaticResource ColHdr_Version}"
                                        Binding="{Binding Version}"
                                        Width="65" SortMemberPath="Version"/>

                    <!-- Quality column with color indicator -->
                    <DataGridTemplateColumn HeaderTemplate="{StaticResource ColHdr_Quality}" Width="80" SortMemberPath="QualityScore">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:WhfmtFormatItemVm}">
                                <Grid VerticalAlignment="Center" Margin="2,0">
                                    <!-- Score + bar for OK formats -->
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <ProgressBar Minimum="0" Maximum="100" Height="4" Width="40"
                                                     Value="{Binding QualityScore}"
                                                     Background="{DynamicResource SE_SearchBoxBrush}"
                                                     VerticalAlignment="Center" BorderThickness="0">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Foreground" Value="{DynamicResource SE_AccentBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding QualityScore}" Value="0">
                                                            <Setter Property="Foreground" Value="{DynamicResource SE_ValidationErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <TextBlock Text="{Binding QualityScore}" FontSize="10"
                                                   Margin="4,0,0,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                    </StackPanel>
                                    <!-- Failure indicator -->
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource WhfmtCatalog_ErrorText}" FontSize="10"
                                                   Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn HeaderTemplate="{StaticResource ColHdr_Author}"
                                        Binding="{Binding Author}"
                                        Width="110" SortMemberPath="Author"/>

                    <DataGridTextColumn HeaderTemplate="{StaticResource ColHdr_Source}"
                                        Binding="{Binding SourceLabel}"
                                        Width="65" SortMemberPath="SourceLabel"/>

                    <!-- Pop-toolbar column (always visible as icons, no header) -->
                    <DataGridTemplateColumn Width="76" CanUserSort="False" CanUserResize="False">
                        <DataGridTemplateColumn.Header>
                            <TextBlock/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:WhfmtFormatItemVm}">
                                <Border x:Name="PopBar"
                                        Background="{DynamicResource SE_PopToolbarBackground}"
                                        BorderBrush="{DynamicResource SE_PopToolbarBorderBrush}"
                                        BorderThickness="1" CornerRadius="3"
                                        Margin="2,1" Padding="1,0"
                                        Visibility="Hidden"
                                        HorizontalAlignment="Right">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="5" ShadowDepth="1"
                                                          Opacity="0.25" Color="Black"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource PopRowButton}"
                                                Command="{Binding OpenCommand}"
                                                ToolTip="{StaticResource WhfmtBrowser_OpenInEditorToolTip}">
                                            <TextBlock Text="&#xE7AC;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                        </Button>
                                        <Button Style="{StaticResource PopRowButton}"
                                                Command="{Binding ExportToFileCommand}"
                                                ToolTip="{StaticResource WhfmtBrowser_ExportToFileToolTip}">
                                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                        </Button>
                                        <Button Style="{StaticResource PopRowButton}"
                                                Command="{Binding ViewJsonCommand}"
                                                ToolTip="{StaticResource WhfmtBrowser_ViewJsonToolTip}">
                                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver,
                                        RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                        Value="True">
                                        <Setter TargetName="PopBar" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter x:Name="DetailSplitter" Grid.Column="1" Grid.Row="1"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="{DynamicResource SE_SeparatorBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Detail panel -->
            <local:WhfmtFormatDetailPanel x:Name="DetailPanel" Grid.Column="2" Grid.Row="0"
                                          DataContext="{Binding Detail}"/>
        </Grid>
    </Grid>
</UserControl>

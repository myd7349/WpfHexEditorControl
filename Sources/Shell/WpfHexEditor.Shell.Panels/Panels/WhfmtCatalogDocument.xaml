<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.WhfmtCatalogDocument"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Shell.Panels.ViewModels"
             xmlns:local="clr-namespace:WpfHexEditor.Shell.Panels.Panels"
             Background="{DynamicResource SE_BackgroundBrush}"
             Foreground="{DynamicResource SE_ForegroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- ── Icon-only toolbar button ── -->
        <Style x:Key="CatIconButton" TargetType="Button">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Width"             Value="24"/>
            <Setter Property="Height"            Value="24"/>
            <Setter Property="Padding"           Value="4"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"        Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="400"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Pop-toolbar button (inline on row hover) ── -->
        <Style x:Key="PopRowButton" TargetType="Button">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Width"             Value="22"/>
            <Setter Property="Height"            Value="20"/>
            <Setter Property="Padding"           Value="3"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"        Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SE_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SE_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid theme overrides -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="{DynamicResource SE_BackgroundBrush}"/>
            <Setter Property="Foreground"               Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource SE_SeparatorBrush}"/>
            <Setter Property="RowBackground"            Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#1A1A1A"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource SE_GroupHeaderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SE_SeparatorBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="24"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource Panel_ItemSelectedForegroundBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Panel_WarningTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Padding"         Value="4,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- DataGrid + Detail -->
            <RowDefinition Height="18"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ================================================================ -->
        <!-- Toolbar                                                           -->
        <!-- ================================================================ -->
        <Border Grid.Row="0"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="210"/>
                </Grid.ColumnDefinitions>

                <!-- Left: action icon buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="4,1">
                    <Button Style="{StaticResource CatIconButton}"
                            Command="{Binding OpenSelectedCommand}"
                            ToolTip="Open selected format(s) in Structure Editor">
                        <TextBlock Text="&#xE7AC;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Button>
                    <Button Style="{StaticResource CatIconButton}"
                            Command="{Binding ExportSelectedCommand}"
                            ToolTip="Export selected format(s) to disk">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Button>

                    <Border Width="1" Height="16" Margin="3,0"
                            Background="{DynamicResource SE_SeparatorBrush}"
                            VerticalAlignment="Center"/>

                    <Button Style="{StaticResource CatIconButton}"
                            Command="{Binding AddFormatCommand}"
                            ToolTip="Add user .whfmt file to catalog">
                        <TextBlock Text="&#xE109;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Button>
                    <Button Style="{StaticResource CatIconButton}"
                            Command="{Binding RefreshCommand}"
                            ToolTip="Refresh catalog">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Button>
                </StackPanel>

                <!-- Right: search box -->
                <Border Grid.Column="1"
                        Background="{DynamicResource SE_SearchBoxBrush}"
                        BorderBrush="{DynamicResource Panel_SearchBoxBorderBrush}"
                        BorderThickness="1" CornerRadius="3"
                        Margin="0,2,6,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   VerticalAlignment="Center" Margin="5,0,3,0"
                                   Foreground="{DynamicResource SE_ForegroundBrush}" Opacity="0.45"/>
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0" FontSize="11"
                                 Foreground="{DynamicResource SE_SearchBoxForegroundBrush}"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Filter by name, category, extension or author"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ================================================================ -->
        <!-- Main: DataGrid + Detail                                           -->
        <!-- ================================================================ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="200" MinHeight="100"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="CatalogGrid" Grid.Row="0"
                      ItemsSource="{Binding FilteredView}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      CanUserSortColumns="True"
                      HeadersVisibility="Column"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      SelectionChanged="OnGridSelectionChanged"
                      MouseDoubleClick="OnGridDoubleClick">

                <!-- Row context menu with pop-toolbar actions -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu Background="{DynamicResource SE_BackgroundBrush}"
                                             Foreground="{DynamicResource SE_ForegroundBrush}">
                                    <MenuItem Header="Open"              Command="{Binding OpenCommand}"/>
                                    <MenuItem Header="Open as Read-Only" Command="{Binding OpenReadOnlyCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Export to File…"   Command="{Binding ExportToFileCommand}"/>
                                    <MenuItem Header="View JSON"         Command="{Binding ViewJsonCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Reveal in Explorer" Command="{Binding RevealInExplorerCommand}"/>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name}"
                                        Width="200" SortMemberPath="Name"/>

                    <DataGridTextColumn Header="Category"
                                        Binding="{Binding Category}"
                                        Width="110" SortMemberPath="Category"/>

                    <DataGridTextColumn Header="Extensions"
                                        Binding="{Binding ExtensionsDisplay}"
                                        Width="110" SortMemberPath="ExtensionsDisplay"/>

                    <DataGridTextColumn Header="Version"
                                        Binding="{Binding Version}"
                                        Width="65" SortMemberPath="Version"/>

                    <!-- Quality column with color indicator -->
                    <DataGridTemplateColumn Header="Quality" Width="80" SortMemberPath="QualityScore">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:WhfmtFormatItemVm}">
                                <Grid VerticalAlignment="Center" Margin="2,0">
                                    <!-- Score + bar for OK formats -->
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <ProgressBar Minimum="0" Maximum="100" Height="4" Width="40"
                                                     Value="{Binding QualityScore}"
                                                     Background="{DynamicResource SE_SearchBoxBrush}"
                                                     VerticalAlignment="Center" BorderThickness="0">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Foreground" Value="{DynamicResource SE_AccentBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding QualityScore}" Value="0">
                                                            <Setter Property="Foreground" Value="{DynamicResource SE_ValidationErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <TextBlock Text="{Binding QualityScore}" FontSize="10"
                                                   Margin="4,0,0,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                    </StackPanel>
                                    <!-- Failure indicator -->
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" Error" FontSize="10"
                                                   Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Author"
                                        Binding="{Binding Author}"
                                        Width="110" SortMemberPath="Author"/>

                    <DataGridTextColumn Header="Source"
                                        Binding="{Binding SourceLabel}"
                                        Width="65" SortMemberPath="SourceLabel"/>

                    <!-- Pop-toolbar column (always visible as icons, no header) -->
                    <DataGridTemplateColumn Width="76" CanUserSort="False" CanUserResize="False">
                        <DataGridTemplateColumn.Header>
                            <TextBlock/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type vm:WhfmtFormatItemVm}">
                                <Border x:Name="PopBar" Visibility="Hidden"
                                        Background="{DynamicResource SE_PopToolbarBackground}"
                                        BorderBrush="{DynamicResource SE_PopToolbarBorderBrush}"
                                        BorderThickness="1" CornerRadius="3"
                                        Margin="2,1" Padding="1,0"
                                        HorizontalAlignment="Right">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="5" ShadowDepth="1"
                                                          Opacity="0.25" Color="Black"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource PopRowButton}"
                                                Command="{Binding OpenCommand}"
                                                ToolTip="Open in Structure Editor">
                                            <TextBlock Text="&#xE7AC;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                        </Button>
                                        <Button Style="{StaticResource PopRowButton}"
                                                Command="{Binding ExportToFileCommand}"
                                                ToolTip="Export to file…">
                                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                        </Button>
                                        <Button Style="{StaticResource PopRowButton}"
                                                Command="{Binding ViewJsonCommand}"
                                                ToolTip="View JSON">
                                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                        </Button>
                                    </StackPanel>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                        </Style>
                                    </Border.Style>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Border.MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames
                                                        Storyboard.TargetProperty="Visibility">
                                                        <DiscreteObjectKeyFrame KeyTime="0"
                                                            Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver,
                                        RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                        Value="True">
                                        <Setter TargetName="PopBar" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="4"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="{DynamicResource SE_SeparatorBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Detail panel -->
            <local:WhfmtFormatDetailPanel Grid.Row="2" DataContext="{Binding Detail}"/>
        </Grid>

        <!-- ================================================================ -->
        <!-- Status bar                                                        -->
        <!-- ================================================================ -->
        <Border Grid.Row="2"
                Background="{DynamicResource Panel_StatusBarBackgroundBrush}"
                BorderBrush="{DynamicResource SE_SeparatorBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Margin="8,0" Text="{Binding StatusText}"
                       FontSize="10" VerticalAlignment="Center"
                       Foreground="{DynamicResource SE_ForegroundBrush}" Opacity="0.7"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.BookmarksPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:WpfHexEditor.Shell.Panels.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <svc:ShellPanelsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <WrapPanel Grid.Row="0" Margin="4,2">
            <Button x:Name="RefreshBtn" Content="&#x21BB;" ToolTip="{StaticResource BookmarksPanel_RefreshToolTip}"
                    Padding="6,2" Margin="2,0" FontSize="12" Click="OnRefreshClick"/>
            <Button x:Name="ClearAllBtn" Content="&#x2715;" ToolTip="{StaticResource BookmarksPanel_ClearAllToolTip}"
                    Padding="6,2" Margin="2,0" FontSize="12" Click="OnClearAllClick"/>
            <Separator Margin="4,0"/>
            <TextBlock x:Name="CountText" Text="{StaticResource BookmarksPanel_EmptyCount}"
                       VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>
        </WrapPanel>

        <!-- Bookmark list -->
        <ListView x:Name="BookmarkList" Grid.Row="1"
                  BorderThickness="0"
                  SelectionChanged="OnBookmarkSelected"
                  MouseDoubleClick="OnBookmarkDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{StaticResource BookmarksPanel_OffsetHeader}" Width="100"
                                    DisplayMemberBinding="{Binding OffsetHex}"/>
                    <GridViewColumn Header="{StaticResource BookmarksPanel_DescriptionHeader}" Width="200"
                                    DisplayMemberBinding="{Binding Description}"/>
                    <GridViewColumn Header="{StaticResource BookmarksPanel_CategoryHeader}" Width="80"
                                    DisplayMemberBinding="{Binding Category}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyText" Grid.Row="1"
                   Text="{StaticResource BookmarksPanel_EmptyMessage}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"
                   Margin="20" Visibility="Visible"/>
    </Grid>
</UserControl>

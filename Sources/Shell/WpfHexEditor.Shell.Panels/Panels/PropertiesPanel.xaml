<UserControl x:Class="WpfHexEditor.Shell.Panels.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Shell.Panels"
             xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core;assembly=WpfHexEditor.Editor.Core"
             Background="{DynamicResource PP_BackgroundBrush}"
             Foreground="{DynamicResource PP_ForegroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter       x:Key="BoolToVis"/>
        <local:InverseBoolConverter         x:Key="InverseBool"/>
        <local:StringToColorConverter       x:Key="StringToColor"/>
        <local:ThicknessPartConverter       x:Key="ThicknessPart"/>
        <local:NullToCollapsedConverter     x:Key="NullToCollapsed"/>
        <local:DefaultToFontWeightConverter x:Key="DefaultToWeight"/>

        <!-- ── Value cell DataTemplates ─────────────────────────────────── -->

        <!-- Text (read-only) -->
        <DataTemplate x:Key="ReadOnlyTextTemplate" DataType="{x:Type ec:PropertyEntry}">
            <TextBlock Text="{Binding Value}"
                       Foreground="{DynamicResource PP_ForegroundBrush}"
                       VerticalAlignment="Center"
                       Padding="2,1"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding Value}"/>
        </DataTemplate>

        <!-- Text (editable) -->
        <DataTemplate x:Key="EditTextTemplate" DataType="{x:Type ec:PropertyEntry}">
            <TextBox x:Name="EditBox"
                     Text="{Binding Value, Mode=OneWay}"
                     Background="Transparent"
                     Foreground="{DynamicResource PP_EditableForegroundBrush}"
                     BorderBrush="{DynamicResource PP_BorderBrush}"
                     BorderThickness="0,0,0,1"
                     Padding="2,1"
                     LostFocus="OnTextBoxCommit"
                     KeyDown="OnTextBoxKeyDown"/>
        </DataTemplate>

        <!-- Integer / Hex (editable) -->
        <DataTemplate x:Key="EditIntegerTemplate" DataType="{x:Type ec:PropertyEntry}">
            <TextBox Text="{Binding Value, Mode=OneWay}"
                     Background="Transparent"
                     Foreground="{DynamicResource PP_EditableForegroundBrush}"
                     BorderBrush="{DynamicResource PP_BorderBrush}"
                     BorderThickness="0,0,0,1"
                     Padding="2,1"
                     LostFocus="OnTextBoxCommit"
                     KeyDown="OnTextBoxKeyDown"/>
        </DataTemplate>

        <!-- Boolean (CheckBox) — IsEnabled uses InverseBool so read-only entries are disabled -->
        <DataTemplate x:Key="BooleanTemplate" DataType="{x:Type ec:PropertyEntry}">
            <CheckBox IsChecked="{Binding Value, Mode=OneWay}"
                      IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBool}}"
                      Checked="OnCheckBoxChanged"
                      Unchecked="OnCheckBoxChanged"
                      VerticalAlignment="Center"/>
        </DataTemplate>

        <!-- Enum (ComboBox) -->
        <DataTemplate x:Key="EnumTemplate" DataType="{x:Type ec:PropertyEntry}">
            <ComboBox ItemsSource="{Binding AllowedValues}"
                      SelectedItem="{Binding Value, Mode=OneWay}"
                      IsEditable="False"
                      Background="{DynamicResource PP_BackgroundBrush}"
                      Foreground="{DynamicResource PP_EditableForegroundBrush}"
                      BorderBrush="{DynamicResource PP_BorderBrush}"
                      Padding="2,1"
                      SelectionChanged="OnComboBoxChanged"/>
        </DataTemplate>

        <!-- FilePath (text + "Open in Explorer" button) -->
        <DataTemplate x:Key="FilePathTemplate" DataType="{x:Type ec:PropertyEntry}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Width="22" Height="20"
                        Margin="2,0,0,0"
                        ToolTip="Open containing folder in Explorer"
                        Click="OnOpenFilePathClick">
                    <TextBlock Text="&#xE8A7;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>
                <TextBlock Text="{Binding Value}"
                           Foreground="{DynamicResource PP_ForegroundBrush}"
                           VerticalAlignment="Center"
                           Padding="2,1"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Value}"/>
            </DockPanel>
        </DataTemplate>

        <!-- Color (swatch + hex text) -->
        <DataTemplate x:Key="ColorTemplate" DataType="{x:Type ec:PropertyEntry}">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Left"
                        Width="14" Height="14"
                        Margin="0,0,5,0"
                        CornerRadius="2"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource PP_BorderBrush}">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding Value, Converter={StaticResource StringToColor}}"/>
                    </Border.Background>
                </Border>
                <TextBlock Text="{Binding Value}"
                           Foreground="{DynamicResource PP_ForegroundBrush}"
                           VerticalAlignment="Center"
                           Padding="2,1"/>
            </DockPanel>
        </DataTemplate>

        <!-- Thickness — four numeric fields L / T / R / B (P5) -->
        <DataTemplate x:Key="ThicknessTemplate" DataType="{x:Type ec:PropertyEntry}">
            <StackPanel Orientation="Vertical" Margin="0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding Value, Converter={StaticResource ThicknessPart}, ConverterParameter=Left, Mode=OneWay}"
                             Tag="Left"
                             Background="Transparent"
                             Foreground="{DynamicResource PP_EditableForegroundBrush}"
                             BorderBrush="{DynamicResource PP_BorderBrush}"
                             BorderThickness="0,0,1,1"
                             Padding="2,1"
                             ToolTip="Left"
                             LostFocus="OnThicknessPartCommit"
                             KeyDown="OnThicknessKeyDown"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding Value, Converter={StaticResource ThicknessPart}, ConverterParameter=Top, Mode=OneWay}"
                             Tag="Top"
                             Background="Transparent"
                             Foreground="{DynamicResource PP_EditableForegroundBrush}"
                             BorderBrush="{DynamicResource PP_BorderBrush}"
                             BorderThickness="0,0,1,1"
                             Padding="2,1"
                             ToolTip="Top"
                             LostFocus="OnThicknessPartCommit"
                             KeyDown="OnThicknessKeyDown"/>
                    <TextBox Grid.Column="2"
                             Text="{Binding Value, Converter={StaticResource ThicknessPart}, ConverterParameter=Right, Mode=OneWay}"
                             Tag="Right"
                             Background="Transparent"
                             Foreground="{DynamicResource PP_EditableForegroundBrush}"
                             BorderBrush="{DynamicResource PP_BorderBrush}"
                             BorderThickness="0,0,1,1"
                             Padding="2,1"
                             ToolTip="Right"
                             LostFocus="OnThicknessPartCommit"
                             KeyDown="OnThicknessKeyDown"/>
                    <TextBox Grid.Column="3"
                             Text="{Binding Value, Converter={StaticResource ThicknessPart}, ConverterParameter=Bottom, Mode=OneWay}"
                             Tag="Bottom"
                             Background="Transparent"
                             Foreground="{DynamicResource PP_EditableForegroundBrush}"
                             BorderBrush="{DynamicResource PP_BorderBrush}"
                             BorderThickness="0,0,0,1"
                             Padding="2,1"
                             ToolTip="Bottom"
                             LostFocus="OnThicknessPartCommit"
                             KeyDown="OnThicknessKeyDown"/>
                </Grid>
                <!-- L T R B labels -->
                <UniformGrid Columns="4" Margin="0,1,0,0">
                    <TextBlock Text="L" FontSize="9" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PP_DescriptionForegroundBrush}"/>
                    <TextBlock Text="T" FontSize="9" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PP_DescriptionForegroundBrush}"/>
                    <TextBlock Text="R" FontSize="9" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PP_DescriptionForegroundBrush}"/>
                    <TextBlock Text="B" FontSize="9" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PP_DescriptionForegroundBrush}"/>
                </UniformGrid>
            </StackPanel>
        </DataTemplate>

        <!-- Brush — color swatch + hex TextBox (P5) -->
        <DataTemplate x:Key="BrushTemplate" DataType="{x:Type ec:PropertyEntry}">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Left"
                        Width="14" Height="14"
                        Margin="0,0,5,0"
                        CornerRadius="2"
                        BorderThickness="1"
                        Cursor="Hand"
                        BorderBrush="{DynamicResource PP_BorderBrush}"
                        MouseLeftButtonDown="OnBrushSwatchClick">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding Value, Converter={StaticResource StringToColor}}"/>
                    </Border.Background>
                </Border>
                <TextBox Text="{Binding Value, Mode=OneWay}"
                         Background="Transparent"
                         Foreground="{DynamicResource PP_EditableForegroundBrush}"
                         BorderBrush="{DynamicResource PP_BorderBrush}"
                         BorderThickness="0,0,0,1"
                         Padding="2,1"
                         LostFocus="OnTextBoxCommit"
                         KeyDown="OnTextBoxKeyDown"/>
            </DockPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>  <!-- toolbar (with context label) -->
            <RowDefinition Height="24"/>  <!-- search/filter bar (P4)       -->
            <RowDefinition Height="*"/>   <!-- properties list              -->
            <RowDefinition Height="60"/>  <!-- description area             -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ───────────────────────────────────────────────────── -->
        <Border x:Name="ToolbarBorder"
                Grid.Row="0"
                Style="{DynamicResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel VerticalAlignment="Center" Margin="4,0">

                <!-- Context label (left) — always visible -->
                <TextBlock x:Name="ContextLabelText"
                           DockPanel.Dock="Left"
                           Text="Properties"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="180"/>

                <!-- Right: always-visible (Refresh) -->
                <StackPanel x:Name="ToolbarRightPanel"
                            Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            ToolTip="Refresh properties"
                            Click="OnRefreshButtonClick">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <!-- Overflow button — shown only when groups are collapsed -->
                <Button x:Name="ToolbarOverflowButton"
                        DockPanel.Dock="Right"
                        Visibility="Collapsed"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        ToolTip="More options"
                        Click="OnOverflowButtonClick">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowContextMenu" Opened="OnOverflowMenuOpened">
                            <!-- TbgPropActions items -->
                            <MenuItem x:Name="OvfSort"
                                      Header="Sort Alphabetically"
                                      IsCheckable="True"
                                      Tag="TbgPropActions"
                                      Click="OvfSort_Click"/>
                            <MenuItem Header="Copy Value"
                                      Tag="TbgPropActions"
                                      Click="OnCopyButtonClick"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Group: TbgPropActions [0] (only collapsible group) -->
                <StackPanel x:Name="TbgPropActions"
                            Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <!-- Sort alphabetically toggle -->
                    <ToggleButton x:Name="SortToggle"
                                  Style="{DynamicResource PanelIconToggleStyle}"
                                  ToolTip="Sort properties alphabetically"
                                  Checked="OnSortChanged"
                                  Unchecked="OnSortChanged">
                        <TextBlock Text="&#xE8CB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </ToggleButton>
                    <!-- Copy selected value -->
                    <Button x:Name="CopyButton"
                            Style="{DynamicResource PanelIconButtonStyle}"
                            ToolTip="Copy selected property value"
                            Click="OnCopyButtonClick">
                        <TextBlock Text="&#xE8C8;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>
                    <!-- Separator -->
                    <Rectangle Width="1" Height="14" Margin="4,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Search/filter bar (P4) ───────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource PP_BackgroundBrush}"
                BorderBrush="{DynamicResource PP_BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,2">
            <DockPanel>
                <!-- Search glyph -->
                <TextBlock DockPanel.Dock="Left"
                           Text="&#xE721;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="11"
                           Foreground="{DynamicResource PP_DescriptionForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="2,0,4,0"/>
                <!-- Clear button (right, hidden when empty) -->
                <Button x:Name="SearchClearButton"
                        DockPanel.Dock="Right"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Visibility="Collapsed"
                        Width="16" Height="16"
                        Click="OnSearchClearClick">
                    <TextBlock Text="&#xE711;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="9"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>
                <!-- Filter text box -->
                <Grid>
                    <TextBox x:Name="SearchBox"
                             Background="Transparent"
                             Foreground="{DynamicResource PP_EditableForegroundBrush}"
                             BorderThickness="0"
                             VerticalAlignment="Center"
                             TextChanged="OnSearchTextChanged"
                             KeyDown="OnSearchKeyDown"/>
                    <TextBlock x:Name="SearchPlaceholder"
                               Text="Filter properties…"
                               Foreground="{DynamicResource PP_DescriptionForegroundBrush}"
                               Opacity="0.45"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="2,0,0,0"
                               IsHitTestVisible="False"/>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ── Property groups ───────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="GroupsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type ec:PropertyGroup}">
                        <Expander IsExpanded="True"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <!-- Group header -->
                            <Expander.Header>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{DynamicResource PP_CategoryHeaderForegroundBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="11"
                                           Padding="4,2"/>
                            </Expander.Header>
                            <Expander.Style>
                                <Style TargetType="Expander">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Expander">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Border Grid.Row="0"
                                                            Background="{DynamicResource PP_CategoryHeaderBackgroundBrush}"
                                                            Cursor="Hand"
                                                            Padding="2,2">
                                                        <DockPanel>
                                                            <Path DockPanel.Dock="Left"
                                                                  x:Name="Arrow"
                                                                  Data="M 0,0 L 4,4 L 8,0"
                                                                  Stroke="{DynamicResource PP_CategoryHeaderForegroundBrush}"
                                                                  StrokeThickness="1.5"
                                                                  Margin="4,0,6,0"
                                                                  VerticalAlignment="Center"
                                                                  Width="8" Height="5"/>
                                                            <ContentPresenter ContentSource="Header"
                                                                              VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                    </Border>
                                                    <ContentPresenter Grid.Row="1"
                                                                      x:Name="ExpandSite"
                                                                      Visibility="Collapsed"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsExpanded" Value="True">
                                                        <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="Arrow" Property="Data" Value="M 0,0 L 4,4 L 8,0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsExpanded" Value="False">
                                                        <Setter TargetName="Arrow" Property="Data" Value="M 0,4 L 4,0 L 8,4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Expander.Style>

                            <!-- Entries grid -->
                            <ItemsControl ItemsSource="{Binding Entries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type ec:PropertyEntry}">
                                        <Border x:Name="EntryRow"
                                                BorderBrush="{DynamicResource PP_BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Cursor="Arrow"
                                                MouseLeftButtonDown="OnEntryRowClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource PP_SelectedEntryBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <!-- Right-click context menu -->
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Copy Value" FontSize="11" Click="OnCopyEntryValue"/>
                                                    <MenuItem Header="Copy Name"  FontSize="11" Click="OnCopyEntryName"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Name + reset button (P7) -->
                                                <DockPanel Grid.Column="0">
                                                    <!-- Reset-to-default icon (hidden when IsDefault=true or OnResetToDefault=null) -->
                                                    <Button DockPanel.Dock="Right"
                                                            Style="{DynamicResource PanelIconButtonStyle}"
                                                            Width="14" Height="14"
                                                            Margin="0,0,2,0"
                                                            ToolTip="Reset to default"
                                                            Click="OnResetPropertyClick"
                                                            Visibility="{Binding OnResetToDefault,
                                                                Converter={StaticResource NullToCollapsed}}">
                                                        <TextBlock Text="&#xE777;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="9"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{DynamicResource PP_NonDefaultIndicatorBrush}"/>
                                                    </Button>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{DynamicResource PP_ForegroundBrush}"
                                                               FontWeight="{Binding IsDefault,
                                                                   Converter={StaticResource DefaultToWeight}}"
                                                               VerticalAlignment="Center"
                                                               Padding="6,3,4,3"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding Name}"/>
                                                </DockPanel>

                                                <!-- Value (DataTemplateSelector in code-behind) -->
                                                <ContentPresenter Grid.Column="1"
                                                                  Content="{Binding}"
                                                                  Margin="2,1"
                                                                  ContentTemplateSelector="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=EntryTemplateSelector}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Description area ─────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{DynamicResource PP_DescriptionBackgroundBrush}"
                BorderBrush="{DynamicResource PP_BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <StackPanel>
                <TextBlock x:Name="DescNameText"
                           Text=""
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PP_ForegroundBrush}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="DescDetailText"
                           Text=""
                           Foreground="{DynamicResource PP_DescriptionForegroundBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

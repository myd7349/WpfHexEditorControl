<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.WhfmtFormatDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,2,8,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- No-selection placeholder -->
        <TextBlock Text="Select a format to see details."
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Opacity="0.5" FontStyle="Italic" FontSize="12">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSelection}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Detail content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Margin="10,8">

                <!-- Name -->
                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                           TextWrapping="Wrap" Margin="0,0,0,2"/>

                <!-- Description -->
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                           Opacity="0.7" FontSize="11" Margin="0,0,0,6"/>

                <Separator Margin="0,2,0,6"/>

                <!-- Metadata grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Version"   Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Version}"   Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Author"    Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Author}"    Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Category"  Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Category}"  Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Platform"  Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Platform}"  Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Diff Mode" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DiffMode}"  Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Status"    Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LoadStatusDisplay}" Style="{StaticResource ValueStyle}"/>
                </Grid>

                <Separator Margin="0,6"/>

                <!-- Extensions -->
                <TextBlock Text="Extensions" Style="{StaticResource LabelStyle}" Margin="0,0,0,3"/>
                <TextBlock Text="{Binding ExtensionsDisplay}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,6"/>

                <!-- Quality score -->
                <TextBlock Text="Quality Score" Style="{StaticResource LabelStyle}" Margin="0,0,0,2"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" Value="{Binding QualityScore}"
                                 Minimum="0" Maximum="100" Height="6"
                                 Foreground="#4C9BE8" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="11"
                               Text="{Binding QualityScore, StringFormat={}{0}/100}"
                               VerticalAlignment="Center"/>
                </Grid>

                <Separator Margin="0,2,0,6"/>

                <!-- Detection + blocks -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Detection" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DetectionRulesSummary}" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Blocks"    Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BlockCount}"  Style="{StaticResource ValueStyle}"/>
                </Grid>

                <!-- Load failure section -->
                <Border Margin="0,8,0,4" Padding="8" CornerRadius="4"
                        BorderThickness="1" BorderBrush="#CCCC4444" Background="#15CC4444"
                        Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Load Error" FontWeight="SemiBold" Foreground="#DDAA0000" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding FailureReason}" TextWrapping="Wrap" FontSize="11"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Retry"   Padding="8,3" Margin="0,0,4,0"
                                    Command="{Binding RetryLoadCommand}" FontSize="11"/>
                            <Button Content="Exclude" Padding="8,3"
                                    Command="{Binding ExcludeCommand}"  FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Separator Margin="0,4,0,6"/>

                <!-- Action buttons -->
                <WrapPanel>
                    <Button Content="Open"      Padding="10,4" Margin="0,0,4,4"
                            Command="{Binding OpenCommand}"     FontSize="11"/>
                    <Button Content="Export…"   Padding="10,4" Margin="0,0,4,4"
                            Command="{Binding ExportCommand}"   FontSize="11"/>
                    <Button Content="Copy JSON" Padding="10,4" Margin="0,0,0,4"
                            Command="{Binding CopyJsonCommand}" FontSize="11"/>
                </WrapPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

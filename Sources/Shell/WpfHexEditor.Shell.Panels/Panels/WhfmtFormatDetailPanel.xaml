<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.WhfmtFormatDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ce="clr-namespace:WpfHexEditor.Editor.CodeEditor.Controls;assembly=WpfHexEditor.Editor.CodeEditor"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:svc="clr-namespace:WpfHexEditor.Shell.Panels.Services"
             Background="{DynamicResource SE_BackgroundBrush}"
             Foreground="{DynamicResource SE_ForegroundBrush}"
             MinWidth="180">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="WhfmtPanelStyles.xaml"/>
                <svc:ShellPanelsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- Hides a row when value equals "—" (unused metadata) -->
            <Style x:Key="HideDash" TargetType="FrameworkElement">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding}" Value="—">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding}" Value="">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <!-- Empty placeholder -->
        <TextBlock Text="{StaticResource WhfmtDetail_EmptyPlaceholder}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontStyle="Italic" FontSize="12"
                   Foreground="{DynamicResource SE_ForegroundBrush}" Opacity="0.4">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSelection}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Detail content -->
        <Grid Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Mini-toolbar ── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Panel_ToolbarBrush}"
                    BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding OpenCommand}"
                                ToolTip="{StaticResource WhfmtDetail_OpenInEditorToolTip}">
                            <TextBlock Text="&#xE7AC;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </Button>
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding ExportCommand}"
                                ToolTip="{StaticResource WhfmtDetail_ExportToFileToolTip}">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </Button>
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding CopyJsonCommand}"
                                ToolTip="{StaticResource WhfmtDetail_ViewRawJsonToolTip}">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SE_ForegroundBrush}"/>
                        </Button>
                        <Border Width="1" Margin="3,4" Background="{DynamicResource SE_SeparatorBrush}"
                                VerticalAlignment="Stretch"/>
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding RetryLoadCommand}"
                                Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}"
                                ToolTip="{StaticResource WhfmtDetail_RetryLoadToolTip}">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource Panel_WarningTextBrush}"/>
                        </Button>
                        <Button Style="{StaticResource DetailIconButton}"
                                Command="{Binding ExcludeCommand}"
                                Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}"
                                ToolTip="{StaticResource WhfmtDetail_ExcludeFromCatalogToolTip}">
                            <TextBlock Text="&#xEBD3;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource Panel_WarningTextBrush}"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,4,0"
                                VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xE73E;"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SE_AccentBrush}"
                                   ToolTip="{StaticResource WhfmtDetail_FormatLoadedSuccessfully}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Text="&#xEB90;"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Panel_WarningTextBrush}"
                                   ToolTip="{StaticResource WhfmtDetail_FormatLoadFailed}"
                                   Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Content: TabControl + splitter + CodeEditor preview ── -->
            <Grid Grid.Row="1" x:Name="ContentSplitGrid">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="TabRow"      Height="*"/>
                    <RowDefinition x:Name="SplitterRow"  Height="4"/>
                    <RowDefinition x:Name="PreviewRow"   Height="220"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="TabCol"      Width="*"/>
                    <ColumnDefinition x:Name="SplitterCol" Width="0"/>
                    <ColumnDefinition x:Name="PreviewCol"  Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- TabControl -->
                <TabControl x:Name="DetailTabControl"
                            Grid.Row="0" Grid.Column="0"
                            Style="{StaticResource WE_DetailTabControl}">

                    <!-- ════ Tab 1: Overview — compact VS-style card ════ -->
                    <TabItem Style="{StaticResource WE_DetailTabItem}" Header="{StaticResource WhfmtDetail_OverviewTab}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                                <!-- ── Name + description header ── -->
                                <Border Background="{DynamicResource SE_GroupHeaderBrush}"
                                        BorderBrush="{DynamicResource SE_SeparatorBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                                   FontSize="10" Opacity="0.65" Margin="0,3,0,0"
                                                   Foreground="{DynamicResource SE_ForegroundBrush}"
                                                   LineHeight="15"/>
                                    </StackPanel>
                                </Border>

                                <!-- ── Quality bar ── -->
                                <Border Padding="8,5,8,4"
                                        BorderBrush="{DynamicResource SE_SeparatorBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0" Value="{Binding QualityScore}"
                                                     Minimum="0" Maximum="100" Height="4"
                                                     Background="{DynamicResource SE_SearchBoxBrush}"
                                                     VerticalAlignment="Center" BorderThickness="0">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Foreground" Value="{DynamicResource SE_AccentBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding QualityScore}" Value="0">
                                                            <Setter Property="Foreground" Value="{DynamicResource SE_ValidationErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="10"
                                                   Text="{Binding QualityScore, StringFormat={}{0}/100}"
                                                   Foreground="{DynamicResource SE_ForegroundBrush}"
                                                   VerticalAlignment="Center" Opacity="0.75"/>
                                    </Grid>
                                </Border>

                                <!-- ── Compact metadata grid ── -->
                                <Border Padding="8,4,8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Version -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource WhfmtDetail_VersionLabel}"
                                                   Style="{StaticResource MetaLabel}" Margin="0,0,8,2"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Version}"
                                                   Style="{StaticResource MetaValue}" FontFamily="Consolas" FontSize="10" Margin="0,0,0,2"/>

                                        <!-- Author -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource WhfmtDetail_AuthorLabel}"
                                                   Style="{StaticResource MetaLabel}" Margin="0,0,8,2"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Author}"
                                                   Style="{StaticResource MetaValue}" Margin="0,0,0,2"/>

                                        <!-- Category -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource WhfmtDetail_CategoryLabel}"
                                                   Style="{StaticResource MetaLabel}" Margin="0,0,8,2"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Category}"
                                                   Style="{StaticResource MetaValue}" Margin="0,0,0,2"/>

                                        <!-- Extensions -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{StaticResource WhfmtDetail_ExtensionsLabel}"
                                                   Style="{StaticResource MetaLabel}" Margin="0,0,8,2"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ExtensionsDisplay}"
                                                   Style="{StaticResource MetaValue}" FontFamily="Consolas" FontSize="10"
                                                   Foreground="{DynamicResource SE_AccentBrush}"
                                                   TextWrapping="Wrap" Margin="0,0,0,2"/>

                                        <!-- Detection -->
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{StaticResource WhfmtDetail_DetectionLabel}"
                                                   Style="{StaticResource MetaLabel}" Margin="0,0,8,2"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DetectionRulesSummary}"
                                                   Style="{StaticResource MetaValue}" Margin="0,0,0,2"/>

                                        <!-- Blocks -->
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{StaticResource WhfmtDetail_BlocksLabel}"
                                                   Style="{StaticResource MetaLabel}" Margin="0,0,8,2"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding BlockCount}"
                                                   Style="{StaticResource MetaValue}" Margin="0,0,0,2"/>

                                        <!-- Platform — hidden when "—" -->
                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="{StaticResource WhfmtDetail_PlatformLabel}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MetaLabel}">
                                                    <Setter Property="Margin" Value="0,0,8,2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Platform}" Value="—">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Platform}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MetaValue}">
                                                    <Setter Property="Margin" Value="0,0,0,2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Platform}" Value="—">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Editor — hidden when "—" -->
                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="{StaticResource WhfmtDetail_EditorLabel}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MetaLabel}">
                                                    <Setter Property="Margin" Value="0,0,8,2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PreferredEditor}" Value="—">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding PreferredEditor}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MetaValue}">
                                                    <Setter Property="Margin" Value="0,0,0,2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PreferredEditor}" Value="—">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- DiffMode — hidden when "—" -->
                                        <TextBlock Grid.Row="8" Grid.Column="0" Text="{StaticResource WhfmtDetail_DiffLabel}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MetaLabel}">
                                                    <Setter Property="Margin" Value="0,0,8,2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DiffMode}" Value="—">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding DiffMode}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MetaValue}">
                                                    <Setter Property="Margin" Value="0,0,0,2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DiffMode}" Value="—">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                    </Grid>
                                </Border>

                                <!-- ── Load failure card ── -->
                                <Border Margin="8,0,8,6" Padding="8,6" CornerRadius="3"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource Panel_WarningBorderBrush}"
                                        Background="{DynamicResource Panel_WarningBackgroundBrush}"
                                        Visibility="{Binding IsLoadFailure, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{StaticResource WhfmtDetail_LoadErrorTitle}" FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding FailureReason}" TextWrapping="Wrap" FontSize="10"
                                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ════ Tab 2: References ════ -->
                    <TabItem Header="{StaticResource WhfmtDetail_ReferencesTab}">
                        <TabItem.Style>
                            <Style TargetType="TabItem" BasedOn="{StaticResource WE_DetailTabItem}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasReferences}" Value="False">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity"   Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TabItem.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="8,6">
                                <TextBlock Text="{StaticResource WhfmtDetail_SpecificationsLabel}" Style="{StaticResource MetaLabel}" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding SpecificationsDisplay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,2"
                                                       Foreground="{DynamicResource SE_AccentBrush}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{StaticResource WhfmtDetail_WebLinksLabel}" Style="{StaticResource MetaLabel}" Margin="0,8,0,4"/>
                                <ItemsControl ItemsSource="{Binding WebLinksDisplay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,2"
                                                       Foreground="{DynamicResource SE_AccentBrush}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ════ Tab 3: Assertions ════ -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{StaticResource WhfmtDetail_AssertionsTab}"/>
                                <Border CornerRadius="8" Background="{DynamicResource SE_AccentBrush}"
                                        Padding="4,0" Margin="4,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding HasAssertions, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding AssertionCount}" FontSize="9"
                                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                </Border>
                            </StackPanel>
                        </TabItem.Header>
                        <TabItem.Style>
                            <Style TargetType="TabItem" BasedOn="{StaticResource WE_DetailTabItem}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAssertions}" Value="False">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity"   Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TabItem.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding AssertionsSummary}" Margin="8,6">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource SE_SeparatorBrush}"
                                                BorderThickness="0,0,0,1" Padding="0,3">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="10"
                                                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                                    <Border CornerRadius="3" Padding="4,0" Margin="6,0,0,0"
                                                            Background="{DynamicResource Panel_WarningBackgroundBrush}">
                                                        <TextBlock Text="{Binding Severity}" FontSize="9"
                                                                   Foreground="{DynamicResource Panel_WarningTextBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Expression}" FontFamily="Consolas" FontSize="10"
                                                           Foreground="{DynamicResource SE_AccentBrush}"
                                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                                                <TextBlock Text="{Binding Message}" FontSize="10" Opacity="0.7"
                                                           Foreground="{DynamicResource SE_ForegroundBrush}"
                                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ════ Tab 4: AI Hints ════ -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{StaticResource WhfmtDetail_AIHintsTab}"/>
                                <Border CornerRadius="8" Background="{DynamicResource SE_AccentBrush}"
                                        Padding="4,0" Margin="4,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding HasAiHints, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding AiHintCount}" FontSize="9"
                                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                </Border>
                            </StackPanel>
                        </TabItem.Header>
                        <TabItem.Style>
                            <Style TargetType="TabItem" BasedOn="{StaticResource WE_DetailTabItem}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAiHints}" Value="False">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity"   Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TabItem.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="8,6">
                                <TextBlock Text="{StaticResource WhfmtDetail_AnalysisContextLabel}" Style="{StaticResource MetaLabel}" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding AiAnalysisContext}" FontSize="10" TextWrapping="Wrap"
                                           Foreground="{DynamicResource SE_ForegroundBrush}" Margin="0,0,0,8" LineHeight="15"/>
                                <TextBlock Text="{StaticResource WhfmtDetail_KnownVulnerabilitiesLabel}" Style="{StaticResource MetaLabel}" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding AiVulnerabilities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                           Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding}" FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ════ Tab 5: Documentation (Piste A — Software/UseCases/Relationships/Navigation) ════ -->
                    <!-- TODO loc: replace "Docs" with DynamicResource WhfmtDetail_DocumentationTab once string is added to ShellPanelsResources.resx -->
                    <TabItem Header="Docs">
                        <TabItem.Style>
                            <Style TargetType="TabItem" BasedOn="{StaticResource WE_DetailTabItem}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDocumentation}" Value="False">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity"   Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TabItem.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="8,6">

                                <!-- Software -->
                                <StackPanel Visibility="{Binding HasSoftware, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Software" Style="{StaticResource MetaLabel}" Margin="0,0,0,4"/>
                                    <ItemsControl ItemsSource="{Binding SoftwareDisplay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding Name}" FontSize="10"
                                                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                                    <TextBlock Text="{Binding Role, StringFormat=' — {0}'}" FontSize="10"
                                                               Foreground="{DynamicResource SE_MutedBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Use Cases -->
                                <StackPanel Visibility="{Binding HasUseCases, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Use Cases" Style="{StaticResource MetaLabel}" Margin="0,8,0,4"/>
                                    <ItemsControl ItemsSource="{Binding UseCasesDisplay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,2"
                                                           Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Format Relationships -->
                                <StackPanel Visibility="{Binding HasRelationships, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Related Formats" Style="{StaticResource MetaLabel}" Margin="0,8,0,4"/>
                                    <ItemsControl ItemsSource="{Binding RelationshipsDisplay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding Format}" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource SE_AccentBrush}"/>
                                                    <TextBlock Text="{Binding Relationship, StringFormat=' — {0}'}" FontSize="10" TextWrapping="Wrap"
                                                               Foreground="{DynamicResource SE_MutedBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Navigation Structure -->
                                <StackPanel Visibility="{Binding HasNavigationStructure, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Structure" Style="{StaticResource MetaLabel}" Margin="0,8,0,4"/>
                                    <TextBlock Text="{Binding NavigationStructure}" FontSize="10" TextWrapping="Wrap"
                                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                </StackPanel>

                                <!-- Navigation Notes -->
                                <StackPanel Visibility="{Binding HasNavigationNotes, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Notes" Style="{StaticResource MetaLabel}" Margin="0,8,0,4"/>
                                    <TextBlock Text="{Binding NavigationNotes}" FontSize="10" TextWrapping="Wrap"
                                               Foreground="{DynamicResource SE_MutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>

                <!-- GridSplitter -->
                <GridSplitter x:Name="PreviewSplitter"
                              Grid.Row="1" Grid.Column="0"
                              ShowsPreview="False"
                              Background="{DynamicResource SE_SeparatorBrush}"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                <!-- Code preview — always-visible readonly JSON -->
                <Border Grid.Row="2" Grid.Column="0"
                        x:Name="PreviewBorder"
                        BorderBrush="{DynamicResource SE_SeparatorBrush}"
                        BorderThickness="0,1,0,0">
                    <ce:CodeEditor x:Name="JsonCodeEditor"
                                   IsReadOnly="True"
                                   ShowLineNumbers="True"
                                   EditorBackground="{DynamicResource SE_BackgroundBrush}"
                                   EditorForeground="{DynamicResource SE_ForegroundBrush}"
                                   LineNumberBackground="{DynamicResource SE_GroupHeaderBrush}"
                                   LineNumberForeground="{DynamicResource SE_ForegroundBrush}"
                                   CurrentLineBackground="Transparent"
                                   SelectionBackground="{DynamicResource SE_SelectedBrush}"
                                   SyntaxKeyColor="{DynamicResource TE_Keyword}"
                                   SyntaxKeywordColor="{DynamicResource TE_Keyword}"
                                   SyntaxBooleanColor="{DynamicResource TE_Keyword}"
                                   SyntaxStringValueColor="{DynamicResource TE_String}"
                                   SyntaxNumberColor="{DynamicResource TE_Number}"
                                   SyntaxCommentColor="{DynamicResource TE_Comment}"
                                   SyntaxUrlColor="{DynamicResource TE_Register}"
                                   SyntaxBraceColor="{DynamicResource SE_ForegroundBrush}"
                                   SyntaxBracketColor="{DynamicResource SE_ForegroundBrush}"
                                   SyntaxCommaColor="{DynamicResource SE_ForegroundBrush}"/>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</UserControl>

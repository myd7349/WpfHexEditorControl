<UserControl x:Class="WpfHexEditor.Shell.Panels.Panels.WhfmtBrowserPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:WpfHexEditor.Shell.Panels.Services"
             xmlns:vm="clr-namespace:WpfHexEditor.Shell.Panels.ViewModels"
             xmlns:local="clr-namespace:WpfHexEditor.Shell.Panels.Panels"
             Background="{DynamicResource SE_BackgroundBrush}"
             Foreground="{DynamicResource SE_ForegroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <svc:ShellPanelsLocalizedDictionary/>
                <ResourceDictionary Source="WhfmtPanelStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- ── TreeViewItem style ── -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Setter Property="IsExpanded"                 Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="RowBg" Background="Transparent" Height="22">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Selection accent bar -->
                                    <Border x:Name="AccentBar" Grid.Column="0"
                                            Background="{DynamicResource SE_AccentBrush}"
                                            Visibility="Collapsed"/>

                                    <!-- Expander arrow -->
                                    <ToggleButton x:Name="Expander" Grid.Column="1"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Style="{x:Null}" Background="Transparent" BorderThickness="0"
                                                  Focusable="False" ClickMode="Press"
                                                  Width="16" Height="16" Cursor="Hand">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <TextBlock x:Name="Arrow" Text="▶" FontSize="8"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource SE_ForegroundBrush}"
                                                           Opacity="0.6"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <!-- Header content -->
                                    <ContentPresenter Grid.Column="2" x:Name="PART_Header"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"/>

                                    <!-- Pop-toolbar (shown on hover) -->
                                    <Border x:Name="PopHost" Grid.Column="3"
                                            Visibility="Hidden"
                                            Margin="0,0,4,0" VerticalAlignment="Center">
                                        <Border Background="{DynamicResource SE_PopToolbarBackground}"
                                                BorderBrush="{DynamicResource SE_PopToolbarBorderBrush}"
                                                BorderThickness="1" CornerRadius="3" Padding="1,0">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="6" ShadowDepth="1"
                                                                  Opacity="0.3" Color="Black"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="PopOpenBtn" Style="{StaticResource PopRowButton}"
                                                        ToolTip="{StaticResource WhfmtBrowser_OpenInEditorToolTip}">
                                                    <TextBlock Text="&#xE7AC;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                                </Button>
                                                <Button x:Name="PopExportBtn" Style="{StaticResource PopRowButton}"
                                                        ToolTip="{StaticResource WhfmtBrowser_ExportToFileToolTip}">
                                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                                </Button>
                                                <Button x:Name="PopJsonBtn" Style="{StaticResource PopRowButton}"
                                                        ToolTip="{StaticResource WhfmtBrowser_ViewJsonToolTip}">
                                                    <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Border>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="10,0,0,0"/>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBg"    Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                                <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"  Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RowBg"    Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                                <Setter TargetName="PopHost"  Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                            <!-- Show pop-toolbar even when selected + hover -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"  Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="PopHost" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Category node header ── -->
        <DataTemplate x:Key="CategoryHeaderTemplate" DataType="{x:Type vm:WhfmtCategoryNodeVm}">
            <StackPanel Orientation="Horizontal" Margin="2,0">
                <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                           Foreground="{DynamicResource SE_AccentBrush}" Opacity="0.8"
                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding Name}"
                           FontWeight="SemiBold" FontSize="11"
                           Foreground="{DynamicResource SE_ForegroundBrush}"
                           VerticalAlignment="Center"/>
                <Border CornerRadius="8" Background="{DynamicResource SE_SearchBoxBrush}"
                        Padding="5,0" Margin="6,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding VisibleCount}" FontSize="10"
                               Foreground="{DynamicResource SE_ForegroundBrush}" Opacity="0.7"/>
                </Border>
                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                           Margin="5,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Panel_WarningTextBrush}"
                           ToolTip="{StaticResource WhfmtBrowser_LoadFailureIndicator}"
                           Visibility="{Binding HasFailures, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </DataTemplate>

        <!-- ── Format item row ── -->
        <DataTemplate x:Key="FormatItemTemplate" DataType="{x:Type vm:WhfmtFormatItemVm}">
            <Grid Height="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16"/>   <!-- icon -->
                    <ColumnDefinition Width="*"/>    <!-- name -->
                    <ColumnDefinition Width="Auto"/> <!-- badges -->
                </Grid.ColumnDefinitions>

                <!-- Format icon -->
                <TextBlock Grid.Column="0" Text="&#xEBD2;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                           VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource SE_AccentBrush}"/>
                            <Setter Property="Opacity"    Value="0.7"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Panel_WarningTextBrush}"/>
                                    <Setter Property="Text"       Value="&#xE783;"/>
                                    <Setter Property="Opacity"    Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Name + extensions -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="{Binding Name}" FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                </StackPanel>

                <!-- Badges (quality + user) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="2,0,4,0">

                    <!-- Quality badge -->
                    <Border CornerRadius="3" Padding="4,1" Margin="0,0,3,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SE_AccentBrush}"/>
                                <Setter Property="Opacity"    Value="0.55"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoadFailure}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding QualityScore}" FontSize="9"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Border>

                    <!-- User source badge -->
                    <Border CornerRadius="3" Padding="4,1"
                            Background="{DynamicResource SE_SelectionBorderBrush}" Opacity="0.65"
                            Visibility="{Binding IsUserFormat, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="User" FontSize="9"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ── Context menu ── -->
        <ContextMenu x:Key="FormatItemContextMenu"
                     Background="{DynamicResource SE_BackgroundBrush}"
                     Foreground="{DynamicResource SE_ForegroundBrush}">
            <MenuItem Header="{StaticResource WhfmtBrowser_Open}"               Command="{Binding OpenCommand}"/>
            <MenuItem Header="{StaticResource WhfmtBrowser_OpenReadOnly}"  Command="{Binding OpenReadOnlyCommand}"/>
            <Separator/>
            <MenuItem Header="{StaticResource WhfmtBrowser_ExportToFile}"    Command="{Binding ExportToFileCommand}"/>
            <MenuItem Header="{StaticResource WhfmtBrowser_ViewJson}"          Command="{Binding ViewJsonCommand}"/>
            <MenuItem Header="{StaticResource WhfmtBrowser_CopyPath}"          Command="{Binding CopyPathCommand}"/>
            <Separator/>
            <MenuItem Header="{StaticResource WhfmtBrowser_Delete}"             Command="{Binding DeleteCommand}"/>
            <MenuItem Header="{StaticResource WhfmtBrowser_RevealInExplorer}" Command="{Binding RevealInExplorerCommand}"/>
            <Separator/>
            <MenuItem Header="{StaticResource WhfmtBrowser_DuplicateFormat}"        Command="{Binding DuplicateCommand}"/>
            <MenuItem Header="{StaticResource WhfmtBrowser_EditInCodeEditor}"      Command="{Binding ViewJsonCommand}"/>
        </ContextMenu>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- ── Root grid: content + QuickSearchBar overlay ── -->
    <Grid>

        <!-- ================================================================ -->
        <!-- Main: list + detail                                               -->
        <!-- ================================================================ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="120"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="230" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <!-- TreeView (grouped) -->
            <TreeView x:Name="FormatTree" Grid.Column="0"
                      ItemsSource="{Binding CategoryNodes}"
                      Background="{DynamicResource SE_BackgroundBrush}"
                      BorderThickness="0"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      SelectedItemChanged="OnTreeSelectedItemChanged"
                      MouseDoubleClick="OnTreeDoubleClick">
                <TreeView.Style>
                    <Style TargetType="TreeView">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTreeView}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.Style>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vm:WhfmtCategoryNodeVm}"
                                              ItemsSource="{Binding Items}">
                        <ContentPresenter Content="{Binding}"
                                          ContentTemplate="{StaticResource CategoryHeaderTemplate}"/>
                        <HierarchicalDataTemplate.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:WhfmtFormatItemVm}">
                                <ContentPresenter Content="{Binding}"
                                                  ContentTemplate="{StaticResource FormatItemTemplate}"
                                                  ContextMenu="{StaticResource FormatItemContextMenu}"/>
                            </DataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- Flat ListView -->
            <ListView x:Name="FormatList" Grid.Column="0"
                      ItemsSource="{Binding FlatItems}"
                      ItemTemplate="{StaticResource FormatItemTemplate}"
                      Background="{DynamicResource SE_BackgroundBrush}"
                      BorderThickness="0"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      SelectionChanged="OnListSelectionChanged"
                      MouseDoubleClick="OnListDoubleClick">
                <ListView.Style>
                    <Style TargetType="ListView">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTreeView}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background"                  Value="Transparent"/>
                        <Setter Property="BorderThickness"             Value="0"/>
                        <Setter Property="HorizontalContentAlignment"  Value="Stretch"/>
                        <Setter Property="FocusVisualStyle"            Value="{x:Null}"/>
                        <Setter Property="ContextMenu"                 Value="{StaticResource FormatItemContextMenu}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="{DynamicResource SE_SeparatorBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Detail panel -->
            <local:WhfmtFormatDetailPanel x:Name="DetailPanel" Grid.Column="2"
                                          DataContext="{Binding Detail}"/>
        </Grid>

        <!-- ================================================================ -->
        <!-- QuickSearchBar overlay (Ctrl+F, floating, draggable)             -->
        <!-- ================================================================ -->
        <Canvas x:Name="SearchBarCanvas"
                Panel.ZIndex="5"
                IsHitTestVisible="False"
                Background="Transparent"/>

    </Grid>
</UserControl>

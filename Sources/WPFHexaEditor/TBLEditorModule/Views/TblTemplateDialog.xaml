<Window x:Class="WpfHexaEditor.TBLEditorModule.Views.TblTemplateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TBL Templates"
        Height="650" Width="950"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- V2 Style - CardBorder with DropShadow -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.2" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- V2 Style - ModernButton (Primary) -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004275"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#9E9E9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- V2 Style - CancelButton (Secondary) -->
        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BDBDBD"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#9E9E9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="25">
        <Border Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>      <!-- Categories TreeView -->
                    <ColumnDefinition Width="8"/>        <!-- Splitter -->
                    <ColumnDefinition Width="*"/>        <!-- Template List + Preview -->
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>       <!-- Header -->
                    <RowDefinition Height="*"/>          <!-- Content -->
                    <RowDefinition Height="Auto"/>       <!-- Buttons -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,20">
                    <TextBlock Text="📋 TBL Templates"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#212121"/>
                    <TextBlock Text="Choose from built-in templates or create your own"
                               FontSize="12"
                               Foreground="#757575"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Categories TreeView -->
                <Border Grid.Row="1" Grid.Column="0"
                        BorderBrush="#E0E0E0"
                        BorderThickness="0,0,1,0">
                    <StackPanel>
                        <TextBlock Text="Categories"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="8,0,8,12"/>
                        <TreeView ItemsSource="{Binding Categories}"
                                  SelectedItemChanged="TreeView_SelectedItemChanged"
                                  BorderThickness="0"
                                  Background="Transparent">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Templates}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📁 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text=" (" Foreground="#757575" Margin="4,0,0,0"/>
                                        <TextBlock Text="{Binding Templates.Count}" Foreground="#757575"/>
                                        <TextBlock Text=")" Foreground="#757575"/>
                                    </StackPanel>
                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📄 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Name}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </StackPanel>
                </Border>

                <GridSplitter Grid.Row="1" Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="Transparent"/>

                <!-- Template List + Preview -->
                <Grid Grid.Row="1" Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Header -->
                        <RowDefinition Height="2*"/>     <!-- Template List -->
                        <RowDefinition Height="8"/>      <!-- Splitter -->
                        <RowDefinition Height="3*"/>     <!-- Preview -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Background="#FAFAFA"
                            CornerRadius="4"
                            Padding="12"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Available Templates"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedCategory.Name}"
                                       Foreground="#757575"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Template List -->
                    <Border Grid.Row="1"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="4"
                            Margin="0,0,0,0">
                        <ListBox ItemsSource="{Binding FilteredTemplates}"
                                 SelectedItem="{Binding SelectedTemplate}"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" Margin="0,0,0,4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"/>
                                                <Border Background="#4CAF50"
                                                        CornerRadius="3"
                                                        Padding="6,2"
                                                        Margin="8,0,0,0"
                                                        Visibility="{Binding IsBuiltIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Built-in"
                                                               Foreground="White"
                                                               FontSize="10"
                                                               FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#757575"
                                                       Margin="0,4,0,0"
                                                       FontSize="12"/>
                                            <TextBlock Text="{Binding Author, StringFormat='By: {0}'}"
                                                       FontSize="11"
                                                       Foreground="#9E9E9E"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <GridSplitter Grid.Row="2"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="Transparent"/>

                    <!-- Preview -->
                    <Grid Grid.Row="3"
                          Margin="0,0,0,0"
                          Visibility="{Binding SelectedTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#FAFAFA"
                                CornerRadius="4"
                                Padding="12"
                                Margin="0,0,0,8">
                            <TextBlock Text="Preview"
                                       FontWeight="SemiBold"
                                       FontSize="14"/>
                        </Border>

                        <Border Grid.Row="1"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="4"
                                Background="White">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding PreviewContent, Mode=OneWay}"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         TextWrapping="NoWrap"
                                         Padding="12"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">
                    <Button Content="Load Template"
                            Style="{StaticResource ModernButton}"
                            Padding="16,10"
                            Margin="0,0,8,0"
                            IsEnabled="{Binding SelectedTemplate, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Click="LoadTemplateButton_Click"
                            IsDefault="True"/>
                    <Button Content="Merge with Current"
                            Style="{StaticResource CancelButton}"
                            Padding="16,10"
                            Margin="0,0,8,0"
                            IsEnabled="{Binding SelectedTemplate, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Click="MergeTemplateButton_Click"/>
                    <Button Content="Cancel"
                            Style="{StaticResource CancelButton}"
                            Padding="16,10"
                            Click="CancelButton_Click"
                            IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

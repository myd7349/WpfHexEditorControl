<Window x:Class="WpfHexaEditor.TBLEditorModule.Views.TblEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TBL Character Table Editor"
        Height="800" Width="1200"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- V2 Style - CardBorder with DropShadow -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.2" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- V2 Style - ModernButton (Primary) -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004275"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#9E9E9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- V2 Style - CancelButton (Secondary) -->
        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BDBDBD"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#9E9E9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- V2 Style - ToolbarButton -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Type to Color Converter -->
        <SolidColorBrush x:Key="AsciiColor" Color="#4CAF50"/>
        <SolidColorBrush x:Key="DteColor" Color="#FF9800"/>
        <SolidColorBrush x:Key="MteColor" Color="#2196F3"/>
        <SolidColorBrush x:Key="SpecialColor" Color="#9C27B0"/>

        <!-- DataGrid Row Styles -->
        <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasConflict}" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsValid}" Value="False">
                    <Setter Property="Background" Value="#FFF3E0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Border Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>    <!-- Header -->
                    <RowDefinition Height="Auto"/>    <!-- Toolbar -->
                    <RowDefinition Height="Auto"/>    <!-- Search/Filter Bar -->
                    <RowDefinition Height="*"/>       <!-- Main Content -->
                    <RowDefinition Height="Auto"/>    <!-- Action Buttons -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="📋 TBL Character Table Editor"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#212121"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="12"
                                   Foreground="#757575"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Modified Indicator -->
                    <Border Grid.Column="1"
                            Background="#FF9800"
                            CornerRadius="12"
                            Padding="12,6"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsDirty, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="● Modified" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </Border>
                </Grid>

                <!-- Toolbar -->
                <Border Grid.Row="1"
                        Background="#FAFAFA"
                        CornerRadius="4"
                        Padding="10"
                        Margin="0,0,0,12">
                    <WrapPanel>
                        <!-- File Operations -->
                        <Button Style="{StaticResource ToolbarButton}"
                                Command="{Binding SaveCommand}"
                                ToolTip="Save (Ctrl+S)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Save" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolbarButton}"
                                Command="{Binding SaveAsCommand}"
                                ToolTip="Save As">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Save As" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Width="1" Height="24" Margin="4,0" Background="#E0E0E0"/>

                        <!-- Edit Operations -->
                        <Button Style="{StaticResource ToolbarButton}"
                                Command="{Binding AddEntryCommand}"
                                ToolTip="Add Entry (Ctrl+N)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Add" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolbarButton}"
                                Command="{Binding DeleteEntryCommand}"
                                ToolTip="Delete Entry (Delete)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Delete" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolbarButton}"
                                Command="{Binding DuplicateEntryCommand}"
                                ToolTip="Duplicate Entry">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Duplicate" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Width="1" Height="24" Margin="4,0" Background="#E0E0E0"/>

                        <!-- Advanced Operations -->
                        <Button Style="{StaticResource ToolbarButton}"
                                Command="{Binding DetectConflictsCommand}"
                                ToolTip="Detect Conflicts">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Validate" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Width="1" Height="24" Margin="4,0" Background="#E0E0E0"/>

                        <!-- Special Markers -->
                        <Button Style="{StaticResource ToolbarButton}"
                                Command="{Binding AddEndBlockCommand}"
                                ToolTip="Add End Block Marker (/)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="/" FontSize="16" Margin="0,0,6,0" FontFamily="Consolas"/>
                                <TextBlock Text="End" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolbarButton}"
                                Command="{Binding AddEndLineCommand}"
                                ToolTip="Add End Line Marker (*)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="*" FontSize="16" Margin="0,0,6,0" FontFamily="Consolas"/>
                                <TextBlock Text="EOL" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Width="1" Height="24" Margin="4,0" Background="#E0E0E0"/>

                        <!-- Undo/Redo -->
                        <Button Style="{StaticResource ToolbarButton}"
                                Command="{Binding UndoCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⬅" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="Undo"/>
                                    <Run Text="{Binding UndoStackCount, StringFormat='({0})', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolbarButton}"
                                Command="{Binding RedoCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➡" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="Redo"/>
                                    <Run Text="{Binding RedoStackCount, StringFormat='({0})', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Border>

                <!-- Search/Filter Bar -->
                <Border Grid.Row="2"
                        Background="#FAFAFA"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="0,0,0,12">
                    <Expander IsExpanded="True"
                              Background="Transparent"
                              BorderThickness="0">
                    <Expander.Header>
                        <TextBlock Text="🔍 Search &amp; Filter" FontWeight="SemiBold"/>
                    </Expander.Header>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <!-- Search TextBox -->
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="250"
                                     VerticalAlignment="Center"
                                     Padding="8,6"
                                     ToolTip="Search by hex value or character"/>

                            <!-- Type Filters -->
                            <TextBlock Text="Type:" Margin="16,0,8,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <ComboBox SelectedValue="{Binding FilterByType}"
                                      Width="120"
                                      VerticalAlignment="Center"
                                      Padding="8,6">
                                <ComboBoxItem Content="All" Tag="{x:Null}"/>
                                <ComboBoxItem Content="ASCII"/>
                                <ComboBoxItem Content="DTE"/>
                                <ComboBoxItem Content="MTE"/>
                                <ComboBoxItem Content="Special"/>
                            </ComboBox>

                            <!-- Conflicts Only -->
                            <CheckBox IsChecked="{Binding ShowConflictsOnly}"
                                      Content="⚠ Conflicts only"
                                      Margin="16,0,0,0"
                                      VerticalAlignment="Center"/>

                            <!-- Clear Button -->
                            <Button Command="{Binding ClearSearchCommand}"
                                    Content="Clear"
                                    Style="{StaticResource CancelButton}"
                                    Margin="16,0,0,0"
                                    Padding="12,6"/>
                        </StackPanel>

                        <!-- Entry Count -->
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#0078D4"
                                   Margin="16,0,0,0">
                            <Run Text="{Binding FilteredEntries.Count, Mode=OneWay}"/>
                            <Run Text="entries"/>
                        </TextBlock>
                    </Grid>
                    </Expander>
                </Border>

                <!-- Main Content -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="1*" MinWidth="280" MaxWidth="400"/>
                    </Grid.ColumnDefinitions>

                    <!-- DataGrid - Virtualized -->
                    <Border Grid.Column="0"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="4">
                        <DataGrid ItemsSource="{Binding FilteredEntries}"
                                  SelectedItem="{Binding SelectedEntry}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  RowStyle="{StaticResource DataGridRowStyle}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  VirtualizingPanel.CacheLength="20,20"
                                  EnableRowVirtualization="True"
                                  ScrollViewer.CanContentScroll="True"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  AlternatingRowBackground="#FAFAFA">

                            <!-- Group by Type -->
                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="GroupItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="GroupItem">
                                                        <Expander IsExpanded="True" Background="#F5F5F5">
                                                            <Expander.Header>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontWeight="Bold"
                                                                               FontSize="14"
                                                                               Margin="5,0,10,0"/>
                                                                    <TextBlock Text="{Binding ItemCount, StringFormat='({0} entries)'}"
                                                                               Foreground="#757575"/>
                                                                </StackPanel>
                                                            </Expander.Header>
                                                            <ItemsPresenter Margin="20,5,0,5"/>
                                                        </Expander>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </DataGrid.GroupStyle>

                            <DataGrid.Columns>
                                <!-- Status Icon -->
                                <DataGridTemplateColumn Header="" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="16" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="✓"/>
                                                        <Setter Property="Foreground" Value="Green"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasConflict}" Value="True">
                                                                <Setter Property="Text" Value="⚠"/>
                                                                <Setter Property="Foreground" Value="Orange"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                <Setter Property="Text" Value="✖"/>
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Hex Value -->
                                <DataGridTextColumn Header="Hex Value"
                                                    Binding="{Binding Entry, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="CharacterCasing" Value="Upper"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>

                                <!-- Character(s) -->
                                <DataGridTemplateColumn Header="Character(s)" Width="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayValue}"
                                                       FontSize="14"
                                                       Padding="8,4"
                                                       ToolTip="{Binding Value}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="14"
                                                     BorderThickness="0"
                                                     Padding="8,4"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <!-- Type -->
                                <DataGridTemplateColumn Header="Type" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="6,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource AsciiColor}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TypeDisplay}" Value="DTE">
                                                                <Setter Property="Background" Value="{StaticResource DteColor}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding TypeDisplay}" Value="MTE">
                                                                <Setter Property="Background" Value="{StaticResource MteColor}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding TypeDisplay}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="11"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Bytes -->
                                <DataGridTextColumn Header="Bytes"
                                                    Binding="{Binding ByteLength}"
                                                    Width="70"
                                                    IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Comment -->
                                <DataGridTextColumn Header="Comment"
                                                    Binding="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="*"
                                                    MinWidth="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontStyle" Value="Italic"/>
                                            <Setter Property="Foreground" Value="#757575"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="FontStyle" Value="Italic"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="Transparent"/>

                    <!-- Right Panel - Details -->
                    <Border Grid.Column="2"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="White">
                        <TabControl BorderThickness="0">
                            <!-- Details Tab -->
                            <TabItem Header="📝 Details">
                                <ScrollViewer>
                                    <StackPanel Margin="12" DataContext="{Binding SelectedEntry}">
                                        <!-- No selection message -->
                                        <TextBlock Text="No entry selected"
                                                   Visibility="{Binding Converter={StaticResource BooleanToVisibilityConverter}}"
                                                   FontStyle="Italic"
                                                   Foreground="#757575"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,40,0,0"/>

                                        <!-- Entry details -->
                                        <Grid Visibility="{Binding Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Hex Value -->
                                            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                                <TextBlock Text="Hex Value"
                                                           FontWeight="SemiBold"
                                                           Foreground="#212121"
                                                           Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding Entry, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="Consolas"
                                                         CharacterCasing="Upper"
                                                         Padding="10,8"
                                                         FontSize="14"/>
                                            </StackPanel>

                                            <!-- Character -->
                                            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                                                <TextBlock Text="Character"
                                                           FontWeight="SemiBold"
                                                           Foreground="#212121"
                                                           Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                         Padding="10,8"
                                                         FontSize="14"/>
                                            </StackPanel>

                                            <!-- Type & Bytes -->
                                            <Grid Grid.Row="2" Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                    <TextBlock Text="Type" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <TextBlock Text="{Binding TypeDisplay}"
                                                               Padding="10,8"
                                                               Background="#F5F5F5"
                                                               FontSize="14"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBlock Text="Bytes" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <TextBlock Text="{Binding ByteLength}"
                                                               Padding="10,8"
                                                               Background="#F5F5F5"
                                                               FontSize="14"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Validation Status -->
                                            <Border Grid.Row="3"
                                                    BorderBrush="#FF9800"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="12"
                                                    Margin="0,0,0,12"
                                                    Visibility="{Binding IsValid, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel>
                                                    <TextBlock Text="⚠ Validation Error"
                                                               FontWeight="SemiBold"
                                                               Foreground="#FF9800"/>
                                                    <TextBlock Text="{Binding ValidationError}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,6,0,0"
                                                               Foreground="#424242"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Conflicts -->
                                            <Border Grid.Row="4"
                                                    BorderBrush="#F44336"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="12"
                                                    Visibility="{Binding HasConflict, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel>
                                                    <TextBlock Text="⚠ Conflicts Detected"
                                                               FontWeight="SemiBold"
                                                               Foreground="#F44336"/>
                                                    <ItemsControl ItemsSource="{Binding Conflicts}" Margin="0,6,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Description}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,4"
                                                                           Foreground="#424242"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- Statistics Tab -->
                            <TabItem Header="📊 Stats">
                                <ScrollViewer>
                                    <StackPanel Margin="12" DataContext="{Binding Statistics}">
                                        <TextBlock Text="Entry Statistics"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Margin="0,0,0,16"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Entries:" Margin="0,8"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalCount}" FontWeight="Bold" Margin="0,8"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="ASCII:" Margin="0,8" Foreground="#757575"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AsciiCount}" Margin="0,8" Foreground="#757575"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="DTE (2-byte):" Margin="0,8" Foreground="#757575"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DteCount}" Margin="0,8" Foreground="#757575"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="MTE (3+ bytes):" Margin="0,8" Foreground="#757575"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MteCount}" Margin="0,8" Foreground="#757575"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="End Blocks:" Margin="0,8" Foreground="#757575"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EndBlockCount}" Margin="0,8" Foreground="#757575"/>

                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="End Lines:" Margin="0,8" Foreground="#757575"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding EndLineCount}" Margin="0,8" Foreground="#757575"/>

                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Coverage:" Margin="0,8" Foreground="#757575"/>
                                            <TextBlock Grid.Row="6" Grid.Column="1"
                                                       Text="{Binding CoveragePercent, StringFormat={}{0:F1}%}"
                                                       Margin="0,8"
                                                       Foreground="#757575"/>
                                        </Grid>

                                        <Button Command="{Binding DataContext.RefreshStatisticsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Content="Refresh Statistics"
                                                Style="{StaticResource ModernButton}"
                                                Margin="0,24,0,0"
                                                HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- Advanced Tab -->
                            <TabItem Header="⚙ Advanced">
                                <ScrollViewer>
                                    <StackPanel Margin="12">
                                        <TextBlock Text="Advanced Operations"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Margin="0,0,0,16"/>

                                        <Button Command="{Binding DetectConflictsCommand}"
                                                Style="{StaticResource ModernButton}"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="⚠ Analyze Conflicts" FontWeight="SemiBold"/>
                                                <TextBlock Text="Detect prefix and duplicate conflicts"
                                                           FontSize="11"
                                                           Foreground="#E0E0E0"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Button>

                                        <Separator Margin="0,16" Background="#E0E0E0"/>

                                        <TextBlock Text="Templates" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <Button Content="Load Template..."
                                                Style="{StaticResource CancelButton}"
                                                Command="{Binding LoadTemplateCommand}"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,0,0,8"/>
                                        <Button Content="Save as Template..."
                                                Style="{StaticResource CancelButton}"
                                                Command="{Binding SaveTemplateCommand}"
                                                HorizontalAlignment="Stretch"
                                                Margin="0,0,0,0"/>

                                        <Separator Margin="0,16" Background="#E0E0E0"/>

                                        <TextBlock Text="Generation" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <Button Style="{StaticResource ModernButton}"
                                                HorizontalAlignment="Stretch">
                                            <StackPanel>
                                                <TextBlock Text="✨ Generate from Text" FontWeight="SemiBold"/>
                                                <TextBlock Text="Discover encoding from sample text"
                                                           FontSize="11"
                                                           Foreground="#E0E0E0"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>

                <!-- Action Buttons -->
                <Grid Grid.Row="4" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Entry count info -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="14" Foreground="#757575">
                            <Run Text="{Binding Entries.Count, Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text="entries"/>
                        </TextBlock>
                        <TextBlock Text=" │ " Margin="8,0" Foreground="#E0E0E0"/>
                        <TextBlock FontSize="14" Foreground="#757575">
                            <Run Text="{Binding Statistics.ConflictCount, Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text="conflicts"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Dialog buttons -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Apply to Editor"
                                Style="{StaticResource ModernButton}"
                                Padding="16,10"
                                Margin="0,0,8,0"
                                Click="ApplyToEditor_Click"
                                IsDefault="True"/>
                        <Button Content="Close"
                                Style="{StaticResource CancelButton}"
                                Padding="16,10"
                                Click="Close_Click"
                                IsCancel="True"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

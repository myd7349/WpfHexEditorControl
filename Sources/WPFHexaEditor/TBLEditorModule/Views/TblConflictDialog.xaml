<Window x:Class="WpfHexaEditor.TBLEditorModule.Views.TblConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TBL Conflict Analysis"
        Height="650" Width="950"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- V2 Style - CardBorder with DropShadow -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.2" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- V2 Style - ModernButton (Primary) -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004275"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#9E9E9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- V2 Style - CancelButton (Secondary) -->
        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BDBDBD"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#9E9E9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Severity to Color Converter -->
        <SolidColorBrush x:Key="ErrorColor" Color="#F44336"/>
        <SolidColorBrush x:Key="WarningColor" Color="#FF9800"/>
        <SolidColorBrush x:Key="InfoColor" Color="#2196F3"/>
    </Window.Resources>

    <Grid Margin="25">
        <Border Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>    <!-- Header -->
                    <RowDefinition Height="Auto"/>    <!-- Summary -->
                    <RowDefinition Height="*"/>       <!-- Conflicts List -->
                    <RowDefinition Height="Auto"/>    <!-- Details Panel -->
                    <RowDefinition Height="Auto"/>    <!-- Buttons -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="⚠ TBL Conflict Analysis"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#212121"/>
                    <TextBlock Text="Review and resolve conflicts in your TBL character table"
                               FontSize="12"
                               Foreground="#757575"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Summary Statistics -->
                <Border Grid.Row="1"
                        Background="#FAFAFA"
                        CornerRadius="4"
                        Padding="16"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Errors -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ErrorCount}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ErrorColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Errors"
                                       FontSize="14"
                                       Foreground="#757575"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Warnings -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding WarningCount}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource WarningColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Warnings"
                                       FontSize="14"
                                       Foreground="#757575"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Info -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding InfoCount}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InfoColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Info"
                                       FontSize="14"
                                       Foreground="#757575"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Conflicts List -->
                <Border Grid.Row="2"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="0,0,0,16">
                    <Grid>
                        <!-- No conflicts message -->
                        <TextBlock Text="✓ No conflicts detected!"
                                   FontSize="16"
                                   Foreground="#4CAF50"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Visibility>
                                <Binding Path="Conflicts.Count">
                                    <Binding.Converter>
                                        <BooleanToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </TextBlock.Visibility>
                        </TextBlock>

                        <!-- Conflicts DataGrid -->
                        <DataGrid ItemsSource="{Binding Conflicts}"
                                  SelectedItem="{Binding SelectedConflict}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  AlternatingRowBackground="#FAFAFA">
                            <DataGrid.Visibility>
                                <Binding Path="Conflicts.Count">
                                    <Binding.Converter>
                                        <BooleanToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </DataGrid.Visibility>

                            <DataGrid.Columns>
                                <!-- Severity Icon -->
                                <DataGridTemplateColumn Header="" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="20" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="ℹ"/>
                                                        <Setter Property="Foreground" Value="{StaticResource InfoColor}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                                <Setter Property="Text" Value="✖"/>
                                                                <Setter Property="Foreground" Value="{StaticResource ErrorColor}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                <Setter Property="Text" Value="⚠"/>
                                                                <Setter Property="Foreground" Value="{StaticResource WarningColor}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Type -->
                                <DataGridTextColumn Header="Type"
                                                    Binding="{Binding Type}"
                                                    Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Entry -->
                                <DataGridTextColumn Header="Entry"
                                                    Binding="{Binding Entry}"
                                                    Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Description -->
                                <DataGridTextColumn Header="Description"
                                                    Binding="{Binding Description}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Count -->
                                <DataGridTextColumn Header="Entries"
                                                    Binding="{Binding ConflictingEntries.Count}"
                                                    Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                            <Setter Property="Background" Value="#FFF3E0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Details Panel -->
                <Border Grid.Row="3"
                        Background="#FAFAFA"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12"
                        Margin="0,0,0,16"
                        Visibility="{Binding SelectedConflict, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Expander IsExpanded="True"
                              Background="Transparent"
                              BorderThickness="0">
                    <Expander.Header>
                        <TextBlock Text="Conflict Details" FontWeight="SemiBold" FontSize="14"/>
                    </Expander.Header>
                    <StackPanel Margin="0,12,0,0" DataContext="{Binding SelectedConflict}">
                        <!-- Description -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Description"
                                       FontWeight="SemiBold"
                                       Foreground="#212121"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding Description}"
                                       TextWrapping="Wrap"
                                       Foreground="#424242"/>
                        </StackPanel>

                        <!-- Suggestion -->
                        <Border Background="#E3F2FD"
                                CornerRadius="4"
                                Padding="12"
                                Margin="0,0,0,12"
                                Visibility="{Binding Suggestion, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="💡 Suggestion"
                                           FontWeight="SemiBold"
                                           Foreground="#0078D4"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Suggestion}"
                                           TextWrapping="Wrap"
                                           Foreground="#424242"/>
                            </StackPanel>
                        </Border>

                        <!-- Conflicting Entries -->
                        <StackPanel>
                            <TextBlock Text="Conflicting Entries"
                                       FontWeight="SemiBold"
                                       Foreground="#212121"
                                       Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding ConflictingEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E0E0E0"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Background="White"
                                                Padding="10"
                                                Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Entry}"
                                                           FontFamily="Consolas"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           Margin="16,0,0,0"
                                                           FontSize="14"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Type}"
                                                           Foreground="#757575"
                                                           HorizontalAlignment="Right"
                                                           FontSize="12"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                    </Expander>
                </Border>

                <!-- Buttons -->
                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Export Report"
                            Style="{StaticResource CancelButton}"
                            Padding="16,10"
                            Margin="0,0,8,0"/>
                    <Button Content="Close"
                            Style="{StaticResource ModernButton}"
                            Padding="16,10"
                            Click="CloseButton_Click"
                            IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

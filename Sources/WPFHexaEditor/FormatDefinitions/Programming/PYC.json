{
  "formatName": "Python Compiled Bytecode",
  "version": "1.0",
  "extensions": [
    ".pyc",
    ".pyo"
  ],
  "description": "Python compiled bytecode file",
  "category": "Programming",
  "author": "WPFHexaEditor Team",
  "references": {
    "specifications": [
      "Python Compiled Bytecode Format"
    ],
    "web_links": [
      "https://en.wikipedia.org/wiki/PYC"
    ]
  },
  "detection": {
    "signature": "00",
    "offset": 0,
    "required": false
  },
  "variables": {
    "currentOffset": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "Magic Number",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Python version-specific magic"
    },
    {
      "type": "field",
      "name": "Timestamp",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Source file modification time"
    },
    {
      "type": "field",
      "name": "File Size",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Source file size"
    }
  ]
}
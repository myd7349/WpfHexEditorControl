        {
            "type": "field",
            "name": "Length",
            "offset": 8,
            "length": 4,
            "color": "#95E1D3",
            "opacity": 0.3,
            "description": "Total WOFF file size"
        },
        {
            "type": "field",
            "name": "Num Tables",
            "offset": 12,
            "length": 2,
            "color": "#FFE66D",
            "opacity": 0.3,

{
  "formatName": "IPFIX",
  "version": "1.0",
  "extensions": [ ".ipfix" ],
  "description": "IP Flow Information Export - Network flow monitoring protocol",
  "author": "WPFHexaEditor Team",

  "detection": {
    "signature": "000A",
    "offset": 0,
    "required": true
  },

  "variables": {
    "currentOffset": 0
  },

  "blocks": [
    {
      "type": "signature",
      "name": "IPFIX Version",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Version 10 (0x000A)"
    },
    {
      "type": "field",
      "name": "Message Length",
      "offset": 2,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Total length of IPFIX message"
    },
    {
      "type": "field",
      "name": "Export Time",
      "offset": 4,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Unix timestamp (seconds)"
    },
    {
      "type": "field",
      "name": "Sequence Number",
      "offset": 8,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Incremental sequence counter"
    },
    {
      "type": "field",
      "name": "Observation Domain ID",
      "offset": 12,
      "length": 4,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "Source ID for flow data"
    },
    {
      "type": "field",
      "name": "Set ID",
      "offset": 16,
      "length": 2,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Set identifier (2=template, 3=options, 256+=data)"
    },
    {
      "type": "field",
      "name": "Set Length",
      "offset": 18,
      "length": 2,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Length of this set"
    }
  ]
}

{
  "formatName": "MGH/MGZ Medical Image",
  "version": "1.0",
  "extensions": [
    ".mgh",
    ".mgz"
  ],
  "description": "MGH/MGZ FreeSurfer medical image format",
  "category": "Medical",
  "author": "WPFHexaEditor Team",
  "references": {
    "specifications": [
      "MGH/MGZ Medical Image Format"
    ],
    "web_links": [
      "https://en.wikipedia.org/wiki/MGH"
    ]
  },
  "detection": {
    "signature": "00000001",
    "offset": 0,
    "required": true
  },
  "variables": {
    "currentOffset": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Version",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "MGH version (1)"
    },
    {
      "type": "field",
      "name": "Width",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Image width"
    },
    {
      "type": "field",
      "name": "Height",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Image height"
    },
    {
      "type": "field",
      "name": "Depth",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Image depth"
    }
  ]
}
{
  "formatName": "Portable Pixmap",
  "version": "1.0",
  "extensions": [ ".ppm" ],
  "description": "Netpbm Portable Pixmap (RGB color)",
  "author": "WPFHexaEditor Team",

  "detection": {
    "signature": "5033",
    "offset": 0,
    "required": true
  },

  "variables": {},

  "blocks": [
    {
      "type": "signature",
      "name": "PPM Magic",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "P3 or P6 magic number"
    },
    {
      "type": "field",
      "name": "Header",
      "offset": 2,
      "length": 32,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "ASCII header (width, height, maxval)"
    }
  ]
}

{
    "formatName": "JPEG-LS Lossless",
    "version": "1.0",
    "extensions": [
        ".jls"
    ],
    "description": "JPEG-LS Lossless/Near-lossless compression",
    "category": "Images",
    "author": "WPFHexaEditor Team",
    "references": {
        "specifications": [
            "ISO/IEC 10918-1 - Digital Compression and Coding",
            "JFIF File Format Specification",
            "ITU-T T.81"
        ],
        "web_links": [
            "https://www.w3.org/Graphics/JPEG/",
            "https://jpeg.org/jpeg/",
            "https://en.wikipedia.org/wiki/JPEG"
        ]
    },
    "detection": {
        "signature": "FFD8FFF7",
        "offset": 0,
        "required": true
    },
    "variables": {},
    "blocks": [
        {
            "type": "signature",
            "name": "JPEG-LS SOI + SOF55",
            "offset": 0,
            "length": 4,
            "color": "#FF6B6B",
            "opacity": 0.4,
            "description": "Start of Image + SOF55 marker"
        },
        {
            "type": "field",
            "name": "SOF55 Length",
            "offset": 4,
            "length": 2,
            "color": "#4ECDC4",
            "opacity": 0.3,
            "description": "Start of Frame length"
        }
    ]
}
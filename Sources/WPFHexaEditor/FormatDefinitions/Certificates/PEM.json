{
  "formatName": "PEM Certificate",
  "version": "1.0",
  "extensions": [ ".pem", ".crt", ".cer" ],
  "description": "PEM-encoded X.509 certificate - Base64 encoded certificate",
  "author": "WPFHexaEditor Team",

  "detection": {
    "signature": "2D2D2D2D2D424547494E20434552544946494341544544",
    "offset": 0,
    "required": true
  },

  "variables": {
    "currentOffset": 0

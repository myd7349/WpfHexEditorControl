    },
    {
      "type": "field",
      "name": "Base64 Line 1",
      "offset": 29,
      "length": 64,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "First line of Base64 encoded certificate"
    },
    {
      "type": "field",
      "name": "Newline",
      "offset": 93,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "CRLF line ending"
    },
    {
      "type": "field",
      "name": "Base64 Data",
      "offset": 95,
      "length": 512,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "Base64 encoded DER certificate data"

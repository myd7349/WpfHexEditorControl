{
    "formatName": "Windows Executable (PE)",
    "version": "1.0",
    "extensions": [
        ".exe",
        ".dll",
        ".sys",
        ".scr"
    ],
    "description": "Windows Portable Executable format",
    "category": "Executables",
    "author": "WPFHexaEditor Team",
    "references": {
        "specifications": [
            "Microsoft PE and COFF Specification",
            "Portable Executable Format"
        ],
        "web_links": [
            "https://docs.microsoft.com/en-us/windows/win32/debug/pe-format",
            "https://en.wikipedia.org/wiki/Portable_Executable"
        ]
    },
    "detection": {
        "signature": "4D5A",
        "offset": 0,
        "required": true
    },
    "variables": {},
    "blocks": [
        {
            "type": "signature",
            "name": "DOS MZ Signature",
            "offset": 0,
            "length": 2,
            "color": "#FF6B6B",
            "opacity": 0.4,
            "description": "MZ magic bytes"
        },
        {
            "type": "field",
            "name": "Bytes on Last Page",
            "offset": 2,
            "length": 2,
            "color": "#4ECDC4",
            "opacity": 0.3,
            "description": "Bytes on last 512-byte page"
        },
        {
            "type": "field",
            "name": "Pages in File",
            "offset": 4,
            "length": 2,
            "color": "#95E1D3",
            "opacity": 0.3,
            "description": "Number of 512-byte pages"
        },
        {
            "type": "field",
            "name": "Relocations",
            "offset": 6,
            "length": 2,
            "color": "#FFE66D",
            "opacity": 0.3,
            "description": "Number of relocation entries"
        },
        {
            "type": "field",
            "name": "Header Paragraphs",
            "offset": 8,
            "length": 2,
            "color": "#FFA07A",
            "opacity": 0.3,
            "description": "Size of header in 16-byte paragraphs"
        },
        {
            "type": "field",
            "name": "Min Extra Paragraphs",
            "offset": 10,
            "length": 2,
            "color": "#C7CEEA",
            "opacity": 0.3,
            "description": "Minimum extra memory paragraphs"
        },
        {
            "type": "field",
            "name": "Max Extra Paragraphs",
            "offset": 12,
            "length": 2,
            "color": "#B8B8FF",
            "opacity": 0.3,
            "description": "Maximum extra memory paragraphs"
        },
        {
            "type": "field",
            "name": "Initial SS",
            "offset": 14,
            "length": 2,
            "color": "#FF6B9D",
            "opacity": 0.3,
            "description": "Initial stack segment value"
        },
        {
            "type": "field",
            "name": "Initial SP",
            "offset": 16,
            "length": 2,
            "color": "#C44569",
            "opacity": 0.3,
            "description": "Initial stack pointer value"
        },
        {
            "type": "field",
            "name": "Checksum",
            "offset": 18,
            "length": 2,
            "color": "#98D8C8",
            "opacity": 0.3,
            "description": "DOS header checksum"
        },
        {
            "type": "field",
            "name": "Initial IP",
            "offset": 20,
            "length": 2,
            "color": "#A8E6CF",
            "opacity": 0.3,
            "description": "Initial instruction pointer"
        },
        {
            "type": "field",
            "name": "Initial CS",
            "offset": 22,
            "length": 2,
            "color": "#FFDDC1",
            "opacity": 0.3,
            "description": "Initial code segment value"
        },
        {
            "type": "field",
            "name": "Reloc Table Offset",
            "offset": 24,
            "length": 2,
            "color": "#FFC8DD",
            "opacity": 0.3,
            "description": "Offset to relocation table"
        },
        {
            "type": "field",
            "name": "Overlay Number",
            "offset": 26,
            "length": 2,
            "color": "#BDB2FF",
            "opacity": 0.3,
            "description": "Overlay number"
        },
        {
            "type": "field",
            "name": "PE Header Offset",
            "offset": 60,
            "length": 4,
            "color": "#FFC6FF",
            "opacity": 0.4,
            "description": "Offset to PE header (e_lfanew)"
        }
    ]
}
            "type": "signature",
            "name": "ZIP Signature",
            "offset": 0,
            "length": 4,
            "color": "#FF6B6B",
            "opacity": 0.4,
            "description": "EPUB is a ZIP container"
        },
        {
            "type": "field",
            "name": "ZIP Header",
            "offset": 4,
            "length": 26,
            "color": "#4ECDC4",
            "opacity": 0.3,
            "description": "ZIP local file header"
        }
    ]
}
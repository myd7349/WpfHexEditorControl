{
    "formatName": "EPUB eBook",
    "version": "1.0",
    "extensions": [
        ".epub"
    ],
    "description": "Electronic Publication - eBook format",
    "category": "Documents",
    "author": "WPFHexaEditor Team",
    "references": {
        "specifications": [
            "EPUB 3.2 Specification",
            "ISO/IEC TS 30135 - EPUB File Format"
        ],
        "web_links": [
            "https://www.w3.org/publishing/epub3/epub-spec.html",
            "https://en.wikipedia.org/wiki/EPUB"
        ]
    },
    "detection": {
        "signature": "504B0304",
        "offset": 0,
        "required": true
    },
    "variables": {

{
  "formatName": "XML Paper Specification",
  "version": "1.0",
  "extensions": [
    ".xps"
  ],
  "description": "Microsoft XPS (XML Paper Specification) document format, a ZIP-based fixed-layout document format",
  "category": "Documents",
  "author": "WPFHexaEditor Team",
  "references": {
    "specifications": [
      "XML Paper Specification Format"
    ],
    "web_links": [
      "https://en.wikipedia.org/wiki/XPS"
    ]
  },
  "detection": {
    "signature": "504B0304",
    "offset": 0,
    "required": true
  },
  "variables": {},
  "blocks": [
    {
      "type": "signature",
      "name": "ZIP Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "ZIP archive signature: 'PK' 0x03 0x04 (XPS uses ZIP format)"
    },
    {
      "type": "data",
      "name": "Version",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.4,
      "description": "ZIP version needed to extract"
    },
    {
      "type": "data",
      "name": "Flags",
      "offset": 6,
      "length": 2,
      "color": "#45B7D1",
      "opacity": 0.4,
      "description": "General purpose bit flag"
    },
    {
      "type": "data",
      "name": "Compression Method",
      "offset": 8,
      "length": 2,
      "color": "#96CEB4",
      "opacity": 0.4,
      "description": "Compression method (0=stored, 8=deflated)"
    }
  ]
}
{
  "formatName": "PowerPoint Presentation",
  "version": "1.0",
  "extensions": [
    ".pptx"
  ],
  "description": "Microsoft PowerPoint Open XML presentation",
  "category": "Documents",
  "author": "WPFHexaEditor Team",
  "references": {
    "specifications": [
      "PowerPoint Presentation Format"
    ],
    "web_links": [
      "https://en.wikipedia.org/wiki/PPTX"
    ]
  },
  "detection": {
    "signature": "504B0304",
    "offset": 0,
    "required": true
  },
  "variables": {

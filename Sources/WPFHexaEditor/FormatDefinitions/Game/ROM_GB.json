            "storeAs": "gameTitle",
            "description": "Game title in ASCII (padded with null bytes)"
        },
        {
            "type": "field",
            "name": "CGB Flag",
            "offset": 323,
            "length": 1,
            "color": "#FFE66D",
            "opacity": 0.3,
            "valueType": "uint8",
            "storeAs": "cgbFlag",

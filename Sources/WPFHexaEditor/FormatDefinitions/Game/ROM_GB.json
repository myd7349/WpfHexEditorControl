        {
            "type": "field",
            "name": "SGB Flag",
            "offset": 326,
            "length": 1,
            "color": "#C7CEEA",
            "opacity": 0.3,
            "valueType": "uint8",
            "description": "0x03=SGB functions supported, 0x00=no SGB"
        },
        {
            "type": "field",
            "name": "Cartridge Type",
            "offset": 327,
            "length": 1,
            "color": "#FFE66D",
            "opacity": 0.3,
            "valueType": "uint8",
            "storeAs": "cartType",
            "description": "MBC type: 0x00=ROM only, 0x01=MBC1, 0x02=MBC1+RAM, 0x03=MBC1+RAM+BATTERY, etc."
        },
        {
            "type": "field",
            "name": "ROM Size Code",
            "offset": 328,
            "length": 1,
            "color": "#95E1D3",
            "opacity": 0.3,
            "valueType": "uint8",
            "description": "ROM size: 0=32KB, 1=64KB, 2=128KB, 3=256KB, 4=512KB, 5=1MB, 6=2MB, 7=4MB, 8=8MB"
        },
        {
            "type": "field",
            "name": "RAM Size Code",
            "offset": 329,
            "length": 1,
            "color": "#95E1D3",
            "opacity": 0.3,
            "valueType": "uint8",
            "description": "External RAM: 0=None, 2=8KB, 3=32KB, 4=128KB, 5=64KB"
        },
        {
            "type": "field",
            "name": "Destination Code",
            "offset": 330,
            "length": 1,
            "color": "#C7CEEA",
            "opacity": 0.3,
            "valueType": "uint8",
            "description": "0x00=Japan only, 0x01=Overseas",
            "validationRules": {
                "allowedValues": [
                    0,
                    1
                ]
            }
        },
        {
            "type": "field",
            "name": "Old Licensee Code",
            "offset": 331,
            "length": 1,
            "color": "#C7CEEA",
            "opacity": 0.3,
            "valueType": "uint8",
            "description": "Old licensee (0x33 = use new licensee code at 0x144)"
        },
        {
            "type": "field",
            "name": "Mask ROM Version",
            "offset": 332,
            "length": 1,
            "color": "#C7CEEA",
            "opacity": 0.3,
            "valueType": "uint8",
            "description": "Game revision number (usually 0x00)"
        },
        {
            "type": "field",
            "name": "Header Checksum",
            "offset": 333,
            "length": 1,
            "color": "#FF6B9D",
            "opacity": 0.3,
            "valueType": "uint8",
            "storeAs": "headerChecksum",
            "description": "8-bit checksum of header bytes 0x0134-0x014C"
        },
        {
            "type": "field",
            "name": "Global Checksum",
            "offset": 334,
            "length": 2,
            "color": "#FF6B9D",
            "opacity": 0.3,
            "valueType": "uint16",
            "description": "16-bit big-endian sum of all bytes in ROM (not verified by hardware)"
        }
    ]

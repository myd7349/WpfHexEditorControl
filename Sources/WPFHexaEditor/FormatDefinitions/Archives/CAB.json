{
    "formatName": "Cabinet Archive",
    "version": "1.0",
    "extensions": [
        ".cab"
    ],
    "description": "Microsoft Cabinet archive format",
    "category": "Archives",
    "author": "WPFHexaEditor Team",
    "references": {
        "specifications": [
            "POSIX.1-1988 (IEEE Std 1003.1)",
            "GNU tar Format Documentation",
            "UStar Format Specification"
        ],
        "web_links": [
            "https://www.gnu.org/software/tar/manual/",
            "https://en.wikipedia.org/wiki/Tar_(computing)",
            "https://pubs.opengroup.org/onlinepubs/9699919799/utilities/pax.html"
        ]
    },
    "detection": {
        "signature": "4D534346",
        "offset": 0,
        "required": true
    },
    "variables": {
        "currentOffset": 0
    },
    "blocks": [
        {
            "type": "signature",
            "name": "CAB Signature",
            "offset": 0,
            "length": 4,
            "color": "#FF6B6B",
            "opacity": 0.4,
            "description": "MSCF magic bytes"
        },
        {
            "type": "field",
            "name": "Reserved",
            "offset": 4,
            "length": 4,
            "color": "#4ECDC4",
            "opacity": 0.3,
            "description": "Reserved field"
        },
        {
            "type": "field",
            "name": "Cabinet Size",
            "offset": 8,
            "length": 4,
            "color": "#95E1D3",
            "opacity": 0.3,
            "description": "Total cabinet file size"
        },
        {
            "type": "field",
            "name": "Files Offset",
            "offset": 16,
            "length": 4,
            "color": "#FFE66D",
            "opacity": 0.3,
            "description": "Offset to first file entry"
        }
    ]
}
  <PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Debug|netcoreapp3.1|AnyCPU'">
    <DefineConstants>TRACE;DEBUG</DefineConstants>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <!-- Profile-Guided Optimization (PGO) Configuration for .NET 8.0+ -->
  <!-- Enables dynamic runtime optimization based on actual usage patterns -->
  <PropertyGroup Condition="'$(Configuration)'=='Release' and '$(TargetFramework)'=='net8.0-windows'">
    <!-- Enable Tiered Compilation: Quick JIT initially, then optimize hot paths -->
    <TieredCompilation>true</TieredCompilation>

    <!-- Enable Dynamic PGO: Runtime profiling + recompilation of hot methods -->
    <!-- Provides 10-30% performance boost for CPU-intensive operations -->
    <TieredPGO>true</TieredPGO>

    <!-- Enable ReadyToRun: Ahead-of-time compilation for faster startup -->
    <!-- Reduces JIT time on first run by 30-50% -->
    <PublishReadyToRun>true</PublishReadyToRun>

    <!-- Embed debug info for better profiling without separate PDB files -->
    <DebugType>embedded</DebugType>

    <!-- Enable full compiler optimizations -->
    <Optimize>true</Optimize>
  </PropertyGroup>

  <!-- Standard optimizations for .NET Framework 4.8 (no Dynamic PGO support) -->
  <PropertyGroup Condition="'$(Configuration)'=='Release' and '$(TargetFramework)'=='net48'">
    <Optimize>true</Optimize>
    <DebugType>embedded</DebugType>
  </PropertyGroup>


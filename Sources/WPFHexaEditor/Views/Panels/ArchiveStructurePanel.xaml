<UserControl x:Class="WpfHexaEditor.Views.Panels.ArchiveStructurePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350">

    <UserControl.Resources>
        <HierarchicalDataTemplate x:Key="TreeTemplate" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SizeInfo}"
                           FontSize="10"
                           Foreground="Gray"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusIcon}"
                           FontSize="12"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="📦 Archive Structure"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1"
                           x:Name="ArchiveInfoText"
                           Text="No archive loaded"
                           FontSize="10"
                           Foreground="Gray"/>
            </Grid>
        </Border>

        <!-- Tree View -->
        <TreeView Grid.Row="1"
                  x:Name="StructureTreeView"
                  ItemTemplate="{StaticResource TreeTemplate}"
                  ItemContainerStyle="{StaticResource TreeViewItemStyle}"
                  BorderThickness="0"
                  Padding="8"
                  SelectedItemChanged="StructureTreeView_SelectedItemChanged">
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Extract..." Click="Extract_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📤" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="View Details" Click="ViewDetails_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="ℹ️" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Expand All" Click="ExpandAll_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="➕" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Collapse All" Click="CollapseAll_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="➖" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="FileCountText" Text="0 files" FontSize="10" Margin="0,0,12,0"/>
                    <TextBlock x:Name="FolderCountText" Text="0 folders" FontSize="10" Margin="0,0,12,0"/>
                    <TextBlock x:Name="TotalSizeText" Text="0 bytes" FontSize="10"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           x:Name="CompressionRatioText"
                           Text="Ratio: N/A"
                           FontSize="10"
                           Foreground="Gray"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>

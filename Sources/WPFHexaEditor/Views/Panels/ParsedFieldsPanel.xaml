<UserControl x:Class="WpfHexaEditor.Views.Panels.ParsedFieldsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300"
             Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

    <UserControl.Resources>
        <!-- Style for field items -->
        <Style x:Key="FieldItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Data template for parsed fields -->
        <DataTemplate x:Key="FieldTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Color indicator -->
                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        Width="4" Margin="0,0,8,0"
                        Background="{Binding Color}"
                        CornerRadius="2"/>

                <!-- Field name -->
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding Name}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Name}"/>

                <!-- Field value -->
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Value: "
                               FontSize="11"
                               Foreground="#666666"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding FormattedValue}"
                               FontSize="11"
                               FontFamily="Consolas"
                               Foreground="#2196F3"
                               TextWrapping="Wrap"
                               ToolTip="{Binding FormattedValue}"/>
                </Grid>

                <!-- Field details -->
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Margin="0,2,0,0"
                           FontSize="10"
                           Foreground="#999999">
                    <Run Text="{Binding RangeDisplay}"/>
                    <Run Text=" • "/>
                    <Run Text="{Binding ValueType}"/>
                </TextBlock>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#2196F3"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Parsed Fields"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="RefreshButton"
                            Content="🔄"
                            Width="30" Height="30"
                            Margin="4,0,0,0"
                            ToolTip="Refresh field values"
                            Click="RefreshButton_Click"
                            Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Format info -->
        <Border Grid.Row="1"
                Background="#F5F5F5"
                Padding="12,8"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0"
                Visibility="{Binding FormatInfo.IsDetected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4">
                    <Run Text="Format:"/>
                    <Run Text="{Binding FormatInfo.Name}" Foreground="#2196F3"/>
                </TextBlock>
                <TextBlock FontSize="11" Foreground="#666666" TextWrapping="Wrap"
                           Text="{Binding FormatInfo.Description}"/>
            </StackPanel>
        </Border>

        <!-- Fields list -->
        <ListBox x:Name="FieldsListBox"
                 Grid.Row="2"
                 ItemsSource="{Binding ParsedFields}"
                 ItemTemplate="{StaticResource FieldTemplate}"
                 ItemContainerStyle="{StaticResource FieldItemStyle}"
                 SelectionChanged="FieldsListBox_SelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 BorderThickness="0">
            <ListBox.Style>
                <Style TargetType="ListBox">
                    <Style.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBox">
                                        <Border Background="White">
                                            <TextBlock Text="No fields parsed yet.&#x0a;Open a file to see its structure."
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     TextAlignment="Center"
                                                     Foreground="#999999"
                                                     FontSize="12"
                                                     Margin="20"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
        </ListBox>

        <!-- Status bar -->
        <Border Grid.Row="3"
                Background="#F5F5F5"
                Padding="12,6"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           FontSize="11"
                           Foreground="#666666">
                    <Run Text="{Binding ParsedFields.Count}"/>
                    <Run Text="field(s)"/>
                </TextBlock>

                <ComboBox x:Name="FormatterComboBox"
                          Grid.Column="1"
                          Width="120"
                          FontSize="11"
                          SelectionChanged="FormatterComboBox_SelectionChanged"
                          ToolTip="Choose value display format">
                    <ComboBoxItem Content="Hexadecimal" Tag="hex" IsSelected="True"/>
                    <ComboBoxItem Content="Decimal" Tag="decimal"/>
                    <ComboBoxItem Content="String" Tag="string"/>
                    <ComboBoxItem Content="Mixed" Tag="mixed"/>
                </ComboBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="WpfHexaEditor.Views.Panels.ParsedFieldsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300"
             Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

    <UserControl.Resources>
        <!-- Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Style for field items with improved colors -->
        <Style x:Key="FieldItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EEEEEE"/>
            <EventSetter Event="MouseDoubleClick" Handler="FieldItem_MouseDoubleClick"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#E1F5FE" Offset="0"/>
                                <GradientStop Color="#B3E5FC" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="#01579B"/>
                    <Setter Property="BorderBrush" Value="#81D4FA"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFAFA"/>
                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#B3E5FC" Offset="0"/>
                                <GradientStop Color="#81D4FA" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- Data template for parsed fields -->
        <DataTemplate x:Key="FieldTemplate">
            <Border Padding="4,2" CornerRadius="4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                <Setter Property="Background" Value="#FFEBEE"/>
                                <Setter Property="BorderBrush" Value="#F44336"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="{Binding IndentMargin}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Color indicator -->
                    <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="0"
                            Width="4" Margin="0,0,8,0"
                            Background="{Binding Color}"
                            CornerRadius="2"/>

                    <!-- Icon -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="1"
                               Text="{Binding FieldIcon}"
                               FontSize="14"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               ToolTip="{Binding ValueType}"/>

                    <!-- Validation warning icon -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="2"
                               Text="⚠"
                               FontSize="14"
                               Margin="0,0,6,0"
                               Foreground="#F44336"
                               VerticalAlignment="Center"
                               ToolTip="{Binding ValidationMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Search match indicator -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="3"
                               Text="🔍"
                               FontSize="11"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="#4CAF50"
                               ToolTip="Search match"
                               Visibility="{Binding IsSearchMatch, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Bookmark indicator -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="3"
                               Text="⭐"
                               FontSize="12"
                               Margin="14,0,6,0"
                               VerticalAlignment="Center"
                               ToolTip="Bookmarked"
                               Visibility="{Binding IsBookmarked, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Field name -->
                    <TextBlock Grid.Row="0" Grid.Column="4"
                               Text="{Binding Name}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding DetailedTooltip}"/>

                    <!-- Field value -->
                    <Grid Grid.Row="1" Grid.Column="4" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Value: "
                                   FontSize="11"
                                   Foreground="#666666"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding FormattedValue}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   Foreground="#2196F3"
                                   TextWrapping="Wrap"
                                   ToolTip="{Binding DetailedTooltip}"/>
                    </Grid>

                    <!-- Field details -->
                    <TextBlock Grid.Row="2" Grid.Column="4"
                               Margin="0,2,0,0"
                               FontSize="10"
                               Foreground="#999999">
                        <Run Text="{Binding RangeDisplay, Mode=OneWay}"/>
                        <Run Text=" • "/>
                        <Run Text="{Binding ValueType, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Validation error message -->
                    <TextBlock Grid.Row="3" Grid.Column="4"
                               Margin="0,4,0,0"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#F44336"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> <!-- Search box -->
            <RowDefinition Height="Auto"/> <!-- Quick Actions -->
            <RowDefinition Height="Auto"/> <!-- Format info -->
            <RowDefinition Height="*"/>    <!-- Fields list -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Header with gradient -->
        <Border Grid.Row="0" Padding="12,8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E88E5" Offset="0"/>
                    <GradientStop Color="#1976D2" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📋" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Parsed Fields"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ToggleButton x:Name="ShowBookmarksButton"
                                  Content="⭐"
                                  Width="32" Height="32"
                                  Margin="4,0,0,0"
                                  ToolTip="Show bookmarked fields only"
                                  Checked="ShowBookmarksButton_Checked"
                                  Unchecked="ShowBookmarksButton_Unchecked"
                                  Style="{DynamicResource {x:Static ToolBar.ToggleButtonStyleKey}}"/>
                    <Button x:Name="RefreshButton"
                            Content="🔄"
                            Width="32" Height="32"
                            Margin="4,0,0,0"
                            ToolTip="Refresh field values (F5)"
                            Click="RefreshButton_Click"
                            Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search box -->
        <Border Grid.Row="1"
                Background="White"
                Padding="12,8"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search icon and textbox -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="🔍"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox x:Name="SearchTextBox"
                         Grid.Row="0" Grid.Column="1"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12"
                         Padding="4"
                         VerticalAlignment="Center"
                         BorderThickness="1"
                         BorderBrush="#CCCCCC">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search fields..."
                                                             Foreground="#999999"
                                                             FontSize="12"
                                                             Margin="4,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button x:Name="ClearSearchButton"
                        Grid.Row="0" Grid.Column="2"
                        Content="✕"
                        Width="24" Height="24"
                        Margin="4,0,0,0"
                        FontSize="12"
                        ToolTip="Clear search"
                        Click="ClearSearchButton_Click"
                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}">
                    <Button.Visibility>
                        <Binding Path="SearchText">
                            <Binding.Converter>
                                <StaticResource ResourceKey="BoolToVisibilityConverter"/>
                            </Binding.Converter>
                        </Binding>
                    </Button.Visibility>
                </Button>

                <!-- Advanced search options -->
                <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                           Orientation="Horizontal"
                           Margin="0,6,0,0">
                    <CheckBox x:Name="RegexSearchCheckBox"
                              Content="Regex"
                              FontSize="10"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              Checked="SearchOption_Changed"
                              Unchecked="SearchOption_Changed"/>
                    <CheckBox x:Name="CaseSensitiveCheckBox"
                              Content="Case-sensitive"
                              FontSize="10"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              Checked="SearchOption_Changed"
                              Unchecked="SearchOption_Changed"/>
                    <TextBlock Text="In:"
                               FontSize="10"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="#666666"/>
                    <ComboBox x:Name="SearchFieldCombo"
                              FontSize="10"
                              Width="110"
                              Margin="0,0,12,0"
                              SelectedIndex="0"
                              SelectionChanged="SearchOption_Changed">
                        <ComboBoxItem Content="All fields"/>
                        <ComboBoxItem Content="Name only"/>
                        <ComboBoxItem Content="Value only"/>
                        <ComboBoxItem Content="Description"/>
                    </ComboBox>
                    <TextBlock Text="Type:"
                               FontSize="10"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="#666666"/>
                    <ComboBox x:Name="TypeFilterCombo"
                              FontSize="10"
                              Width="100"
                              SelectedIndex="0"
                              SelectionChanged="SearchOption_Changed">
                        <ComboBoxItem Content="All types"/>
                        <ComboBoxItem Content="Integers"/>
                        <ComboBoxItem Content="Strings"/>
                        <ComboBoxItem Content="Bytes"/>
                    </ComboBox>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Quick Actions Toolbar -->
        <Border Grid.Row="2"
                Background="#FAFAFA"
                Padding="8,6"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0">
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="QuickEditButton"
                        Content="✏️ Edit"
                        Width="80" Height="32"
                        Margin="4,0"
                        FontSize="11"
                        ToolTip="Edit selected field value (Enter)"
                        Click="EditValue_Click"
                        IsEnabled="{Binding HasSelection}"
                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>

                <Button x:Name="QuickCopyButton"
                        Content="📋 Copy"
                        Width="80" Height="32"
                        Margin="4,0"
                        FontSize="11"
                        ToolTip="Copy field value (Ctrl+C)"
                        Click="CopyValue_Click"
                        IsEnabled="{Binding HasSelection}"
                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>

                <Button x:Name="QuickNavigateButton"
                        Content="🎯 Navigate"
                        Width="90" Height="32"
                        Margin="4,0"
                        FontSize="11"
                        ToolTip="Navigate to field position in hex editor"
                        Click="QuickNavigate_Click"
                        IsEnabled="{Binding HasSelection}"
                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>

                <ToggleButton x:Name="QuickBookmarkButton"
                              Content="⭐ Bookmark"
                              Width="95" Height="32"
                              Margin="4,0"
                              FontSize="11"
                              ToolTip="Toggle bookmark on selected field (Space)"
                              Click="ToggleBookmark_Click"
                              IsEnabled="{Binding HasSelection}"
                              Style="{DynamicResource {x:Static ToolBar.ToggleButtonStyleKey}}"/>

                <Separator Margin="8,0" Width="1" Background="#E0E0E0"/>

                <Button x:Name="QuickExportButton"
                        Content="💾 Export"
                        Width="85" Height="32"
                        Margin="4,0"
                        FontSize="11"
                        ToolTip="Export all fields to file"
                        Click="ExportAsText_Click"
                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
            </WrapPanel>
        </Border>

        <!-- Format info -->
        <Border Grid.Row="3"
                Background="#F5F5F5"
                Padding="12,8"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0"
                Visibility="{Binding FormatInfo.IsDetected, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontWeight="SemiBold" FontSize="12">
                        <Run Text="Format:"/>
                        <Run Text="{Binding FormatInfo.Name, Mode=OneWay}" Foreground="#2196F3"/>
                    </TextBlock>
                    <Border Grid.Column="2"
                            Background="#FFE5B4"
                            BorderBrush="#FFA500"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,2"
                            Margin="8,0,0,0">
                        <TextBlock FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#D2691E"
                                   Text="{Binding FormatInfo.Category}"/>
                    </Border>
                </Grid>
                <TextBlock FontSize="11" Foreground="#666666" TextWrapping="Wrap"
                           Text="{Binding FormatInfo.Description}"/>

                <!-- References Section -->
                <StackPanel Margin="0,12,0,0"
                            Visibility="{Binding FormatInfo.HasReferences, Converter={StaticResource BoolToVisibilityConverter}}">
                    <!-- References Header with Toggle -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ToggleButton x:Name="ShowReferencesToggle"
                                      Grid.Column="0"
                                      Content="📚 References"
                                      FontSize="11"
                                      FontWeight="SemiBold"
                                      Padding="8,4"
                                      IsChecked="True"
                                      Style="{DynamicResource {x:Static ToolBar.ToggleButtonStyleKey}}"/>

                        <Button x:Name="CopyReferencesButton"
                                Grid.Column="2"
                                Content="📋 Copy"
                                FontSize="10"
                                Padding="6,2"
                                Margin="4,0,0,0"
                                ToolTip="Copy references to clipboard"
                                Click="CopyReferences_Click"
                                Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                    </Grid>

                    <!-- References Content (collapsible) -->
                    <StackPanel Margin="0,8,0,0"
                                Visibility="{Binding IsChecked, ElementName=ShowReferencesToggle, Converter={StaticResource BoolToVisibilityConverter}}">

                        <!-- Specifications -->
                        <StackPanel Visibility="{Binding FormatInfo.References.Specifications.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Specifications:"
                                       FontWeight="SemiBold"
                                       FontSize="10"
                                       Foreground="#666666"
                                       Margin="0,0,0,4"/>
                            <ItemsControl ItemsSource="{Binding FormatInfo.References.Specifications}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="10"
                                                   Foreground="#333333"
                                                   Margin="12,2,0,2"
                                                   TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Web Links -->
                        <StackPanel Margin="0,8,0,0"
                                    Visibility="{Binding FormatInfo.References.WebLinks.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Web Links:"
                                       FontWeight="SemiBold"
                                       FontSize="10"
                                       Foreground="#666666"
                                       Margin="0,0,0,4"/>
                            <ItemsControl ItemsSource="{Binding FormatInfo.References.WebLinks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="12,2,0,2">
                                            <Hyperlink NavigateUri="{Binding}"
                                                       RequestNavigate="Hyperlink_RequestNavigate"
                                                       Foreground="#2196F3"
                                                       TextDecorations="Underline">
                                                <Run Text="{Binding}" FontSize="10"/>
                                            </Hyperlink>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Fields list -->
        <ListBox x:Name="FieldsListBox"
                 Grid.Row="4"
                 ItemsSource="{Binding FilteredFields}"
                 ItemTemplate="{StaticResource FieldTemplate}"
                 ItemContainerStyle="{StaticResource FieldItemStyle}"
                 SelectionChanged="FieldsListBox_SelectionChanged"
                 KeyDown="FieldsListBox_KeyDown"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 BorderThickness="0"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.CacheLength="20,20"
                 VirtualizingPanel.CacheLengthUnit="Item">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit Value..." Click="EditValue_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="✏️" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Toggle Bookmark" Click="ToggleBookmark_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="⭐" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Copy Offset" Click="CopyOffset_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📌" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Jump to Offset..." Click="JumpToOffset_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🔍" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Copy Value" Click="CopyValue_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📋" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Copy Details" Click="CopyDetails_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📄" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Export All Fields...">
                        <MenuItem.Icon>
                            <TextBlock Text="💾" FontSize="14"/>
                        </MenuItem.Icon>
                        <MenuItem Header="As Text" Click="ExportAsText_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📄" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As JSON" Click="ExportAsJson_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="{}{}" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As CSV" Click="ExportAsCsv_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📊" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As XML" Click="ExportAsXml_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📋" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As HTML" Click="ExportAsHtml_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="🌐" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As Markdown" Click="ExportAsMarkdown_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📝" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.Style>
                <Style TargetType="ListBox">
                    <Style.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBox">
                                        <Border Background="White">
                                            <TextBlock Text="No fields parsed yet.&#x0a;Open a file to see its structure."
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     TextAlignment="Center"
                                                     Foreground="#999999"
                                                     FontSize="12"
                                                     Margin="20"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
        </ListBox>

        <!-- Status bar -->
        <Border Grid.Row="5"
                Background="#F5F5F5"
                Padding="12,6"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           FontSize="11"
                           Foreground="#666666">
                    <Run Text="{Binding FilteredFields.Count, Mode=OneWay}"/>
                    <Run Text="/"/>
                    <Run Text="{Binding ParsedFields.Count, Mode=OneWay}"/>
                    <Run Text="field(s)"/>
                    <Run Text="{Binding SearchResultText, Mode=OneWay}" Foreground="#4CAF50" FontWeight="SemiBold"/>
                </TextBlock>

                <ComboBox x:Name="FormatterComboBox"
                          Grid.Column="1"
                          Width="120"
                          FontSize="11"
                          SelectionChanged="FormatterComboBox_SelectionChanged"
                          ToolTip="Choose value display format">
                    <ComboBoxItem Content="Mixed (Smart)" Tag="mixed" IsSelected="True"/>
                    <ComboBoxItem Content="Hexadecimal" Tag="hex"/>
                    <ComboBoxItem Content="Decimal" Tag="decimal"/>
                    <ComboBoxItem Content="String" Tag="string"/>
                </ComboBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>

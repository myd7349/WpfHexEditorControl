<UserControl x:Class="WpfHexaEditor.Views.Panels.ParsedFieldsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300"
             Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

    <UserControl.Resources>
        <!-- Style for field items -->
        <Style x:Key="FieldItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Data template for parsed fields -->
        <DataTemplate x:Key="FieldTemplate">
            <Grid Margin="{Binding IndentMargin}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Color indicator -->
                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        Width="4" Margin="0,0,8,0"
                        Background="{Binding Color}"
                        CornerRadius="2"/>

                <!-- Icon -->
                <TextBlock Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                           Text="{Binding FieldIcon}"
                           FontSize="14"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center"
                           ToolTip="{Binding ValueType}"/>

                <!-- Field name -->
                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="{Binding Name}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding DetailedTooltip}"/>

                <!-- Field value -->
                <Grid Grid.Row="1" Grid.Column="2" Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Value: "
                               FontSize="11"
                               Foreground="#666666"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding FormattedValue}"
                               FontSize="11"
                               FontFamily="Consolas"
                               Foreground="#2196F3"
                               TextWrapping="Wrap"
                               ToolTip="{Binding DetailedTooltip}"/>
                </Grid>

                <!-- Field details -->
                <TextBlock Grid.Row="2" Grid.Column="2"
                           Margin="0,2,0,0"
                           FontSize="10"
                           Foreground="#999999">
                    <Run Text="{Binding RangeDisplay}"/>
                    <Run Text=" • "/>
                    <Run Text="{Binding ValueType}"/>
                </TextBlock>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> <!-- Search box -->
            <RowDefinition Height="Auto"/> <!-- Format info -->
            <RowDefinition Height="*"/>    <!-- Fields list -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#2196F3"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Parsed Fields"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="RefreshButton"
                            Content="🔄"
                            Width="30" Height="30"
                            Margin="4,0,0,0"
                            ToolTip="Refresh field values"
                            Click="RefreshButton_Click"
                            Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search box -->
        <Border Grid.Row="1"
                Background="White"
                Padding="12,8"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="🔍"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox x:Name="SearchTextBox"
                         Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12"
                         Padding="4"
                         VerticalAlignment="Center"
                         BorderThickness="1"
                         BorderBrush="#CCCCCC">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search fields..."
                                                             Foreground="#999999"
                                                             FontSize="12"
                                                             Margin="4,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button x:Name="ClearSearchButton"
                        Grid.Column="2"
                        Content="✕"
                        Width="24" Height="24"
                        Margin="4,0,0,0"
                        FontSize="12"
                        ToolTip="Clear search"
                        Click="ClearSearchButton_Click"
                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}">
                    <Button.Visibility>
                        <Binding Path="SearchText">
                            <Binding.Converter>
                                <StaticResource ResourceKey="BoolToVisibilityConverter"/>
                            </Binding.Converter>
                        </Binding>
                    </Button.Visibility>
                </Button>
            </Grid>
        </Border>

        <!-- Format info -->
        <Border Grid.Row="2"
                Background="#F5F5F5"
                Padding="12,8"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0"
                Visibility="{Binding FormatInfo.IsDetected, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4">
                    <Run Text="Format:"/>
                    <Run Text="{Binding FormatInfo.Name}" Foreground="#2196F3"/>
                </TextBlock>
                <TextBlock FontSize="11" Foreground="#666666" TextWrapping="Wrap"
                           Text="{Binding FormatInfo.Description}"/>
            </StackPanel>
        </Border>

        <!-- Fields list -->
        <ListBox x:Name="FieldsListBox"
                 Grid.Row="3"
                 ItemsSource="{Binding FilteredFields}"
                 ItemTemplate="{StaticResource FieldTemplate}"
                 ItemContainerStyle="{StaticResource FieldItemStyle}"
                 SelectionChanged="FieldsListBox_SelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 BorderThickness="0"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.CacheLength="20,20"
                 VirtualizingPanel.CacheLengthUnit="Item">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy Value" Click="CopyValue_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📋" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Copy Details" Click="CopyDetails_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📄" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Export All Fields...">
                        <MenuItem.Icon>
                            <TextBlock Text="💾" FontSize="14"/>
                        </MenuItem.Icon>
                        <MenuItem Header="As Text" Click="ExportAsText_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📄" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As JSON" Click="ExportAsJson_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="{}{}" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As CSV" Click="ExportAsCsv_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📊" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As XML" Click="ExportAsXml_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📋" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.Style>
                <Style TargetType="ListBox">
                    <Style.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBox">
                                        <Border Background="White">
                                            <TextBlock Text="No fields parsed yet.&#x0a;Open a file to see its structure."
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     TextAlignment="Center"
                                                     Foreground="#999999"
                                                     FontSize="12"
                                                     Margin="20"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
        </ListBox>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Background="#F5F5F5"
                Padding="12,6"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           FontSize="11"
                           Foreground="#666666">
                    <Run Text="{Binding ParsedFields.Count}"/>
                    <Run Text="field(s)"/>
                </TextBlock>

                <ComboBox x:Name="FormatterComboBox"
                          Grid.Column="1"
                          Width="120"
                          FontSize="11"
                          SelectionChanged="FormatterComboBox_SelectionChanged"
                          ToolTip="Choose value display format">
                    <ComboBoxItem Content="Hexadecimal" Tag="hex" IsSelected="True"/>
                    <ComboBoxItem Content="Decimal" Tag="decimal"/>
                    <ComboBoxItem Content="String" Tag="string"/>
                    <ComboBoxItem Content="Mixed" Tag="mixed"/>
                </ComboBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>

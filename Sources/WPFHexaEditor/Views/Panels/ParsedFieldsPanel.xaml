<UserControl x:Class="WpfHexaEditor.Views.Panels.ParsedFieldsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexaEditor.Views.Panels"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300"
             Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

    <UserControl.Resources>
        <!-- Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <!-- Style for field items with improved colors -->
        <Style x:Key="FieldItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EEEEEE"/>
            <EventSetter Event="MouseDoubleClick" Handler="FieldItem_MouseDoubleClick"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#E1F5FE" Offset="0"/>
                                <GradientStop Color="#B3E5FC" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="#01579B"/>
                    <Setter Property="BorderBrush" Value="#81D4FA"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFAFA"/>
                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#B3E5FC" Offset="0"/>
                                <GradientStop Color="#81D4FA" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- Data template for parsed fields -->
        <DataTemplate x:Key="FieldTemplate">
            <Border Padding="4,2" CornerRadius="4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                <Setter Property="Background" Value="#FFEBEE"/>
                                <Setter Property="BorderBrush" Value="#F44336"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="{Binding IndentMargin}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Color indicator -->
                    <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="0"
                            Width="4" Margin="0,0,8,0"
                            Background="{Binding Color}"
                            CornerRadius="2"/>

                    <!-- Icon -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="1"
                               Text="{Binding FieldIcon}"
                               FontSize="14"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               ToolTip="{Binding ValueType}"/>

                    <!-- Validation warning icon -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="2"
                               Text="⚠"
                               FontSize="14"
                               Margin="0,0,6,0"
                               Foreground="#F44336"
                               VerticalAlignment="Center"
                               ToolTip="{Binding ValidationMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Search match indicator -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="3"
                               Text="🔍"
                               FontSize="11"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="#4CAF50"
                               ToolTip="Search match"
                               Visibility="{Binding IsSearchMatch, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Bookmark indicator -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="3"
                               Text="⭐"
                               FontSize="12"
                               Margin="14,0,6,0"
                               VerticalAlignment="Center"
                               ToolTip="Bookmarked"
                               Visibility="{Binding IsBookmarked, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Field name -->
                    <TextBlock Grid.Row="0" Grid.Column="4"
                               Text="{Binding Name}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding DetailedTooltip}"/>

                    <!-- Field value -->
                    <Grid Grid.Row="1" Grid.Column="4" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Value: "
                                   FontSize="11"
                                   Foreground="#666666"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding ActiveFormattedValue}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   Foreground="#2196F3"
                                   TextWrapping="Wrap"
                                   ToolTip="{Binding DetailedTooltip}"/>

                        <!-- Display mode toggle H/D/B (C7) -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,0,0,0"
                                    Visibility="{Binding IsNumericType, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button Content="H" Tag="hex" Click="DisplayModeButton_Click"
                                    Width="18" Height="16" FontSize="9" FontFamily="Consolas"
                                    FontWeight="SemiBold" Padding="0" Margin="1,0"
                                    ToolTip="Hexadecimal"
                                    Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                            <Button Content="D" Tag="dec" Click="DisplayModeButton_Click"
                                    Width="18" Height="16" FontSize="9" FontFamily="Consolas"
                                    FontWeight="SemiBold" Padding="0" Margin="1,0"
                                    ToolTip="Decimal"
                                    Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                            <Button Content="B" Tag="bin" Click="DisplayModeButton_Click"
                                    Width="18" Height="16" FontSize="9" FontFamily="Consolas"
                                    FontWeight="SemiBold" Padding="0" Margin="1,0"
                                    ToolTip="Binary"
                                    Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Field details -->
                    <TextBlock Grid.Row="2" Grid.Column="4"
                               Margin="0,2,0,0"
                               FontSize="10"
                               Foreground="#999999">
                        <Run Text="{Binding RangeDisplay, Mode=OneWay}"/>
                        <Run Text=" • "/>
                        <Run Text="{Binding ValueType, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Validation error message -->
                    <TextBlock Grid.Row="3" Grid.Column="4"
                               Margin="0,4,0,0"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#F44336"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> <!-- Search box -->
            <RowDefinition Height="Auto"/> <!-- Quick Actions -->
            <RowDefinition Height="Auto"/> <!-- Format info -->
            <RowDefinition Height="Auto"/> <!-- Computed Values spotlight -->
            <RowDefinition Height="Auto"/> <!-- Key Insights strip -->
            <RowDefinition Height="Auto"/> <!-- Coverage bar -->
            <RowDefinition Height="*"/>    <!-- Fields list -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Header with gradient — draggable pour tear-off flottant -->
        <Border Grid.Row="0"
                x:Name="PanelTitleBar"
                Cursor="SizeAll"
                MouseLeftButtonDown="PanelTitleBar_MouseLeftButtonDown"
                Padding="12,8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E88E5" Offset="0"/>
                    <GradientStop Color="#1976D2" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📋" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Parsed Fields"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Validation Summary Badges (C2) -->
                    <Border x:Name="ValidBadge"
                            CornerRadius="8"
                            Padding="6,2"
                            Margin="0,0,4,0"
                            Background="#4CAF50"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            ToolTip="Valid fields">
                        <TextBlock FontSize="10" Foreground="White" FontWeight="SemiBold">
                            <Run Text="&#x2713; "/>
                            <Run x:Name="ValidCountRun" Text="0"/>
                        </TextBlock>
                    </Border>
                    <Border x:Name="InvalidBadge"
                            CornerRadius="8"
                            Padding="6,2"
                            Margin="0,0,4,0"
                            Background="#F44336"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            ToolTip="Fields with validation errors"
                            MouseLeftButtonDown="InvalidBadge_Click">
                        <TextBlock FontSize="10" Foreground="White" FontWeight="SemiBold">
                            <Run Text="&#x26A0; "/>
                            <Run x:Name="InvalidCountRun" Text="0"/>
                        </TextBlock>
                    </Border>
                    <ToggleButton x:Name="ShowBookmarksButton"
                                  Content="⭐"
                                  Width="32" Height="32"
                                  Margin="4,0,0,0"
                                  ToolTip="Show bookmarked fields only"
                                  Checked="ShowBookmarksButton_Checked"
                                  Unchecked="ShowBookmarksButton_Unchecked"
                                  Style="{DynamicResource {x:Static ToolBar.ToggleButtonStyleKey}}"/>
                    <Button x:Name="RefreshButton"
                            Content="🔄"
                            Width="32" Height="32"
                            Margin="4,0,0,0"
                            ToolTip="Refresh field values (F5)"
                            Click="RefreshButton_Click"
                            Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search box -->
        <Border Grid.Row="1"
                Background="White"
                Padding="12,8"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search icon and textbox -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="🔍"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox x:Name="SearchTextBox"
                         Grid.Row="0" Grid.Column="1"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12"
                         Padding="4"
                         VerticalAlignment="Center"
                         BorderThickness="1"
                         BorderBrush="#CCCCCC">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search fields..."
                                                             Foreground="#999999"
                                                             FontSize="12"
                                                             Margin="4,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button x:Name="ClearSearchButton"
                        Grid.Row="0" Grid.Column="2"
                        Content="✕"
                        Width="24" Height="24"
                        Margin="4,0,0,0"
                        FontSize="12"
                        ToolTip="Clear search"
                        Click="ClearSearchButton_Click"
                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}">
                    <Button.Visibility>
                        <Binding Path="SearchText">
                            <Binding.Converter>
                                <StaticResource ResourceKey="BoolToVisibilityConverter"/>
                            </Binding.Converter>
                        </Binding>
                    </Button.Visibility>
                </Button>

                <!-- Advanced search options -->
                <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                           Orientation="Horizontal"
                           Margin="0,6,0,0">
                    <CheckBox x:Name="RegexSearchCheckBox"
                              Content="Regex"
                              FontSize="10"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              Checked="SearchOption_Changed"
                              Unchecked="SearchOption_Changed"/>
                    <CheckBox x:Name="CaseSensitiveCheckBox"
                              Content="Case-sensitive"
                              FontSize="10"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              Checked="SearchOption_Changed"
                              Unchecked="SearchOption_Changed"/>
                    <TextBlock Text="In:"
                               FontSize="10"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="#666666"/>
                    <ComboBox x:Name="SearchFieldCombo"
                              FontSize="10"
                              Width="110"
                              Margin="0,0,12,0"
                              SelectedIndex="0"
                              SelectionChanged="SearchOption_Changed">
                        <ComboBoxItem Content="All fields"/>
                        <ComboBoxItem Content="Name only"/>
                        <ComboBoxItem Content="Value only"/>
                        <ComboBoxItem Content="Description"/>
                    </ComboBox>
                    <TextBlock Text="Type:"
                               FontSize="10"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="#666666"/>
                    <ComboBox x:Name="TypeFilterCombo"
                              FontSize="10"
                              Width="100"
                              SelectedIndex="0"
                              SelectionChanged="SearchOption_Changed">
                        <ComboBoxItem Content="All types"/>
                        <ComboBoxItem Content="Integers"/>
                        <ComboBoxItem Content="Strings"/>
                        <ComboBoxItem Content="Bytes"/>
                    </ComboBox>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Quick Actions Toolbar -->
        <Border Grid.Row="2"
                Background="#FAFAFA"
                Padding="8,6"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0">
            <!-- Phase C: Compact Menu System (2 menus instead of 5 buttons) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Actions Menu -->
                <Button x:Name="ActionsMenuButton"
                        Content="📝 Actions ▼"
                        Width="100" Height="28"
                        Margin="4,0"
                        FontSize="11"
                        Click="ActionsMenuButton_Click"
                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="ActionsContextMenu" Placement="Bottom">
                            <MenuItem Header="✏️ _Edit" InputGestureText="Enter" Click="EditValue_Click" IsEnabled="{Binding HasSelection}"/>
                            <MenuItem Header="📋 _Copy" InputGestureText="Ctrl+C" Click="CopyValue_Click" IsEnabled="{Binding HasSelection}"/>
                            <MenuItem Header="📄 Copy _Details" Click="CopyDetails_Click" IsEnabled="{Binding HasSelection}"/>
                            <MenuItem Header="📌 Copy _Offset" Click="CopyOffset_Click" IsEnabled="{Binding HasSelection}"/>
                            <Separator/>
                            <MenuItem Header="🎯 _Navigate" Click="QuickNavigate_Click" IsEnabled="{Binding HasSelection}"/>
                            <MenuItem Header="🔍 _Jump to Offset..." Click="JumpToOffset_Click"/>
                            <Separator/>
                            <MenuItem Header="⭐ _Bookmark" InputGestureText="Space" Click="ToggleBookmark_Click" IsEnabled="{Binding HasSelection}"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <Separator Margin="8,0" Width="1" Background="#E0E0E0" Height="20"/>

                <!-- Export Menu -->
                <Button x:Name="ExportMenuButton"
                        Content="💾 Export ▼"
                        Width="100" Height="28"
                        Margin="4,0"
                        FontSize="11"
                        Click="ExportMenuButton_Click"
                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="ExportContextMenu" Placement="Bottom">
                            <MenuItem Header="📄 Text" Click="ExportAsText_Click"/>
                            <MenuItem Header="{}{} JSON" Click="ExportAsJson_Click"/>
                            <MenuItem Header="📊 CSV" Click="ExportAsCsv_Click"/>
                            <MenuItem Header="📋 XML" Click="ExportAsXml_Click"/>
                            <MenuItem Header="🌐 HTML" Click="ExportAsHtml_Click"/>
                            <MenuItem Header="📝 Markdown" Click="ExportAsMarkdown_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>
        </Border>

        <!-- Format info -->
        <Border Grid.Row="3"
                Background="#F5F5F5"
                Padding="12,8"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0"
                Visibility="{Binding FormatInfo.IsDetected, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,4,0"
                                   Text="Format:"/>
                        <!-- Dropdown when multiple candidates detected -->
                        <ComboBox x:Name="FormatCandidateCombo"
                                  ItemsSource="{Binding FormatInfo.Candidates}"
                                  SelectedItem="{Binding FormatInfo.SelectedCandidate, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  Visibility="{Binding FormatInfo.HasMultipleCandidates, Converter={StaticResource BoolToVisibilityConverter}}"
                                  FontSize="11" FontWeight="SemiBold" Foreground="#2196F3"
                                  MinWidth="180" MaxWidth="280"
                                  VerticalAlignment="Center"
                                  SelectionChanged="FormatCandidateCombo_SelectionChanged"/>
                        <!-- Static text when single format -->
                        <TextBlock Text="{Binding FormatInfo.Name, Mode=OneWay}"
                                   Foreground="#2196F3" FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding FormatInfo.HasMultipleCandidates, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    </StackPanel>
                    <Border Grid.Column="2"
                            Background="#FFE5B4"
                            BorderBrush="#FFA500"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,2"
                            Margin="8,0,0,0">
                        <TextBlock FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#D2691E"
                                   Text="{Binding FormatInfo.Category}"/>
                    </Border>
                </Grid>
                <TextBlock FontSize="11" Foreground="#666666" TextWrapping="Wrap"
                           Text="{Binding FormatInfo.Description}"/>

                <!-- Enriched Format Metadata Section -->
                <Expander x:Name="EnrichedFormatExpander"
                          IsExpanded="False"
                          Margin="0,12,0,0"
                          BorderBrush="#CCCCCC"
                          BorderThickness="1"
                          Background="White">
                    <Expander.Header>
                        <TextBlock Text="Enriched Format Metadata"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#1976D2"/>
                    </Expander.Header>
                    <Border Padding="8">
                        <local:EnrichedFormatInfoPanel x:Name="EnrichedFormatPanel"
                                                       MaxHeight="400"/>
                    </Border>
                </Expander>

            </StackPanel>
        </Border>

        <!-- Computed Values Spotlight (C1) -->
        <Border x:Name="ComputedValuesSection"
                Grid.Row="4"
                Background="#E3F2FD"
                Padding="10,6"
                BorderThickness="0,0,0,1"
                BorderBrush="#BBDEFB"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Computed Values"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#1565C0"
                           Margin="0,0,0,4"/>
                <ItemsControl x:Name="MetadataItemsControl"
                              ItemsSource="{Binding MetadataFields}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="&#x2139;"
                                           FontSize="11"
                                           Foreground="#1976D2"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           FontSize="11"
                                           Foreground="#333333"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding FormattedValue}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas"
                                           Foreground="#0D47A1"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Key Insights Strip (C4) -->
        <Border x:Name="KeyInsightsSection"
                Grid.Row="5"
                Background="#FFFDE7"
                Padding="10,6"
                BorderThickness="0,0,0,1"
                BorderBrush="#FFF9C4"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Key Insights"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#F57F17"
                           Margin="0,0,0,4"/>
                <ItemsControl x:Name="InsightsItemsControl"
                              ItemsSource="{Binding InsightChips}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10"
                                    Padding="8,3"
                                    Margin="0,0,6,4"
                                    Background="{Binding Background}">
                                <TextBlock FontSize="11">
                                    <Run Text="{Binding Icon, Mode=OneWay}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Value, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Byte Coverage Bar (C6) -->
        <Border x:Name="CoverageBarSection"
                Grid.Row="6"
                Background="White"
                Padding="10,4"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Height="8">
                    <Border CornerRadius="4" Background="#EEEEEE"/>
                    <ProgressBar x:Name="CoverageProgressBar"
                                 Height="8"
                                 Minimum="0" Maximum="100" Value="0"
                                 Foreground="#42A5F5"
                                 Background="Transparent"
                                 BorderThickness="0"/>
                </Grid>
                <TextBlock x:Name="CoverageText"
                           Grid.Column="1"
                           FontSize="10"
                           Foreground="#666666"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Text="0% parsed"/>
            </Grid>
        </Border>

        <!-- Fields list -->
        <ListBox x:Name="FieldsListBox"
                 Grid.Row="7"
                 ItemsSource="{Binding FilteredFields}"
                 ItemTemplate="{StaticResource FieldTemplate}"
                 ItemContainerStyle="{StaticResource FieldItemStyle}"
                 SelectionChanged="FieldsListBox_SelectionChanged"
                 KeyDown="FieldsListBox_KeyDown"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 BorderThickness="0"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.CacheLength="20,20"
                 VirtualizingPanel.CacheLengthUnit="Item">
            <!-- Group Style for collapsible section headers (C3) -->
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="{x:Type GroupItem}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                        <Expander IsExpanded="True"
                                                  BorderThickness="0"
                                                  Margin="0,2,0,0">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="Bold"
                                                               FontSize="11"
                                                               Foreground="#1565C0"
                                                               VerticalAlignment="Center"/>
                                                    <Border CornerRadius="8"
                                                            Background="#E0E0E0"
                                                            Padding="6,1"
                                                            Margin="6,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ItemCount}"
                                                                   FontSize="10"
                                                                   Foreground="#666666"/>
                                                    </Border>
                                                </StackPanel>
                                            </Expander.Header>
                                            <ItemsPresenter/>
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit Value..." Click="EditValue_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="✏️" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Toggle Bookmark" Click="ToggleBookmark_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="⭐" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Copy Offset" Click="CopyOffset_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📌" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Jump to Offset..." Click="JumpToOffset_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🔍" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Copy Value">
                        <MenuItem.Icon>
                            <TextBlock Text="📋" FontSize="14"/>
                        </MenuItem.Icon>
                        <MenuItem Header="As Displayed" Click="CopyValue_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📄" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As Hex" Click="CopyValueHex_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="🔢" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As Decimal" Click="CopyValueDecimal_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="🔟" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As Binary" Click="CopyValueBinary_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="01" FontSize="12" FontFamily="Consolas"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                    <MenuItem Header="Copy Details" Click="CopyDetails_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📄" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Find Similar Values..." Click="FindSimilar_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🔍" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Show in Data Inspector" Click="ShowInDataInspector_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🔬" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Export All Fields...">
                        <MenuItem.Icon>
                            <TextBlock Text="💾" FontSize="14"/>
                        </MenuItem.Icon>
                        <MenuItem Header="As Text" Click="ExportAsText_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📄" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As JSON" Click="ExportAsJson_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="{}{}" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As CSV" Click="ExportAsCsv_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📊" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As XML" Click="ExportAsXml_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📋" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As HTML" Click="ExportAsHtml_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="🌐" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As Markdown" Click="ExportAsMarkdown_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📝" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.Style>
                <Style TargetType="ListBox">
                    <Style.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBox">
                                        <Border Background="White">
                                            <TextBlock Text="No fields parsed yet.&#x0a;Open a file to see its structure."
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     TextAlignment="Center"
                                                     Foreground="#999999"
                                                     FontSize="12"
                                                     Margin="20"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
        </ListBox>

        <!-- Status bar -->
        <Border Grid.Row="8"
                Background="#F5F5F5"
                Padding="12,6"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           FontSize="11"
                           Foreground="#666666">
                    <Run Text="{Binding FilteredFields.Count, Mode=OneWay}"/>
                    <Run Text="/"/>
                    <Run Text="{Binding ParsedFields.Count, Mode=OneWay}"/>
                    <Run Text="field(s)"/>
                    <Run Text="{Binding SearchResultText, Mode=OneWay}" Foreground="#4CAF50" FontWeight="SemiBold"/>
                </TextBlock>

                <ComboBox x:Name="SortComboBox"
                          Grid.Column="1"
                          Width="110"
                          FontSize="10"
                          Margin="0,0,8,0"
                          SelectedIndex="0"
                          SelectionChanged="SortComboBox_SelectionChanged"
                          ToolTip="Sort fields">
                    <ComboBoxItem Content="Sort: Offset"/>
                    <ComboBoxItem Content="Sort: Name A-Z"/>
                    <ComboBoxItem Content="Sort: Name Z-A"/>
                    <ComboBoxItem Content="Sort: Type"/>
                    <ComboBoxItem Content="Sort: Size"/>
                </ComboBox>

                <ComboBox x:Name="FormatterComboBox"
                          Grid.Column="2"
                          Width="120"
                          FontSize="11"
                          SelectionChanged="FormatterComboBox_SelectionChanged"
                          ToolTip="Choose value display format">
                    <ComboBoxItem Content="Mixed (Smart)" Tag="mixed" IsSelected="True"/>
                    <ComboBoxItem Content="Hexadecimal" Tag="hex"/>
                    <ComboBoxItem Content="Decimal" Tag="decimal"/>
                    <ComboBoxItem Content="String" Tag="string"/>
                </ComboBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>

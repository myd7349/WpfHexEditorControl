<UserControl x:Class="WpfHexaEditor.HexEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexaEditor"
             xmlns:models="clr-namespace:WpfHexaEditor.Models"
             xmlns:converters="clr-namespace:WpfHexaEditor.Converters"
             xmlns:controls="clr-namespace:WpfHexaEditor.Controls"
             xmlns:panels="clr-namespace:WpfHexaEditor.Views.Panels"
             xmlns:prop="clr-namespace:WpfHexaEditor.Properties"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="White"
             FontFamily="Consolas"
             FontSize="14">

    <UserControl.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToSelectionBrushConverter x:Key="BoolToSelectionBrushConverter"/>
        <converters:ActionToBrushConverter x:Key="ActionToBrushConverter"/>

        <!-- Professional Color Scheme -->
        <SolidColorBrush x:Key="SelectionBrush" Color="#0078D4" Opacity="0.4"/>
        <SolidColorBrush x:Key="ModifiedBrush" Color="#FFA500"/>
        <SolidColorBrush x:Key="AddedBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="DeletedBrush" Color="#F44336"/>
        <SolidColorBrush x:Key="HeaderBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#424242"/>
        <SolidColorBrush x:Key="OffsetBrush" Color="#757575"/>
        <SolidColorBrush x:Key="ByteBorderBrush" Color="Transparent"/>
        <SolidColorBrush x:Key="ByteHoverBrush" Color="#E3F2FD"/>

        <!-- Customizable Byte Colors (V1 compatibility) -->
        <SolidColorBrush x:Key="ByteForegroundBrush" Color="#000000"/>
        <SolidColorBrush x:Key="AlternateByteForegroundBrush" Color="#0000FF"/>
        <SolidColorBrush x:Key="ColumnSeparatorBrush" Color="#D0D0D0"/>

        <!-- Styles for better appearance -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}"/>
            <Setter Property="Padding" Value="5,3"/>
        </Style>

        <!-- Data template for a single hex byte -->
        <DataTemplate x:Key="HexByteTemplate">
            <Border x:Name="ByteBorder" Width="22" Height="18" Margin="0,0,2,0" CornerRadius="2"
                    Background="{Binding IsSelected, Converter={StaticResource BoolToSelectionBrushConverter}}"
                    BorderBrush="{Binding Action, Converter={StaticResource ActionToBrushConverter}}"
                    BorderThickness="1.5">
                <TextBlock Text="{Binding HexString}"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#212121"
                           FontWeight="Medium"/>
            </Border>
            <DataTemplate.Triggers>
                <!-- Cursor visual: thicker blue border -->
                <DataTrigger Binding="{Binding IsCursor}" Value="True">
                    <Setter TargetName="ByteBorder" Property="BorderBrush" Value="#0078D4"/>
                    <Setter TargetName="ByteBorder" Property="BorderThickness" Value="2.5"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Data template for a single ASCII byte -->
        <DataTemplate x:Key="AsciiByteTemplate">
            <Border x:Name="AsciiBorder" Width="10" Height="18" Margin="0" CornerRadius="1"
                    Background="{Binding IsSelected, Converter={StaticResource BoolToSelectionBrushConverter}}"
                    BorderBrush="Transparent"
                    BorderThickness="1">
                <TextBlock Text="{Binding AsciiChar}"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#424242"
                           FontSize="13"/>
            </Border>
            <DataTemplate.Triggers>
                <!-- Cursor visual: blue border -->
                <DataTrigger Binding="{Binding IsCursor}" Value="True">
                    <Setter TargetName="AsciiBorder" Property="BorderBrush" Value="#0078D4"/>
                    <Setter TargetName="AsciiBorder" Property="BorderThickness" Value="1.5"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Data template for a hex line -->
        <DataTemplate DataType="{x:Type models:HexLine}">
            <Grid Margin="0,1" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/> <!-- Offset -->
                    <ColumnDefinition Width="Auto"/>   <!-- Hex bytes -->
                    <ColumnDefinition Width="Auto"/> <!-- Separator -->
                    <ColumnDefinition Width="Auto"/> <!-- ASCII -->
                </Grid.ColumnDefinitions>

                <!-- Offset label -->
                <TextBlock Grid.Column="0"
                           Text="{Binding OffsetLabel}"
                           Foreground="{StaticResource OffsetBrush}"
                           FontFamily="Consolas"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="8,0,10,0"/>

                <!-- Hex bytes -->
                <ItemsControl Grid.Column="1"
                              ItemsSource="{Binding Bytes}"
                              ItemTemplate="{StaticResource HexByteTemplate}"
                              Margin="0,2">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Separator -->
                <Border Grid.Column="2" Width="1" Background="#E0E0E0" Margin="8,0"/>

                <!-- ASCII bytes -->
                <ItemsControl Grid.Column="3"
                              ItemsSource="{Binding Bytes}"
                              ItemTemplate="{StaticResource AsciiByteTemplate}"
                              Margin="8,2,0,2">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <!-- V1 Compatible Context Menu -->
    <UserControl.ContextMenu>
        <ContextMenu x:Name="ByteContextMenu" Visibility="Collapsed">
            <!-- Undo -->
            <MenuItem x:Name="UndoMenuItem" Header="{DynamicResource UndoString}" Click="UndoMenuItem_Click">
                <MenuItem.Icon>
                    <TextBlock Text="↶" FontSize="16" Foreground="#0078D4"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>

            <!-- Bookmarks -->
            <MenuItem x:Name="BookmarksMenuItem" Header="{DynamicResource BookmarksString}">
                <MenuItem x:Name="SetBookmarkMenuItem" Header="{DynamicResource SetBookMarkString}" Click="SetBookmarkMenuItem_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="📌" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="ClearBookmarksMenuItem" Header="{DynamicResource ClearBookMarkString}" Click="ClearBookmarksMenuItem_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="🗑️" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <Separator/>

            <!-- Copy (default mode) -->
            <MenuItem x:Name="CopyMenuItem" Header="{DynamicResource CopyString}" Click="CopyMenuItem_Click">
                <MenuItem.Icon>
                    <TextBlock Text="📋" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>

            <!-- Copy submenu -->
            <MenuItem x:Name="CopyAsMenuItem" Header="{DynamicResource CopySelectionAsString}">
                <MenuItem x:Name="CopyHexaMenuItem" Header="{DynamicResource CopyAsHexadecimalString}" Click="CopyHexaMenuItem_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="📋" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="CopyAsciiMenuItem" Header="{DynamicResource CopyAsASCIIString}" Click="CopyAsciiMenuItem_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="📋" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="CopyCSharpMenuItem" Header="{DynamicResource CopyAsCSharpCodeString}" Click="CopyCSharpMenuItem_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="📋" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="CopyCMenuItem" Header="{DynamicResource CopyAsCCodeString}" Click="CopyCMenuItem_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="📋" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="CopyTblMenuItem" Header="{DynamicResource CopyAsTBLString}" Click="CopyTblMenuItem_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="📋" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="CopyFormattedViewMenuItem" Header="{DynamicResource CopyAsFormattedViewString}" Click="CopyFormattedViewMenuItem_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="📋" FontSize="14"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <Separator/>

            <!-- Find All (Async with Progress) -->
            <MenuItem x:Name="FindAllMenuItem" Header="{DynamicResource FindAllString}" Click="FindAllMenuItemAsync_Click" ToolTip="Search for all occurrences with progress overlay">
                <MenuItem.Icon>
                    <TextBlock Text="🔍" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <!-- Paste -->
            <MenuItem x:Name="PasteMenuItem" Header="{DynamicResource PasteString}" Click="PasteMenuItem_Click">
                <MenuItem.Icon>
                    <TextBlock Text="📄" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>

            <!-- Paste without inserting (Overwrite mode) -->
            <MenuItem x:Name="PasteOverwriteMenuItem" Header="{DynamicResource PasteNotInsertString}" Click="PasteOverwriteMenuItem_Click">
                <MenuItem.Icon>
                    <TextBlock Text="📝" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>

            <!-- Delete -->
            <MenuItem x:Name="DeleteMenuItem" Header="{DynamicResource DeleteString}" Click="DeleteMenuItem_Click">
                <MenuItem.Icon>
                    <TextBlock Text="🗑️" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>

            <!-- Fill -->
            <MenuItem x:Name="FillByteMenuItem" Header="{DynamicResource FillWithByteString}" Click="FillByteMenuItem_Click" ToolTip="{DynamicResource FillWithByteTooltipString}">
                <MenuItem.Icon>
                    <TextBlock Text="🎨" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>

            <!-- Replace -->
            <MenuItem x:Name="ReplaceByteMenuItem" Header="{DynamicResource ReplaceByteMenuString}" Click="ReplaceByteMenuItem_Click" ToolTip="{DynamicResource ReplaceByteTooltipString}">
                <MenuItem.Icon>
                    <TextBlock Text="🔄" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>

            <!-- Reverse Selection -->
            <MenuItem x:Name="ReverseSelectionMenuItem" Header="{DynamicResource ReverseSelectionString}" Click="ReverseSelectionMenuItem_Click" ToolTip="{DynamicResource ReverseSelectionTooltipString}">
                <MenuItem.Icon>
                    <TextBlock Text="⇄" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>

            <!-- Invert Selection -->
            <MenuItem x:Name="InvertSelectionMenuItem" Header="{DynamicResource InvertSelectionString}" Click="InvertSelectionMenuItem_Click" ToolTip="{DynamicResource InvertSelectionTooltipString}">
                <MenuItem.Icon>
                    <TextBlock Text="⊕" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <!-- Select All -->
            <MenuItem x:Name="SelectAllMenuItem" Header="{DynamicResource SelectAllString}" Click="SelectAllMenuItem_Click">
                <MenuItem.Icon>
                    <TextBlock Text="▦" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.ContextMenu>

    <Grid x:Name="BaseGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Column Headers -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Bar Chart Panel (Phase 7.4) -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Column Headers -->
        <Border x:Name="HeaderBorder" Grid.Row="0" Background="{StaticResource HeaderBrush}" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="0,5,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding ActualOffsetWidth, RelativeSource={RelativeSource AncestorType=local:HexEditor}}"/> <!-- Offset: dynamic width based on format -->
                    <ColumnDefinition Width="Auto"/>   <!-- Hex: auto-size for all columns with spacers -->
                    <ColumnDefinition Width="20"/> <!-- Separator: matches SeparatorWidth -->
                    <ColumnDefinition Width="Auto"/> <!-- ASCII: auto-size -->
                    <ColumnDefinition Width="*"/> <!-- Remaining space -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{DynamicResource OffsetString}" Style="{StaticResource HeaderTextStyle}" Margin="8,0,0,0"/>

                <!-- Dynamic hex column headers (00 01 02...0F) with byte spacers -->
                <StackPanel x:Name="HexHeaderStackPanel" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,0"/>

                <Border Grid.Column="2" Width="1" Background="Transparent" Margin="8,0,8,0"/>

                <!-- Dynamic ASCII column headers with byte spacers -->
                <StackPanel x:Name="AsciiHeaderStackPanel" Grid.Column="3" Orientation="Horizontal" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- Content area with scrollbar and parsed fields panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/> <!-- Scrollbar -->
                <ColumnDefinition Width="Auto"/> <!-- GridSplitter -->
                <ColumnDefinition Width="300" MinWidth="200" MaxWidth="600"/> <!-- ParsedFieldsPanel -->
            </Grid.ColumnDefinitions>

            <!-- Lines display - Custom high-performance rendering -->
            <ScrollViewer Grid.Column="0"
                          x:Name="ContentScroller"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Auto"
                          CanContentScroll="False">
                <controls:HexViewport x:Name="HexViewport"
                                      MouseDown="Content_MouseDown"
                                      MouseMove="Content_MouseMove"
                                      MouseUp="Content_MouseUp"
                                      PreviewKeyDown="Content_KeyDown"/>
            </ScrollViewer>

            <!-- Vertical scrollbar -->
            <ScrollBar Grid.Column="1"
                       x:Name="VerticalScroll"
                       Orientation="Vertical"
                       Scroll="VerticalScroll_Scroll"
                       Minimum="0"
                       Maximum="1000"
                       ViewportSize="20"
                       SmallChange="1"
                       LargeChange="10"/>

            <!-- Scroll markers overlay (V1 compatible) -->
            <controls:ScrollMarkerPanel Grid.Column="1"
                                         x:Name="ScrollMarkers"
                                         Panel.ZIndex="1"
                                         Width="18"
                                         HorizontalAlignment="Right"
                                         Margin="0,18,0,18"/>

            <!-- Grid Splitter for resizing parsed fields panel -->
            <GridSplitter Grid.Column="2"
                         Width="5"
                         Background="#E0E0E0"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Stretch"
                         ShowsPreview="True"
                         ResizeBehavior="PreviousAndNext"
                         Visibility="{Binding ParsedFieldsPanelVisibility, RelativeSource={RelativeSource AncestorType=local:HexEditor}}"/>

            <!-- Parsed Fields Panel (Issue #111) -->
            <Border Grid.Column="3"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding ParsedFieldsPanelVisibility, RelativeSource={RelativeSource AncestorType=local:HexEditor}}">
                <panels:ParsedFieldsPanel x:Name="ParsedFieldsPanel"/>
            </Border>

            <!-- Progress overlay for long-running operations -->
            <controls:ProgressOverlay x:Name="ProgressOverlay"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="4"
                                      Panel.ZIndex="10"
                                      Visibility="Collapsed"/>
        </Grid>

        <!-- Bar Chart Panel (Phase 7.4 - V1 compatible feature) -->
        <Border x:Name="BarChartBorder" Grid.Row="2"
                BorderBrush="#D0D0D0" BorderThickness="0,1,0,0"
                Visibility="{Binding BarChartPanelVisibility, RelativeSource={RelativeSource AncestorType=local:HexEditor}}">
            <controls:BarChartPanel x:Name="BarChartPanel"
                                     Height="150"
                                     Margin="5"/>
        </Border>

        <!-- Status bar -->
        <StatusBar x:Name="StatusBar" Grid.Row="3" DataContext="{Binding RelativeSource={RelativeSource AncestorType=local:HexEditor}}">
            <StatusBar.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="{DynamicResource StatusMessageString}" IsCheckable="True" IsChecked="{Binding ShowStatusMessage, Mode=TwoWay}"/>
                    <MenuItem Header="{DynamicResource FileSizeString}" IsCheckable="True" IsChecked="{Binding ShowFileSizeInStatusBar, Mode=TwoWay}"/>
                    <MenuItem Header="{DynamicResource SelectionInfoString}" IsCheckable="True" IsChecked="{Binding ShowSelectionInStatusBar, Mode=TwoWay}"/>
                    <MenuItem Header="{DynamicResource PositionString}" IsCheckable="True" IsChecked="{Binding ShowPositionInStatusBar, Mode=TwoWay}"/>
                    <MenuItem Header="{DynamicResource EditModeString}" IsCheckable="True" IsChecked="{Binding ShowEditModeInStatusBar, Mode=TwoWay}"/>
                    <MenuItem Header="{DynamicResource BytesPerLineString}" IsCheckable="True" IsChecked="{Binding ShowBytesPerLineInStatusBar, Mode=TwoWay}"/>
                    <MenuItem Header="{DynamicResource RefreshTimeString}" IsCheckable="True" IsChecked="{Binding ShowRefreshTimeInStatusBar, Mode=TwoWay}"/>
                </ContextMenu>
            </StatusBar.ContextMenu>

            <StatusBarItem Visibility="{Binding ShowStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock x:Name="StatusText" Text="{DynamicResource ReadyString}"/>
            </StatusBarItem>
            <Separator Visibility="{Binding ShowStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <StatusBarItem Visibility="{Binding ShowFileSizeInStatusBar, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock x:Name="FileSizeText"/>
            </StatusBarItem>
            <Separator Visibility="{Binding ShowFileSizeInStatusBar, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <StatusBarItem Visibility="{Binding ShowSelectionInStatusBar, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock x:Name="SelectionInfo" Text="{DynamicResource NoSelectionString}"/>
            </StatusBarItem>
            <Separator Visibility="{Binding ShowSelectionInStatusBar, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <StatusBarItem Visibility="{Binding ShowPositionInStatusBar, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock x:Name="PositionInfo"/>
            </StatusBarItem>
            <Separator Visibility="{Binding ShowPositionInStatusBar, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <StatusBarItem Visibility="{Binding ShowEditModeInStatusBar, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock x:Name="EditModeText" Text="{DynamicResource ModeOverwriteString}"/>
            </StatusBarItem>
            <Separator Visibility="{Binding ShowEditModeInStatusBar, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <StatusBarItem Visibility="{Binding ShowBytesPerLineInStatusBar, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock x:Name="BytesPerLineText"/>
            </StatusBarItem>
            <Separator Visibility="{Binding ShowBytesPerLineInStatusBar, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <StatusBarItem Visibility="{Binding ShowRefreshTimeInStatusBar, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock x:Name="RefreshTimeText"/>
            </StatusBarItem>

            <!-- TBL Status Indicator (right-aligned) -->
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TblStatusIcon"
                           Text="📋"
                           FontFamily="Segoe UI Emoji"
                           FontSize="14"
                           Margin="5,0,5,0"
                           Visibility="Collapsed"
                           Cursor="Hand">
                    <TextBlock.ToolTip>
                        <ToolTip x:Name="TblStatusTooltip">
                            <TextBlock x:Name="TblStatusTooltipText" Text="No TBL loaded"/>
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>

<UserControl x:Class="WpfHexEditor.Editor.CodeEditor.Controls.FormatScriptEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.CodeEditor.Controls"
             xmlns:codeEditor="clr-namespace:WpfHexEditor.Editor.CodeEditor.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- Button Style -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource TE_Background}">

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource Panel_ToolbarBrush}"
                Padding="4"
                TextElement.Foreground="{DynamicResource Panel_ToolbarForegroundBrush}">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="NewFileButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="New Format Definition">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📄" FontSize="16" Margin="0,0,4,0"/>
                        <TextBlock Text="New" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="OpenFileButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open Format Definition">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📂" FontSize="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Open" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="SaveFileButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Save Current File">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" FontSize="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Save" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Width="1" Margin="8,4" Background="{DynamicResource Panel_ToolbarBorderBrush}"/>

                <Button x:Name="UndoButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Undo (Ctrl+Z)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↶" FontSize="18" Margin="0,0,4,0"/>
                        <TextBlock Text="Undo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="RedoButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Redo (Ctrl+Y)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↷" FontSize="18" Margin="0,0,4,0"/>
                        <TextBlock Text="Redo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Width="1" Margin="8,4" Background="{DynamicResource Panel_ToolbarBorderBrush}"/>

                <Button x:Name="FormatButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Format JSON (Ctrl+Shift+F)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✨" FontSize="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Format" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ValidateButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Validate Format Definition">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" FontSize="18" Margin="0,0,4,0"/>
                        <TextBlock Text="Validate" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource Panel_ToolbarBrush}"
                Padding="8,4"
                TextElement.Foreground="{DynamicResource Panel_ToolbarForegroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Line/Column indicator -->
                <TextBlock x:Name="LineColumnText" Grid.Column="0" Text="Ln 1, Col 1" Margin="0,0,16,0"/>

                <!-- Errors/Warnings -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="❌" Margin="0,0,4,0"/>
                    <TextBlock x:Name="ErrorCountText" Text="0 Errors"/>
                    <TextBlock Text=" " Margin="4,0"/>
                    <TextBlock Text="⚠️" Margin="0,0,4,0"/>
                    <TextBlock x:Name="WarningCountText" Text="0 Warnings"/>
                </StackPanel>

                <!-- Current file name -->
                <TextBlock x:Name="FileNameText" Grid.Column="3" Text="No file loaded" HorizontalAlignment="Left"/>

                <!-- Encoding / File Type -->
                <TextBlock x:Name="FileTypeText" Grid.Column="4" Text="JSON" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- File Tree (Left Panel) -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Background="{DynamicResource TE_Background}">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource SE_GroupHeaderBrush}"
                            BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Embedded Formats"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                   Padding="8"/>
                    </Border>

                    <TreeView x:Name="FormatTreeView"
                              BorderThickness="0"
                              Background="{DynamicResource TE_Background}"
                              Foreground="{DynamicResource TE_Foreground}">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockSplitterBrush}"/>

            <!-- Editor Area (Right Panel) -->
            <TabControl x:Name="MainTabControl" Grid.Column="2" BorderThickness="0"
                       SelectionChanged="MainTabControl_SelectionChanged">

                <!-- Editor Tab -->
                <TabItem x:Name="EditorTab" Header="Editor">
                    <Grid>
                        <codeEditor:CodeEditor x:Name="CodeEditorControl"
                                              ShowLineNumbers="True"
                                              EnableIntelliSense="True"
                                              EnableValidation="True"
                                              EditorBackground="{DynamicResource TE_Background}"
                                              EditorForeground="{DynamicResource TE_Foreground}"
                                              LineNumberBackground="{DynamicResource TE_LineNumberBackground}"
                                              LineNumberForeground="{DynamicResource TE_LineNumberForeground}"
                                              CurrentLineBackground="{DynamicResource TE_CurrentLineBrush}"
                                              SelectionBackground="{DynamicResource TE_SelectionBackground}"
                                              SyntaxKeyColor="{DynamicResource TE_Keyword}"
                                              SyntaxKeywordColor="{DynamicResource TE_Keyword}"
                                              SyntaxBooleanColor="{DynamicResource TE_Keyword}"
                                              SyntaxStringValueColor="{DynamicResource TE_String}"
                                              SyntaxNumberColor="{DynamicResource TE_Number}"
                                              SyntaxCommentColor="{DynamicResource TE_Comment}"
                                              SyntaxValueTypeColor="{DynamicResource TE_Type}"
                                              SyntaxCalcExpressionColor="{DynamicResource TE_Directive}"
                                              SyntaxVariableReferenceColor="{DynamicResource TE_Register}"
                                              SyntaxEscapeSequenceColor="{DynamicResource TE_Label}"
                                              SyntaxUrlColor="{DynamicResource TE_Register}"
                                              SyntaxBraceColor="{DynamicResource TE_Foreground}"
                                              SyntaxBracketColor="{DynamicResource TE_Foreground}"
                                              SyntaxCommaColor="{DynamicResource TE_Foreground}"
                                              SyntaxColonColor="{DynamicResource TE_Foreground}"
                                              SyntaxNullColor="{DynamicResource TE_Operator}"
                                              SyntaxDeprecatedColor="{DynamicResource TE_Operator}"/>
                    </Grid>
                </TabItem>

                <!-- Preview Tab -->
                <TabItem Header="Preview">
                    <ScrollViewer Background="{DynamicResource TE_Background}">
                        <TextBlock x:Name="PreviewTextBlock"
                                  Padding="10"
                                  FontFamily="Consolas"
                                  FontSize="12"
                                  TextWrapping="Wrap"
                                  Foreground="{DynamicResource TE_Foreground}"
                                  Text="Load a format definition to see preview..."/>
                    </ScrollViewer>
                </TabItem>

                <!-- Validation Tab -->
                <TabItem Header="Validation">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Padding="8"
                                  Background="{DynamicResource SE_GroupHeaderBrush}"
                                  Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                  Text="Validation Results" FontWeight="Bold"/>

                        <ListBox x:Name="ValidationListBox"
                                 BorderThickness="0"
                                 Background="{DynamicResource TE_Background}"
                                 Foreground="{DynamicResource TE_Foreground}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Message}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Location}"
                                                       Foreground="{DynamicResource PFP_SubTextBrush}"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </TabItem>

                <!-- Test Tab -->
                <TabItem Header="Test">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="8"
                                Background="{DynamicResource SE_GroupHeaderBrush}">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Select Test File..." Padding="8,4" Margin="0,0,8,0"/>
                                <Button Content="Run Test" Padding="8,4"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Padding="10" TextWrapping="Wrap"
                                  Foreground="{DynamicResource TE_Foreground}"
                                  Text="Test your format definition against sample files here.&#x0a;&#x0a;Select a file and click 'Run Test' to see parsing results."/>
                    </DockPanel>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</UserControl>

<Window x:Class="RiderSimpleExample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hex="clr-namespace:WpfHexaEditor;assembly=WPFHexaEditor"
        mc:Ignorable="d"
        Title="WpfHexEditor - Rider Simple Example"
        Icon="Logo.ico"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="📂 Open File"
                        Click="OpenFileButton_Click"
                        Padding="15,8"
                        Margin="5"
                        Background="#007ACC"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>

                <Button Content="💾 Save"
                        Click="SaveButton_Click"
                        Padding="15,8"
                        Margin="5"
                        Background="#28A745"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>

                <Button Content="📋 Load TBL"
                        Click="LoadTblButton_Click"
                        Padding="15,8"
                        Margin="5"
                        Background="#6F42C1"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        ToolTip="Load a TBL (Character Table) file for custom encoding"/>

                <Button x:Name="CloseTblButton"
                        Content="❌ Close TBL"
                        Click="CloseTblButton_Click"
                        Padding="15,8"
                        Margin="5"
                        Background="#DC3545"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsEnabled="False"
                        ToolTip="Close the current TBL file and return to ASCII"/>

                <CheckBox Content="🔒 Read-Only Mode"
                          IsChecked="{Binding ElementName=HexEditor, Path=ReadOnlyMode}"
                          VerticalAlignment="Center"
                          Margin="20,0,0,0"
                          Foreground="White"
                          FontSize="14"/>

                <TextBlock Text="Made with Rider ❤️"
                           VerticalAlignment="Center"
                           Margin="30,0,0,0"
                           Foreground="#9CDCFE"
                           FontSize="12"
                           FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <!-- HexEditor Control -->
        <!--
            💡 Rider Tip: Start typing <hex: and IntelliSense shows all properties!
            Press Ctrl+Space on any property to see available values.
        -->
        <hex:HexEditor x:Name="HexEditor"
                       Grid.Row="1"
                       ReadOnlyMode="False"
                       BytePerLine="16"
                       AllowExtend="False"
                       SelectionChanged="HexEditor_OnSelectionChanged"
                       DataCopied="HexEditor_OnDataCopied"
                       Margin="10"/>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#007ACC" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="👋 Welcome! Click 'Open File' to start editing a binary file."
                           Foreground="White"
                           FontSize="13"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="SelectionText"
                           Grid.Column="1"
                           Text="No selection"
                           Foreground="White"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>

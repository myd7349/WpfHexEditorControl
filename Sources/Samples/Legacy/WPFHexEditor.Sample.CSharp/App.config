<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
      <section name="WpfHexEditor.Sample.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
    </sectionGroup>
  </configSections>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>
  <userSettings>
    <WpfHexEditor.Sample.Properties.Settings>
      <setting name="ApplicationName" serializeAs="String">
        <value>Wpf HexEditor control c# sample</value>
      </setting>
      <!-- View Settings -->
      <setting name="HeaderVisible" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="HexDataVisible" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="StringDataVisible" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="LineInfoVisible" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="StatusBarVisible" serializeAs="String">
        <value>True</value>
      </setting>
      <!-- Option Settings -->
      <setting name="AllowContextMenu" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="ShowByteToolTip" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="AllowAutoHighLightSelectionByte" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="AllowAutoSelectSameByteAtDoubleClick" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="AllowByteCount" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="FileDroppingConfirmation" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="AllowTextDrop" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="AllowFileDrop" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="HideByteDeleted" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="AllowDeleteByte" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="AppendNeedConfirmation" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="AllowExtend" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="AllowDrop" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="AllowZoom" serializeAs="String">
        <value>True</value>
      </setting>
      <!-- INSERT MODE Settings -->
      <setting name="CanInsertAnywhere" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="IsInsertMode" serializeAs="String">
        <value>False</value>
      </setting>
      <!-- Editor Settings -->
      <setting name="ReadOnlyMode" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="BytePerLine" serializeAs="String">
        <value>16</value>
      </setting>
    </WpfHexEditor.Sample.Properties.Settings>
  </userSettings>
</configuration>

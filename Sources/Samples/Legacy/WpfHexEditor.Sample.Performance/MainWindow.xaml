<Window x:Class="WpfHexEditor.Sample.Performance.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WPF HexEditor - Performance Demonstration"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Styles -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="MetricStyle">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5,2"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2196F3" Padding="15">
            <StackPanel>
                <TextBlock Text="WPF HexEditor Performance Demonstration"
                          FontSize="20"
                          FontWeight="Bold"
                          Foreground="White"/>
                <TextBlock Text="Interactive demos of Span&lt;byte&gt;, Async/Await, and UI Virtualization optimizations"
                          FontSize="12"
                          Foreground="White"
                          Opacity="0.9"
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content - Tabs -->
        <TabControl Grid.Row="1" Margin="10">

            <!-- Tab 1: Span<byte> Demo -->
            <TabItem Header="🚀 Span&lt;byte&gt; Demo">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Description -->
                    <Border Grid.Row="0" Background="#E3F2FD" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Zero-Allocation Operations with Span&lt;byte&gt;" Style="{StaticResource HeaderStyle}"/>
                            <TextBlock TextWrapping="Wrap" Text="Demonstrates the performance difference between traditional byte array operations and modern Span&lt;byte&gt; with ArrayPool. Span operations are 2-5x faster and reduce GC pressure by 80%."/>
                        </StackPanel>
                    </Border>

                    <!-- Controls -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="LoadFileSpanButton" Content="1. Load Test File" Click="LoadFileSpan_Click"/>
                        <Button x:Name="RunTraditionalButton" Content="2. Run Traditional (Array)" Click="RunTraditional_Click" IsEnabled="False"/>
                        <Button x:Name="RunSpanButton" Content="3. Run Span&lt;byte&gt;" Click="RunSpan_Click" IsEnabled="False"/>
                        <TextBlock Text="File Size:" VerticalAlignment="Center" Margin="20,0,5,0"/>
                        <TextBlock x:Name="FileSizeSpanText" Text="No file loaded" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Results -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Traditional Results -->
                        <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Margin="0,0,5,0">
                            <StackPanel>
                                <TextBlock Text="❌ Traditional Array Method" Style="{StaticResource HeaderStyle}" Foreground="#F44336"/>
                                <Separator Margin="0,5"/>

                                <TextBlock Text="Performance Metrics:" FontWeight="Bold" Margin="0,10,0,5"/>
                                <TextBlock x:Name="TraditionalTimeText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="TraditionalMemoryText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="TraditionalAllocText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="TraditionalGCText" Style="{StaticResource MetricStyle}"/>

                                <TextBlock Text="Code:" FontWeight="Bold" Margin="0,20,0,5"/>
                                <Border Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="1">
                                    <TextBlock FontFamily="Consolas" FontSize="11" TextWrapping="Wrap">
                                        <Run>// Allocates new array every call</Run><LineBreak/>
                                        <Run>byte[] data = new byte[1000];</Run><LineBreak/>
                                        <Run>for (int i = 0; i &lt; 1000; i++)</Run><LineBreak/>
                                        <Run>{</Run><LineBreak/>
                                        <Run>    data[i] = GetByte(i);</Run><LineBreak/>
                                        <Run>}</Run><LineBreak/>
                                        <Run>// Heavy GC pressure! 💥</Run>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Span Results -->
                        <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Margin="5,0,0,0">
                            <StackPanel>
                                <TextBlock Text="✅ Modern Span&lt;byte&gt; Method" Style="{StaticResource HeaderStyle}" Foreground="#4CAF50"/>
                                <Separator Margin="0,5"/>

                                <TextBlock Text="Performance Metrics:" FontWeight="Bold" Margin="0,10,0,5"/>
                                <TextBlock x:Name="SpanTimeText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="SpanMemoryText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="SpanAllocText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="SpanGCText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="SpanImprovementText" Style="{StaticResource MetricStyle}" FontWeight="Bold" Foreground="#4CAF50" Margin="0,10,0,0"/>

                                <TextBlock Text="Code:" FontWeight="Bold" Margin="0,20,0,5"/>
                                <Border Background="#E8F5E9" Padding="10" BorderBrush="#4CAF50" BorderThickness="1">
                                    <TextBlock FontFamily="Consolas" FontSize="11" TextWrapping="Wrap">
                                        <Run>// Zero allocations with ArrayPool</Run><LineBreak/>
                                        <Run>using var pooled = provider</Run><LineBreak/>
                                        <Run>    .GetBytesPooled(0, 1000);</Run><LineBreak/>
                                        <Run>ReadOnlySpan&lt;byte&gt; data = </Run><LineBreak/>
                                        <Run>    pooled.Span;</Run><LineBreak/>
                                        <Run>// Use data here</Run><LineBreak/>
                                        <Run>// Buffer auto-returned! ✨</Run>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Async/Await Demo -->
            <TabItem Header="⏱️ Async/Await Demo">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Description -->
                    <Border Grid.Row="0" Background="#FFF3E0" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Non-Blocking I/O with Async/Await" Style="{StaticResource HeaderStyle}"/>
                            <TextBlock TextWrapping="Wrap" Text="Shows how async operations keep the UI responsive during long-running searches. Includes progress reporting and cancellation support."/>
                        </StackPanel>
                    </Border>

                    <!-- Controls -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="LoadFileAsyncButton" Content="1. Load Test File" Click="LoadFileAsync_Click"/>
                            <Button x:Name="RunSyncSearchButton" Content="2. Search Sync (UI Freezes)" Click="RunSyncSearch_Click" IsEnabled="False"/>
                            <Button x:Name="RunAsyncSearchButton" Content="3. Search Async (Responsive)" Click="RunAsyncSearch_Click" IsEnabled="False"/>
                        </StackPanel>

                        <Button Grid.Column="2" x:Name="CancelAsyncButton" Content="❌ Cancel" Click="CancelAsync_Click" IsEnabled="False" Background="#F44336" Foreground="White"/>
                    </Grid>

                    <!-- Progress -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Progress Bar -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock x:Name="AsyncStatusText" Text="Ready" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ProgressBar x:Name="AsyncProgressBar" Value="0" Maximum="100"/>
                            <TextBlock x:Name="AsyncProgressText" Text="0%" HorizontalAlignment="Center" Margin="0,5"/>
                        </StackPanel>

                        <!-- Results -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Sync Results -->
                            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Margin="0,0,5,0">
                                <StackPanel>
                                    <TextBlock Text="❌ Synchronous Search" Style="{StaticResource HeaderStyle}" Foreground="#F44336"/>
                                    <Separator Margin="0,5"/>
                                    <TextBlock x:Name="SyncResultsText" Style="{StaticResource MetricStyle}" TextWrapping="Wrap"/>
                                    <TextBlock Text="⚠️ UI FROZEN during search!" FontWeight="Bold" Foreground="#F44336" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Async Results -->
                            <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Margin="5,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="✅ Asynchronous Search" Style="{StaticResource HeaderStyle}" Foreground="#4CAF50"/>
                                    <Separator Margin="0,5"/>
                                    <TextBlock x:Name="AsyncResultsText" Style="{StaticResource MetricStyle}" TextWrapping="Wrap"/>
                                    <TextBlock Text="✨ UI RESPONSIVE during search!" FontWeight="Bold" Foreground="#4CAF50" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- UI Responsiveness Test -->
                        <Border Grid.Row="2" Background="#E8F5E9" Padding="10" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="UI Responsiveness Test" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="Try clicking this button during the async search - it still works!" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                <Button x:Name="TestResponsiveButton" Content="🖱️ Click Me During Search" Click="TestResponsive_Click" Background="#4CAF50" Foreground="White"/>
                                <TextBlock x:Name="ResponsiveTestText" Text="" Margin="0,10,0,0" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 3: Virtualization Demo -->
            <TabItem Header="💾 Virtualization Demo">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Description -->
                    <Border Grid.Row="0" Background="#F3E5F5" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="UI Virtualization for Large Files" Style="{StaticResource HeaderStyle}"/>
                            <TextBlock TextWrapping="Wrap" Text="Demonstrates memory-efficient rendering by creating controls only for visible bytes. Can reduce memory usage by 80-99% for large files."/>
                        </StackPanel>
                    </Border>

                    <!-- Controls -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="LoadSmallFileButton" Content="Load 1 MB File" Click="LoadSmallFile_Click"/>
                        <Button x:Name="LoadMediumFileButton" Content="Load 10 MB File" Click="LoadMediumFile_Click"/>
                        <Button x:Name="LoadLargeFileButton" Content="Load 100 MB File" Click="LoadLargeFile_Click"/>
                        <TextBlock Text="Current File:" VerticalAlignment="Center" Margin="20,0,5,0"/>
                        <TextBlock x:Name="VirtualFileSizeText" Text="No file loaded" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Results -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Without Virtualization -->
                        <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Margin="0,0,5,0">
                            <StackPanel>
                                <TextBlock Text="❌ Without Virtualization" Style="{StaticResource HeaderStyle}" Foreground="#F44336"/>
                                <Separator Margin="0,5"/>

                                <TextBlock Text="Memory Usage:" FontWeight="Bold" Margin="0,10,0,5"/>
                                <TextBlock x:Name="NoVirtualMemoryText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="NoVirtualControlsText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="NoVirtualRenderTimeText" Style="{StaticResource MetricStyle}"/>

                                <TextBlock Text="⚠️ Problems:" FontWeight="Bold" Margin="0,20,0,5"/>
                                <TextBlock Text="• Creates controls for ALL bytes" Style="{StaticResource MetricStyle}"/>
                                <TextBlock Text="• High memory usage" Style="{StaticResource MetricStyle}"/>
                                <TextBlock Text="• Slow initial render" Style="{StaticResource MetricStyle}"/>
                                <TextBlock Text="• OutOfMemory for large files" Style="{StaticResource MetricStyle}" Foreground="#F44336"/>
                            </StackPanel>
                        </Border>

                        <!-- With Virtualization -->
                        <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Margin="5,0,0,0">
                            <StackPanel>
                                <TextBlock Text="✅ With Virtualization" Style="{StaticResource HeaderStyle}" Foreground="#4CAF50"/>
                                <Separator Margin="0,5"/>

                                <TextBlock Text="Memory Usage:" FontWeight="Bold" Margin="0,10,0,5"/>
                                <TextBlock x:Name="VirtualMemoryText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="VirtualControlsText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="VirtualRenderTimeText" Style="{StaticResource MetricStyle}"/>
                                <TextBlock x:Name="MemorySavingsText" Style="{StaticResource MetricStyle}" FontWeight="Bold" Foreground="#4CAF50" Margin="0,10,0,0"/>

                                <TextBlock Text="✨ Benefits:" FontWeight="Bold" Margin="0,20,0,5"/>
                                <TextBlock Text="• Creates controls ONLY for visible bytes" Style="{StaticResource MetricStyle}"/>
                                <TextBlock Text="• Minimal memory usage" Style="{StaticResource MetricStyle}"/>
                                <TextBlock Text="• Instant render" Style="{StaticResource MetricStyle}"/>
                                <TextBlock Text="• Handles GB-sized files easily" Style="{StaticResource MetricStyle}" Foreground="#4CAF50"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 4: Combined Demo -->
            <TabItem Header="🎯 Combined Demo">
                <Grid Margin="10">
                    <StackPanel>
                        <Border Background="#E1F5FE" Padding="15" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="All Three Optimizations Combined" Style="{StaticResource HeaderStyle}"/>
                                <TextBlock TextWrapping="Wrap" Text="This demo shows how to use Span&lt;byte&gt;, Async/Await, and Virtualization together for maximum performance gains. Perfect for production use cases with large binary files."/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="RunCombinedButton" Content="🚀 Run Combined Performance Test" Click="RunCombined_Click" Padding="15" FontSize="16" Background="#2196F3" Foreground="White"/>

                        <TextBlock x:Name="CombinedResultsText" Text="" Margin="0,20,0,0" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="💡 Tip: Check the code-behind (MainWindow.xaml.cs) to see the implementation details"
                          VerticalAlignment="Center"/>
                <TextBlock Text="WPF HexEditor v2.2.0 Performance Demo"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Foreground="#666"/>
            </Grid>
        </Border>
    </Grid>
</Window>

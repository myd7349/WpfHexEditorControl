<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <AssemblyName>WpfHexEditor.Sample.Performance</AssemblyName>
    <RootNamespace>WpfHexEditor.Sample.Performance</RootNamespace>
    <Title>WPF HexEditor - Performance Demonstration</Title>
    <Description>Interactive demonstration of Span, Async, and Virtualization performance optimizations</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\WPFHexaEditor\WpfHexEditorCore.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Diagnostics.PerformanceCounter" Version="8.0.0" />
  </ItemGroup>

</Project>

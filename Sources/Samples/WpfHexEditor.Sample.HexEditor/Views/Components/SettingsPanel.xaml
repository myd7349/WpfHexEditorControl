<UserControl x:Class="WpfHexEditor.Sample.HexEditor.Views.Components.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexEditor.Sample.HexEditor.Views.Components"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">

    <UserControl.Resources>
        <local:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <local:ThemeConverter x:Key="ThemeConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20">
        <StackPanel>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="??" FontSize="28" Margin="0,0,12,0"/>
                <TextBlock Text="{DynamicResource Settings_Title}"
                          FontSize="22"
                          FontWeight="Bold"
                          Foreground="{DynamicResource ForegroundBrush}"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Theme Section -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings_Theme_Title}"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource ForegroundBrush}"
                              Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding AvailableThemes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton GroupName="Theme"
                                           Command="{Binding DataContext.SelectThemeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           CommandParameter="{Binding Name}"
                                           Margin="0,0,0,8">
                                    <RadioButton.IsChecked>
                                        <MultiBinding Converter="{StaticResource ThemeConverter}" Mode="OneWay">
                                            <Binding Path="Name"/>
                                            <Binding Path="DataContext.SelectedTheme" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                        </MultiBinding>
                                    </RadioButton.IsChecked>
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="ThemeBorder"
                                                   Background="{DynamicResource SurfaceBrush}"
                                                   BorderBrush="{DynamicResource BorderBrush}"
                                                   BorderThickness="2"
                                                   CornerRadius="8"
                                                   Padding="16,12"
                                                   Cursor="Hand">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                             FontSize="14"
                                                             FontWeight="SemiBold"
                                                             Foreground="{DynamicResource ForegroundBrush}"/>
                                                    <TextBlock Text="{Binding Description}"
                                                             FontSize="11"
                                                             Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                                             Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ThemeBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter TargetName="ThemeBorder" Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThemeBorder" Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Language Section -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings_Language_Title}"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource ForegroundBrush}"
                              Margin="0,0,0,12"/>

                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                             SelectedValue="{Binding SelectedLanguage}"
                             SelectedValuePath="Code"
                             DisplayMemberPath="DisplayName"
                             Height="40"
                             FontSize="14"
                             Background="{DynamicResource SurfaceElevatedBrush}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                </StackPanel>
            </Border>

            <!-- Search Options Section -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings_Search_Title}"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource ForegroundBrush}"
                              Margin="0,0,0,12"/>

                    <CheckBox Content="{DynamicResource Settings_Search_EnableParallel}"
                             IsChecked="{Binding EnableParallelSearch}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Margin="0,0,0,8"/>

                    <CheckBox Content="{DynamicResource Settings_Search_UseWildcard}"
                             IsChecked="{Binding UseWildcardSearch}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Margin="0,0,0,8"/>

                    <CheckBox Content="{DynamicResource Settings_Search_HighlightMatches}"
                             IsChecked="{Binding HighlightAllMatches}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="{DynamicResource Settings_Search_ResultLimit}"
                                  FontSize="12"
                                  Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                  Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0"
                                   Minimum="100"
                                   Maximum="100000"
                                   Value="{Binding SearchResultLimit}"
                                   TickFrequency="1000"
                                   IsSnapToTickEnabled="True"
                                   VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                      Text="{Binding SearchResultLimit}"
                                      FontSize="14"
                                      FontWeight="Bold"
                                      Foreground="{DynamicResource AccentBrush}"
                                      Margin="12,0,0,0"
                                      MinWidth="60"
                                      TextAlignment="Right"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Display Options Section -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings_Display_Title}"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource ForegroundBrush}"
                              Margin="0,0,0,12"/>

                    <CheckBox Content="{DynamicResource Settings_Display_ShowLineNumbers}"
                             IsChecked="{Binding ShowLineNumbers}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Margin="0,0,0,8"/>

                    <CheckBox Content="{DynamicResource Settings_Display_ShowScrollMarkers}"
                             IsChecked="{Binding ShowScrollMarkers}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Margin="0,0,0,8"/>

                    <CheckBox Content="{DynamicResource Settings_Display_ShowStatusBar}"
                             IsChecked="{Binding ShowStatusBar}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Margin="0,0,0,12"/>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings_Display_BytesPerLine}"
                                  FontSize="12"
                                  Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                  Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <RadioButton Content="8" IsChecked="{Binding BytesPerLine, Converter={StaticResource IntToBoolConverter}, ConverterParameter=8}" Margin="0,0,12,0"/>
                            <RadioButton Content="16" IsChecked="{Binding BytesPerLine, Converter={StaticResource IntToBoolConverter}, ConverterParameter=16}" Margin="0,0,12,0"/>
                            <RadioButton Content="32" IsChecked="{Binding BytesPerLine, Converter={StaticResource IntToBoolConverter}, ConverterParameter=32}" Margin="0,0,12,0"/>
                            <RadioButton Content="64" IsChecked="{Binding BytesPerLine, Converter={StaticResource IntToBoolConverter}, ConverterParameter=64}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Performance Info Section -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings_Performance_Title}"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource ForegroundBrush}"
                              Margin="0,0,0,12"/>

                    <Border Background="{DynamicResource AccentBrush}"
                           CornerRadius="8"
                           Padding="12,8"
                           Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Settings_Performance_V2Active}"
                                  FontSize="12"
                                  FontWeight="Bold"
                                  Foreground="#000000"
                                  HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="{DynamicResource Settings_Performance_Feature1}"
                              FontSize="11"
                              Foreground="{DynamicResource ForegroundSecondaryBrush}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource Settings_Performance_Feature2}"
                              FontSize="11"
                              Foreground="{DynamicResource ForegroundSecondaryBrush}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource Settings_Performance_Feature3}"
                              FontSize="11"
                              Foreground="{DynamicResource ForegroundSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                       Content="{DynamicResource Settings_Button_ResetDefaults}"
                       Command="{Binding ResetToDefaultsCommand}"
                       Style="{StaticResource ModernButtonStyle}"
                       Margin="0,0,8,0"/>

                <Button Grid.Column="1"
                       Content="{DynamicResource Settings_Button_SaveSettings}"
                       Command="{Binding SaveSettingsCommand}"
                       Style="{StaticResource AccentButtonStyle}"
                       Margin="8,0,0,0"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

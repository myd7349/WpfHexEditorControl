<Window x:Class="WpfHexEditor.Sample.HexEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hexEditor="clr-namespace:WpfHexEditor.HexEditor;assembly=WpfHexEditor.HexEditor"
        xmlns:hexControls="clr-namespace:WpfHexEditor.HexEditor.Controls;assembly=WpfHexEditor.HexEditor"
        xmlns:components="clr-namespace:WpfHexEditor.Sample.HexEditor.Views.Components"
        Title="WPF Hex Editor — Sample"
        Height="720" Width="1200"
        MinHeight="480" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Command="{Binding OpenCommand}"      Key="O" Modifiers="Ctrl"/>
        <KeyBinding Command="{Binding SaveCommand}"      Key="S" Modifiers="Ctrl"/>
        <KeyBinding Command="{Binding CloseFileCommand}" Key="W" Modifiers="Ctrl"/>
        <KeyBinding Command="{Binding UndoCommand}"      Key="Z" Modifiers="Ctrl"/>
        <KeyBinding Command="{Binding RedoCommand}"      Key="Y" Modifiers="Ctrl"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- menu -->
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="*"/>     <!-- content -->
            <RowDefinition Height="Auto"/>  <!-- statusbar -->
        </Grid.RowDefinitions>

        <!-- ═══ MENU ═══════════════════════════════════════════════════════ -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open…"       Command="{Binding OpenCommand}"      InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save"         Command="{Binding SaveCommand}"      InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="_Close File"   Command="{Binding CloseFileCommand}" InputGestureText="Ctrl+W"/>
                <Separator/>
                <MenuItem Header="E_xit"         Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"  Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo"  Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Parsed Fields Panel" IsCheckable="True"
                          IsChecked="{Binding ShowParsedFieldsPanel}"/>
                <MenuItem Header="Settings Panel"      IsCheckable="True"
                          IsChecked="{Binding ShowSettingsPanel}"/>
                <Separator/>
                <MenuItem Header="Dark Theme"  x:Name="ThemeDarkItem"  IsCheckable="True" IsChecked="True"  Click="ThemeDark_Click"/>
                <MenuItem Header="Light Theme" x:Name="ThemeLightItem" IsCheckable="True" IsChecked="False" Click="ThemeLight_Click"/>
                <Separator/>
                <MenuItem Header="8 Bytes/Line"  Tag="8"  Click="BytesPerLine_Click" x:Name="Bpl8"/>
                <MenuItem Header="16 Bytes/Line" Tag="16" Click="BytesPerLine_Click" x:Name="Bpl16" IsChecked="True"/>
                <MenuItem Header="32 Bytes/Line" Tag="32" Click="BytesPerLine_Click" x:Name="Bpl32"/>
                <MenuItem Header="64 Bytes/Line" Tag="64" Click="BytesPerLine_Click" x:Name="Bpl64"/>
            </MenuItem>
            <MenuItem Header="_TBL">
                <MenuItem Header="_Load TBL File…"  Click="LoadTbl_Click"/>
                <MenuItem Header="_Close TBL"        Click="CloseTbl_Click" x:Name="CloseTblItem" IsEnabled="False"/>
            </MenuItem>
        </Menu>

        <!-- ═══ TOOLBAR ═════════════════════════════════════════════════════ -->
        <ToolBarTray Grid.Row="1">
            <ToolBar>
                <!-- File operations -->
                <Button Command="{Binding OpenCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        Content="&#xED25;"
                        ToolTip="Open (Ctrl+O)"/>
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        Content="&#xE74E;"
                        ToolTip="Save (Ctrl+S)"/>
                <Separator/>

                <!-- Edit operations -->
                <Button Command="{Binding UndoCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        Content="&#xE7A7;"
                        ToolTip="Undo (Ctrl+Z)"/>
                <Button Command="{Binding RedoCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        Content="&#xE7A6;"
                        ToolTip="Redo (Ctrl+Y)"/>
                <Separator/>

                <!-- Edit mode -->
                <ToggleButton x:Name="InsertModeToggle"
                              Style="{StaticResource ToolbarToggleStyle}"
                              Click="InsertMode_Click"
                              ToolTip="Insert Mode"
                              Padding="6,3"
                              Content="INS"/>
                <ToggleButton x:Name="ReadOnlyToggle"
                              Style="{StaticResource ToolbarToggleStyle}"
                              Click="ReadOnly_Click"
                              ToolTip="Read Only"
                              Padding="6,3"
                              Content="RO"/>
                <Separator/>

                <!-- Panel toggles -->
                <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                              IsChecked="{Binding ShowParsedFieldsPanel}"
                              ToolTip="Toggle Parsed Fields Panel"
                              Padding="6,3"
                              Content="Fields"/>
                <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                              IsChecked="{Binding ShowSettingsPanel}"
                              ToolTip="Toggle Settings Panel"
                              Padding="6,3"
                              Content="Settings"/>
            </ToolBar>
        </ToolBarTray>

        <!-- ═══ CONTENT ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>  <!-- splitter -->
                <ColumnDefinition x:Name="RightPanelColumn" Width="300" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <!-- HexEditor -->
            <hexControls:HexEditorSplitHost x:Name="HexEditorHost"
                                             Grid.Column="0"/>

            <!-- Vertical splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource SeparatorBrush}">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowParsedFieldsPanel}" Value="False">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- Right panels -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Parsed Fields Panel -->
                <components:ParsedFieldsPanel x:Name="ParsedFieldsPanel"
                                              Grid.Row="0"
                                              Visibility="{Binding ShowParsedFieldsPanel, Converter={StaticResource BoolToVis}}"/>

                <!-- Settings panel splitter -->
                <GridSplitter Grid.Row="1"
                              Height="4"
                              Width="Auto"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="{StaticResource SeparatorBrush}"
                              Visibility="{Binding ShowSettingsPanel, Converter={StaticResource BoolToVis}}"/>

                <!-- HexEditor Settings -->
                <hexControls:HexEditorSettings x:Name="HexEditorSettings"
                                               Grid.Row="2"
                                               MaxHeight="350"
                                               Visibility="{Binding ShowSettingsPanel, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Grid>

        <!-- ═══ STATUS BAR ════════════════════════════════════════════════════ -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>

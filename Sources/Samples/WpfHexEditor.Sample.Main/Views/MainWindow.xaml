    HexEditor V2 - Main Window (Classic Menu + Toolbar Style)
    Based on original MainWindow.xaml structure
    Author : Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.5
-->

<Window x:Class="WpfHexEditor.Sample.Main.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfHexEditor.Sample.Main.Views"
        xmlns:components="clr-namespace:WpfHexEditor.Sample.Main.Views.Components"
        xmlns:hexEditor="clr-namespace:WpfHexaEditor;assembly=WPFHexaEditor"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <components:VisibilityToBoolConverter x:Key="VisibilityToBooleanConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <!-- Keyboard shortcuts -->
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewFileCommand}"/>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding ToggleSearchPanelCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding CopyCommand}"/>
        <KeyBinding Key="X" Modifiers="Control" Command="{Binding CutCommand}"/>
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding PasteCommand}"/>
        <KeyBinding Key="A" Modifiers="Control" Command="{Binding SelectAllCommand}"/>
        <KeyBinding Key="G" Modifiers="Control" Command="{Binding GoToPositionCommand}"/>
        <KeyBinding Key="B" Modifiers="Control" Command="{Binding ToggleBookmarkCommand}"/>
        <KeyBinding Key="OemComma" Modifiers="Control" Command="{Binding ToggleSettingsPanelCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Menu -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Menu Bar (Original Structure) -->
        <Menu Grid.Row="0">
            <MenuItem Header="{DynamicResource Menu_File}">
                <MenuItem Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_File_Open}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding SaveFileCommand}" InputGestureText="Ctrl+S">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_File_Save}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding SaveAsFileCommand}">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_File_SaveAs}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator/>
                <MenuItem Command="{Binding CloseFileCommand}">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="❌ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_File_Close}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator/>
                <MenuItem Command="{Binding ExitCommand}">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_File_Exit}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Edit}">
                <MenuItem Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↶ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Edit_Undo}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↷ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Edit_Redo}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator/>
                <MenuItem Command="{Binding ToggleSearchPanelCommand}" InputGestureText="Ctrl+F">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Edit_Find}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding ToggleSearchPanelCommand}" InputGestureText="Ctrl+H">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔎 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Edit_FindReplace}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator/>
                <MenuItem Command="{Binding CopyCommand}" InputGestureText="Ctrl+C">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Edit_Copy}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding PasteCommand}" InputGestureText="Ctrl+V">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Edit_Paste}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding DeleteSelectionCommand}" InputGestureText="Del">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑️ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Edit_DeleteSelection}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator/>
                <MenuItem Command="{Binding SelectAllCommand}" InputGestureText="Ctrl+A">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☑️ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Edit_SelectAll}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding ClearSelectionCommand}">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬜ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Edit_ClearSelection}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator/>
                <MenuItem Command="{Binding ReverseSelectionCommand}"
                          ToolTip="{DynamicResource ReverseSelectionTooltipString}"
                          ToolTipService.ShowOnDisabled="True"
                          ToolTipService.IsEnabled="True">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⇄ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="Reverse Selection"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding InvertSelectionCommand}"
                          ToolTip="{DynamicResource InvertSelectionTooltipString}"
                          ToolTipService.ShowOnDisabled="True"
                          ToolTipService.IsEnabled="True">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊕ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="Invert Selection"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Edit_Bookmarks}">
                    <MenuItem Command="{Binding ToggleBookmarkCommand}" InputGestureText="Ctrl+B">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔖 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource Menu_Edit_ToggleBookmark}"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding ClearBookmarksCommand}">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑️ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource Menu_Edit_ClearAllBookmarks}"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Search}">
                <MenuItem Command="{Binding FindNextCommand}" InputGestureText="F3">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬇️ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Search_FindNext}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding FindPreviousCommand}" InputGestureText="Shift+F3">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬆️ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Search_FindPrevious}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Tools}">
                <MenuItem Header="{DynamicResource Menu_Tools_Bookmarks}">
                    <MenuItem Command="{Binding ToggleBookmarkCommand}" InputGestureText="Ctrl+B">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔖 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource Menu_Edit_ToggleBookmark}"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding ClearBookmarksCommand}">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑️ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource Menu_Edit_ClearAllBookmarks}"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Command="{Binding NextBookmarkCommand}" InputGestureText="Ctrl+N">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⬇️ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource Menu_Tools_NextBookmark}"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding PreviousBookmarkCommand}" InputGestureText="Ctrl+P">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⬆️ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource Menu_Tools_PreviousBookmark}"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Command="{Binding ShowBookmarksCommand}">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📚 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource Menu_Tools_ShowAllBookmarks}"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Byte Operations">
                    <MenuItem Command="{Binding FillWithByteCommand}"
                              ToolTip="{DynamicResource FillWithByteTooltipString}"
                              ToolTipService.ShowOnDisabled="True"
                              ToolTipService.IsEnabled="True">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎨 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                <TextBlock Text="Fill with Byte..."/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding ReplaceByteCommand}"
                              ToolTip="{DynamicResource ReplaceByteTooltipString}"
                              ToolTipService.ShowOnDisabled="True"
                              ToolTipService.IsEnabled="True">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔄 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                <TextBlock Text="Replace Byte..."/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Character Table (TBL)">
                    <MenuItem Click="LoadTblMenuItem_Click">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                <TextBlock Text="Load TBL File..."/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem x:Name="CloseTblMenuItem"
                              Click="CloseTblMenuItem_Click"
                              IsEnabled="False">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="❌ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                                <TextBlock Text="Close TBL"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Position}">
                <MenuItem Command="{Binding GoToPositionCommand}" InputGestureText="Ctrl+G">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎯 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Position_GoTo}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_View}">
                <MenuItem Header="{DynamicResource Menu_View_DisplayOptions}">
                    <MenuItem Header="{DynamicResource Menu_View_ShowStatusBar}"
                             IsCheckable="True"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=StatusBarVisibility, Converter={StaticResource VisibilityToBooleanConverter}, Mode=TwoWay}"/>
                    <MenuItem Header="{DynamicResource Menu_View_ShowHeader}"
                             IsCheckable="True"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=HeaderVisibility, Converter={StaticResource VisibilityToBooleanConverter}, Mode=TwoWay}"/>
                    <MenuItem Header="{DynamicResource Menu_View_ShowOffset}"
                             IsCheckable="True"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=ShowOffset, Mode=TwoWay}"/>
                    <MenuItem Header="{DynamicResource Menu_View_ShowASCII}"
                             IsCheckable="True"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=ShowAscii, Mode=TwoWay}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_View_BytesPerLine}">
                    <MenuItem Header="8" Tag="8"/>
                    <MenuItem Header="16" Tag="16" IsChecked="True"/>
                    <MenuItem Header="32" Tag="32"/>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Options}">
                <MenuItem Command="{Binding ToggleSettingsPanelCommand}" InputGestureText="Ctrl+,">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Options_SettingsPanel}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator/>
                <MenuItem Click="ShowOptionsDialog_Click">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔧 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Options_Advanced}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Options_ContextMenu}"
                         IsCheckable="True"
                         IsChecked="{Binding ElementName=HexEditorControl, Path=AllowContextMenu, Mode=TwoWay}"/>
                <MenuItem Header="{DynamicResource Menu_Options_ShowByteToolTip}"
                         IsCheckable="True"
                         IsChecked="{Binding ElementName=HexEditorControl, Path=ShowByteToolTip, Mode=TwoWay}"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_Options_AutoHighlight}"
                         IsCheckable="True"
                         IsChecked="{Binding ElementName=HexEditorControl, Path=AllowAutoHighLightSelectionByte, Mode=TwoWay}"/>
                <MenuItem Header="{DynamicResource Menu_Options_CountSelected}"
                         IsCheckable="True"
                         IsChecked="{Binding ElementName=HexEditorControl, Path=AllowByteCount, Mode=TwoWay}"/>
            </MenuItem>

            <MenuItem Header="{DynamicResource Menu_Help}">
                <MenuItem Command="{Binding ShowAboutCommand}">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ️ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Help_About}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding ShowKeyboardShortcutsCommand}">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌨️ " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Help_KeyboardShortcuts}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator/>
                <MenuItem Command="{Binding OpenGitHubCommand}">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔗 " FontFamily="Segoe UI Emoji" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource Menu_Help_GitHub}"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Toolbar (Original Structure) -->
        <ToolBar Grid.Row="1">
            <Button Command="{Binding OpenFileCommand}" ToolTip="{DynamicResource Toolbar_Open_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_Open}" FontSize="12"/>
            </Button>
            <Button Command="{Binding SaveFileCommand}" ToolTip="{DynamicResource Toolbar_Save_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_Save}" FontSize="12"/>
            </Button>
            <Separator/>
            <Button Command="{Binding UndoCommand}" ToolTip="{DynamicResource Toolbar_Undo_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_Undo}" FontSize="12"/>
            </Button>
            <Button Command="{Binding RedoCommand}" ToolTip="{DynamicResource Toolbar_Redo_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_Redo}" FontSize="12"/>
            </Button>
            <Separator/>
            <ToggleButton ToolTip="{DynamicResource Toolbar_Insert_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_Insert}" FontSize="12" FontWeight="Bold"/>
            </ToggleButton>
            <ToggleButton ToolTip="{DynamicResource Toolbar_ReadOnly_ToolTip}">
                <TextBlock Text="{DynamicResource Toolbar_ReadOnly}" FontSize="12"/>
            </ToggleButton>
        </ToolBar>

        <!-- Main Content with Settings Panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- HexEditor Control -->
            <hexEditor:HexEditor x:Name="HexEditorControl"
                                Grid.Column="0"
                                Margin="4"/>

            <!-- Settings Panel (Slide-in from right) -->
            <components:HexEditorSettings x:Name="HexEditorSettingsPanel"
                                         Grid.Column="1"
                                         Visibility="{Binding IsSettingsPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <components:HexEditorSettings.Style>
                    <Style TargetType="components:HexEditorSettings">
                        <Setter Property="Width" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsPanelVisible}" Value="True">
                                <Setter Property="Width" Value="350"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </components:HexEditorSettings.Style>
            </components:HexEditorSettings>

        </Grid>

    </Grid>

</Window>

<UserControl x:Class="WpfHexEditor.Sample.Main.Views.Components.HexEditorSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:components="clr-namespace:WpfHexEditor.Sample.Main.Views.Components"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16">

            <!-- Header -->
            <TextBlock Text="HEX EDITOR SETTINGS"
                      FontSize="16"
                      FontWeight="Bold"
                      Foreground="{StaticResource ForegroundBrush}"
                      Margin="0,0,0,16"/>

            <!-- Display Settings -->
            <Expander Header="📺 Display Options" IsExpanded="True" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="Show Line Numbers (placeholder)"
                             IsEnabled="False"
                             ToolTip="This feature is not yet available in V2"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="Show Byte Tooltip"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=ShowByteToolTip, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="Hide Deleted Bytes"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=HideByteDeleted, Mode=TwoWay}"
                             Margin="0,0,0,8"/>

                    <TextBlock Text="Bytes Per Line:" FontSize="11" Margin="0,8,0,4"/>
                    <ComboBox x:Name="BytesPerLineComboBox"
                             SelectedIndex="1"
                             Margin="0,0,0,8"
                             SelectionChanged="BytesPerLineComboBox_SelectionChanged">
                        <ComboBoxItem Content="8" Tag="8"/>
                        <ComboBoxItem Content="16" Tag="16"/>
                        <ComboBoxItem Content="32" Tag="32"/>
                        <ComboBoxItem Content="64" Tag="64"/>
                    </ComboBox>

                    <TextBlock Text="Zoom Scale:" FontSize="11" Margin="0,8,0,4"/>
                    <Slider x:Name="ZoomSlider"
                           Minimum="0.5"
                           Maximum="3"
                           Value="1"
                           TickFrequency="0.1"
                           ValueChanged="ZoomSlider_ValueChanged"/>
                </StackPanel>
            </Expander>

            <!-- Editing Options -->
            <Expander Header="✏️ Editing Options" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="Read Only Mode"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=ReadOnlyMode, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="Allow Insert Anywhere"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=CanInsertAnywhere, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="Allow Delete Byte"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=AllowDeleteByte, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="Allow Extend File"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=AllowExtend, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="Append Needs Confirmation"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=AppendNeedConfirmation, Mode=TwoWay}"
                             Margin="0,0,0,8"/>

                    <TextBlock Text="Edit Mode:" FontSize="11" Margin="0,8,0,4"/>
                    <ComboBox x:Name="EditModeComboBox"
                             SelectedIndex="0"
                             Margin="0,0,0,8"
                             SelectionChanged="EditModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Overwrite" Tag="Overwrite"/>
                        <ComboBoxItem Content="Insert" Tag="Insert"/>
                    </ComboBox>

                    <TextBlock Text="Caret Mode:" FontSize="11" Margin="0,8,0,4"/>
                    <ComboBox x:Name="CaretModeComboBox"
                             SelectedIndex="0"
                             SelectionChanged="CaretModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Insert" Tag="Insert"/>
                        <ComboBoxItem Content="Overwrite" Tag="Overwrite"/>
                    </ComboBox>
                </StackPanel>
            </Expander>

            <!-- Clipboard Options -->
            <Expander Header="📋 Clipboard Options" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <TextBlock Text="Default Copy Mode:" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CopyModeComboBox"
                             SelectedIndex="0"
                             Margin="0,0,0,8"
                             SelectionChanged="CopyModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Hex String" Tag="HexaString"/>
                        <ComboBoxItem Content="Byte Array" Tag="ByteArray"/>
                        <ComboBoxItem Content="C# Code" Tag="CSharpCode"/>
                        <ComboBoxItem Content="VB Code" Tag="VBCode"/>
                        <ComboBoxItem Content="C Code" Tag="CCode"/>
                        <ComboBoxItem Content="Java Code" Tag="JavaCode"/>
                    </ComboBox>
                </StackPanel>
            </Expander>

            <!-- Drag &amp; Drop Options -->
            <Expander Header="📎 Drag &amp; Drop Options" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="Allow File Drop"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=AllowFileDrop, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="File Dropping Confirmation"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=FileDroppingConfirmation, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="Allow Text Drop"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=AllowTextDrop, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                </StackPanel>
            </Expander>

            <!-- Highlight &amp; Selection -->
            <Expander Header="🎨 Highlight &amp; Selection" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="Auto-Highlight Selection Byte"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=AllowAutoHighLightSelectionByte, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="Auto-Select Same Byte (Double-Click)"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=AllowAutoSelectSameByteAtDoubleClick, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="Allow Marker Click Navigation"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=AllowMarkerClickNavigation, Mode=TwoWay}"
                             Margin="0,0,0,8"/>

                    <TextBlock Text="Auto-Highlight Color:" FontSize="11" Margin="0,8,0,4"/>
                    <components:ColorPicker x:Name="AutoHighlightColorPicker"
                                           ColorChanged="AutoHighlightColorPicker_ColorChanged"/>
                </StackPanel>
            </Expander>

            <!-- Search Options -->
            <Expander Header="🔍 Search Options" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="Enable Parallel Search"
                             x:Name="ParallelSearchCheckBox"
                             IsChecked="True"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="Use Wildcard Search (??)"
                             x:Name="WildcardSearchCheckBox"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="Highlight All Matches"
                             x:Name="HighlightMatchesCheckBox"
                             IsChecked="True"
                             Margin="0,0,0,8"/>

                    <TextBlock Text="Search Result Limit:" FontSize="11" Margin="0,8,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                               x:Name="SearchLimitSlider"
                               Minimum="100"
                               Maximum="100000"
                               Value="10000"
                               TickFrequency="1000"/>
                        <TextBlock Grid.Column="1"
                                  Text="{Binding ElementName=SearchLimitSlider, Path=Value, StringFormat='{}{0:F0}'}"
                                  FontSize="12"
                                  Margin="8,0,0,0"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Statistics & Counting -->
            <Expander Header="📊 Statistics" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="Allow Byte Count"
                             IsChecked="{Binding ElementName=HexEditorControl, Path=AllowByteCount, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                </StackPanel>
            </Expander>

            <!-- Advanced Options -->
            <Expander Header="⚙️ Advanced Options" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <TextBlock Text="Byte Shift Left:" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="ByteShiftLeftTextBox"
                            Text="0"
                            Style="{StaticResource ModernTextBoxStyle}"
                            TextChanged="ByteShiftLeftTextBox_TextChanged"
                            Margin="0,0,0,12"/>

                    <Button Content="Save Current State"
                           x:Name="SaveStateButton"
                           Click="SaveStateButton_Click"
                           Style="{StaticResource ModernButtonStyle}"
                           Margin="0,0,0,8"/>
                    <Button Content="Load Saved State"
                           x:Name="LoadStateButton"
                           Click="LoadStateButton_Click"
                           Style="{StaticResource ModernButtonStyle}"/>
                </StackPanel>
            </Expander>

            <!-- Reset Button -->
            <Button Content="🔄 Reset All to Defaults"
                   x:Name="ResetButton"
                   Click="ResetButton_Click"
                   Style="{StaticResource ModernButtonStyle}"
                   Margin="0,16,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

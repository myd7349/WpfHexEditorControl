<UserControl x:Class="WpfHexEditor.Sample.Main.Views.Components.HexEditorSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:components="clr-namespace:WpfHexEditor.Sample.Main.Views.Components"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">

    <UserControl.Resources>
        <components:EnumToComboBoxConverter x:Key="EnumToComboBoxConverter"/>
        <components:BytesPerLineToIndexConverter x:Key="BytesPerLineToIndexConverter"/>
        <components:ZoomToPercentConverter x:Key="ZoomToPercentConverter"/>
    </UserControl.Resources>

    <!--
        Dynamic Settings Panel - Auto-generated via reflection
        Content is created by DynamicSettingsGenerator in code-behind
    -->
    <ScrollViewer x:Name="SettingsScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"/>

</UserControl>

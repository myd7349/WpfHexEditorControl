<UserControl x:Class="WpfHexEditor.Sample.Main.Views.Components.HexEditorSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:components="clr-namespace:WpfHexEditor.Sample.Main.Views.Components"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16">

            <!-- Header -->
            <TextBlock Text="{DynamicResource HexSettings_Title}"
                      FontSize="16"
                      FontWeight="Bold"
                      Foreground="{DynamicResource ForegroundBrush}"
                      Margin="0,0,0,16"/>

            <!-- Display Settings -->
            <Expander Header="{DynamicResource HexSettings_Display_Title}" IsExpanded="True" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="{DynamicResource HexSettings_Display_ShowLineNumbers}"
                             IsEnabled="False"
                             ToolTip="{DynamicResource HexSettings_Display_ShowLineNumbers_ToolTip}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_Display_ShowByteTooltip}"
                             IsChecked="{Binding Path=ShowByteToolTip, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_Display_HideDeleted}"
                             IsChecked="{Binding Path=HideByteDeleted, Mode=TwoWay}"
                             Margin="0,0,0,8"/>

                    <TextBlock Text="{DynamicResource HexSettings_Display_BytesPerLine}" FontSize="11" Margin="0,8,0,4"/>
                    <ComboBox x:Name="BytesPerLineComboBox"
                             SelectedIndex="1"
                             Margin="0,0,0,8"
                             SelectionChanged="BytesPerLineComboBox_SelectionChanged">
                        <ComboBoxItem Content="8" Tag="8"/>
                        <ComboBoxItem Content="16" Tag="16"/>
                        <ComboBoxItem Content="32" Tag="32"/>
                        <ComboBoxItem Content="64" Tag="64"/>
                    </ComboBox>

                    <TextBlock Text="{DynamicResource HexSettings_Display_ZoomScale}" FontSize="11" Margin="0,8,0,4"/>
                    <Slider x:Name="ZoomSlider"
                           Minimum="0.5"
                           Maximum="3"
                           Value="1"
                           TickFrequency="0.1"
                           ValueChanged="ZoomSlider_ValueChanged"/>
                </StackPanel>
            </Expander>

            <!-- Editing Options -->
            <Expander Header="{DynamicResource HexSettings_Editing_Title}" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="{DynamicResource HexSettings_Editing_ReadOnly}"
                             IsChecked="{Binding Path=ReadOnlyMode, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_Editing_AllowInsertAnywhere}"
                             IsChecked="{Binding Path=CanInsertAnywhere, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_Editing_AllowDeleteByte}"
                             IsChecked="{Binding Path=AllowDeleteByte, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_Editing_AllowExtendFile}"
                             IsChecked="{Binding Path=AllowExtend, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_Editing_AppendNeedsConfirmation}"
                             IsChecked="{Binding Path=AppendNeedConfirmation, Mode=TwoWay}"
                             Margin="0,0,0,8"/>

                    <TextBlock Text="{DynamicResource HexSettings_Editing_EditMode}" FontSize="11" Margin="0,8,0,4"/>
                    <ComboBox x:Name="EditModeComboBox"
                             SelectedIndex="0"
                             Margin="0,0,0,8"
                             SelectionChanged="EditModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="{DynamicResource HexSettings_Editing_Overwrite}" Tag="Overwrite"/>
                        <ComboBoxItem Content="{DynamicResource HexSettings_Editing_Insert}" Tag="Insert"/>
                    </ComboBox>

                    <TextBlock Text="{DynamicResource HexSettings_Editing_CaretMode}" FontSize="11" Margin="0,8,0,4"/>
                    <ComboBox x:Name="CaretModeComboBox"
                             SelectedIndex="0"
                             SelectionChanged="CaretModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="{DynamicResource HexSettings_Editing_Insert}" Tag="Insert"/>
                        <ComboBoxItem Content="{DynamicResource HexSettings_Editing_Overwrite}" Tag="Overwrite"/>
                    </ComboBox>
                </StackPanel>
            </Expander>

            <!-- Clipboard Options -->
            <Expander Header="{DynamicResource HexSettings_Clipboard_Title}" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <TextBlock Text="{DynamicResource HexSettings_Clipboard_DefaultCopyMode}" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CopyModeComboBox"
                             SelectedIndex="0"
                             Margin="0,0,0,8"
                             SelectionChanged="CopyModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="{DynamicResource HexSettings_Clipboard_HexString}" Tag="HexaString"/>
                        <ComboBoxItem Content="{DynamicResource HexSettings_Clipboard_ByteArray}" Tag="ByteArray"/>
                        <ComboBoxItem Content="{DynamicResource HexSettings_Clipboard_CSharpCode}" Tag="CSharpCode"/>
                        <ComboBoxItem Content="{DynamicResource HexSettings_Clipboard_VBCode}" Tag="VBCode"/>
                        <ComboBoxItem Content="{DynamicResource HexSettings_Clipboard_CCode}" Tag="CCode"/>
                        <ComboBoxItem Content="{DynamicResource HexSettings_Clipboard_JavaCode}" Tag="JavaCode"/>
                    </ComboBox>
                </StackPanel>
            </Expander>

            <!-- Drag &amp; Drop Options -->
            <Expander Header="{DynamicResource HexSettings_DragDrop_Title}" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="{DynamicResource HexSettings_DragDrop_AllowFileDrop}"
                             IsChecked="{Binding Path=AllowFileDrop, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_DragDrop_FileDropConfirmation}"
                             IsChecked="{Binding Path=FileDroppingConfirmation, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_DragDrop_AllowTextDrop}"
                             IsChecked="{Binding Path=AllowTextDrop, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                </StackPanel>
            </Expander>

            <!-- Highlight &amp; Selection -->
            <Expander Header="{DynamicResource HexSettings_Highlight_Title}" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="{DynamicResource HexSettings_Highlight_AutoHighlight}"
                             IsChecked="{Binding Path=AllowAutoHighLightSelectionByte, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_Highlight_AutoSelectDoubleClick}"
                             IsChecked="{Binding Path=AllowAutoSelectSameByteAtDoubleClick, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_Highlight_AllowMarkerClick}"
                             IsChecked="{Binding Path=AllowMarkerClickNavigation, Mode=TwoWay}"
                             Margin="0,0,0,8"/>

                    <TextBlock Text="{DynamicResource HexSettings_Highlight_AutoHighlightColor}" FontSize="11" Margin="0,8,0,4"/>
                    <components:ColorPicker x:Name="AutoHighlightColorPicker"
                                           ColorChanged="AutoHighlightColorPicker_ColorChanged"/>
                </StackPanel>
            </Expander>

            <!-- Search Options -->
            <Expander Header="{DynamicResource HexSettings_Search_Title}" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="{DynamicResource HexSettings_Search_EnableParallel}"
                             x:Name="ParallelSearchCheckBox"
                             IsChecked="True"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_Search_UseWildcard}"
                             x:Name="WildcardSearchCheckBox"
                             Margin="0,0,0,8"/>
                    <CheckBox Content="{DynamicResource HexSettings_Search_HighlightMatches}"
                             x:Name="HighlightMatchesCheckBox"
                             IsChecked="True"
                             Margin="0,0,0,8"/>

                    <TextBlock Text="{DynamicResource HexSettings_Search_ResultLimit}" FontSize="11" Margin="0,8,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                               x:Name="SearchLimitSlider"
                               Minimum="100"
                               Maximum="100000"
                               Value="10000"
                               TickFrequency="1000"/>
                        <TextBlock Grid.Column="1"
                                  Text="{Binding ElementName=SearchLimitSlider, Path=Value, StringFormat='{}{0:F0}'}"
                                  FontSize="12"
                                  Margin="8,0,0,0"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Statistics & Counting -->
            <Expander Header="{DynamicResource HexSettings_Statistics_Title}" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <CheckBox Content="{DynamicResource HexSettings_Statistics_AllowByteCount}"
                             IsChecked="{Binding Path=AllowByteCount, Mode=TwoWay}"
                             Margin="0,0,0,8"/>
                </StackPanel>
            </Expander>

            <!-- Advanced Options -->
            <Expander Header="{DynamicResource HexSettings_Advanced_Title}" Margin="0,0,0,8">
                <StackPanel Margin="16,8,0,0">
                    <TextBlock Text="{DynamicResource HexSettings_Advanced_ByteShiftLeft}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="ByteShiftLeftTextBox"
                            Text="0"
                            Style="{StaticResource ModernTextBoxStyle}"
                            TextChanged="ByteShiftLeftTextBox_TextChanged"
                            Margin="0,0,0,12"/>

                    <Button Content="{DynamicResource HexSettings_Advanced_SaveState}"
                           x:Name="SaveStateButton"
                           Click="SaveStateButton_Click"
                           Style="{StaticResource ModernButtonStyle}"
                           Margin="0,0,0,8"/>
                    <Button Content="{DynamicResource HexSettings_Advanced_LoadState}"
                           x:Name="LoadStateButton"
                           Click="LoadStateButton_Click"
                           Style="{StaticResource ModernButtonStyle}"/>
                </StackPanel>
            </Expander>

            <!-- Reset Button -->
            <Button Content="{DynamicResource HexSettings_ResetButton}"
                   x:Name="ResetButton"
                   Click="ResetButton_Click"
                   Style="{StaticResource ModernButtonStyle}"
                   Margin="0,16,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="WpfHexEditor.Sample.Main.Views.Components.SearchCommandCenter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexEditor.Sample.Main.Views.Components"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="500"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <!-- Main Container -->
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Bar Row -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search Box -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Height="32"
                    Margin="0,0,8,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Icon -->
                    <TextBlock Grid.Column="0"
                              Text="🔍"
                              FontSize="14"
                              VerticalAlignment="Center"
                              Margin="8,0,6,0"
                              Opacity="0.6"/>

                    <!-- Search TextBox -->
                    <TextBox Grid.Column="1"
                            x:Name="SearchTextBox"
                            Text="{Binding SearchPattern, UpdateSourceTrigger=PropertyChanged}"
                            FontSize="13"
                            FontFamily="Segoe UI"
                            BorderThickness="0"
                            Background="Transparent"
                            Foreground="{DynamicResource ForegroundBrush}"
                            CaretBrush="{DynamicResource AccentBrush}"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding FindAllCommand}"/>
                            <KeyBinding Key="F3" Command="{Binding FindNextCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- Mode Selector (Dropdown-style) -->
                    <ComboBox Grid.Column="2"
                             SelectedIndex="0"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource ForegroundSecondaryBrush}"
                             FontSize="11"
                             VerticalAlignment="Center"
                             Margin="4,0">
                        <ComboBoxItem Content="{DynamicResource Search_Mode_Text}" IsSelected="{Binding IsTextMode}"/>
                        <ComboBoxItem Content="{DynamicResource Search_Mode_Hex}" IsSelected="{Binding IsHexMode}"/>
                        <ComboBoxItem Content="{DynamicResource Search_Mode_Regex}" IsSelected="{Binding IsRegexMode}"/>
                    </ComboBox>

                    <!-- Clear Button -->
                    <Button Grid.Column="3"
                           Content="✕"
                           FontSize="12"
                           Width="24"
                           Height="24"
                           Margin="2,0,4,0"
                           Style="{StaticResource ModernButtonStyle}"
                           Command="{Binding ClearSearchCommand}"
                           ToolTip="{DynamicResource Search_Clear_ToolTip}"
                           Visibility="{Binding HasSearchPattern, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="◀"
                       Width="28"
                       Height="32"
                       Style="{StaticResource ModernButtonStyle}"
                       Command="{Binding FindPreviousCommand}"
                       IsEnabled="{Binding HasResults}"
                       ToolTip="{DynamicResource Search_Previous_ToolTip}"
                       Margin="0,0,4,0"/>

                <Button Content="▶"
                       Width="28"
                       Height="32"
                       Style="{StaticResource ModernButtonStyle}"
                       Command="{Binding FindNextCommand}"
                       IsEnabled="{Binding HasResults}"
                       ToolTip="{DynamicResource Search_Next_ToolTip}"
                       Margin="0,0,4,0"/>

                <Button Content="{DynamicResource Search_FindAll}"
                       Height="32"
                       Padding="12,0"
                       Style="{StaticResource AccentButtonStyle}"
                       Command="{Binding FindAllCommand}"
                       IsEnabled="{Binding CanSearch}"
                       ToolTip="{DynamicResource Search_FindAll_ToolTip}"/>
            </StackPanel>
        </Grid>

        <!-- Results Info (Compact) -->
        <StackPanel Grid.Row="1"
                   Orientation="Horizontal"
                   Margin="8,6,0,0"
                   Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}">

            <TextBlock FontSize="11"
                      Foreground="{DynamicResource ForegroundSecondaryBrush}"
                      VerticalAlignment="Center">
                <Run Text="{Binding ResultCount, Mode=OneWay}"/>
                <Run Text="{DynamicResource Search_Matches}"/>
            </TextBlock>

            <TextBlock Text="•"
                      FontSize="11"
                      Foreground="{DynamicResource ForegroundTertiaryBrush}"
                      Margin="8,0"/>

            <TextBlock Text="{Binding SearchDurationMs, StringFormat={}{0:F1}ms}"
                      FontSize="11"
                      Foreground="{DynamicResource SuccessBrush}"
                      VerticalAlignment="Center"/>

            <TextBlock Text="•"
                      FontSize="11"
                      Foreground="{DynamicResource ForegroundTertiaryBrush}"
                      Margin="8,0"/>

            <TextBlock Text="{Binding SearchSpeedMBps, StringFormat={}{0:F0} MB/s}"
                      FontSize="11"
                      Foreground="{DynamicResource InfoBrush}"
                      VerticalAlignment="Center"/>

            <Border Background="{DynamicResource SuccessBrush}"
                   CornerRadius="2"
                   Padding="4,2"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center">
                <TextBlock Text="V2"
                          FontSize="9"
                          FontWeight="Bold"
                          Foreground="#FFFFFF"/>
            </Border>
        </StackPanel>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="0"
                    Height="1"
                    VerticalAlignment="Bottom"
                    IsIndeterminate="True"
                    Foreground="{DynamicResource AccentBrush}"
                    Background="Transparent"
                    BorderThickness="0"
                    Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</UserControl>

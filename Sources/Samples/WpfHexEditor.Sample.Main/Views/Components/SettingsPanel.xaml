<UserControl x:Class="WpfHexEditor.Sample.Main.Views.Components.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexEditor.Sample.Main.Views.Components"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">

    <UserControl.Resources>
        <local:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <local:ThemeConverter x:Key="ThemeConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20">
        <StackPanel>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="⚙️" FontSize="28" Margin="0,0,12,0"/>
                <TextBlock Text="SETTINGS"
                          FontSize="22"
                          FontWeight="Bold"
                          Foreground="{StaticResource ForegroundBrush}"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Theme Section -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🎨 Theme"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="{StaticResource ForegroundBrush}"
                              Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding AvailableThemes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton GroupName="Theme"
                                           Command="{Binding DataContext.SelectThemeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           CommandParameter="{Binding Name}"
                                           Margin="0,0,0,8">
                                    <RadioButton.IsChecked>
                                        <MultiBinding Converter="{StaticResource ThemeConverter}" Mode="OneWay">
                                            <Binding Path="Name"/>
                                            <Binding Path="DataContext.SelectedTheme" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                        </MultiBinding>
                                    </RadioButton.IsChecked>
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="ThemeBorder"
                                                   Background="{StaticResource SurfaceBrush}"
                                                   BorderBrush="{StaticResource BorderBrush}"
                                                   BorderThickness="2"
                                                   CornerRadius="8"
                                                   Padding="16,12"
                                                   Cursor="Hand">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                             FontSize="14"
                                                             FontWeight="SemiBold"
                                                             Foreground="{StaticResource ForegroundBrush}"/>
                                                    <TextBlock Text="{Binding Description}"
                                                             FontSize="11"
                                                             Foreground="{StaticResource ForegroundSecondaryBrush}"
                                                             Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ThemeBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    <Setter TargetName="ThemeBorder" Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThemeBorder" Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Language Section -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🌐 Language"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="{StaticResource ForegroundBrush}"
                              Margin="0,0,0,12"/>

                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                             SelectedValue="{Binding SelectedLanguage}"
                             SelectedValuePath="Code"
                             DisplayMemberPath="DisplayName"
                             Height="40"
                             FontSize="14"
                             Background="{StaticResource SurfaceElevatedBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}"/>
                </StackPanel>
            </Border>

            <!-- Search Options Section -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🔍 Search Options"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="{StaticResource ForegroundBrush}"
                              Margin="0,0,0,12"/>

                    <CheckBox Content="Enable parallel search (faster for large files)"
                             IsChecked="{Binding EnableParallelSearch}"
                             Foreground="{StaticResource ForegroundBrush}"
                             Margin="0,0,0,8"/>

                    <CheckBox Content="Use wildcard search (?? notation)"
                             IsChecked="{Binding UseWildcardSearch}"
                             Foreground="{StaticResource ForegroundBrush}"
                             Margin="0,0,0,8"/>

                    <CheckBox Content="Highlight all matches"
                             IsChecked="{Binding HighlightAllMatches}"
                             Foreground="{StaticResource ForegroundBrush}"
                             Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Search result limit:"
                                  FontSize="12"
                                  Foreground="{StaticResource ForegroundSecondaryBrush}"
                                  Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0"
                                   Minimum="100"
                                   Maximum="100000"
                                   Value="{Binding SearchResultLimit}"
                                   TickFrequency="1000"
                                   IsSnapToTickEnabled="True"
                                   VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                      Text="{Binding SearchResultLimit}"
                                      FontSize="14"
                                      FontWeight="Bold"
                                      Foreground="{StaticResource AccentBrush}"
                                      Margin="12,0,0,0"
                                      MinWidth="60"
                                      TextAlignment="Right"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Display Options Section -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="📺 Display Options"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="{StaticResource ForegroundBrush}"
                              Margin="0,0,0,12"/>

                    <CheckBox Content="Show line numbers"
                             IsChecked="{Binding ShowLineNumbers}"
                             Foreground="{StaticResource ForegroundBrush}"
                             Margin="0,0,0,8"/>

                    <CheckBox Content="Show scroll markers"
                             IsChecked="{Binding ShowScrollMarkers}"
                             Foreground="{StaticResource ForegroundBrush}"
                             Margin="0,0,0,8"/>

                    <CheckBox Content="Show status bar"
                             IsChecked="{Binding ShowStatusBar}"
                             Foreground="{StaticResource ForegroundBrush}"
                             Margin="0,0,0,12"/>

                    <StackPanel>
                        <TextBlock Text="Bytes per line:"
                                  FontSize="12"
                                  Foreground="{StaticResource ForegroundSecondaryBrush}"
                                  Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <RadioButton Content="8" IsChecked="{Binding BytesPerLine, Converter={StaticResource IntToBoolConverter}, ConverterParameter=8}" Margin="0,0,12,0"/>
                            <RadioButton Content="16" IsChecked="{Binding BytesPerLine, Converter={StaticResource IntToBoolConverter}, ConverterParameter=16}" Margin="0,0,12,0"/>
                            <RadioButton Content="32" IsChecked="{Binding BytesPerLine, Converter={StaticResource IntToBoolConverter}, ConverterParameter=32}" Margin="0,0,12,0"/>
                            <RadioButton Content="64" IsChecked="{Binding BytesPerLine, Converter={StaticResource IntToBoolConverter}, ConverterParameter=64}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Performance Info Section -->
            <Border Style="{StaticResource GlassPanelStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="⚡ Performance"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="{StaticResource ForegroundBrush}"
                              Margin="0,0,0,12"/>

                    <Border Background="{StaticResource AccentBrush}"
                           CornerRadius="8"
                           Padding="12,8"
                           Margin="0,0,0,8">
                        <TextBlock Text="V2 ENGINE ACTIVE"
                                  FontSize="12"
                                  FontWeight="Bold"
                                  Foreground="#000000"
                                  HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="• Boyer-Moore-Horspool algorithm"
                              FontSize="11"
                              Foreground="{StaticResource ForegroundSecondaryBrush}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="• Parallel processing support"
                              FontSize="11"
                              Foreground="{StaticResource ForegroundSecondaryBrush}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="• Up to 99% faster than V1"
                              FontSize="11"
                              Foreground="{StaticResource ForegroundSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                       Content="Reset to Defaults"
                       Command="{Binding ResetToDefaultsCommand}"
                       Style="{StaticResource ModernButtonStyle}"
                       Margin="0,0,8,0"/>

                <Button Grid.Column="1"
                       Content="Save Settings"
                       Command="{Binding SaveSettingsCommand}"
                       Style="{StaticResource AccentButtonStyle}"
                       Margin="8,0,0,0"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

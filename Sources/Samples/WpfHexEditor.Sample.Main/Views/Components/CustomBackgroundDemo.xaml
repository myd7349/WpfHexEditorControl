<UserControl x:Class="WpfHexEditor.Sample.Main.Views.Components.CustomBackgroundDemo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}"
                Padding="12,8" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <TextBlock Text="Custom Background Blocks Demo"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="White"/>
        </Border>

        <!-- Quick Actions -->
        <StackPanel Grid.Row="1" Margin="8">
            <TextBlock Text="Quick Actions:" FontWeight="Bold" FontSize="13" Margin="4,8,4,4"/>

            <UniformGrid Columns="2">
                <Button Content="🔴 Add Red (0-16)" Click="AddRedBlock_Click"
                        ToolTip="Add a red block at bytes 0-16 (file header)"/>
                <Button Content="🔵 Add Blue (16-32)" Click="AddBlueBlock_Click"
                        ToolTip="Add a blue block at bytes 16-32"/>
            </UniformGrid>

            <UniformGrid Columns="2">
                <Button Content="🟢 Add Green (32-64)" Click="AddGreenBlock_Click"
                        ToolTip="Add a green block at bytes 32-64"/>
                <Button Content="🟡 Add Yellow (64-128)" Click="AddYellowBlock_Click"
                        ToolTip="Add a yellow block at bytes 64-128"/>
            </UniformGrid>

            <Separator Margin="4,8"/>

            <TextBlock Text="Advanced:" FontWeight="Bold" FontSize="13" Margin="4,4"/>

            <Button Content="🎲 Add Random Block" Click="AddRandomBlock_Click"
                    ToolTip="Add a random block at a random position"/>

            <Button Content="🔍 Detect File Format" Click="DetectFormat_Click"
                    ToolTip="Auto-detect common file signatures (ZIP, PNG, PDF, etc.)"/>

            <Separator Margin="4,8"/>

            <Button Content="🗑️ Clear All Blocks" Click="ClearBlocks_Click"
                    Background="#D32F2F" Foreground="White"
                    ToolTip="Remove all custom background blocks"/>
        </StackPanel>

        <!-- Block List -->
        <Border Grid.Row="2" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                Margin="8,0,8,8" Background="{DynamicResource BackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Active Blocks:" FontWeight="Bold" FontSize="13"
                           Margin="8,8,8,4" Grid.Row="0"/>

                <ListBox x:Name="BlocksListBox" Grid.Row="1"
                         Margin="4" BorderThickness="0"
                         SelectionMode="Single"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,4" Margin="2"
                                    Background="{Binding BackgroundBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayText}"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="10"
                                                   Opacity="0.7"
                                                   Margin="0,2,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="❌"
                                            Width="24" Height="24"
                                            Padding="0" Margin="4,0,0,0"
                                            ToolTip="Remove this block"
                                            Tag="{Binding Block}"
                                            Click="RemoveBlock_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{DynamicResource AccentBrush}"
                Padding="8,4" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderBrush}">
            <TextBlock x:Name="StatusTextBlock"
                       Text="Ready. Add blocks to highlight byte ranges."
                       Foreground="White" FontSize="11"/>
        </Border>
    </Grid>
</UserControl>

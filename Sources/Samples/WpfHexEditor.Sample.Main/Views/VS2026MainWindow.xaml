<Window x:Class="WpfHexEditor.Sample.Main.Views.VS2026MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfHexEditor.Sample.Main.Views"
        xmlns:hexEditor="clr-namespace:WpfHexaEditor;assembly=WPFHexaEditor"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E27">

    <Window.InputBindings>
        <!-- Keyboard shortcuts -->
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding ToggleSearchPanelCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="OemComma" Modifiers="Control" Command="{Binding ToggleSettingsPanelCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Command Bar -->
            <RowDefinition Height="*"/>     <!-- Main Content -->
            <RowDefinition Height="Auto"/>  <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Floating Command Bar (Minimal styling) -->
        <Border Grid.Row="0"
                Background="#252842"
                CornerRadius="16"
                Padding="16"
                Margin="16,12,16,8"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="8" Opacity="0.5"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- File Group -->
                <Button Content="📄" ToolTip="New File (Ctrl+N)"
                        Command="{Binding NewFileCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="White"
                        Padding="12,6" FontSize="18" Cursor="Hand"/>
                <Button Content="📁" ToolTip="Open File (Ctrl+O)"
                        Command="{Binding OpenFileCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="White"
                        Padding="12,6" FontSize="18" Cursor="Hand"/>
                <Button Content="💾" ToolTip="Save File (Ctrl+S)"
                        Command="{Binding SaveFileCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="White"
                        Padding="12,6" FontSize="18" Cursor="Hand"/>

                <Separator Width="1" Margin="8,4" Background="#60FFFFFF"/>

                <!-- Edit Group -->
                <Button Content="↩️" ToolTip="Undo (Ctrl+Z)"
                        Command="{Binding UndoCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="White"
                        Padding="12,6" FontSize="18" Cursor="Hand"/>
                <Button Content="↪️" ToolTip="Redo (Ctrl+Y)"
                        Command="{Binding RedoCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="White"
                        Padding="12,6" FontSize="18" Cursor="Hand"/>

                <Separator Width="1" Margin="8,4" Background="#60FFFFFF"/>

                <!-- Search Box -->
                <TextBox x:Name="SearchBox" Width="250"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="#1A1D35" Foreground="White" BorderBrush="#60FFFFFF"
                         BorderThickness="1" Padding="12,8" FontSize="14"
                         ToolTip="Quick search in file"/>

                <Separator Width="1" Margin="8,4" Background="#60FFFFFF"/>

                <!-- Right Side -->
                <Button Content="⚙️" ToolTip="Settings (Ctrl+,)"
                        Command="{Binding ToggleSettingsPanelCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="White"
                        Padding="12,6" FontSize="18" Cursor="Hand"/>
                <Button Content="🎨" ToolTip="Theme"
                        Command="{Binding ToggleThemeCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="White"
                        Padding="12,6" FontSize="18" Cursor="Hand"/>
                <Button Content="🌐" ToolTip="Language"
                        Command="{Binding ToggleLanguageCommand}"
                        Background="Transparent" BorderThickness="0" Foreground="White"
                        Padding="12,6" FontSize="18" Cursor="Hand"/>

            </StackPanel>
        </Border>

        <!-- Main Content (No sidebar for now) -->
        <Border Grid.Row="1"
                Background="#1A1D35"
                CornerRadius="12"
                Margin="16,8">

            <hexEditor:HexEditor x:Name="HexEditorControl"
                                Background="#0A0E27"
                                Foreground="White"
                                Margin="4"/>

        </Border>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#1A1D35" Foreground="#B4B9D8"
                   Height="28" Padding="8,0" BorderBrush="#60FFFFFF" BorderThickness="0,1,0,0">
            <StatusBarItem Content="{Binding StatusText}"/>
            <Separator Width="1" Margin="8,4" Background="#60FFFFFF"/>
            <StatusBarItem Content="{Binding PositionText}"/>
            <Separator Width="1" Margin="8,4" Background="#60FFFFFF"/>
            <StatusBarItem Content="{Binding EncodingText}"/>
            <Separator Width="1" Margin="8,4" Background="#60FFFFFF"/>
            <StatusBarItem Content="{Binding FileSizeText}" HorizontalAlignment="Right"/>
        </StatusBar>

    </Grid>

</Window>

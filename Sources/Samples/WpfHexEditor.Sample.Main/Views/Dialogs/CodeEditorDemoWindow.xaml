<Window x:Class="WpfHexEditor.Sample.Main.Views.Dialogs.CodeEditorDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:codeEditor="clr-namespace:WpfHexEditor.Editor.CodeEditor.Controls;assembly=WpfHexEditor.Editor.CodeEditor"
        Title="Code Editor Demo - Settings Panel" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="400" MaxWidth="500"/>
        </Grid.ColumnDefinitions>

        <!-- Code Editor (Left) -->
        <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Code Editor" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto">
                    <codeEditor:CodeEditor x:Name="CodeEditorControl"
                                          ShowLineNumbers="True"
                                          EnableIntelliSense="True"
                                          EnableValidation="True"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- GridSplitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

        <!-- Settings Panel (Right) -->
        <Border Grid.Column="2" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Settings Panel" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                <codeEditor:CodeEditorSettings x:Name="SettingsPanel"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>

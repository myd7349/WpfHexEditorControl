<Application x:Class="WpfHexEditor.Sample.Main.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/ModernMainWindow.xaml">
    <!-- Modern 2026 UI is now active! Change back to "MainWindow.xaml" for legacy UI -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default Theme: Office (Light - Professional) -->
                <ResourceDictionary Source="Resources/Themes/Office.xaml"/>
                <!-- Ribbon Vector Icons -->
                <ResourceDictionary Source="Resources/RibbonIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>

<Application x:Class="WpfHexEditor.Sample.Main.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:WpfHexEditor.Sample.Main.Services"
             xmlns:hexServices="clr-namespace:WpfHexaEditor.Services;assembly=WPFHexaEditor"
             StartupUri="Views/MainWindow.xaml">
    <!-- Modern Main Window (VS 2026 inspired design) -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Dynamic Localization Resources - Updates automatically when culture changes -->
                <services:LocalizedResourceDictionary/>
                <!-- HexEditor Control Localization Resources -->
                <hexServices:LocalizedResourceDictionary/>
                <!-- Office Theme (needed for existing dialogs like Options/Paramètres) -->
                <ResourceDictionary Source="Resources/Themes/Office.xaml"/>
                <!-- Ribbon Vector Icons (Temporary - will be removed when Ribbon is deleted) -->
                <ResourceDictionary Source="Resources/RibbonIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>

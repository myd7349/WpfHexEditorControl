<Window x:Class="WpfHexEditor.Sample.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hex="clr-namespace:WpfHexaEditor;assembly=WPFHexaEditor"
        mc:Ignorable="d"
        Title="HexEditor Sample - Advanced Features Demo"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="A" Modifiers="Control" Command="{Binding SelectAllCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Menu -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- HexEditor -->
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File" SubmenuOpened="Menu_SubmenuOpened">
                <MenuItem Header="_Open..." Click="Open_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save" x:Name="SaveMenuItem" Click="Save_Click" InputGestureText="Ctrl+S" IsEnabled="False"/>
                <MenuItem Header="Save _As..." x:Name="SaveAsMenuItem" Click="SaveAs_Click" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Open (Async)..." x:Name="OpenAsyncMenuItem" Click="OpenAsync_Click" ToolTip="Open file with progress overlay"/>
                <MenuItem Header="Save (Async)" x:Name="SaveAsyncMenuItem" Click="SaveAsync_Click" IsEnabled="False" ToolTip="Save file with progress overlay"/>
                <Separator/>
                <MenuItem Header="_Close" x:Name="CloseMenuItem" Click="Close_Click" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit" SubmenuOpened="Menu_SubmenuOpened">
                <MenuItem Header="_Undo" x:Name="UndoMenuItem" Click="Undo_Click" InputGestureText="Ctrl+Z" IsEnabled="False"/>
                <MenuItem Header="_Redo" x:Name="RedoMenuItem" Click="Redo_Click" InputGestureText="Ctrl+Y" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="_Find..." x:Name="FindMenuItem" Click="Find_Click" InputGestureText="Ctrl+F" IsEnabled="False"/>
                <MenuItem Header="Find and _Replace..." x:Name="ReplaceMenuItem" Click="Replace_Click" InputGestureText="Ctrl+H" IsEnabled="False"/>
                <MenuItem Header="Find All Occurrence of Selection" x:Name="FindAllOccurrenceMenuItem" Click="FindAllOccurrence_Click" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Find All (Async)..." x:Name="FindAllAsyncMenuItem" Click="FindAllAsync_Click" IsEnabled="False" ToolTip="Search with progress overlay and cancellation support"/>
                <MenuItem Header="Replace All (Async)..." x:Name="ReplaceAllAsyncMenuItem" Click="ReplaceAllAsync_Click" IsEnabled="False" ToolTip="Replace with progress overlay"/>
                <Separator/>
                <MenuItem Header="Reverse Selection" x:Name="ReverseSelectionMenuItem" Click="ReverseSelection_Click" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Read Only" x:Name="ReadOnlyMenuItemEdit" IsCheckable="True"
                          Checked="ReadOnly_Changed"
                          Unchecked="ReadOnly_Changed"
                          IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Copy" x:Name="CopyMenuItem" Click="Copy_Click" InputGestureText="Ctrl+C" IsEnabled="False"/>
                <MenuItem Header="Copy as Hexadecimal" x:Name="CopyHexMenuItem" Click="CopyHex_Click" IsEnabled="False"/>
                <MenuItem Header="Copy as ASCII String" x:Name="CopyAsciiMenuItem" Click="CopyAscii_Click" IsEnabled="False"/>
                <MenuItem Header="Delete Selection" x:Name="DeleteSelectionMenuItem" Click="DeleteSelection_Click" InputGestureText="Del" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Select _All" x:Name="SelectAllMenuItem" Click="SelectAll_Click" InputGestureText="Ctrl+A" IsEnabled="False"/>
                <MenuItem Header="_Clear Selection" x:Name="ClearSelectionMenuItem" Click="ClearSelection_Click" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Paste" x:Name="PasteMenuItem" Click="Paste_Click" InputGestureText="Ctrl+V" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="_Bookmarks">
                    <MenuItem Header="Toggle Bookmark" x:Name="ToggleBookmarkMenuItemEdit" Click="ToggleBookmark_Click" InputGestureText="Ctrl+B" IsEnabled="False"/>
                    <MenuItem Header="_Clear All Bookmarks" x:Name="ClearBookmarksMenuItemEdit" Click="ClearBookmarks_Click" IsEnabled="False"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Character Table (TBL)">
                    <MenuItem Header="_Load TBL File..." x:Name="LoadTBLMenuItemEdit" Click="LoadTBL_Click" IsEnabled="False"/>
                    <MenuItem Header="_Close TBL" x:Name="CloseTBLMenuItemEdit" Click="CloseTBL_Click" IsEnabled="False"/>
                    <Separator/>
                    <MenuItem Header="Table Type">
                        <MenuItem Header="ASCII" x:Name="TblAsciiMenuItemEdit" Click="TblType_Click" Tag="0" IsCheckable="True" IsChecked="True"/>
                        <MenuItem Header="EBCDIC (with special chars)" x:Name="TblEbcdicSpecialMenuItemEdit" Click="TblType_Click" Tag="1" IsCheckable="True"/>
                        <MenuItem Header="EBCDIC (no special chars)" x:Name="TblEbcdicNoSpecialMenuItemEdit" Click="TblType_Click" Tag="2" IsCheckable="True"/>
                    </MenuItem>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Search" SubmenuOpened="Menu_SubmenuOpened">
                <MenuItem Header="Find _Next" x:Name="FindNextMenuItem" Click="FindNext_Click" InputGestureText="F3" IsEnabled="False"/>
                <MenuItem Header="Find _Previous" x:Name="FindPreviousMenuItem" Click="FindPrevious_Click" InputGestureText="Shift+F3" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="_Tools" SubmenuOpened="Menu_SubmenuOpened">
                <MenuItem Header="_Byte Operations">
                    <MenuItem Header="_Fill with Byte..." x:Name="FillWithByteMenuItem" Click="FillWithByte_Click" IsEnabled="False"/>
                    <MenuItem Header="_Get Byte at Position..." x:Name="GetByteMenuItem" Click="GetByte_Click" IsEnabled="False"/>
                    <MenuItem Header="_Set Byte at Position..." x:Name="SetByteMenuItem" Click="SetByte_Click" IsEnabled="False"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Bookmarks">
                    <MenuItem Header="Toggle Bookmark" x:Name="ToggleBookmarkMenuItem" Click="ToggleBookmark_Click" InputGestureText="Ctrl+B" IsEnabled="False"/>
                    <MenuItem Header="_Clear All Bookmarks" x:Name="ClearBookmarksMenuItem" Click="ClearBookmarks_Click" IsEnabled="False"/>
                    <Separator/>
                    <MenuItem Header="_Next Bookmark" x:Name="NextBookmarkMenuItem" Click="NextBookmark_Click" InputGestureText="Ctrl+N" IsEnabled="False"/>
                    <MenuItem Header="_Previous Bookmark" x:Name="PreviousBookmarkMenuItem" Click="PreviousBookmark_Click" InputGestureText="Ctrl+P" IsEnabled="False"/>
                    <Separator/>
                    <MenuItem Header="_Show All Bookmarks..." x:Name="ShowBookmarksMenuItem" Click="ShowBookmarks_Click" IsEnabled="False"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Character Table (TBL)">
                    <MenuItem Header="_Load TBL File..." x:Name="LoadTBLMenuItem" Click="LoadTBL_Click" IsEnabled="False"/>
                    <MenuItem Header="_Close TBL" x:Name="CloseTBLMenuItem" Click="CloseTBL_Click" IsEnabled="False"/>
                    <Separator/>
                    <MenuItem Header="Table Type">
                        <MenuItem Header="ASCII" x:Name="TblAsciiMenuItem" Click="TblType_Click" Tag="0" IsCheckable="True" IsChecked="True"/>
                        <MenuItem Header="EBCDIC (with special chars)" x:Name="TblEbcdicSpecialMenuItem" Click="TblType_Click" Tag="1" IsCheckable="True"/>
                        <MenuItem Header="EBCDIC (no special chars)" x:Name="TblEbcdicNoSpecialMenuItem" Click="TblType_Click" Tag="2" IsCheckable="True"/>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="🧪 _Test ByteProvider V2" Click="TestByteProviderV2_Click"/>
            </MenuItem>
            <MenuItem Header="_Position" SubmenuOpened="Menu_SubmenuOpened">
                <MenuItem Header="_Go to Position..." x:Name="GoToPositionMenuItem" Click="GoToPosition_Click" InputGestureText="Ctrl+G" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="_View" SubmenuOpened="Menu_SubmenuOpened">
                <MenuItem Header="_Insert Mode" IsCheckable="True"
                          x:Name="InsertModeMenuItem"
                          Checked="InsertMode_Changed"
                          Unchecked="InsertMode_Changed"
                          IsEnabled="False"/>
                <MenuItem Header="_Read Only" IsCheckable="True"
                          x:Name="ReadOnlyMenuItem"
                          Checked="ReadOnly_Changed"
                          Unchecked="ReadOnly_Changed"
                          IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Display Options">
                    <MenuItem Header="Show Status Bar" IsCheckable="True" x:Name="ShowStatusBarMenuItem"
                              Checked="ShowStatusBar_Changed" Unchecked="ShowStatusBar_Changed" IsChecked="True" IsEnabled="False"/>
                    <MenuItem Header="Show Header" IsCheckable="True" x:Name="ShowHeaderMenuItem"
                              Checked="ShowHeader_Changed" Unchecked="ShowHeader_Changed" IsChecked="True" IsEnabled="False"/>
                    <MenuItem Header="Show Offset" IsCheckable="True" x:Name="ShowOffsetMenuItem"
                              IsChecked="True" IsEnabled="False"
                              ToolTip="Note: Always visible in V2 (XAML limitation)"/>
                    <MenuItem Header="Show ASCII" IsCheckable="True" x:Name="ShowAsciiMenuItem"
                              IsChecked="True" IsEnabled="False"
                              ToolTip="Note: Always visible in V2 (XAML limitation)"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Bytes Per Line">
                    <MenuItem Header="8" x:Name="BytesPerLine8MenuItem" Click="BytesPerLine_Click" Tag="8"/>
                    <MenuItem Header="16" x:Name="BytesPerLine16MenuItem" Click="BytesPerLine_Click" Tag="16" IsChecked="True"/>
                    <MenuItem Header="32" x:Name="BytesPerLine32MenuItem" Click="BytesPerLine_Click" Tag="32"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Colors (V1 Compatible)">
                    <MenuItem Header="🎨 Change Selection Color..." Click="ChangeSelectionColor_Click"/>
                    <MenuItem Header="🟧 Change Modified Color..." Click="ChangeModifiedColor_Click"/>
                    <MenuItem Header="🟩 Change Added Color..." Click="ChangeAddedColor_Click"/>
                    <MenuItem Header="🟥 Change Deleted Color..." Click="ChangeDeletedColor_Click"/>
                    <MenuItem Header="🔵 Change Alternate Byte Color..." Click="ChangeAlternateColor_Click"/>
                    <Separator/>
                    <MenuItem Header="↩️ Reset to Defaults" Click="ResetColors_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="Context Menu" IsCheckable="True" x:Name="AllowContextMenuOption"
                          IsChecked="True" IsEnabled="False"
                          ToolTip="Enable or disable right-click context menu"/>
                <MenuItem Header="Show Byte ToolTip" IsCheckable="True" x:Name="ShowByteToolTipOption"
                          IsChecked="False" IsEnabled="False"
                          ToolTip="Show tooltip with byte information on hover"/>
                <Separator/>
                <MenuItem Header="Auto-Highlight Selection Byte" IsCheckable="True" x:Name="AutoHighlightOption"
                          IsChecked="False" IsEnabled="False"
                          ToolTip="Automatically highlight all bytes with same value as selected byte"/>
                <MenuItem Header="Count Selected Bytes" IsCheckable="True" x:Name="ByteCountOption"
                          IsChecked="False" IsEnabled="False"
                          ToolTip="Count occurrences of selected byte value"/>
                <Separator/>
                <MenuItem Header="File Operations">
                    <MenuItem Header="Allow File Drop" IsCheckable="True" x:Name="AllowFileDropOption"
                              IsChecked="True" IsEnabled="False"
                              ToolTip="Allow dragging files onto the editor"/>
                    <MenuItem Header="File Drop Confirmation" IsCheckable="True" x:Name="FileDropConfirmOption"
                              IsChecked="True" IsEnabled="False"
                              ToolTip="Require confirmation before opening dropped file"/>
                    <MenuItem Header="Allow Text Drop" IsCheckable="True" x:Name="AllowTextDropOption"
                              IsChecked="True" IsEnabled="False"
                              ToolTip="Allow dragging text onto the editor"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Allow Zoom" IsCheckable="True" x:Name="AllowZoomOption"
                          IsChecked="True" IsEnabled="False"
                          ToolTip="Enable zoom with Ctrl+MouseWheel"/>
                <MenuItem Header="Zoom Level">
                    <MenuItem Header="Reset Zoom (100%)" Click="ResetZoom_Click" IsEnabled="False"/>
                    <Separator/>
                    <StackPanel Orientation="Horizontal" Margin="10,5">
                        <Label Content="50%" Width="40"/>
                        <Slider x:Name="ZoomSlider" Width="200" Minimum="0.5" Maximum="2.0"
                                Value="1.0" LargeChange="0.1"
                                ToolTip="Zoom: 50% to 200%"
                                IsEnabled="False"/>
                        <Label Content="200%" Width="40" Margin="5,0,0,0"/>
                    </StackPanel>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Mouse Wheel Scroll Speed" IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Margin="10,5">
                        <Label Content="Speed:" Width="60"/>
                        <Slider x:Name="ScrollSpeedSlider" Width="200" Minimum="1" Maximum="10"
                                Value="3" TickFrequency="1" IsSnapToTickEnabled="True"
                                ToolTip="Lines per wheel notch"/>
                        <Label x:Name="ScrollSpeedLabel" Content="3" Width="30" Margin="5,0,0,0"/>
                    </StackPanel>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click"/>
                <MenuItem Header="_Keyboard Shortcuts" Click="KeyboardShortcuts_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar Grid.Row="1">
            <Button x:Name="OpenButton" Click="Open_Click" ToolTip="Open file (Ctrl+O)">
                <TextBlock Text="📂 Open" FontSize="12"/>
            </Button>
            <Button x:Name="SaveButton" Click="Save_Click" ToolTip="Save file (Ctrl+S)" IsEnabled="False">
                <TextBlock Text="💾 Save" FontSize="12"/>
            </Button>
            <Separator/>
            <Button x:Name="UndoButton" Click="Undo_Click" ToolTip="Undo (Ctrl+Z)" IsEnabled="False">
                <TextBlock Text="↶ Undo" FontSize="12"/>
            </Button>
            <Button x:Name="RedoButton" Click="Redo_Click" ToolTip="Redo (Ctrl+Y)" IsEnabled="False">
                <TextBlock Text="↷ Redo" FontSize="12"/>
            </Button>
            <Separator/>
            <ToggleButton x:Name="InsertModeToggle" ToolTip="Toggle Insert/Overwrite mode (Insert key)"
                          Checked="InsertModeToggle_Changed" Unchecked="InsertModeToggle_Changed" IsEnabled="False">
                <TextBlock Text="INS" FontSize="12" FontWeight="Bold"/>
            </ToggleButton>
            <ToggleButton x:Name="ReadOnlyToggle" ToolTip="Toggle Read-Only mode"
                          Checked="ReadOnlyToggle_Changed" Unchecked="ReadOnlyToggle_Changed" IsEnabled="False">
                <TextBlock Text="🔒 RO" FontSize="12"/>
            </ToggleButton>
        </ToolBar>

        <!-- HexEditor Control (V2 Architecture) -->
        <hex:HexEditor x:Name="HexEditor" Grid.Row="2"
                        AllowContextMenu="{Binding IsChecked, ElementName=AllowContextMenuOption}"
                        ShowByteToolTip="{Binding IsChecked, ElementName=ShowByteToolTipOption}"
                        AllowAutoHighLightSelectionByte="{Binding IsChecked, ElementName=AutoHighlightOption}"
                        AllowAutoSelectSameByteAtDoubleClick="True"
                        AllowByteCount="{Binding IsChecked, ElementName=ByteCountOption}"
                        FileDroppingConfirmation="{Binding IsChecked, ElementName=FileDropConfirmOption}"
                        AllowTextDrop="{Binding IsChecked, ElementName=AllowTextDropOption}"
                        AllowFileDrop="{Binding IsChecked, ElementName=AllowFileDropOption}"
                        HideByteDeleted="False"
                        AllowDeleteByte="True"
                        AppendNeedConfirmation="True"
                        AllowExtend="False"
                        AllowZoom="{Binding IsChecked, ElementName=AllowZoomOption}"/>
    </Grid>
</Window>

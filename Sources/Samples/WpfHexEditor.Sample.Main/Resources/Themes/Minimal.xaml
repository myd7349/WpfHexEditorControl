<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== COLOR PALETTE ==================== -->

    <!-- Background Colors (Monochrome Minimal) -->
    <Color x:Key="BackgroundColor">#FAFAFA</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceElevatedColor">#FFFFFF</Color>
    <Color x:Key="OverlayColor">#40000000</Color>

    <!-- Foreground Colors (Monochrome) -->
    <Color x:Key="ForegroundColor">#000000</Color>
    <Color x:Key="ForegroundSecondaryColor">#666666</Color>
    <Color x:Key="ForegroundTertiaryColor">#999999</Color>

    <!-- Accent Colors (Pure Black) -->
    <Color x:Key="AccentColor">#000000</Color>
    <Color x:Key="AccentHoverColor">#333333</Color>
    <Color x:Key="AccentPressedColor">#111111</Color>
    <Color x:Key="AccentSecondaryColor">#444444</Color>

    <!-- Semantic Colors (Minimal) -->
    <Color x:Key="SuccessColor">#000000</Color>
    <Color x:Key="WarningColor">#666666</Color>
    <Color x:Key="ErrorColor">#000000</Color>
    <Color x:Key="InfoColor">#444444</Color>

    <!-- Border & Divider (Subtle) -->
    <Color x:Key="BorderColor">#E0E0E0</Color>
    <Color x:Key="DividerColor">#F0F0F0</Color>

    <!-- Hover & Press States -->
    <Color x:Key="HoverColor">#F5F5F5</Color>
    <Color x:Key="PressedColor">#E8E8E8</Color>
    <Color x:Key="SelectedColor">#E0E0E0</Color>

    <!-- ==================== HEXEDITOR COLORS ==================== -->

    <!-- HexEditor Control Colors for Minimal Theme (Monochrome) -->
    <Color x:Key="HexEditor_SelectionFirstColor">#66000000</Color>         <!-- Black with 40% opacity -->
    <Color x:Key="HexEditor_SelectionSecondColor">#66000000</Color>        <!-- Black with 40% opacity -->
    <Color x:Key="HexEditor_ByteModifiedColor">#666666</Color>             <!-- Medium Gray -->
    <Color x:Key="HexEditor_ByteDeletedColor">#000000</Color>              <!-- Black -->
    <Color x:Key="HexEditor_ByteAddedColor">#444444</Color>                <!-- Dark Gray -->
    <Color x:Key="HexEditor_HighLightColor">#999999</Color>                <!-- Light Gray -->
    <Color x:Key="HexEditor_MouseOverColor">#F0F0F0</Color>                <!-- Very Light Gray -->
    <Color x:Key="HexEditor_ForegroundSecondColor">#444444</Color>         <!-- Dark Gray -->
    <Color x:Key="HexEditor_ForegroundOffSetHeaderColor">#666666</Color>   <!-- Medium Gray -->
    <Color x:Key="HexEditor_ForegroundHighLightOffSetHeaderColor">#000000</Color> <!-- Black -->
    <Color x:Key="HexEditor_ForegroundContrast">#FFFFFF</Color>            <!-- White -->
    <Color x:Key="HexEditor_AutoHighLiteSelectionByteBrush">#CCCCCC</Color> <!-- Light Gray -->
    <Color x:Key="HexEditor_TblDteColor">#000000</Color>                   <!-- Black -->
    <Color x:Key="HexEditor_TblMteColor">#444444</Color>                   <!-- Dark Gray -->
    <Color x:Key="HexEditor_TblEndBlockColor">#666666</Color>              <!-- Medium Gray -->
    <Color x:Key="HexEditor_TblEndLineColor">#888888</Color>               <!-- Gray -->

    <!-- ==================== BRUSHES ==================== -->

    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{DynamicResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="{DynamicResource ForegroundColor}"/>
    <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="{DynamicResource ForegroundSecondaryColor}"/>
    <SolidColorBrush x:Key="ForegroundTertiaryBrush" Color="{DynamicResource ForegroundTertiaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}"/>

    <!-- Semantic Color Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}"/>

    <!-- Minimal Glass Brush -->
    <SolidColorBrush x:Key="GlassBrush" Color="#10000000" Opacity="0.02"/>

    <!-- ==================== EFFECTS ==================== -->

    <!-- No shadows in minimal theme -->
    <DropShadowEffect x:Key="SubtleShadow"
                      Color="Transparent"
                      ShadowDepth="0"
                      BlurRadius="0"
                      Opacity="0"/>

    <DropShadowEffect x:Key="AccentGlow"
                      Color="Transparent"
                      ShadowDepth="0"
                      BlurRadius="0"
                      Opacity="0"/>

    <!-- ==================== MODERN BUTTON STYLE ==================== -->

    <Style x:Key="ModernButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource HoverColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource PressedColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.3"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent Button (Primary Action) -->
    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ==================== MODERN TEXTBOX STYLE ==================== -->

    <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="4,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionOpacity" Value="0.3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0">
                        <ScrollViewer x:Name="PART_ContentHost"
                                     Margin="{TemplateBinding Padding}"
                                     VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="0,0,0,2"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource ForegroundSecondaryColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== GLASS PANEL STYLE ==================== -->

    <Style x:Key="GlassPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="24"/>
    </Style>

    <!-- ==================== MODERN TOGGLE BUTTON ==================== -->

    <Style x:Key="ModernToggleButtonStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource HoverColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== MENU & TOOLBAR STYLES ==================== -->

    <!-- Default Menu Style -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- Default MenuItem Style -->
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <!-- Default ToolBar Style -->
    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- Default Button Style (for toolbar buttons) -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="2"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PressedColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

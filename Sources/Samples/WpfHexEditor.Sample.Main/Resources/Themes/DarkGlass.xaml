<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== COLOR PALETTE ==================== -->

    <!-- Background Colors (Dark Glass) -->
    <Color x:Key="BackgroundColor">#1A1A1A</Color>
    <Color x:Key="SurfaceColor">#252525</Color>
    <Color x:Key="SurfaceElevatedColor">#2E2E2E</Color>
    <Color x:Key="OverlayColor">#80000000</Color>  <!-- Semi-transparent for glass effect -->

    <!-- Foreground Colors -->
    <Color x:Key="ForegroundColor">#FFFFFF</Color>
    <Color x:Key="ForegroundSecondaryColor">#B0B0B0</Color>
    <Color x:Key="ForegroundTertiaryColor">#808080</Color>

    <!-- Accent Colors (Cyan/Teal - Modern 2026) -->
    <Color x:Key="AccentColor">#00D9FF</Color>
    <Color x:Key="AccentHoverColor">#33E0FF</Color>
    <Color x:Key="AccentPressedColor">#00B8D9</Color>
    <Color x:Key="AccentSecondaryColor">#0099CC</Color>

    <!-- Semantic Colors -->
    <Color x:Key="SuccessColor">#00E676</Color>
    <Color x:Key="WarningColor">#FFD600</Color>
    <Color x:Key="ErrorColor">#FF5252</Color>
    <Color x:Key="InfoColor">#40C4FF</Color>

    <!-- Border & Divider -->
    <Color x:Key="BorderColor">#3F3F3F</Color>
    <Color x:Key="DividerColor">#2E2E2E</Color>

    <!-- Hover & Press States -->
    <Color x:Key="HoverColor">#333333</Color>
    <Color x:Key="PressedColor">#404040</Color>
    <Color x:Key="SelectedColor">#1A4D5C</Color>

    <!-- ==================== HEXEDITOR COLORS ==================== -->

    <!-- HexEditor Control Colors for Dark Glass Theme -->
    <Color x:Key="HexEditor_SelectionFirstColor">#6600D9FF</Color>         <!-- Cyan with 40% opacity -->
    <Color x:Key="HexEditor_SelectionSecondColor">#6600D9FF</Color>        <!-- Cyan with 40% opacity -->
    <Color x:Key="HexEditor_ByteModifiedColor">#FFD600</Color>             <!-- Yellow -->
    <Color x:Key="HexEditor_HighLightColor">#FFD700</Color>                <!-- Gold -->
    <!-- MouseOverColor removed - controlled by HexEditor DP default -->
    <Color x:Key="HexEditor_ForegroundSecondColor">#40C4FF</Color>         <!-- Light Blue -->
    <Color x:Key="HexEditor_ForegroundOffSetHeaderColor">#B0B0B0</Color>   <!-- Light Gray -->
    <Color x:Key="HexEditor_ForegroundHighLightOffSetHeaderColor">#00D9FF</Color> <!-- Bright Cyan -->
    <Color x:Key="HexEditor_ForegroundContrast">#FFFFFF</Color>            <!-- White -->
    <Color x:Key="HexEditor_AutoHighLiteSelectionByteBrush">#0099CC</Color> <!-- Medium Cyan -->
    <Color x:Key="HexEditor_TblDteColor">#FF5252</Color>                   <!-- Red -->
    <Color x:Key="HexEditor_TblMteColor">#00E676</Color>                   <!-- Green -->
    <Color x:Key="HexEditor_TblEndBlockColor">#FFD600</Color>              <!-- Yellow -->
    <Color x:Key="HexEditor_TblEndLineColor">#FFD600</Color>               <!-- Yellow -->

    <!-- ==================== BRUSHES ==================== -->

    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{DynamicResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="{DynamicResource ForegroundColor}"/>
    <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="{DynamicResource ForegroundSecondaryColor}"/>
    <SolidColorBrush x:Key="ForegroundTertiaryBrush" Color="{DynamicResource ForegroundTertiaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}"/>

    <!-- Semantic Color Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}"/>

    <!-- Glassmorphism Effect Brush -->
    <SolidColorBrush x:Key="GlassBrush" Color="#40FFFFFF" Opacity="0.05"/>

    <!-- ==================== EFFECTS ==================== -->

    <!-- Blur Effect for Glassmorphism -->
    <BlurEffect x:Key="GlassBlur" Radius="20"/>

    <!-- Glow Effect for Accent Elements -->
    <DropShadowEffect x:Key="AccentGlow"
                      Color="{DynamicResource AccentColor}"
                      ShadowDepth="0"
                      BlurRadius="16"
                      Opacity="0.6"/>

    <!-- Subtle Shadow -->
    <DropShadowEffect x:Key="SubtleShadow"
                      Color="#000000"
                      ShadowDepth="2"
                      BlurRadius="8"
                      Opacity="0.3"/>

    <!-- ==================== MODERN BUTTON STYLE ==================== -->

    <Style x:Key="ModernButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect" Value="{StaticResource SubtleShadow}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource HoverColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource PressedColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent Button (Primary Action) -->
    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="#000000"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Effect" Value="{StaticResource AccentGlow}"/>
    </Style>

    <!-- ==================== MODERN TEXTBOX STYLE ==================== -->

    <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionOpacity" Value="0.4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost"
                                     Margin="{TemplateBinding Padding}"
                                     VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="border" Property="Effect" Value="{StaticResource AccentGlow}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource ForegroundSecondaryColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== GLASS PANEL STYLE ==================== -->

    <Style x:Key="GlassPanelStyle" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource SurfaceColor}" Opacity="0.7"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{StaticResource GlassBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{StaticResource SubtleShadow}"/>
    </Style>

    <!-- ==================== MODERN SCROLLBAR ==================== -->

    <Style x:Key="ModernScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Background="{StaticResource ForegroundSecondaryBrush}"
                                                   CornerRadius="4"
                                                   Opacity="0.5"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== MODERN TOGGLE BUTTON ==================== -->

    <Style x:Key="ModernToggleButtonStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="#000000"/>
                            <Setter TargetName="border" Property="Effect" Value="{StaticResource AccentGlow}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource HoverColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== MENU & TOOLBAR STYLES ==================== -->

    <!-- Default Menu Style -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- Default MenuItem Style -->
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <!-- Default ToolBar Style -->
    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- Default Button Style (for toolbar buttons) -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="2"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PressedColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== COLOR PALETTE ==================== -->

    <!-- Background Colors (VS Dark Professional) -->
    <Color x:Key="BackgroundColor">#1E1E1E</Color>
    <Color x:Key="SurfaceColor">#252526</Color>
    <Color x:Key="SurfaceElevatedColor">#2D2D30</Color>
    <Color x:Key="OverlayColor">#3F3F46</Color>

    <!-- Foreground Colors -->
    <Color x:Key="ForegroundColor">#FFFFFF</Color>
    <Color x:Key="ForegroundSecondaryColor">#CCCCCC</Color>
    <Color x:Key="ForegroundTertiaryColor">#999999</Color>

    <!-- Accent Colors (VS Blue) -->
    <Color x:Key="AccentColor">#007ACC</Color>
    <Color x:Key="AccentHoverColor">#1C97EA</Color>
    <Color x:Key="AccentPressedColor">#005A9E</Color>
    <Color x:Key="AccentSecondaryColor">#0E639C</Color>

    <!-- Semantic Colors (Professional) -->
    <Color x:Key="SuccessColor">#4EC9B0</Color>
    <Color x:Key="WarningColor">#FFCC00</Color>
    <Color x:Key="ErrorColor">#F48771</Color>
    <Color x:Key="InfoColor">#007ACC</Color>

    <!-- Border & Divider -->
    <Color x:Key="BorderColor">#3F3F46</Color>
    <Color x:Key="DividerColor">#2D2D30</Color>

    <!-- Hover & Press States -->
    <Color x:Key="HoverColor">#3E3E40</Color>
    <Color x:Key="PressedColor">#007ACC</Color>
    <Color x:Key="SelectedColor">#094771</Color>

    <!-- ==================== HEXEDITOR COLORS ==================== -->

    <!-- HexEditor Control Colors for Visual Studio Theme -->
    <Color x:Key="HexEditor_SelectionFirstColor">#66007ACC</Color>         <!-- VS Blue with 40% opacity -->
    <Color x:Key="HexEditor_SelectionSecondColor">#66007ACC</Color>        <!-- VS Blue with 40% opacity -->
    <Color x:Key="HexEditor_ByteModifiedColor">#FFCC00</Color>             <!-- Yellow -->
    <Color x:Key="HexEditor_ByteDeletedColor">#F48771</Color>              <!-- Salmon Red -->
    <Color x:Key="HexEditor_ByteAddedColor">#4EC9B0</Color>                <!-- Teal Green -->
    <Color x:Key="HexEditor_HighLightColor">#FFCC00</Color>                <!-- Yellow -->
    <Color x:Key="HexEditor_MouseOverColor">#094771</Color>                <!-- Dark Blue -->
    <Color x:Key="HexEditor_ForegroundSecondColor">#1C97EA</Color>         <!-- Light Blue -->
    <Color x:Key="HexEditor_ForegroundOffSetHeaderColor">#CCCCCC</Color>   <!-- Light Gray -->
    <Color x:Key="HexEditor_ForegroundHighLightOffSetHeaderColor">#1C97EA</Color> <!-- Bright Blue -->
    <Color x:Key="HexEditor_ForegroundContrast">#FFFFFF</Color>            <!-- White -->
    <Color x:Key="HexEditor_AutoHighLiteSelectionByteBrush">#007ACC</Color> <!-- VS Blue -->
    <Color x:Key="HexEditor_TblDteColor">#F48771</Color>                   <!-- Salmon Red -->
    <Color x:Key="HexEditor_TblMteColor">#4EC9B0</Color>                   <!-- Teal Green -->
    <Color x:Key="HexEditor_TblEndBlockColor">#FFCC00</Color>              <!-- Yellow -->
    <Color x:Key="HexEditor_TblEndLineColor">#FFCC00</Color>               <!-- Yellow -->

    <!-- ==================== BRUSHES ==================== -->

    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{DynamicResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="{DynamicResource ForegroundColor}"/>
    <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="{DynamicResource ForegroundSecondaryColor}"/>
    <SolidColorBrush x:Key="ForegroundTertiaryBrush" Color="{DynamicResource ForegroundTertiaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}"/>

    <!-- Semantic Color Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}"/>

    <!-- Glass Brush (Very Subtle) -->
    <SolidColorBrush x:Key="GlassBrush" Color="Transparent"/>

    <!-- ==================== EFFECTS ==================== -->

    <!-- No effects - Clean and professional -->
    <DropShadowEffect x:Key="SubtleShadow"
                      Color="Transparent"
                      ShadowDepth="0"
                      BlurRadius="0"
                      Opacity="0"/>

    <DropShadowEffect x:Key="AccentGlow"
                      Color="Transparent"
                      ShadowDepth="0"
                      BlurRadius="0"
                      Opacity="0"/>

    <!-- ==================== MODERN BUTTON STYLE ==================== -->

    <Style x:Key="ModernButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource HoverColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource PressedColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent Button (Primary Action) -->
    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>

    <!-- ==================== MODERN TEXTBOX STYLE ==================== -->

    <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="CaretBrush" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionOpacity" Value="0.4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0">
                        <ScrollViewer x:Name="PART_ContentHost"
                                     Margin="{TemplateBinding Padding}"
                                     VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource SurfaceElevatedColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== GLASS PANEL STYLE ==================== -->

    <Style x:Key="GlassPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- ==================== MODERN TOGGLE BUTTON ==================== -->

    <Style x:Key="ModernToggleButtonStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource HoverColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== MENU & TOOLBAR STYLES ==================== -->

    <!-- Default Menu Style -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- Default MenuItem Style -->
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <!-- Default ToolBar Style -->
    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- Default Button Style (for toolbar buttons) -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="2"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PressedColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

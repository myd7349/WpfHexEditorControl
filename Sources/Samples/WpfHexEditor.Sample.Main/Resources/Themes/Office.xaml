<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== COLOR PALETTE ==================== -->

    <!-- Background Colors (Office Light) -->
    <Color x:Key="BackgroundColor">#FFFFFF</Color>
    <Color x:Key="SurfaceColor">#F3F3F3</Color>
    <Color x:Key="SurfaceElevatedColor">#FAFAFA</Color>
    <Color x:Key="OverlayColor">#E1E1E1</Color>

    <!-- Foreground Colors -->
    <Color x:Key="ForegroundColor">#323130</Color>
    <Color x:Key="ForegroundSecondaryColor">#605E5C</Color>
    <Color x:Key="ForegroundTertiaryColor">#8A8886</Color>

    <!-- Accent Colors (Office Blue) -->
    <Color x:Key="AccentColor">#0078D4</Color>
    <Color x:Key="AccentHoverColor">#106EBE</Color>
    <Color x:Key="AccentPressedColor">#005A9E</Color>
    <Color x:Key="AccentSecondaryColor">#2B88D8</Color>

    <!-- Semantic Colors -->
    <Color x:Key="SuccessColor">#107C10</Color>
    <Color x:Key="WarningColor">#FF8C00</Color>
    <Color x:Key="ErrorColor">#E81123</Color>
    <Color x:Key="InfoColor">#0078D4</Color>

    <!-- Border & Divider -->
    <Color x:Key="BorderColor">#D1D1D1</Color>
    <Color x:Key="DividerColor">#EDEBE9</Color>

    <!-- Hover & Press States -->
    <Color x:Key="HoverColor">#F3F2F1</Color>
    <Color x:Key="PressedColor">#EDEBE9</Color>
    <Color x:Key="SelectedColor">#DEECF9</Color>

    <!-- ==================== HEXEDITOR COLORS ==================== -->

    <!-- HexEditor Control Colors for Office Light Theme -->
    <Color x:Key="HexEditor_SelectionFirstColor">#660078D4</Color>         <!-- Office Blue with 40% opacity -->
    <Color x:Key="HexEditor_SelectionSecondColor">#330078D4</Color>        <!-- Office Blue with 20% opacity (inactive panel) -->
    <Color x:Key="HexEditor_ByteModifiedColor">#FF8C00</Color>             <!-- Orange -->
    <Color x:Key="HexEditor_HighLightColor">#FFD700</Color>                <!-- Gold -->
    <!-- MouseOverColor removed - controlled by HexEditor DP default -->
    <Color x:Key="HexEditor_ForegroundSecondColor">#0000FF</Color>         <!-- Blue -->
    <Color x:Key="HexEditor_ForegroundOffSetHeaderColor">#757575</Color>   <!-- Gray -->
    <Color x:Key="HexEditor_ForegroundHighLightOffSetHeaderColor">#00008B</Color> <!-- Dark Blue -->
    <Color x:Key="HexEditor_ForegroundContrast">#FFFFFF</Color>            <!-- White -->
    <Color x:Key="HexEditor_AutoHighLiteSelectionByteBrush">#ADD8E6</Color> <!-- Light Blue -->
    <Color x:Key="HexEditor_TblDteColor">#FF0000</Color>                   <!-- Red -->
    <Color x:Key="HexEditor_TblMteColor">#008000</Color>                   <!-- Green -->
    <Color x:Key="HexEditor_TblEndBlockColor">#FFFF00</Color>              <!-- Yellow -->
    <Color x:Key="HexEditor_TblEndLineColor">#FFA500</Color>               <!-- Orange -->
    <Color x:Key="HexEditor_BackgroundColor">#FFFFFF</Color>              <!-- White -->
    <Color x:Key="HexEditor_HeaderBackgroundColor">#F5F5F5</Color>       <!-- Light Gray -->
    <Color x:Key="HexEditor_HeaderForegroundColor">#424242</Color>       <!-- Dark Gray -->
    <Color x:Key="HexEditor_ColumnSeparatorColor">#D0D0D0</Color>       <!-- Medium Gray -->
    <Color x:Key="HexEditor_ForegroundFirstColor">#000000</Color>       <!-- Black -->
    <Color x:Key="HexEditor_AsciiForegroundColor">#424242</Color>      <!-- Dark Gray -->
    <Color x:Key="HexEditor_StatusBarBackgroundColor">#F5F5F5</Color>  <!-- Light Gray -->
    <Color x:Key="HexEditor_StatusBarForegroundColor">#333333</Color>  <!-- Dark -->
    <Color x:Key="HexEditor_ScrollBarBackgroundColor">#F0F0F0</Color>  <!-- Light -->
    <Color x:Key="HexEditor_ScrollBarThumbColor">#CDCDCD</Color>       <!-- Gray -->

    <!-- ==================== BRUSHES ==================== -->

    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{DynamicResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="{DynamicResource ForegroundColor}"/>
    <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="{DynamicResource ForegroundSecondaryColor}"/>
    <SolidColorBrush x:Key="ForegroundTertiaryBrush" Color="{DynamicResource ForegroundTertiaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}"/>

    <!-- Semantic Color Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}"/>

    <SolidColorBrush x:Key="GlassBrush" Color="Transparent"/>

    <!-- ==================== EFFECTS ==================== -->

    <DropShadowEffect x:Key="SubtleShadow"
                      Color="#000000"
                      ShadowDepth="0"
                      BlurRadius="3"
                      Opacity="0.08"/>

    <DropShadowEffect x:Key="AccentGlow"
                      Color="Transparent"
                      ShadowDepth="0"
                      BlurRadius="0"
                      Opacity="0"/>

    <!-- ==================== BUTTON STYLE ==================== -->

    <Style x:Key="ModernButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource HoverColor}"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource PressedColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ==================== TEXTBOX STYLE ==================== -->

    <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionOpacity" Value="0.4"/>
    </Style>

    <!-- ==================== PANEL STYLE ==================== -->

    <Style x:Key="GlassPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <!-- ==================== TOGGLE BUTTON ==================== -->

    <Style x:Key="ModernToggleButtonStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource HoverColor}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== MENU & TOOLBAR STYLES ==================== -->

    <!-- Default Menu Style -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- Default MenuItem Style -->
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <!-- Default ToolBar Style -->
    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- Default Button Style (for toolbar buttons) -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="2"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PressedColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

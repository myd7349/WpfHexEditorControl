<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        VS 2026 Preview Theme
        Modern futuristic theme with glassmorphism, neumorphism, and fluid animations

        Usage in App.xaml:
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="Resources/Styles/VS2026Theme.xaml"/>
        </ResourceDictionary.MergedDictionaries>
    -->

    <ResourceDictionary.MergedDictionaries>

        <!-- Base Color Palette -->
        <ResourceDictionary Source="VS2026/Colors.xaml"/>

        <!-- Visual Effects (Glassmorphism, Shadows) -->
        <ResourceDictionary Source="VS2026/Effects.xaml"/>

        <!-- Animations & Transitions -->
        <ResourceDictionary Source="VS2026/Animations.xaml"/>

        <!-- Button Styles -->
        <ResourceDictionary Source="VS2026/Buttons.xaml"/>

    </ResourceDictionary.MergedDictionaries>

    <!-- Default Window Style -->
    <Style x:Key="VS2026Window" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource VS2026_DeepSpaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource VS2026_TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Rounded TextBox (Search Box) -->
    <Style x:Key="VS2026SearchBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource VS2026_CardBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource VS2026_TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource VS2026_GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="18"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource VS2026_NeonBlueBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Modern Separator -->
    <Style x:Key="VS2026Separator" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource VS2026_GlassBorderBrush}"/>
        <Setter Property="Width" Value="1"/>
        <Setter Property="Margin" Value="8,4"/>
    </Style>

    <!-- Status Bar Style -->
    <Style x:Key="VS2026StatusBar" TargetType="StatusBar">
        <Setter Property="Background" Value="{StaticResource VS2026_DarkSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource VS2026_TextSecondaryBrush}"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="BorderBrush" Value="{StaticResource VS2026_GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <!-- Card Style -->
    <Style x:Key="VS2026Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource VS2026_CardBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{StaticResource FloatingShadow}"/>
    </Style>

    <!-- Floating Panel Style -->
    <Style x:Key="VS2026FloatingPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource VS2026_GlassBlurBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource VS2026_GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{StaticResource FloatingShadow}"/>
    </Style>

</ResourceDictionary>

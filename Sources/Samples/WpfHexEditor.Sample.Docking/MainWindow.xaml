<!-- ==========================================================
     Project: WpfHexEditor.Sample.Docking
     File: MainWindow.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude Sonnet 4.6
     Created: 2026-03-07
     Description:
         Main application window. VS Code-style chrome with a custom title bar
         (logo, inline menu, window control buttons) and a DockControl filling
         the content area. A StatusBar at the bottom shows the active theme.

     Architecture Notes:
         Theme: DockWindowBackgroundBrush, DockMenuBackgroundBrush,
                DockDarkMenuStyle, TitleBarButtonStyle, TitleBarCloseButtonStyle
                — all dynamic, auto-update on theme switch.
         Menu items: View > Theme (Dark/Light) | View > Layout > Reset
     ========================================================== -->

<Window x:Class="WpfHexEditor.Sample.Docking.MainWindow"
        x:Name="ThisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="clr-namespace:WpfHexEditor.Shell;assembly=WpfHexEditor.Shell"
        Title="WpfHexEditor — Docking Sample"
        Width="1100" Height="700"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource DockWindowBackgroundBrush}"
        Loaded="OnLoaded"
        Closed="OnClosed">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar -->
            <RowDefinition Height="32" />
            <!-- DockControl -->
            <RowDefinition Height="*" />
            <!-- Status bar -->
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             Row 0 — Title bar (VS Code style: menu left + buttons right)
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource DockMenuBackgroundBrush}">
            <DockPanel Height="32">

                <!-- Window buttons — right side -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE949;"
                            Style="{DynamicResource TitleBarButtonStyle}"
                            ToolTip="Minimize"
                            Click="OnMinimize"
                            WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button x:Name="MaxRestoreButton"
                            Content="&#xE739;"
                            Style="{DynamicResource TitleBarButtonStyle}"
                            ToolTip="Maximize"
                            Click="OnMaximizeRestore"
                            WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button Content="&#xE106;"
                            Style="{DynamicResource TitleBarCloseButtonStyle}"
                            ToolTip="Close"
                            Click="OnClose"
                            WindowChrome.IsHitTestVisibleInChrome="True" />
                </StackPanel>

                <!-- App icon — far left -->
                <TextBlock DockPanel.Dock="Left"
                           Text="&#xE700;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="14"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="10,0,4,0"
                           IsHitTestVisible="False" />

                <!-- Inline menu bar — VS Code style -->
                <Menu DockPanel.Dock="Left"
                      Style="{DynamicResource DockDarkMenuStyle}"
                      VerticalAlignment="Center"
                      WindowChrome.IsHitTestVisibleInChrome="True">

                    <!-- ═══ View ═══ -->
                    <MenuItem Header="_View">

                        <!-- Theme submenu -->
                        <MenuItem Header="_Theme">
                            <MenuItem x:Name="MenuDarkTheme"
                                      Header="_Dark (VS2022)"
                                      IsCheckable="True"
                                      IsChecked="True"
                                      Click="OnThemeDark" />
                            <MenuItem x:Name="MenuLightTheme"
                                      Header="_Light (Office)"
                                      IsCheckable="True"
                                      IsChecked="False"
                                      Click="OnThemeLight" />
                        </MenuItem>

                        <Separator />

                        <!-- Layout submenu -->
                        <MenuItem Header="_Layout">
                            <MenuItem Header="_Reset to default"
                                      Click="OnLayoutReset"
                                      ToolTip="Restore the original panel arrangement (Explorer left, Output+Properties bottom)" />
                        </MenuItem>

                    </MenuItem>
                </Menu>

                <!-- Title — centered, non-interactive drag area -->
                <TextBlock Text="WpfHexEditor — Docking Sample"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           IsHitTestVisible="False" />
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             Row 1 — DockControl
             ═══════════════════════════════════════════════════════════ -->
        <dock:DockControl x:Name="DockHost"
                          Grid.Row="1"
                          Margin="2,2,2,0"
                          TabCloseRequested="OnTabCloseRequested"
                          ActiveItemChanged="OnActiveItemChanged" />

        <!-- ═══════════════════════════════════════════════════════════
             Row 2 — Status bar
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="StatusThemeLabel"
                           DockPanel.Dock="Right"
                           Text="Theme: Dark"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Opacity="0.7" />

                <TextBlock x:Name="StatusActiveItemLabel"
                           Text="Ready"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Opacity="0.7" />
            </DockPanel>
        </Border>
    </Grid>
</Window>

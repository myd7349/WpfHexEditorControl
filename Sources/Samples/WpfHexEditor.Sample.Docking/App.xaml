<!-- ==========================================================
     Project: WpfHexEditor.Sample.Docking
     File: App.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude Sonnet 4.6
     Created: 2026-03-07
     Description:
         Application entry point. Merges the default Dark theme from
         WpfHexEditor.Shell. Theme can be switched at runtime via
         App.SwitchTheme(uri) — see App.xaml.cs.

     Architecture Notes:
         Theme: DarkTheme.xaml (VS2022 Dark, default)
         ResourceDictionaries applied: WpfHexEditor.Shell/Themes/DarkTheme.xaml
     ========================================================== -->

<Application x:Class="WpfHexEditor.Sample.Docking.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default theme: VS2022 Dark -->
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Shell;component/Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>

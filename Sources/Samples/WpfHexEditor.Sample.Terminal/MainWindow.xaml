<!-- ==========================================================
     Project: WpfHexEditor.Sample.Terminal
     File: MainWindow.xaml
     Author: Auto
     Created: 2026-03-08
     Description:
         Main window — standard WPF Window with a menu bar (File / View /
         Terminal / Help), a full-area TerminalPanel, and a thin status bar.
         No docking engine. No custom chrome.

     Architecture Notes:
         Theme: all brushes via DynamicResource — auto-update on theme switch.
           DockWindowBackgroundBrush  — window root background
           DockMenuBackgroundBrush    — status bar background
           DockBorderBrush            — status bar top border
           Panel_ToolbarForegroundBrush — status bar text
         TerminalPanel DataContext inherited from MainWindow (= TerminalPanelViewModel).
     ========================================================== -->

<Window x:Class="WpfHexEditor.Sample.Terminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:terminal="clr-namespace:WpfHexEditor.Terminal;assembly=WpfHexEditor.Terminal"
        Title="WpfHexEditor — Terminal Sample"
        Width="1000" Height="680"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource DockWindowBackgroundBrush}"
        Closed="OnClosed">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Menu bar -->
            <RowDefinition Height="Auto" />
            <!-- Terminal panel -->
            <RowDefinition Height="*" />
            <!-- Status bar -->
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             Row 0 — Menu bar
             ═══════════════════════════════════════════════════════════ -->
        <Menu Grid.Row="0"
              Style="{DynamicResource DockDarkMenuStyle}">

            <!-- ─── File ─── -->
            <MenuItem Header="_File">
                <MenuItem Header="E_xit"
                          InputGestureText="Alt+F4"
                          Click="OnExit" />
            </MenuItem>

            <!-- ─── View ─── -->
            <MenuItem Header="_View">
                <MenuItem Header="_Theme">
                    <MenuItem x:Name="MenuDarkTheme"
                              Header="_Dark (VS2022)"
                              IsCheckable="True"
                              IsChecked="True"
                              Click="OnThemeDark" />
                    <MenuItem x:Name="MenuLightTheme"
                              Header="_Light (Office)"
                              IsCheckable="True"
                              IsChecked="False"
                              Click="OnThemeLight" />
                </MenuItem>
            </MenuItem>

            <!-- ─── Terminal ─── -->
            <MenuItem Header="_Terminal">
                <MenuItem Header="_Clear Output"
                          InputGestureText="Ctrl+L"
                          Click="OnClearOutput" />
                <Separator />
                <MenuItem x:Name="MenuHxTerminal"
                          Header="_HxTerminal Mode"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="OnModeHxTerminal" />
                <MenuItem x:Name="MenuPowerShell"
                          Header="_PowerShell Mode"
                          IsCheckable="True"
                          IsChecked="False"
                          Click="OnModePowerShell" />
                <MenuItem x:Name="MenuBash"
                          Header="_Bash Mode"
                          IsCheckable="True"
                          IsChecked="False"
                          Click="OnModeBash" />
                <Separator />
                <MenuItem Header="_Save Output…"
                          Click="OnSaveOutput" />
            </MenuItem>

            <!-- ─── Help ─── -->
            <MenuItem Header="_Help">
                <MenuItem Header="_About…"
                          Click="OnAbout" />
            </MenuItem>

        </Menu>

        <!-- ═══════════════════════════════════════════════════════════
             Row 1 — Terminal panel (fills all remaining space)
             ═══════════════════════════════════════════════════════════ -->
        <terminal:TerminalPanel Grid.Row="1" />

        <!-- ═══════════════════════════════════════════════════════════
             Row 2 — Status bar
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>

                <!-- Right: active theme label -->
                <TextBlock x:Name="StatusThemeLabel"
                           DockPanel.Dock="Right"
                           Text="Theme: Dark"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Opacity="0.75" />

                <!-- Separator -->
                <Rectangle DockPanel.Dock="Right"
                           Width="1"
                           Margin="0,3"
                           Fill="{DynamicResource DockBorderBrush}" />

                <!-- Left: active shell mode -->
                <TextBlock x:Name="StatusShellLabel"
                           Text="● HxTerminal"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Opacity="0.75" />

            </DockPanel>
        </Border>

    </Grid>
</Window>

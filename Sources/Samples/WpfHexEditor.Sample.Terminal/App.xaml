<!-- ==========================================================
     Project: WpfHexEditor.Sample.Terminal
     File: App.xaml
     Author: Auto
     Created: 2026-03-08
     Description:
         Application entry point. Loads the Dark theme ResourceDictionary
         by default. Theme switching is handled by App.SwitchTheme().

     Architecture Notes:
         Theme: DarkTheme.xaml (from WpfHexEditor.Shell — transitive ref)
         All DynamicResource bindings in the application update automatically
         when SwitchTheme() replaces the active ResourceDictionary.
     ========================================================== -->

<Application x:Class="WpfHexEditor.Sample.Terminal.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default theme: VS2022 Dark -->
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Shell;component/Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>

<UserControl
    x:Class="WpfHexEditor.Editor.XamlDesigner.Panels.AnimationTimelinePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:WpfHexEditor.Editor.XamlDesigner.Panels"
    xmlns:vm="clr-namespace:WpfHexEditor.Editor.XamlDesigner.ViewModels"
    xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.XamlDesigner.Controls"
    MinHeight="140">

    <UserControl.Resources>
        <!-- Track row header style -->
        <Style x:Key="TrackHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding"           Value="6,0"/>
            <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
            <Setter Property="Foreground"        Value="{DynamicResource DockMenuForegroundBrush}"/>
        </Style>

        <!-- Keyframe dot style -->
        <Style x:Key="KeyframeDotStyle" TargetType="Ellipse">
            <Setter Property="Width"  Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Fill"   Value="{DynamicResource XD_KeyframeThumbBrush}"/>
            <Setter Property="Stroke" Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Track list item style -->
        <Style x:Key="TrackListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="Margin"            Value="0"/>
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource DockBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Height="24">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource XD_TimelineBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Play/Pause button style -->
        <Style x:Key="PlayButtonStyle" TargetType="Button">
            <Setter Property="Width"            Value="22"/>
            <Setter Property="Height"           Value="22"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Foreground"       Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontFamily"       Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Padding="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>  <!-- Toolbar -->
            <RowDefinition Height="22"/>  <!-- Ruler -->
            <RowDefinition Height="*"/>   <!-- Tracks -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DockBorderBrush}">
            <Border.Background>
                <DynamicResourceExtension ResourceKey="XD_PanelToolbarBrush"/>
            </Border.Background>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">

                <!-- Stop -->
                <Button Style="{StaticResource PlayButtonStyle}"
                        Content="&#xE71A;"
                        ToolTip="Stop"
                        Command="{Binding StopCommand}"/>

                <!-- Play -->
                <Button Style="{StaticResource PlayButtonStyle}"
                        ToolTip="Play"
                        Command="{Binding PlayCommand}"
                        x:Name="BtnPlay">
                    <Button.Content>
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE768;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Text" Value="&#xE769;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button.Content>
                </Button>

                <!-- Pause -->
                <Button Style="{StaticResource PlayButtonStyle}"
                        Content="&#xE769;"
                        ToolTip="Pause"
                        Command="{Binding PauseCommand}"/>

                <Separator Width="1" Margin="4,4" Background="{DynamicResource DockBorderBrush}"/>

                <!-- Duration display -->
                <TextBlock VerticalAlignment="Center"
                           FontSize="10"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="4,0,0,0">
                    <Run Text="Duration: "/>
                    <Run Text="{Binding Duration, StringFormat={}{0:mm\\:ss\\.ff}, Mode=OneWay}"/>
                </TextBlock>

                <Separator Width="1" Margin="4,4" Background="{DynamicResource DockBorderBrush}"/>

                <!-- Current time display -->
                <TextBlock VerticalAlignment="Center"
                           FontSize="10"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="4,0,0,0">
                    <Run Text="Time: "/>
                    <Run Text="{Binding CurrentTime, StringFormat={}{0:mm\\:ss\\.ff}, Mode=OneWay}"/>
                </TextBlock>

            </StackPanel>
        </Border>

        <!-- ── Time Ruler ───────────────────────────────────────────── -->
        <ctrl:TimelineRuler Grid.Row="1"
                            x:Name="TimeRuler"
                            Duration="{Binding Duration}"
                            CurrentTime="{Binding CurrentTime}"
                            SeekRequested="OnRulerSeekRequested"
                            Height="22"
                            Cursor="SizeWE"/>

        <!-- ── Track list + keyframe area ──────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>         <!-- Track headers -->
                <ColumnDefinition Width="Auto"/>        <!-- Splitter -->
                <ColumnDefinition Width="*"/>           <!-- Keyframe lane -->
            </Grid.ColumnDefinitions>

            <!-- Track header list -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Tracks}"
                     SelectedItem="{Binding SelectedTrack}"
                     ItemContainerStyle="{StaticResource TrackListItemStyle}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                     Background="{DynamicResource DockBackgroundBrush}"
                     BorderThickness="0"
                     x:Name="TrackHeaders">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:AnimationTrackViewModel}">
                        <TextBlock Style="{StaticResource TrackHeaderStyle}"
                                   Text="{Binding TrackLabel}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Column separator -->
            <GridSplitter Grid.Column="1"
                          Width="3"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"/>

            <!-- Keyframe lanes (Canvas per track) -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          x:Name="LaneScroller">
                <ItemsControl ItemsSource="{Binding Tracks}"
                              x:Name="KeyframeLanes">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AnimationTrackViewModel}">
                            <!-- One 24px-high Canvas row per track -->
                            <Canvas Height="24"
                                    Background="Transparent"
                                    ClipToBounds="True"
                                    x:Name="LaneCanvas"
                                    Loaded="OnLaneLoaded"
                                    Tag="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

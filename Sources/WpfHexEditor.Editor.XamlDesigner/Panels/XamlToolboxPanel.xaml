<UserControl x:Class="WpfHexEditor.Editor.XamlDesigner.Panels.XamlToolboxPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Editor.XamlDesigner.ViewModels"
             xmlns:models="clr-namespace:WpfHexEditor.Editor.XamlDesigner.Models">

    <!-- ==========================================================
         Project: WpfHexEditor.Editor.XamlDesigner
         File: XamlToolboxPanel.xaml
         Created: 2026-03-17
         Description: VS-Like dockable panel listing all WPF toolbox controls
                      organized by category. Supports drag-to-canvas and text search.
         Theme: XD_* tokens (Dynamic Resources)
         ========================================================== -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border x:Name="ToolbarBorder" Grid.Row="0"
                BorderThickness="0,0,0,1" Height="26">
            <Border.Background>
                <DynamicResource ResourceKey="XD_PanelToolbarBrush"/>
            </Border.Background>
            <Border.BorderBrush>
                <DynamicResource ResourceKey="XD_PanelToolbarBorderBrush"/>
            </Border.BorderBrush>
            <DockPanel Margin="4,0">
                <TextBlock Text="\uE721" FontFamily="Segoe MDL2 Assets" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,4,0"
                           Foreground="{DynamicResource XD_PropertyNameForeground}"/>
                <TextBox x:Name="TbxFilter"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Height="18" FontSize="11"
                         Background="Transparent"
                         Foreground="{DynamicResource XD_PropertyValueForeground}"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         Padding="2,0"
                         ToolTip="Filter controls (type to search)"/>
            </DockPanel>
        </Border>

        <!-- ── Separator ────────────────────────────────────────── -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource DockBorderBrush}"/>

        <!-- ── Item list ────────────────────────────────────────── -->
        <ListBox x:Name="ToolboxList" Grid.Row="2"
                 ItemsSource="{Binding ItemsView}"
                 SelectedItem="{Binding SelectedItem}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 PreviewMouseMove="OnListPreviewMouseMove">

            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0,0,0,1" Padding="4,3"
                                    Background="{DynamicResource XD_PropertyGroupHeaderBackground}"
                                    BorderBrush="{DynamicResource DockBorderBrush}">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource XD_PropertyNameForeground}"/>
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListBox.GroupStyle>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ToolboxItem}">
                    <StackPanel Orientation="Horizontal" Margin="8,2,4,2">
                        <TextBlock Text="{Binding IconGlyph}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Width="18" VerticalAlignment="Center"
                                   Foreground="{DynamicResource XD_PropertyNameForeground}"/>
                        <TextBlock Text="{Binding Name}"
                                   FontSize="12" Margin="4,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource XD_PropertyValueForeground}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding"     Value="2"/>
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource XD_ToolboxItemHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource XD_ToolboxItemHover}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</UserControl>

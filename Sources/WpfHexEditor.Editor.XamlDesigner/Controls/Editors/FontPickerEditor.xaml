<UserControl x:Class="WpfHexEditor.Editor.XamlDesigner.Controls.Editors.FontPickerEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="22">

    <!-- ==========================================================
         File: FontPickerEditor.xaml
         Created: 2026-03-17
         Description: Inline font family picker using a ComboBox
                      populated with all system fonts.
         ========================================================== -->

    <ComboBox x:Name="CbFont"
              Height="18" FontSize="11"
              IsEditable="True"
              Background="Transparent"
              Foreground="{DynamicResource XD_PropertyValueForeground}"
              BorderBrush="{DynamicResource DockBorderBrush}"
              BorderThickness="1"
              Text="{Binding FamilyName, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=LostFocus}"
              SelectionChanged="OnFontSelected">
        <ComboBox.ItemTemplate>
            <DataTemplate>
                <TextBlock Text="{Binding Source}" FontFamily="{Binding}" FontSize="12"/>
            </DataTemplate>
        </ComboBox.ItemTemplate>
    </ComboBox>
</UserControl>

<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentStructurePane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Controls"
             Background="{DynamicResource DockBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:ResourceKeyToBrushConverter x:Key="ResourceKeyToBrushConverter"/>

        <!-- Small icon button style -->
        <Style x:Key="StructToolBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="2"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SE_HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header + toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Search box -->
            <RowDefinition Height="*"/>     <!-- Tree -->
        </Grid.RowDefinitions>

        <!-- ── Header + toolbar ──────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource DockBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,3">
            <DockPanel>
                <!-- Title + block count -->
                <TextBlock x:Name="PART_Header"
                           DockPanel.Dock="Left"
                           Text="Structure"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DE_StructureNodeFg}"/>

                <TextBlock x:Name="PART_CountLabel"
                           DockPanel.Dock="Left"
                           Margin="6,0,0,0"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Opacity="0.6"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>

                <!-- Right-side toolbar buttons -->
                <Button x:Name="PART_CollapseAllBtn"
                        Style="{StaticResource StructToolBtnStyle}"
                        DockPanel.Dock="Right"
                        ToolTip="Collapse all"
                        Click="OnCollapseAllClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70D;" FontSize="11"/>
                </Button>

                <Button x:Name="PART_ExpandAllBtn"
                        Style="{StaticResource StructToolBtnStyle}"
                        DockPanel.Dock="Right"
                        ToolTip="Expand all"
                        Click="OnExpandAllClicked">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70E;" FontSize="11"/>
                </Button>
            </DockPanel>
        </Border>

        <!-- ── Search box ────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource DockBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="PART_SearchBox"
                         Grid.Column="0"
                         Background="{DynamicResource DockBackgroundBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         CaretBrush="{DynamicResource DockMenuForegroundBrush}"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         Padding="4,2"
                         FontSize="12"
                         TextChanged="OnSearchTextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Resources>
                                <VisualBrush x:Key="HintBrush" Stretch="None" AlignmentX="Left">
                                    <VisualBrush.Visual>
                                        <TextBlock Text="Filter blocks…"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                   Opacity="0.4"
                                                   FontSize="12"
                                                   Margin="5,2"/>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Style.Resources>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button x:Name="PART_ClearSearchBtn"
                        Grid.Column="1"
                        Style="{StaticResource StructToolBtnStyle}"
                        Width="20" Height="20"
                        Margin="2,0,0,0"
                        ToolTip="Clear filter"
                        Click="OnClearSearchClicked"
                        Visibility="{Binding Text.Length, ElementName=PART_SearchBox,
                                     Converter={StaticResource BoolToVis}}">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" FontSize="10"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── Structure tree ────────────────────────────────────────── -->
        <TreeView x:Name="PART_Tree"
                  Grid.Row="2"
                  Background="Transparent"
                  BorderThickness="0"
                  SelectedItemChanged="OnTreeSelectedItemChanged">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type local:DocumentBlockNode}"
                                          ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Forensic badge dot -->
                        <Border x:Name="PART_ForensicBadge"
                                Width="8" Height="8"
                                CornerRadius="4"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAlert, Converter={StaticResource BoolToVis}}"
                                Background="{Binding AlertBrushKey, Converter={StaticResource ResourceKeyToBrushConverter}}"
                                ToolTip="{Binding AlertMessage}"/>

                        <!-- Kind chip -->
                        <Border CornerRadius="2"
                                Padding="3,0"
                                Margin="0,0,4,0"
                                Background="{DynamicResource DE_ToolbarButtonActiveBrush}">
                            <TextBlock Text="{Binding KindLabel}"
                                       FontSize="10"
                                       Foreground="{DynamicResource DE_StructureKindFg}"/>
                        </Border>

                        <!-- Text preview -->
                        <TextBlock Text="{Binding Preview}"
                                   Foreground="{DynamicResource DE_StructureNodeFg}"
                                   FontSize="12"/>

                        <!-- Offset badge -->
                        <TextBlock Text="{Binding OffsetText}"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   FontSize="10"
                                   Opacity="0.5"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}"/>
                    <Setter Property="Background"   Value="Transparent"/>
                    <Setter Property="IsExpanded"   Value="True"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource SE_HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource DE_SelectedBlockBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="PART_MenuNavigate"
                              Header="Navigate to text"
                              Click="OnMenuNavigateClicked">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="PART_MenuJumpHex"
                              Header="Jump to hex offset"
                              Click="OnMenuJumpHexClicked">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C4;" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="PART_MenuCopyText"
                              Header="Copy block text"
                              Click="OnMenuCopyTextClicked">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="PART_MenuCopyOffset"
                              Header="Copy offset"
                              Click="OnMenuCopyOffsetClicked">
                        <MenuItem.Icon>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F4;" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>
    </Grid>
</UserControl>

<UserControl x:Class="WpfHexEditor.Editor.DocumentEditor.Controls.DocumentPopToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.DocumentEditor.Controls"
             Opacity="0.95">
    <UserControl.Resources>
        <Style x:Key="PopBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DE_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopSepStyle" TargetType="Separator">
            <Setter Property="Width"      Value="1"/>
            <Setter Property="Margin"     Value="2,4"/>
            <Setter Property="Background" Value="{DynamicResource DE_PopToolbarBorderBrush}"/>
        </Style>
    </UserControl.Resources>

    <!-- Floating semi-transparent popup card -->
    <Border Background="{DynamicResource DE_PopToolbarBackground}"
            BorderBrush="{DynamicResource DE_PopToolbarBorderBrush}"
            BorderThickness="1"
            CornerRadius="5"
            Padding="4,3">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <StackPanel Orientation="Horizontal">
            <!-- Group 1: Formatting -->
            <Button x:Name="PART_BoldBtn"
                    Style="{StaticResource PopBtnStyle}"
                    ToolTip="Bold (Ctrl+B)"
                    Click="OnBoldClicked">
                <TextBlock Text="B" FontWeight="Bold" FontSize="13"/>
            </Button>

            <Button x:Name="PART_ItalicBtn"
                    Style="{StaticResource PopBtnStyle}"
                    ToolTip="Italic (Ctrl+I)"
                    Click="OnItalicClicked">
                <TextBlock Text="I" FontStyle="Italic" FontSize="13"/>
            </Button>

            <Button x:Name="PART_UnderlineBtn"
                    Style="{StaticResource PopBtnStyle}"
                    ToolTip="Underline (Ctrl+U)"
                    Click="OnUnderlineClicked">
                <TextBlock Text="U" FontSize="13">
                    <TextBlock.TextDecorations>
                        <TextDecoration/>
                    </TextBlock.TextDecorations>
                </TextBlock>
            </Button>

            <Separator Style="{StaticResource PopSepStyle}"/>

            <!-- Group 2: Copy -->
            <Button x:Name="PART_CopyTextBtn"
                    Style="{StaticResource PopBtnStyle}"
                    ToolTip="Copy selected text"
                    Click="OnCopyTextClicked">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" FontSize="13"/>
            </Button>

            <Button x:Name="PART_CopyHexBtn"
                    Style="{StaticResource PopBtnStyle}"
                    ToolTip="Copy as hex bytes"
                    Click="OnCopyHexClicked">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8F4;" FontSize="13"/>
            </Button>

            <Separator Style="{StaticResource PopSepStyle}"/>

            <!-- Group 3: Navigation -->
            <Button x:Name="PART_InspectBtn"
                    Style="{StaticResource PopBtnStyle}"
                    ToolTip="Inspect block in Structure pane"
                    Click="OnInspectClicked">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C9;" FontSize="13"/>
            </Button>

            <Button x:Name="PART_JumpHexBtn"
                    Style="{StaticResource PopBtnStyle}"
                    ToolTip="Jump to offset in Hex pane"
                    Click="OnJumpHexClicked">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C4;" FontSize="13"/>
            </Button>
        </StackPanel>
    </Border>
</UserControl>

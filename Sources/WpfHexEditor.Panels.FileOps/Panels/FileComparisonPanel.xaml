<UserControl x:Class="WpfHexEditor.Panels.FileOps.FileComparisonPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Background="{DynamicResource PFP_PanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <DockPanel>
                <!-- Load buttons (docked right) -->
                <Button DockPanel.Dock="Right"
                        Content="Load File 2…"
                        Style="{StaticResource PanelDropdownButtonStyle}"
                        Padding="12,3" Height="22" Margin="0,0,4,0"
                        Click="LoadFile2_Click"/>
                <Button DockPanel.Dock="Right"
                        Content="Load File 1…"
                        Style="{StaticResource PanelDropdownButtonStyle}"
                        Padding="12,3" Height="22" Margin="0,0,8,0"
                        Click="LoadFile1_Click"/>
                <Rectangle DockPanel.Dock="Right" Width="1" Margin="0,4,8,4"
                           Fill="{DynamicResource PFP_BorderBrush}"/>

                <!-- Info text (fills remaining space) -->
                <TextBlock x:Name="ComparisonInfoText"
                           Text="Select files to compare"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0" FontSize="11"
                           Foreground="{DynamicResource PFP_SubTextBrush}"/>
            </DockPanel>
        </Border>

        <!-- ── Comparison view ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- File 1 -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource PFP_BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Column header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource Panel_ToolbarBrush}"
                            BorderBrush="{DynamicResource PFP_BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,5">
                        <TextBlock x:Name="File1NameText" Text="File 1"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource PFP_TextBrush}"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="File1Fields" Padding="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4" Margin="0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Removed">
                                                        <Setter Property="Background"       Value="{DynamicResource DiffRemoved_BackgroundBrush}"/>
                                                        <Setter Property="BorderBrush"      Value="{DynamicResource DiffRemoved_BorderBrush}"/>
                                                        <Setter Property="BorderThickness"  Value="2,0,0,0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Modified">
                                                        <Setter Property="Background"       Value="{DynamicResource DiffModified_BackgroundBrush}"/>
                                                        <Setter Property="BorderBrush"      Value="{DynamicResource DiffModified_BorderBrush}"/>
                                                        <Setter Property="BorderThickness"  Value="2,0,0,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold" FontSize="10"
                                                       Foreground="{DynamicResource PFP_TextBrush}"/>
                                            <TextBlock Text="{Binding Value}"
                                                       FontFamily="Consolas" FontSize="9"
                                                       Foreground="{DynamicResource PFP_SubTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Diff legend (center strip) -->
            <Border Grid.Column="1" Width="36"
                    Background="{DynamicResource PFP_SectionBackgroundBrush}"
                    BorderBrush="{DynamicResource PFP_BorderBrush}"
                    BorderThickness="1,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Background="{DynamicResource DiffAdded_BackgroundBrush}"
                            BorderBrush="{DynamicResource DiffAdded_BorderBrush}"
                            BorderThickness="1"
                            Width="26" Height="26" Margin="0,4" CornerRadius="4" ToolTip="Added"/>
                    <TextBlock Text="+" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource DiffAdded_BorderBrush}"/>

                    <Border Background="{DynamicResource DiffModified_BackgroundBrush}"
                            BorderBrush="{DynamicResource DiffModified_BorderBrush}"
                            BorderThickness="1"
                            Width="26" Height="26" Margin="0,8,0,4" CornerRadius="4" ToolTip="Modified"/>
                    <TextBlock Text="≠" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource DiffModified_BorderBrush}"/>

                    <Border Background="{DynamicResource DiffRemoved_BackgroundBrush}"
                            BorderBrush="{DynamicResource DiffRemoved_BorderBrush}"
                            BorderThickness="1"
                            Width="26" Height="26" Margin="0,8,0,4" CornerRadius="4" ToolTip="Removed"/>
                    <TextBlock Text="-" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource DiffRemoved_BorderBrush}"/>
                </StackPanel>
            </Border>

            <!-- File 2 -->
            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource PFP_BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Column header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource Panel_ToolbarBrush}"
                            BorderBrush="{DynamicResource PFP_BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,5">
                        <TextBlock x:Name="File2NameText" Text="File 2"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource PFP_TextBrush}"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="File2Fields" Padding="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4" Margin="0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Added">
                                                        <Setter Property="Background"       Value="{DynamicResource DiffAdded_BackgroundBrush}"/>
                                                        <Setter Property="BorderBrush"      Value="{DynamicResource DiffAdded_BorderBrush}"/>
                                                        <Setter Property="BorderThickness"  Value="2,0,0,0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Modified">
                                                        <Setter Property="Background"       Value="{DynamicResource DiffModified_BackgroundBrush}"/>
                                                        <Setter Property="BorderBrush"      Value="{DynamicResource DiffModified_BorderBrush}"/>
                                                        <Setter Property="BorderThickness"  Value="2,0,0,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold" FontSize="10"
                                                       Foreground="{DynamicResource PFP_TextBrush}"/>
                                            <TextBlock Text="{Binding Value}"
                                                       FontFamily="Consolas" FontSize="9"
                                                       Foreground="{DynamicResource PFP_SubTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Status bar ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="MatchingFieldsText" Text="Matching: 0"  FontSize="10" Margin="0,0,16,0"
                           Foreground="{DynamicResource PFP_SubTextBrush}"/>
                <TextBlock x:Name="AddedFieldsText"    Text="Added: 0"     FontSize="10" Margin="0,0,16,0"
                           Foreground="{DynamicResource DiffAdded_BorderBrush}"/>
                <TextBlock x:Name="ModifiedFieldsText" Text="Modified: 0"  FontSize="10" Margin="0,0,16,0"
                           Foreground="{DynamicResource DiffModified_BorderBrush}"/>
                <TextBlock x:Name="RemovedFieldsText"  Text="Removed: 0"   FontSize="10"
                           Foreground="{DynamicResource DiffRemoved_BorderBrush}"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>

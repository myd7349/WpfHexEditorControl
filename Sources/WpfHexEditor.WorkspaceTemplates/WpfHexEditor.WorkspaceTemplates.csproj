    WpfHexEditor.WorkspaceTemplates
    ================================
    Provides built-in and user-defined workspace templates for the
    New Project dialog. Scaffolds .whproj / .whsln files and wires
    language definitions, SmartComplete, and optional plugins.
-->

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>WpfHexEditor.WorkspaceTemplates</RootNamespace>
    <AssemblyName>WpfHexEditor.WorkspaceTemplates</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>Workspace templates engine for WpfHexEditor — TemplateManager, ProjectScaffolder, NewProjectDialog.</Description>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\WpfHexEditor.Editor.Core\WpfHexEditor.Editor.Core.csproj" />
    <ProjectReference Include="..\WpfHexEditor.ProjectSystem\WpfHexEditor.ProjectSystem.csproj" />
    <ProjectReference Include="..\WpfHexEditor.SDK\WpfHexEditor.SDK.csproj" />
    <ProjectReference Include="..\WpfHexEditor.Docking.Core\WpfHexEditor.Docking.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Embedded built-in templates -->
    <EmbeddedResource Include="Templates\*.json"/>
  </ItemGroup>

</Project>

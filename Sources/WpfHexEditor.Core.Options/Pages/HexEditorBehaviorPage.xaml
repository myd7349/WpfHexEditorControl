<UserControl x:Class="WpfHexEditor.Core.Options.Pages.HexEditorBehaviorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <TextBlock Text="Advanced Behavior"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,16"/>

        <CheckBox x:Name="CheckAllowAutoHighLight"
                  Content="Highlight same bytes under cursor"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckAllowAutoSelectDoubleClick"
                  Content="Auto-select same bytes on double-click"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckAllowContextMenu"
                  Content="Enable context menu"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckAllowDeleteByte"
                  Content="Allow byte deletion"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckAllowExtend"
                  Content="Allow file extension (append bytes)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckFileDroppingConfirmation"
                  Content="Confirm before opening dropped file"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,16"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,0,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- Preload mode -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Byte preload mode:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="PreloadModeCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

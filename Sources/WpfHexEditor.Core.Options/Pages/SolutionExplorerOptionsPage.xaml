// Description:
//     Options page for the Solution Explorer panel.
//     Covers: active document tracking, collapse state persistence,
//     contextual notifications, default sort/filter.
//
// Theme: PanelCommon.xaml + DynamicResource brushes (all themes)
// ==========================================================
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.SolutionExplorerOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── Navigation ────────────────────────────────────────────────── -->
        <TextBlock Text="Navigation"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="CheckTrackActive"
                  Content="Automatically highlight active document in tree"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckPersistCollapse"
                  Content="Remember expanded / collapsed state between sessions"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Notifications ─────────────────────────────────────────────── -->
        <TextBlock Text="Notifications"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="CheckNotifications"
                  Content="Show contextual notifications (external changes, paste conflicts…)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Default Sort ───────────────────────────────────────────────── -->
        <TextBlock Text="Defaults when opening a solution"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Default sort:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="SortCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="None"         Tag="None"/>
                <ComboBoxItem Content="Name"         Tag="Name"/>
                <ComboBoxItem Content="Type"         Tag="Type"/>
                <ComboBoxItem Content="Date Modified" Tag="DateModified"/>
                <ComboBoxItem Content="Size"         Tag="Size"/>
            </ComboBox>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Default filter:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="FilterCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="All"      Tag="All"/>
                <ComboBoxItem Content="Binary"   Tag="Binary"/>
                <ComboBoxItem Content="Text"     Tag="Text"/>
                <ComboBoxItem Content="Image"    Tag="Image"/>
                <ComboBoxItem Content="Language" Tag="Language"/>
            </ComboBox>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

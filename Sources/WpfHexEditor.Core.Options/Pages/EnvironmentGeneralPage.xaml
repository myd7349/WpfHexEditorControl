<UserControl x:Class="WpfHexEditor.Core.Options.Pages.EnvironmentGeneralPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── Apparence ──────────────────────────────────────────────────── -->
        <TextBlock Text="Appearance"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,16"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Color theme:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="ThemeCombo" Grid.Column="1"
                      SelectionChanged="OnThemeSelectionChanged"/>
        </Grid>

        <TextBlock Text="Preview is applied immediately."
                   FontStyle="Italic" FontSize="11"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.65"
                   Margin="0,4,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

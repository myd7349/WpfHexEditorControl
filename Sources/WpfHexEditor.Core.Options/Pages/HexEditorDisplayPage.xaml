<UserControl x:Class="WpfHexEditor.Core.Options.Pages.HexEditorDisplayPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <TextBlock Text="Display"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,16"/>

        <!-- Bytes par ligne -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Bytes per line:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="BytePerLineCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="8"   Tag="8"/>
                <ComboBoxItem Content="16"  Tag="16"/>
                <ComboBoxItem Content="32"  Tag="32"/>
                <ComboBoxItem Content="64"  Tag="64"/>
                <ComboBoxItem Content="128" Tag="128"/>
            </ComboBox>
        </Grid>

        <!-- Colonnes visibles -->
        <CheckBox x:Name="CheckShowOffset"
                  Content="Show offset column"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowAscii"
                  Content="Show ASCII column"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,10"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <!-- Mouse wheel speed -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Mouse wheel speed:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="MouseWheelSpeedCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Byte tooltip mode -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Byte tooltip:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="ByteToolTipModeCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <Separator Margin="0,0,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <TextBlock Text="Display Format"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,16"/>

        <!-- Data string visual -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Value format:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="DataVisualCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Offset string visual -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Offset format:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="OffsetVisualCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Byte grouping -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Byte grouping:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="ByteGroupingCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Byte spacer position -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Spacer position:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="SpacerPositionCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <Separator Margin="0,8,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <TextBlock Text="Scroll Bar Markers"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,16"/>

        <CheckBox x:Name="CheckShowBookmarkMarkers"
                  Content="Show bookmark markers"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowModifiedMarkers"
                  Content="Show modified markers"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowInsertedMarkers"
                  Content="Show inserted markers"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowDeletedMarkers"
                  Content="Show deleted markers"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowSearchResultMarkers"
                  Content="Show search result markers"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,0"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,16,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <TextBlock Text="Column and Row Highlight"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,16"/>

        <CheckBox x:Name="CheckShowColumnHighlight"
                  Content="Show active column highlight (hex panel)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowAsciiColumnHighlight"
                  Content="Show active column highlight (ASCII panel)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowRowHighlight"
                  Content="Show active row (line) highlight"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,0"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

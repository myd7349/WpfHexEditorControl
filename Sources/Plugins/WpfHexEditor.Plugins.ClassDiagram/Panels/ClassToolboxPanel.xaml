<!--
    Project: WpfHexEditor.Plugins.ClassDiagram
    File: Panels/ClassToolboxPanel.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-19
    Description:
        Dockable toolbox panel listing draggable diagram element types
        (Class, Interface, Enum, Struct, Abstract Class).
        Supports text search via the ViewModel's FilteredEntries.
        Theme tokens: CD_* / DockMenu* global brushes.
-->
<UserControl x:Class="WpfHexEditor.Plugins.ClassDiagram.Panels.ClassToolboxPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockMenuBackgroundBrush}">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockToolBarBorderBrush}"
                Padding="4,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,4,0"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <TextBox Width="140"
                         Padding="2,1"
                         FontSize="11"
                         VerticalAlignment="Center"
                         Background="{DynamicResource CD_DslEditorBackground}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         BorderBrush="{DynamicResource DockToolBarBorderBrush}"
                         CaretBrush="{DynamicResource DockMenuForegroundBrush}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Filter toolbox items"/>
            </StackPanel>
        </Border>

        <!-- Toolbox entry list — PreviewMouseMove initiates drag-and-drop onto the diagram canvas -->
        <ListBox ItemsSource="{Binding FilteredEntries}"
                 Background="{DynamicResource DockMenuBackgroundBrush}"
                 Foreground="{DynamicResource DockMenuForegroundBrush}"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 PreviewMouseMove="OnListBoxPreviewMouseMove">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2,3">
                        <TextBlock Text="&#xE92F;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource CD_NodeHeaderForeground}"/>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                            <TextBlock Text="{Binding Kind}"
                                       FontSize="10"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>

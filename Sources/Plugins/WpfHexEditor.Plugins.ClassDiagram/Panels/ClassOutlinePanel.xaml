<!--
    Project: WpfHexEditor.Plugins.ClassDiagram
    File: Panels/ClassOutlinePanel.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-19
    Description:
        VS-Like dockable panel that lists all class nodes in the active
        diagram document. Supports text search and single-node selection.
        Theme tokens: CD_* (from WpfHexEditor.Editor.ClassDiagram Themes/Generic.xaml).
-->
<UserControl x:Class="WpfHexEditor.Plugins.ClassDiagram.Panels.ClassOutlinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Editor.ClassDiagram.ViewModels;assembly=WpfHexEditor.Editor.ClassDiagram"
             Background="{DynamicResource DockMenuBackgroundBrush}">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockToolBarBorderBrush}"
                Padding="4,3">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="SearchBox"
                         Width="140"
                         Style="{DynamicResource PanelSearchBoxStyle}"
                         Tag="Search class names and kinds"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Border>

        <!-- Class tree with expandable members -->
        <TreeView x:Name="NodeTree"
                  ItemsSource="{Binding FilteredNodes}"
                  Background="{DynamicResource DockMenuBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0"
                  SelectedItemChanged="OnTreeSelectedItemChanged"
                  MouseDoubleClick="OnTreeDoubleClick"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <TreeView.Resources>
                <!-- Class node item -->
                <HierarchicalDataTemplate DataType="{x:Type vm:ClassNodeViewModel}"
                                          ItemsSource="{Binding MemberViewModels}">
                    <StackPanel Orientation="Horizontal" Margin="1,2">
                        <!-- Kind chip -->
                        <Border CornerRadius="3" Padding="3,0" Background="{Binding KindColor}"
                                Margin="0,0,5,0" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding KindLabel}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding KindLabel}" FontSize="9" Foreground="White"/>
                        </Border>
                        <!-- Class name (selectable read-only TextBox) -->
                        <TextBox Text="{Binding Name, Mode=OneWay}"
                                 IsReadOnly="True" BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource DockMenuForegroundBrush}"
                                 FontWeight="SemiBold" FontSize="12"
                                 IsTabStop="False" Focusable="False"
                                 Cursor="Arrow"/>
                    </StackPanel>
                </HierarchicalDataTemplate>

                <!-- Member sub-item -->
                <DataTemplate DataType="{x:Type vm:ClassMemberViewModel}">
                    <StackPanel Orientation="Horizontal" Margin="2,1">
                        <!-- Visibility ellipse -->
                        <Ellipse Width="7" Height="7" Fill="{Binding VisibilityColor}"
                                 VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <!-- Member text -->
                        <TextBox Text="{Binding OutlineDisplayText, Mode=OneWay}"
                                 IsReadOnly="True" BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{Binding KindBrush}"
                                 FontSize="11" IsTabStop="False" Focusable="False"
                                 Cursor="Arrow"
                                 ToolTipService.ShowDuration="8000">
                            <TextBox.ToolTip>
                                <TextBlock Text="{Binding TooltipText}" MaxWidth="300" TextWrapping="Wrap"
                                           FontSize="11"/>
                            </TextBox.ToolTip>
                        </TextBox>
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>
    </DockPanel>
</UserControl>

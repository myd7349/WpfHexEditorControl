<!--
    Project: WpfHexEditor.Plugins.ClassDiagram
    File: Panels/ClassHistoryPanel.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-19
    Description:
        VS-Like dockable history panel that mirrors the diagram undo stack.
        The current state is highlighted; clicking an entry requests a jump.
        Theme tokens: CD_* / DockMenu* global brushes.
-->
<UserControl x:Class="WpfHexEditor.Plugins.ClassDiagram.Panels.ClassHistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockMenuBackgroundBrush}">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockToolBarBorderBrush}"
                Padding="6,3">
            <TextBlock Text="Diagram History"
                       FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
        </Border>

        <!-- History list — most-recent at top -->
        <ListBox x:Name="HistoryList"
                 ItemsSource="{Binding Entries}"
                 Background="{DynamicResource DockMenuBackgroundBrush}"
                 Foreground="{DynamicResource DockMenuForegroundBrush}"
                 BorderThickness="0"
                 SelectionMode="Single"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 MouseLeftButtonUp="OnHistoryListClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
                    <Setter Property="Padding" Value="6,3"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,5,0"
                                   Foreground="{DynamicResource CD_NodeHeaderForeground}"/>
                        <TextBlock Text="{Binding Description}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>

    Created: 2026-03-19
    Description:
        Dockable panel listing all directed relationships in the active diagram.
        Allows selecting a relationship to highlight it on the canvas.
        Theme tokens: CD_* / DockMenu* global brushes.
-->
<UserControl x:Class="WpfHexEditor.Plugins.ClassDiagram.Panels.RelationshipsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockMenuBackgroundBrush}">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockToolBarBorderBrush}"
                Padding="6,3">
            <TextBlock Text="Relationships"
                       FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
        </Border>

        <!-- Relationships list -->
        <ListBox ItemsSource="{Binding Relationships}"
                 SelectedItem="{Binding SelectedRelationship, Mode=TwoWay}"
                 Background="{DynamicResource DockMenuBackgroundBrush}"
                 Foreground="{DynamicResource DockMenuForegroundBrush}"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="2,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding SourceId}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ArrowDescription}"
                                   FontSize="11"
                                   Margin="6,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource CD_NodeHeaderForeground}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding TargetId}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>

<!--
    Project: WpfHexEditor.Plugins.ClassDiagram
    File: Panels/DiagramSearchPanel.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-19
    Description:
        VS-Like dockable search panel for the class diagram editor.
        Searches class names and member names/types across the document.
        Theme tokens: CD_* / DockMenu* global brushes.
-->
<UserControl x:Class="WpfHexEditor.Plugins.ClassDiagram.Panels.DiagramSearchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockMenuBackgroundBrush}">

    <DockPanel>

        <!-- Search bar -->
        <Border DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockToolBarBorderBrush}"
                Padding="4,3">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="SearchBox"
                         Width="160"
                         Style="{DynamicResource PanelSearchBoxStyle}"
                         Tag="Search classes and members..."
                         ToolTip="Search classes and members (Enter)"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="OnSearchBoxKeyDown" />
                <Button Content="&#xE721;" FontFamily="Segoe MDL2 Assets"
                        FontSize="11"
                        Margin="4,0,0,0"
                        Padding="4,2"
                        VerticalAlignment="Center"
                        Background="{DynamicResource DockMenuBackgroundBrush}"
                        Foreground="{DynamicResource DockMenuForegroundBrush}"
                        BorderBrush="{DynamicResource DockToolBarBorderBrush}"
                        Click="OnSearchClick"
                        ToolTip="Run search"/>
            </StackPanel>
        </Border>

        <!-- Results count -->
        <TextBlock DockPanel.Dock="Top"
                   Margin="6,2"
                   FontSize="10"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.7">
            <Run Text="{Binding Results.Count, Mode=OneWay}"/>
            <Run Text=" result(s)"/>
        </TextBlock>

        <!-- Results list -->
        <ListBox ItemsSource="{Binding Results}"
                 SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                 Background="{DynamicResource DockMenuBackgroundBrush}"
                 Foreground="{DynamicResource DockMenuForegroundBrush}"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayText}"
                               FontSize="11"
                               FontFamily="Consolas"
                               Margin="2,2"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               ToolTip="{Binding DisplayText}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>

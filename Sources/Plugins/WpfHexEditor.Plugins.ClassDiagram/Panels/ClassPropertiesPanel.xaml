<!--
    Project: WpfHexEditor.Plugins.ClassDiagram
    File: Panels/ClassPropertiesPanel.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-19
    Description:
        F4-like properties panel for the active class diagram node or member.
        Shows a header (TypeInfo) and a property grid for editable fields.
        Theme tokens: CD_* / DockMenu* global brushes.
-->
<UserControl x:Class="WpfHexEditor.Plugins.ClassDiagram.Panels.ClassPropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockMenuBackgroundBrush}">

    <DockPanel>

        <!-- Toolbar / header -->
        <Border DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockToolBarBorderBrush}"
                Padding="6,4">
            <TextBlock Text="{Binding TypeInfo}"
                       FontSize="11"
                       FontStyle="Italic"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       ToolTip="{Binding TypeInfo}"/>
        </Border>

        <!-- No selection placeholder -->
        <TextBlock DockPanel.Dock="Top"
                   Text="No selection"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,24,0,0"
                   FontSize="12"
                   Foreground="{DynamicResource DockMenuForegroundBrush}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedObject}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Properties grid (shown when a node is selected) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="6">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedObject}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- Name row (read-only — rename via F2 on canvas) -->
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Name"
                               FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding NodeName}"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                </Grid>

                <!-- Kind row (read-only) -->
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Kind"
                               FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding NodeKind}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                </Grid>

                <!-- IsAbstract row -->
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Abstract"
                               FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <CheckBox Grid.Column="1"
                              IsChecked="{Binding NodeIsAbstract}"
                              VerticalAlignment="Center"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>

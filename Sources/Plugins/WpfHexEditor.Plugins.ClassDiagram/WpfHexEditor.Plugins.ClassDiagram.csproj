<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>WpfHexEditor.Plugins.ClassDiagram</RootNamespace>
    <AssemblyName>WpfHexEditor.Plugins.ClassDiagram</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>1.0.0</Version>
    <Authors>WpfHexEditor Contributors</Authors>
    <Description>Plugin that registers the Class Diagram editor panels, wires IDE focus context, and provides Solution Explorer context menu integration for generating class diagrams from C# source files.</Description>
    <!-- Plugin metadata required by WpfHexEditor.SDK.targets to generate manifest.json -->
    <PluginId>WpfHexEditor.Plugins.ClassDiagram</PluginId>
    <PluginName>Class Diagram</PluginName>
    <PluginVersion>1.0.0</PluginVersion>
    <PluginEntryPoint>WpfHexEditor.Plugins.ClassDiagram.ClassDiagramPlugin</PluginEntryPoint>
    <PluginAuthor>Derek Tremblay (derektremblay666@gmail.com)</PluginAuthor>
    <PluginPublisher>WpfHexEditor</PluginPublisher>
    <PluginTrustedPublisher>true</PluginTrustedPublisher>
    <PluginDescription>Visual class diagram editor with DSL/canvas split view, outline, relationships, search, history, toolbox, and properties panels. Generates diagrams from C# source files.</PluginDescription>
    <PluginIsolationMode>Auto</PluginIsolationMode>
    <PluginLoadPriority>35</PluginLoadPriority>
    <PluginSdkVersion>1.2.0</PluginSdkVersion>
    <PluginMinIDEVersion>0.3.0</PluginMinIDEVersion>
    <PluginPermAccessHexEditor>false</PluginPermAccessHexEditor>
    <PluginPermAccessFileSystem>true</PluginPermAccessFileSystem>
    <PluginPermAccessNetwork>false</PluginPermAccessNetwork>
    <PluginPermRegisterMenus>true</PluginPermRegisterMenus>
    <PluginPermWriteOutput>true</PluginPermWriteOutput>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Editors\WpfHexEditor.Editor.ClassDiagram\WpfHexEditor.Editor.ClassDiagram.csproj" />
    <ProjectReference Include="..\..\Editors\WpfHexEditor.Editor.ClassDiagram.Core\WpfHexEditor.Editor.ClassDiagram.Core.csproj" />
    <ProjectReference Include="..\WpfHexEditor.SDK\WpfHexEditor.SDK.csproj" />
    <ProjectReference Include="..\..\Editors\WpfHexEditor.Editor.Core\WpfHexEditor.Editor.Core.csproj" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core\WpfHexEditor.Core.csproj" />
  </ItemGroup>

  <Import Project="..\WpfHexEditor.SDK\Build\WpfHexEditor.SDK.targets" />

  <!-- Copy compiled plugin to App Plugins directory after build -->
  <Target Name="CopyToPluginsDir" AfterTargets="GeneratePluginManifest">
    <PropertyGroup>
      <PluginDestDir>$(MSBuildThisFileDirectory)..\..\WpfHexEditor.App\bin\$(Configuration)\net8.0-windows\Plugins\$(AssemblyName)\</PluginDestDir>
    </PropertyGroup>
    <MakeDir Directories="$(PluginDestDir)" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll;$(OutputPath)$(AssemblyName).deps.json;$(OutputPath)manifest.json"
          DestinationFolder="$(PluginDestDir)"
          SkipUnchangedFiles="true" />
  </Target>

</Project>

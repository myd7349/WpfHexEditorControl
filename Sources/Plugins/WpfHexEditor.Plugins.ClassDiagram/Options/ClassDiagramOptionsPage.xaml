<!--
    Project: WpfHexEditor.Plugins.ClassDiagram
    File: Options/ClassDiagramOptionsPage.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-19
    Description:
        Options page for the Class Diagram plugin.
        Shown in IDE Options > Plugins > Class Diagram
        and in Plugin Manager "Settings" tab.
        Theme: DynamicResource PFP_* tokens — consistent with all other
        plugin options pages (XamlDesigner, AssemblyExplorer, etc.).
-->
<UserControl x:Class="WpfHexEditor.Plugins.ClassDiagram.Options.ClassDiagramOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             Padding="12">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- ── Section: Layout ──────────────────────────────────────────── -->
            <TextBlock Text="Layout"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkAutoLayout"
                      Content="Auto-layout nodes when opening a generated diagram"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkGroupByNamespace"
                      Content="Group nodes by namespace during auto-layout"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <!-- Default node width -->
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Default node width (px):"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TxtNodeWidth"
                             Width="60"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Background="{DynamicResource PFP_SectionBackgroundBrush}"
                             Foreground="{DynamicResource PFP_TextBrush}"
                             BorderBrush="{DynamicResource PFP_BorderBrush}"
                             CaretBrush="{DynamicResource PFP_TextBrush}"
                             Padding="4,2"
                             FontSize="12"
                             MaxLength="5"
                             TextAlignment="Right"/>
                    <TextBlock Text="px"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- Default node height -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Default node height (px):"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="TxtNodeHeight"
                             Width="60"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Background="{DynamicResource PFP_SectionBackgroundBrush}"
                             Foreground="{DynamicResource PFP_TextBrush}"
                             BorderBrush="{DynamicResource PFP_BorderBrush}"
                             CaretBrush="{DynamicResource PFP_TextBrush}"
                             Padding="4,2"
                             FontSize="12"
                             MaxLength="5"
                             TextAlignment="Right"/>
                    <TextBlock Text="px"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Canvas ───────────────────────────────────────── -->
            <TextBlock Text="Canvas"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkShowGrid"
                      Content="Show dot-grid by default"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkSnapEnabled"
                      Content="Enable snap-to-grid by default"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <!-- Snap size -->
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Grid snap size (px):"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Slider x:Name="SnapSizeSlider"
                            Minimum="1" Maximum="64" TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Width="140"
                            VerticalAlignment="Center"
                            ValueChanged="OnSnapSizeChanged"/>
                    <TextBlock x:Name="SnapSizeLabel"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Source Analysis ──────────────────────────────── -->
            <TextBlock Text="Source Analysis"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource PFP_SubTextBrush}"
                       FontSize="11"
                       Margin="0,0,0,8">
                Controls how C# source files are parsed when using
                "View Class Diagram" or "Generate Class Diagram for Project"
                from Solution Explorer.
            </TextBlock>

            <CheckBox x:Name="ChkIncludePrivate"
                      Content="Include private and protected members"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkIncludeInherited"
                      Content="Include inherited members (requires full analysis)"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Minimap ──────────────────────────────────────── -->
            <TextBlock Text="Minimap"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkShowMinimapByDefault"
                      Content="Show minimap when diagram opens"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Outline Panel ────────────────────────────────── -->
            <TextBlock Text="Outline Panel"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkOutlineShowMembers"
                      Content="Show expandable member sub-items"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <CheckBox x:Name="ChkOutlineColorByVisibility"
                      Content="Color member dots by visibility (green / orange / red)"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Hover Tooltips ───────────────────────────────── -->
            <TextBlock Text="Hover Tooltips"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkShowHoverTooltips"
                      Content="Show detail tooltip on node hover"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,4"/>

            <!-- Tooltip delay -->
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Tooltip delay (ms):"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Slider x:Name="TooltipDelaySlider"
                            Minimum="100" Maximum="2000" TickFrequency="100"
                            IsSnapToTickEnabled="True"
                            Width="140"
                            VerticalAlignment="Center"
                            ValueChanged="OnTooltipDelayChanged"/>
                    <TextBlock x:Name="TooltipDelayLabel"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- ── Separator ─────────────────────────────────────────────── -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

            <!-- ── Section: Session ──────────────────────────────────────── -->
            <TextBlock Text="Session"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource PFP_AccentBrush}"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkRestoreLastState"
                      Content="Restore zoom, pan, selection, and minimap position on reopen"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      Margin="0,0,0,12"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

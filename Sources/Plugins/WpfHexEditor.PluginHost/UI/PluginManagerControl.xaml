<!--
    Project: WpfHexEditor.PluginHost
    File: PluginManagerControl.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-06
    Updated: 2026-03-07
    Description:
        Plugin Manager document-tab panel. VS-like two-column layout:
        left sidebar with grouped plugin list, filter/sort toolbar, context menu;
        right pane with plugin detail header, metrics, CPU/RAM sparkline charts,
        permissions tab, and settings tab.
        Phase 6: drag-drop .whxplugin install, export diagnostics, crash report.
    Theme: DynamicResource only — PM_* keys from PanelCommon.xaml + Colors.xaml.
    ContentId: "plugin-manager"
-->
<UserControl x:Class="WpfHexEditor.PluginHost.UI.PluginManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pb="clr-namespace:WpfHexEditor.ProgressBar.Controls;assembly=WpfHexEditor.ProgressBar"
             xmlns:local="clr-namespace:WpfHexEditor.PluginHost.UI"
             Background="{DynamicResource DockBackgroundBrush}"
             AllowDrop="True"
             Drop="OnPanelDrop"
             DragOver="OnPanelDragOver"
             DragLeave="OnPanelDragLeave">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NullToVisibilityConverter    x:Key="NullToVis"    Invert="False"/>
        <local:NullToVisibilityConverter    x:Key="NotNullToVis" Invert="True"/>
        <local:CountToVisibilityConverter   x:Key="ZeroToVis"/>

        <!-- Themed filter TextBox -->
        <Style x:Key="PM_FilterTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"    Value="{DynamicResource Panel_ToolbarBrush}"/>
            <Setter Property="Foreground"    Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource Panel_ToolbarBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush"    Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource PM_ListItemSelectedBrush}"/>
            <Setter Property="Padding"       Value="4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Context menu -->
        <ContextMenu x:Key="PM_PluginContextMenu"
                     Background="{DynamicResource DockMenuBackgroundBrush}"
                     BorderBrush="{DynamicResource DockMenuBorderBrush}"
                     BorderThickness="1" Padding="0,4">

            <MenuItem IsHitTestVisible="False" Focusable="False"
                      Background="{DynamicResource PM_CategoryHeaderBrush}"
                      Foreground="{DynamicResource PM_CategoryHeaderForegroundBrush}"
                      FontSize="10" FontWeight="SemiBold" Padding="10,3"
                      Header="PLUGIN ACTIONS"/>
            <MenuItem Header="Enable"  Foreground="{DynamicResource DockMenuForegroundBrush}" Click="OnContextEnable">
                <MenuItem.Icon><TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Disable" Foreground="{DynamicResource DockMenuForegroundBrush}" Click="OnContextDisable">
                <MenuItem.Icon><TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Reload"  Foreground="{DynamicResource DockMenuForegroundBrush}" Click="OnContextReload">
                <MenuItem.Icon><TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Toggle Watch Mode" Foreground="{DynamicResource DockMenuForegroundBrush}" Click="OnContextToggleWatchMode">
                <MenuItem.Icon><TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
            </MenuItem>

            <Separator Background="{DynamicResource DockMenuBorderBrush}" Margin="4,2"/>

            <MenuItem IsHitTestVisible="False" Focusable="False"
                      Background="{DynamicResource PM_CategoryHeaderBrush}"
                      Foreground="{DynamicResource PM_CategoryHeaderForegroundBrush}"
                      FontSize="10" FontWeight="SemiBold" Padding="10,3"
                      Header="DIAGNOSTIC"/>
            <MenuItem Header="Open Monitor Panel" Foreground="{DynamicResource DockMenuForegroundBrush}" Click="OnContextOpenMonitor">
                <MenuItem.Icon><TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Export Diagnostics" Foreground="{DynamicResource DockMenuForegroundBrush}" Click="OnContextExportDiagnostics">
                <MenuItem.Icon><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Export Crash Report" Foreground="{DynamicResource DockMenuForegroundBrush}" Click="OnContextExportCrashReport"
                      Visibility="{Binding SelectedPlugin.FaultMessage, Converter={StaticResource NotNullToVis}}">
                <MenuItem.Icon><TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Copy Plugin ID"    Foreground="{DynamicResource DockMenuForegroundBrush}" Click="OnContextCopyId">
                <MenuItem.Icon><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Copy Fault Message" Foreground="{DynamicResource DockMenuForegroundBrush}" Click="OnContextCopyFault"
                      Visibility="{Binding SelectedPlugin.FaultMessage, Converter={StaticResource NotNullToVis}}">
                <MenuItem.Icon><TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="12"/></MenuItem.Icon>
            </MenuItem>

            <Separator Background="{DynamicResource DockMenuBorderBrush}" Margin="4,2"/>

            <MenuItem Header="Uninstall..." Foreground="{DynamicResource DangerBrush}" Click="OnContextUninstall">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{DynamicResource DangerBrush}"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Background="{DynamicResource DockBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="180"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT SIDEBAR ═══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>   <!-- Toolbar -->
                <RowDefinition Height="30"/>   <!-- Filter + Sort -->
                <RowDefinition Height="*"/>    <!-- Plugin list -->
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border x:Name="ToolbarBorder"
                    Grid.Row="0"
                    Style="{DynamicResource PanelToolbarStyle}"
                    SizeChanged="OnToolbarSizeChanged">
                <DockPanel Margin="4,0">
                    <!-- Left: title — always visible -->
                    <TextBlock Text="PLUGINS" FontSize="10" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               DockPanel.Dock="Left"/>

                    <!-- Right: always-visible (Refresh) -->
                    <StackPanel x:Name="ToolbarRightPanel"
                                Orientation="Horizontal"
                                DockPanel.Dock="Right"
                                VerticalAlignment="Center">
                        <Button Style="{DynamicResource PanelIconButtonStyle}"
                                Content="&#xE72C;" ToolTip="Refresh Plugin List"
                                Command="{Binding RefreshCommand}"/>
                    </StackPanel>

                    <!-- Overflow button — shown only when groups are collapsed -->
                    <Button x:Name="ToolbarOverflowButton"
                            DockPanel.Dock="Right"
                            Visibility="Collapsed"
                            Style="{DynamicResource PanelIconButtonStyle}"
                            ToolTip="More options"
                            Click="OnOverflowButtonClick">
                        <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="OverflowContextMenu" Opened="OnOverflowMenuOpened">
                                <!-- TbgPluginDiag items -->
                                <MenuItem Header="Export Diagnostics"
                                          Tag="TbgPluginDiag"
                                          Click="OvfExportDiag_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator Tag="TbgPluginDiag"/>
                                <!-- TbgPluginInstall items -->
                                <MenuItem Header="Install Plugin…"
                                          Tag="TbgPluginInstall"
                                          Click="OvfInstall_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Group: TbgPluginInstall [1] last to collapse -->
                    <StackPanel x:Name="TbgPluginInstall"
                                Orientation="Horizontal"
                                DockPanel.Dock="Right"
                                VerticalAlignment="Center">
                        <Button Style="{DynamicResource PanelIconButtonStyle}"
                                Content="&#xE710;" ToolTip="Install Plugin from .whxplugin"
                                Command="{Binding InstallFromFileCommand}"/>
                    </StackPanel>

                    <!-- Group: TbgPluginDiag [0] first to collapse -->
                    <StackPanel x:Name="TbgPluginDiag"
                                Orientation="Horizontal"
                                DockPanel.Dock="Right"
                                VerticalAlignment="Center">
                        <Button Style="{DynamicResource PanelIconButtonStyle}"
                                Content="&#xE74E;" ToolTip="Export all diagnostics (CSV / JSON)"
                                Command="{Binding ExportDiagnosticsCommand}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Filter + Sort row -->
            <Grid Grid.Row="1" Margin="4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Filter by name, ID or author…"
                         Style="{StaticResource PM_FilterTextBoxStyle}"
                         Margin="0,0,2,0"/>
                <Button Grid.Column="1"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE711;" ToolTip="Clear Filter"
                        Command="{Binding ClearFilterCommand}"
                        Margin="0,0,2,0"/>
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SortBy}"
                          Style="{DynamicResource DockComboBoxStyle}"
                          ToolTip="Sort by"/>
            </Grid>

            <!-- Plugin list -->
            <Grid Grid.Row="2">
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding Plugins.Count, Converter={StaticResource ZeroToVis}}"
                            Margin="8">
                    <TextBlock Text="&#xE737;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                               HorizontalAlignment="Center" Opacity="0.3"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    <TextBlock Text="No plugins loaded" FontSize="11" Margin="0,6,0,2"
                               HorizontalAlignment="Center" Opacity="0.5"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    <TextBlock Text="Build the solution to copy plugins&#x0A;or use Install to add a .whxplugin"
                               FontSize="10" HorizontalAlignment="Center" Opacity="0.4"
                               TextAlignment="Center" TextWrapping="Wrap"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </StackPanel>

                <!-- Plugin list -->
                <ListBox x:Name="PluginListBox"
                         ItemsSource="{Binding Plugins}"
                         SelectedItem="{Binding SelectedPlugin}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Visibility="{Binding Plugins.Count, Converter={StaticResource ZeroToVis}, ConverterParameter=invert}"
                         ContextMenu="{StaticResource PM_PluginContextMenu}">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource PM_PluginListItemStyle}"/>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:PluginListItemViewModel}">
                            <Grid Margin="4,3" ToolTip="{Binding Description}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="10"/>   <!-- State dot -->
                                    <ColumnDefinition Width="*"/>    <!-- Name / meta / sparkline -->
                                    <ColumnDefinition Width="Auto"/> <!-- Badges -->
                                </Grid.ColumnDefinitions>

                                <!-- State dot -->
                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                         VerticalAlignment="Top" Margin="0,4,0,0"
                                         Fill="{Binding StateBadgeColor}"/>

                                <!-- Name / Publisher · version + mini CPU sparkline -->
                                <StackPanel Grid.Column="1" Margin="6,0,4,0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="10" Opacity="0.7"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}">
                                            <Run Text="{Binding Publisher, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding VersionLabel, Mode=OneWay}"/>
                                        </TextBlock>
                                        <!-- Mini CPU sparkline (40×14 px, green) -->
                                        <local:PluginSparklineControl
                                            Grid.Column="1"
                                            PointsSource="{Binding CpuHistory}"
                                            LineColor="#22C55E"
                                            MaxValue="100"
                                            StrokeThickness="1.0"
                                            Width="40" Height="14"
                                            VerticalAlignment="Center"
                                            ToolTip="{Binding CpuPercent, StringFormat='CPU: {0:F1}%'}"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Badges: STANDBY + SLOW + Memory Alert + Trusted -->
                                <StackPanel Grid.Column="2" Orientation="Vertical"
                                            VerticalAlignment="Center" Margin="0,0,2,0">
                                    <Border Background="#A855F7"
                                            CornerRadius="6" Padding="4,1" Margin="0,0,0,2"
                                            Visibility="{Binding IsDormant, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="STANDBY" FontSize="8" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <Border Background="{DynamicResource PM_BadgeSlowBrush}"
                                            CornerRadius="6" Padding="4,1" Margin="0,0,0,2"
                                            Visibility="{Binding IsSlow, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="SLOW" FontSize="8" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <!-- Memory Alert Badge -->
                                    <TextBlock Text="{Binding MemoryAlertIcon}" FontSize="11"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,2"
                                               ToolTip="{Binding MemoryAlertMessage}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MemoryAlertIcon}" Value="🟡">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MemoryAlertIcon}" Value="🟠">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MemoryAlertIcon}" Value="🔴">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="&#xE8A4;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{DynamicResource PM_BadgeTrustedBrush}"
                                               HorizontalAlignment="Center"
                                               Visibility="{Binding IsTrustedPublisher, Converter={StaticResource BoolToVis}}"
                                               ToolTip="Trusted Publisher"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!--
                    Drop hint overlay — shown while dragging a .whxplugin over the sidebar.
                    Controlled by code-behind via x:Name.
                -->
                <Border x:Name="DropHintOverlay"
                        Panel.ZIndex="10"
                        Background="#3360A5FA"
                        BorderBrush="#60A5FA"
                        BorderThickness="2"
                        CornerRadius="4"
                        Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="#60A5FA" HorizontalAlignment="Center"/>
                        <TextBlock Text="Drop .whxplugin to install" FontSize="11"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!--
                    Install progress overlay — shown while IsInstalling is true.
                -->
                <Border Panel.ZIndex="11"
                        Background="#CC1E1E1E"
                        CornerRadius="4"
                        Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="#60A5FA" HorizontalAlignment="Center"/>
                        <TextBlock Text="Installing…" FontSize="12" FontWeight="SemiBold"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,6"/>
                        <pb:LinearProgressBar IsIndeterminate="True" Width="140" Height="4" BarHeight="4"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource Panel_ToolbarBorderBrush}"/>

        <!-- ═══ RIGHT PANE ═══ -->
        <Grid Grid.Column="2">

            <!-- No selection placeholder -->
            <TextBlock Text="Select a plugin to view details"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Opacity="0.5"
                       Visibility="{Binding SelectedPlugin, Converter={StaticResource NullToVis}}"/>

            <!-- Detail pane (plugin selected) -->
            <Grid Visibility="{Binding SelectedPlugin, Converter={StaticResource NotNullToVis}}"
                  DataContext="{Binding SelectedPlugin}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Plugin header card -->
                    <RowDefinition Height="Auto"/> <!-- Dormant info banner (hidden when not Standby) -->
                    <RowDefinition Height="*"/>    <!-- Tabs -->
                </Grid.RowDefinitions>

                <!-- Plugin header card -->
                <Border Grid.Row="0"
                        Background="{DynamicResource Panel_ToolbarBrush}"
                        BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                        BorderThickness="0,0,0,1" Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Plugin icon -->
                        <Border Grid.Column="0" Width="32" Height="32"
                                Background="{DynamicResource Panel_ToolbarBorderBrush}"
                                CornerRadius="6" VerticalAlignment="Center">
                            <TextBlock Text="&#xECAA;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        </Border>

                        <!-- Name / publisher / version / isolation -->
                        <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <Border Background="{DynamicResource PM_BadgeTrustedBrush}"
                                        CornerRadius="8" Padding="5,1" Margin="6,2,0,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsTrustedPublisher, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="OFFICIAL" FontSize="8" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontSize="11" Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                           Opacity="0.8" VerticalAlignment="Center">
                                    <Run Text="{Binding Publisher, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding VersionLabel, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                </TextBlock>
                                <ComboBox ItemsSource="{Binding IsolationModes}"
                                          SelectedItem="{Binding SelectedIsolationMode}"
                                          IsEnabled="{Binding CanChangeIsolationMode}"
                                          FontSize="11"
                                          Background="{DynamicResource Panel_ToolbarBrush}"
                                          Foreground="{DynamicResource DockMenuForegroundBrush}"
                                          BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                                          VerticalAlignment="Center"
                                          Padding="4,1" MinWidth="80"/>
                                <TextBlock Text="⟳" FontSize="12" Margin="4,0,0,0"
                                           Foreground="{DynamicResource DockAccentBrush}"
                                           Visibility="{Binding IsReloading, Converter={StaticResource BoolToVis}}"
                                           VerticalAlignment="Center"
                                           ToolTip="Reloading plugin with new isolation mode…"/>
                                <TextBlock Text="{Binding ResolvedIsolationModeLabel}"
                                           FontSize="10" Margin="4,0,0,0"
                                           Foreground="{Binding ResolvedIsolationModeColor}"
                                           Opacity="0.85"
                                           VerticalAlignment="Center"
                                           ToolTip="Effective mode chosen by Auto decision engine">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedIsolationMode}" Value="Auto">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- State pill + action buttons -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0">
                            <Border CornerRadius="8" Padding="8,2" Margin="0,0,0,6"
                                    Background="{Binding StateBadgeColor}" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding StateLabel}" FontSize="10"
                                           FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <!-- Load Now: visible only for Dormant/Standby plugins -->
                            <Button Content="&#xE768; Load Now"
                                    Command="{Binding LoadNowCommand}"
                                    Visibility="{Binding IsDormant, Converter={StaticResource BoolToVis}}"
                                    Style="{DynamicResource PM_ActionButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,4" Padding="8,3" FontSize="11"
                                    ToolTip="Activate this plugin immediately (overrides lazy-load trigger)"/>
                            <!-- Suspend: visible for Loaded lazy-load plugins (onStartup=false) -->
                            <Button Content="&#xE769; Suspend"
                                    Command="{Binding SuspendCommand}"
                                    Style="{DynamicResource PM_ActionButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,4" Padding="8,3" FontSize="11"
                                    ToolTip="Unload plugin and return to Standby — re-activates on next trigger"/>
                            <!-- Move to Sandbox: visible only for InProcess + Loaded plugins -->
                            <Button Content="&#xE72A; Sandbox"
                                    Command="{Binding MigrateToSandboxCommand}"
                                    Visibility="{Binding CanMigrateToSandbox, Converter={StaticResource BoolToVis}}"
                                    Style="{DynamicResource PM_ActionButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,0" Padding="8,3" FontSize="11"
                                    FontFamily="Segoe MDL2 Assets"
                                    ToolTip="Reload this plugin in an isolated out-of-process Sandbox"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Dormant info banner: activation trigger hint (Row 1) -->
                <Border Grid.Row="1"
                        Margin="8,4,8,4"
                        Visibility="{Binding IsDormant, Converter={StaticResource BoolToVis}}">
                    <Border Background="#1FA855F7" BorderBrush="#A855F7" BorderThickness="1"
                            CornerRadius="4" Padding="8,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="#A855F7" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <StackPanel>
                                <TextBlock Text="Standby — activates automatically when triggered" FontSize="11"
                                           Foreground="#A855F7" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ActivationTriggerLabel}"
                                           FontSize="10" Opacity="0.8"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Single scrollable page: Info / Permissions / Settings -->
                <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,12,12,20">

                        <!-- ── Section: Info ────────────────────────────────── -->
                        <TextBlock Text="Info"
                                   FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   Margin="0,0,0,10"/>

                        <!-- Fault banner -->
                        <Border Background="#3EEF4444" CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                                Visibility="{Binding FaultMessage, Converter={StaticResource NotNullToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{DynamicResource PM_BadgeFaultedBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding FaultMessage}" FontSize="11"
                                           Foreground="{DynamicResource PM_BadgeFaultedBrush}"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Migration suggestion banner — shown when monitor flags this plugin -->
                        <Border Background="{DynamicResource WarningBannerBrush}"
                                BorderBrush="{DynamicResource WarningBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                                Visibility="{Binding MigrationSuggested, Converter={StaticResource BoolToVis}}">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="&#xE711;"
                                        FontFamily="Segoe MDL2 Assets" FontSize="10"
                                        Command="{Binding DismissMigrationSuggestionCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource WarningForegroundBrush}"
                                        Padding="4,2" Margin="4,0,0,0"
                                        ToolTip="Dismiss suggestion"/>
                                <Button DockPanel.Dock="Right"
                                        Content="Move to Sandbox"
                                        Command="{Binding MigrateToSandboxCommand}"
                                        Style="{DynamicResource PM_ActionButtonStyle}"
                                        Padding="8,2" FontSize="11"
                                        Margin="4,0,0,0"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource WarningForegroundBrush}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding MigrationSuggestionReason}"
                                               FontSize="11" TextWrapping="Wrap"
                                               Foreground="{DynamicResource WarningForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Description -->
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   Opacity="0.85" Margin="0,0,0,12"/>

                        <!-- METRICS label -->
                        <TextBlock Text="METRICS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                   Margin="0,0,0,4"/>

                        <!-- Metrics card: CPU / Mem / Init / AvgCall / Uptime -->
                        <Border Style="{DynamicResource PM_MetricCardStyle}" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Center"
                                            ToolTip="Process-level CPU — per-plugin isolation is not available in InProcess mode">
                                    <TextBlock Text="{Binding CpuPercent, StringFormat={}{0:F1}%}"
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="#22C55E"/>
                                    <TextBlock Text="Proc. CPU" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                    <TextBlock Text="{Binding PeakCpuPercent, StringFormat='peak {0:F1}%'}"
                                               FontSize="9" HorizontalAlignment="Center" Opacity="0.6"
                                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding MemoryMb, StringFormat={}{0} MB}"
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="#60A5FA"/>
                                    <TextBlock Text="Proc. Heap" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                               ToolTip="Total managed heap (process-wide, not per-plugin)"/>
                                    <TextBlock Text="{Binding PeakMemoryMb, StringFormat='peak {0} MB'}"
                                               FontSize="9" HorizontalAlignment="Center" Opacity="0.6"
                                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding InitTimeMs, StringFormat={}{0:F0} ms}"
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    <TextBlock Text="Init" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding AvgExecMs, StringFormat={}{0:F1} ms}"
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    <TextBlock Text="Avg Call" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding UptimeLabel}"
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    <TextBlock Text="Uptime" FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Loaded since -->
                        <TextBlock Margin="0,0,0,12" FontSize="11"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}">
                            <Run Text="Loaded since: "/><Run Text="{Binding LoadedSince, Mode=OneWay}"/>
                        </TextBlock>

                        <!-- CPU % Chart -->
                        <TextBlock Text="CPU % — History" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#22C55E" Margin="0,0,0,4"/>
                        <Border Height="70" Margin="0,0,0,10"
                                Background="{DynamicResource DockBackgroundBrush}"
                                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                                BorderThickness="1" CornerRadius="3">
                            <local:PluginSparklineControl
                                PointsSource="{Binding CpuHistory}"
                                LineColor="#22C55E"
                                MaxValue="100"
                                StrokeThickness="1.5"
                                Margin="6,6"/>
                        </Border>

                        <!-- Memory MB Chart -->
                        <TextBlock Text="Memory MB — History" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#60A5FA" Margin="0,0,0,4"/>
                        <Border Height="70" Margin="0,0,0,10"
                                Background="{DynamicResource DockBackgroundBrush}"
                                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                                BorderThickness="1" CornerRadius="3">
                            <local:PluginSparklineControl
                                PointsSource="{Binding MemoryHistory}"
                                LineColor="#60A5FA"
                                MaxValue="0"
                                StrokeThickness="1.5"
                                Margin="6,6"/>
                        </Border>

                        <Separator Margin="0,4,0,12" Background="{DynamicResource DockBorderBrush}"/>

                        <!-- ── Section: Permissions ──────────────────────────── -->
                        <TextBlock Text="Permissions"
                                   FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Toggle individual permissions for this plugin. Changes take effect immediately."
                                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Opacity="0.7"/>
                        <ItemsControl ItemsSource="{Binding Permissions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:PluginPermissionItemViewModel}">
                                    <Border Padding="8,6" Margin="0,0,0,4"
                                            Background="{DynamicResource Panel_ToolbarBrush}"
                                            BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                                            BorderThickness="1" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Label}" FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="10"
                                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                                           Opacity="0.65" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      IsChecked="{Binding IsGranted}"
                                                      VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- ── Section: Dormant Info (Lazy Loaded) ──────────── -->
                        <StackPanel Visibility="{Binding IsDormant, Converter={StaticResource BoolToVis}}">
                            <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>
                            <TextBlock Text="Lazy Loading"
                                       FontWeight="SemiBold" FontSize="13"
                                       Foreground="#A855F7" Margin="0,0,0,6"/>
                            <Border Padding="10,8" Margin="0,0,0,8"
                                    Background="{DynamicResource Panel_ToolbarBrush}"
                                    BorderBrush="#A855F7" BorderThickness="1" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Text="This plugin is dormant — it activates when a trigger is matched."
                                               FontSize="11" TextWrapping="Wrap"
                                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding ActivationTriggerLabel}"
                                               FontSize="11" FontStyle="Italic"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               Margin="0,0,0,8"/>
                                    <Button Content="Load Now"
                                            Command="{Binding LoadNowCommand}"
                                            HorizontalAlignment="Left"
                                            Style="{DynamicResource PM_PrimaryButtonStyle}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ── Section: ALC Diagnostics (InProcess only) ─────── -->
                        <StackPanel Visibility="{Binding IsInProcess, Converter={StaticResource BoolToVis}}">
                            <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>
                            <TextBlock Text="ALC Diagnostics"
                                       FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Margin="0,0,0,6"/>
                            <Border Padding="10,8" Margin="0,0,0,4"
                                    Background="{DynamicResource Panel_ToolbarBrush}"
                                    BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                                    BorderThickness="1" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding AlcAssemblyCount}"
                                                   FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                        <TextBlock Text="Assemblies" FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding AlcConflictCount}"
                                                   FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAlcConflicts}" Value="True">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Conflicts" FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding AssemblyConflictLabels}"
                                          Visibility="{Binding HasAlcConflicts, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="10"
                                                   Foreground="#F59E0B"
                                                   TextWrapping="Wrap" Margin="0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ── Section: Capability Features ─────────────────── -->
                        <StackPanel Visibility="{Binding HasFeatures, Converter={StaticResource BoolToVis}}">
                            <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>
                            <TextBlock Text="Capabilities"
                                       FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding Features}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,3" Margin="0,0,4,4"
                                                Background="{DynamicResource DockAccentBrush}"
                                                CornerRadius="10">
                                            <TextBlock Text="{Binding}" FontSize="10"
                                                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ── Section: Extension Points ─────────────────────── -->
                        <StackPanel Visibility="{Binding HasExtensions, Converter={StaticResource BoolToVis}}">
                            <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>
                            <TextBlock Text="Extension Points"
                                       FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding ExtensionLabels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                                   Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ── Section: Dependency Warnings ─────────────────── -->
                        <StackPanel Visibility="{Binding HasUnresolvedDeps, Converter={StaticResource BoolToVis}}">
                            <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>
                            <TextBlock Text="Dependency Errors"
                                       FontWeight="SemiBold" FontSize="13"
                                       Foreground="#EF4444" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding UnresolvedDepLabels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11"
                                                   Foreground="#EF4444"
                                                   TextWrapping="Wrap" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>


                        <!-- ── Section: Watch Mode (Dev Hot-Reload) ─────────── -->
                        <StackPanel>
                            <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>
                            <TextBlock Text="Watch Mode"
                                       FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Opacity="0.7"
                                       Margin="0,0,0,8"
                                       Text="Hot-reload this plugin automatically when its DLL is rebuilt. Select the plugin's build output directory."/>
                            <DockPanel LastChildFill="False">
                                <Button DockPanel.Dock="Left"
                                        Command="{Binding ToggleWatchModeCommand}"
                                        Style="{DynamicResource PM_ActionButtonStyle}"
                                        Margin="0,0,6,0">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding WatchModeLabel}"/>
                                        </StackPanel>
                                    </Button.Content>
                                </Button>
                                <Border DockPanel.Dock="Left"
                                        Background="{DynamicResource PM_CategoryHeaderBrush}"
                                        CornerRadius="4" Padding="6,2"
                                        Visibility="{Binding IsWatching, Converter={StaticResource BoolToVis}}"
                                        VerticalAlignment="Center">
                                    <TextBlock FontSize="10" FontWeight="Bold"
                                               Foreground="{Binding WatchModeBadgeColor}"
                                               Text="● WATCHING"/>
                                </Border>
                            </DockPanel>
                            <TextBlock FontSize="10" Opacity="0.6" Margin="0,4,0,0"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Visibility="{Binding IsWatching, Converter={StaticResource BoolToVis}}"
                                       Text="{Binding WatchDirectory, StringFormat='Directory: {0}'}"/>
                        </StackPanel>

                        <!-- ── Section: Settings (conditional) ──────────────── -->
                        <StackPanel Visibility="{Binding HasOptions, Converter={StaticResource BoolToVis}}">
                            <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>
                            <TextBlock Text="Settings"
                                       FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Margin="0,0,0,10"/>
                            <ContentPresenter Content="{Binding OptionsPage}"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

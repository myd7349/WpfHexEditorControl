    File:    UI/PluginDevLogPanel.xaml
    Description: Dockable panel rendering the PluginDevLog rolling buffer with
                 per-category filters, auto-scroll to bottom, and Clear action.
    Theme: DynamicResource only.
    ContentId: "plugin-dev-log"
-->
<UserControl x:Class="WpfHexEditor.PluginHost.UI.PluginDevLogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:phSvc="clr-namespace:WpfHexEditor.PluginHost.Services"
             xmlns:dev="clr-namespace:WpfHexEditor.PluginHost.DevTools"
             Background="{DynamicResource DockPanelBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <phSvc:PluginHostLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="4,4,4,2" LastChildFill="False">
            <CheckBox x:Name="PART_FilterInfo"      Content="{StaticResource PluginDevLog_Cat_Info}"      IsChecked="True" Margin="2,0" Click="OnFilterChanged"/>
            <CheckBox x:Name="PART_FilterLoad"      Content="{StaticResource PluginDevLog_Cat_Load}"      IsChecked="True" Margin="2,0" Click="OnFilterChanged"/>
            <CheckBox x:Name="PART_FilterUnload"    Content="{StaticResource PluginDevLog_Cat_Unload}"    IsChecked="True" Margin="2,0" Click="OnFilterChanged"/>
            <CheckBox x:Name="PART_FilterHotReload" Content="{StaticResource PluginDevLog_Cat_HotReload}" IsChecked="True" Margin="2,0" Click="OnFilterChanged"/>
            <CheckBox x:Name="PART_FilterCrash"     Content="{StaticResource PluginDevLog_Cat_Crash}"     IsChecked="True" Margin="2,0" Click="OnFilterChanged"/>
            <CheckBox x:Name="PART_FilterSlow"      Content="{StaticResource PluginDevLog_Cat_Slow}"      IsChecked="True" Margin="2,0" Click="OnFilterChanged"/>
            <Button   x:Name="PART_ClearBtn"
                      Content="{StaticResource PluginDevLog_Clear}"
                      DockPanel.Dock="Right"
                      Padding="6,1" Margin="6,0,0,0"
                      Click="OnClearClicked"/>
        </DockPanel>

        <ListView x:Name="PART_List"
                  Grid.Row="1"
                  Margin="4,2,4,4"
                  FontFamily="Consolas, Courier New"
                  FontSize="11"
                  Background="{DynamicResource TE_Background}"
                  Foreground="{DynamicResource TE_Foreground}"
                  BorderBrush="{DynamicResource DockBorderBrush}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{StaticResource PluginDevLog_Col_Timestamp}" Width="160" DisplayMemberBinding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}"/>
                    <GridViewColumn Header="{StaticResource PluginDevLog_Col_Category}"  Width="90"  DisplayMemberBinding="{Binding Category}"/>
                    <GridViewColumn Header="{StaticResource PluginDevLog_Col_PluginId}"  Width="220" DisplayMemberBinding="{Binding PluginId}"/>
                    <GridViewColumn Header="{StaticResource PluginDevLog_Col_Message}"   Width="500" DisplayMemberBinding="{Binding Message}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>

<!--
    Project: WpfHexEditor.PluginHost.UI
    File: PluginMonitoringPanel.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-06
    Updated: 2026-03-07
    Description:
        Docking panel for real-time plugin health monitoring.
        — Global CPU% and Memory MB line charts (Canvas+Polyline, no external lib)
        — Per-plugin sparkline columns in the DataGrid (SparklineControl)
        — Detail pane with TabControl: Overview / CPU+RAM / Permissions / Settings
        — Alert badge in toolbar, Export CSV/JSON buttons
        — Interactive permissions editor (DataGrid with checkboxes, risk badges)
        — Settings tab routed to IPluginWithOptions.CreateOptionsPage()
        — Install (.whxplugin drag-drop + toolbar button), Uninstall (context menu)
    Theme: DynamicResource only (PanelCommon.xaml via merged parent theme).
    ContentId: "plugin-monitor"
-->
<UserControl x:Class="WpfHexEditor.PluginHost.UI.PluginMonitoringPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.PluginHost.UI"
             xmlns:vm="clr-namespace:WpfHexEditor.PluginHost.UI"
             Background="{DynamicResource DockBackgroundBrush}"
             AllowDrop="True"
             Drop="OnPanelDrop"
             DragOver="OnPanelDragOver">

    <UserControl.Resources>
        <local:ChartPointsConverter x:Key="ChartPointsConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Used in DataGrid GroupStyle to resolve CollectionViewGroup.Name → PluginGroupSummaryViewModel -->
        <local:GroupSummaryConverter x:Key="GroupSummaryConverter"/>

        <!-- Export dropdown menu (opened programmatically on Export button click) -->
        <ContextMenu x:Key="ExportMenu" DataContext="{Binding}">
            <MenuItem Header="Export Metrics CSV"  Command="{Binding ExportCsvCommand}"/>
            <MenuItem Header="Export Metrics JSON" Command="{Binding ExportJsonCommand}"/>
            <Separator/>
            <MenuItem Header="Export Event Log…"   Command="{Binding ExportEventLogCommand}"/>
            <MenuItem Header="Copy Table"          Command="{Binding CopyTableCommand}"/>
        </ContextMenu>

        <!-- DataGrid column header -->
        <Style x:Key="MonitorColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"                 Value="{DynamicResource Panel_ToolbarBrush}"/>
            <Setter Property="Foreground"                 Value="{DynamicResource Panel_ToolbarForegroundBrush}"/>
            <Setter Property="BorderBrush"                Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness"            Value="0,0,1,1"/>
            <Setter Property="Padding"                    Value="6,4"/>
            <Setter Property="FontSize"                   Value="11"/>
            <Setter Property="FontWeight"                 Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- DataGrid cell -->
        <Style x:Key="MonitorCellStyle" TargetType="DataGridCell">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid row -->
        <Style x:Key="MonitorRowStyle" TargetType="DataGridRow">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected"   Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Panel_ToolbarBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Risk badge style -->
        <Style x:Key="RiskBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding"      Value="4,1"/>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>                 <!-- Row 0: Toolbar -->
            <RowDefinition Height="Auto"/>               <!-- Row 1: Filter chips strip -->
            <RowDefinition Height="Auto"/>               <!-- Row 2: Summary cards -->
            <RowDefinition Height="*" MinHeight="150"/>  <!-- Row 3: ContentGrid + TabControl detail -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
        <!-- ToolbarOverflowManager collapses groups right→left when too narrow. -->
        <!-- Collapse order: TbgPlugin(0) TbgLog(1) TbgCharts(2) TbgLayout(3) TbgInterval(4) TbgMonitor(5) -->
        <Border Grid.Row="0" x:Name="ToolbarBorder"
                Style="{DynamicResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="False" Margin="4,0">

                <!-- ── Fixed LEFT: title + health badge + alert badge (always visible) ── -->
                <StackPanel x:Name="ToolbarLeftPanel" DockPanel.Dock="Left"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PLUGIN MONITOR"
                               FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    <Border CornerRadius="3" Padding="5,1" Margin="8,0,4,0"
                            VerticalAlignment="Center" Background="{Binding HealthColor}">
                        <TextBlock Text="{Binding HealthLabel}" FontSize="10"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                    <Border CornerRadius="3" Padding="5,1" Margin="2,0,4,0"
                            VerticalAlignment="Center" Background="#F97316"
                            Visibility="{Binding HasAlerts, Converter={StaticResource BoolToVis}}"
                            ToolTip="Resource alerts triggered">
                        <TextBlock Text="{Binding AlertBadgeLabel}" FontSize="10"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- ── Fixed RIGHT: search box (always visible) — declared before left groups ── -->
                <StackPanel x:Name="ToolbarRightPanel" DockPanel.Dock="Right"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <Rectangle Width="1" Height="14" Margin="4,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                    <TextBox x:Name="SearchBox"
                             Width="90"
                             Style="{DynamicResource PanelSearchBoxStyle}"
                             Tag="Filter plugins…"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- ── Overflow button (right, just inside search) ── -->
                <Button x:Name="ToolbarOverflowButton" DockPanel.Dock="Right"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        ToolTip="More options" Visibility="Collapsed"
                        Click="OnOverflowButtonClick">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowContextMenu" Opened="OnOverflowMenuOpened">
                            <!-- TbgPlugin items -->
                            <MenuItem Header="Reload Selected Plugin"
                                      Click="OnOvfReloadPlugin" Tag="TbgPlugin"
                                      IsEnabled="{Binding HasSelectedPlugin}"/>
                            <MenuItem x:Name="OvfTogglePlugin" Header="Enable Plugin"
                                      Click="OnOvfTogglePlugin" Tag="TbgPlugin"
                                      IsEnabled="{Binding HasSelectedPlugin}"/>
                            <MenuItem Header="Install Plugin…"
                                      Click="OnOvfInstallPlugin" Tag="TbgPlugin"/>
                            <MenuItem Header="Uninstall Plugin"
                                      Click="OnOvfUninstallPlugin" Tag="TbgPlugin"
                                      IsEnabled="{Binding HasSelectedPlugin}"/>
                            <MenuItem Header="Export Crash Report"
                                      Click="OnOvfCrashReport" Tag="TbgPlugin"
                                      IsEnabled="{Binding HasFaultedPlugin}"/>
                            <Separator Tag="TbgPlugin"/>
                            <!-- TbgLog items -->
                            <MenuItem x:Name="OvfShowEventLog" Header="Show Event Log"
                                      IsCheckable="True" Click="OnOvfToggleEventLog" Tag="TbgLog"/>
                            <MenuItem Header="Clear Event Log"
                                      Click="OnOvfClearLog" Tag="TbgLog"/>
                            <Separator Tag="TbgLog"/>
                            <!-- TbgCharts items -->
                            <MenuItem x:Name="OvfShowSparklines" Header="Show Sparklines"
                                      IsCheckable="True" Click="OnOvfToggleSparklines" Tag="TbgCharts"/>
                            <MenuItem Header="Export Metrics CSV"  Command="{Binding ExportCsvCommand}"  Tag="TbgCharts"/>
                            <MenuItem Header="Export Metrics JSON" Command="{Binding ExportJsonCommand}" Tag="TbgCharts"/>
                            <MenuItem Header="Export Event Log…"   Command="{Binding ExportEventLogCommand}" Tag="TbgCharts"/>
                            <Separator Tag="TbgCharts"/>
                            <!-- TbgLayout items -->
                            <MenuItem Header="Layout" Tag="TbgLayout">
                                <MenuItem x:Name="OvfLayoutTop"    Header="Top"    IsCheckable="True" Tag="Top"    Click="OnOverflowLayoutClick"/>
                                <MenuItem x:Name="OvfLayoutBottom" Header="Bottom" IsCheckable="True" Tag="Bottom" Click="OnOverflowLayoutClick"/>
                                <MenuItem x:Name="OvfLayoutLeft"   Header="Left"   IsCheckable="True" Tag="Left"   Click="OnOverflowLayoutClick"/>
                                <MenuItem x:Name="OvfLayoutRight"  Header="Right"  IsCheckable="True" Tag="Right"  Click="OnOverflowLayoutClick"/>
                            </MenuItem>
                            <Separator Tag="TbgLayout"/>
                            <!-- TbgInterval items -->
                            <MenuItem Header="Interval" Tag="TbgInterval">
                                <MenuItem Header="1 s"  Click="OnOvfInterval" Tag="1"/>
                                <MenuItem Header="5 s"  Click="OnOvfInterval" Tag="5"/>
                                <MenuItem Header="10 s" Click="OnOvfInterval" Tag="10"/>
                                <MenuItem Header="30 s" Click="OnOvfInterval" Tag="30"/>
                            </MenuItem>
                            <Separator Tag="TbgInterval"/>
                            <!-- TbgMonitor items -->
                            <MenuItem x:Name="OvfStartStop" Header="Pause Monitoring"
                                      Click="OnOvfStartStop" Tag="TbgMonitor"/>
                            <MenuItem Header="Reset Chart History"
                                      Click="OnOvfReset" Tag="TbgMonitor"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- ── Group: TbgMonitor — Start/Pause, Reset (collapse last) ── -->
                <StackPanel x:Name="TbgMonitor" DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding StartStopCommand}" ToolTip="{Binding StartStopLabel}">
                        <TextBlock Text="{Binding StartStopIcon}" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ResetCommand}" ToolTip="Reset chart history and alerts">
                        <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Rectangle Width="1" Height="14" Margin="4,0" Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                </StackPanel>

                <!-- ── Group: TbgInterval — sampling interval combo ── -->
                <StackPanel x:Name="TbgInterval" DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Interval:" FontSize="10" VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,0"/>
                    <ComboBox x:Name="IntervalComboBox" FontSize="11" Width="50" Height="20"
                              VerticalContentAlignment="Center"
                              Background="{DynamicResource Panel_ToolbarBrush}"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              BorderBrush="{DynamicResource DockBorderBrush}"
                              SelectionChanged="OnIntervalSelectionChanged">
                        <ComboBoxItem Content="1 s"  Tag="1"/>
                        <ComboBoxItem Content="5 s"  Tag="5" IsSelected="True"/>
                        <ComboBoxItem Content="10 s" Tag="10"/>
                        <ComboBoxItem Content="30 s" Tag="30"/>
                    </ComboBox>
                    <Rectangle Width="1" Height="14" Margin="4,0" Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                </StackPanel>

                <!-- ── Group: TbgLayout — charts layout position combo ── -->
                <StackPanel x:Name="TbgLayout" DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Layout:" FontSize="10" VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,0"/>
                    <ComboBox x:Name="LayoutPositionCombo" FontSize="11" Width="65" Height="20"
                              VerticalContentAlignment="Center"
                              Background="{DynamicResource Panel_ToolbarBrush}"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              BorderBrush="{DynamicResource DockBorderBrush}"
                              ToolTip="Charts position relative to the plugin table"
                              SelectionChanged="OnLayoutPositionChanged">
                        <ComboBoxItem Content="Top"    Tag="Top"/>
                        <ComboBoxItem Content="Bottom" Tag="Bottom"/>
                        <ComboBoxItem Content="Left"   Tag="Left"/>
                        <ComboBoxItem Content="Right"  Tag="Right"/>
                    </ComboBox>
                    <Rectangle Width="1" Height="14" Margin="4,0" Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                </StackPanel>

                <!-- ── Group: TbgCharts — sparklines, event log, export ── -->
                <StackPanel x:Name="TbgCharts" DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ToggleSparklinesCommand}" ToolTip="{Binding ShowSparklinesLabel}">
                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ToggleEventLogCommand}" ToolTip="{Binding ShowEventLogTooltip}">
                        <TextBlock Text="{Binding ShowEventLogIcon}" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="ExportButton" Style="{DynamicResource PanelIconButtonStyle}"
                            ToolTip="Export…" Click="OnExportButtonClick">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Rectangle Width="1" Height="14" Margin="4,0" Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                </StackPanel>

                <!-- ── Group: TbgPlugin — plugin lifecycle actions ── -->
                <StackPanel x:Name="TbgPlugin" DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ReloadPluginCommand}"
                            ToolTip="Reload selected plugin" IsEnabled="{Binding HasSelectedPlugin}">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding TogglePluginCommand}"
                            ToolTip="{Binding TogglePluginLabel}" IsEnabled="{Binding HasSelectedPlugin}">
                        <TextBlock Text="{Binding TogglePluginIcon}" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding InstallPluginCommand}"
                            ToolTip="Install plugin from .whxplugin package">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding UninstallPluginCommand}"
                            ToolTip="Uninstall selected plugin" IsEnabled="{Binding HasSelectedPlugin}">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#EF4444"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ExportCrashReportCommand}"
                            ToolTip="Export crash report for selected plugin"
                            Visibility="{Binding HasFaultedPlugin, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#EF4444"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Rectangle Width="1" Height="14" Margin="4,0" Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                </StackPanel>

                <!-- ── Group: TbgLog — event log controls ── -->
                <StackPanel x:Name="TbgLog" DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ClearLogCommand}" ToolTip="Clear event log and alerts">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ── Filter chips strip ────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="0,0,0,1"
                Padding="6,2">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                           Text="{Binding VisibleCountLabel}" FontSize="9"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           Margin="0,0,4,0"/>
                <StackPanel Orientation="Horizontal">
                    <ToggleButton Style="{DynamicResource PanelIconToggleStyle}"
                                  IsChecked="{Binding FilterStateLoaded}"
                                  Padding="6,2" Margin="0,0,3,0"
                                  ToolTip="Show only loaded plugins">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#22C55E" VerticalAlignment="Center"/>
                            <TextBlock Text="Loaded" FontSize="9" Margin="4,0,0,0"
                                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{DynamicResource PanelIconToggleStyle}"
                                  IsChecked="{Binding FilterStateDisabled}"
                                  Padding="6,2" Margin="0,0,3,0"
                                  ToolTip="Show only disabled plugins">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#6B7280" VerticalAlignment="Center"/>
                            <TextBlock Text="Disabled" FontSize="9" Margin="4,0,0,0"
                                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{DynamicResource PanelIconToggleStyle}"
                                  IsChecked="{Binding FilterStateFaulted}"
                                  Padding="6,2" Margin="0,0,3,0"
                                  ToolTip="Show only faulted plugins">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="#EF4444" VerticalAlignment="Center"/>
                            <TextBlock Text="Faulted" FontSize="9" Margin="4,0,0,0"
                                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        </StackPanel>
                    </ToggleButton>
                    <Rectangle Width="1" Height="12" Margin="3,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                    <ToggleButton Style="{DynamicResource PanelIconToggleStyle}"
                                  IsChecked="{Binding FilterWarningsOnly}"
                                  Padding="6,2"
                                  ToolTip="Show only plugins with warnings or faults">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="#F59E0B" VerticalAlignment="Center"/>
                            <TextBlock Text="Warnings" FontSize="9" Margin="4,0,0,0"
                                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Summary cards ─────────────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="6,4,6,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource Panel_ToolbarBrush}"
                    CornerRadius="4" Margin="0,0,3,0" Padding="8,6">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrentCpu, StringFormat={}{0:F1}%}"
                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <TextBlock Text="CPU" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource Panel_ToolbarBrush}"
                    CornerRadius="4" Margin="3,0,3,0" Padding="8,6">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrentMemoryMb, StringFormat={}{0} MB}"
                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <TextBlock Text="Memory" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource Panel_ToolbarBrush}"
                    CornerRadius="4" Margin="3,0,3,0" Padding="8,6">
                <StackPanel HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding LoadedCount}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        <TextBlock Text="/" FontSize="18"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        <TextBlock Text="{Binding TotalCount}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Running" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="{DynamicResource Panel_ToolbarBrush}"
                    CornerRadius="4" Margin="3,0,0,0" Padding="8,6">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding FaultCount}" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <TextBlock Text="Faults" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Adaptive content area ───────────────────────────────────────────
             ContentGrid: portrait = 3 rows (charts / splitter / table)
                          landscape = 3 columns (charts | splitter | table)
             Code-behind rebuilds layout on SizeChanged.                     -->
        <!-- Inner grid: Row 0 = plugin list/charts (fills available space), Row 1 = detail pane (auto height).
             This structure ensures the outer GridSplitter (Row 4) directly resizes Row 3 (*) vs Row 5 (events *). -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="60"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto" MinHeight="0"/>
            </Grid.RowDefinitions>

        <Grid x:Name="ContentGrid" Grid.Row="0" Margin="6,4,6,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"  MinHeight="50"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="2*" MinHeight="50"/>
            </Grid.RowDefinitions>

            <!-- Charts area -->
            <Grid x:Name="ChartsArea" Grid.Row="0">
                <Grid x:Name="ChartsInnerGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Global CPU chart -->
                    <Grid x:Name="CpuChartGrid" Grid.Column="0">
                        <Border Background="{DynamicResource Panel_ToolbarBrush}" CornerRadius="4"/>
                        <TextBlock Text="CPU %" FontSize="9" FontWeight="SemiBold" Margin="6,4,0,0"
                                   VerticalAlignment="Top" HorizontalAlignment="Left"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        <Canvas x:Name="CpuChartCanvas" Margin="4,18,4,4" ClipToBounds="True">
                            <Polyline x:Name="CpuPolyline" Stroke="#22C55E" StrokeThickness="1.5" StrokeLineJoin="Round"/>
                        </Canvas>
                    </Grid>

                    <GridSplitter x:Name="ChartsInnerSplitter"
                                  Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource Panel_ToolbarBorderBrush}"/>

                    <!-- Global Memory chart -->
                    <Grid x:Name="MemChartGrid" Grid.Column="2">
                        <Border Background="{DynamicResource Panel_ToolbarBrush}" CornerRadius="4"/>
                        <TextBlock Text="Memory MB" FontSize="9" FontWeight="SemiBold" Margin="6,4,0,0"
                                   VerticalAlignment="Top" HorizontalAlignment="Left"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        <Canvas x:Name="MemChartCanvas" Margin="4,18,4,4" ClipToBounds="True">
                            <Polyline x:Name="MemPolyline" Stroke="#60A5FA" StrokeThickness="1.5" StrokeLineJoin="Round"/>
                        </Canvas>
                        <!-- GC cleanup event markers — amber dashed vertical lines, non-interactive -->
                        <Canvas x:Name="GcMarkerCanvas" Margin="4,18,4,4" ClipToBounds="True" IsHitTestVisible="False"/>
                    </Grid>
                </Grid>
            </Grid>

            <GridSplitter x:Name="ContentSplitter"
                          Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Panel_ToolbarBorderBrush}"/>

            <!-- ── Plugin table ──────────────────────────────────────────────── -->
            <DataGrid x:Name="PluginsDataGrid"
                      Grid.Row="2"
                      ItemsSource="{Binding FilteredRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource Panel_ToolbarBrush}"
                      ColumnHeaderStyle="{StaticResource MonitorColumnHeaderStyle}"
                      CellStyle="{StaticResource MonitorCellStyle}"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      SelectionChanged="OnPluginSelectionChanged">
                <DataGrid.Columns>

                    <!-- Warning badge (slow / not responsive) -->
                    <DataGridTemplateColumn Header="" Width="22" CanUserResize="False" SortMemberPath="HasWarning">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WarningIcon}" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{Binding WarningColor}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" ToolTip="{Binding WarningTooltip}"
                                           Visibility="{Binding HasWarning, Converter={StaticResource BoolToVis}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- State dot -->
                    <DataGridTemplateColumn Header="" Width="20" CanUserResize="False" SortMemberPath="StateColor">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="8" Height="8" HorizontalAlignment="Center"
                                         VerticalAlignment="Center" Fill="{Binding StateColor}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Plugin" Binding="{Binding Name}" Width="*" MinWidth="120"/>

                    <!-- State with fault tooltip -->
                    <DataGridTemplateColumn Header="State" Width="80" MinWidth="60" SortMemberPath="State">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding State}" ToolTip="{Binding FaultMessage}"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           VerticalAlignment="Center" Margin="4,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- CPU%: amber + "~" prefix for InProcess estimates, green for real Sandbox metrics -->
                    <DataGridTemplateColumn Header="CPU%" Width="65" MinWidth="55" SortMemberPath="WeightedCpu">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" Margin="4,2"
                                           ToolTip="{Binding CpuTooltip}">
                                    <Run Text="{Binding MetricsPrefix, Mode=OneWay}"/>
                                    <Run Text="{Binding WeightedCpu, StringFormat={}{0:F1}%, Mode=OneWay}"/>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMetricsEstimated}" Value="True">
                                                    <!-- Amber for estimated InProcess metrics -->
                                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--
                        Mini CPU sparkline — SparklineControl subscribes to CpuHistory.CollectionChanged
                        and auto-redraws. Visibility toggled by ShowSparklines via code-behind.
                    -->
                    <DataGridTemplateColumn x:Name="SparklineCpuColumn" Width="60" CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="CPU" Foreground="#22C55E" FontSize="10" FontWeight="SemiBold"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <local:SparklineControl
                                    PointsSource="{Binding MiniChart.CpuHistory}"
                                    LineColor="#22C55E"
                                    MaxValue="100"
                                    StrokeThickness="1.2"
                                    Height="20" Margin="2,1"
                                    ToolTip="{Binding WeightedCpu, StringFormat='Weighted CPU: {0:F1}%'}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Peak%"  Binding="{Binding PeakCpu, StringFormat={}{0:F1}%}"    Width="55" MinWidth="45"/>
                    <!-- Mem MB: amber for InProcess GC estimates, blue for real Sandbox private memory -->
                    <DataGridTemplateColumn Header="Mem MB" Width="65" MinWidth="55" SortMemberPath="MemoryDisplayMb">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" Margin="4,2"
                                           ToolTip="{Binding MemTooltip}">
                                    <Run Text="{Binding MetricsPrefix, Mode=OneWay}"/>
                                    <Run Text="{Binding MemoryDisplayMb, Mode=OneWay}"/>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMetricsEstimated}" Value="True">
                                                    <!-- Amber for estimated InProcess metrics -->
                                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--
                        Mini Memory sparkline — same pattern as CPU sparkline above.
                    -->
                    <DataGridTemplateColumn x:Name="SparklineMemColumn" Width="60" CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="Mem" Foreground="#60A5FA" FontSize="10" FontWeight="SemiBold"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <local:SparklineControl
                                    PointsSource="{Binding MiniChart.MemoryHistory}"
                                    LineColor="#60A5FA"
                                    MaxValue="0"
                                    StrokeThickness="1.2"
                                    Height="20" Margin="2,1"
                                    ToolTip="{Binding WeightedMemMb, StringFormat='Weighted Memory: {0} MB'}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Uptime"  Binding="{Binding UptimeLabel}"                              Width="65" MinWidth="50"/>
                    <DataGridTextColumn Header="Avg ms"  Binding="{Binding AvgExecMs, StringFormat={}{0:F1}}"        Width="60" MinWidth="50"/>
                    <DataGridTextColumn Header="Init ms" Binding="{Binding InitTimeMs, StringFormat={}{0:F0}}"       Width="60" MinWidth="50"/>
                    <DataGridTextColumn Header="Reload"  Binding="{Binding ReloadMode}"                              Width="50" MinWidth="45"
                                        ToolTipService.ToolTip="Fast = IWpfHexEditorPluginV2.SupportsHotReload; Full = full unload+GC+reload cycle"/>
                </DataGrid.Columns>

                <!--
                    DataGrid group headers: one row per isolation category (In Process / Sandbox).
                    DataContext of each GroupItem = CollectionViewGroup (Name, ItemCount).
                    GroupSummaryConverter maps (CollectionViewGroup, PluginMonitoringViewModel) → PluginGroupSummaryViewModel,
                    which is set as DataContext of the inner SummaryGrid so child bindings resolve naturally.
                    ExpandToggle (ToggleButton) controls ItemsPresenter visibility via ElementName binding.
                -->
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <StackPanel>
                                                <!-- Group header strip -->
                                                <Border Background="{DynamicResource DockGroupHeaderBrush}"
                                                        BorderBrush="{DynamicResource DockBorderBrush}"
                                                        BorderThickness="0,1,0,1"
                                                        Padding="4,3">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="20"/>   <!-- expand toggle -->
                                                            <ColumnDefinition Width="Auto"/> <!-- icon -->
                                                            <ColumnDefinition Width="Auto"/> <!-- category label -->
                                                            <ColumnDefinition Width="Auto"/> <!-- count chip -->
                                                            <ColumnDefinition Width="*"/>    <!-- spacer -->
                                                            <ColumnDefinition Width="Auto"/> <!-- CPU aggregate -->
                                                            <ColumnDefinition Width="Auto"/> <!-- Mem aggregate -->
                                                            <ColumnDefinition Width="Auto"/> <!-- metrics note -->
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Expand / collapse toggle -->
                                                        <ToggleButton x:Name="ExpandToggle"
                                                                      Grid.Column="0"
                                                                      IsChecked="True"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Center"
                                                                      Background="Transparent"
                                                                      BorderThickness="0"
                                                                      Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                                                      FontFamily="Segoe MDL2 Assets"
                                                                      FontSize="10"
                                                                      Padding="0"
                                                                      Cursor="Hand">
                                                            <ToggleButton.Style>
                                                                <Style TargetType="ToggleButton">
                                                                    <Setter Property="Content" Value="&#xE972;"/> <!-- ChevronDown -->
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <Border Background="Transparent" Padding="2">
                                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsChecked" Value="False">
                                                                            <Setter Property="Content" Value="&#xE974;"/> <!-- ChevronRight (collapsed) -->
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ToggleButton.Style>
                                                        </ToggleButton>

                                                        <!--
                                                            SummaryGrid: DataContext resolved to PluginGroupSummaryViewModel
                                                            via GroupSummaryConverter(CollectionViewGroup, PluginMonitoringViewModel).
                                                            RelativeSource AncestorType=DataGrid reaches the panel VM.
                                                        -->
                                                        <Grid Grid.Column="1" Grid.ColumnSpan="7">
                                                            <Grid.DataContext>
                                                                <MultiBinding Converter="{StaticResource GroupSummaryConverter}">
                                                                    <!-- CollectionViewGroup (outer DataContext) -->
                                                                    <Binding/>
                                                                    <!-- PluginMonitoringViewModel via DataGrid -->
                                                                    <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" Path="DataContext"/>
                                                                </MultiBinding>
                                                            </Grid.DataContext>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/> <!-- icon -->
                                                                <ColumnDefinition Width="Auto"/> <!-- category label -->
                                                                <ColumnDefinition Width="Auto"/> <!-- count chip -->
                                                                <ColumnDefinition Width="*"/>    <!-- spacer -->
                                                                <ColumnDefinition Width="Auto"/> <!-- CPU aggregate -->
                                                                <ColumnDefinition Width="Auto"/> <!-- Mem aggregate -->
                                                                <ColumnDefinition Width="Auto"/> <!-- metrics note -->
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Category icon (Segoe MDL2 glyph, colored) -->
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding CategoryIcon}"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="11"
                                                                       Foreground="{Binding CategoryColor}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,5,0"/>

                                                            <!-- Category label ("In Process" / "Sandbox") -->
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Category}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,6,0"/>

                                                            <!-- Count chip: "12/14" -->
                                                            <Border Grid.Column="2"
                                                                    Background="#22FFFFFF"
                                                                    CornerRadius="8"
                                                                    Padding="5,1"
                                                                    Margin="0,0,8,0"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding CountChip}"
                                                                           FontSize="10"
                                                                           Foreground="{Binding CategoryColor}"/>
                                                            </Border>

                                                            <!-- Aggregate CPU -->
                                                            <StackPanel Grid.Column="4" Orientation="Horizontal"
                                                                        Margin="0,0,12,0" VerticalAlignment="Center">
                                                                <TextBlock Text="CPU "
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                                                           Opacity="0.6"/>
                                                                <TextBlock Text="{Binding AggregateCpu, StringFormat={}{0:F1}%}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#4ADE80"/>
                                                            </StackPanel>

                                                            <!-- Aggregate Memory -->
                                                            <StackPanel Grid.Column="5" Orientation="Horizontal"
                                                                        Margin="0,0,12,0" VerticalAlignment="Center">
                                                                <TextBlock Text="Mem "
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                                                           Opacity="0.6"/>
                                                                <TextBlock Text="{Binding AggregateMem, StringFormat={}{0} MB}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#60A5FA"/>
                                                            </StackPanel>

                                                            <!-- Metrics quality note -->
                                                            <TextBlock Grid.Column="6"
                                                                       Text="{Binding MetricsNote}"
                                                                       FontSize="9"
                                                                       FontStyle="Italic"
                                                                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                                                       Opacity="0.5"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>

                                                <!-- Plugin rows — collapsed/expanded via ExpandToggle.IsChecked -->
                                                <ItemsPresenter Visibility="{Binding IsChecked, ElementName=ExpandToggle, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </DataGrid.GroupStyle>

                <!-- Context menu on each row: Reload / Enable-Disable / Open in Manager / Uninstall        -->
                <!-- DataContext fix: ContextMenu lives in a Popup (not in the visual tree).               -->
                <!-- RelativeSource AncestorType=UserControl does NOT work from a Popup.                   -->
                <!-- Solution: bind DataGridRow.Tag to the DataGrid's DataContext (PluginMonitoringViewModel)
                     while still in the visual tree, then read it back via PlacementTarget.Tag.            -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MonitorRowStyle}">
                        <!-- Carry the panel VM through the Tag so the ContextMenu (Popup) can reach it. -->
                        <Setter Property="Tag"
                                Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                        <!-- Select the row on right-click so _selectedPlugin is set before the menu opens. -->
                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnRowPreviewRightClick"/>
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <!-- PlacementTarget = the DataGridRow; Tag = PluginMonitoringViewModel -->
                                <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="Reload"
                                              Command="{Binding ReloadPluginCommand}"
                                              IsEnabled="{Binding HasSelectedPlugin}">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{Binding TogglePluginLabel}"
                                              Command="{Binding TogglePluginCommand}"
                                              IsEnabled="{Binding HasSelectedPlugin}">
                                        <MenuItem.Icon>
                                            <TextBlock Text="{Binding TogglePluginIcon}" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="Open in Plugin Manager"
                                              Command="{Binding OpenInPluginManagerCommand}"
                                              IsEnabled="{Binding HasSelectedPlugin}">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="Uninstall…"
                                              Command="{Binding UninstallPluginCommand}"
                                              IsEnabled="{Binding HasSelectedPlugin}">
                                        <MenuItem.Icon>
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="#EF4444"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <!--
                Drop-zone progress overlay — shown while IsInstalling is true.
                Rendered on top of the DataGrid so drag feedback is clearly visible.
            -->
            <Border Grid.Row="2"
                    Panel.ZIndex="10"
                    Background="#CC1E1E1E"
                    CornerRadius="6"
                    Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                               Foreground="#60A5FA" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Installing plugin…" FontSize="13" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <ProgressBar IsIndeterminate="True" Width="180" Height="4"
                                 Foreground="#60A5FA"/>
                </StackPanel>
            </Border>

            <!--
                Drag-target hint overlay — shown when a valid .whxplugin file is dragged over the panel.
                Controlled by code-behind via x:Name.
            -->
            <Border x:Name="DropHintOverlay"
                    Grid.Row="2"
                    Panel.ZIndex="9"
                    Background="#3360A5FA"
                    BorderBrush="#60A5FA"
                    BorderThickness="2"
                    CornerRadius="6"
                    Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                               Foreground="#60A5FA" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Drop .whxplugin to install" FontSize="12"
                               Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Splitter between plugin list and detail pane -->
        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      Background="{DynamicResource Panel_ToolbarBorderBrush}"/>

        <!-- ── Plugin detail pane — TabControl avec onglets Overview / Charts / Permissions / Settings ── -->
        <Border Grid.Row="2" Margin="6,0,6,0" MaxHeight="320"
                BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="0,1,0,0"
                Background="{DynamicResource Panel_ToolbarBrush}">
            <TabControl Background="Transparent" BorderThickness="0" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="{DynamicResource Panel_ToolbarBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Padding" Value="12,6"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter ContentSource="Header"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#60A5FA"/>
                                            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Tab 0: Events (nouveau premier onglet) -->
                <TabItem Header="📋 Events">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- En-tête avec bouton Clear -->
                        <Border Grid.Row="0" Background="{DynamicResource Panel_ToolbarBrush}"
                                BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="8,4">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Style="{DynamicResource PanelIconButtonStyle}"
                                        Command="{Binding ClearLogCommand}"
                                        ToolTip="Clear event log"
                                        Padding="6,2" Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="Clear" FontSize="10" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="EVENTS" FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                            </DockPanel>
                        </Border>

                        <!-- Liste des événements -->
                        <ListBox x:Name="EventLogListBox" Grid.Row="1"
                                 ItemsSource="{Binding EventLog}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="8,2">
                                        <TextBlock Text="{Binding TimeLabel}" FontSize="9" Width="50"
                                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                        <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                   Foreground="{Binding Color}" Width="20" Margin="4,0"/>
                                        <TextBlock Text="{Binding PluginName}" FontSize="9" FontWeight="SemiBold"
                                                   Width="120" TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Message}" FontSize="9"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>

                <!-- Tab 1: Overview -->
                <TabItem Header="📊 Overview" DataContext="{Binding SelectedPluginDetail}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8,8,8,16">
<!-- ── Section: Overview ──────────────────────────────────── -->
                    <TextBlock Text="Overview"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Margin="0,0,0,10"/>

                    <StackPanel>

                        <!-- name / version / trust / author -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse Width="8" Height="8" Fill="{Binding StateColor}"
                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Version, StringFormat=' v{0}'}" FontSize="10"
                                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                       VerticalAlignment="Center" Margin="4,0"/>
                            <Border CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                    VerticalAlignment="Center" Background="{DynamicResource DockBorderBrush}">
                                <TextBlock Text="{Binding TrustLabel}" FontSize="9"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                            </Border>
                            <TextBlock Text="{Binding Author, StringFormat=' — by {0}'}" FontSize="10"
                                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>

                        <!-- metrics grid (2×3 pairs) -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="V"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="V"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Loaded"    FontSize="9" VerticalAlignment="Center" Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LoadedAtLabel}"   FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Uptime"    FontSize="9" VerticalAlignment="Center" Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UptimeLabel}"     FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource DockMenuForegroundBrush}"/>

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Init"      FontSize="9" VerticalAlignment="Center" Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding InitTimeMsLabel}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Avg exec"  FontSize="9" VerticalAlignment="Center" Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding AvgExecMsLabel}"  FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource DockMenuForegroundBrush}"/>

                            <TextBlock Grid.Row="0" Grid.Column="6" Text="Peak CPU"  FontSize="9" VerticalAlignment="Center" Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="7" Text="{Binding PeakCpuLabel}"    FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="6" Text="Avg CPU"   FontSize="9" VerticalAlignment="Center" Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="7" Text="{Binding AvgCpuLabel}"     FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        </Grid>

                        <!-- fault message -->
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding FaultMessage}" FontSize="9" Foreground="#EF4444"
                                   TextWrapping="Wrap" MaxHeight="32" TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding HasFault, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>


                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Charts -->
                <TabItem Header="📈 Charts" DataContext="{Binding SelectedMiniChart}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8,8,8,16">
<!-- ── Section: CPU / RAM ──────────────────────────────────── -->
                    <TextBlock Text="CPU / RAM"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Margin="0,0,0,10"/>

                    <StackPanel>

                        <!-- CPU sparkline -->
                        <Grid Height="70" Margin="0,0,0,4">
                            <Border Background="{DynamicResource DockBackgroundBrush}" CornerRadius="3"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Left"
                                        Margin="4,2">
                                <TextBlock Text="CPU (est.)  " FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                <TextBlock Text="{Binding CurrentCpu, StringFormat={}{0:F1}%}"
                                           FontSize="9" FontWeight="SemiBold" Foreground="#22C55E"/>
                                <TextBlock Text="  peak: " FontSize="9"
                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                <TextBlock Text="{Binding PeakCpu, StringFormat={}{0:F1}%}"
                                           FontSize="9" FontWeight="SemiBold" Foreground="#22C55E"/>
                            </StackPanel>
                            <local:SparklineControl
                                PointsSource="{Binding CpuHistory}"
                                LineColor="#22C55E"
                                MaxValue="100"
                                StrokeThickness="1.5"
                                Margin="4,18,4,4"/>
                        </Grid>

                        <!-- Memory sparkline -->
                        <Grid Height="70">
                            <Border Background="{DynamicResource DockBackgroundBrush}" CornerRadius="3"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Left"
                                        Margin="4,2">
                                <TextBlock Text="Memory  " FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                <TextBlock Text="{Binding CurrentMemoryMb, StringFormat={}{0} MB}"
                                           FontSize="9" FontWeight="SemiBold" Foreground="#60A5FA"/>
                                <TextBlock Text="  peak: " FontSize="9"
                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                <TextBlock Text="{Binding PeakMemoryMb, StringFormat={}{0} MB}"
                                           FontSize="9" FontWeight="SemiBold" Foreground="#60A5FA"/>
                            </StackPanel>
                            <local:SparklineControl
                                PointsSource="{Binding MemoryHistory}"
                                LineColor="#60A5FA"
                                MaxValue="0"
                                StrokeThickness="1.5"
                                Margin="4,18,4,4"/>
                        </Grid>
                    </StackPanel>


                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 3: Permissions -->
                <TabItem Header="🔒 Permissions" DataContext="{Binding SelectedPluginDetail}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8,8,8,16">
<!-- ── Section: Permissions ──────────────────────────────────── -->
                    <TextBlock Text="Permissions"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Permission changes take effect after plugin reload."
                               FontSize="11" FontStyle="Italic" Opacity="0.65"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               Margin="0,0,0,8"/>

                    <DataGrid ItemsSource="{Binding PermissionRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              SelectionMode="Single"
                              Background="Transparent"
                              BorderThickness="0"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserSortColumns="False"
                              ColumnHeaderStyle="{StaticResource MonitorColumnHeaderStyle}"
                              CellStyle="{StaticResource MonitorCellStyle}"
                              RowStyle="{StaticResource MonitorRowStyle}">
                        <DataGrid.Columns>

                            <!-- Granted checkbox (two-way bound, calls PermissionService.Grant/Revoke) -->
                            <DataGridCheckBoxColumn Header="✓" Width="28"
                                Binding="{Binding IsGranted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Permission name -->
                            <DataGridTextColumn Header="Permission" Binding="{Binding Name}" Width="90" IsReadOnly="True"/>

                            <!-- Declared in manifest (checkmark / empty) -->
                            <DataGridTemplateColumn Header="Declared" Width="62" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Text="{Binding IsDeclared, Converter={x:Static local:BoolToCheckConverter.Instance}}"
                                                   Foreground="{Binding IsDeclared, Converter={x:Static local:BoolToGrantColorConverter.Instance}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Risk level badge -->
                            <DataGridTemplateColumn Header="Risk" Width="52" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource RiskBadgeStyle}"
                                                Background="{Binding RiskColor}" Margin="2,1">
                                            <TextBlock Text="{Binding RiskLevel}" FontSize="9"
                                                       Foreground="White" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Description -->
                            <DataGridTextColumn Header="Description"
                                                Binding="{Binding Description}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>


                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 4: Settings -->
                <TabItem Header="⚙️ Settings" Visibility="{Binding SelectedPluginDetail.HasOptions, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8,8,8,16">

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Border>

        </Grid><!-- end inner wrapper Grid (Row 3) -->
    </Grid>
</UserControl>

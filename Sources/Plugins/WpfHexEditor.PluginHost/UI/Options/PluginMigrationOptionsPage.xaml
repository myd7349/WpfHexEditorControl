<!--
    Project: WpfHexEditor.PluginHost
    File: PluginMigrationOptionsPage.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-15
    Description:
        Options page for the dynamic plugin migration feature.
        Registered in the IDE Options dialog under "Plugin System / Migration".
        Accessible via Tools > Plugin System Settings > Plugin System / Migration.
    Theme: DynamicResource only — PFP_* tokens from Colors.xaml (all 8 themes).
-->
<UserControl x:Class="WpfHexEditor.PluginHost.UI.Options.PluginMigrationOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             xmlns:phSvc="clr-namespace:WpfHexEditor.PluginHost.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <phSvc:PluginHostLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

            <!-- ── Section: Migration Mode ─────────────────────────────── -->
            <TextBlock Text="{StaticResource PH_MigrationMode}"
                       FontWeight="SemiBold" FontSize="13"
                       Foreground="{DynamicResource PFP_TextBrush}"
                       Margin="0,0,0,8"/>

            <DockPanel Margin="0,0,0,16">
                <TextBlock DockPanel.Dock="Left" Text="{StaticResource PH_ModeLabel}"
                           VerticalAlignment="Center"
                           Width="200"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <ComboBox x:Name="ModeComboBox"
                          Width="160" HorizontalAlignment="Left"
                          Background="{DynamicResource PFP_SectionBackgroundBrush}"
                          Foreground="{DynamicResource PFP_TextBrush}"
                          BorderBrush="{DynamicResource PFP_BorderBrush}"
                          SelectionChanged="OnModeChanged">
                    <ComboBoxItem Content="{StaticResource PH_ModeDisabled}"     Tag="Disabled"/>
                    <ComboBoxItem Content="{StaticResource PH_ModeSuggestOnly}" Tag="SuggestOnly"/>
                    <ComboBoxItem Content="{StaticResource PH_ModeAutoMigrate}" Tag="AutoMigrate"/>
                </ComboBox>
            </DockPanel>

            <TextBlock TextWrapping="Wrap" FontSize="11" Opacity="0.75"
                       Foreground="{DynamicResource PFP_TextBrush}" Margin="0,0,0,20">
                <Run FontWeight="Bold" Text="{StaticResource PH_ModeDisabled}"/><Run Text="{StaticResource PH_DisabledDesc}"/>
                <LineBreak/>
                <Run FontWeight="Bold" Text="{StaticResource PH_ModeSuggestOnly}"/><Run Text="{StaticResource PH_SuggestOnlyDesc}"/>
                <LineBreak/>
                <Run FontWeight="Bold" Text="{StaticResource PH_ModeAutoMigrate}"/><Run Text="{StaticResource PH_AutoMigrateDesc}"/>
            </TextBlock>

            <!-- Separator -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,16"/>

            <!-- ── Section: Memory Thresholds ──────────────────────────── -->
            <TextBlock Text="{StaticResource PH_MemoryThresholds}"
                       FontWeight="SemiBold" FontSize="13"
                       Foreground="{DynamicResource PFP_TextBrush}"
                       Margin="0,0,0,8"/>

            <DockPanel Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Left" Text="{StaticResource PH_SuggestAtMb}"
                           VerticalAlignment="Center" Width="200"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <TextBox x:Name="MemorySuggestTextBox"
                         Width="80" HorizontalAlignment="Left"
                         Background="{DynamicResource PFP_SectionBackgroundBrush}"
                         Foreground="{DynamicResource PFP_TextBrush}"
                         BorderBrush="{DynamicResource PFP_BorderBrush}"
                         CaretBrush="{DynamicResource PFP_TextBrush}"
                         Padding="4,2"/>
            </DockPanel>

            <DockPanel Margin="0,0,0,16">
                <TextBlock DockPanel.Dock="Left" Text="{StaticResource PH_AutoMigrateAtMb}"
                           VerticalAlignment="Center" Width="200"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <TextBox x:Name="MemoryAutoTextBox"
                         Width="80" HorizontalAlignment="Left"
                         Background="{DynamicResource PFP_SectionBackgroundBrush}"
                         Foreground="{DynamicResource PFP_TextBrush}"
                         BorderBrush="{DynamicResource PFP_BorderBrush}"
                         CaretBrush="{DynamicResource PFP_TextBrush}"
                         Padding="4,2"/>
            </DockPanel>

            <!-- Separator -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,16"/>

            <!-- ── Section: CPU Thresholds ──────────────────────────────── -->
            <TextBlock Text="{StaticResource PH_CpuThresholds}"
                       FontWeight="SemiBold" FontSize="13"
                       Foreground="{DynamicResource PFP_TextBrush}"
                       Margin="0,0,0,8"/>

            <DockPanel Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Left" Text="{StaticResource PH_SuggestAtPct}"
                           VerticalAlignment="Center" Width="200"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <TextBox x:Name="CpuSuggestTextBox"
                         Width="80" HorizontalAlignment="Left"
                         Background="{DynamicResource PFP_SectionBackgroundBrush}"
                         Foreground="{DynamicResource PFP_TextBrush}"
                         BorderBrush="{DynamicResource PFP_BorderBrush}"
                         CaretBrush="{DynamicResource PFP_TextBrush}"
                         Padding="4,2"/>
            </DockPanel>

            <DockPanel Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Left" Text="{StaticResource PH_AutoMigrateAtPct}"
                           VerticalAlignment="Center" Width="200"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <TextBox x:Name="CpuAutoTextBox"
                         Width="80" HorizontalAlignment="Left"
                         Background="{DynamicResource PFP_SectionBackgroundBrush}"
                         Foreground="{DynamicResource PFP_TextBrush}"
                         BorderBrush="{DynamicResource PFP_BorderBrush}"
                         CaretBrush="{DynamicResource PFP_TextBrush}"
                         Padding="4,2"/>
            </DockPanel>

            <DockPanel Margin="0,0,0,16">
                <TextBlock DockPanel.Dock="Left" Text="{StaticResource PH_SustainedWindow}"
                           VerticalAlignment="Center" Width="200"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <TextBox x:Name="CpuWindowTextBox"
                         Width="80" HorizontalAlignment="Left"
                         Background="{DynamicResource PFP_SectionBackgroundBrush}"
                         Foreground="{DynamicResource PFP_TextBrush}"
                         BorderBrush="{DynamicResource PFP_BorderBrush}"
                         CaretBrush="{DynamicResource PFP_TextBrush}"
                         Padding="4,2"/>
            </DockPanel>

            <!-- Separator -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,16"/>

            <!-- ── Section: Crash Threshold ──────────────────────────────── -->
            <TextBlock Text="{StaticResource PH_CrashThreshold}"
                       FontWeight="SemiBold" FontSize="13"
                       Foreground="{DynamicResource PFP_TextBrush}"
                       Margin="0,0,0,8"/>

            <DockPanel Margin="0,0,0,20">
                <TextBlock DockPanel.Dock="Left" Text="{StaticResource PH_MigrateAfterCrashes}"
                           VerticalAlignment="Center" Width="200"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <TextBox x:Name="CrashCountTextBox"
                         Width="80" HorizontalAlignment="Left"
                         Background="{DynamicResource PFP_SectionBackgroundBrush}"
                         Foreground="{DynamicResource PFP_TextBrush}"
                         BorderBrush="{DynamicResource PFP_BorderBrush}"
                         CaretBrush="{DynamicResource PFP_TextBrush}"
                         Padding="4,2"/>
            </DockPanel>

            <!-- Separator -->
            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,16"/>

            <!-- ── Action buttons ─────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal">
                <Button x:Name="SaveButton" Content="{StaticResource PH_SaveButton}"
                        Click="OnSave"
                        Padding="16,5" Margin="0,0,8,0"
                        Background="{DynamicResource DockAccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="12"/>
                <Button x:Name="ResetButton" Content="{StaticResource PH_ResetToDefaults}"
                        Click="OnResetDefaults"
                        Padding="12,5"
                        Background="{DynamicResource PFP_SectionBackgroundBrush}"
                        Foreground="{DynamicResource PFP_TextBrush}"
                        BorderBrush="{DynamicResource PFP_BorderBrush}"
                        BorderThickness="1"
                        FontSize="12"/>
            </StackPanel>

            <!-- Validation error message -->
            <TextBlock x:Name="ErrorMessage"
                       FontSize="11" Foreground="{DynamicResource DangerBrush}"
                       Visibility="Collapsed" Margin="0,8,0,0"
                       TextWrapping="Wrap"/>

            <!-- Save confirmation message -->
            <TextBlock x:Name="SavedMessage"
                       Text="{StaticResource PH_SettingsSaved}" FontSize="11"
                       Foreground="{DynamicResource DockAccentBrush}"
                       Visibility="Collapsed" Margin="0,8,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

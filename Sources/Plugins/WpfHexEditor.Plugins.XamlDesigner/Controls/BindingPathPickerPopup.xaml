<Popup x:Class="WpfHexEditor.Plugins.XamlDesigner.Controls.BindingPathPickerPopup"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       StaysOpen="False"
       AllowsTransparency="True"
       Placement="Bottom"
       Width="280"
       MaxHeight="320">

    <!-- ==========================================================
         Project: WpfHexEditor.Plugins.XamlDesigner
         File: BindingPathPickerPopup.xaml
         Description:
             VS-style binding property-path tree picker.
             Shows a filtered TreeView of the DataContext type's
             properties. Selecting a leaf fires PathSelected with
             the dotted path string.
         Theme: XD_BindingPickerBackground / XD_BindingPickerSelectedBrush
         ========================================================== -->

    <Border Background="{DynamicResource XD_BindingPickerBackground}"
            BorderBrush="{DynamicResource DockBorderBrush}"
            BorderThickness="1"
            CornerRadius="3"
            Padding="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- Filter bar -->
            <TextBox Grid.Row="0"
                     x:Name="FilterBox"
                     Margin="0,0,0,4"
                     Height="20"
                     FontSize="11"
                     Background="Transparent"
                     Foreground="{DynamicResource XD_PropertyValueForeground}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     BorderThickness="1"
                     VerticalContentAlignment="Center"
                     Padding="3,0"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="OnFilterChanged"/>

            <!-- Property tree -->
            <TreeView Grid.Row="1"
                      x:Name="PathTree"
                      Background="Transparent"
                      BorderThickness="0"
                      ItemsSource="{Binding RootNodes}"
                      SelectedItemChanged="OnSelectedItemChanged">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        <Setter Property="Foreground"  Value="{DynamicResource XD_PropertyNameForeground}"/>
                        <Setter Property="FontSize"    Value="11"/>
                        <Setter Property="Padding"     Value="2,1"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource XD_BindingPickerSelectedBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A2;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Margin="0,0,4,0"
                                       Foreground="{DynamicResource XD_PropertyValueForeground}"/>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource XD_PropertyNameForeground}"/>
                            <TextBlock Text=" : " Opacity="0.5" FontSize="10"
                                       Foreground="{DynamicResource XD_PropertyValueForeground}"/>
                            <TextBlock Text="{Binding TypeName}" FontSize="10"
                                       Foreground="{DynamicResource XD_PropertyValueForeground}"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- Accept bar -->
            <DockPanel Grid.Row="2" Margin="0,4,0,0">
                <Button DockPanel.Dock="Right"
                        Content="OK" Width="48" Height="20" FontSize="11"
                        Click="OnOkClick"/>
                <TextBlock x:Name="PathPreview"
                           VerticalAlignment="Center"
                           FontSize="10" FontStyle="Italic"
                           Foreground="{DynamicResource XD_PropertyValueForeground}"
                           Text="{Binding SelectedPath}"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Grid>
    </Border>
</Popup>

<!--
    Project: WpfHexEditor.Plugins.XamlDesigner
    File: Options/XamlDesignerOptionsPage.xaml
    Author: Derek Tremblay
    Created: 2026-03-16
    Description:
        Options page for the XAML Designer plugin.
        Shown in IDE Options > Plugins > XAML Designer
        and in Plugin Manager "Settings" tab.
        Theme: DynamicResource PFP_* tokens.
-->
<UserControl x:Class="WpfHexEditor.Plugins.XamlDesigner.Options.XamlDesignerOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             Padding="12">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

        <!-- Section: Preview -->
        <TextBlock Text="Live Preview"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <CheckBox x:Name="ChkAutoPreview"
                  Content="Enable live preview (re-renders design canvas on edit)"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Preview delay (ms):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Slider x:Name="PreviewDelaySlider"
                        Minimum="100" Maximum="2000" TickFrequency="100"
                        IsSnapToTickEnabled="True"
                        Width="140"
                        VerticalAlignment="Center"
                        ValueChanged="OnPreviewDelayChanged"/>
                <TextBlock x:Name="PreviewDelayLabel"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

        <!-- Section: Designer -->
        <TextBlock Text="Designer"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Default view mode:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <ComboBox x:Name="ViewModeCombo"
                      Grid.Column="1"
                      Width="160"
                      HorizontalAlignment="Left"
                      Background="{DynamicResource PFP_SectionBackgroundBrush}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      BorderBrush="{DynamicResource PFP_BorderBrush}">
                <ComboBoxItem Content="Split (code + design)" Tag="Split" IsSelected="True"/>
                <ComboBoxItem Content="Code only"             Tag="CodeOnly"/>
                <ComboBoxItem Content="Design only"           Tag="DesignOnly"/>
            </ComboBox>
        </Grid>

        <CheckBox x:Name="ChkSnapToGrid"
                  Content="Snap elements to grid when dragging"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Grid snap size (px):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBox x:Name="TxtSnapSize"
                         Width="50"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Background="{DynamicResource PFP_SectionBackgroundBrush}"
                         Foreground="{DynamicResource PFP_TextBrush}"
                         BorderBrush="{DynamicResource PFP_BorderBrush}"
                         CaretBrush="{DynamicResource PFP_TextBrush}"
                         Padding="4,2"
                         FontSize="12"
                         MaxLength="3"
                         TextAlignment="Right"/>
                <TextBlock Text="px"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

        <!-- Section: Property Inspector -->
        <TextBlock Text="Property Inspector"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <CheckBox x:Name="ChkShowDefaultProps"
                  Content="Show properties with default values"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

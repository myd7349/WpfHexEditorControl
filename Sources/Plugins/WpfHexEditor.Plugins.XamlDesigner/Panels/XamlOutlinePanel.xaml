<UserControl x:Class="WpfHexEditor.Plugins.XamlDesigner.Panels.XamlOutlinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.XamlDesigner.ViewModels"
             Background="{DynamicResource DockBackgroundBrush}">

    <UserControl.Resources>

        <!-- ── Icon button style matching VS-Like panel standard ── -->
        <Style x:Key="XD_IconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Search TextBox style ── -->
        <Style x:Key="XD_SearchBox" TargetType="TextBox">
            <Setter Property="Width"           Value="120"/>
            <Setter Property="Height"          Value="18"/>
            <Setter Property="Padding"         Value="4,1"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background"      Value="{DynamicResource XD_PanelToolbarBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource DockTabActiveBrush}"/>
        </Style>

        <!-- ── TreeViewItem style ── -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded"                 Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected"                 Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <!-- MEMORY.md rule: IsMouseOver must use Property Trigger, never DataTrigger -->
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DockTabActiveTextBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Breadcrumb chevron item style ── -->
        <Style x:Key="XD_BreadcrumbItem" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"     Value="0,0,4,0"/>
        </Style>

        <!-- ── Inline rename TextBox style ── -->
        <Style x:Key="XD_InlineRenameBox" TargetType="TextBox">
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Padding"     Value="2,0"/>
            <Setter Property="Background"  Value="{DynamicResource XD_PanelToolbarBrush}"/>
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockTabActiveBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource DockTabActiveBrush}"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="MinWidth"    Value="80"/>
        </Style>

        <!-- ── BoolToVisibility converter (collapsed when false) ── -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: Toolbar (26px) -->
            <RowDefinition Height="26"/>
            <!-- Row 1: Content (*) -->
            <RowDefinition Height="*"/>
            <!-- Row 2: Breadcrumb bar (22px) -->
            <RowDefinition Height="22"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- Row 0 — Toolbar                                           -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border x:Name="ToolbarBorder" Grid.Row="0"
                Background="{DynamicResource XD_PanelToolbarBrush}"
                BorderBrush="{DynamicResource XD_PanelToolbarBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">

                <!-- Right anchor: overflow button -->
                <StackPanel x:Name="ToolbarRightPanel" DockPanel.Dock="Right"
                            Orientation="Horizontal" Margin="2,0,2,0"
                            VerticalAlignment="Center">

                    <!-- Element count label -->
                    <TextBlock x:Name="TbxElementCount"
                               Text="{Binding ElementCountLabel}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="4,0,6,0"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Opacity="0.65"
                               ToolTip="Total elements in outline"/>

                    <!-- Overflow toggle -->
                    <ToggleButton x:Name="ToolbarOverflowButton"
                                  Width="22" Height="22" Padding="3"
                                  Background="Transparent" BorderThickness="0"
                                  FontFamily="Segoe MDL2 Assets" FontSize="11"
                                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                                  Content="&#xE712;" ToolTip="More options"
                                  Visibility="Collapsed"/>
                </StackPanel>

                <!-- Left group: navigation buttons + search box -->
                <StackPanel x:Name="TbgNavigation" DockPanel.Dock="Left"
                            Orientation="Horizontal" Margin="2,0,0,0"
                            VerticalAlignment="Center">

                    <Button x:Name="BtnExpandAll" Style="{StaticResource XD_IconButton}"
                            Content="&#xE9A0;" ToolTip="Expand All"/>
                    <Button x:Name="BtnCollapseAll" Style="{StaticResource XD_IconButton}"
                            Content="&#xE972;" ToolTip="Collapse All"/>
                    <Button x:Name="BtnSyncToCode" Style="{StaticResource XD_IconButton}"
                            Content="&#xE8B0;" ToolTip="Sync selection to code editor"/>

                    <!-- Separator -->
                    <Rectangle Width="1" Height="14" Margin="3,0"
                               Fill="{DynamicResource DockBorderBrush}"
                               VerticalAlignment="Center"/>

                    <Button x:Name="BtnRefreshOutline" Style="{StaticResource XD_IconButton}"
                            ToolTip="Rebuild outline from current XAML"
                            Click="OnRefreshOutline">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE72C;"/>
                    </Button>
                    <Button x:Name="BtnNavigateToParent" Style="{StaticResource XD_IconButton}"
                            ToolTip="Select parent element"
                            Click="OnNavigateToParent">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE96F;"/>
                    </Button>
                    <Button x:Name="BtnCopyPath" Style="{StaticResource XD_IconButton}"
                            ToolTip="Copy element XAML path to clipboard"
                            Click="OnCopyPath">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE8C8;"/>
                    </Button>

                    <!-- Separator -->
                    <Rectangle Width="1" Height="14" Margin="3,0"
                               Fill="{DynamicResource DockBorderBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Search filter TextBox with placeholder -->
                    <Grid VerticalAlignment="Center">
                        <TextBox x:Name="TbxSearch"
                                 Style="{StaticResource XD_SearchBox}"
                                 ToolTip="Filter elements by name or tag"/>
                        <!-- Placeholder text — hidden when TextBox has content -->
                        <TextBlock x:Name="TbxSearchPlaceholder"
                                   Text="Search elements…"
                                   FontSize="11"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   Opacity="0.4"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- Row 1 — XAML Outline Tree                                 -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <TreeView x:Name="OutlineTree" Grid.Row="1"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0"
                  ItemsSource="{Binding RootNodes}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">

            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type vm:XamlOutlineNode}"
                                          ItemsSource="{Binding Children}">

                    <!-- Each row dims when IsMatch = False -->
                    <Grid Opacity="{Binding DimOpacity}"
                          Margin="2,1">
                        <Grid.ColumnDefinitions>
                            <!-- Col 0: element icon (14px) -->
                            <ColumnDefinition Width="14"/>
                            <!-- Col 1: display label or inline rename TextBox (*) -->
                            <ColumnDefinition Width="*"/>
                            <!-- Col 2: error badge (16px, auto-hidden) -->
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── Element type icon (Segoe MDL2) ── -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding ElementIcon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="11"
                                   Width="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>

                        <!-- ── Display label (normal view) ── -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DisplayLabel}"
                                   FontSize="11"
                                   Margin="3,0,2,0"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- ── Inline rename TextBox (visible only during IsEditing) ── -->
                        <TextBox x:Name="InlineRenameBox"
                                 Grid.Column="1"
                                 Text="{Binding EditLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="2,0"
                                 VerticalAlignment="Center"
                                 Tag="{Binding}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource XD_InlineRenameBox}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- ── Error badge (⚠) — visible only when HasError = True ── -->
                        <TextBlock Grid.Column="2"
                                   Text="&#x26A0;"
                                   FontSize="10"
                                   Margin="2,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#E8A000"
                                   ToolTip="{Binding ErrorMessage}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- ── Row context menu ── -->
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="CtxRename"
                                          Header="Rename"
                                          Tag="Rename">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8AC;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="CtxDelete"
                                          Header="Delete"
                                          Tag="Delete">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE74D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem x:Name="CtxMoveUp"
                                          Header="Move Up"
                                          Tag="MoveUp">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE74A;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="CtxMoveDown"
                                          Header="Move Down"
                                          Tag="MoveDown">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE74B;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem x:Name="CtxWrapGrid"
                                          Header="Wrap in Grid"
                                          Tag="Grid">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE80A;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="CtxWrapStackPanel"
                                          Header="Wrap in StackPanel"
                                          Tag="StackPanel">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8FD;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="CtxWrapBorder"
                                          Header="Wrap in Border"
                                          Tag="Border">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE81E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem x:Name="CtxNavigateToXaml"
                                          Header="Navigate to XAML"
                                          Tag="Navigate">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8B0;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Grid.ContextMenu>
                    </Grid>

                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- Row 2 — Breadcrumb bar                                    -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource XD_PanelToolbarBrush}"
                BorderBrush="{DynamicResource XD_PanelToolbarBorderBrush}"
                BorderThickness="0,1,0,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Padding="4,0">
                <ItemsControl x:Name="BreadcrumbBar"
                              ItemsSource="{Binding BreadcrumbItems}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding}"
                                           Style="{StaticResource XD_BreadcrumbItem}"/>
                                <!-- Chevron separator — not shown for the last item
                                     (handled in code-behind by checking index) -->
                                <TextBlock Text="&#xE76C;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="8"
                                           Margin="0,0,4,0"
                                           Opacity="0.5"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>

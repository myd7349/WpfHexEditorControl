<UserControl
    x:Class="WpfHexEditor.Plugins.XamlDesigner.Panels.AnimationTimelinePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:WpfHexEditor.Plugins.XamlDesigner.Panels"
    xmlns:vm="clr-namespace:WpfHexEditor.Plugins.XamlDesigner.ViewModels"
    xmlns:models="clr-namespace:WpfHexEditor.Editor.XamlDesigner.Models;assembly=WpfHexEditor.Editor.XamlDesigner"
    xmlns:ctrl="clr-namespace:WpfHexEditor.Editor.XamlDesigner.Controls;assembly=WpfHexEditor.Editor.XamlDesigner"
    MinHeight="140"
             xmlns:xdSvc="clr-namespace:WpfHexEditor.Plugins.XamlDesigner.Services">

    <!-- ==========================================================
         Project: WpfHexEditor.Plugins.XamlDesigner
         File: AnimationTimelinePanel.xaml
         Created: 2026-03-17 | Updated: 2026-03-19
         Moved to plugin project: 2026-03-22
         Description: Animation Timeline dockable panel.
                      Toolbar: Stop, Play/Pause, Add/Delete Keyframe, Loop,
                               AutoReverse, FrameRate, Export, Duration/Time labels,
                               Storyboard name dropdown.
                      Track headers: PropertyIcon glyph + label + Remove button.
                      Context-matching tracks: lighter background via DataTrigger.
         Theme: XD_* + Dock* tokens (DynamicResource)
         ========================================================== -->

    <UserControl.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <xdSvc:XamlDesignerLocalizedDictionary/>
                </ResourceDictionary.MergedDictionaries>


        <!-- Shared toolbar button style -->
        <Style x:Key="TlButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2" Padding="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle button style for Loop/AutoReverse -->
        <Style x:Key="TlToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="PART_Border" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4" Padding="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="PART_Border" Property="Background"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                                <Setter TargetName="PART_Border" Property="BorderBrush"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Track list item style — context-match gets lighter BG -->
        <Style x:Key="TrackListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="Margin"     Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="PART_Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource DockBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Height="24">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="PART_Bd" Property="Background"
                                        Value="{DynamicResource XD_TimelineBackground}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsContextMatch}" Value="True">
                                <Setter TargetName="PART_Bd" Property="Background"
                                        Value="{DynamicResource XD_ContextMatchTrackBrush}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Keyframe dot style -->
        <Style x:Key="KeyframeDotStyle" TargetType="Ellipse">
            <Setter Property="Width"            Value="8"/>
            <Setter Property="Height"           Value="8"/>
            <Setter Property="Fill"             Value="{DynamicResource XD_KeyframeThumbBrush}"/>
            <Setter Property="Stroke"           Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="StrokeThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Thin separator helper -->
        <Style x:Key="TlSepStyle" TargetType="Separator">
            <Setter Property="Width"      Value="1"/>
            <Setter Property="Margin"     Value="4,4"/>
            <Setter Property="Background" Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Rectangle Width="{TemplateBinding Width}"
                                   Fill="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

                </ResourceDictionary>
        </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>  <!-- Toolbar -->
            <RowDefinition Height="22"/>  <!-- Ruler -->
            <RowDefinition Height="*"/>   <!-- Tracks -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DockBorderBrush}"
                Background="{DynamicResource XD_PanelToolbarBrush}">
            <DockPanel VerticalAlignment="Center" Margin="4,0">

                <!-- Right-aligned: Duration label + Time label + Storyboard dropdown -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Storyboard name dropdown -->
                    <ComboBox ItemsSource="{Binding StoryboardNames}"
                              SelectedItem="{Binding ActiveStoryboardName, Mode=TwoWay}"
                              Height="18" MinWidth="90" FontSize="10"
                              Background="Transparent"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              BorderBrush="{DynamicResource DockBorderBrush}"
                              ToolTip="{StaticResource XamlDesigner_ActiveStoryboard}"
                              Margin="4,0"/>

                    <Separator Style="{StaticResource TlSepStyle}"/>

                    <!-- Duration display -->
                    <TextBlock VerticalAlignment="Center" FontSize="10"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="4,0,0,0">
                        <Run Text="{StaticResource XamlDesigner_DurLabel}"/>
                        <Run Text="{Binding Duration, StringFormat={}{0:mm\\:ss\\.ff}, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Current time display -->
                    <TextBlock VerticalAlignment="Center" FontSize="10"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="6,0,4,0">
                        <Run Text="T:"/>
                        <Run Text="{Binding CurrentTime, StringFormat={}{0:mm\\:ss\\.ff}, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Left-aligned controls -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Stop -->
                    <Button Style="{StaticResource TlButtonStyle}"
                            Content="&#xE71A;" ToolTip="{StaticResource XamlDesigner_Stop}"
                            Command="{Binding StopCommand}"/>

                    <!-- Play / Pause toggle -->
                    <Button Style="{StaticResource TlButtonStyle}" ToolTip="{StaticResource XamlDesigner_PlayPause}"
                            Command="{Binding PlayCommand}"
                            x:Name="BtnPlay">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE768;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Text" Value="&#xE769;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>

                    <Separator Style="{StaticResource TlSepStyle}"/>

                    <!-- Add Keyframe -->
                    <Button Style="{StaticResource TlButtonStyle}"
                            Content="&#xE710;" ToolTip="{StaticResource XamlDesigner_AddKeyframe}"
                            Command="{Binding AddKeyframeCommand}"
                            Click="OnAddKeyframeClick"/>

                    <!-- Delete Keyframe -->
                    <Button Style="{StaticResource TlButtonStyle}"
                            Content="&#xE74D;" ToolTip="{StaticResource XamlDesigner_DeleteKeyframe}"
                            Command="{Binding DeleteKeyframeCommand}"
                            Click="OnDeleteKeyframeClick"/>

                    <Separator Style="{StaticResource TlSepStyle}"/>

                    <!-- Loop toggle -->
                    <ToggleButton Style="{StaticResource TlToggleButtonStyle}"
                                  Content="&#xE8EE;" ToolTip="{StaticResource XamlDesigner_LoopPlayback}"
                                  IsChecked="{Binding IsLooping, Mode=TwoWay}"/>

                    <!-- AutoReverse toggle -->
                    <ToggleButton Style="{StaticResource TlToggleButtonStyle}"
                                  Content="&#xE7C4;" ToolTip="{StaticResource XamlDesigner_AutoReverse}"
                                  IsChecked="{Binding AutoReverse, Mode=TwoWay}"/>

                    <Separator Style="{StaticResource TlSepStyle}"/>

                    <!-- Playback speed multiplier -->
                    <ComboBox x:Name="CbxPlaybackSpeed"
                              Width="55"
                              VerticalAlignment="Center"
                              ToolTip="{StaticResource XamlDesigner_PlaybackSpeed}"
                              ItemsSource="{x:Static vm:AnimationTimelinePanelViewModel.AvailablePlaybackSpeeds}"
                              SelectedItem="{Binding PlaybackSpeed, Mode=TwoWay}"
                              Height="18" FontSize="10"
                              Background="Transparent"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              BorderBrush="{DynamicResource DockBorderBrush}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="10">
                                    <Run Text="{Binding Mode=OneWay}"/>
                                    <Run Text="x"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Zoom in timeline -->
                    <Button x:Name="BtnZoomIn"
                            Style="{StaticResource TlButtonStyle}" ToolTip="{StaticResource XamlDesigner_ZoomInTimeline}"
                            Command="{Binding ZoomInCommand}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE8A3;"/>
                    </Button>

                    <!-- Zoom out timeline -->
                    <Button x:Name="BtnZoomOut"
                            Style="{StaticResource TlButtonStyle}" ToolTip="{StaticResource XamlDesigner_ZoomOutTimeline}"
                            Command="{Binding ZoomOutCommand}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE71F;"/>
                    </Button>

                    <Separator Style="{StaticResource TlSepStyle}"/>

                    <!-- FrameRate ComboBox -->
                    <ComboBox ItemsSource="{x:Static vm:AnimationTimelinePanelViewModel.AvailableFrameRates}"
                              SelectedItem="{Binding FrameRate, Mode=TwoWay}"
                              Height="18" Width="54" FontSize="10"
                              Background="Transparent"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              BorderBrush="{DynamicResource DockBorderBrush}" ToolTip="{StaticResource XamlDesigner_FrameRate}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="10">
                                    <Run Text="{Binding Mode=OneWay}"/>
                                    <Run Text="fps"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Separator Style="{StaticResource TlSepStyle}"/>

                    <!-- Export to clipboard -->
                    <Button Style="{StaticResource TlButtonStyle}"
                            Content="&#xE8C8;" ToolTip="{StaticResource XamlDesigner_ExportStoryboard}"
                            Command="{Binding ExportStoryboardCommand}"/>

                    <!-- Add track -->
                    <Button Style="{StaticResource TlButtonStyle}"
                            Content="&#xE948;" ToolTip="{StaticResource XamlDesigner_AddTrack}"
                            Command="{Binding AddTrackCommand}"/>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Time Ruler ───────────────────────────────────────────── -->
        <ctrl:TimelineRuler Grid.Row="1"
                            x:Name="TimeRuler"
                            Duration="{Binding Duration}"
                            CurrentTime="{Binding CurrentTime}"
                            SeekRequested="OnRulerSeekRequested"
                            Height="22"
                            Cursor="SizeWE"/>

        <!-- ── Track list + keyframe area ──────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Track header list -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Tracks}"
                     SelectedItem="{Binding SelectedTrack}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                     Background="{DynamicResource DockBackgroundBrush}"
                     BorderThickness="0"
                     x:Name="TrackHeaders">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:AnimationTrackViewModel}">
                        <Grid x:Name="TrackHeaderRoot">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Property type icon -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PropertyIcon}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       Width="16"
                                       VerticalAlignment="Center"
                                       Margin="4,0,2,0"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>

                            <!-- Track label -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TrackLabel}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Padding="0,0,4,0"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>

                            <!-- Remove track button — shown when row is hovered (code-behind wires visibility) -->
                            <Button Grid.Column="2"
                                    x:Name="BtnRemoveTrack"
                                    Width="14" Height="14"
                                    Margin="0,0,2,0"
                                    FontFamily="Segoe MDL2 Assets" FontSize="9"
                                    Content="&#xE8BB;"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                                    Cursor="Hand" Visibility="Hidden" ToolTip="{StaticResource XamlDesigner_RemoveTrack}"
                                    Command="{Binding DataContext.RemoveTrackCommand,
                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <!-- Show remove button when hovering over the row -->
                            <DataTrigger Binding="{Binding IsMouseOver,
                                         RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                         Value="True">
                                <Setter TargetName="BtnRemoveTrack" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource TrackListItemStyle}">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Column separator -->
            <GridSplitter Grid.Column="1"
                          Width="3"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"/>

            <!-- Keyframe lanes (Canvas per track) -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          x:Name="LaneScroller">
                <ItemsControl ItemsSource="{Binding Tracks}"
                              x:Name="KeyframeLanes">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:AnimationTrackViewModel}">
                            <Canvas Height="24"
                                    Background="Transparent"
                                    ClipToBounds="True"
                                    x:Name="LaneCanvas"
                                    Loaded="OnLaneLoaded"
                                    Tag="{Binding}"
                                    PreviewMouseLeftButtonDown="OnLanePreviewMouseDown"
                                    PreviewMouseMove="OnLanePreviewMouseMove"
                                    PreviewMouseLeftButtonUp="OnLanePreviewMouseUp"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- Easing curve editor popup — opens when a keyframe is selected -->
            <Popup x:Name="EasingPopup"
                   Grid.Column="2"
                   IsOpen="{Binding HasSelectedKeyframe}"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=LaneScroller}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="{DynamicResource DockBackgroundBrush}"
                        BorderBrush="{DynamicResource DockBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="6">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Easing Curve"
                                   FontSize="11"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   Margin="0,0,0,4"/>
                        <ctrl:EasingCurveEditor x:Name="EasingEditor"
                                                Width="200" Height="200"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</UserControl>

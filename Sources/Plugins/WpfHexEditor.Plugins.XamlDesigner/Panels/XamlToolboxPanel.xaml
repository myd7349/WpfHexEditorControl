<UserControl x:Class="WpfHexEditor.Plugins.XamlDesigner.Panels.XamlToolboxPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.XamlDesigner.ViewModels"
             xmlns:models="clr-namespace:WpfHexEditor.Editor.XamlDesigner.Models;assembly=WpfHexEditor.Editor.XamlDesigner">

    <!-- ==========================================================
         Project: WpfHexEditor.Plugins.XamlDesigner
         File: XamlToolboxPanel.xaml
         Created: 2026-03-17 | Updated: 2026-03-19
         Moved to plugin project: 2026-03-22
         Description: VS-Like dockable XAML Toolbox panel.
                      Toolbar: Search TextBox | Favorites toggle.
                      Content: Favorites section, Recent section,
                               grouped category items (60px tall,
                               24px icon + 11px label).
                      Items dimmed (0.35 opacity) when search non-match.
                      Star button in item context menu.
         Theme: XD_* tokens (DynamicResource)
         ========================================================== -->

    <UserControl.Resources>

        <!-- Toolbar button style -->
        <Style x:Key="TbxToolButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource XD_PropertyNameForeground}"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="1,0"/>
        </Style>

        <!-- Toggle button for Favorites filter -->
        <Style x:Key="FavToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Foreground"      Value="{DynamicResource XD_PropertyNameForeground}"/>
            <Setter Property="ToolTip"         Value="Show favorites"/>
            <Setter Property="Content"         Value="&#xE734;"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4" Padding="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                                <Setter Property="Foreground" Value="Gold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="{DynamicResource XD_PropertyNameForeground}"/>
            <Setter Property="Opacity"     Value="0.7"/>
            <Setter Property="Margin"      Value="6,4,0,2"/>
        </Style>

        <!-- Toolbox item ListBoxItem style -->
        <Style x:Key="ToolboxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height"          Value="60"/>
            <Setter Property="Padding"         Value="4"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource XD_ToolboxItemHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource XD_ToolboxItemHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Category group header button style -->
        <Style x:Key="CategoryHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource XD_PropertyGroupHeaderBackground}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource XD_PropertyNameForeground}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="4,3"/>
        </Style>

        <!-- Item DataTemplate used in both sections and category groups -->
        <DataTemplate x:Key="ToolboxItemDataTemplate" DataType="{x:Type models:ToolboxItem}">
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="56">
                <TextBlock Text="{Binding IconGlyph}"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="24"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource XD_PropertyNameForeground}"/>
                <TextBlock Text="{Binding Name}"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource XD_PropertyValueForeground}"/>
            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border x:Name="ToolbarBorder" Grid.Row="0"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource XD_PanelToolbarBrush}"
                BorderBrush="{DynamicResource XD_PanelToolbarBorderBrush}">
            <DockPanel Margin="4,0" VerticalAlignment="Center">

                <!-- Favorites toggle (right-aligned) -->
                <ToggleButton DockPanel.Dock="Right"
                              x:Name="BtnFavoritesToggle"
                              Style="{StaticResource FavToggleStyle}"
                              Checked="OnFavoritesToggleChanged"
                              Unchecked="OnFavoritesToggleChanged"/>

                <!-- Clear Recent -->
                <Button DockPanel.Dock="Right"
                        x:Name="BtnClearRecent"
                        Style="{StaticResource TbxToolButtonStyle}"
                        ToolTip="Clear recently used items"
                        Click="OnClearRecent">
                    <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </Button>

                <!-- Collapse all categories -->
                <Button DockPanel.Dock="Right"
                        x:Name="BtnCollapseAllCategories"
                        Style="{StaticResource TbxToolButtonStyle}"
                        ToolTip="Collapse all categories"
                        Click="OnCollapseAllCategories">
                    <TextBlock Text="&#xE972;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </Button>

                <!-- Expand all categories -->
                <Button DockPanel.Dock="Right"
                        x:Name="BtnExpandAllCategories"
                        Style="{StaticResource TbxToolButtonStyle}"
                        ToolTip="Expand all categories"
                        Click="OnExpandAllCategories">
                    <TextBlock Text="&#xE9A0;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                </Button>

                <!-- Sort -->
                <Button DockPanel.Dock="Right"
                        x:Name="BtnSortBy"
                        Style="{StaticResource TbxToolButtonStyle}"
                        ToolTip="Sort toolbox items"
                        Click="OnToolboxSortClick">
                    <TextBlock Text="&#xE174;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Name (A–Z)"    Tag="ByNameAZ"   Click="OnToolboxSortSelected"/>
                            <MenuItem Header="By Category"   Tag="ByCategory" Click="OnToolboxSortSelected"/>
                            <MenuItem Header="Recently Used" Tag="ByRecent"   Click="OnToolboxSortSelected"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Separator between sort buttons and search box -->
                <Separator DockPanel.Dock="Right" Width="1" Margin="4,3"
                           Background="{DynamicResource DockBorderBrush}">
                    <Separator.Template>
                        <ControlTemplate TargetType="Separator">
                            <Rectangle Width="{TemplateBinding Width}"
                                       Fill="{TemplateBinding Background}"/>
                        </ControlTemplate>
                    </Separator.Template>
                </Separator>

                <!-- Search icon + TextBox -->
                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,4,0"
                           Foreground="{DynamicResource XD_PropertyNameForeground}"/>
                <TextBox x:Name="TbxFilter"
                         Height="18" FontSize="11"
                         Background="Transparent"
                         Foreground="{DynamicResource XD_PropertyValueForeground}"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         Padding="2,0"
                         ToolTip="Search controls…"
                         TextChanged="OnSearchTextChanged"/>
            </DockPanel>
        </Border>

        <Rectangle Grid.Row="1" Fill="{DynamicResource DockBorderBrush}"/>

        <!-- ── Main content ─────────────────────────────────────── -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="MainContentPanel">

                <!-- ── Favorites section ── -->
                <StackPanel x:Name="FavoritesSection" Visibility="Collapsed">
                    <TextBlock Text="Favorites" Style="{StaticResource SectionHeaderStyle}"/>
                    <WrapPanel x:Name="FavoritesWrap"
                               Orientation="Horizontal"
                               Margin="4,0,4,4"/>
                </StackPanel>

                <!-- ── Recent section ── -->
                <StackPanel x:Name="RecentSection" Visibility="Collapsed">
                    <TextBlock Text="Recent" Style="{StaticResource SectionHeaderStyle}"/>
                    <WrapPanel x:Name="RecentWrap"
                               Orientation="Horizontal"
                               Margin="4,0,4,4"/>
                </StackPanel>

                <!-- ── Category grouped list ── -->
                <ListBox x:Name="ToolboxList"
                         ItemsSource="{Binding ItemsView}"
                         SelectedItem="{Binding SelectedItem}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         PreviewMouseMove="OnListPreviewMouseMove"
                         MouseDoubleClick="OnListDoubleClick">

                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="GroupItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GroupItem">
                                                <StackPanel>
                                                    <!-- Category header button -->
                                                    <Button Style="{StaticResource CategoryHeaderButtonStyle}"
                                                            Tag="{Binding Name}"
                                                            Click="OnCategoryHeaderClick">
                                                        <DockPanel>
                                                            <!-- Collapse arrow -->
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       x:Name="CollapseArrow"
                                                                       Text="&#xE70D;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,4,0"
                                                                       Foreground="{DynamicResource XD_PropertyNameForeground}"/>
                                                            <!-- Category name + count -->
                                                            <TextBlock>
                                                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                                                <Run Text=" ("/>
                                                                <Run Text="{Binding ItemCount, Mode=OneWay}"/>
                                                                <Run Text=")"/>
                                                            </TextBlock>
                                                        </DockPanel>
                                                    </Button>
                                                    <!-- Items panel -->
                                                    <WrapPanel x:Name="CategoryItemsPanel"
                                                               Orientation="Horizontal"
                                                               IsItemsHost="True"
                                                               Margin="4,2"/>
                                                </StackPanel>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </ListBox.GroupStyle>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource ToolboxItemStyle}">
                            <Style.Triggers>
                                <!-- Context menu for each item -->
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ToolboxItem}">
                            <Grid Width="60" Height="56">
                                <Grid.Opacity>1</Grid.Opacity>
                                <StackPanel Orientation="Vertical"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource XD_PropertyNameForeground}"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="56"
                                               Foreground="{DynamicResource XD_PropertyValueForeground}"/>
                                </StackPanel>

                                <!-- Context menu -->
                                <Grid.ContextMenu>
                                    <ContextMenu Tag="{Binding}">
                                        <MenuItem Header="Add to Favorites"
                                                  Click="OnToggleFavoriteClick"
                                                  Tag="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Remove from Favorites"
                                                  Click="OnRemoveFavoriteClick"
                                                  Tag="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Insert at Selection"
                                                  Click="OnInsertAtSelectionClick"
                                                  Tag="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE8A6;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Copy Tag"
                                                  Click="OnCopyTagClick"
                                                  Tag="{Binding}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Grid.ContextMenu>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                </ListBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

    Updated: 2026-03-19 — Phase 2: type-specific icons (IconGlyph/IconBrush)
                           Phase 3: rich hover tooltips (TooltipLines)
                           Phase 5: Auto-refresh toggle (BtnAutoRefresh)
                           Phase 6: Expand-to-selection button (BtnExpandToSelected)
                           Phase 7: Context menu on tree items
                           Phase 8: Breadcrumb bar (Row 1), UseLogicalTree toggle
                           Phase 9: Node count status bar (Row 6)
                           Phase 10: Visual/Logical tree toggle (BtnLogicalTree)
             2026-03-19 — Toolbar improvements:
                           A) Expand All (BtnExpandAll)
                           B) Search bar / Ctrl+F / F3 navigation with match count (Row 2)
                           C) Set as Root / inspect subtree + Reset Root / inspect banner (Row 4)
                           D) Pick Element toggle (BtnPickMode)
                           E) Track Selection toggle (BtnTrackSelection)
                           F) Filter presets dropdown + inline clear X button
                           G) Show/Hide Dimensions toggle (BtnShowDimensions)
                           H) Copy XAML Snippet context menu item
                           Search highlights on tree nodes (LVT_SearchHighlightBrush / LVT_SearchMatchBrush)
             2026-03-22 — Moved to plugin project (WpfHexEditor.Plugins.XamlDesigner.Panels).
    Theme: Global theme via XD_* and DockBackgroundBrush tokens (DynamicResource)
    ResourceDictionaries: WpfHexEditor.Shell/Themes/{Theme}/Colors.xaml
    Panel: Live Visual Tree — shows the runtime WPF visual tree of the design canvas.
    Bidirectional sync: node selection → canvas highlight; canvas selection → node highlight.
-->

<UserControl x:Class="WpfHexEditor.Plugins.XamlDesigner.Panels.LiveVisualTreePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.XamlDesigner.ViewModels"
             xmlns:models="clr-namespace:WpfHexEditor.Editor.XamlDesigner.Models;assembly=WpfHexEditor.Editor.XamlDesigner"
             Background="{DynamicResource DockBackgroundBrush}">

    <UserControl.Resources>
        <!-- Icon button style — same pattern as XamlOutlinePanel -->
        <Style x:Key="XD_LiveTreeIconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle button style (auto-refresh / logical-tree / pick-mode / track-selection toggles) -->
        <Style x:Key="XD_LiveTreeToggleButton" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Breadcrumb button style (small, no fixed width) -->
        <Style x:Key="XD_BreadcrumbButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="3,1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>   <!-- Row 0: Toolbar -->
            <RowDefinition Height="22"/>   <!-- Row 1: Breadcrumb bar -->
            <RowDefinition x:Name="SearchBarRow" Height="0"/>  <!-- Row 2: Search bar (hidden by default) -->
            <RowDefinition Height="1"/>    <!-- Row 3: Separator -->
            <RowDefinition Height="Auto"/> <!-- Row 4: Inspect Root banner (Auto-collapses when not in inspect mode) -->
            <RowDefinition Height="*"/>    <!-- Row 5: TreeView -->
            <RowDefinition Height="18"/>   <!-- Row 6: Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Row 0 — Toolbar ── -->
        <Border x:Name="ToolbarBorder" Grid.Row="0"
                Background="{DynamicResource XD_PanelToolbarBrush}"
                BorderBrush="{DynamicResource XD_PanelToolbarBorderBrush}"
                BorderThickness="0,0,0,1">
            <!-- LastChildFill="False" ensures TbgNavigation reports its content width,
                 not the fill width — required for ToolbarOverflowManager.CaptureNaturalWidths()
                 to measure the true natural size (not the available-space size). -->
            <DockPanel LastChildFill="False">
                <!-- Always-visible right panel (ToolbarOverflowManager anchor) -->
                <StackPanel x:Name="ToolbarRightPanel" DockPanel.Dock="Right"
                            Orientation="Horizontal" Margin="0,0,2,0">
                    <!-- Collapse all nodes -->
                    <Button x:Name="BtnCollapseAll" Style="{StaticResource XD_LiveTreeIconButton}"
                            Content="&#xE972;" ToolTip="Collapse All"/>
                    <!-- Overflow toggle (managed by ToolbarOverflowManager — initially hidden) -->
                    <ToggleButton x:Name="ToolbarOverflowButton"
                                  Width="22" Height="22" Padding="3"
                                  Background="Transparent" BorderThickness="0"
                                  FontFamily="Segoe MDL2 Assets" FontSize="11"
                                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                                  Content="&#xE712;" ToolTip="More options"
                                  Visibility="Collapsed"/>
                </StackPanel>

                <!-- Collapsible group: navigation + new features + filter + toggles -->
                <StackPanel x:Name="TbgNavigation" DockPanel.Dock="Left"
                            Orientation="Horizontal" Margin="2,2,0,2">
                    <!-- Refresh visual tree -->
                    <Button x:Name="BtnRefresh" Style="{StaticResource XD_LiveTreeIconButton}"
                            Content="&#xE72C;" ToolTip="Refresh visual tree"/>

                    <!-- Auto-refresh on render toggle -->
                    <ToggleButton x:Name="BtnAutoRefresh" Style="{StaticResource XD_LiveTreeToggleButton}"
                                  Content="&#xE8BD;"
                                  ToolTip="Auto-refresh on canvas render"
                                  IsChecked="{Binding AutoRefresh, Mode=TwoWay}"/>

                    <!-- Visual / Logical tree toggle -->
                    <ToggleButton x:Name="BtnLogicalTree" Style="{StaticResource XD_LiveTreeToggleButton}"
                                  Content="&#xE8A0;"
                                  ToolTip="Switch to Logical Tree view"
                                  IsChecked="{Binding UseLogicalTree, Mode=TwoWay}"/>

                    <!-- Expand to selected element -->
                    <Button x:Name="BtnExpandToSelected" Style="{StaticResource XD_LiveTreeIconButton}"
                            Content="&#xE8A4;" ToolTip="Expand and scroll to selected element"/>

                    <!-- A: Expand All -->
                    <Button x:Name="BtnExpandAll" Style="{StaticResource XD_LiveTreeIconButton}"
                            Content="&#xE9A6;" ToolTip="Expand All"/>

                    <!-- B: Toggle Search bar (Ctrl+F) -->
                    <Button x:Name="BtnSearch" Style="{StaticResource XD_LiveTreeIconButton}"
                            Content="&#xE721;" ToolTip="Search elements (Ctrl+F)"/>

                    <!-- C: Set selected node as inspect root -->
                    <Button x:Name="BtnSetAsRoot" Style="{StaticResource XD_LiveTreeIconButton}"
                            Content="&#xE89A;" ToolTip="Set selected element as tree root (inspect subtree)"/>

                    <!-- C: Reset to full tree (visible only in inspect mode) -->
                    <Button x:Name="BtnResetRoot"
                            Content="&#xE8B3;" ToolTip="Reset to full tree view">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource XD_LiveTreeIconButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInspectMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- D: Pick Element eyedropper mode -->
                    <ToggleButton x:Name="BtnPickMode" Style="{StaticResource XD_LiveTreeToggleButton}"
                                  Content="&#xEF3C;"
                                  ToolTip="Pick Element — click canvas to navigate tree"
                                  IsChecked="{Binding IsPickMode, Mode=TwoWay}"/>

                    <!-- E: Track Selection toggle -->
                    <ToggleButton x:Name="BtnTrackSelection" Style="{StaticResource XD_LiveTreeToggleButton}"
                                  Content="&#xE8CB;"
                                  ToolTip="Track active canvas selection in tree"
                                  IsChecked="{Binding TrackSelection, Mode=TwoWay}"/>

                    <!-- G: Show/Hide Dimensions toggle -->
                    <ToggleButton x:Name="BtnShowDimensions" Style="{StaticResource XD_LiveTreeToggleButton}"
                                  Content="&#xE9B9;"
                                  ToolTip="Show/hide element dimensions"
                                  IsChecked="{Binding ShowDimensions, Mode=TwoWay}"/>

                    <!-- F: Filter Preset dropdown button — left-click opens ContextMenu -->
                    <Button x:Name="BtnFilterPreset" Style="{StaticResource XD_LiveTreeIconButton}"
                            Content="&#xE71C;" ToolTip="Filter presets">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="All Elements"          Tag="All"          Click="OnFilterPresetItem"/>
                                <MenuItem Header="Hidden / Collapsed"    Tag="HiddenOnly"   Click="OnFilterPresetItem"/>
                                <MenuItem Header="Disabled Only"         Tag="DisabledOnly" Click="OnFilterPresetItem"/>
                                <MenuItem Header="Named Elements Only"   Tag="NamedOnly"    Click="OnFilterPresetItem"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- F: Filter textbox + separate clear button -->
                    <TextBox x:Name="TbxFilter"
                             Width="90"
                             Margin="4,0,0,0"
                             Style="{DynamicResource PanelSearchBoxStyle}"
                             Tag="Filter types…"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button x:Name="BtnClearFilter"
                            Width="14" Height="14"
                            Margin="2,0,0,0"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="8"
                            Padding="1"
                            Content="&#xE711;"
                            ToolTip="Clear filter">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource XD_LiveTreeIconButton}">
                                <Setter Property="Width"      Value="14"/>
                                <Setter Property="Height"     Value="14"/>
                                <Setter Property="FontSize"   Value="8"/>
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FilterText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Row 1 — Breadcrumb bar ── -->
        <Border Grid.Row="1"
                Background="{DynamicResource XD_PanelToolbarBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden">
                <ItemsControl ItemsSource="{Binding BreadcrumbPath}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:LiveTreeNode}">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding TypeName}"
                                        Style="{StaticResource XD_BreadcrumbButton}"
                                        Click="OnBreadcrumbNodeClick"/>
                                <TextBlock Text="›"
                                           FontSize="10"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           Opacity="0.5"
                                           VerticalAlignment="Center"
                                           Margin="0,0,2,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ── Row 2 — Search bar (hidden by default, shown on Ctrl+F / BtnSearch click) ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource LVT_SearchBarBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                ClipToBounds="True">
            <DockPanel Margin="4,2">
                <!-- Right: match count + prev/next/close buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock FontSize="10"
                               VerticalAlignment="Center"
                               Margin="4,0"
                               Foreground="{DynamicResource DockMenuForegroundBrush}">
                        <Run Text="{Binding SearchCurrentIndex, Mode=OneWay}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding SearchMatchCount, Mode=OneWay}"/>
                    </TextBlock>
                    <Button x:Name="BtnSearchPrev"
                            Style="{StaticResource XD_LiveTreeIconButton}"
                            Width="18" Height="18" FontSize="10"
                            Content="&#xE76B;" ToolTip="Previous match (Shift+F3)"/>
                    <Button x:Name="BtnSearchNext"
                            Style="{StaticResource XD_LiveTreeIconButton}"
                            Width="18" Height="18" FontSize="10"
                            Content="&#xE76C;" ToolTip="Next match (F3)"/>
                    <Button x:Name="BtnSearchClose"
                            Style="{StaticResource XD_LiveTreeIconButton}"
                            Width="18" Height="18" FontSize="10"
                            Content="&#xE711;" ToolTip="Close search (Esc)"/>
                </StackPanel>
                <!-- Search TextBox -->
                <TextBox x:Name="TbxSearch"
                         Style="{DynamicResource PanelSearchBoxStyle}"
                         Tag="Search elements…"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
        </Border>

        <!-- ── Row 3 — Separator ── -->
        <Border Grid.Row="3" Height="1"
                Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Row 4 — Inspect Root banner (collapsed when not in inspect mode) ── -->
        <Border Grid.Row="4"
                Background="{DynamicResource LVT_InspectRootBadgeBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,2">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsInspectMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource XD_LiveTreeIconButton}"
                        Width="16" Height="16" FontSize="9"
                        Content="&#xE8B3;" ToolTip="Return to full tree"
                        Click="OnResetRoot"/>
                <TextBlock Text="{Binding InspectRootLabel}"
                           FontSize="10"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ── Row 5 — Live Visual Tree ── -->
        <TreeView x:Name="LiveTree" Grid.Row="5"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0"
                  ItemsSource="{Binding RootNodes}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <!-- PanelTreeViewItemStyle provides a full ControlTemplate with themed hover/selection
                 (Panel_ItemHoverBrush / Panel_ItemSelectedBrush). The inline BasedOn layer adds
                 only the TwoWay VM bindings for expand/select state sync. -->
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource PanelTreeViewItemStyle}">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type models:LiveTreeNode}"
                                          ItemsSource="{Binding Children}">
                    <!-- Grid wraps the node row to allow a search-highlight overlay layer -->
                    <Grid>
                        <!-- B: Search match highlight layer (behind content) -->
                        <Border CornerRadius="2" Margin="-2,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <!-- Current (active) match — stronger highlight -->
                                        <DataTrigger Binding="{Binding IsCurrentSearchMatch}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource LVT_SearchMatchBrush}"/>
                                        </DataTrigger>
                                        <!-- Other matches — softer highlight -->
                                        <DataTrigger Binding="{Binding IsSearchMatch}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource LVT_SearchHighlightBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!-- Node content row -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Type-specific icon (Segoe MDL2, color from IconBrush) -->
                            <TextBlock Text="{Binding IconGlyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"
                                       Foreground="{Binding IconBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>

                            <!-- TypeName — inherits TreeViewItem foreground (adapts on selection) -->
                            <TextBlock Text="{Binding TypeName}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>

                            <!-- Quick Peek — discriminating property value for unnamed nodes (italic, muted) -->
                            <TextBlock Visibility="{Binding QuickPeekVisibility}"
                                       Text="{Binding QuickPeekLabel}"
                                       FontSize="10"
                                       FontStyle="Italic"
                                       Opacity="0.6"
                                       VerticalAlignment="Center"
                                       Margin="5,0,0,0"/>

                            <!-- x:Name — highlighted color, visible only when HasName -->
                            <TextBlock Visibility="{Binding NameVisibility}"
                                       Foreground="{DynamicResource LVT_NameBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="5,0,0,0">
                                <Run Text="["/><Run Text="{Binding ElementName, Mode=OneWay}"/><Run Text="]"/>
                            </TextBlock>

                            <!-- G: Dimensions — muted, hidden when ShowDimensions = false -->
                            <TextBlock Visibility="{Binding DimsVisibility}"
                                       Text="{Binding DimensionsLabel, StringFormat=' ({0})'}"
                                       Opacity="0.45"
                                       FontSize="10"
                                       VerticalAlignment="Center"
                                       Margin="3,0,0,0"/>

                            <!-- Badge: Hidden / Collapsed -->
                            <Border Visibility="{Binding VisibilityBadgeVisibility}"
                                    Background="{DynamicResource LVT_BadgeHiddenBrush}"
                                    CornerRadius="3"
                                    Padding="4,1"
                                    Margin="5,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding VisibilityBadgeText}"
                                           Foreground="{DynamicResource LVT_BadgeTextBrush}"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Badge: Disabled -->
                            <Border Visibility="{Binding DisabledBadgeVisibility}"
                                    Background="{DynamicResource LVT_BadgeDisabledBrush}"
                                    CornerRadius="3"
                                    Padding="4,1"
                                    Margin="5,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="disabled"
                                           Foreground="{DynamicResource LVT_BadgeTextBrush}"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Rich hover tooltip (TooltipLines from ViewModel) -->
                            <StackPanel.ToolTip>
                                <ToolTip Background="{DynamicResource DockBackgroundBrush}"
                                         BorderBrush="{DynamicResource DockBorderBrush}">
                                    <ItemsControl ItemsSource="{Binding TooltipLines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           FontSize="11"
                                                           FontFamily="Consolas"
                                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ToolTip>
                            </StackPanel.ToolTip>

                            <!-- Context menu: copy / navigate / select / inspect / xaml -->
                            <StackPanel.ContextMenu>
                                <ContextMenu>
                                    <!-- C: Set as Inspect Root -->
                                    <MenuItem Header="Set as Inspect Root"
                                              Click="OnContextSetAsRoot"/>
                                    <Separator/>
                                    <MenuItem Header="Copy Type Name"
                                              Command="{Binding CopyTypeNameCommand}"/>
                                    <MenuItem Header="Copy x:Name"
                                              Command="{Binding CopyElementNameCommand}"/>
                                    <MenuItem Header="Copy Full Path"
                                              Command="{Binding CopyFullPathCommand}"/>
                                    <!-- H: Copy XAML Snippet -->
                                    <MenuItem Header="Copy XAML Snippet"
                                              Command="{Binding CopyXamlSnippetCommand}"/>
                                    <Separator/>
                                    <MenuItem x:Name="MiSelectOnCanvas" Header="Select on Canvas"
                                              Click="OnContextSelectOnCanvas"/>
                                    <MenuItem x:Name="MiNavigateToXaml" Header="Navigate to XAML"
                                              Click="OnContextNavigateToXaml"/>
                                    <Separator/>
                                    <MenuItem x:Name="MiExpandChildren" Header="Expand All Children"
                                              Click="OnContextExpandAllChildren"/>
                                </ContextMenu>
                            </StackPanel.ContextMenu>
                        </StackPanel>
                    </Grid>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- ── Row 6 — Status bar ── -->
        <Border Grid.Row="6"
                Background="{DynamicResource XD_PanelToolbarBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="10"
                       Margin="6,0"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>

<!--
    Apache 2.0  2026
    Author : Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6

    Unified bottom panel — ByteChart (left) + Byte Interpretations (right).
    Optimized for bottom-dock layout: wide/short (design 1000×180).

    Theme: PanelCommon.xaml (PanelToolbarStyle, PanelIconButtonStyle,
           PanelIconToggleStyle, PanelDropdownButtonStyle, PanelToolbarSeparatorStyle)
    ResourceDictionaries: merged via docking theme chain (Dark/Light/VS2022Dark/etc.)
    Brushes: DynamicResource PFP_* + Panel_* (no hardcoded colors on structural elements)
-->

<UserControl x:Class="WpfHexEditor.Plugins.DataInspector.Views.DataInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:chart="clr-namespace:WpfHexEditor.Plugins.DataInspector.Controls"
             mc:Ignorable="d"
             d:DesignHeight="180" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- Category color indicators (semantic — theme-independent) -->
        <SolidColorBrush x:Key="CategoryIntegerBrush"  Color="#4A90E2"/>
        <SolidColorBrush x:Key="CategoryFloatBrush"    Color="#7ED321"/>
        <SolidColorBrush x:Key="CategoryDateTimeBrush" Color="#F5A623"/>
        <SolidColorBrush x:Key="CategoryNetworkBrush"  Color="#BD10E0"/>
        <SolidColorBrush x:Key="CategoryGuidBrush"     Color="#50E3C2"/>
        <SolidColorBrush x:Key="CategoryColorBrush"    Color="#FF6B6B"/>
        <SolidColorBrush x:Key="CategoryBasicBrush"    Color="#95A5A6"/>
        <SolidColorBrush x:Key="CategoryBitsBrush"     Color="#34495E"/>

        <Style x:Key="CategoryIndicatorStyle" TargetType="Border">
            <Setter Property="Width"        Value="4"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin"       Value="0,0,6,0"/>
        </Style>

        <!-- Compact item template — optimised for limited height (horizontal layout) -->
        <DataTemplate x:Key="InspectorValueTemplate">
            <Border Padding="6,3" Margin="0,0,0,1"
                    Background="{DynamicResource PFP_SectionBackgroundBrush}"
                    BorderBrush="{DynamicResource PFP_BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Category color bar -->
                    <Border Grid.Column="0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource CategoryIndicatorStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Category}" Value="Integer">
                                        <Setter Property="Background" Value="{StaticResource CategoryIntegerBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Float">
                                        <Setter Property="Background" Value="{StaticResource CategoryFloatBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Date/Time">
                                        <Setter Property="Background" Value="{StaticResource CategoryDateTimeBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Network">
                                        <Setter Property="Background" Value="{StaticResource CategoryNetworkBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="GUID">
                                        <Setter Property="Background" Value="{StaticResource CategoryGuidBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Color">
                                        <Setter Property="Background" Value="{StaticResource CategoryColorBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Basic">
                                        <Setter Property="Background" Value="{StaticResource CategoryBasicBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Bits">
                                        <Setter Property="Background" Value="{StaticResource CategoryBitsBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Format + value (compact 2-line layout) -->
                    <StackPanel Grid.Column="1">
                        <DockPanel>
                            <!-- Help icon — visible only when Description is set -->
                            <TextBlock DockPanel.Dock="Right"
                                       Text="&#xE9CE;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="9"
                                       Foreground="{DynamicResource PFP_SubTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"
                                       Cursor="Help">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Description}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.ToolTip>
                                    <ToolTip Background="{DynamicResource DockMenuBackgroundBrush}"
                                             BorderBrush="{DynamicResource DockBorderBrush}"
                                             BorderThickness="1"
                                             Padding="8,6">
                                        <TextBlock Text="{Binding Description}"
                                                   MaxWidth="300"
                                                   TextWrapping="Wrap"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <TextBlock Text="{Binding Format}"
                                       FontWeight="SemiBold" FontSize="10"
                                       Foreground="{DynamicResource PFP_TextBrush}"/>
                        </DockPanel>
                        <TextBlock Text="{Binding Value}"
                                   FontFamily="Consolas" FontSize="11"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource PFP_ValueBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PFP_PanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Row 0: unified toolbar -->
            <RowDefinition Height="*"/>        <!-- Row 1: chart + interpretations -->
            <RowDefinition Height="Auto"/>     <!-- Row 2: status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- Row 0 — Unified toolbar (PanelToolbarStyle, H=26px)               -->
        <!-- Left  : Scope | Chart toggles | Mode | Zoom | Refresh/Copy        -->
        <!-- Right : Category filter | All formats                              -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" x:Name="ToolbarBorder"
                Style="{StaticResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="False" Margin="4,0">

                <!-- ── RIGHT: Always-visible items (Category filter + All formats) -->
                <!-- Declared FIRST so it is placed at the far right of the DockPanel.  -->
                <!-- The overflow button is declared second, just inside of this panel.  -->
                <StackPanel DockPanel.Dock="Right" x:Name="ToolbarRightPanel"
                            Orientation="Horizontal">
                    <Rectangle Style="{StaticResource PanelToolbarSeparatorStyle}"/>
                    <TextBlock Text="Category:"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               Margin="0,0,4,0"/>
                    <ComboBox x:Name="CategoryFilterComboBox"
                              Width="100" FontSize="11"
                              VerticalAlignment="Center"
                              SelectedValue="{Binding SelectedCategory, Mode=TwoWay}"
                              SelectedValuePath="Content">
                        <ComboBoxItem Content="All"       IsSelected="True"/>
                        <ComboBoxItem Content="Integer"/>
                        <ComboBoxItem Content="Float"/>
                        <ComboBoxItem Content="Date/Time"/>
                        <ComboBoxItem Content="Network"/>
                        <ComboBoxItem Content="GUID"/>
                        <ComboBoxItem Content="Color"/>
                        <ComboBoxItem Content="Basic"/>
                        <ComboBoxItem Content="Bits"/>
                    </ComboBox>
                    <Rectangle Style="{StaticResource PanelToolbarSeparatorStyle}"/>
                    <CheckBox Content="All formats"
                              VerticalAlignment="Center"
                              IsChecked="{Binding ShowAllFormats, Mode=TwoWay}"
                              FontSize="11"
                              Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                              Margin="0,0,6,0"/>
                </StackPanel>

                <!-- ── RIGHT: Overflow button — shown when collapsible items don't fit -->
                <!-- Declared SECOND so it appears just to the left of ToolbarRightPanel. -->
                <Button DockPanel.Dock="Right"
                        x:Name="ToolbarOverflowButton"
                        Style="{StaticResource PanelIconButtonStyle}"
                        Content="&#xE712;"
                        ToolTip="More toolbar options"
                        Visibility="Collapsed"
                        Click="OnOverflowButtonClick">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowContextMenu"
                                     Opened="OnOverflowMenuOpened">
                            <!-- TbgToggles -->
                            <MenuItem x:Name="OvfToggleLabels" Header="Show Axis Labels"
                                      IsCheckable="True" Click="OnToggleLabels" Tag="TbgToggles"/>
                            <MenuItem x:Name="OvfToggleGrid"   Header="Show Grid Lines"
                                      IsCheckable="True" Click="OnToggleGrid"   Tag="TbgToggles"/>
                            <MenuItem x:Name="OvfToggleStats"  Header="Show Statistics"
                                      IsCheckable="True" Click="OnToggleStats"  Tag="TbgToggles"/>
                            <Separator Tag="TbgToggles"/>
                            <!-- TbgMode -->
                            <MenuItem x:Name="OvfModeFrequency" Header="Frequency Distribution"
                                      IsCheckable="True" Click="OnModeFrequency" Tag="TbgMode"/>
                            <MenuItem x:Name="OvfModeEntropy"   Header="Entropy (Sliding Window)"
                                      IsCheckable="True" Click="OnModeEntropy"   Tag="TbgMode"/>
                            <Separator Tag="TbgMode"/>
                            <!-- TbgZoom -->
                            <MenuItem Header="Zoom In"    Click="OnZoomIn"    InputGestureText="Wheel ↑" Tag="TbgZoom"/>
                            <MenuItem Header="Zoom Out"   Click="OnZoomOut"   InputGestureText="Wheel ↓" Tag="TbgZoom"/>
                            <MenuItem Header="Reset Zoom" Click="OnZoomReset"                            Tag="TbgZoom"/>
                            <Separator Tag="TbgZoom"/>
                            <!-- TbgAction -->
                            <MenuItem Header="Refresh Chart"    Click="OnRefresh"   Tag="TbgAction"/>
                            <MenuItem Header="Copy Chart Image" Click="OnCopyChart" Tag="TbgAction"/>
                            <Separator Tag="TbgAction"/>
                            <!-- TbgLayout -->
                            <MenuItem Header="Layout" Tag="TbgLayout">
                                <MenuItem x:Name="OvfLayoutLeft"   Header="Left"   IsCheckable="True" Tag="Left"   Click="OnOverflowLayoutClick"/>
                                <MenuItem x:Name="OvfLayoutRight"  Header="Right"  IsCheckable="True" Tag="Right"  Click="OnOverflowLayoutClick"/>
                                <MenuItem x:Name="OvfLayoutTop"    Header="Top"    IsCheckable="True" Tag="Top"    Click="OnOverflowLayoutClick"/>
                                <MenuItem x:Name="OvfLayoutBottom" Header="Bottom" IsCheckable="True" Tag="Bottom" Click="OnOverflowLayoutClick"/>
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- ── LEFT: TbgScope — always visible ───────────────────────── -->
                <StackPanel DockPanel.Dock="Left" x:Name="TbgScope" Orientation="Horizontal">
                    <TextBlock Text="Scope:"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               Margin="4,0,4,0"/>
                    <ComboBox x:Name="ScopeComboBox"
                              Width="120" FontSize="11"
                              VerticalAlignment="Center"
                              SelectionChanged="OnScopeChanged">
                        <ComboBoxItem x:Name="ScopeActiveView" Content="Active view"/>
                        <ComboBoxItem x:Name="ScopeSelection"  Content="Selection" IsSelected="True"/>
                        <ComboBoxItem x:Name="ScopeWholeFile"  Content="Whole file"/>
                    </ComboBox>
                    <Rectangle Style="{StaticResource PanelToolbarSeparatorStyle}"/>
                </StackPanel>

                <!-- ── LEFT: TbgToggles (collapse priority 4 — last) ─────────── -->
                <StackPanel DockPanel.Dock="Left" x:Name="TbgToggles" Orientation="Horizontal">
                    <ToggleButton x:Name="ToggleLabels"
                                  Style="{StaticResource PanelIconToggleStyle}"
                                  Content="&#xE8EC;"
                                  IsChecked="True"
                                  ToolTip="Show axis labels"
                                  Checked="OnToggleLabels" Unchecked="OnToggleLabels"/>
                    <ToggleButton x:Name="ToggleGrid"
                                  Style="{StaticResource PanelIconToggleStyle}"
                                  Content="&#xE80A;"
                                  IsChecked="False"
                                  ToolTip="Show grid lines"
                                  Checked="OnToggleGrid" Unchecked="OnToggleGrid"/>
                    <ToggleButton x:Name="ToggleStats"
                                  Style="{StaticResource PanelIconToggleStyle}"
                                  Content="&#xE9D9;"
                                  IsChecked="True"
                                  ToolTip="Show statistics overlay"
                                  Checked="OnToggleStats" Unchecked="OnToggleStats"/>
                    <Rectangle Style="{StaticResource PanelToolbarSeparatorStyle}"/>
                </StackPanel>

                <!-- ── LEFT: TbgMode (collapse priority 3) ───────────────────── -->
                <StackPanel DockPanel.Dock="Left" x:Name="TbgMode" Orientation="Horizontal">
                    <Button x:Name="ModeButton"
                            Style="{StaticResource PanelDropdownButtonStyle}"
                            ToolTip="Chart display mode"
                            Click="OnModeButtonClick">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="ModeLabel" Text="Frequency" FontSize="11"/>
                                <TextBlock Text=" &#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="ModeContextMenu">
                                <MenuItem Header="Frequency distribution"
                                          Click="OnModeFrequency"
                                          IsCheckable="True" x:Name="ModeFrequencyItem" IsChecked="True"/>
                                <MenuItem Header="Entropy (sliding window)"
                                          Click="OnModeEntropy"
                                          IsCheckable="True" x:Name="ModeEntropyItem"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Rectangle Style="{StaticResource PanelToolbarSeparatorStyle}"/>
                </StackPanel>

                <!-- ── LEFT: TbgZoom (collapse priority 2) ───────────────────── -->
                <StackPanel DockPanel.Dock="Left" x:Name="TbgZoom" Orientation="Horizontal">
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE8A3;"
                            ToolTip="Zoom in (mouse wheel also works)"
                            Click="OnZoomIn"/>
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE71F;"
                            ToolTip="Zoom out"
                            Click="OnZoomOut"/>
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE740;"
                            ToolTip="Reset zoom (show full 0x00–0xFF)"
                            Click="OnZoomReset"/>
                    <Rectangle Style="{StaticResource PanelToolbarSeparatorStyle}"/>
                </StackPanel>

                <!-- ── LEFT: TbgAction (collapse priority 1) ─────────────────── -->
                <StackPanel DockPanel.Dock="Left" x:Name="TbgAction" Orientation="Horizontal">
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE72C;"
                            ToolTip="Refresh chart"
                            Click="OnRefresh"/>
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE8C8;"
                            ToolTip="Copy chart as image"
                            Click="OnCopyChart"/>
                    <Rectangle Style="{StaticResource PanelToolbarSeparatorStyle}"/>
                </StackPanel>

                <!-- ── LEFT: TbgLayout (collapse priority 0 — first to collapse) -->
                <StackPanel DockPanel.Dock="Left" x:Name="TbgLayout" Orientation="Horizontal">
                    <TextBlock Text="Layout:"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               Margin="4,0,4,0"/>
                    <ComboBox x:Name="ChartPositionCombo"
                              Width="75" FontSize="11"
                              VerticalAlignment="Center"
                              ToolTip="Chart position relative to the interpretation list"
                              SelectionChanged="OnChartPositionChanged">
                        <ComboBoxItem Content="Left"   Tag="Left"/>
                        <ComboBoxItem Content="Right"  Tag="Right"/>
                        <ComboBoxItem Content="Top"    Tag="Top"/>
                        <ComboBoxItem Content="Bottom" Tag="Bottom"/>
                    </ComboBox>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- Row 1 — Main area: Chart + Interpretations                        -->
        <!-- Layout (Left/Right/Top/Bottom) is set dynamically by RebuildLayout()-->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" x:Name="MainAreaGrid">
            <!-- ColumnDefinitions / RowDefinitions built at runtime by RebuildLayout() -->

            <!-- ── Chart area ────────────────────────────────────────────────── -->
            <!-- Grid.Row / Grid.Column set by RebuildLayout() -->
            <Grid x:Name="ChartContainer">
                <Grid.ContextMenu>
                    <ContextMenu Opened="OnChartContextMenuOpening">

                        <!-- Group 1 — Zoom -->
                        <MenuItem Header="Zoom In"    Click="OnZoomIn"    InputGestureText="Wheel ↑"/>
                        <MenuItem Header="Zoom Out"   Click="OnZoomOut"   InputGestureText="Wheel ↓"/>
                        <MenuItem Header="Reset Zoom" Click="OnZoomReset"/>

                        <Separator/>

                        <!-- Group 2 — Display toggles -->
                        <MenuItem x:Name="CtxToggleLabels" Header="Show Axis Labels" IsCheckable="True" Click="OnCtxToggleLabels"/>
                        <MenuItem x:Name="CtxToggleGrid"   Header="Show Grid Lines"  IsCheckable="True" Click="OnCtxToggleGrid"/>
                        <MenuItem x:Name="CtxToggleStats"  Header="Show Statistics"  IsCheckable="True" Click="OnCtxToggleStats"/>

                        <Separator/>

                        <!-- Group 3 — Chart mode -->
                        <MenuItem x:Name="CtxModeFrequency" Header="Frequency Distribution"   IsCheckable="True" Click="OnModeFrequency"/>
                        <MenuItem x:Name="CtxModeEntropy"   Header="Entropy (Sliding Window)" IsCheckable="True" Click="OnModeEntropy"/>

                        <Separator/>

                        <!-- Group 4 — Actions -->
                        <MenuItem Header="Refresh"             Click="OnRefresh"/>
                        <MenuItem Header="Copy Chart as Image" Click="OnCopyChart"/>

                    </ContextMenu>
                </Grid.ContextMenu>

                <!-- Frequency mode: BarChartPanel wrapped in horizontal ScrollViewer for zoom -->
                <ScrollViewer x:Name="ChartScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Visibility="Visible"
                              SizeChanged="OnChartScrollViewerSizeChanged">
                    <chart:BarChartPanel x:Name="Chart"
                                         MinHeight="50"
                                         MouseLeftButtonDown="OnChartMouseDown"
                                         MouseMove="OnChartMouseMove"
                                         MouseLeftButtonUp="OnChartMouseUp"
                                         MouseWheel="OnChartMouseWheel"
                                         MouseRightButtonUp="OnChartAreaRightClick"
                                         Cursor="Cross"/>
                </ScrollViewer>

                <!-- Entropy mode: sliding-window canvas (alternate) -->
                <Canvas x:Name="EntropyCanvas"
                        Visibility="Collapsed"
                        MinHeight="50"
                        SizeChanged="OnEntropyCanvasSizeChanged"
                        MouseRightButtonUp="OnChartAreaRightClick"
                        Background="{DynamicResource PFP_PanelBackgroundBrush}"/>

                <!-- Drag-to-zoom rubber band overlay (hit-test transparent) -->
                <Canvas x:Name="ZoomRubberBandCanvas"
                        IsHitTestVisible="False"/>

                <!-- Async progress overlay (visible during WholeFile load > 1 MB) -->
                <Border x:Name="ProgressOverlay"
                        Visibility="Collapsed"
                        Background="#AA1E1E1E"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="ProgressLabel"
                                   Text="Analyzing file..."
                                   FontSize="11"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <ProgressBar x:Name="LoadingProgress"
                                     Width="200" Height="6"
                                     IsIndeterminate="True"
                                     Foreground="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── GridSplitter — Row/Column set by RebuildLayout() ──────────── -->
            <GridSplitter x:Name="ChartSplitter"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource PFP_BorderBrush}"
                          Cursor="SizeWE"/>

            <!-- ── Interpretations list container — Row/Column set by RebuildLayout() -->
            <Grid x:Name="ListContainer">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource PFP_PanelBackgroundBrush}">
                    <ItemsControl x:Name="ValuesItemsControl"
                                  ItemsSource="{Binding Values}"
                                  ItemTemplate="{StaticResource InspectorValueTemplate}">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ItemsPresenter/>
                                </Border>
                            </ControlTemplate>
                        </ItemsControl.Template>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- Row 2 — Status bar (chart stats left | interpretations count right) -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="6,3">
            <DockPanel>
                <!-- Right: interpretations count -->
                <TextBlock DockPanel.Dock="Right"
                           FontSize="10"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           VerticalAlignment="Center">
                    <Run Text="Interpretations: "/>
                    <Run Text="{Binding Values.Count, Mode=OneWay}" FontWeight="Bold"/>
                </TextBlock>

                <!-- Left: chart stats (chart-side context) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="EntropyText"
                               FontSize="10" FontFamily="Consolas"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="SepEntropy" Text=" | " FontSize="10"
                               Foreground="{DynamicResource Panel_ToolbarBorderBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="MostCommonText"
                               FontSize="10" FontFamily="Consolas"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="SepMostCommon" Text=" | " FontSize="10"
                               Foreground="{DynamicResource Panel_ToolbarBorderBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="NullPctText"
                               FontSize="10" FontFamily="Consolas"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="SepNull" Text=" | " FontSize="10"
                               Foreground="{DynamicResource Panel_ToolbarBorderBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="AsciiPctText"
                               FontSize="10" FontFamily="Consolas"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="SepAscii" Text=" | " FontSize="10"
                               Foreground="{DynamicResource Panel_ToolbarBorderBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="TotalBytesText"
                               Text="No data"
                               FontSize="10" FontFamily="Consolas"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="SepZoom" Text=" | " FontSize="10"
                               Visibility="Collapsed"
                               Foreground="{DynamicResource Panel_ToolbarBorderBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="ZoomRangeText"
                               FontSize="10" FontFamily="Consolas"
                               Visibility="Collapsed"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

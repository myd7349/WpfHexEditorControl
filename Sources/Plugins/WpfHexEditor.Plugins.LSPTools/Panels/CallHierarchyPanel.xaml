<UserControl x:Class="WpfHexEditor.Plugins.LSPTools.Panels.CallHierarchyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource CH_BackgroundBrush}"
             Foreground="{DynamicResource CH_ForegroundBrush}">

    <UserControl.Resources>

        <!-- ── Mode button style (CH_ tokens) ──────────────────────────────── -->
        <Style x:Key="CH_ModeButton" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Padding"         Value="8,2"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground"      Value="{DynamicResource CH_ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource CH_HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource CH_HoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource CH_ItemBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TreeViewItem style ───────────────────────────────────────────── -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground"    Value="{DynamicResource CH_ForegroundBrush}"/>
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="2,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource CH_ToolbarBrush}"
                BorderBrush="{DynamicResource CH_ItemBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="4,0" LastChildFill="True" VerticalAlignment="Center">

                <Button DockPanel.Dock="Left"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        ToolTip="Refresh"
                        Click="OnRefreshClicked"
                        Margin="0,0,4,0">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </Button>

                <Rectangle DockPanel.Dock="Left"
                           Width="1" Height="16"
                           Fill="{DynamicResource CH_ItemBorderBrush}"
                           Margin="2,0,6,0"/>

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="IncomingToggle"
                                  Style="{StaticResource CH_ModeButton}"
                                  IsChecked="True"
                                  Checked="OnModeChanged"
                                  Unchecked="OnModeChanged"
                                  ToolTip="Show incoming calls (callers)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Incoming" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="OutgoingToggle"
                                  Style="{StaticResource CH_ModeButton}"
                                  IsChecked="False"
                                  Checked="OnModeChanged"
                                  Unchecked="OnModeChanged"
                                  ToolTip="Show outgoing calls (callees)"
                                  Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Outgoing" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>

                <TextBlock x:Name="SymbolNameText"
                           DockPanel.Dock="Right"
                           Foreground="{DynamicResource CH_ForegroundBrush}"
                           FontSize="11"
                           Opacity="0.7"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="4,0"
                           TextTrimming="CharacterEllipsis"/>

            </DockPanel>
        </Border>

        <!-- ── Call Hierarchy Tree ──────────────────────────────────────────── -->
        <TreeView x:Name="HierarchyTree"
                  Grid.Row="1"
                  Background="{DynamicResource CH_BackgroundBrush}"
                  Foreground="{DynamicResource CH_ForegroundBrush}"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  SelectedItemChanged="OnTreeSelectionChanged"
                  MouseDoubleClick="OnTreeItemDoubleClick"
                  KeyDown="OnTreeKeyDown">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2,1">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Margin="0,0,5,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding KindGlyph}"/>
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LocationHint}"
                                   FontSize="10"
                                   Opacity="0.6"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <TextBlock x:Name="EmptyPlaceholder"
                   Grid.Row="1"
                   Text="No call hierarchy. Place caret on a method and press Shift+Alt+H."
                   Foreground="{DynamicResource CH_ForegroundBrush}"
                   Opacity="0.5"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="16"
                   Visibility="Visible"/>

    </Grid>
</UserControl>

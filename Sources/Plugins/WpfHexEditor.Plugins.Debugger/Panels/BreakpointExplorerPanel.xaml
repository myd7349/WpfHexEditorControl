<UserControl x:Class="WpfHexEditor.Plugins.Debugger.Panels.BreakpointExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.Debugger.ViewModels"
             xmlns:conv="clr-namespace:WpfHexEditor.Plugins.Debugger.Converters"
             xmlns:ctrl="clr-namespace:WpfHexEditor.Plugins.Debugger.Controls">

    <UserControl.Resources>
        <conv:BoolToOpacityConverter       x:Key="BoolToOpacity" />
        <conv:BoolToVerifiedConverter      x:Key="BoolToVerified" />
        <conv:BreakpointTypeToBrushConverter x:Key="TypeToBrush" />
        <conv:HitCountToVisibilityConverter x:Key="HitCountToVis" />
        <BooleanToVisibilityConverter      x:Key="BoolToVis" />
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: Toolbar (ToolbarOverflowManager pattern) ═══ -->
        <!-- Collapse order: TbgGroupBy(0) → TbgImportExport(1) → TbgActions(2) -->
        <Border Grid.Row="0" x:Name="ToolbarBorder"
                Style="{DynamicResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="False" Margin="4,0">

                <!-- ── Fixed RIGHT: always visible ── -->
                <StackPanel x:Name="ToolbarRightPanel" DockPanel.Dock="Right"
                            Orientation="Horizontal" VerticalAlignment="Center" />

                <!-- ── Search box (right-anchored, always visible, before overflow) ── -->
                <StackPanel x:Name="ToolbarLeftPanel" DockPanel.Dock="Right"
                            Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <TextBox x:Name="SearchBox"
                             Width="140"
                             Style="{DynamicResource PanelSearchBoxStyle}"
                             Tag="Search breakpoints..."
                             Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged, Delay=200}" />
                </StackPanel>

                <!-- ── Overflow button (right, Visibility=Collapsed by default) ── -->
                <Button x:Name="OverflowButton" DockPanel.Dock="Right"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        ToolTip="More options" Visibility="Collapsed"
                        Click="OnOverflowButtonClick">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               VerticalAlignment="Center" HorizontalAlignment="Center" />
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowMenu" Opened="OnOverflowMenuOpened">
                            <!-- TbgActions items -->
                            <MenuItem Header="Enable All"  Click="OnOvfEnableAll"  Tag="TbgActions">
                                <MenuItem.Icon><TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Disable All" Click="OnOvfDisableAll" Tag="TbgActions">
                                <MenuItem.Icon><TextBlock Text="&#xECC9;" FontFamily="Segoe MDL2 Assets" FontSize="12" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Delete All"  Click="OnOvfDeleteAll"  Tag="TbgActions">
                                <MenuItem.Icon><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" /></MenuItem.Icon>
                            </MenuItem>
                            <Separator Tag="TbgActions" />
                            <!-- TbgImportExport items -->
                            <MenuItem Header="Import from VS XML…"   Click="OnImportBreakpoints" Tag="TbgImportExport">
                                <MenuItem.Icon><TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Export All to VS XML…" Click="OnExportBreakpoints" Tag="TbgImportExport">
                                <MenuItem.Icon><TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="12" /></MenuItem.Icon>
                            </MenuItem>
                            <Separator Tag="TbgImportExport" />
                            <!-- TbgGroupBy items -->
                            <MenuItem Header="Group by None"    Click="OnOvfGroupNone"    Tag="TbgGroupBy" />
                            <MenuItem Header="Group by File"    Click="OnOvfGroupFile"    Tag="TbgGroupBy" />
                            <MenuItem Header="Group by Type"    Click="OnOvfGroupType"    Tag="TbgGroupBy" />
                            <MenuItem Header="Group by Enabled" Click="OnOvfGroupEnabled" Tag="TbgGroupBy" />
                            <MenuItem Header="Group by Project" Click="OnOvfGroupProject" Tag="TbgGroupBy" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- ── Group: TbgActions — Enable/Disable/Delete (collapse last) ── -->
                <StackPanel x:Name="TbgActions" DockPanel.Dock="Left"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding EnableAllCommand}" ToolTip="Enable All"
                            Style="{DynamicResource PanelIconButtonStyle}" Content="&#xE73E;" />
                    <Button Command="{Binding DisableAllCommand}" ToolTip="Disable All"
                            Style="{DynamicResource PanelIconButtonStyle}" Content="&#xECC9;" />
                    <Button Command="{Binding DeleteAllCommand}" ToolTip="Delete All Breakpoints"
                            Style="{DynamicResource PanelIconButtonStyle}" Content="&#xE74D;" />
                    <Rectangle Width="1" Height="16" Margin="6,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}" />
                </StackPanel>

                <!-- ── Group: TbgImportExport — Import(↓)/Export(↑) ── -->
                <StackPanel x:Name="TbgImportExport" DockPanel.Dock="Left"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding ImportCommand}" ToolTip="Import Breakpoints (VS XML)"
                            Style="{DynamicResource PanelIconButtonStyle}" Content="&#xE896;" />
                    <Button Command="{Binding ExportCommand}" ToolTip="Export Breakpoints (VS XML)"
                            Style="{DynamicResource PanelIconButtonStyle}" Content="&#xE898;" />
                    <Rectangle Width="1" Height="16" Margin="6,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}" />
                </StackPanel>

                <!-- ── Group: TbgGroupBy — Group ComboBox (collapse first) ── -->
                <StackPanel x:Name="TbgGroupBy" DockPanel.Dock="Left"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Group:" VerticalAlignment="Center" FontSize="11"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="2,0,4,0" />
                    <ComboBox x:Name="GroupByCombo" Width="90" Height="20" FontSize="11"
                              VerticalContentAlignment="Center"
                              SelectedIndex="1" SelectionChanged="OnGroupByChanged">
                        <ComboBoxItem Content="None" />
                        <ComboBoxItem Content="File" />
                        <ComboBoxItem Content="Type" />
                        <ComboBoxItem Content="Enabled" />
                        <ComboBoxItem Content="Project" />
                    </ComboBox>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══ Row 1: Flat ListView (when GroupBy == None) ═══ -->
        <ListView Grid.Row="1" ItemsSource="{Binding FlatBreakpoints}"
                  SelectedItem="{Binding SelectedBreakpoint}"
                  Visibility="{Binding IsGrouped, Converter={StaticResource InvertBoolToVis}}"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  MouseDoubleClick="OnRowDoubleClick"
                  MouseMove="OnListMouseMove"
                  MouseLeave="OnListMouseLeave"
                  x:Name="FlatList">

            <!-- VS-style dark-theme item: custom ControlTemplate overrides system Highlight -->
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="FocusVisualStyle"           Value="{x:Null}" />
                    <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="Bd"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0,1"
                                        SnapsToDevicePixels="True">
                                    <GridViewRowPresenter VerticalAlignment="Center"
                                                          Columns="{Binding Path=View.Columns,
                                                              RelativeSource={RelativeSource AncestorType=ListView}}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource BP_ExplorerRowSelectedBrush}" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True" />
                                            <Condition Property="IsSelected"  Value="False" />
                                        </MultiTrigger.Conditions>
                                        <MultiTrigger.Setters>
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource BP_ExplorerRowHoverBrush}" />
                                        </MultiTrigger.Setters>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.View>
                <GridView>
                    <GridViewColumn Width="26">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="10" Height="10"
                                         Fill="{Binding TypeLabel, Converter={StaticResource TypeToBrush}}"
                                         Opacity="{Binding IsEnabled, Converter={StaticResource BoolToOpacity}}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="26">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"
                                          Click="OnCheckBoxClicked" Tag="{Binding}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Location" Width="220"
                                    DisplayMemberBinding="{Binding DisplayLocation}" />
                    <GridViewColumn Header="Condition" Width="150"
                                    DisplayMemberBinding="{Binding Condition}" />
                    <GridViewColumn Header="Hits" Width="50">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding HitCount}"
                                           Visibility="{Binding HitCount, Converter={StaticResource HitCountToVis}}"
                                           Foreground="{DynamicResource DB_BreakpointConditionalBrush}"
                                           FontWeight="SemiBold" FontSize="11" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="&#x2713;" Width="26">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsVerified, Converter={StaticResource BoolToVerified}}"
                                           Foreground="{DynamicResource DB_BreakpointActiveBrush}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="28">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="&#xE74D;"
                                        Style="{DynamicResource PanelIconButtonStyle}"
                                        Width="18" Height="18" FontSize="11"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}" ToolTip="Delete breakpoint" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>

            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Go To Source" Click="OnGoToSource" InputGestureText="Enter">
                        <MenuItem.Icon><TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="12" /></MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Enable/Disable" Click="OnToggleEnabled">
                        <MenuItem.Icon><TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" /></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Copy Location" Click="OnCopyLocation">
                        <MenuItem.Icon><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12" /></MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Delete" Click="OnDeleteSelected">
                        <MenuItem.Icon><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" /></MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Import from VS XML…" Click="OnImportBreakpoints">
                        <MenuItem.Icon><TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12" /></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Export All to VS XML…" Click="OnExportBreakpoints">
                        <MenuItem.Icon><TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="12" /></MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>

        <!-- ═══ Row 1: Grouped TreeView (when GroupBy != None) ═══ -->
        <TreeView Grid.Row="1" ItemsSource="{Binding GroupedBreakpoints}"
                  Visibility="{Binding IsGrouped, Converter={StaticResource BoolToVis}}"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  MouseMove="OnTreeMouseMove"
                  MouseLeave="OnListMouseLeave"
                  x:Name="GroupedTree">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type vm:BreakpointGroupNode}"
                                           ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding GroupIcon}" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding GroupKey}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Opacity="0.6">
                            <TextBlock.Text>
                                <Binding Path="Count" StringFormat="({0})" />
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    <HierarchicalDataTemplate.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:BreakpointRowEx}">
                            <StackPanel Orientation="Horizontal" Margin="0,1" MouseLeftButtonDown="OnTreeItemDoubleClick">
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                         Fill="{Binding TypeLabel, Converter={StaticResource TypeToBrush}}"
                                         Opacity="{Binding IsEnabled, Converter={StaticResource BoolToOpacity}}" />
                                <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,6,0"
                                          Click="OnCheckBoxClicked" Tag="{Binding}" />
                                <TextBlock Text="{Binding DisplayLocation}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Condition}" Margin="8,0,0,0" Opacity="0.6"
                                           VerticalAlignment="Center" FontStyle="Italic" />
                                <TextBlock Text="{Binding HitCount, StringFormat=' [{0} hits]'}"
                                           Visibility="{Binding HitCount, Converter={StaticResource HitCountToVis}}"
                                           Foreground="{DynamicResource DB_BreakpointConditionalBrush}"
                                           Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </DataTemplate>
                    </HierarchicalDataTemplate.ItemTemplate>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded"  Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}" />
                    <Setter Property="Background"  Value="Transparent" />
                    <Setter Property="Padding"     Value="2,1" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource BP_ExplorerRowSelectedBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource BP_ExplorerRowHoverBrush}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <!-- ═══ Row 2: Status bar ═══ -->
        <Border Grid.Row="2" Style="{DynamicResource PanelToolbarStyle}">
            <TextBlock Text="{Binding SummaryText}" VerticalAlignment="Center"
                       Margin="4,0" FontSize="11"
                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Opacity="0.7" />
        </Border>
    </Grid>
</UserControl>

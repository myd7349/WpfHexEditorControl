<UserControl x:Class="WpfHexEditor.Plugins.Debugger.Panels.CallStackPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WpfHexEditor.Plugins.Debugger.Converters">

    <UserControl.Resources>
        <conv:FileNameConverter x:Key="FileNameConverter" />
    </UserControl.Resources>

    <ListView ItemsSource="{Binding Frames}"
              SelectedItem="{Binding SelectedFrame, Mode=TwoWay}"
              Background="{DynamicResource PanelBackground}"
              Foreground="{DynamicResource PanelForeground}"
              VirtualizingPanel.IsVirtualizing="True">
        <ListView.View>
            <GridView>
                <GridViewColumn Header="#" Width="30">
                    <GridViewColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Id}" />
                        </DataTemplate>
                    </GridViewColumn.CellTemplate>
                </GridViewColumn>
                <GridViewColumn Header="Name"   Width="240" DisplayMemberBinding="{Binding Name}" />
                <GridViewColumn Header="File"   Width="180">
                    <GridViewColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding FilePath, Converter={StaticResource FileNameConverter}}" />
                                <Run Text=":" />
                                <Run Text="{Binding Line}" />
                            </TextBlock>
                        </DataTemplate>
                    </GridViewColumn.CellTemplate>
                </GridViewColumn>
            </GridView>
        </ListView.View>
        <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Id}" Value="0">
                        <Setter Property="Foreground" Value="{DynamicResource DB_CallStackActiveBrush}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ListView.ItemContainerStyle>
    </ListView>
</UserControl>

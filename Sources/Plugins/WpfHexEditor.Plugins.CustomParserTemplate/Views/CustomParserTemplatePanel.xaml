<UserControl x:Class="WpfHexEditor.Plugins.CustomParserTemplate.Views.CustomParserTemplatePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             xmlns:cpSvc="clr-namespace:WpfHexEditor.Plugins.CustomParserTemplate.Services">

    <UserControl.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <cpSvc:CustomParserTemplateLocalizedDictionary/>
                </ResourceDictionary.MergedDictionaries>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_AccentBrush}"/>
            <Setter Property="Margin"     Value="0,8,0,4"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,8,0"/>
            <Setter Property="Foreground"        Value="{DynamicResource PFP_SubTextBrush}"/>
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Padding"         Value="4"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Background"      Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource PFP_InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource DockMenuForegroundBrush}"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="12"/>
            <Setter Property="Margin"          Value="0,0,0,12"/>
        </Style>

        <Style x:Key="ThemedDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background"               Value="{DynamicResource PFP_PanelBackgroundBrush}"/>
            <Setter Property="Foreground"               Value="{DynamicResource PFP_TextBrush}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush"   Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="RowBackground"            Value="{DynamicResource PFP_PanelBackgroundBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="{DynamicResource Panel_ToolbarBrush}"/>
                        <Setter Property="Foreground"      Value="{DynamicResource PFP_TextBrush}"/>
                        <Setter Property="BorderBrush"     Value="{DynamicResource PFP_BorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding"         Value="8,4"/>
                        <Setter Property="FontSize"        Value="10"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground"      Value="{DynamicResource PFP_TextBrush}"/>
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="Padding"         Value="4,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Panel_ItemSelectedForegroundBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
                </ResourceDictionary>
        </UserControl.Resources>

    <Grid Background="{DynamicResource PFP_PanelBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Template List -->
        <Border Grid.Column="0"
                Background="{DynamicResource PFP_SectionBackgroundBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="0,0,1,0"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{StaticResource CustomParser_TemplatesLabel}"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource PFP_TextBrush}"
                           Margin="0,0,0,12"/>

                <ListBox Grid.Row="1"
                         x:Name="TemplateListBox"
                         SelectionChanged="TemplateListBox_SelectionChanged"
                         DisplayMemberPath="Name"
                         Background="{DynamicResource PFP_PanelBackgroundBrush}"
                         Foreground="{DynamicResource PFP_TextBrush}"
                         BorderBrush="{DynamicResource PFP_BorderBrush}"
                         BorderThickness="1">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground"       Value="{DynamicResource PFP_TextBrush}"/>
                            <Setter Property="Background"       Value="Transparent"/>
                            <Setter Property="Padding"          Value="6,3"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Panel_ItemSelectedForegroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="0,8,0,0">
                    <Button Content="{StaticResource CustomParser_NewTemplate}"    Height="28" Margin="0,0,0,4"
                            Style="{StaticResource PanelDropdownButtonStyle}"
                            Padding="8,3"
                            Click="NewTemplate_Click"/>
                    <Button Content="{StaticResource CustomParser_DeleteTemplate}" Height="28"
                            Style="{StaticResource PanelDropdownButtonStyle}"
                            Padding="8,3"
                            Click="DeleteTemplate_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Panel: Template Editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource PFP_PanelBackgroundBrush}">
            <StackPanel Margin="12">

                <TextBlock Text="{StaticResource CustomParser_TemplateEditor}"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource PFP_TextBrush}"
                           Margin="0,0,0,12"/>

                <!-- Template Info Card -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource CustomParser_NameLabel}"        Style="{StaticResource LabelStyle}"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TemplateNameBox"
                                   Style="{StaticResource InputBoxStyle}" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource CustomParser_DescriptionLabel}" Style="{StaticResource LabelStyle}"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TemplateDescriptionBox"
                                   Style="{StaticResource InputBoxStyle}" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource CustomParser_ExtensionsLabel}"  Style="{StaticResource LabelStyle}"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TemplateExtensionsBox"
                                   Style="{StaticResource InputBoxStyle}" Margin="0,0,0,4" ToolTip="{StaticResource CustomParser_ExtensionsHint}"/>

                        <Button Grid.Row="3" Grid.Column="1" Content="{StaticResource CustomParser_SaveTemplate}" Height="28" Margin="0,8,0,0"
                                Style="{StaticResource PanelDropdownButtonStyle}"
                                Padding="8,3"
                                Click="SaveTemplate_Click"/>
                    </Grid>
                </Border>

                <!-- Blocks Section -->
                <TextBlock Text="{StaticResource CustomParser_FormatBlocks}" Style="{StaticResource SectionHeaderStyle}"/>

                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0"
                                  x:Name="BlocksDataGrid"
                                  Style="{StaticResource ThemedDataGridStyle}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  Height="250"
                                  Margin="0,0,0,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{StaticResource CustomParser_ColName}"        Binding="{Binding Name}"        Width="150"/>
                                <DataGridTextColumn Header="{StaticResource Common_ColOffset}"      Binding="{Binding Offset}"      Width="80"/>
                                <DataGridTextColumn Header="{StaticResource CustomParser_ColLength}"      Binding="{Binding Length}"      Width="80"/>
                                <DataGridComboBoxColumn Header="{StaticResource CustomParser_ColType}"    SelectedItemBinding="{Binding ValueType}" Width="100">
                                    <DataGridComboBoxColumn.ElementStyle>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="ItemsSource" Value="{Binding DataContext.ValueTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </Style>
                                    </DataGridComboBoxColumn.ElementStyle>
                                    <DataGridComboBoxColumn.EditingElementStyle>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="ItemsSource" Value="{Binding DataContext.ValueTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </Style>
                                    </DataGridComboBoxColumn.EditingElementStyle>
                                </DataGridComboBoxColumn>
                                <DataGridTextColumn Header="{StaticResource CustomParser_ColColor}"       Binding="{Binding Color}"       Width="100"/>
                                <DataGridTextColumn Header="{StaticResource CustomParser_ColDescription}" Binding="{Binding Description}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <Button Content="{StaticResource CustomParser_AddBlock}"    Width="100" Height="26" Margin="0,0,8,0"
                                    Style="{StaticResource PanelDropdownButtonStyle}"
                                    Click="AddBlock_Click"/>
                            <Button Content="{StaticResource CustomParser_RemoveBlock}" Width="120" Height="26"
                                    Style="{StaticResource PanelDropdownButtonStyle}"
                                    Click="RemoveBlock_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Apply Section -->
                <TextBlock Text="{StaticResource CustomParser_ApplyToFile}" Style="{StaticResource SectionHeaderStyle}"/>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{StaticResource CustomParser_ApplyDesc}"
                                   FontSize="10"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                        <Button Content="{StaticResource CustomParser_ApplyButton}" Height="32"
                                Style="{StaticResource PanelDropdownButtonStyle}"
                                FontWeight="SemiBold"
                                Padding="12,3"
                                Click="ApplyTemplate_Click"/>
                    </StackPanel>
                </Border>

                <!-- Export/Import Section -->
                <TextBlock Text="{StaticResource CustomParser_ExportImport}" Style="{StaticResource SectionHeaderStyle}"/>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{StaticResource CustomParser_ExportJson}"   Width="130" Height="28" Margin="0,0,8,0"
                                Style="{StaticResource PanelDropdownButtonStyle}"
                                Click="ExportTemplate_Click"/>
                        <Button Content="{StaticResource CustomParser_ImportJson}" Width="140" Height="28"
                                Style="{StaticResource PanelDropdownButtonStyle}"
                                Click="ImportTemplate_Click"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

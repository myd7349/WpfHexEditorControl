<UserControl x:Class="WpfHexEditor.Plugins.DocumentStructure.Views.DocumentStructurePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.DocumentStructure.ViewModels"
             xmlns:conv="clr-namespace:WpfHexEditor.Plugins.DocumentStructure.Converters">

    <UserControl.Resources>
        <conv:KindToBrushConverter x:Key="KindToBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>

        <!-- Context menu for tree nodes -->
        <ContextMenu x:Key="TreeNodeContextMenu">
            <MenuItem Header="Navigate To"         Tag="navigate"       Click="OnContextMenuClick">
                <MenuItem.Icon><TextBlock Text="&#xE7B0;" FontFamily="Segoe MDL2 Assets" FontSize="13"/></MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Copy Name"           Tag="copy-name"      Click="OnContextMenuClick">
                <MenuItem.Icon><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Copy Qualified Name" Tag="copy-qualified" Click="OnContextMenuClick">
                <MenuItem.Icon><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/></MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Expand All"          Tag="expand-all"     Click="OnContextMenuClick"/>
            <MenuItem Header="Collapse All"        Tag="collapse-all"   Click="OnContextMenuClick"/>
        </ContextMenu>

        <!-- Context menu for flat list nodes -->
        <ContextMenu x:Key="FlatNodeContextMenu">
            <MenuItem Header="Navigate To"         Tag="navigate"       Click="OnContextMenuClick">
                <MenuItem.Icon><TextBlock Text="&#xE7B0;" FontFamily="Segoe MDL2 Assets" FontSize="13"/></MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Copy Name"           Tag="copy-name"      Click="OnContextMenuClick">
                <MenuItem.Icon><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Copy Qualified Name" Tag="copy-qualified" Click="OnContextMenuClick">
                <MenuItem.Icon><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/></MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource DockBackgroundBrush}">

        <!-- ── Toolbar ────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Style="{DynamicResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="False">

                <!-- Left: standard action buttons (refresh + tree toggle + collapse + pin + sync) -->
                <StackPanel x:Name="ToolbarLeftPanel" Orientation="Horizontal"
                            DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button x:Name="RefreshButton"
                            Style="{DynamicResource PanelIconButtonStyle}"
                            Content="&#xE72C;"
                            ToolTip="Refresh"
                            Click="OnRefreshClicked"/>
                    <ToggleButton x:Name="TreeModeToggle"
                                  Style="{DynamicResource PanelIconToggleStyle}"
                                  Content="&#xE8B7;"
                                  ToolTip="Tree view"
                                  IsChecked="{Binding IsTreeMode}"/>
                    <Button x:Name="CollapseAllButton"
                            Style="{DynamicResource PanelIconButtonStyle}"
                            Content="&#xE8B6;"
                            ToolTip="Collapse All"
                            Click="OnCollapseAllClicked"/>
                    <ToggleButton x:Name="PinButton"
                                  Style="{DynamicResource PanelIconToggleStyle}"
                                  Content="&#xE840;"
                                  ToolTip="Pin document (keep structure while navigating)"
                                  IsChecked="{Binding IsPinned}"/>
                    <ToggleButton x:Name="ScrollSyncButton"
                                  Style="{DynamicResource PanelIconToggleStyle}"
                                  Content="&#xE8B1;"
                                  ToolTip="Sync with editor cursor"
                                  IsChecked="{Binding ScrollSyncEnabled}"/>
                </StackPanel>

                <!-- Left: collapsible sort combo -->
                <StackPanel x:Name="TbgSort" Orientation="Horizontal"
                            DockPanel.Dock="Left" VerticalAlignment="Center">
                    <ComboBox x:Name="SortCombo"
                              Style="{DynamicResource DockComboBoxStyle}"
                              Width="110" Height="20" FontSize="11"
                              VerticalContentAlignment="Center"
                              SelectedIndex="{Binding SortModeIndex}"
                              ToolTip="Sort order">
                        <ComboBoxItem Content="Source Order"/>
                        <ComboBoxItem Content="Alphabetical"/>
                        <ComboBoxItem Content="By Kind"/>
                    </ComboBox>
                </StackPanel>

                <!-- Left: max depth combo -->
                <StackPanel x:Name="TbgDepth" Orientation="Horizontal"
                            DockPanel.Dock="Left" VerticalAlignment="Center">
                    <ComboBox x:Name="DepthCombo"
                              Style="{DynamicResource DockComboBoxStyle}"
                              Width="72" Height="20" FontSize="11"
                              VerticalContentAlignment="Center"
                              SelectedIndex="{Binding MaxDepthIndex}"
                              ToolTip="Max tree depth">
                        <ComboBoxItem Content="&#x221E; Depth"/>
                        <ComboBoxItem Content="2 Levels"/>
                        <ComboBoxItem Content="3 Levels"/>
                        <ComboBoxItem Content="5 Levels"/>
                        <ComboBoxItem Content="10 Levels"/>
                    </ComboBox>
                </StackPanel>

                <!-- Right: overflow — declared first = far right -->
                <Button x:Name="ToolbarOverflowButton"
                        DockPanel.Dock="Right"
                        Visibility="Collapsed"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        ToolTip="More options"
                        Click="OnOverflowButtonClick">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowContextMenu" Opened="OnOverflowMenuOpened">
                            <MenuItem Header="Source Order" Tag="s0" Click="OnOverflowSortClicked"/>
                            <MenuItem Header="Alphabetical" Tag="s1" Click="OnOverflowSortClicked"/>
                            <MenuItem Header="By Kind"      Tag="s2" Click="OnOverflowSortClicked"/>
                            <Separator/>
                            <MenuItem Header="&#x221E; Depth" Tag="d0" Click="OnOverflowDepthClicked"/>
                            <MenuItem Header="2 Levels"       Tag="d1" Click="OnOverflowDepthClicked"/>
                            <MenuItem Header="3 Levels"       Tag="d2" Click="OnOverflowDepthClicked"/>
                            <MenuItem Header="5 Levels"       Tag="d3" Click="OnOverflowDepthClicked"/>
                            <MenuItem Header="10 Levels"      Tag="d4" Click="OnOverflowDepthClicked"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Right: filter box — fixed width -->
                <TextBox x:Name="FilterBox"
                         DockPanel.Dock="Right"
                         Width="140"
                         Style="{DynamicResource PanelSearchBoxStyle}"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         Tag="Filter symbols…"/>

            </DockPanel>
        </Border>

        <!-- ── Status bar ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource Panel_StatusBarBackgroundBrush}"
                Height="20"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}">
            <DockPanel Margin="6,0" LastChildFill="False">

                <!-- Provider badge pill (right) -->
                <Border DockPanel.Dock="Right"
                        Background="{DynamicResource DS_ProviderBadgeBackground}"
                        CornerRadius="3" Padding="5,1" Margin="4,2"
                        Visibility="{Binding ActiveProviderName, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="{Binding ActiveProviderName}"
                               FontSize="10"
                               Foreground="{DynamicResource DS_NodeForeground}"/>
                </Border>

                <!-- Symbol count / breadcrumb (left) -->
                <TextBlock Text="{Binding BreadcrumbText}"
                           FontSize="10" VerticalAlignment="Center"
                           Foreground="{DynamicResource DS_DetailForeground}"
                           Visibility="{Binding BreadcrumbText, Converter={StaticResource NullToVis}}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="10" VerticalAlignment="Center"
                           Foreground="{DynamicResource DS_DetailForeground}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding BreadcrumbText, Converter={StaticResource NullToVis}}" Value="Visible">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </DockPanel>
        </Border>

        <!-- ── Loading indicator ──────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Height="2"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" Height="2"/>
        </Border>

        <!-- ── Tree View (Tree mode) ──────────────────────────────── -->
        <TreeView x:Name="StructureTree"
                  ItemsSource="{Binding RootNodes}"
                  Visibility="{Binding IsTreeMode, Converter={StaticResource BoolToVis}}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  BorderThickness="0"
                  Background="Transparent"
                  SelectedItemChanged="OnTreeSelectedItemChanged"
                  MouseDoubleClick="OnTreeDoubleClick">
            <!-- Override system selection brushes so DS_ theme tokens take effect -->
            <TreeView.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                 Color="{DynamicResource DS_RowSelectedColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                 Color="{DynamicResource DS_RowSelectedTextColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                 Color="{DynamicResource DS_RowSelectedColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                 Color="{DynamicResource DS_RowSelectedTextColor}"/>
            </TreeView.Resources>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type vm:StructureNodeVm}"
                                          ItemsSource="{Binding Children}">
                    <Grid Margin="0,1" Visibility="{Binding Visibility}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2"/>   <!-- left accent bar -->
                            <ColumnDefinition Width="4"/>   <!-- gap -->
                            <ColumnDefinition Width="Auto"/><!-- icon badge -->
                            <ColumnDefinition Width="4"/>   <!-- gap -->
                            <ColumnDefinition Width="*"/>   <!-- name + detail -->
                        </Grid.ColumnDefinitions>
                        <!-- Left accent bar (visible when IsSelected) -->
                        <Rectangle Grid.Column="0" Fill="{DynamicResource DS_AccentColorBrush}">
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                        <!-- Kind icon: Segoe MDL2 glyph, colored by symbol type -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding IconGlyph}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{Binding Kind, Converter={StaticResource KindToBrush}}"
                                   Width="16" Height="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <!-- Name + : ReturnType -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource DS_NodeForeground}"/>
                            <TextBlock Foreground="{DynamicResource DS_DetailForeground}"
                                       FontSize="11"
                                       Visibility="{Binding Detail, Converter={StaticResource NullToVis}}">
                                <Run Text=" : "/>
                                <Run Text="{Binding Detail, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded"  Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="IsSelected"  Value="{Binding IsSelected, Mode=TwoWay}"/>
                    <Setter Property="Visibility"  Value="{Binding Visibility}"/>
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="ContextMenu" Value="{StaticResource TreeNodeContextMenu}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource DS_RowHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource DS_RowSelectedBrush}"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource DS_CaretHighlightBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <!-- ── Flat List (Flat mode) ──────────────────────────────── -->
        <ListBox x:Name="FlatList"
                 ItemsSource="{Binding FlatNodes}"
                 Visibility="{Binding IsTreeMode, Converter={StaticResource InverseBoolToVis}}"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 BorderThickness="0"
                 Background="Transparent"
                 SelectionChanged="OnFlatSelectionChanged"
                 MouseDoubleClick="OnFlatDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding"    Value="2,1"/>
                    <Setter Property="ContextMenu" Value="{StaticResource FlatNodeContextMenu}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource DS_RowHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource DS_RowSelectedBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:StructureNodeVm}">
                    <Grid Margin="{Binding IndentLevel, Converter={conv:IndentToMarginConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="{DynamicResource DS_AccentColorBrush}">
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding IconGlyph}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{Binding Kind, Converter={StaticResource KindToBrush}}"
                                   Width="16" Height="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource DS_NodeForeground}"/>
                            <TextBlock Foreground="{DynamicResource DS_DetailForeground}"
                                       FontSize="11"
                                       Visibility="{Binding Detail, Converter={StaticResource NullToVis}}">
                                <Run Text=" : "/>
                                <Run Text="{Binding Detail, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ── Empty state ─────────────────────────────────────────── -->
        <Grid Visibility="{Binding IsDocumentOpen, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Opacity="0.4">
                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource DS_NodeForeground}"/>
                <TextBlock Text="Open a document to see its structure"
                           FontSize="11" HorizontalAlignment="Center"
                           Foreground="{DynamicResource DS_DetailForeground}"
                           Margin="0,8,0,0" TextWrapping="Wrap"
                           MaxWidth="180" TextAlignment="Center"/>
            </StackPanel>
        </Grid>

    </DockPanel>
</UserControl>

<!--
    Project: WpfHexEditor.Plugins.SynalysisGrammar
    File: Options/GrammarExplorerOptionsPage.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-16
    Description:
        Options page for the Grammar Explorer plugin.
        Shown in IDE Options > Plugins > Grammar Explorer
        and in Plugin Manager "Settings" tab.
        Theme: DynamicResource PFP_* tokens (Background Transparent).
-->
<UserControl x:Class="WpfHexEditor.Plugins.SynalysisGrammar.Options.GrammarExplorerOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             Padding="12"
             xmlns:synSvc="clr-namespace:WpfHexEditor.Plugins.SynalysisGrammar.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <synSvc:SynalysisGrammarLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

        <!-- Section: Behaviour -->
        <TextBlock Text="{StaticResource Synalysis_BehaviourSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <CheckBox x:Name="ChkAutoApply" Content="{StaticResource Synalysis_AutoApplyOnOpen}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{StaticResource Synalysis_MaxSampleSize}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Slider x:Name="SampleSizeSlider"
                        Minimum="8" Maximum="512" TickFrequency="8"
                        IsSnapToTickEnabled="True"
                        Width="140"
                        VerticalAlignment="Center"
                        ValueChanged="OnSampleSizeChanged"/>
                <TextBlock x:Name="SampleSizeLabel"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- Section: Filter -->
        <TextBlock Text="{StaticResource Synalysis_GrammarListFilter}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <CheckBox x:Name="ChkShowEmbedded" Content="{StaticResource Synalysis_ShowBuiltIn}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkShowFile" Content="{StaticResource Synalysis_ShowFromDisk}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkShowPlugin" Content="{StaticResource Synalysis_ShowFromPlugins}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,16"/>

        <!-- Section: Overlay -->
        <TextBlock Text="{StaticResource Synalysis_OverlaySection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <CheckBox x:Name="ChkClearOverlayOnRemoval" Content="{StaticResource Synalysis_ClearOnRemove}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<!--
    Project: WpfHexEditor.Plugins.AssemblyExplorer
    File: Views/AssemblyDetailPane.xaml
    Author: Derek Tremblay
    Created: 2026-03-08
    Description:
        Detail pane displayed in the bottom split of the Assembly Explorer panel.
        Phase 4: 4-tab TabControl —
          Code  — C# structural skeleton (CSharpSkeletonEmitter output)
          IL    — raw IL disassembly (IlTextEmitter output, methods only)
          Info  — metadata token, PE offset, visibility/modifier flags, custom attrs
          Hex   — 64-byte hex dump at the node's PE offset
        ActiveTabIndex auto-switches based on the selected node type.
    Theme: DynamicResource PFP_* brush tokens (light + dark compliant).
-->
<UserControl x:Class="WpfHexEditor.Plugins.AssemblyExplorer.Views.AssemblyDetailPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource PFP_SectionBackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Shared read-only code TextBox style -->
        <Style x:Key="CodeBoxStyle" TargetType="TextBox">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{DynamicResource PFP_SubTextBrush}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="IsReadOnly"       Value="True"/>
            <Setter Property="TextWrapping"     Value="NoWrap"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Padding"          Value="8,4"/>
            <Setter Property="CaretBrush"       Value="Transparent"/>
        </Style>

        <!-- Tab header style -->
        <Style x:Key="DetailTabItemStyle" TargetType="TabItem">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{DynamicResource PFP_SubTextBrush}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="Padding"      Value="10,3"/>
            <Setter Property="FontSize"     Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar: node title + metadata token + PE offset -->
        <Border Grid.Row="0"
                Background="{DynamicResource PFP_PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="{DynamicResource PFP_TextBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Text="{Binding Title}"/>
                <TextBlock Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Text="{Binding MetadataInfo}"/>
                <TextBlock Foreground="{DynamicResource PFP_AccentBrush}"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Visibility="{Binding HasOffset, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding PeOffsetValue, StringFormat='PE: 0x{0:X}'}"/>
            </StackPanel>
        </Border>

        <!-- 4-tab detail body -->
        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}"
                    Background="{DynamicResource PFP_SectionBackgroundBrush}"
                    Foreground="{DynamicResource PFP_SubTextBrush}"
                    BorderBrush="{DynamicResource PFP_BorderBrush}"
                    BorderThickness="0,1,0,0">

            <!-- Tab 0: Code — C# structural skeleton -->
            <TabItem Header="Code" Style="{StaticResource DetailTabItemStyle}">
                <ScrollViewer Background="{DynamicResource PFP_SectionBackgroundBrush}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox Style="{StaticResource CodeBoxStyle}"
                             Text="{Binding DetailText, Mode=OneWay}"/>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 1: IL — raw IL disassembly (methods only) -->
            <TabItem Header="IL" Style="{StaticResource DetailTabItemStyle}">
                <Grid Background="{DynamicResource PFP_SectionBackgroundBrush}">
                    <!-- Shown when no IL text is available -->
                    <TextBlock Text="// Select a method node to view IL disassembly."
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontFamily="Consolas"
                               FontSize="11"
                               Margin="8,4"
                               VerticalAlignment="Top">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IlText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IlText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <TextBox Style="{StaticResource CodeBoxStyle}"
                                 Text="{Binding IlText, Mode=OneWay}"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Tab 2: Info — structured metadata key/value grid -->
            <TabItem Header="Info" Style="{StaticResource DetailTabItemStyle}">
                <ScrollViewer Background="{DynamicResource PFP_SectionBackgroundBrush}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding InfoItems}"
                                  Margin="8,4"
                                  Grid.IsSharedSizeScope="True">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" SharedSizeGroup="InfoKey"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Key}"
                                               Foreground="{DynamicResource PFP_SubTextBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               Foreground="{DynamicResource PFP_TextBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: Hex — 64-byte raw hex dump at PE offset -->
            <TabItem Header="Hex" Style="{StaticResource DetailTabItemStyle}">
                <ScrollViewer Background="{DynamicResource PFP_SectionBackgroundBrush}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox Style="{StaticResource CodeBoxStyle}"
                             Text="{Binding HexDumpText, Mode=OneWay}"/>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>

<!--
    Project: WpfHexEditor.Plugins.AssemblyExplorer
    File: Views/AssemblyDetailPane.xaml
    Author: Derek Tremblay
    Created: 2026-03-08
    Description:
        Detail pane displayed in the bottom split of the Assembly Explorer panel.
        7-tab TabControl —
          Code   — C# structural skeleton (CSharpSkeletonEmitter output)
          IL     — raw IL disassembly (IlTextEmitter output, methods only)
          Info   — metadata token, PE offset, visibility/modifier flags, custom attrs
          Hex    — 64-byte hex dump at the node's PE offset
          CFG    — Control Flow Graph canvas (method nodes only)
          XRefs  — cross-reference analysis (method / field nodes)
          Source — PDB sequence points + SourceLink URL (method nodes with PDB)
        ActiveTabIndex auto-switches based on the selected node type.
    Theme: DynamicResource PFP_* brush tokens (light + dark compliant).
-->
<UserControl x:Class="WpfHexEditor.Plugins.AssemblyExplorer.Views.AssemblyDetailPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WpfHexEditor.Plugins.AssemblyExplorer.Controls"
             Background="{DynamicResource PFP_SectionBackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Shared read-only code TextBox style -->
        <Style x:Key="CodeBoxStyle" TargetType="TextBox">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{DynamicResource PFP_SubTextBrush}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="IsReadOnly"       Value="True"/>
            <Setter Property="TextWrapping"     Value="NoWrap"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Padding"          Value="8,4"/>
            <Setter Property="CaretBrush"       Value="Transparent"/>
        </Style>

        <!-- Tab header style -->
        <Style x:Key="DetailTabItemStyle" TargetType="TabItem">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{DynamicResource PFP_SubTextBrush}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="Padding"      Value="10,3"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush"     Value="{DynamicResource PFP_AccentBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter Property="Foreground"                             Value="{DynamicResource PFP_TextBrush}"/>
                                <Setter Property="FontWeight"                             Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"  Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabControl style: overrides the default template so the header strip
             uses PFP theme brushes instead of the Windows system Aero brush. -->
        <Style x:Key="DetailTabControlStyle" TargetType="TabControl">
            <Setter Property="Background"     Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
            <Setter Property="BorderBrush"    Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"        Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Header strip: explicit PFP background prevents Windows Aero bleed-through -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource PFP_PanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource PFP_BorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True"
                                          Background="Transparent"
                                          KeyboardNavigation.TabNavigation="Local"/>
                            </Border>
                            <!-- Content area -->
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  KeyboardNavigation.TabNavigation="Local"
                                                  KeyboardNavigation.DirectionalNavigation="Contained"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar: node title + metadata token + PE offset + Extract button -->
        <Border Grid.Row="0"
                Background="{DynamicResource PFP_PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,3">
            <DockPanel LastChildFill="True">
                <!-- Extract to Project button — right-docked, visible for decompilable nodes -->
                <Button x:Name="ExtractButton"
                        DockPanel.Dock="Right"
                        Margin="4,0,0,0"
                        Padding="6,1"
                        Background="Transparent"
                        BorderBrush="{DynamicResource PFP_BorderBrush}"
                        Foreground="{DynamicResource PFP_TextBrush}"
                        ToolTip="Extract decompiled code to the loaded project"
                        Visibility="{Binding IsExtractAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                        Click="OnExtractButtonClick">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" Margin="0,0,3,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Extract" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- Title info (fills remaining space) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource PFP_TextBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Text="{Binding Title}"/>
                    <TextBlock Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               Text="{Binding MetadataInfo}"/>
                    <TextBlock Foreground="{DynamicResource PFP_AccentBrush}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               Visibility="{Binding HasOffset, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding PeOffsetValue, StringFormat='PE: 0x{0:X}'}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 4-tab detail body -->
        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}"
                    Style="{StaticResource DetailTabControlStyle}"
                    ItemContainerStyle="{StaticResource DetailTabItemStyle}">

            <!-- Tab 0: Code — C# structural skeleton -->
            <TabItem Header="Code">
                <ScrollViewer Background="{DynamicResource PFP_SectionBackgroundBrush}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox Style="{StaticResource CodeBoxStyle}"
                             Text="{Binding DetailText, Mode=OneWay}"/>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 1: IL — raw IL disassembly (methods only) -->
            <TabItem Header="IL">
                <Grid Background="{DynamicResource PFP_SectionBackgroundBrush}">
                    <!-- Shown when no IL text is available -->
                    <TextBlock Text="// Select a method node to view IL disassembly."
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontFamily="Consolas"
                               FontSize="11"
                               Margin="8,4"
                               VerticalAlignment="Top">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IlText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IlText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <TextBox Style="{StaticResource CodeBoxStyle}"
                                 Text="{Binding IlText, Mode=OneWay}"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Tab 2: Info — structured metadata key/value grid -->
            <TabItem Header="Info">
                <ScrollViewer Background="{DynamicResource PFP_SectionBackgroundBrush}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding InfoItems}"
                                  Margin="8,4"
                                  Grid.IsSharedSizeScope="True">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130" SharedSizeGroup="InfoKey"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Key}"
                                               Foreground="{DynamicResource PFP_SubTextBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               Foreground="{DynamicResource PFP_TextBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: Hex — 64-byte raw hex dump at PE offset -->
            <TabItem Header="Hex">
                <ScrollViewer Background="{DynamicResource PFP_SectionBackgroundBrush}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox Style="{StaticResource CodeBoxStyle}"
                             Text="{Binding HexDumpText, Mode=OneWay}"/>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 4: CFG — Control Flow Graph (method nodes only) -->
            <TabItem Header="CFG">
                <Grid Background="{DynamicResource PFP_SectionBackgroundBrush}">

                    <!-- Placeholder shown when no CFG is available -->
                    <TextBlock Text="// Select a method node to view the Control Flow Graph."
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontFamily="Consolas" FontSize="11"
                               Margin="8,4" VerticalAlignment="Top">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CfgViewModel.IsAvailable}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Error message (build failure) -->
                    <TextBlock Text="{Binding CfgViewModel.ErrorMessage}"
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontFamily="Consolas" FontSize="11"
                               Margin="8,4" VerticalAlignment="Top"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CfgViewModel.IsAvailable}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Building spinner -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding CfgViewModel.IsBuilding,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar IsIndeterminate="True" Width="160" Height="3"
                                     Foreground="{DynamicResource PFP_AccentBrush}"
                                     Background="Transparent" BorderThickness="0"/>
                        <TextBlock Text="Building CFG…" Margin="0,6,0,0"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                   FontSize="11" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- CFG Canvas (only when graph is ready) -->
                    <controls:CfgCanvas x:Name="CfgCanvasControl"
                                        Graph="{Binding CfgViewModel.Graph}"
                                        Visibility="{Binding CfgViewModel.IsAvailable,
                                                     Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </TabItem>

            <!-- Tab 5: XRefs — cross-reference analysis (method and field nodes) -->
            <TabItem Header="XRefs">
                <Grid Background="{DynamicResource PFP_SectionBackgroundBrush}">

                    <!-- Placeholder when no XRefs loaded -->
                    <TextBlock Text="// Select a method or field node to view cross-references."
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontFamily="Consolas" FontSize="11"
                               Margin="8,4" VerticalAlignment="Top">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding XRefViewModel.IsAvailable}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Loading spinner -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding XRefViewModel.IsLoading,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar IsIndeterminate="True" Width="160" Height="3"
                                     Foreground="{DynamicResource PFP_AccentBrush}"
                                     Background="Transparent" BorderThickness="0"/>
                        <TextBlock Text="Scanning XRefs…" Margin="0,6,0,0"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                   FontSize="11" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- XRef groups (visible when data is ready) -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding XRefViewModel.IsAvailable,
                                               Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding XRefViewModel.Groups}" Margin="8,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{DynamicResource PFP_TextBrush}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Margin="0,0,0,3"/>
                                        <ItemsControl ItemsSource="{Binding Entries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,1" Padding="6,3"
                                                            CornerRadius="2" Cursor="Hand">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background"
                                                                                Value="{DynamicResource Panel_ItemHoverBrush}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftDoubleClick"
                                                                          Command="{Binding NavigateCommand}"/>
                                                        </Border.InputBindings>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding MemberSignature}"
                                                                       Foreground="{DynamicResource PFP_TextBrush}"
                                                                       FontFamily="Consolas" FontSize="11"/>
                                                            <TextBlock Text="{Binding TypeName}"
                                                                       Foreground="{DynamicResource PFP_SubTextBrush}"
                                                                       FontSize="10" Margin="0,1,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </Grid>
            </TabItem>

            <!-- Tab 6: Source — PDB sequence points + SourceLink integration -->
            <TabItem Header="Source">
                <Grid Background="{DynamicResource PFP_SectionBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Status bar + action buttons -->
                        <RowDefinition Height="Auto"/>  <!-- Loading spinner -->
                        <RowDefinition Height="Auto"/>  <!-- Source preview -->
                        <RowDefinition Height="*"/>     <!-- Sequence points DataGrid -->
                    </Grid.RowDefinitions>

                    <!-- Status / file info bar -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource PFP_PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource PFP_BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="6,3">
                        <DockPanel LastChildFill="True">
                            <!-- Action buttons — right-docked -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <!-- Open via SourceLink button -->
                                <Button Margin="0,0,4,0"
                                        Padding="5,1"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource PFP_BorderBrush}"
                                        Foreground="{DynamicResource PFP_TextBrush}"
                                        Command="{Binding SourceViewModel.OpenSourceLinkCommand}"
                                        ToolTip="Open in browser via SourceLink">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10" Margin="0,0,3,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="SourceLink" FontSize="10" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <!-- Go to Source button -->
                                <Button Padding="5,1"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource PFP_BorderBrush}"
                                        Foreground="{DynamicResource PFP_TextBrush}"
                                        Command="{Binding SourceViewModel.GoToSourceCommand}"
                                        ToolTip="Open local source file in the text editor">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10" Margin="0,0,3,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Go to Source" FontSize="10" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <!-- Status message -->
                            <TextBlock Text="{Binding SourceViewModel.StatusMessage}"
                                       Foreground="{DynamicResource PFP_SubTextBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </Border>

                    <!-- Loading spinner (row 1) -->
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                Margin="0,6"
                                Visibility="{Binding SourceViewModel.IsLoading,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar IsIndeterminate="True" Width="160" Height="3"
                                     Foreground="{DynamicResource PFP_AccentBrush}"
                                     Background="Transparent" BorderThickness="0"/>
                        <TextBlock Text="Reading PDB…" Margin="0,4,0,0"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                   FontSize="11" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Source preview (row 2) — 3-line snippet from local file -->
                    <Border Grid.Row="2"
                            Margin="4,4,4,0"
                            Background="{DynamicResource PFP_PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource PFP_BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SourceViewModel.SourcePreview}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBox Style="{StaticResource CodeBoxStyle}"
                                 Text="{Binding SourceViewModel.SourcePreview, Mode=OneWay}"
                                 Padding="6,4"
                                 FontSize="11"/>
                    </Border>

                    <!-- Sequence points DataGrid (row 3) -->
                    <DataGrid Grid.Row="3"
                              Margin="4,4,4,4"
                              ItemsSource="{Binding SourceViewModel.SequencePoints}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              Background="{DynamicResource PFP_SectionBackgroundBrush}"
                              Foreground="{DynamicResource PFP_TextBrush}"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{DynamicResource PFP_PanelBackgroundBrush}"
                              HorizontalGridLinesBrush="{DynamicResource PFP_BorderBrush}"
                              ColumnHeaderHeight="22"
                              RowHeight="20"
                              FontFamily="Consolas"
                              FontSize="11">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"  Value="{DynamicResource PFP_PanelBackgroundBrush}"/>
                                <Setter Property="Foreground"  Value="{DynamicResource PFP_SubTextBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource PFP_BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding"     Value="6,0"/>
                                <Setter Property="FontSize"    Value="10"/>
                                <Setter Property="FontWeight"  Value="SemiBold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding"         Value="4,0"/>
                                <Setter Property="Foreground"      Value="{DynamicResource PFP_TextBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PFP_SelectionBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                        <Setter Property="Opacity" Value="0.45"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="IL Offset"   Binding="{Binding IlOffset}"   Width="75"/>
                            <DataGridTextColumn Header="Line"        Binding="{Binding Line}"        Width="55"/>
                            <DataGridTextColumn Header="Col"         Binding="{Binding Column}"      Width="45"/>
                            <DataGridTextColumn Header="Source File" Binding="{Binding SourceFile}"  Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Placeholder: no PDB available -->
                    <TextBlock Grid.Row="3"
                               Text="// No portable PDB found for this method."
                               Foreground="{DynamicResource PFP_SubTextBrush}"
                               FontFamily="Consolas" FontSize="11"
                               Margin="8,8" VerticalAlignment="Top">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding SourceViewModel.IsPdbAvailable}" Value="False"/>
                                            <Condition Binding="{Binding SourceViewModel.IsLoading}"     Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </Grid>
            </TabItem>

        </TabControl>

        <!-- Phase 8: Loading overlay — appears on top of the TabControl while
             background decompilation is in progress. Semi-transparent so the user
             can still see the previous content beneath. -->
        <Border Grid.Row="1"
                Panel.ZIndex="10"
                Opacity="0.92"
                Background="{DynamicResource PFP_SectionBackgroundBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="200" Height="3"
                             Foreground="{DynamicResource PFP_AccentBrush}"
                             Background="Transparent"
                             BorderThickness="0"/>
                <TextBlock Text="{Binding LoadingMessage}"
                           Margin="0,7,0,0"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>

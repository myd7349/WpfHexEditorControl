<!--
    Project: WpfHexEditor.Plugins.AssemblyExplorer
    File: Views/AssemblyDetailPane.xaml
    Author: Derek Tremblay
    Created: 2026-03-08
    Description:
        Detail pane displayed in the bottom split of the Assembly Explorer panel.
        Shows stub decompiled text for the currently selected tree node,
        its metadata token, and its raw PE file offset.
        Theme: DynamicResource PFP_* brush tokens.
-->
<UserControl x:Class="WpfHexEditor.Plugins.AssemblyExplorer.Views.AssemblyDetailPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource PFP_SectionBackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar: node title + metadata token + PE offset -->
        <Border Grid.Row="0"
                Background="{DynamicResource PFP_PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TitleText"
                           Foreground="{DynamicResource PFP_TextBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Text="{Binding Title}"/>
                <TextBlock x:Name="MetaText"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Text="{Binding MetadataInfo}"/>
                <TextBlock Foreground="{DynamicResource PFP_AccentBrush}"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Visibility="{Binding HasOffset, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding PeOffsetValue, StringFormat='PE: 0x{0:X}'}"/>
            </StackPanel>
        </Border>

        <!-- Stub decompiler text / detail body -->
        <ScrollViewer Grid.Row="1"
                      Background="{DynamicResource PFP_SectionBackgroundBrush}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
            <TextBox x:Name="DetailTextBox"
                     Background="Transparent"
                     Foreground="{DynamicResource PFP_SubTextBrush}"
                     BorderThickness="0"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas"
                     FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     Padding="8,4"
                     Text="{Binding DetailText, Mode=OneWay}"
                     CaretBrush="Transparent"/>
        </ScrollViewer>
    </Grid>
</UserControl>

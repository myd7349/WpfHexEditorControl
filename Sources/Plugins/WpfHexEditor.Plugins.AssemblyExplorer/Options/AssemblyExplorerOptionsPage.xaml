<!--
    Project: WpfHexEditor.Plugins.AssemblyExplorer
    File: Options/AssemblyExplorerOptionsPage.xaml
    Author: Derek Tremblay
    Created: 2026-03-08
    Description:
        Options page for the Assembly Explorer plugin.
        Shown in IDE Options > Plugins > Assembly Explorer
        and in Plugin Manager "Settings" tab.
        Theme: DynamicResource PFP_* tokens.
-->
<UserControl x:Class="WpfHexEditor.Plugins.AssemblyExplorer.Options.AssemblyExplorerOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             Padding="12">

    <StackPanel>

        <!-- Section: Decompiler -->
        <TextBlock Text="Decompiler"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Detail pane font size:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Slider x:Name="FontSizeSlider"
                        Minimum="8" Maximum="24" TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Width="120"
                        VerticalAlignment="Center"
                        ValueChanged="OnFontSizeChanged"/>
                <TextBlock x:Name="FontSizeLabel"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="11"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Decompiler backend:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <ComboBox x:Name="BackendCombo"
                      Grid.Column="1"
                      Width="160"
                      HorizontalAlignment="Left"
                      Background="{DynamicResource PFP_SectionBackgroundBrush}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      BorderBrush="{DynamicResource PFP_BorderBrush}">
                <ComboBoxItem Content="None (stub — Phase 1)" Tag="None" IsSelected="True"/>
                <ComboBoxItem Content="ILSpy engine (future)" Tag="ILSpy" IsEnabled="False"/>
                <ComboBoxItem Content="dnSpy engine (future)" Tag="dnSpy" IsEnabled="False"/>
            </ComboBox>
        </Grid>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Decompile language:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <ComboBox x:Name="LanguageCombo"
                      Grid.Column="1"
                      Width="160"
                      HorizontalAlignment="Left"
                      Background="{DynamicResource PFP_SectionBackgroundBrush}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      BorderBrush="{DynamicResource PFP_BorderBrush}">
                <ComboBoxItem Content="C#"           Tag="CSharp"   IsSelected="True"/>
                <ComboBoxItem Content="IL"           Tag="IL"/>
                <ComboBoxItem Content="VB.NET (future)" Tag="VBNet"  IsEnabled="False"/>
                <ComboBoxItem Content="F# (future)"  Tag="FSharp"   IsEnabled="False"/>
            </ComboBox>
        </Grid>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

        <!-- Section: Behaviour -->
        <TextBlock Text="Behaviour"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <CheckBox x:Name="ChkAutoAnalyze"
                  Content="Automatically analyze file when opened in HexEditor"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkAutoSync"
                  Content="Sync HexEditor cursor when selecting a tree node"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkShowResources"
                  Content="Show Resources group in the tree"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkShowMetadata"
                  Content="Show Metadata Tables group in the tree"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkInheritTheme"
                  Content="Inherit IDE global theme"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkShowNonPublic"
                  Content="Show non-public members (private, internal, protected)"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkShowInherited"
                  Content="Show inherited members in type nodes"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkPinAssemblies"
                  Content="Pin loaded assemblies across active editor changes"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,8,0,8"/>

        <!-- Section: Recent Files -->
        <TextBlock Text="Recent Assemblies"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <Border Background="{DynamicResource PFP_SectionBackgroundBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="1"
                CornerRadius="2"
                Height="120"
                Margin="0,0,0,6">
            <ListBox x:Name="RecentFilesList"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource PFP_TextBrush}"
                     FontSize="11"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionMode="Single"/>
        </Border>

        <Button x:Name="BtnClearRecent"
                Content="Clear All Recent"
                HorizontalAlignment="Left"
                Padding="8,4"
                FontSize="11"
                Background="{DynamicResource PFP_SectionBackgroundBrush}"
                Foreground="{DynamicResource PFP_TextBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="1"
                Click="OnClearRecentClick">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background"   Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
                    <Setter Property="Foreground"   Value="{DynamicResource PFP_TextBrush}"/>
                    <Setter Property="BorderBrush"  Value="{DynamicResource PFP_BorderBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Padding"      Value="8,4"/>
                    <Setter Property="FontSize"     Value="11"/>
                    <Setter Property="Cursor"       Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="2"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource PFP_ItemHoverBrush}"/>
                                        <Setter TargetName="Bd" Property="BorderBrush"
                                                Value="{DynamicResource PFP_InputBorderBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource PFP_BorderBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

    </StackPanel>
</UserControl>

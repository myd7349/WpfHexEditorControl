<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>WpfHexEditor.Plugins.AssemblyExplorer</RootNamespace>
    <AssemblyName>WpfHexEditor.Plugins.AssemblyExplorer</AssemblyName>
    <!-- Plugin metadata required by WpfHexEditor.SDK.targets to generate manifest.json -->
    <PluginId>WpfHexEditor.Plugins.AssemblyExplorer</PluginId>
    <PluginName>Assembly Explorer</PluginName>
    <PluginVersion>0.2.0</PluginVersion>
    <PluginEntryPoint>WpfHexEditor.Plugins.AssemblyExplorer.AssemblyExplorerPlugin</PluginEntryPoint>
    <PluginAuthor>Derek Tremblay</PluginAuthor>
    <PluginPublisher>WpfHexEditor</PluginPublisher>
    <PluginTrustedPublisher>true</PluginTrustedPublisher>
    <PluginDescription>Explores .NET and native PE assemblies with a VS-like tree view, metadata inspection, and PE offset sync with the hex editor.</PluginDescription>
    <PluginIsolationMode>Auto</PluginIsolationMode>
    <PluginLoadPriority>40</PluginLoadPriority>
    <PluginActivationOnStartup>false</PluginActivationOnStartup>
    <PluginActivationExtensions>".exe", ".dll", ".sys", ".ocx", ".netmodule"</PluginActivationExtensions>
    <PluginActivationCommands>"View.AssemblyExplorer"</PluginActivationCommands>
    <PluginMenuContributionsJson>[{"commandId":"View.AssemblyExplorer","label":"_Assembly Explorer","parentPath":"View","group":"Panels","category":"Core IDE","iconGlyph":"\uE943"}]</PluginMenuContributionsJson>
    <PluginSdkVersion>1.2.0</PluginSdkVersion>
    <PluginMinIDEVersion>0.3.0</PluginMinIDEVersion>
    <PluginPermAccessHexEditor>true</PluginPermAccessHexEditor>
    <PluginPermAccessFileSystem>true</PluginPermAccessFileSystem>
    <PluginPermAccessNetwork>false</PluginPermAccessNetwork>
    <PluginPermRegisterMenus>true</PluginPermRegisterMenus>
    <PluginPermWriteOutput>true</PluginPermWriteOutput>
    <!-- System.Reflection.Metadata and System.Reflection.PortableExecutable are BCL
         inbox assemblies in net8.0 — no NuGet PackageReference required. -->
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>WpfHexEditor.Plugins.AssemblyExplorer.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <!-- ICSharpCode.Decompiler: hard dependency for full C# decompilation (real method bodies).
         The SkeletonDecompilerBackend remains as an always-available BCL-only fallback.
         CopyLocalLockFileAssemblies ensures the DLL is emitted to the bin output directory
         (required for the plugin-dir copy step — the plugin loads in an isolated ALC). -->
    <PackageReference Include="ICSharpCode.Decompiler" Version="9.*" />
    <!-- ICSharpCode.CodeConverter: converts ILSpy C# output to VB.NET.
         Same team as ILSpy; uses Roslyn internally (Microsoft.CodeAnalysis.*).
         Roslyn assemblies resolve via the host ALC fallback (host app uses Roslyn for the
         code editor). If the host does not expose Roslyn, the VbNetDecompilationLanguage
         transform falls back gracefully to annotated C# without throwing. -->
    <PackageReference Include="ICSharpCode.CodeConverter" Version="10.0.1.923" />
  </ItemGroup>

  <PropertyGroup>
    <!-- Force NuGet lock-file assemblies (e.g. ICSharpCode.Decompiler netstandard2.0)
         to be copied into the output directory so CopyToPluginsDir can find them. -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\WpfHexEditor.SDK\WpfHexEditor.SDK.csproj" />
    <ProjectReference Include="..\..\Controls\WpfHexEditor.ProgressBar\WpfHexEditor.ProgressBar.csproj" />
  </ItemGroup>

  <Import Project="..\WpfHexEditor.SDK\Build\WpfHexEditor.SDK.targets" />

  <!-- Copy compiled plugin to App Plugins directory after build -->
  <Target Name="CopyToPluginsDir" AfterTargets="GeneratePluginManifest">
    <PropertyGroup>
      <PluginDestDir>$(MSBuildThisFileDirectory)..\..\WpfHexEditor.App\bin\$(Configuration)\net8.0-windows\Plugins\$(AssemblyName)\</PluginDestDir>
    </PropertyGroup>
    <MakeDir Directories="$(PluginDestDir)" />
    <!-- Core plugin DLLs -->
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll;$(OutputPath)$(AssemblyName).deps.json;$(OutputPath)manifest.json;$(OutputPath)WpfHexEditor.Core.AssemblyAnalysis.dll;$(OutputPath)ICSharpCode.Decompiler.dll;$(OutputPath)ICSharpCode.CodeConverter.dll" DestinationFolder="$(PluginDestDir)" OverwriteReadOnlyFiles="true" />
    <!-- Roslyn transitive deps needed by ICSharpCode.CodeConverter (VB.NET conversion).
         The host ALC does not always expose these; copy them alongside the plugin so
         the plugin's isolated ALC can resolve them. Uses an ItemGroup inside the Target
         so the glob expands at execution time (after NuGet restore).
         Covers: Microsoft.CodeAnalysis.dll, .CSharp.dll, .VisualBasic.dll, .Workspaces.* -->
    <ItemGroup>
      <_RoslynDlls Include="$(OutputPath)Microsoft.CodeAnalysis*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_RoslynDlls)" DestinationFolder="$(PluginDestDir)" OverwriteReadOnlyFiles="true" />
    <!-- VS Threading transitive deps needed by ICSharpCode.CodeConverter (VB.NET conversion).
         Covers: Microsoft.VisualStudio.Threading.dll, .Validation.dll, .Composition.dll, etc. -->
    <ItemGroup>
      <_VsThreadingDlls Include="$(OutputPath)Microsoft.VisualStudio.*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_VsThreadingDlls)" DestinationFolder="$(PluginDestDir)" OverwriteReadOnlyFiles="true" />
    <!-- System.Composition MEF assemblies (version 9.0.0) required by ICSharpCode.CodeConverter
         via Microsoft.VisualStudio.Composition. The .NET 8 SDK suppresses copy-local for these
         because System.Composition.* also ships as inbox assemblies at version 8.0.0.0 with the
         shared framework — so CopyLocalLockFileAssemblies=true does NOT place them in $(OutputPath).
         CodeConverter 10.x requires 9.0.0.0; to avoid the version mismatch we copy the 9.0.0
         DLLs directly from the global NuGet package cache, bypassing the SDK suppression.
         Note: $(NuGetPackageRoot) = C:\Users\<user>\.nuget\packages\ (trailing backslash).
               Backslash separators used throughout to avoid MSBuild glob issues on Windows. -->
    <ItemGroup>
      <_SystemCompositionDlls Include="$(NuGetPackageRoot)system.composition.*\9.0.0\lib\net8.0\*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_SystemCompositionDlls)" DestinationFolder="$(PluginDestDir)" OverwriteReadOnlyFiles="true" />
  </Target>

</Project>

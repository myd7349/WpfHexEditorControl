<!--
    Project: WpfHexEditor.Plugins.AssemblyExplorer
    File: Controls/AssemblyTreeView.xaml
    Author: Derek Tremblay
    Created: 2026-03-08
    Description:
        Custom TreeView for the Assembly Explorer panel.
        Uses VS-style icons (Segoe MDL2 Assets) beside each node label.
        VirtualizingPanel enabled + Recycling mode for large assemblies.
        Theme: DynamicResource PFP_* brush tokens.
        ContextMenu defined in UserControl.Resources (same pattern as PluginManagerControl)
        so that MenuItem.Icon icons resolve correctly.
-->
<UserControl x:Class="WpfHexEditor.Plugins.AssemblyExplorer.Controls.AssemblyTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.AssemblyExplorer.ViewModels"
             xmlns:conv="clr-namespace:WpfHexEditor.Plugins.AssemblyExplorer.Converters">

    <UserControl.Resources>
        <conv:NodeTypeToIconConverter x:Key="NodeIconConverter"/>
        <conv:MemberAccessToVisibilityConverter x:Key="AccessConverter"/>

        <!--
            Explicit implicit styles for ContextMenu and MenuItem.
            Required because the plugin's AssemblyLoadContext may not reach
            Application.Resources for implicit style lookup in popup windows.
            DockDarkContextMenuStyle sets Grid.IsSharedSizeScope="True" on the popup
            border — without it, SharedSizeGroup="MenuItemIconGroup" has no scope
            and the icon column collapses to zero width.
        -->
        <Style TargetType="{x:Type ContextMenu}" BasedOn="{StaticResource DockDarkContextMenuStyle}"/>
        <Style TargetType="{x:Type MenuItem}"    BasedOn="{StaticResource DockDarkMenuItemStyle}"/>
        <Style TargetType="{x:Type Separator}"   BasedOn="{StaticResource DockDarkMenuSeparatorStyle}"/>

        <!-- Expander toggle button: chevron arrow, themed -->
        <Style x:Key="TreeExpanderStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Width"     Value="16"/>
            <Setter Property="Height"    Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Width="16" Height="16">
                            <Path x:Name="Arrow"
                                  Data="M 4 2 L 12 8 L 4 14 Z"
                                  Fill="{DynamicResource PFP_SubTextBrush}"
                                  Stretch="Uniform"
                                  Width="6" Height="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value><RotateTransform Angle="90"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Item container: full ControlTemplate so selected bg uses PFP tokens, not SystemColors -->
        <Style x:Key="AsmTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded"  Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected"  Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="ToolTip"     Value="{Binding ToolTipText}"/>
            <Setter Property="Foreground"  Value="{DynamicResource PFP_TextBrush}"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <!-- Expand/collapse arrow -->
                            <ToggleButton x:Name="Expander"
                                          Grid.Row="0" Grid.Column="0"
                                          Style="{StaticResource TreeExpanderStyle}"
                                          IsChecked="{Binding IsExpanded,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>

                            <!-- Row highlight + content -->
                            <Border x:Name="Bd"
                                    Grid.Row="0" Grid.Column="1"
                                    Background="Transparent"
                                    Padding="2,1">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                            </Border>

                            <!-- Children -->
                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.Row="1" Grid.Column="1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource PFP_ItemHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource PFP_ItemSelectedBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource PFP_ItemSelectedForegroundBrush}"/>
                            </Trigger>
                            <!-- Keep selection visible when TreeView loses keyboard focus -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"        Value="True"/>
                                    <Condition Property="IsSelectionActive" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource PFP_ItemSelectedBrush}"/>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </MultiTrigger>
                            <!-- Deep filter: collapse nodes not matching search -->
                            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Root node DataTemplate — shows pin badge when IsPinned=true -->
        <HierarchicalDataTemplate DataType="{x:Type vm:AssemblyRootNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <!-- Assembly icon (teal) -->
                <TextBlock Text="{Binding Converter={StaticResource NodeIconConverter}}"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,2,0"
                           Foreground="{Binding IconBrush}"/>
                <!-- Pin badge: visible only when IsPinned=true -->
                <TextBlock Text="&#xE840;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="8"
                           VerticalAlignment="Center"
                           Margin="0,0,3,0"
                           Foreground="{DynamicResource PFP_AccentBrush}"
                           ToolTip="Pinned — this assembly will not be evicted automatically">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding DisplayName}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Default node DataTemplate -->
        <HierarchicalDataTemplate DataType="{x:Type vm:AssemblyNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <!-- Semantic color icon -->
                <TextBlock Text="{Binding Converter={StaticResource NodeIconConverter}}"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,2,0"
                           Foreground="{Binding IconBrush}"/>
                <!-- Lock badge: visible only for non-public members/types -->
                <TextBlock Text="&#xE72E;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="8"
                           VerticalAlignment="Center"
                           Margin="0,0,3,0"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           Visibility="{Binding IsPublic,
                                                Converter={StaticResource AccessConverter},
                                                ConverterParameter=invert}"/>
                <TextBlock Text="{Binding DisplayName}"
                           VerticalAlignment="Center"
                           FontSize="12"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!--
            Context menu defined here in Resources (same pattern as PluginManagerControl).
            Style and ItemContainerStyle are set explicitly because the plugin runs in a
            separate AssemblyLoadContext where implicit style lookup may not reach
            Application.Resources, causing Grid.IsSharedSizeScope to never be established
            and the MenuItem icon column (SharedSizeGroup="MenuItemIconGroup") to collapse.
        -->
        <ContextMenu x:Key="AsmNodeContextMenu"
                     Opened="OnContextMenuOpened">

            <MenuItem x:Name="MenuHighlightInHex" Header="Highlight in Hex Editor"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Open assembly file in hex editor and navigate to this member's byte range"
                      Click="OnHighlightInHexEditor">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem x:Name="MenuOpenInHex" Header="Open Assembly File in Hex Editor"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Open the raw assembly bytes in the hex editor (no navigation)"
                      Click="OnOpenInHexEditor">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem x:Name="MenuCopyName" Header="Copy Name"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Click="OnCopyName">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem x:Name="MenuCopyFull" Header="Copy Full Name"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Click="OnCopyFullName">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem x:Name="MenuCopyOffset" Header="Copy IL Offset"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Click="OnCopyOffset">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <MenuItem x:Name="MenuGoToDefinition"
                      Header="Go to Definition"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Click="OnGoToDefinition">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <!-- Submenu items are built dynamically in RebuildDecompileSubmenu (ADR-ASM-03) -->
            <MenuItem x:Name="MenuDecompile"
                      Header="Decompile to…"
                      Foreground="{DynamicResource DockMenuForegroundBrush}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem x:Name="MenuExtractToProject" Header="Extract to Project…"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Decompile and add .cs file to the loaded project"
                      Click="OnExtractToProject">
                <MenuItem.Icon>
                    <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem x:Name="MenuShowInMetadata"
                      Header="Show in Metadata Tables"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Click="OnShowInMetadataTables">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <MenuItem x:Name="MenuExportIL"
                      Header="Export IL"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Click="OnExportIL">
                <MenuItem.Icon>
                    <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem x:Name="MenuExportCSharp"
                      Header="Export C#"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Click="OnExportCSharp">
                <MenuItem.Icon>
                    <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <MenuItem x:Name="MenuPin" Header="Pin Assembly"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Pin this assembly so it is not evicted when the active file changes"
                      Click="OnPinAssembly">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE840;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem x:Name="MenuCompareWith" Header="Compare with…"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Open the Diff panel with this assembly pre-selected as baseline"
                      Click="OnCompareWith">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8AD;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <MenuItem x:Name="MenuCollapseAll" Header="Collapse All"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      ToolTip="Collapse all nodes in the tree"
                      Click="OnCollapseAll">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8AA;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem x:Name="MenuCloseAllAssemblies" Header="Close All Assemblies"
                      Foreground="#EF4444"
                      ToolTip="Unload all assemblies from the workspace"
                      Click="OnCloseAllAssemblies">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="#EF4444"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <MenuItem x:Name="MenuCloseAssembly" Header="Close Assembly"
                      Foreground="#EF4444"
                      Click="OnCloseAssembly">
                <MenuItem.Icon>
                    <TextBlock Text="&#xED60;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="#EF4444"/>
                </MenuItem.Icon>
            </MenuItem>

        </ContextMenu>

    </UserControl.Resources>

    <TreeView x:Name="InnerTreeView"
              Background="{DynamicResource PFP_PanelBackgroundBrush}"
              Foreground="{DynamicResource PFP_TextBrush}"
              BorderThickness="0"
              ItemContainerStyle="{StaticResource AsmTreeItemStyle}"
              VirtualizingPanel.IsVirtualizing="True"
              VirtualizingPanel.VirtualizationMode="Recycling"
              ScrollViewer.HorizontalScrollBarVisibility="Auto"
              SelectedItemChanged="OnSelectedItemChanged"
              ContextMenu="{StaticResource AsmNodeContextMenu}"/>

</UserControl>

{
  "id": "WpfHexEditor.Plugins.AssemblyExplorer",
  "name": "Assembly Explorer",
  "author": "Derek Tremblay",
  "publisher": "WpfHexEditor",
  "trustedPublisher": true,
  "version": "0.1.0",
  "sdkVersion": "1.0.0",
  "minIDEVersion": "0.2.0",
  "description": "Explores .NET and native PE assemblies with a VS-like tree view, metadata inspection, and PE offset sync with the hex editor.",
  "entryPoint": "WpfHexEditor.Plugins.AssemblyExplorer.AssemblyExplorerPlugin",
  "isolationMode": "InProcess",
  "loadPriority": 40,
  "assembly": {
    "file": "WpfHexEditor.Plugins.AssemblyExplorer.dll"
  },
  "permissions": {
    "accessHexEditor": true,
    "accessFileSystem": true,
    "registerMenus": true,
    "writeOutput": true,
    "accessSettings": true
  }
}

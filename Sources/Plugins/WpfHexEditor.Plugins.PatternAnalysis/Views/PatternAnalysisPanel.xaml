<UserControl x:Class="WpfHexEditor.Plugins.PatternAnalysis.Views.PatternAnalysisPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350"
             xmlns:paSvc="clr-namespace:WpfHexEditor.Plugins.PatternAnalysis.Services">

    <UserControl.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <paSvc:PatternAnalysisLocalizedDictionary/>
                </ResourceDictionary.MergedDictionaries>

        <!-- Semantic entropy brushes (constant across themes) -->
        <SolidColorBrush x:Key="LowEntropyBrush"    Color="#7ED321"/>
        <SolidColorBrush x:Key="MediumEntropyBrush" Color="#F5A623"/>
        <SolidColorBrush x:Key="HighEntropyBrush"   Color="#FF6B6B"/>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{DynamicResource PFP_AccentBrush}"/>
            <Setter Property="Margin"       Value="0,16,0,8"/>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_SubTextBrush}"/>
            <Setter Property="Margin"     Value="0,0,8,0"/>
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"       Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="4"/>
            <Setter Property="Padding"          Value="12"/>
            <Setter Property="Margin"           Value="0,0,0,8"/>
        </Style>
                </ResourceDictionary>
        </UserControl.Resources>

    <Grid Background="{DynamicResource PFP_PanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border x:Name="ToolbarBorder"
                Grid.Row="0"
                Style="{StaticResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="True">
                <!-- Right: always-visible placeholder -->
                <StackPanel x:Name="ToolbarRightPanel"
                            Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center"/>

                <!-- Overflow button -->
                <Button x:Name="ToolbarOverflowButton"
                        DockPanel.Dock="Right"
                        Visibility="Collapsed"
                        Style="{StaticResource PanelIconButtonStyle}" ToolTip="{StaticResource PatternAnalysis_MoreOptions}"
                        Click="OnOverflowButtonClick">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowContextMenu" Opened="OnOverflowMenuOpened">
                            <MenuItem Header="{StaticResource PatternAnalysis_AnalyzeMenu}"
                                      Tag="TbgPatternRefresh"
                                      Click="AnalyzeButton_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Group: TbgPatternRefresh [0] -->
                <StackPanel x:Name="TbgPatternRefresh"
                            Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE72C;" ToolTip="{StaticResource PatternAnalysis_AnalyzeTooltip}"
                            Click="AnalyzeButton_Click"/>
                </StackPanel>

                <TextBlock Text="{StaticResource PatternAnalysis_Title}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12">

                <!-- Status Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="StatusCard">
                    <StackPanel>
                        <TextBlock x:Name="StatusTextBlock" Text="{StaticResource PatternAnalysis_ClickToStart}"
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"/>
                        <Button x:Name="AnalyzeButton" Content="{StaticResource PatternAnalysis_AnalyzeSelection}"
                                Style="{StaticResource PanelDropdownButtonStyle}"
                                Height="28" Margin="0,8,0,0"
                                Padding="12,3"
                                Click="AnalyzeButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- Entropy Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="EntropyCard" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{StaticResource PatternAnalysis_EntropySection}" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{StaticResource PatternAnalysis_EntropyLabel}" Style="{StaticResource MetricLabelStyle}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock x:Name="EntropyValueText" Text="0.00" Style="{StaticResource MetricValueStyle}"/>
                                <TextBlock Text="{StaticResource PatternAnalysis_MaxBits}" FontSize="10"
                                           Foreground="{DynamicResource PFP_SubTextBrush}"
                                           Margin="4,0,0,0" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="8" Background="{DynamicResource PFP_BorderBrush}" CornerRadius="4" Margin="0,0,0,8">
                            <Border x:Name="EntropyBar"
                                    HorizontalAlignment="Left"
                                    CornerRadius="4"
                                    Background="{StaticResource MediumEntropyBrush}"/>
                        </Border>

                        <TextBlock x:Name="EntropyInterpretation"
                                   Text="{StaticResource PatternAnalysis_Entropy_Medium}"
                                   FontSize="10" FontStyle="Italic"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Byte Distribution Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="DistributionCard" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{StaticResource PatternAnalysis_ByteDistribution}" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>

                        <Border Height="150"
                                Background="{DynamicResource PFP_PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource PFP_BorderBrush}"
                                BorderThickness="1" Padding="4" Margin="0,0,0,8">
                            <Canvas x:Name="HistogramCanvas"/>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource PatternAnalysis_MostFrequent}" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="MostFrequentByteText"
                                       Text="0x00" FontFamily="Consolas"
                                       Foreground="{DynamicResource PFP_TextBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource PatternAnalysis_UniqueBytes}" Style="{StaticResource MetricLabelStyle}" Margin="0,4,8,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="UniqueBytesText"
                                       Text="0 / 256" Margin="0,4,0,0"
                                       Foreground="{DynamicResource PFP_TextBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Detected Patterns Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="PatternsCard" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{StaticResource PatternAnalysis_DetectedPatterns}" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>

                        <ItemsControl x:Name="PatternsListBox">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Panel_ItemHoverBrush}"
                                            BorderBrush="{DynamicResource PFP_BorderBrush}"
                                            BorderThickness="1" CornerRadius="3"
                                            Padding="8" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Pattern}"
                                                           FontFamily="Consolas" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PFP_TextBrush}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="9" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource PFP_SubTextBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoPatternsText" Text="{StaticResource PatternAnalysis_NoPatterns}"
                                   FontSize="10" FontStyle="Italic"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Anomalies Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="AnomaliesCard" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{StaticResource PA_Anomalies}" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>

                        <ItemsControl x:Name="AnomaliesListBox">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Panel_WarningBackgroundBrush}"
                                            BorderBrush="{DynamicResource Panel_WarningBorderBrush}"
                                            BorderThickness="1" CornerRadius="3"
                                            Padding="8" Margin="0,0,0,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold" FontSize="10"
                                                       Foreground="{DynamicResource Panel_WarningTextBrush}"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="9" Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoAnomaliesText"
                                   Text="{StaticResource PA_NoAnomalies}"
                                   FontSize="10"
                                   Foreground="{DynamicResource PFP_AccentBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

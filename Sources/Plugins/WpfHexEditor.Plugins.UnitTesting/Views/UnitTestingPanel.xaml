<UserControl x:Class="WpfHexEditor.Plugins.UnitTesting.Views.UnitTestingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.UnitTesting.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- null → Collapsed, non-null → Visible -->
        <vm:NullToVisibilityConverter x:Key="NullToVis"/>

        <!-- int count → star GridLength for ratio bar -->
        <vm:IntToStarGridLengthConverter x:Key="StarGL"/>

        <!-- Spinner rotation animation -->
        <Storyboard x:Key="SpinStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:1.2"/>
        </Storyboard>

        <!-- Outcome glyph base style -->
        <Style x:Key="OutcomeGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="4,0,6,0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><RotateTransform/></Setter.Value>
            </Setter>
        </Style>

        <!-- Filter toggle button style — ControlTemplate required so Background triggers apply -->
        <Style x:Key="FilterToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding"         Value="6,2"/>
            <Setter Property="Margin"          Value="0,0,2,0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource UT_SelectionBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource UT_HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search box style — custom template removes Aero2 blue focus chrome -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background"             Value="{DynamicResource UT_SearchBoxBrush}"/>
            <Setter Property="Foreground"             Value="{DynamicResource DockWindowForegroundBrush}"/>
            <Setter Property="BorderBrush"            Value="{DynamicResource DockSplitterBrush}"/>
            <Setter Property="BorderThickness"        Value="1"/>
            <Setter Property="Padding"                Value="4,2,22,2"/>
            <Setter Property="FontSize"               Value="11"/>
            <Setter Property="FocusVisualStyle"       Value="{x:Null}"/>
            <Setter Property="CaretBrush"             Value="{DynamicResource DockWindowForegroundBrush}"/>
            <Setter Property="SelectionBrush"         Value="{DynamicResource UT_SelectionBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          Focusable="False"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource UT_SelectionBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TestResultTemplate" DataType="{x:Type vm:TestResultRow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <!-- Outcome glyph (with spinner animation when running) -->
                <TextBlock Grid.Column="0" Text="{Binding OutcomeGlyph}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource OutcomeGlyphStyle}">
                            <Setter Property="Foreground" Value="{DynamicResource UT_SkipForegroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Outcome}" Value="Passed">
                                    <Setter Property="Foreground" Value="{DynamicResource UT_PassForegroundBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Outcome}" Value="Failed">
                                    <Setter Property="Foreground" Value="{DynamicResource UT_FailForegroundBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource UT_SkipForegroundBrush}"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="SpinBegin" Storyboard="{StaticResource SpinStoryboard}"/>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="SpinBegin"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Test name -->
                <TextBlock Grid.Column="1" Text="{Binding Display}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontFamily="Cascadia Mono, Consolas, monospace"
                           FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource DockWindowForegroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Outcome}" Value="Failed">
                                    <Setter Property="Foreground" Value="{DynamicResource UT_FailForegroundBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="FontStyle" Value="Italic"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Duration (ms) -->
                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,6,0"
                           FontSize="11"
                           Opacity="0.65"
                           Foreground="{DynamicResource DockWindowForegroundBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOutput}" Value="False">
                                    <Setter Property="Text" Value="{Binding DurationMs, StringFormat='{}{0} ms'}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                    <Setter Property="Text" Value=""/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource DockWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: Toolbar -->
            <RowDefinition Height="Auto"/>   <!-- 1: Filter bar -->
            <RowDefinition Height="2"/>      <!-- 2: Progress bar -->
            <RowDefinition Height="*"/>      <!-- 3: ContentArea (results + splitter + detail) -->
            <RowDefinition Height="Auto"/>   <!-- 4: Ratio bar -->
            <RowDefinition Height="Auto"/>   <!-- 5: Status bar -->
        </Grid.RowDefinitions>

        <!-- ─── Row 0: Toolbar ───────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource PanelToolbarStyle}">
            <DockPanel LastChildFill="False">

                <!-- LEFT: action buttons -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="2,0">
                    <Button x:Name="RunButton"
                            Style="{StaticResource PanelIconButtonStyle}"
                            Width="Auto" Padding="6,0"
                            ToolTip="Run All Tests (Ctrl+R)"
                            Click="OnRunAllClicked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Run All" FontSize="11" VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="RunFailedButton"
                            Style="{StaticResource PanelIconButtonStyle}"
                            Width="Auto" Padding="6,0"
                            IsEnabled="{Binding CanRunFailed}"
                            ToolTip="Run Failed Tests"
                            Click="OnRunFailedClicked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEB90;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource UT_FailForegroundBrush}"/>
                            <TextBlock Text="Run Failed" FontSize="11" VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="StopButton"
                            Style="{StaticResource PanelIconButtonStyle}"
                            Width="Auto" Padding="6,0"
                            IsEnabled="False"
                            ToolTip="Stop Tests"
                            Click="OnStopClicked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Stop" FontSize="11" VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            ToolTip="Clear Results"
                            Click="OnClearClicked">
                        <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    </Button>
                </StackPanel>

                <!-- Separator -->
                <Rectangle DockPanel.Dock="Left" Width="1" Margin="4,4"
                           Fill="{DynamicResource Panel_ToolbarBorderBrush}"
                           VerticalAlignment="Stretch"/>

                <!-- RIGHT: settings gear dropdown -->
                <Button x:Name="SettingsButton"
                        DockPanel.Dock="Right"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTip="Unit Testing Settings"
                        Click="OnSettingsClicked">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    <Button.ContextMenu>
                        <ContextMenu Background="{DynamicResource DockMenuBackgroundBrush}"
                                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                                     BorderBrush="{DynamicResource DockBorderBrush}">
                            <!-- Run Behavior -->
                            <MenuItem x:Name="MiAutoRun"
                                      Header="Auto-run on build"
                                      IsCheckable="True"
                                      Click="OnOptionChanged"/>
                            <MenuItem x:Name="MiAutoExpand"
                                      Header="Auto-expand detail on failure"
                                      IsCheckable="True"
                                      Click="OnOptionChanged"/>
                            <Separator/>
                            <!-- Display -->
                            <MenuItem x:Name="MiRatioBar"
                                      Header="Show ratio bar"
                                      IsCheckable="True"
                                      Click="OnOptionChanged"/>
                            <MenuItem x:Name="MiGroupByClass"
                                      Header="Group results by class"
                                      IsCheckable="True"
                                      Click="OnOptionChanged"/>
                            <Separator/>
                            <!-- Sort order -->
                            <MenuItem Header="Sort by">
                                <MenuItem x:Name="MiSortName"
                                          Header="Name"
                                          IsCheckable="True"
                                          Click="OnSortChanged"/>
                                <MenuItem x:Name="MiSortOutcome"
                                          Header="Outcome"
                                          IsCheckable="True"
                                          Click="OnSortChanged"/>
                                <MenuItem x:Name="MiSortDuration"
                                          Header="Duration (slowest first)"
                                          IsCheckable="True"
                                          Click="OnSortChanged"/>
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- RIGHT: detail pane layout dropdown -->
                <Button x:Name="LayoutButton"
                        DockPanel.Dock="Right"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTip="Detail pane layout"
                        Click="OnLayoutButtonClicked">
                    <TextBlock x:Name="LayoutGlyph" Text="&#xE8BC;"
                               FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    <Button.ContextMenu>
                        <ContextMenu Background="{DynamicResource DockMenuBackgroundBrush}"
                                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                                     BorderBrush="{DynamicResource DockBorderBrush}">
                            <MenuItem x:Name="MiLayoutTopBottom"
                                      Header="Top / Bottom"
                                      IsCheckable="True" IsChecked="True"
                                      Click="OnLayoutChanged"/>
                            <MenuItem x:Name="MiLayoutLeftRight"
                                      Header="Left / Right"
                                      IsCheckable="True"
                                      Click="OnLayoutChanged"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

            </DockPanel>
        </Border>

        <!-- ─── Row 1: Filter bar ─────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource UT_ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource DockSplitterBrush}"
                BorderThickness="0,1,0,0"
                Padding="4,2">
            <DockPanel>
                <!-- Filter toggles -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton Style="{StaticResource FilterToggleStyle}"
                                  IsChecked="{Binding FilterAll, Mode=OneWay}"
                                  Click="OnFilterAll"
                                  ToolTip="Show all tests">
                        <TextBlock Text="All" FontSize="11" Foreground="{DynamicResource DockWindowForegroundBrush}"/>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource FilterToggleStyle}"
                                  IsChecked="{Binding FilterPassed, Mode=OneWay}"
                                  Click="OnFilterPassed"
                                  ToolTip="Show passed tests">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE930;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Margin="0,0,3,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource UT_PassForegroundBrush}"/>
                            <TextBlock Text="Passed" FontSize="11"
                                       Foreground="{DynamicResource UT_PassForegroundBrush}"/>
                            <TextBlock FontSize="11" Margin="4,0,0,0" Opacity="0.75"
                                       Foreground="{DynamicResource UT_PassForegroundBrush}"
                                       Text="{Binding PassCount}"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource FilterToggleStyle}"
                                  IsChecked="{Binding FilterFailed, Mode=OneWay}"
                                  Click="OnFilterFailed"
                                  ToolTip="Show failed tests">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEB90;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Margin="0,0,3,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource UT_FailForegroundBrush}"/>
                            <TextBlock Text="Failed" FontSize="11"
                                       Foreground="{DynamicResource UT_FailForegroundBrush}"/>
                            <TextBlock FontSize="11" Margin="4,0,0,0" Opacity="0.75"
                                       Foreground="{DynamicResource UT_FailForegroundBrush}"
                                       Text="{Binding FailCount}"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource FilterToggleStyle}"
                                  IsChecked="{Binding FilterSkipped, Mode=OneWay}"
                                  Click="OnFilterSkipped"
                                  ToolTip="Show skipped tests">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE89A;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Margin="0,0,3,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource UT_SkipForegroundBrush}"/>
                            <TextBlock Text="Skipped" FontSize="11"
                                       Foreground="{DynamicResource UT_SkipForegroundBrush}"/>
                            <TextBlock FontSize="11" Margin="4,0,0,0" Opacity="0.75"
                                       Foreground="{DynamicResource UT_SkipForegroundBrush}"
                                       Text="{Binding SkipCount}"/>
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>

                <!-- Search box -->
                <Grid DockPanel.Dock="Right" Width="180" VerticalAlignment="Center" Margin="4,0,0,0">
                    <TextBox x:Name="SearchBox"
                             Style="{StaticResource SearchBoxStyle}"
                             TextChanged="OnSearchTextChanged"/>
                    <!-- Placeholder -->
                    <TextBlock IsHitTestVisible="False" Text="Filter tests…"
                               FontSize="11" Opacity="0.45"
                               VerticalAlignment="Center" Margin="6,0,0,0"
                               Foreground="{DynamicResource DockWindowForegroundBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Clear button -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="18" Height="18" Margin="0,0,2,0"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand"
                            Click="OnClearSearch"
                            ToolTip="Clear filter">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox, FallbackValue=0}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="9" VerticalAlignment="Center"
                                   Foreground="{DynamicResource DockWindowForegroundBrush}"/>
                    </Button>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ─── Row 2: Progress bar (2px, running only) ──────────── -->
        <ProgressBar Grid.Row="2"
                     Height="2"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource UT_PassForegroundBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>

        <!-- ─── Row 3: ContentArea (results + splitter + detail) ──── -->
        <Grid x:Name="ContentArea" Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto" MinHeight="0"/>
            </Grid.RowDefinitions>

            <!-- Results list -->
            <ListView x:Name="ResultsList"
                      Grid.Row="0"
                      ItemsSource="{Binding FilteredResults}"
                      ItemTemplate="{StaticResource TestResultTemplate}"
                      Background="Transparent"
                      BorderThickness="0"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      SelectionMode="Single"
                      SelectionChanged="OnResultSelectionChanged">
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold" FontSize="11"
                                           Foreground="{DynamicResource DockWindowForegroundBrush}"
                                           Margin="4,6,0,2" Opacity="0.7"/>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Run This Test"    Click="OnRunThisTestClicked"
                                  IsEnabled="{Binding PlacementTarget.SelectedItem.IsPlaceholder,
                                              RelativeSource={RelativeSource AncestorType=ContextMenu},
                                              Converter={StaticResource BoolToVis}, FallbackValue=True}"/>
                        <Separator/>
                        <MenuItem Header="Copy Test Name"   Click="OnCopyTestNameClicked"/>
                        <MenuItem Header="Copy Stack Trace" Click="OnCopyStackTraceClicked"/>
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding"                    Value="2,1"/>
                        <Setter Property="Background"                 Value="Transparent"/>
                        <Setter Property="BorderThickness"            Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource UT_RunningRowBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Outcome}" Value="Failed">
                                <Setter Property="Background" Value="{DynamicResource UT_FailRowBackgroundBrush}"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource UT_HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource UT_SelectionBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- GridSplitter (only when detail is visible) -->
            <GridSplitter x:Name="ContentSplitter"
                          Grid.Row="1"
                          Height="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockSplitterBrush}"
                          Visibility="{Binding SelectedResult, Converter={StaticResource NullToVis}}"/>

            <!-- Detail pane -->
            <Border x:Name="DetailPane"
                    Grid.Row="2"
                    Background="{DynamicResource UT_StatusBarBackgroundBrush}"
                    BorderBrush="{DynamicResource DockSplitterBrush}"
                    BorderThickness="0,1,0,0"
                    MinHeight="100" MaxHeight="260"
                    Visibility="{Binding SelectedResult, Converter={StaticResource NullToVis}}">
                <Grid Margin="6,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header: name + assembly + copy button -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right"
                                ToolTip="Copy Stack Trace"
                                Padding="4,2" Margin="4,0,0,0"
                                Background="Transparent" BorderThickness="0"
                                Click="OnCopyStackTraceClicked">
                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource DockWindowForegroundBrush}"/>
                        </Button>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding SelectedResult.AssemblyName}"
                                   FontSize="10" Opacity="0.55"
                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource DockWindowForegroundBrush}"/>
                        <TextBlock Text="{Binding SelectedResult.Display}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="12" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource DockWindowForegroundBrush}"/>
                    </DockPanel>

                    <!-- Error message (only when failed) -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding SelectedResult.ErrorMessage}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource UT_FailForegroundBrush}"
                               Visibility="{Binding SelectedResult.HasDetail, Converter={StaticResource BoolToVis}}"/>

                    <!-- Stack trace (scrollable) -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Visibility="{Binding SelectedResult.HasDetail, Converter={StaticResource BoolToVis}}">
                        <TextBox Text="{Binding SelectedResult.StackTrace, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Cascadia Mono, Consolas, monospace"
                                 FontSize="11"
                                 Foreground="{DynamicResource DockWindowForegroundBrush}"
                                 TextWrapping="NoWrap"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ─── Row 4: Pass/Fail ratio bar (hidden via ShowRatioBar option) ── -->
        <Grid Grid.Row="4" Height="6"
              Visibility="{Binding ShowRatioBar, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding PassCount, Converter={StaticResource StarGL}}"/>
                <ColumnDefinition Width="{Binding FailCount, Converter={StaticResource StarGL}}"/>
                <ColumnDefinition Width="{Binding SkipCount, Converter={StaticResource StarGL}}"/>
            </Grid.ColumnDefinitions>
            <Rectangle Grid.Column="0" Fill="{DynamicResource UT_PassForegroundBrush}" Opacity="0.75"/>
            <Rectangle Grid.Column="1" Fill="{DynamicResource UT_FailForegroundBrush}" Opacity="0.75"/>
            <Rectangle Grid.Column="2" Fill="{DynamicResource UT_SkipForegroundBrush}" Opacity="0.5"/>
        </Grid>

        <!-- ─── Row 5: Status bar ─────────────────────────────────── -->
        <Border Grid.Row="5"
                Background="{DynamicResource UT_StatusBarBackgroundBrush}"
                BorderBrush="{DynamicResource DockSplitterBrush}"
                BorderThickness="0,1,0,0"
                Padding="6,3">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource DockWindowForegroundBrush}"
                       FontSize="11" Opacity="0.75"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</UserControl>

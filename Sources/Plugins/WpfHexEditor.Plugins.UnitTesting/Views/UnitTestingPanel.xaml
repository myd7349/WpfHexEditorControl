<UserControl x:Class="WpfHexEditor.Plugins.UnitTesting.Views.UnitTestingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.UnitTesting.ViewModels">

    <UserControl.Resources>
        <!-- Pass / Fail / Skip colors -->
        <SolidColorBrush x:Key="TP_PassBrush"    Color="#4EC9B0"/>
        <SolidColorBrush x:Key="TP_FailBrush"    Color="#F14C4C"/>
        <SolidColorBrush x:Key="TP_SkipBrush"    Color="#9CDCFE"/>

        <!-- Outcome → foreground selector -->
        <Style x:Key="OutcomeGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"      Value="4,0,6,0"/>
        </Style>

        <DataTemplate x:Key="TestResultTemplate" DataType="{x:Type vm:TestResultRow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <!-- Outcome glyph -->
                <TextBlock Grid.Column="0"
                           Text="{Binding OutcomeGlyph}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource OutcomeGlyphStyle}">
                            <Setter Property="Foreground" Value="{StaticResource TP_SkipBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Outcome}" Value="Passed">
                                    <Setter Property="Foreground" Value="{StaticResource TP_PassBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Outcome}" Value="Failed">
                                    <Setter Property="Foreground" Value="{StaticResource TP_FailBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Test name or output line -->
                <TextBlock Grid.Column="1" Text="{Binding Display}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontFamily="Cascadia Mono, Consolas, monospace"
                           FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource DockWindowForegroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Outcome}" Value="Failed">
                                    <Setter Property="Foreground" Value="{StaticResource TP_FailBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Duration (ms) — only for real test results -->
                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,6,0"
                           FontSize="11"
                           Opacity="0.65"
                           Foreground="{DynamicResource DockWindowForegroundBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOutput}" Value="False">
                                    <Setter Property="Text" Value="{Binding DurationMs, StringFormat='{}{0} ms'}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource DockWindowBackgroundBrush}">

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Background="Transparent">
            <Button x:Name="RunButton" ToolTip="Run All Tests (Ctrl+R)"
                    Padding="8,3" Margin="0,0,3,0"
                    Click="OnRunAllClicked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Margin="0,0,4,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Run All" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button x:Name="StopButton" ToolTip="Stop Tests"
                    Padding="8,3" Margin="0,0,3,0"
                    IsEnabled="False"
                    Click="OnStopClicked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Margin="0,0,4,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Stop" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button ToolTip="Clear Results"
                    Padding="8,3" Margin="0,0,3,0"
                    Click="OnClearClicked">
                <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets"
                           FontSize="13" VerticalAlignment="Center"/>
            </Button>
            <Separator/>
            <!-- Counters -->
            <TextBlock Margin="6,0,3,0" VerticalAlignment="Center"
                       FontFamily="Segoe MDL2 Assets" FontSize="13" Text="&#xE930;"
                       Foreground="{StaticResource TP_PassBrush}"/>
            <TextBlock x:Name="PassCountText" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{StaticResource TP_PassBrush}" FontSize="12"
                       Text="{Binding PassCount}"/>
            <TextBlock VerticalAlignment="Center"
                       FontFamily="Segoe MDL2 Assets" FontSize="13" Text="&#xEB90;"
                       Foreground="{StaticResource TP_FailBrush}"/>
            <TextBlock x:Name="FailCountText" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{StaticResource TP_FailBrush}" FontSize="12"
                       Text="{Binding FailCount}"/>
            <TextBlock VerticalAlignment="Center"
                       FontFamily="Segoe MDL2 Assets" FontSize="13" Text="&#xE89A;"
                       Foreground="{StaticResource TP_SkipBrush}"/>
            <TextBlock x:Name="SkipCountText" VerticalAlignment="Center"
                       Foreground="{StaticResource TP_SkipBrush}" FontSize="12"
                       Text="{Binding SkipCount}"/>
        </ToolBar>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource DockWindowBackgroundBrush}"
                Padding="6,2">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource DockWindowForegroundBrush}"
                       FontSize="11" Opacity="0.75"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Results list -->
        <ListView x:Name="ResultsList"
                  ItemsSource="{Binding Results}"
                  ItemTemplate="{StaticResource TestResultTemplate}"
                  Background="Transparent"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  SelectionMode="Single"
                  SelectionChanged="OnResultSelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding"           Value="2,1"/>
                    <Setter Property="Background"        Value="Transparent"/>
                    <Setter Property="BorderThickness"   Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource DockDocumentHighlightedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource DockDocumentHighlightedBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </DockPanel>
</UserControl>

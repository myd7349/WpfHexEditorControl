<UserControl
    x:Class="WpfHexEditor.Plugins.DiagnosticTools.Views.DiagnosticToolsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:WpfHexEditor.Plugins.DiagnosticTools.Controls"
    xmlns:vm="clr-namespace:WpfHexEditor.Plugins.DiagnosticTools.ViewModels"
    Background="{DynamicResource DT_PanelBackground}"
    Foreground="{DynamicResource DT_PanelForeground}"
    FontFamily="Segoe UI"
    FontSize="12">

    <UserControl.Resources>

        <!-- Implicit styles: reference DT_* theme tokens only — no hard-coded colors -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground"  Value="{DynamicResource DT_PanelForeground}" />
            <Setter Property="Background"  Value="{DynamicResource DT_ToolbarBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DT_GraphBorder}" />
            <Setter Property="Padding"     Value="8,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="2,2,0,0"
                                Margin="0,0,2,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource DT_PanelBackground}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource DT_GraphBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DT_SectionHeader}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin"     Value="4,6,4,2" />
            <Setter Property="FontSize"   Value="11" />
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DT_PanelForeground}" />
            <Setter Property="Margin"     Value="4,0,4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DT_StatusForeground}" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Margin"     Value="0,0,10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize"        Value="14" />
            <Setter Property="Padding"         Value="6,2" />
            <Setter Property="Margin"          Value="0,0,2,0" />
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground"      Value="{DynamicResource DT_PanelForeground}" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource DT_GraphGridLine}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource DT_GraphBorder}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- TabControl: remove Aero2 system chrome, use DT_* tokens throughout -->
        <Style TargetType="TabControl">
            <Setter Property="Background"      Value="{DynamicResource DT_PanelBackground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{DynamicResource DT_ToolbarBackground}"
                                    BorderBrush="{DynamicResource DT_GraphBorder}"
                                    BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True"
                                          Background="Transparent"
                                          Margin="4,2,4,0" />
                            </Border>
                            <Border Grid.Row="1"
                                    Background="{DynamicResource DT_PanelBackground}">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  KeyboardNavigation.TabNavigation="Local"
                                                  KeyboardNavigation.DirectionalNavigation="Contained" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="22" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Toolbar ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource DT_ToolbarBackground}"
                BorderBrush="{DynamicResource DT_GraphBorder}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">

                <!-- Pause / Resume -->
                <Button Content="{Binding PauseResumeGlyph}"
                        Style="{StaticResource ToolbarBtn}"
                        ToolTip="Pause / Resume collection"
                        Click="OnPauseResumeClick" />

                <Separator Width="1" Background="{DynamicResource DT_GraphBorder}" Margin="4,2" />

                <!-- Heap snapshot -->
                <Button Content="&#xE9F9;"
                        Style="{StaticResource ToolbarBtn}"
                        ToolTip="Capture heap snapshot (.gcdump)"
                        Click="OnSnapshotClick" />

                <!-- Clear events -->
                <Button Content="&#xE894;"
                        Style="{StaticResource ToolbarBtn}"
                        ToolTip="Clear event log"
                        Click="OnClearEventsClick" />

                <!-- Export CSV -->
                <Button Content="&#xE74E;"
                        Style="{StaticResource ToolbarBtn}"
                        ToolTip="Export metrics to CSV"
                        Click="OnExportClick" />

                <Separator Width="1" Background="{DynamicResource DT_GraphBorder}" Margin="4,2" />

                <TextBlock Text="CPU:"  Style="{StaticResource MetricLabel}" />
                <TextBlock Text="{Binding CurrentCpu}"    Style="{StaticResource MetricValue}" />
                <TextBlock Text="Mem:"  Style="{StaticResource MetricLabel}" />
                <TextBlock Text="{Binding CurrentMemory}" Style="{StaticResource MetricValue}" />
                <TextBlock Text="GC:"   Style="{StaticResource MetricLabel}" />
                <TextBlock Text="{Binding GcHeapMbText}"  Style="{StaticResource MetricValue}" />
                <TextBlock Text="TP:"   Style="{StaticResource MetricLabel}" />
                <TextBlock Text="{Binding ThreadPoolQueue}"   Style="{StaticResource MetricValue}" />
                <TextBlock Text="threads:"  Style="{StaticResource MetricLabel}" />
                <TextBlock Text="{Binding ThreadPoolThreads}" Style="{StaticResource MetricValue}" />

            </StackPanel>
        </Border>

        <!-- ── Status bar ───────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource DT_ToolbarBackground}"
                BorderBrush="{DynamicResource DT_GraphBorder}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="{Binding SessionStatus}"
                       Foreground="{DynamicResource DT_StatusForeground}"
                       Margin="6,0"
                       VerticalAlignment="Center"
                       FontStyle="Italic" />
        </Border>

        <!-- ── Tabs ─────────────────────────────────────────────────────────── -->
        <TabControl Grid.Row="2"
                    Background="{DynamicResource DT_PanelBackground}"
                    BorderThickness="0">

            <!-- Summary tab -->
            <TabItem Header="Summary">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="120" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="CPU Usage"
                               Style="{StaticResource SectionLabel}" />
                    <Border Grid.Row="1" Grid.Column="0"
                            BorderBrush="{DynamicResource DT_GraphBorder}"
                            BorderThickness="1" Margin="4,0,4,4">
                        <ctrl:CpuGraphControl Samples="{Binding CpuSamples}" />
                    </Border>

                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="Working Set"
                               Style="{StaticResource SectionLabel}" />
                    <Border Grid.Row="1" Grid.Column="1"
                            BorderBrush="{DynamicResource DT_GraphBorder}"
                            BorderThickness="1" Margin="4,0,4,4">
                        <ctrl:MemoryGraphControl Samples="{Binding MemorySamples}" />
                    </Border>

                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                               Text=".NET Runtime"
                               Style="{StaticResource SectionLabel}" />
                    <WrapPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="4,2">
                        <TextBlock Text="GC Heap:"        Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding GcHeapMbText}"     Style="{StaticResource MetricValue}" />
                        <TextBlock Text="TP queue:"        Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding ThreadPoolQueue}"   Style="{StaticResource MetricValue}" />
                        <TextBlock Text="Threads:"         Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding ThreadPoolThreads}" Style="{StaticResource MetricValue}" />
                    </WrapPanel>
                </Grid>
            </TabItem>

            <!-- Events tab with filter -->
            <TabItem Header="Events">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Filter bar -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource DT_ToolbarBackground}"
                            BorderBrush="{DynamicResource DT_GraphBorder}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                            <TextBlock Text="Filter:" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource DT_PanelForeground}" />
                            <ComboBox SelectedValue="{Binding EventFilter}"
                                      SelectedValuePath="Tag"
                                      Width="120"
                                      Background="{DynamicResource DT_GraphBackground}"
                                      Foreground="{DynamicResource DT_PanelForeground}">
                                <ComboBoxItem Content="All"        Tag="{x:Static vm:EventFilter.All}"        IsSelected="True" />
                                <ComboBoxItem Content="GC"         Tag="{x:Static vm:EventFilter.GC}" />
                                <ComboBoxItem Content="Exceptions" Tag="{x:Static vm:EventFilter.Exceptions}" />
                                <ComboBoxItem Content="ThreadPool" Tag="{x:Static vm:EventFilter.ThreadPool}" />
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Virtualized event list -->
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding FilteredEvents}"
                              Background="{DynamicResource DT_EventListBackground}"
                              Foreground="{DynamicResource DT_PanelForeground}"
                              BorderThickness="0"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time"    Width="90"
                                                DisplayMemberBinding="{Binding TimeText}" />
                                <GridViewColumn Header="Message" Width="600"
                                                DisplayMemberBinding="{Binding Text}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- CPU full-height -->
            <TabItem Header="CPU">
                <Border BorderBrush="{DynamicResource DT_GraphBorder}"
                        BorderThickness="1" Margin="4">
                    <ctrl:CpuGraphControl Samples="{Binding CpuSamples}" />
                </Border>
            </TabItem>

            <!-- Memory full-height -->
            <TabItem Header="Memory">
                <Border BorderBrush="{DynamicResource DT_GraphBorder}"
                        BorderThickness="1" Margin="4">
                    <ctrl:MemoryGraphControl Samples="{Binding MemorySamples}" />
                </Border>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>

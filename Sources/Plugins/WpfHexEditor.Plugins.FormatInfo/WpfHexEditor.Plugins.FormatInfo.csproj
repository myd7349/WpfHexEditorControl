<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>WpfHexEditor.Plugins.FormatInfo</RootNamespace>
    <AssemblyName>WpfHexEditor.Plugins.FormatInfo</AssemblyName>
    <!-- Plugin metadata required by WpfHexEditor.SDK.targets to generate manifest.json -->
    <PluginId>WpfHexEditor.Plugins.FormatInfo</PluginId>
    <PluginName>Format Info</PluginName>
    <PluginVersion>0.4.1</PluginVersion>
    <PluginEntryPoint>WpfHexEditor.Plugins.FormatInfo.FormatInfoPlugin</PluginEntryPoint>
    <PluginAuthor>Derek Tremblay</PluginAuthor>
    <PluginPublisher>WpfHexEditor</PluginPublisher>
    <PluginTrustedPublisher>true</PluginTrustedPublisher>
    <PluginDescription>Shows enriched format metadata, version information, and structural details for detected file formats.</PluginDescription>
    <PluginIsolationMode>Auto</PluginIsolationMode>
    <PluginLoadPriority>60</PluginLoadPriority>
    <PluginSdkVersion>1.2.0</PluginSdkVersion>
    <PluginMinIDEVersion>0.3.0</PluginMinIDEVersion>
    <PluginPermAccessHexEditor>true</PluginPermAccessHexEditor>
    <PluginPermAccessFileSystem>false</PluginPermAccessFileSystem>
    <PluginPermAccessNetwork>false</PluginPermAccessNetwork>
    <PluginPermRegisterMenus>true</PluginPermRegisterMenus>
    <PluginPermWriteOutput>true</PluginPermWriteOutput>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\WpfHexEditor.SDK\WpfHexEditor.SDK.csproj" />
  </ItemGroup>

  <Import Project="..\..\WpfHexEditor.SDK\Build\WpfHexEditor.SDK.targets" />

  <!-- Copy compiled plugin to App Plugins directory after build -->
  <Target Name="CopyToPluginsDir" AfterTargets="GeneratePluginManifest">
    <PropertyGroup>
      <PluginDestDir>$(MSBuildThisFileDirectory)..\..\WpfHexEditor.App\bin\$(Configuration)\net8.0-windows\Plugins\$(AssemblyName)\</PluginDestDir>
    </PropertyGroup>
    <MakeDir Directories="$(PluginDestDir)" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll;$(OutputPath)manifest.json"
          DestinationFolder="$(PluginDestDir)"
          SkipUnchangedFiles="true" />
  </Target>

</Project>

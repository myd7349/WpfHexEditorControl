<UserControl x:Class="WpfHexEditor.Plugins.FormatInfo.Views.EnrichedFormatInfoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="350"
             xmlns:fiSvc="clr-namespace:WpfHexEditor.Plugins.FormatInfo.Services">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <fiSvc:FormatInfoLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        <!-- Semantic colors — constant across themes -->
        <SolidColorBrush x:Key="AccentBrush"       Color="#7ED321"/>
        <SolidColorBrush x:Key="PriorityBadgeBrush" Color="#FF6B6B"/>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_AccentBrush}"/>
            <Setter Property="Margin"     Value="0,12,0,6"/>
        </Style>

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_SubTextBrush}"/>
            <Setter Property="Margin"     Value="0,0,8,0"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground"   Value="{DynamicResource PFP_TextBrush}"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="12"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
        </Style>
            </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PFP_PanelBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12" x:Name="MainPanel">

                <!-- Header Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="HeaderCard">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       x:Name="FormatNameTextBlock"
                                       Text="{StaticResource FI_FormatNameLabel}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource PFP_TextBrush}"
                                       TextWrapping="Wrap"/>

                            <Border Grid.Column="1"
                                    x:Name="PriorityBadge"
                                    Background="{StaticResource PriorityBadgeBrush}"
                                    CornerRadius="3" Padding="6,2" Margin="8,0,0,0"
                                    Visibility="Collapsed"
                                    ToolTip="{StaticResource FI_PriorityTooltip}">
                                <TextBlock Text="{StaticResource FI_PriorityLabel}" FontSize="9" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>

                        <TextBlock x:Name="CategoryTextBlock"
                                   Text="{StaticResource FI_CategoryLabel}"
                                   FontSize="10" FontStyle="Italic" Margin="0,4,0,0"
                                   Foreground="{DynamicResource PFP_AccentBrush}"/>

                        <TextBlock x:Name="DescriptionTextBlock"
                                   Text="{StaticResource FI_DescriptionLabel}"
                                   FontSize="10" TextWrapping="Wrap" Margin="0,8,0,0"
                                   Foreground="{DynamicResource PFP_TextBrush}"/>

                        <!-- Quality score -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{StaticResource FI_QualityLabel}"
                                       Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Height="8"
                                    Background="{DynamicResource PFP_CoverageTrackBrush}"
                                    CornerRadius="4" Margin="0,0,8,0">
                                <Border x:Name="QualityScoreBar"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource AccentBrush}"
                                        CornerRadius="4"/>
                            </Border>
                            <TextBlock Grid.Column="2" x:Name="QualityScoreText"
                                       Text="0%" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Documentation level -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{StaticResource FI_DocLabel}"
                                       Style="{StaticResource InfoLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="DocumentationLevelTextBlock"
                                       Text="{StaticResource FI_BasicLabel}"
                                       Style="{StaticResource InfoValueStyle}"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Extensions Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="ExtensionsCard">
                    <StackPanel>
                        <TextBlock Text="{StaticResource FI_ExtensionsLabel}" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="ExtensionsTextBlock" Text="N/A" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- MIME Types Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="MimeTypesCard">
                    <StackPanel>
                        <TextBlock Text="{StaticResource FI_MimeLabel}" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="MimeTypesTextBlock" Text="N/A" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Software Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="SoftwareCard">
                    <StackPanel>
                        <TextBlock Text="{StaticResource FI_SoftwareLabel}" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="SoftwareTextBlock" Text="N/A" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Use Cases Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="UseCasesCard">
                    <StackPanel>
                        <TextBlock Text="{StaticResource FI_UseCasesLabel}" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="UseCasesTextBlock" Text="N/A" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- References Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="ReferencesCard">
                    <StackPanel>
                        <TextBlock Text="{StaticResource FI_RefsSection}" Style="{StaticResource SectionHeaderStyle}"/>

                        <StackPanel x:Name="SpecificationsSection" Margin="0,4,0,0">
                            <TextBlock Text="{StaticResource FI_SpecsLabel}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PFP_SubTextBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="SpecificationsTextBlock"
                                       Text="N/A" Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                        </StackPanel>

                        <StackPanel x:Name="WebLinksSection" Margin="0,8,0,0">
                            <TextBlock Text="{StaticResource FI_DocLabel}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PFP_SubTextBrush}"
                                       Margin="0,0,0,4"/>
                            <StackPanel x:Name="WebLinksStackPanel" Margin="8,0,0,0"/>
                        </StackPanel>

                        <TextBlock x:Name="NoReferencesTextBlock"
                                   Text="{StaticResource FI_NoRefsText}"
                                   FontSize="10" FontStyle="Italic"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Technical Details Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="TechnicalDetailsCard">
                    <StackPanel>
                        <TextBlock Text="{StaticResource FI_TechnicalSection}" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="TechnicalDetailsTextBlock" Text="N/A" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Related Formats Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="RelatedFormatsCard">
                    <StackPanel>
                        <TextBlock Text="{StaticResource FI_RelatedSection}" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="RelatedFormatsTextBlock" Text="N/A" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Author & Version Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="AuthorVersionCard">
                    <StackPanel>
                        <TextBlock Text="{StaticResource FI_DefinitionSection}" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{StaticResource FI_VersionLabel}" Style="{StaticResource InfoLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="VersionTextBlock" Text="N/A" Style="{StaticResource InfoValueStyle}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{StaticResource FI_AuthorLabel}" Style="{StaticResource InfoLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="AuthorTextBlock" Text="N/A" Style="{StaticResource InfoValueStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Detection Info Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="DetectionInfoCard">
                    <StackPanel>
                        <TextBlock Text="{StaticResource FI_DetectionSection}" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{StaticResource FI_SignatureLabel}" Style="{StaticResource InfoLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="SignatureHexTextBlock"
                                       Text="N/A" Style="{StaticResource InfoValueStyle}" FontFamily="Consolas"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{StaticResource FI_OffsetLabel}" Style="{StaticResource InfoLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="OffsetDisplayTextBlock"
                                       Text="N/A" Style="{StaticResource InfoValueStyle}" FontFamily="Consolas"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{StaticResource FI_RequiredLabel}" Style="{StaticResource InfoLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="RequiredDisplayTextBlock"
                                       Text="N/A" Style="{StaticResource InfoValueStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- No Format Message -->
                <Border x:Name="NoFormatMessage" Style="{StaticResource CardStyle}" Padding="24" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{StaticResource FI_NoFormatText}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PFP_TextBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="{StaticResource FI_OpenFileHint}"
                                   FontSize="11" Foreground="{DynamicResource PFP_SubTextBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="WpfHexEditor.Plugins.ClaudeAssistant.Options.ClaudeAssistantOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="500" MinHeight="400">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>
            <!-- Anthropic -->
            <TextBlock Text="Anthropic Claude" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="API Key:" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <PasswordBox x:Name="AnthropicKeyBox" Grid.Column="1" MaxLength="200"
                             Background="{DynamicResource DockBackgroundBrush}"
                             Foreground="{DynamicResource DockMenuForegroundBrush}"
                             BorderBrush="{DynamicResource DockBorderBrush}" Margin="0,0,8,0"/>
                <Button x:Name="TestAnthropicBtn" Grid.Column="2" Content="Test" Width="60"
                        Click="OnTestAnthropicClick"/>
            </Grid>

            <Separator Margin="0,12"/>

            <!-- OpenAI -->
            <TextBlock Text="OpenAI" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,8,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="API Key:" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <PasswordBox x:Name="OpenAIKeyBox" Grid.Column="1" MaxLength="200"
                             Background="{DynamicResource DockBackgroundBrush}"
                             Foreground="{DynamicResource DockMenuForegroundBrush}"
                             BorderBrush="{DynamicResource DockBorderBrush}" Margin="0,0,8,0"/>
                <Button x:Name="TestOpenAIBtn" Grid.Column="2" Content="Test" Width="60"
                        Click="OnTestOpenAIClick"/>
            </Grid>

            <Separator Margin="0,12"/>

            <!-- Google Gemini -->
            <TextBlock Text="Google Gemini" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,8,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="API Key:" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <PasswordBox x:Name="GeminiKeyBox" Grid.Column="1" MaxLength="200"
                             Background="{DynamicResource DockBackgroundBrush}"
                             Foreground="{DynamicResource DockMenuForegroundBrush}"
                             BorderBrush="{DynamicResource DockBorderBrush}" Margin="0,0,8,0"/>
                <Button x:Name="TestGeminiBtn" Grid.Column="2" Content="Test" Width="60"
                        Click="OnTestGeminiClick"/>
            </Grid>

            <Separator Margin="0,12"/>

            <!-- Ollama -->
            <TextBlock Text="Ollama (Local)" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,8,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Base URL:" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <TextBox x:Name="OllamaUrlBox" Grid.Column="1"
                         Background="{DynamicResource DockBackgroundBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         BorderBrush="{DynamicResource DockBorderBrush}" Margin="0,0,8,0"/>
                <Button x:Name="TestOllamaBtn" Grid.Column="2" Content="Test" Width="60"
                        Click="OnTestOllamaClick"/>
            </Grid>

            <Separator Margin="0,12"/>

            <!-- Defaults -->
            <TextBlock Text="Defaults" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,8,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Provider:" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <ComboBox x:Name="DefaultProviderCombo" Grid.Column="1"
                          SelectionChanged="OnDefaultProviderChanged"/>
            </Grid>
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Model:" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <ComboBox x:Name="DefaultModelCombo" Grid.Column="1"/>
            </Grid>
            <CheckBox x:Name="ThinkingCheck" Content="Enable Thinking (Anthropic only)"
                      Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,4,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="WpfHexEditor.Plugins.ClaudeAssistant.Panel.History.HistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:session="clr-namespace:WpfHexEditor.Plugins.ClaudeAssistant.Session">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Background="{DynamicResource DockBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Height="26" Padding="8,0"
                Background="{DynamicResource DockTabInactiveBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel VerticalAlignment="Center">
                <TextBlock Text="Conversation History" FontWeight="SemiBold" FontSize="11"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center"/>
                <Border DockPanel.Dock="Right" Width="22" Height="22" CornerRadius="2"
                        Cursor="Hand" ToolTip="Clear all"
                        HorizontalAlignment="Right"
                        MouseLeftButtonDown="OnClearAllClick">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- Search box -->
        <Border Grid.Row="1" Margin="8,6,8,4" CornerRadius="4"
                Background="{DynamicResource CA_InputBackgroundBrush}"
                BorderBrush="{DynamicResource CA_InputBorderBrush}"
                BorderThickness="1" Padding="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                           FontSize="11" Foreground="{DynamicResource CA_ToolCallForegroundBrush}"
                           VerticalAlignment="Center" Margin="6,0,4,0"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource CA_InputForegroundBrush}"
                         CaretBrush="{DynamicResource CA_InputForegroundBrush}"
                         Padding="2,4" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Conversation list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredEntries}" Padding="4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type session:SessionMetadata}">
                        <Border Padding="10,8" Margin="4,2" CornerRadius="4" Cursor="Hand"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource DockBorderBrush}"
                                MouseLeftButtonDown="OnEntryClick">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding Title}" FontWeight="Medium" FontSize="11.5"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <Border Grid.Row="0" Grid.Column="1" Width="18" Height="18"
                                        CornerRadius="2" Cursor="Hand"
                                        MouseLeftButtonDown="OnDeleteClick">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Opacity" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding ProviderId}" FontSize="10" Opacity="0.6"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    <TextBlock Text=" / " FontSize="10" Opacity="0.3"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    <TextBlock Text="{Binding ModelId}" FontSize="10" Opacity="0.6"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    <TextBlock Text="  |  " FontSize="10" Opacity="0.3"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    <TextBlock Text="{Binding MessageCount, StringFormat={}{0} msgs}" FontSize="10" Opacity="0.5"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>

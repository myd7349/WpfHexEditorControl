<UserControl x:Class="WpfHexEditor.Plugins.ClaudeAssistant.Panel.History.HistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:session="clr-namespace:WpfHexEditor.Plugins.ClaudeAssistant.Session">
    <Grid Background="{DynamicResource CA_PanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Conversation History" FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource CA_MessageForegroundBrush}" Margin="8,8,8,4"/>

        <!-- Search -->
        <TextBox Grid.Row="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource CA_InputBackgroundBrush}"
                 Foreground="{DynamicResource CA_InputForegroundBrush}"
                 BorderBrush="{DynamicResource CA_InputBorderBrush}"
                 Margin="8,0,8,8" Padding="6,4"/>

        <!-- List -->
        <ListBox Grid.Row="2" ItemsSource="{Binding FilteredEntries}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type session:SessionMetadata}">
                    <Border Padding="8,6" Margin="4,2" CornerRadius="4" Cursor="Hand"
                            Background="{DynamicResource CA_MessageAssistantBackgroundBrush}"
                            BorderBrush="{DynamicResource CA_MessageBorderBrush}"
                            BorderThickness="1"
                            MouseLeftButtonDown="OnEntryClick">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding Title}" FontWeight="Medium"
                                       Foreground="{DynamicResource CA_MessageForegroundBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Row="0" Grid.Column="1" Content="X" Width="20" Height="20"
                                    FontSize="10" Padding="0" VerticalAlignment="Top"
                                    Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"/>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding ProviderId}" FontSize="11" Opacity="0.6"
                                           Foreground="{DynamicResource CA_MessageForegroundBrush}"/>
                                <TextBlock Text=" / " FontSize="11" Opacity="0.4"
                                           Foreground="{DynamicResource CA_MessageForegroundBrush}"/>
                                <TextBlock Text="{Binding ModelId}" FontSize="11" Opacity="0.6"
                                           Foreground="{DynamicResource CA_MessageForegroundBrush}"/>
                                <TextBlock Text=" | " FontSize="11" Opacity="0.4"
                                           Foreground="{DynamicResource CA_MessageForegroundBrush}"/>
                                <TextBlock Text="{Binding MessageCount, StringFormat={}{0} msgs}" FontSize="11" Opacity="0.5"
                                           Foreground="{DynamicResource CA_MessageForegroundBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer -->
        <Button Grid.Row="3" Content="Clear All History" Margin="8"
                HorizontalAlignment="Left"
                Command="{Binding ClearAllCommand}"/>
    </Grid>
</UserControl>

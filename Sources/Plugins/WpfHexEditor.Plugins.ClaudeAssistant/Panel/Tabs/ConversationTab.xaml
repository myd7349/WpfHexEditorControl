<UserControl x:Class="WpfHexEditor.Plugins.ClaudeAssistant.Panel.Tabs.ConversationTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:msgs="clr-namespace:WpfHexEditor.Plugins.ClaudeAssistant.Panel.Messages">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Chat messages -->
        <ScrollViewer x:Name="ChatScroller" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource CA_PanelBackgroundBrush}">
            <ItemsControl x:Name="MessagesControl"
                          ItemsSource="{Binding Messages}" Padding="8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type msgs:ChatMessageViewModel}">
                        <Border Margin="0,4"
                                Padding="10,8"
                                CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource CA_MessageBorderBrush}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource CA_MessageAssistantBackgroundBrush}"/>
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="MaxWidth" Value="380"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource CA_MessageUserBackgroundBrush}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                            <Setter Property="Background" Value="#40E05252"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <!-- Thinking (collapsed by default) -->
                                <Expander Header="Thinking..." Visibility="{Binding HasThinking, Converter={StaticResource BoolToVis}}"
                                          IsExpanded="False" Margin="0,0,0,4">
                                    <TextBlock Text="{Binding ThinkingText}" TextWrapping="Wrap"
                                               Foreground="{DynamicResource CA_ToolCallForegroundBrush}"
                                               FontSize="11" Opacity="0.7" FontFamily="Consolas"/>
                                </Expander>
                                <!-- Message text -->
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource CA_MessageForegroundBrush}"
                                           FontSize="13"/>
                                <!-- Streaming indicator -->
                                <TextBlock Text="..." Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}"
                                           Foreground="{DynamicResource CA_AccentBrandingBrush}"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input bar -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource CA_InputBorderBrush}"
                Background="{DynamicResource CA_InputBackgroundBrush}"
                Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Model selector row -->
                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,6">
                    <ComboBox x:Name="ProviderCombo" Width="110" Margin="0,0,6,0"
                              ItemsSource="{Binding ProviderIds}"
                              SelectedItem="{Binding SelectedProviderId}"
                              SelectionChanged="OnProviderChanged"/>
                    <ComboBox x:Name="ModelCombo" Width="160" Margin="0,0,6,0"
                              ItemsSource="{Binding ModelIds}"
                              SelectedItem="{Binding SelectedModelId}"/>
                    <CheckBox Content="Thinking" IsChecked="{Binding ThinkingEnabled}"
                              Foreground="{DynamicResource CA_MessageForegroundBrush}"
                              VerticalAlignment="Center"
                              IsEnabled="{Binding ThinkingAvailable}"/>
                </StackPanel>

                <!-- Input TextBox -->
                <TextBox Grid.Row="1" Grid.Column="0"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent"
                         Foreground="{DynamicResource CA_InputForegroundBrush}"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource CA_InputBorderBrush}"
                         AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="100"
                         VerticalAlignment="Center" Padding="6,4"
                         KeyDown="OnInputKeyDown"/>

                <!-- Send / Cancel buttons -->
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0">
                    <Button Content="Send" Width="60" Command="{Binding SendCommand}"
                            VerticalAlignment="Bottom"/>
                    <Button Content="Cancel" Width="60" Margin="4,0,0,0"
                            Command="{Binding CancelCommand}"
                            VerticalAlignment="Bottom"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
</UserControl>

<UserControl x:Class="WpfHexEditor.Plugins.ClaudeAssistant.Panel.Input.MentionCompletionPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="260">
    <Border CornerRadius="6" Padding="4"
            BorderThickness="1"
            Background="{DynamicResource DockBackgroundBrush}"
            BorderBrush="{DynamicResource CA_AccentBrandingBrush}">
        <ItemsControl x:Name="MentionList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,5" CornerRadius="3" Cursor="Hand"
                            MouseLeftButtonDown="OnItemClick">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Width="20" VerticalAlignment="Center"
                                       Foreground="{DynamicResource CA_AccentBrandingBrush}"/>
                            <TextBlock Text="{Binding Token}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Description}" FontSize="10.5" Opacity="0.5"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</UserControl>

<UserControl x:Class="WpfHexEditor.Plugins.ClaudeAssistant.Panel.ClaudeAssistantPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tabs="clr-namespace:WpfHexEditor.Plugins.ClaudeAssistant.Panel.Tabs"
             xmlns:hist="clr-namespace:WpfHexEditor.Plugins.ClaudeAssistant.Panel.History"
             MinWidth="320" MinHeight="200">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource CA_PanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab strip header -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource CA_MessageBorderBrush}"
                Background="{DynamicResource CA_PanelBackgroundBrush}"
                Padding="4,4">
            <DockPanel>
                <!-- Right-side buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="4,0,0,0">
                    <Button Content="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Width="28" Height="24" ToolTip="History"
                            Command="{Binding ToggleHistoryCommand}"/>
                    <Button Content="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Width="28" Height="24" ToolTip="New conversation"
                            Command="{Binding CreateNewTabCommand}"/>
                </StackPanel>

                <!-- Tab buttons (scrollable) -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,2,0" Padding="8,4" CornerRadius="4,4,0,0"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="OnTabClick"
                                        Background="{DynamicResource CA_MessageAssistantBackgroundBrush}">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="X" FontSize="9"
                                                Width="16" Height="16" Padding="0" Margin="6,0,0,0"
                                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding Title}" FontSize="11"
                                                   Foreground="{DynamicResource CA_MessageForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="140"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content area: either active tab or history panel -->
        <Grid Grid.Row="1">
            <!-- Active conversation tab -->
            <ContentControl Content="{Binding ActiveTab}"
                            Visibility="{Binding IsHistoryVisible, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHistoryVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <tabs:ConversationTab DataContext="{Binding}"/>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>

            <!-- History panel overlay -->
            <hist:HistoryPanel DataContext="{Binding History}"
                               Visibility="{Binding DataContext.IsHistoryVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Grid>
</UserControl>

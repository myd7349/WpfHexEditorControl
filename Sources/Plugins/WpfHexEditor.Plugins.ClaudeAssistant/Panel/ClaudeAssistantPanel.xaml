<UserControl x:Class="WpfHexEditor.Plugins.ClaudeAssistant.Panel.ClaudeAssistantPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tabs="clr-namespace:WpfHexEditor.Plugins.ClaudeAssistant.Panel.Tabs"
             MinWidth="320" MinHeight="200">
    <Grid Background="{DynamicResource CA_PanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource CA_MessageBorderBrush}"
                Background="{DynamicResource CA_PanelBackgroundBrush}"
                Padding="8,6">
            <DockPanel>
                <TextBlock Text="Claude AI Assistant" FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource CA_MessageForegroundBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}" FontSize="11" Opacity="0.5"
                           Foreground="{DynamicResource CA_MessageForegroundBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- Active conversation tab -->
        <ContentControl Grid.Row="1" Content="{Binding ActiveTab}">
            <ContentControl.ContentTemplate>
                <DataTemplate>
                    <tabs:ConversationTab DataContext="{Binding}"/>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
</UserControl>

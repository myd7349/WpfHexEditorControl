<UserControl x:Class="WpfHexEditor.Plugins.StringExtractor.Views.StringExtractorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:WpfHexEditor.Plugins.StringExtractor.Services"
             Background="{DynamicResource PanelBackground}"
             Foreground="{DynamicResource PanelForeground}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <svc:StringExtractorLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource ToolbarBackground}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="ExtractButton"
                        Content="{StaticResource StringExtractor_ExtractButton}"
                        ToolTip="{StaticResource StringExtractor_Tooltip_Extract}"
                        IsEnabled="{Binding IsIdle}"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Padding="8,3"
                        Margin="0,0,4,0"
                        Click="OnExtractClick"/>

                <TextBlock Grid.Column="1"
                           Text="{StaticResource StringExtractor_MinLength}"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="{DynamicResource PanelForeground}"/>

                <TextBox Grid.Column="2"
                         x:Name="MinLengthBox"
                         Text="4"
                         Width="40"
                         VerticalAlignment="Center"
                         ToolTip="{StaticResource StringExtractor_Tooltip_MinLength}"
                         TextAlignment="Center"
                         Margin="0,0,4,0"
                         Style="{DynamicResource ToolbarTextBoxStyle}"/>

                <Separator Grid.Column="3" Style="{DynamicResource ToolbarSeparatorStyle}"/>

                <CheckBox Grid.Column="4"
                          x:Name="AsciiCheck"
                          Content="{StaticResource StringExtractor_Enc_ASCII}"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Margin="0,0,6,0"
                          Foreground="{DynamicResource PanelForeground}"/>

                <CheckBox Grid.Column="5"
                          x:Name="Utf8Check"
                          Content="{StaticResource StringExtractor_Enc_UTF8}"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Margin="0,0,6,0"
                          Foreground="{DynamicResource PanelForeground}"/>

                <CheckBox Grid.Column="6"
                          x:Name="Utf16LeCheck"
                          Content="{StaticResource StringExtractor_Enc_UTF16LE}"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource PanelForeground}"/>

                <Button Grid.Column="8"
                        x:Name="ExportButton"
                        Content="{StaticResource StringExtractor_ExportButton}"
                        ToolTip="{StaticResource StringExtractor_Tooltip_Export}"
                        IsEnabled="{Binding HasResults}"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Padding="8,3"
                        Click="OnExportClick"/>
            </Grid>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1"
                Background="{DynamicResource ToolbarBackground}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,3">
            <TextBox x:Name="FilterBox"
                     Style="{DynamicResource SearchBoxStyle}"
                     TextChanged="OnFilterChanged"/>
        </Border>

        <!-- Results area -->
        <Grid Grid.Row="2">
            <!-- Empty-state -->
            <TextBlock x:Name="EmptyStateText"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PanelForeground}"
                       Opacity="0.5"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="20"/>

            <!-- Progress overlay -->
            <Border x:Name="ProgressOverlay"
                    Background="{DynamicResource PanelBackground}"
                    Opacity="0.85"
                    Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{StaticResource StringExtractor_Extracting}"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"
                               Margin="0,0,0,8"/>
                    <ProgressBar Width="200" Height="6"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding Progress}"/>
                </StackPanel>
            </Border>

            <!-- Virtualized results -->
            <ListView x:Name="ResultsList"
                      ItemsSource="{Binding Results}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      SelectionMode="Single"
                      MouseDoubleClick="OnResultDoubleClick"
                      Background="{DynamicResource PanelBackground}"
                      Foreground="{DynamicResource PanelForeground}"
                      BorderThickness="0">
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{StaticResource StringExtractor_NavigateTo}" Click="OnNavigateTo"/>
                        <MenuItem Header="{StaticResource StringExtractor_CopyValue}"  Click="OnCopyValue"/>
                        <MenuItem Header="{StaticResource StringExtractor_CopyOffset}" Click="OnCopyOffset"/>
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="110" Header="{StaticResource StringExtractor_ColOffset}"   DisplayMemberBinding="{Binding OffsetHex}"/>
                        <GridViewColumn Width="60"  Header="{StaticResource StringExtractor_ColLength}"   DisplayMemberBinding="{Binding Length}"/>
                        <GridViewColumn Width="80"  Header="{StaticResource StringExtractor_ColEncoding}" DisplayMemberBinding="{Binding Encoding}"/>
                        <GridViewColumn Width="400" Header="{StaticResource StringExtractor_ColValue}"    DisplayMemberBinding="{Binding Value}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource StatusBarBackground}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="6,2">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource StatusBarForeground}"
                       FontSize="11"/>
        </Border>
    </Grid>
</UserControl>

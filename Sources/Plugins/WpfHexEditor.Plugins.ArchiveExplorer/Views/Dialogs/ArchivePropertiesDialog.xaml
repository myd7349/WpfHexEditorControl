<ec:ThemedDialog x:Class="WpfHexEditor.Plugins.ArchiveExplorer.Views.Dialogs.ArchivePropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        Title="Entry Properties"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   x:Name="EntryNameText"
                   FontSize="15"
                   FontWeight="Bold"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,12"/>

        <!-- Properties grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Full Path:"      Style="{StaticResource PropLabelStyle}"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="FullPathText"  Style="{StaticResource PropValueStyle}" TextWrapping="Wrap"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Size:"           Style="{StaticResource PropLabelStyle}"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SizeText"      Style="{StaticResource PropValueStyle}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Compressed:"     Style="{StaticResource PropLabelStyle}"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CompressedText" Style="{StaticResource PropValueStyle}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Ratio:"          Style="{StaticResource PropLabelStyle}"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="RatioText"     Style="{StaticResource PropValueStyle}"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Method:"         Style="{StaticResource PropLabelStyle}"/>
            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="MethodText"    Style="{StaticResource PropValueStyle}"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Last Modified:"  Style="{StaticResource PropLabelStyle}"/>
            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="ModifiedText"  Style="{StaticResource PropValueStyle}"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="CRC32:"          Style="{StaticResource PropLabelStyle}"/>
            <TextBlock Grid.Row="6" Grid.Column="1" x:Name="CrcText"       Style="{StaticResource PropValueStyle}"/>
        </Grid>

        <!-- Close button -->
        <Button Grid.Row="2"
                Content="Close"
                Width="80" Height="28"
                HorizontalAlignment="Right"
                Margin="0,15,0,0"
                IsDefault="True" IsCancel="True"
                Click="OnCloseClick"/>
    </Grid>

    <ec:ThemedDialog.Resources>
        <Style x:Key="PropLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{DynamicResource PFP_SubTextBrush}"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Margin"       Value="0,3,8,3"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="PropValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Margin"       Value="0,3,0,3"/>
        </Style>
    </ec:ThemedDialog.Resources>

</ec:ThemedDialog>

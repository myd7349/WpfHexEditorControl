<!--
    Project      : WpfHexEditorControl
    File         : Views/ArchiveExplorerPanel.xaml
    Description  : Dockable panel for the Archive Explorer plugin.
                   Layout: toolbar (ToolbarOverflowManager, 3 groups) /
                            TreeView (archive hierarchy) /
                            InfoBar (format + stats).
    Theme        : DynamicResource PFP_* + AR_* + Dock* tokens.
    Architecture : Toolbar group collapse priority (lowest=first):
                     TbgExtract → TbgActions → TbgFilter (last to collapse)
                   ToolbarOverflowManager initialized in code-behind Loaded handler.
    GNU Affero General Public License v3.0 - 2026
    Author : Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
-->
<UserControl x:Class="WpfHexEditor.Plugins.ArchiveExplorer.Views.ArchiveExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WpfHexEditor.Plugins.ArchiveExplorer.Converters"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.ArchiveExplorer.ViewModels"
             Background="{DynamicResource PFP_PanelBackgroundBrush}"
             Foreground="{DynamicResource PFP_TextBrush}"
             Focusable="True"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter         x:Key="BoolToVis"/>
        <conv:FileSizeConverter                 x:Key="FileSizeConv"/>
        <conv:ArchiveFormatToIconGlyphConverter x:Key="FormatGlyphConv"/>

        <!-- Shared style for context-menu icon glyphs -->
        <Style x:Key="CtxMenuIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"       Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Collapse TbgExtract and TbgActions into overflow menu items -->
        <ContextMenu x:Key="OverflowContextMenu" x:Name="OverflowMenu">
            <MenuItem x:Name="OvfExtractAll"
                      Header="Extract All…"
                      Command="{Binding ExtractAllCommand}"/>
            <MenuItem x:Name="OvfExtractSelected"
                      Header="Extract Selected…"
                      Command="{Binding ExtractSelectedCommand}"/>
            <Separator x:Name="OvfSep1"/>
            <MenuItem x:Name="OvfPreview"
                      Header="Preview"
                      Command="{Binding PreviewCommand}"/>
            <MenuItem x:Name="OvfOpenRaw"
                      Header="Open Raw in Hex"
                      Command="{Binding OpenRawInHexCommand}"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid AllowDrop="True"
          Drop="OnPanelDrop"
          DragOver="OnPanelDragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- TreeView -->
            <RowDefinition Height="Auto"/>  <!-- InfoBar -->
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0: Toolbar ════════════════════════════════════════════════ -->
        <Border x:Name="ToolbarBorder"
                Grid.Row="0"
                Style="{StaticResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="False">

                <!-- Always-visible right panel — Refresh + NavUp always reachable -->
                <StackPanel x:Name="ToolbarRightPanel"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE72C;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="22" Height="22"
                            Command="{Binding RefreshCommand}"
                            ToolTip="Refresh archive"/>
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE73B;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="22" Height="22"
                            Command="{Binding NavigateUpCommand}"
                            Visibility="{Binding CanNavigateUp, Converter={StaticResource BoolToVis}}"
                            ToolTip="Navigate up (exit nested archive)"/>
                </StackPanel>

                <!-- Overflow button — shown when groups collapse -->
                <Button x:Name="ToolbarOverflowButton"
                        DockPanel.Dock="Right"
                        Style="{StaticResource PanelIconButtonStyle}"
                        Content="&#xE712;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="22" Height="22"
                        Visibility="Collapsed"
                        ToolTip="More options"
                        Click="OnOverflowButtonClick"/>

                <!-- Open (always visible, leftmost — primary entry point) -->
                <Button Style="{StaticResource PanelIconButtonStyle}"
                        Content="&#xE8E5;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="22" Height="22"
                        Margin="0,0,2,0"
                        Click="OnOpenArchiveClick"
                        ToolTip="Open archive…"/>

                <!-- Separator -->
                <Separator Width="1" Margin="2,4"
                           Background="{DynamicResource Panel_ToolbarBorderBrush}"/>

                <!-- Group 1 (lowest priority): Extract operations -->
                <StackPanel x:Name="TbgExtract"
                            Orientation="Horizontal"
                            Margin="2,0,4,0">
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE78C;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="22" Height="22"
                            Command="{Binding ExtractAllCommand}"
                            ToolTip="Extract all…"
                            Tag="OvfExtractAll"/>
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE896;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="22" Height="22"
                            Command="{Binding ExtractSelectedCommand}"
                            ToolTip="Extract selected…"
                            Tag="OvfExtractSelected"/>
                </StackPanel>

                <!-- Separator -->
                <Separator Width="1" Margin="2,4"
                           Background="{DynamicResource Panel_ToolbarBorderBrush}"/>

                <!-- Group 2: Preview / Hex actions -->
                <StackPanel x:Name="TbgActions"
                            Orientation="Horizontal"
                            Margin="4,0,4,0">
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE8A4;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="22" Height="22"
                            Command="{Binding PreviewCommand}"
                            ToolTip="Preview entry"
                            Tag="OvfPreview"/>
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE8F4;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="22" Height="22"
                            Command="{Binding OpenRawInHexCommand}"
                            ToolTip="Open raw bytes in Hex Editor"
                            Tag="OvfOpenRaw"/>
                </StackPanel>

                <!-- Separator -->
                <Separator Width="1" Margin="2,4"
                           Background="{DynamicResource Panel_ToolbarBorderBrush}"/>

                <!-- Group 3 (highest priority): Filter -->
                <StackPanel x:Name="TbgFilter"
                            Orientation="Horizontal"
                            Margin="4,0,0,0">
                    <TextBox x:Name="FilterBox"
                             Width="140"
                             Style="{DynamicResource PanelSearchBoxStyle}"
                             Tag="Filter…"
                             ToolTip="Filter entries…"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="18" Height="18"
                            Command="{Binding ClearFilterCommand}"
                            ToolTip="Clear filter"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══ ROW 1: Loading overlay + TreeView ══════════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- Loading spinner -->
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="Loading…"
                       Foreground="{DynamicResource PFP_SubTextBrush}"
                       FontSize="12"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

            <!-- Archive tree (hidden while loading via DataTrigger below) -->
            <TreeView x:Name="ArchiveTree"
                      ItemsSource="{Binding RootNodes}"
                      Background="Transparent"
                      BorderThickness="0"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      MouseMove="OnTreeMouseMove"
                      MouseDoubleClick="OnTreeMouseDoubleClick"
                      KeyDown="OnTreeKeyDown"
                      SelectedItemChanged="OnTreeSelectedItemChanged">

                <TreeView.Resources>
                    <!-- Item container style: hover, selection using PFP_* tokens -->
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource PanelTreeViewItemStyle}">
                        <Setter Property="IsExpanded"  Value="{Binding IsExpanded,  Mode=TwoWay}"/>
                        <Setter Property="IsSelected"  Value="{Binding IsSelected,  Mode=TwoWay}"/>
                        <Setter Property="Visibility"  Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
                        <Setter Property="ItemsSource" Value="{Binding Children}"/>
                    </Style>
                </TreeView.Resources>

                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vm:ArchiveNodeViewModel}"
                                              ItemsSource="{Binding Children}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>   <!-- Icon -->
                                <ColumnDefinition Width="*"/>    <!-- Name -->
                                <ColumnDefinition Width="Auto"/> <!-- Size -->
                                <ColumnDefinition Width="Auto"/> <!-- Ratio badge -->
                                <ColumnDefinition Width="Auto"/> <!-- Format badge -->
                            </Grid.ColumnDefinitions>

                            <!-- MDL2 icon -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding IconGlyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding IsFolder, Converter={x:Static conv:FolderColorConverter.Instance}}"/>

                            <!-- Name -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Name}"
                                       Margin="4,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource PFP_TextBrush}"
                                       ToolTip="{Binding FullPath}"/>

                            <!-- Size -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Node.Size, Converter={StaticResource FileSizeConv}}"
                                       Margin="0,0,6,0"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource PFP_SubTextBrush}"/>

                            <!-- Compression ratio badge -->
                            <Border Grid.Column="3"
                                    Background="{DynamicResource AR_RatioBadgeBackgroundBrush}"
                                    CornerRadius="3"
                                    Padding="4,1"
                                    Margin="0,0,4,0"
                                    Visibility="{Binding CompressionInfo, Converter={x:Static conv:StringToVisibilityConverter.Instance}}">
                                <TextBlock Text="{Binding CompressionInfo}"
                                           FontSize="10"
                                           Foreground="{DynamicResource AR_RatioBadgeForegroundBrush}"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Format badge (whfmt detection result) -->
                            <Border Grid.Column="4"
                                    Background="{DynamicResource AR_FormatBadgeBackgroundBrush}"
                                    CornerRadius="3"
                                    Padding="4,1"
                                    Visibility="{Binding FormatBadge, Converter={x:Static conv:StringToVisibilityConverter.Instance}}">
                                <TextBlock Text="{Binding FormatBadge}"
                                           FontSize="10"
                                           Foreground="{DynamicResource AR_FormatBadgeForegroundBrush}"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>

                <!-- Context menu -->
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Preview"
                                  Command="{Binding PlacementTarget.DataContext.PreviewCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  InputGestureText="Enter">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource CtxMenuIconStyle}" Text="&#xE8A4;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Extract Selected…"
                                  Command="{Binding PlacementTarget.DataContext.ExtractSelectedCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource CtxMenuIconStyle}" Text="&#xE896;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Open Raw in Hex Editor"
                                  Command="{Binding PlacementTarget.DataContext.OpenRawInHexCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource CtxMenuIconStyle}" Text="&#xE81E;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Drill Into Archive"
                                  Command="{Binding PlacementTarget.DataContext.DrillIntoCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource CtxMenuIconStyle}" Text="&#xE7C3;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Copy Path"
                                  Command="{Binding PlacementTarget.DataContext.CopyPathCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource CtxMenuIconStyle}" Text="&#xE8C8;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Properties…"
                                  Command="{Binding PlacementTarget.DataContext.ShowPropertiesCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <TextBlock Style="{StaticResource CtxMenuIconStyle}" Text="&#xE946;"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </TreeView.ContextMenu>
            </TreeView>

            <!-- Drop hint — visible when not loading AND no archive is loaded -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLoading}" Value="False"/>
                                    <Condition Binding="{Binding CurrentArchivePath,
                                                         Converter={x:Static conv:StringToVisibilityConverter.Instance},
                                                         ConverterParameter=Invert}"
                                               Value="Visible"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="&#xE7C3;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Drop an archive here"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource PFP_TextBrush}"/>
                <TextBlock Text="or click Open in the toolbar above"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ═══ ROW 2: Info bar ════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource Panel_ToolbarBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="6,2">
            <TextBlock Text="{Binding InfoBarText}"
                       FontSize="11"
                       Foreground="{DynamicResource PFP_SubTextBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

    </Grid>
</UserControl>

<UserControl x:Class="WpfHexEditor.Plugins.ArchiveExplorer.Options.ArchiveExplorerOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             Padding="12">

    <StackPanel>

        <!-- Section: Behaviour -->
        <TextBlock Text="Behaviour"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <CheckBox x:Name="ChkAutoShow"
                  Content="Automatically show panel when an archive file is opened"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,2,0,2"/>

        <CheckBox x:Name="ChkShowRatio"
                  Content="Show compression ratio badge in tree"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,2,0,2"/>

        <CheckBox x:Name="ChkShowBadge"
                  Content="Show format detection badge (whfmt)"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,2,0,12"/>

        <!-- Section: Preview -->
        <TextBlock Text="Preview"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Max preview size (KB):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <TextBox x:Name="TxtPreviewMaxKb"
                     Grid.Column="1"
                     Width="80"
                     HorizontalAlignment="Left"
                     VerticalContentAlignment="Center"
                     Foreground="{DynamicResource PFP_TextBrush}"
                     Background="{DynamicResource ERR_SearchBoxBrush}"
                     BorderBrush="{DynamicResource ERR_GridLinesBrush}"/>
        </Grid>

        <!-- Section: Extraction -->
        <TextBlock Text="Extraction"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Max format detection size (KB):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <TextBox x:Name="TxtMaxDetectKb"
                     Grid.Column="1"
                     Width="80"
                     HorizontalAlignment="Left"
                     VerticalContentAlignment="Center"
                     Foreground="{DynamicResource PFP_TextBrush}"
                     Background="{DynamicResource ERR_SearchBoxBrush}"
                     BorderBrush="{DynamicResource ERR_GridLinesBrush}"/>
        </Grid>

        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Default extract folder:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <TextBox x:Name="TxtExtractFolder"
                     Grid.Column="1"
                     VerticalContentAlignment="Center"
                     Foreground="{DynamicResource PFP_TextBrush}"
                     Background="{DynamicResource ERR_SearchBoxBrush}"
                     BorderBrush="{DynamicResource ERR_GridLinesBrush}"
                     Margin="0,0,4,0"/>
            <Button x:Name="BtnBrowse"
                    Grid.Column="2"
                    Content="Browse…"
                    Width="70" Height="22"
                    Click="OnBrowseClick"/>
        </Grid>

    </StackPanel>
</UserControl>

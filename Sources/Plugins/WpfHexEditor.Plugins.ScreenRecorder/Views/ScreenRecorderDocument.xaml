<!--
    Project: WpfHexEditor.Plugins.ScreenRecorder
    File: Views/ScreenRecorderDocument.xaml
    Description: Root document UserControl opened as a document tab in the IDE.
                 Hosts the timeline strip, preview pane, and properties panel.
-->
<UserControl x:Class="WpfHexEditor.Plugins.ScreenRecorder.Views.ScreenRecorderDocument"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:WpfHexEditor.Plugins.ScreenRecorder.Views"
             xmlns:svc="clr-namespace:WpfHexEditor.Plugins.ScreenRecorder.Services"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource DockMenuBackgroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <svc:ScreenRecorderLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Preview + properties -->
            <RowDefinition Height="*" />
            <!-- Splitter -->
            <RowDefinition Height="4" />
            <!-- Timeline strip -->
            <RowDefinition Height="160" MinHeight="100" MaxHeight="300" />
        </Grid.RowDefinitions>

        <!-- Row 0: Preview + Properties -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="340" />
            </Grid.ColumnDefinitions>

            <!-- Preview pane (placeholder — wired in Phase 7) -->
            <Border Grid.Column="0"
                    Background="{DynamicResource DockMenuBackgroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="0,0,0,0">
                <views:PreviewPane x:Name="PreviewPane" />
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockSplitterBrush}" />

            <!-- Properties panel (placeholder — wired in Phase 10) -->
            <views:PropertiesPanel Grid.Column="2" x:Name="PropertiesPanel" />
        </Grid>

        <!-- Row 1: Horizontal splitter -->
        <GridSplitter Grid.Row="1"
                      Height="4"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource DockSplitterBrush}" />

        <!-- Row 2: Timeline strip -->
        <Border Grid.Row="2"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0">
            <views:TimelineStrip x:Name="TimelineStrip" />
        </Border>
    </Grid>
</UserControl>

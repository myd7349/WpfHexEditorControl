<!--
    Project: WpfHexEditor.Plugins.ScreenRecorder
    File: Views/PreviewPane.xaml
    Description: Preview pane — displays the selected frame with zoom support.
                 FitToContainer=True stretches the image to fill the pane.
                 Numeric zoom renders the image at ZoomLevel×natural size inside
                 a ScrollViewer. Ctrl+MouseWheel adjusts zoom.
-->
<UserControl x:Class="WpfHexEditor.Plugins.ScreenRecorder.Views.PreviewPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:WpfHexEditor.Plugins.ScreenRecorder.Services"
             Background="{DynamicResource DockMenuBackgroundBrush}"
             PreviewMouseWheel="OnPreviewMouseWheel">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <svc:ScreenRecorderLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Image area -->
        <Grid Grid.Row="0">
            <!-- Fit-to-container mode: simple Image with Stretch=Uniform -->
            <Image x:Name="FitImage"
                   Source="{Binding CurrentBitmap}"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Margin="8">
                <Image.Style>
                    <Style TargetType="Image">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FitToContainer}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>

            <!-- Numeric zoom mode: Image sized via ScaleTransform inside ScrollViewer -->
            <ScrollViewer x:Name="ZoomScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Focusable="False">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FitToContainer}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <Image x:Name="ZoomImage"
                       Source="{Binding CurrentBitmap}"
                       Stretch="None"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                    <Image.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
                    </Image.LayoutTransform>
                </Image>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock Text="{StaticResource ScreenRecorder_NoFrameSelected}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       FontSize="13"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentBitmap}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Zoom toolbar -->
        <Border Grid.Row="1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,3">
            <DockPanel>
                <!-- Frame label -->
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding FrameLabel}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <!-- Zoom controls right-aligned -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="{StaticResource ScreenRecorder_ZoomOut}"
                            Command="{Binding ZoomOutCommand}"
                            Style="{DynamicResource PM_ActionButtonStyle}"
                            Padding="6,2" FontSize="11" Margin="0,0,2,0"
                            ToolTip="{StaticResource ScreenRecorder_ZoomOut}"/>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Margin="4,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding ZoomLevel, StringFormat={}{0:P0}}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FitToContainer}" Value="True">
                                        <Setter Property="Text" Value="Fit"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Content="{StaticResource ScreenRecorder_ZoomIn}"
                            Command="{Binding ZoomInCommand}"
                            Style="{DynamicResource PM_ActionButtonStyle}"
                            Padding="6,2" FontSize="11" Margin="0,0,6,0"
                            ToolTip="{StaticResource ScreenRecorder_ZoomIn}"/>
                    <Button Content="1:1"
                            Command="{Binding Zoom1To1Command}"
                            Style="{DynamicResource PM_ActionButtonStyle}"
                            Padding="6,2" FontSize="11" Margin="0,0,2,0"
                            ToolTip="{StaticResource ScreenRecorder_Zoom1To1}"/>
                    <Button Content="{StaticResource ScreenRecorder_ZoomFit}"
                            Command="{Binding ZoomFitCommand}"
                            Style="{DynamicResource PM_ActionButtonStyle}"
                            Padding="6,2" FontSize="11"
                            ToolTip="{StaticResource ScreenRecorder_ZoomFit}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

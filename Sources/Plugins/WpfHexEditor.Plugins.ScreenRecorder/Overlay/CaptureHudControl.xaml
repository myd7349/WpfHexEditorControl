<!--
    Project: WpfHexEditor.Plugins.ScreenRecorder
    File: Overlay/CaptureHudControl.xaml
    Description: Small HUD shown inside the capture overlay during an active session.
                 Displays frame count, elapsed time, mode, and ESC reminder.
-->
<UserControl x:Class="WpfHexEditor.Plugins.ScreenRecorder.Overlay.CaptureHudControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False">
    <Border Background="#CC1A1A1A"
            CornerRadius="6"
            Padding="10,6"
            BorderBrush="#44FFFFFF"
            BorderThickness="1">
        <StackPanel Orientation="Horizontal" >
            <!-- Blinking record indicator -->
            <Ellipse x:Name="RecordDot"
                     Width="10" Height="10"
                     Fill="#FFEF5350"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.2" Duration="0:0:0.6"
                                                             AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>

            <TextBlock Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                <Run Text="{Binding StatusLabel, Mode=OneWay}" />
                <Run Text=" · " Foreground="#88FFFFFF"/>
                <Run Text="{Binding FrameCount, Mode=OneWay, StringFormat={}{0} frames}" />
                <Run Text=" · " Foreground="#88FFFFFF"/>
                <Run Text="{Binding Elapsed, Mode=OneWay}" />
            </TextBlock>

            <TextBlock Text=" · " Foreground="#88FFFFFF" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding EscLabel}"
                       Foreground="#AAFFFFFF" FontSize="11"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>

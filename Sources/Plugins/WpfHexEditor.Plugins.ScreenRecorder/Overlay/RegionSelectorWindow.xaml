<!--
    Project: WpfHexEditor.Plugins.ScreenRecorder
    File: Overlay/RegionSelectorWindow.xaml
    Description: Full-screen transparent window for rubber-band region selection.
                 User drags to define the capture rectangle.
-->
<Window x:Class="WpfHexEditor.Plugins.ScreenRecorder.Overlay.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#44000000"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Cursor="Cross">
    <Canvas x:Name="RootCanvas"
            MouseLeftButtonDown="OnMouseDown"
            MouseLeftButtonUp="OnMouseUp"
            MouseMove="OnMouseMove"
            KeyDown="OnKeyDown"
            Focusable="True">

        <!-- Rubber-band selection rectangle -->
        <Rectangle x:Name="SelectionRect"
                   Stroke="#FF2196F3"
                   StrokeThickness="2"
                   Fill="#332196F3"
                   Visibility="Collapsed" />

        <!-- Instruction label -->
        <TextBlock x:Name="InstructionText"
                   Canvas.Left="0" Canvas.Top="0"
                   Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}"
                   Text="Drag to select capture region — ESC to cancel"
                   Foreground="White"
                   FontSize="14"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,20,0,0" />
    </Canvas>
</Window>

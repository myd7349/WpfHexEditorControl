<UserControl x:Class="WpfHexEditor.Plugins.AIAssistant.TitleBar.AITitleBarButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="40" Height="32" Cursor="Hand"
             ToolTip="{DynamicResource AIAssistant_TitleBarTooltip}"
             xmlns:aiSvc="clr-namespace:WpfHexEditor.Plugins.AIAssistant.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <aiSvc:AIAssistantLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="{StaticResource AIAssistant_NewConversation}" Click="OnNewTabClick">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{StaticResource AIAssistant_AskAboutSelection}" Click="OnAskSelectionClick">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{StaticResource AIAssistant_FixErrors2}" Click="OnFixErrorsClick">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="{StaticResource AIAssistant_AccountUsage2}" Click="OnAccountUsageClick">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{StaticResource AIAssistant_ManageConnections2}" Click="OnManageConnectionsClick">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{StaticResource AIAssistant_Options2}" Click="OnOptionsClick">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.ContextMenu>

    <Border x:Name="ButtonBorder" CornerRadius="2" Padding="4,0"
            Background="{DynamicResource CA_TitleBarButtonBackgroundBrush}"
            MouseEnter="OnMouseEnter" MouseLeave="OnMouseLeave"
            MouseLeftButtonDown="OnLeftClick" MouseRightButtonDown="OnRightClick">
        <Grid>
            <!-- Claude icon (sparkle glyph) -->
            <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       Foreground="{DynamicResource CA_AccentBrandingBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Status badge (bottom-right) -->
            <Ellipse x:Name="StatusBadge" Width="8" Height="8"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,2,4"
                     Fill="{DynamicResource CA_TitleBarBadgeIdleBrush}"/>

            <!-- CLI badge text (shown when connected via CLI) -->
            <TextBlock x:Name="CliBadgeText" Text="{StaticResource AIAssistant_CliBadge}" FontSize="7" FontWeight="Bold"
                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                       Margin="1,0,0,3" Visibility="Collapsed"
                       Foreground="{DynamicResource DockTabActiveBrush}"/>
        </Grid>
    </Border>
</UserControl>

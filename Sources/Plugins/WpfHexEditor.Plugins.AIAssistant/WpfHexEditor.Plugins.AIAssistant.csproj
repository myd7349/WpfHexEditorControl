<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>WpfHexEditor.Plugins.AIAssistant</RootNamespace>
    <AssemblyName>WpfHexEditor.Plugins.AIAssistant</AssemblyName>

    <!-- Plugin metadata — WpfHexEditor.SDK.targets generates manifest.json -->
    <PluginId>WpfHexEditor.Plugins.AIAssistant</PluginId>
    <PluginName>AI Assistant</PluginName>
    <PluginVersion>1.0.0</PluginVersion>
    <PluginEntryPoint>WpfHexEditor.Plugins.AIAssistant.AIAssistantPlugin</PluginEntryPoint>
    <PluginAuthor>Derek Tremblay</PluginAuthor>
    <PluginPublisher>WpfHexEditor</PluginPublisher>
    <PluginTrustedPublisher>true</PluginTrustedPublisher>
    <PluginDescription>Multi-provider AI assistant with MCP integration, streaming chat, inline apply, and full IDE context awareness.</PluginDescription>
    <PluginIsolationMode>Auto</PluginIsolationMode>
    <PluginLoadPriority>200</PluginLoadPriority>
    <PluginSdkVersion>2.0.0</PluginSdkVersion>
    <PluginMinIDEVersion>0.6.0</PluginMinIDEVersion>
    <PluginActivationOnStartup>true</PluginActivationOnStartup>
    <PluginActivationCommands>"View.AIAssistant"</PluginActivationCommands>
    <PluginMenuContributionsJson>[{"commandId":"View.AIAssistant","label":"_AI Assistant","parentPath":"View","group":"Panels","category":"AI &amp; Assistants","iconGlyph":"\uE734"}]</PluginMenuContributionsJson>

    <!-- Permissions -->
    <PluginPermAccessHexEditor>true</PluginPermAccessHexEditor>
    <PluginPermAccessCodeEditor>true</PluginPermAccessCodeEditor>
    <PluginPermAccessFileSystem>true</PluginPermAccessFileSystem>
    <PluginPermAccessNetwork>true</PluginPermAccessNetwork>
    <PluginPermAccessSettings>true</PluginPermAccessSettings>
    <PluginPermRegisterMenus>true</PluginPermRegisterMenus>
    <PluginPermWriteOutput>true</PluginPermWriteOutput>
    <PluginPermWriteTerminal>true</PluginPermWriteTerminal>
    <PluginPermRegisterTerminalCommands>true</PluginPermRegisterTerminalCommands>
    <!-- Ensure NuGet runtime DLLs are copied to output (required for plugin ALC loading) -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\WpfHexEditor.SDK\WpfHexEditor.SDK.csproj" />
    <ProjectReference Include="..\..\WpfHexEditor.Core.MCP\WpfHexEditor.Core.MCP.csproj" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.ProjectSystem\WpfHexEditor.Core.ProjectSystem.csproj" />
    <ProjectReference Include="..\..\Editors\WpfHexEditor.Editor.CodeEditor\WpfHexEditor.Editor.CodeEditor.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
  </ItemGroup>

  <Import Project="..\WpfHexEditor.SDK\Build\WpfHexEditor.SDK.targets" />

  <!-- Copy compiled plugin + all dependencies to App Plugins directory after build -->
  <Target Name="CopyToPluginsDir" AfterTargets="GeneratePluginManifest">
    <PropertyGroup>
      <PluginDestDir>$(MSBuildThisFileDirectory)..\..\WpfHexEditor.App\bin\$(Configuration)\net8.0-windows\Plugins\$(AssemblyName)\</PluginDestDir>
    </PropertyGroup>
    <MakeDir Directories="$(PluginDestDir)" />
    <ItemGroup>
      <PluginFiles Include="$(OutputPath)$(AssemblyName).dll" />
      <PluginFiles Include="$(OutputPath)$(AssemblyName).pdb" Condition="Exists('$(OutputPath)$(AssemblyName).pdb')" />
      <PluginFiles Include="$(OutputPath)manifest.json" />
      <PluginFiles Include="$(OutputPath)WpfHexEditor.Core.MCP.dll" />
      <PluginFiles Include="$(OutputPath)CommunityToolkit.Mvvm.dll" />
      <PluginFiles Include="$(OutputPath)Microsoft.Bcl.AsyncInterfaces.dll" Condition="Exists('$(OutputPath)Microsoft.Bcl.AsyncInterfaces.dll')" />
    </ItemGroup>
    <Copy SourceFiles="@(PluginFiles)"
          DestinationFolder="$(PluginDestDir)"
          OverwriteReadOnlyFiles="true"
          SkipUnchangedFiles="true" />
  </Target>

</Project>

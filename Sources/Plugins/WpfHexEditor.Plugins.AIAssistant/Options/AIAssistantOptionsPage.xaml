<UserControl x:Class="WpfHexEditor.Plugins.AIAssistant.Options.AIAssistantOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="500" MinHeight="400"
             Background="Transparent"
             xmlns:aiSvc="clr-namespace:WpfHexEditor.Plugins.AIAssistant.Services">
    <UserControl.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <aiSvc:AIAssistantLocalizedDictionary/>
                </ResourceDictionary.MergedDictionaries>

        <!-- Button style — dark themed -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SE_HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider dark template -->
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{DynamicResource AccentBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{DynamicResource DockBorderBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="ThumbEllipse" Width="14" Height="14"
                                                         Fill="{DynamicResource AccentBrush}"
                                                         Stroke="{DynamicResource DockBorderBrush}" StrokeThickness="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbEllipse" Property="Stroke"
                                                                Value="{DynamicResource DockMenuForegroundBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView / GridViewColumnHeader dark styling -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SE_HoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox / PasswordBox / ComboBox / CheckBox implicit styles -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <!-- ComboBox full dark template -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Bd" Grid.ColumnSpan="2" CornerRadius="2"
                        Background="{DynamicResource DockBackgroundBrush}"
                        BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="1"/>
                <Path x:Name="Arrow" Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                      Fill="{DynamicResource DockMenuForegroundBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SE_HoverBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggle}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,2,24,2"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200"
                                      SnapsToDevicePixels="True">
                                    <Border x:Name="DropDownBorder"
                                            Background="{DynamicResource DockBackgroundBrush}"
                                            BorderBrush="{DynamicResource DockBorderBrush}"
                                            BorderThickness="1" CornerRadius="2"/>
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SE_HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox dark template -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBorder" Width="16" Height="16"
                                    Background="{DynamicResource DockBackgroundBrush}"
                                    BorderBrush="{DynamicResource DockBorderBrush}"
                                    BorderThickness="1" CornerRadius="2"
                                    VerticalAlignment="Center" Margin="0,0,6,0">
                                <Path x:Name="CheckMark" Data="M 2 5 L 5.5 9 L 11 2"
                                      Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="2" Visibility="Collapsed"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background"
                                        Value="{DynamicResource SE_HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource DockBorderBrush}"/>
        </Style>
                </ResourceDictionary>
        </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel Margin="0,0,0,16">
            <!-- ══════════════════ Anthropic ══════════════════ -->
            <TextBlock Text="{StaticResource AIAssistant_AnthropicClaude}" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource AIAssistant_ApiKeyLabel}" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <PasswordBox x:Name="AnthropicKeyBox" Grid.Column="1" MaxLength="200" Margin="0,0,8,0"/>
                <Button x:Name="TestAnthropicBtn" Grid.Column="2" Content="{StaticResource AIAssistant_TestButton}" Width="70"
                        Click="OnTestAnthropicClick" Padding="4,2"/>
            </Grid>

            <Separator Margin="0,12"/>

            <!-- ══════════════════ OpenAI ══════════════════ -->
            <TextBlock Text="{StaticResource AIAssistant_OpenAI}" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,8,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource AIAssistant_ApiKeyLabel}" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <PasswordBox x:Name="OpenAIKeyBox" Grid.Column="1" MaxLength="200" Margin="0,0,8,0"/>
                <Button x:Name="TestOpenAIBtn" Grid.Column="2" Content="{StaticResource AIAssistant_TestButton}" Width="70"
                        Click="OnTestOpenAIClick" Padding="4,2"/>
            </Grid>

            <Separator Margin="0,12"/>

            <!-- ══════════════════ Azure OpenAI ══════════════════ -->
            <TextBlock Text="{StaticResource AIAssistant_AzureOpenAI}" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,8,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource AIAssistant_ApiKeyLabel}" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <PasswordBox x:Name="AzureKeyBox" Grid.Column="1" MaxLength="200" Margin="0,0,8,0"/>
                <Button x:Name="TestAzureBtn" Grid.Column="2" Content="{StaticResource AIAssistant_TestButton}" Width="70"
                        Click="OnTestAzureClick" Padding="4,2"/>
            </Grid>
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource AIAssistant_EndpointLabel}" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <TextBox x:Name="AzureEndpointBox" Grid.Column="1"/>
            </Grid>
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource AIAssistant_DeploymentLabel}" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <TextBox x:Name="AzureDeploymentBox" Grid.Column="1"/>
            </Grid>

            <Separator Margin="0,12"/>

            <!-- ══════════════════ Google Gemini ══════════════════ -->
            <TextBlock Text="{StaticResource AIAssistant_GoogleGemini}" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,8,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource AIAssistant_ApiKeyLabel}" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <PasswordBox x:Name="GeminiKeyBox" Grid.Column="1" MaxLength="200" Margin="0,0,8,0"/>
                <Button x:Name="TestGeminiBtn" Grid.Column="2" Content="{StaticResource AIAssistant_TestButton}" Width="70"
                        Click="OnTestGeminiClick" Padding="4,2"/>
            </Grid>

            <Separator Margin="0,12"/>

            <!-- ══════════════════ Ollama ══════════════════ -->
            <TextBlock Text="{StaticResource AIAssistant_OllamaLocal}" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,8,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource AIAssistant_BaseUrlLabel}" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <TextBox x:Name="OllamaUrlBox" Grid.Column="1" Margin="0,0,8,0"/>
                <Button x:Name="TestOllamaBtn" Grid.Column="2" Content="{StaticResource AIAssistant_TestButton}" Width="70"
                        Click="OnTestOllamaClick" Padding="4,2"/>
            </Grid>

            <Separator Margin="0,12"/>

            <!-- ══════════════════ Defaults ══════════════════ -->
            <TextBlock Text="{StaticResource AIAssistant_DefaultsSection}" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,8,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource AIAssistant_ProviderLabel}" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <ComboBox x:Name="DefaultProviderCombo" Grid.Column="1"
                          SelectionChanged="OnDefaultProviderChanged"/>
            </Grid>
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource AIAssistant_ModelLabel}" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <ComboBox x:Name="DefaultModelCombo" Grid.Column="1"/>
            </Grid>
            <CheckBox x:Name="ThinkingCheck" Content="{StaticResource AIAssistant_EnableThinkingOption}"
                      Margin="0,8,0,4"/>

            <!-- Thinking budget -->
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource AIAssistant_ThinkingBudget}" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <Slider x:Name="ThinkingBudgetSlider" Grid.Column="1"
                        Minimum="1024" Maximum="32768" TickFrequency="1024"
                        IsSnapToTickEnabled="True" VerticalAlignment="Center"
                        ValueChanged="OnThinkingBudgetChanged"/>
                <TextBlock x:Name="ThinkingBudgetLabel" Grid.Column="2"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            </Grid>

            <!-- Max conversation tokens -->
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{StaticResource AIAssistant_MaxTokens}" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <Slider x:Name="MaxTokensSlider" Grid.Column="1"
                        Minimum="10000" Maximum="200000" TickFrequency="10000"
                        IsSnapToTickEnabled="True" VerticalAlignment="Center"
                        ValueChanged="OnMaxTokensChanged"/>
                <TextBlock x:Name="MaxTokensLabel" Grid.Column="2"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            </Grid>

            <CheckBox x:Name="ShowToolCallsCheck" Content="{StaticResource AIAssistant_ShowToolCalls}"
                      Margin="0,8,0,0"/>

            <Separator Margin="0,12"/>

            <!-- ══════════════════ MCP Servers ══════════════════ -->
            <TextBlock Text="{StaticResource AIAssistant_McpServers}" FontWeight="SemiBold" FontSize="14"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,8,0,8"/>

            <ListView x:Name="McpListView" Height="120" Margin="0,0,0,4">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{StaticResource AIAssistant_ColEnabled}" Width="55">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Enabled}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{StaticResource AIAssistant_ColName}" Width="140"
                                        DisplayMemberBinding="{Binding DisplayName}"/>
                        <GridViewColumn Header="{StaticResource AIAssistant_ColCommand}" Width="200"
                                        DisplayMemberBinding="{Binding Command}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Add MCP server inline form -->
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="McpNameBox" Grid.Column="0" ToolTip="{StaticResource AIAssistant_ColDisplayName}" Margin="0,0,4,0"/>
                <TextBox x:Name="McpCommandBox" Grid.Column="1" ToolTip="{StaticResource AI_TipMcpCommand}" Margin="0,0,4,0"/>
                <TextBox x:Name="McpArgsBox" Grid.Column="2" ToolTip="{StaticResource AIAssistant_ColArgs}" Margin="0,0,4,0"/>
                <Button x:Name="McpAddBtn" Grid.Column="3" Content="{StaticResource AIAssistant_Add}" Width="50"
                        Click="OnMcpAddClick" Padding="4,2" Margin="0,0,4,0"/>
                <Button x:Name="McpRemoveBtn" Grid.Column="4" Content="{StaticResource AIAssistant_Remove}" Width="60"
                        Click="OnMcpRemoveClick" Padding="4,2"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>

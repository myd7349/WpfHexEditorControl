<UserControl x:Class="WpfHexEditor.Plugins.EntropyVisualizer.Views.EntropyVisualizerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:WpfHexEditor.Plugins.EntropyVisualizer.Services"
             xmlns:views="clr-namespace:WpfHexEditor.Plugins.EntropyVisualizer.Views"
             Background="{DynamicResource PanelBackground}"
             Foreground="{DynamicResource PanelForeground}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <svc:EntropyVisualizerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource ToolbarBackground}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="AnalyzeButton"
                        Content="{StaticResource EntropyVisualizer_AnalyzeButton}"
                        ToolTip="{StaticResource EntropyVisualizer_Tooltip_Analyze}"
                        IsEnabled="{Binding IsIdle}"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Padding="8,3"
                        Margin="0,0,4,0"
                        Click="OnAnalyzeClick"/>

                <Button Grid.Column="1"
                        x:Name="CancelButton"
                        Content="{StaticResource EntropyVisualizer_CancelButton}"
                        IsEnabled="{Binding IsAnalyzing}"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Padding="8,3"
                        Click="OnCancelClick"/>

                <Separator Grid.Column="2" Style="{DynamicResource ToolbarSeparatorStyle}"/>

                <TextBlock Grid.Column="3"
                           Text="{StaticResource EntropyVisualizer_ChunkSizeLabel}"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           Foreground="{DynamicResource PanelForeground}"/>

                <TextBox Grid.Column="4"
                         x:Name="ChunkSizeBox"
                         Text="256"
                         Width="50"
                         VerticalAlignment="Center"
                         ToolTip="{StaticResource EntropyVisualizer_Tooltip_ChunkSize}"
                         TextAlignment="Center"
                         Style="{DynamicResource ToolbarTextBoxStyle}"/>
            </Grid>
        </Border>

        <!-- Graph area -->
        <Grid Grid.Row="1">

            <!-- Empty-state overlay -->
            <TextBlock x:Name="EmptyStateText"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PanelForeground}"
                       Opacity="0.5"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="20"/>

            <!-- Progress overlay -->
            <Border x:Name="ProgressOverlay"
                    Background="{DynamicResource PanelBackground}"
                    Opacity="0.85"
                    Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{StaticResource EntropyVisualizer_Analyzing}"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"
                               Margin="0,0,0,8"/>
                    <ProgressBar Width="200" Height="6"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding Progress}"/>
                </StackPanel>
            </Border>

            <!-- Entropy graph -->
            <views:EntropyGraphControl x:Name="Graph"
                                       Chunks="{Binding Chunks}"
                                       ToolTip="{StaticResource EntropyVisualizer_Tooltip_Navigate}"
                                       Cursor="Hand"/>

            <!-- Legend (top-right corner) -->
            <StackPanel HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,12,12,0"
                        Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <Rectangle Width="12" Height="3" Fill="#56D577" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{StaticResource EntropyVisualizer_LegendLow}"
                               Foreground="{DynamicResource PanelForeground}"
                               FontSize="10" Opacity="0.7"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Rectangle Width="12" Height="3" Fill="#F44747" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{StaticResource EntropyVisualizer_LegendHigh}"
                               Foreground="{DynamicResource PanelForeground}"
                               FontSize="10" Opacity="0.7"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource StatusBarBackground}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="6,2">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource StatusBarForeground}"
                       FontSize="11"/>
        </Border>
    </Grid>
</UserControl>

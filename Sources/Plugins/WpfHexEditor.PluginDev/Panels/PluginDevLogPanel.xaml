     File: Panels/PluginDevLogPanel.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude Sonnet 4.6
     Created: 2026-03-16
     Description:
         VS-Like dockable panel showing plugin developer logs.
         Toolbar: Clear / Filter toggles / Export.
         ListView: Timestamp | Level | Source | Message.
     WPF Theme: Global theme (DockMenuBackgroundBrush / DockMenuForegroundBrush / DockBorderBrush)
     ========================================================== -->
<UserControl x:Class="WpfHexEditor.PluginDev.Panels.PluginDevLogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.PluginDev.Panels"
             Background="{DynamicResource DockMenuBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}">

    <UserControl.Resources>
        <!-- Level badge converter -->
        <local:LogLevelToBrushConverter x:Key="LevelBrushConverter"/>

        <!-- Row style — color by level -->
        <Style x:Key="LogRowStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <!-- Column header style -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"  Value="{DynamicResource DockMenuBackgroundBrush}"/>
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
        </Style>

        <!-- Toolbar button style -->
        <Style x:Key="TbBtnStyle" TargetType="Button">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding"     Value="6,2"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>

        <Style x:Key="TbToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderBrush"  Value="Transparent"/>
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding"      Value="6,2"/>
            <Setter Property="Cursor"       Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <DockPanel>

        <!-- ================================================================
             Toolbar
             ================================================================ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Height="28">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">

                <!-- Clear -->
                <Button x:Name="BtnClear" Style="{StaticResource TbBtnStyle}"
                        ToolTip="Clear log"
                        Click="OnClear">
                    <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </Button>

                <Separator Width="1" Background="{DynamicResource DockBorderBrush}" Margin="4,4"/>

                <!-- Level filter toggles -->
                <ToggleButton x:Name="TbgDebug" Style="{StaticResource TbToggleStyle}"
                              IsChecked="{Binding ShowDebug}" Content="Debug" FontSize="10"/>
                <ToggleButton x:Name="TbgInfo" Style="{StaticResource TbToggleStyle}"
                              IsChecked="{Binding ShowInfo}" Content="Info" FontSize="10"/>
                <ToggleButton x:Name="TbgWarning" Style="{StaticResource TbToggleStyle}"
                              IsChecked="{Binding ShowWarning}" Content="Warn" FontSize="10"
                              Foreground="#DCDCAA"/>
                <ToggleButton x:Name="TbgError" Style="{StaticResource TbToggleStyle}"
                              IsChecked="{Binding ShowError}" Content="Error" FontSize="10"
                              Foreground="#F48771"/>

                <Separator Width="1" Background="{DynamicResource DockBorderBrush}" Margin="4,4"/>

                <!-- Source filter -->
                <TextBox x:Name="TbSourceFilter"
                         Width="100" Height="20" FontSize="10"
                         Background="{DynamicResource DockMenuBackgroundBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         Text="{Binding FilterSource, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Filter by source"
                         VerticalContentAlignment="Center" Padding="4,0"/>

                <Separator Width="1" Background="{DynamicResource DockBorderBrush}" Margin="4,4"/>

                <!-- Export -->
                <Button x:Name="BtnExport" Style="{StaticResource TbBtnStyle}"
                        ToolTip="Export log to file"
                        Click="OnExport">
                    <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </Button>

                <!-- Auto-scroll toggle -->
                <ToggleButton x:Name="TbgAutoScroll" Style="{StaticResource TbToggleStyle}"
                              IsChecked="{Binding AutoScroll}"
                              ToolTip="Auto-scroll to latest entry"
                              Margin="4,0,0,0">
                    <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </ToggleButton>

            </StackPanel>
        </Border>

        <!-- ================================================================
             Log list
             ================================================================ -->
        <ListView x:Name="LvLog"
                  ItemsSource="{Binding Entries}"
                  ItemContainerStyle="{StaticResource LogRowStyle}"
                  Background="{DynamicResource DockMenuBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  FontFamily="Consolas" FontSize="11">

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Time"    Width="80"
                                    DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"/>
                    <GridViewColumn Header="Level"   Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Level}"
                                           Foreground="{Binding Level, Converter={StaticResource LevelBrushConverter}}"
                                           FontWeight="SemiBold"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Source"  Width="100"
                                    DisplayMemberBinding="{Binding Source}"/>
                    <GridViewColumn Header="Message" Width="600"
                                    DisplayMemberBinding="{Binding Message}"/>
                </GridView>
            </ListView.View>
        </ListView>

    </DockPanel>
</UserControl>

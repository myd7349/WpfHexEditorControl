    WpfHexEditor.PluginDev
    =======================
    In-IDE plugin development support: hot-reload, build orchestration,
    diagnostics panel, packaging, and per-session dev sandbox.
    Requires WpfHexEditor.Core.BuildSystem + WpfHexEditor.Core.WorkspaceTemplates.
-->

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>WpfHexEditor.PluginDev</RootNamespace>
    <AssemblyName>WpfHexEditor.PluginDev</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>In-IDE plugin development engine — hot-reload, build, sandbox, packaging.</Description>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Editors\WpfHexEditor.Editor.Core\WpfHexEditor.Editor.Core.csproj" />
    <ProjectReference Include="..\WpfHexEditor.SDK\WpfHexEditor.SDK.csproj" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.Options\WpfHexEditor.Core.Options.csproj" />
    <ProjectReference Include="..\WpfHexEditor.PluginHost\WpfHexEditor.PluginHost.csproj" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.BuildSystem\WpfHexEditor.Core.BuildSystem.csproj" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.WorkspaceTemplates\WpfHexEditor.Core.WorkspaceTemplates.csproj" />
    <ProjectReference Include="..\..\Docking\WpfHexEditor.Docking.Core\WpfHexEditor.Docking.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- MSBuild discovery — PrivateAssets=all prevents System.Text.Json 10 from leaking to the App. -->
    <PackageReference Include="Microsoft.Build.Locator" Version="1.11.2"><PrivateAssets>all</PrivateAssets></PackageReference>
    <PackageReference Include="Microsoft.Build"                Version="18.4.0" ExcludeAssets="runtime"><PrivateAssets>all</PrivateAssets></PackageReference>
    <PackageReference Include="Microsoft.Build.Framework"      Version="18.4.0" ExcludeAssets="runtime"><PrivateAssets>all</PrivateAssets></PackageReference>
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="18.4.0" ExcludeAssets="runtime"><PrivateAssets>all</PrivateAssets></PackageReference>
  </ItemGroup>

</Project>

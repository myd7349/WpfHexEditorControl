     Description:
         IDE Options page for Plugin Development settings.
         Registered under "Plugin Development" > "General".
     WPF Theme: Global theme (DockMenuBackgroundBrush / DockMenuForegroundBrush / DockBorderBrush)
     ========================================================== -->
<UserControl x:Class="WpfHexEditor.PluginDev.Options.PluginDevOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource DockMenuForegroundBrush}">

    <StackPanel Margin="12,8" MaxWidth="520">

        <!-- Auto-rebuild on save -->
        <CheckBox x:Name="CheckAutoRebuild" Margin="0,4"
                  Content="Rebuild plugin automatically on file save"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Checked="OnChanged" Unchecked="OnChanged"/>

        <!-- Post-build copy -->
        <CheckBox x:Name="CheckCopyOnBuild" Margin="0,4"
                  Content="Copy output to plugin directory after successful build"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Checked="OnChanged" Unchecked="OnChanged"/>

        <Separator Margin="0,8" Background="{DynamicResource DockBorderBrush}"/>

        <!-- Log level -->
        <StackPanel Orientation="Horizontal" Margin="0,4">
            <TextBlock Text="Log level:" VerticalAlignment="Center" Width="120"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="CbLogLevel" Width="140"
                      Background="{DynamicResource DockMenuBackgroundBrush}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      BorderBrush="{DynamicResource DockBorderBrush}"
                      SelectionChanged="OnChanged">
                <ComboBoxItem Content="Debug"   Tag="Debug"/>
                <ComboBoxItem Content="Info"    Tag="Info"/>
                <ComboBoxItem Content="Warning" Tag="Warning"/>
                <ComboBoxItem Content="Error"   Tag="Error"/>
            </ComboBox>
        </StackPanel>

        <!-- Sandbox mode -->
        <StackPanel Orientation="Horizontal" Margin="0,4">
            <TextBlock Text="Sandbox mode:" VerticalAlignment="Center" Width="120"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="CbSandboxMode" Width="200"
                      Background="{DynamicResource DockMenuBackgroundBrush}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      BorderBrush="{DynamicResource DockBorderBrush}"
                      SelectionChanged="OnChanged">
                <ComboBoxItem Content="Light (in-process, catch exceptions)" Tag="Light"/>
                <ComboBoxItem Content="Full (out-of-process Named Pipe)"     Tag="Full"/>
            </ComboBox>
        </StackPanel>

        <!-- Lifecycle timeout -->
        <StackPanel Orientation="Horizontal" Margin="0,4">
            <TextBlock Text="Init timeout (ms):" VerticalAlignment="Center" Width="120"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TbTimeout" Width="80"
                     Background="{DynamicResource DockMenuBackgroundBrush}"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Height="24" Padding="4,2" VerticalContentAlignment="Center"
                     TextChanged="OnChanged"/>
        </StackPanel>

        <Separator Margin="0,8" Background="{DynamicResource DockBorderBrush}"/>

        <!-- Status bar indicator -->
        <CheckBox x:Name="CheckStatusBarIndicator" Margin="0,4"
                  Content="Show 'Plugin Dev Mode' indicator in status bar"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Checked="OnChanged" Unchecked="OnChanged"/>

    </StackPanel>
</UserControl>

<UserControl x:Class="WpfHexEditor.Plugins.ParsedFields.Views.ParsedFieldsPanel"
             x:Name="RootPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexEditor.Plugins.ParsedFields.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300"
             Background="{DynamicResource PFP_PanelBackgroundBrush}">

    <UserControl.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <!-- Collapses groups whose name matches the ConverterParameter (default: "Format Metadata") -->
        <local:GroupNameToExpandedConverter x:Key="GroupNameToExpandedConverter"/>
        <!-- D6 — Maps IsAiSectionExpanded bool to chevron-down / chevron-right glyph -->
        <local:BoolToChevronConverter x:Key="BoolToChevronConverter"/>

        <!-- Override WPF inactive-selection system colors so ListBox and TreeView keep
             the same selection highlight when the panel loses keyboard focus. -->
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                         Color="#2A2A32"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                         Color="#FFFFFF"/>

        <!-- Style for navigator bookmark buttons (section tabs like PE Header, COFF Header…) -->
        <Style x:Key="PFP_NavBookmarkButtonStyle" TargetType="Button">
            <Setter Property="Foreground"   Value="{DynamicResource PFP_TextBrush}"/>
            <Setter Property="Background"   Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="6,2"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="{DynamicResource Panel_ItemHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PFP_ItemSelectedBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PFP_AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Panel_ItemSelectedForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for field items with improved colors -->
        <Style x:Key="FieldItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PFP_ItemSeparatorBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
            <EventSetter Event="MouseDoubleClick" Handler="FieldItem_MouseDoubleClick"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource Panel_ItemSelectedForegroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PFP_ItemSelectedBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PFP_BorderBrush}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- Data template for parsed fields -->
        <DataTemplate x:Key="FieldTemplate">
            <Border Padding="4,2" CornerRadius="4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                <Setter Property="Background" Value="{DynamicResource PFP_ValidationErrorBackgroundBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource PFP_ValidationErrorBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="{Binding IndentMargin}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Color indicator -->
                    <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="0"
                            Width="4" Margin="0,0,8,0"
                            Background="{Binding Color}"
                            CornerRadius="2"/>

                    <!-- Icon -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="1"
                               Text="{Binding FieldIcon}"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               ToolTip="{Binding ValueType}"/>

                    <!-- Validation warning icon -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="2"
                               Text="⚠"
                               FontSize="14"
                               Margin="0,0,6,0"
                               Foreground="#F44336"
                               VerticalAlignment="Center"
                               ToolTip="{Binding ValidationMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Search match indicator -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="3"
                               Text="🔍"
                               FontSize="11"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="#4CAF50"
                               ToolTip="Search match"
                               Visibility="{Binding IsSearchMatch, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Bookmark indicator -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="4" Grid.Column="3"
                               Text="⭐"
                               FontSize="12"
                               Margin="14,0,6,0"
                               VerticalAlignment="Center"
                               ToolTip="Bookmarked"
                               Visibility="{Binding IsBookmarked, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Field name -->
                    <TextBlock Grid.Row="0" Grid.Column="4"
                               Text="{Binding Name}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding DetailedTooltip}"/>

                    <!-- Field value -->
                    <Grid Grid.Row="1" Grid.Column="4" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Value: "
                                   FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource PFP_SubTextBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource Panel_ItemSelectedForegroundBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding ActiveFormattedValue}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"
                                   ToolTip="{Binding DetailedTooltip}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource PFP_ValueBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource Panel_ItemSelectedForegroundBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Display mode toggle H/D/B (C7) -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,0,0,0"
                                    Visibility="{Binding IsNumericType, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button Content="H" Tag="hex" Click="DisplayModeButton_Click"
                                    Width="18" Height="16" FontSize="9" FontFamily="Consolas"
                                    FontWeight="SemiBold" Padding="0" Margin="1,0"
                                    Foreground="{DynamicResource PFP_SubTextBrush}"
                                    ToolTip="Hexadecimal"
                                    Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                            <Button Content="D" Tag="dec" Click="DisplayModeButton_Click"
                                    Width="18" Height="16" FontSize="9" FontFamily="Consolas"
                                    FontWeight="SemiBold" Padding="0" Margin="1,0"
                                    Foreground="{DynamicResource PFP_SubTextBrush}"
                                    ToolTip="Decimal"
                                    Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                            <Button Content="B" Tag="bin" Click="DisplayModeButton_Click"
                                    Width="18" Height="16" FontSize="9" FontFamily="Consolas"
                                    FontWeight="SemiBold" Padding="0" Margin="1,0"
                                    Foreground="{DynamicResource PFP_SubTextBrush}"
                                    ToolTip="Binary"
                                    Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Field details -->
                    <TextBlock Grid.Row="2" Grid.Column="4"
                               Margin="0,2,0,0"
                               FontSize="10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource PFP_PlaceholderBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource Panel_ItemSelectedForegroundBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding RangeDisplay, Mode=OneWay}"/>
                        <Run Text=" • "/>
                        <Run Text="{Binding ValueType, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Validation error message -->
                    <TextBlock Grid.Row="3" Grid.Column="4"
                               Margin="0,4,0,0"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#F44336"
                               TextWrapping="Wrap"
                               Text="{Binding ValidationMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>   <!-- VS-style toolbar -->
            <RowDefinition Height="Auto"/> <!-- Search box -->
            <RowDefinition Height="Auto"/> <!-- Format info -->
            <RowDefinition Height="Auto"/> <!-- Key Insights strip -->
            <RowDefinition Height="Auto"/> <!-- Coverage bar -->
            <RowDefinition Height="*"/>    <!-- Fields list (metadata+enriched+fields as groups) -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- VS-style Toolbar (Row 0) — Segoe MDL2 icons, matches ErrorPanel/SolutionExplorer -->
        <Border x:Name="ToolbarBorder"
                Grid.Row="0"
                Style="{DynamicResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="False" Margin="2,0">

                <!-- LEFT: Refresh — always visible -->
                <Button x:Name="RefreshButton"
                        DockPanel.Dock="Left"
                        Content="&#xE72C;"
                        ToolTip="Refresh field values (F5)"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Click="RefreshButton_Click"/>

                <!-- RIGHT: always-visible (Badges + separator + Bookmarks toggle) -->
                <StackPanel x:Name="ToolbarRightPanel"
                            Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <!-- Valid fields badge -->
                    <Border x:Name="ValidBadge"
                            CornerRadius="8"
                            Padding="5,1"
                            Margin="2,5"
                            Background="#4CAF50"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            ToolTip="Valid fields">
                        <TextBlock FontSize="10" Foreground="White" FontWeight="SemiBold">
                            <Run Text="&#x2713; "/>
                            <Run x:Name="ValidCountRun" Text="0"/>
                        </TextBlock>
                    </Border>
                    <!-- Invalid fields badge — click to jump to first error -->
                    <Border x:Name="InvalidBadge"
                            CornerRadius="8"
                            Padding="5,1"
                            Margin="2,5"
                            Background="#F44336"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            ToolTip="Fields with validation errors — click to navigate"
                            Cursor="Hand"
                            MouseLeftButtonDown="InvalidBadge_Click">
                        <TextBlock FontSize="10" Foreground="White" FontWeight="SemiBold">
                            <Run Text="&#x26A0; "/>
                            <Run x:Name="InvalidCountRun" Text="0"/>
                        </TextBlock>
                    </Border>
                    <Rectangle Style="{DynamicResource PanelToolbarSeparatorStyle}"/>
                    <ToggleButton x:Name="ShowBookmarksButton"
                                  Content="&#xE734;"
                                  ToolTip="Show bookmarked fields only"
                                  Style="{DynamicResource PanelIconToggleStyle}"
                                  Checked="ShowBookmarksButton_Checked"
                                  Unchecked="ShowBookmarksButton_Unchecked"/>
                </StackPanel>

                <!-- Overflow button — shown only when groups are collapsed -->
                <Button x:Name="ToolbarOverflowButton"
                        DockPanel.Dock="Right"
                        Visibility="Collapsed"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        ToolTip="More options"
                        Click="OnOverflowButtonClick">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowContextMenu" Opened="OnOverflowMenuOpened">
                            <!-- TbgActions items -->
                            <MenuItem Header="Field _Actions..."
                                      Tag="TbgActions"
                                      Click="ActionsMenuButton_Click"/>
                            <Separator Tag="TbgActions"/>
                            <!-- TbgExport items -->
                            <MenuItem Header="_Export..."
                                      Tag="TbgExport"
                                      Click="ExportMenuButton_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Group: TbgExport [0] first to collapse -->
                <StackPanel x:Name="TbgExport"
                            Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <Rectangle Style="{DynamicResource PanelToolbarSeparatorStyle}"/>
                    <Button x:Name="ExportMenuButton"
                            ToolTip="Export parsed fields to file or clipboard"
                            Style="{DynamicResource PanelDropdownButtonStyle}"
                            Click="ExportMenuButton_Click">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,5,0"
                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                <TextBlock Text="Export &#x25BE;" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="ExportContextMenu">
                                <MenuItem Header="As _Text"     Click="ExportAsText_Click"/>
                                <MenuItem Header="As _JSON"     Click="ExportAsJson_Click"/>
                                <MenuItem Header="As _CSV"      Click="ExportAsCsv_Click"/>
                                <MenuItem Header="As _XML"      Click="ExportAsXml_Click"/>
                                <MenuItem Header="As _HTML"     Click="ExportAsHtml_Click"/>
                                <MenuItem Header="As _Markdown" Click="ExportAsMarkdown_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <!-- Group: TbgActions [1] last to collapse -->
                <StackPanel x:Name="TbgActions"
                            Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <Rectangle Style="{DynamicResource PanelToolbarSeparatorStyle}"/>
                    <Button x:Name="ActionsMenuButton"
                            ToolTip="Field actions (edit, copy, navigate, bookmark...)"
                            Style="{DynamicResource PanelDropdownButtonStyle}"
                            Click="ActionsMenuButton_Click">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,5,0"
                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                <TextBlock Text="Actions &#x25BE;" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="ActionsContextMenu">
                                <MenuItem Header="_Edit"            InputGestureText="Enter" Click="EditValue_Click"       IsEnabled="{Binding HasSelection}"/>
                                <MenuItem Header="_Copy value"      InputGestureText="Ctrl+C" Click="CopyValue_Click"      IsEnabled="{Binding HasSelection}"/>
                                <MenuItem Header="Copy _Details"    Click="CopyDetails_Click"                              IsEnabled="{Binding HasSelection}"/>
                                <MenuItem Header="Copy _Offset"     Click="CopyOffset_Click"                               IsEnabled="{Binding HasSelection}"/>
                                <Separator/>
                                <MenuItem Header="_Navigate to field" Click="QuickNavigate_Click"                          IsEnabled="{Binding HasSelection}"/>
                                <MenuItem Header="_Jump to Offset..." Click="JumpToOffset_Click"/>
                                <Separator/>
                                <MenuItem Header="_Bookmark" InputGestureText="Space" Click="ToggleBookmark_Click"         IsEnabled="{Binding HasSelection}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Search box -->
        <Border Grid.Row="1"
                Background="{DynamicResource PFP_PanelBackgroundBrush}"
                Padding="12,8"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource PFP_BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchTextBox"
                         Grid.Row="0" Grid.Column="0"
                         Style="{DynamicResource PanelSearchBoxStyle}"
                         Tag="Search fields..."
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <Button x:Name="ClearSearchButton"
                        Grid.Row="0" Grid.Column="1"
                        Content="✕"
                        Width="24" Height="24"
                        Margin="4,0,0,0"
                        FontSize="12"
                        ToolTip="Clear search"
                        Click="ClearSearchButton_Click"
                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}">
                    <Button.Visibility>
                        <Binding Path="SearchText">
                            <Binding.Converter>
                                <StaticResource ResourceKey="BoolToVisibilityConverter"/>
                            </Binding.Converter>
                        </Binding>
                    </Button.Visibility>
                </Button>

                <!-- Advanced search options -->
                <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Orientation="Horizontal"
                           Margin="0,6,0,0">
                    <CheckBox x:Name="RegexSearchCheckBox"
                              Content="Regex"
                              FontSize="10"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              Checked="SearchOption_Changed"
                              Unchecked="SearchOption_Changed"/>
                    <CheckBox x:Name="CaseSensitiveCheckBox"
                              Content="Case-sensitive"
                              FontSize="10"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              Checked="SearchOption_Changed"
                              Unchecked="SearchOption_Changed"/>
                    <TextBlock Text="In:"
                               FontSize="10"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"/>
                    <ComboBox x:Name="SearchFieldCombo"
                              FontSize="10"
                              Width="110"
                              Margin="0,0,12,0"
                              SelectedIndex="0"
                              SelectionChanged="SearchOption_Changed">
                        <ComboBoxItem Content="All fields"/>
                        <ComboBoxItem Content="Name only"/>
                        <ComboBoxItem Content="Value only"/>
                        <ComboBoxItem Content="Description"/>
                    </ComboBox>
                    <TextBlock Text="Type:"
                               FontSize="10"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PFP_SubTextBrush}"/>
                    <ComboBox x:Name="TypeFilterCombo"
                              FontSize="10"
                              Width="100"
                              SelectedIndex="0"
                              SelectionChanged="SearchOption_Changed">
                        <ComboBoxItem Content="All types"/>
                        <ComboBoxItem Content="Integers"/>
                        <ComboBoxItem Content="Strings"/>
                        <ComboBoxItem Content="Bytes"/>
                    </ComboBox>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Format info -->
        <Border Grid.Row="2"
                Background="{DynamicResource PFP_SectionBackgroundBrush}"
                Padding="12,8"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                Visibility="{Binding FormatInfo.IsDetected, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- References info button — far left, visible only when whfmt has references/weblinks -->
                    <Button x:Name="ReferencesInfoButton"
                            Grid.Column="0"
                            Visibility="{Binding FormatInfo.HasReferences, Converter={StaticResource BoolToVisibilityConverter}}"
                            Click="ReferencesInfoButton_Click"
                            ToolTip="Format References &amp; Specifications"
                            Style="{StaticResource PFP_NavBookmarkButtonStyle}"
                            Margin="0,0,4,0" Padding="4,2"
                            FontFamily="Segoe MDL2 Assets" Content="&#xE946;"
                            FontSize="11" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{DynamicResource PFP_TextBrush}"
                                   Text="Format:"/>
                        <!-- Dropdown when multiple candidates detected -->
                        <ComboBox x:Name="FormatCandidateCombo"
                                  ItemsSource="{Binding FormatInfo.Candidates}"
                                  SelectedItem="{Binding FormatInfo.SelectedCandidate, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  Visibility="{Binding FormatInfo.HasMultipleCandidates, Converter={StaticResource BoolToVisibilityConverter}}"
                                  FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PFP_AccentBrush}"
                                  MinWidth="180" MaxWidth="280"
                                  VerticalAlignment="Center"
                                  SelectionChanged="FormatCandidateCombo_SelectionChanged"/>
                        <!-- Static text when single format -->
                        <TextBlock Text="{Binding FormatInfo.Name, Mode=OneWay}"
                                   Foreground="{DynamicResource PFP_AccentBrush}" FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding FormatInfo.HasMultipleCandidates, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    </StackPanel>

                    <Border Grid.Column="3"
                            Background="{DynamicResource PFP_CategoryBadgeBackgroundBrush}"
                            BorderBrush="{DynamicResource PFP_CategoryBadgeBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,2"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PFP_CategoryBadgeForegroundBrush}"
                                   Text="{Binding FormatInfo.Category}"/>
                    </Border>
                </Grid>

                <!-- Proxy element: stays in the visual tree so the Popup can reach the DataContext.
                     Popup content is not in the visual tree and cannot use RelativeSource/ElementName
                     to the UserControl root — this hidden FrameworkElement bridges the gap. -->
                <FrameworkElement x:Name="PopupDataContextProxy" Visibility="Collapsed"/>

                <!-- References popup — anchored to info button. -->
                <Popup x:Name="ReferencesPopup"
                       StaysOpen="False"
                       PlacementTarget="{Binding ElementName=ReferencesInfoButton}"
                       Placement="Bottom"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border DataContext="{Binding DataContext, ElementName=PopupDataContextProxy}"
                            Background="{DynamicResource DockBackgroundBrush}"
                            BorderBrush="{DynamicResource DockBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12,10"
                            MaxWidth="400"
                            MinWidth="220">
                        <StackPanel>
                            <!-- Specifications -->
                            <StackPanel Visibility="{Binding FormatInfo.HasSpecifications, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Specifications"
                                           FontWeight="SemiBold" FontSize="11"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                <ItemsControl ItemsSource="{Binding FormatInfo.Specifications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="4,1" TextWrapping="Wrap" FontSize="11"
                                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                       Text="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <!-- Separator (only when both sections present) -->
                            <Rectangle Height="1"
                                       Fill="{DynamicResource DockBorderBrush}"
                                       Margin="0,6"
                                       Visibility="{Binding FormatInfo.HasBothReferences, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <!-- Web Links -->
                            <StackPanel Visibility="{Binding FormatInfo.HasWebLinks, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Web Links"
                                           FontWeight="SemiBold" FontSize="11"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                <ItemsControl ItemsSource="{Binding FormatInfo.WebLinks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}"
                                                    Tag="{Binding}"
                                                    Click="ReferenceLink_Click"
                                                    Cursor="Hand"
                                                    Margin="4,1,0,1"
                                                    Padding="0"
                                                    BorderThickness="0"
                                                    Background="Transparent"
                                                    Foreground="{DynamicResource PFP_AccentBrush}"
                                                    FontSize="11"
                                                    HorizontalAlignment="Left"
                                                    HorizontalContentAlignment="Left">
                                                <Button.ContentTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   TextWrapping="Wrap"
                                                                   TextDecorations="Underline"/>
                                                    </DataTemplate>
                                                </Button.ContentTemplate>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <ContentPresenter/>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>

                <TextBlock FontSize="11" Foreground="{DynamicResource PFP_SubTextBrush}" TextWrapping="Wrap"
                           Text="{Binding FormatInfo.Description}"/>

                <!-- Format Navigator bookmarks (C6) — shown when whfmt provides navigation.bookmarks -->
                <ItemsControl Margin="0,6,0,0"
                              ItemsSource="{Binding FormatInfo.Bookmarks}"
                              Visibility="{Binding FormatInfo.HasBookmarks, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,5,3"
                                    Padding="6,2"
                                    Tag="{Binding}"
                                    Click="NavigatorBookmark_Click"
                                    ToolTip="{Binding Description}"
                                    Style="{DynamicResource PFP_NavBookmarkButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="11" Margin="0,0,4,0"
                                               Visibility="{Binding Icon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding Name}" FontSize="10"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- D3 — Forensic Alerts: failed assertions from whfmt assertions[] -->
                <!-- Left-accent border pattern: WF_ForensicAlertBrush = accent color, not background -->
                <Border Margin="0,6,0,0"
                        BorderThickness="3,0,0,0"
                        BorderBrush="{DynamicResource WF_ForensicAlertBrush}"
                        Background="{DynamicResource DockBackgroundBrush}"
                        CornerRadius="0,3,3,0"
                        Padding="8,6"
                        Visibility="{Binding FormatInfo.HasForensicAlerts, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="&#xE7BA;  Forensic Alerts"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WF_ForensicAlertBrush}"
                                   Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding FormatInfo.ForensicAlerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,1">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Width="50"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Text="{Binding Severity}"
                                                   Foreground="{DynamicResource WF_AssertionErrorBrush}"/>
                                        <TextBlock FontSize="10" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                   Text="{Binding Message}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- D4 — Inspector: grouped field accordion from whfmt inspector.groups -->
                <StackPanel Margin="0,6,0,0"
                            Visibility="{Binding FormatInfo.HasInspectorGroups, Converter={StaticResource BoolToVisibilityConverter}}">
                    <!-- Inspector badge -->
                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,0,4"
                            Background="{DynamicResource DockAccentBrush}"
                            HorizontalAlignment="Left"
                            Visibility="{Binding FormatInfo.HasInspectorBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding FormatInfo.InspectorBadge}"
                                   FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                    </Border>
                    <!-- Groups -->
                    <ItemsControl ItemsSource="{Binding FormatInfo.InspectorGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,3"
                                        CornerRadius="3"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource PFP_BorderBrush}">
                                    <StackPanel>
                                        <!-- Group header (click to expand/collapse) -->
                                        <Border Padding="6,3" Background="{DynamicResource WF_InspectorGroupHeaderBrush}"
                                                CornerRadius="3,3,0,0"
                                                Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Icon}" FontSize="11" Margin="0,0,4,0"
                                                           Visibility="{Binding Icon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Fields (shown when expanded) -->
                                        <ItemsControl ItemsSource="{Binding Fields}"
                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="8,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                                   FontSize="10" Opacity="0.7"
                                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayValue}"
                                                                   FontSize="10" FontFamily="Consolas"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="{DynamicResource PFP_AccentBrush}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- D5 — Export templates from whfmt exportTemplates -->
                <StackPanel Margin="0,6,0,0"
                            Visibility="{Binding FormatInfo.HasExportTemplates, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="&#xE78C;  Export As"
                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" Opacity="0.7"/>
                    <ItemsControl ItemsSource="{Binding FormatInfo.ExportTemplates}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,5,3"
                                        Padding="6,2"
                                        Tag="{Binding}"
                                        Click="ExportTemplate_Click"
                                        ToolTip="{Binding Format}"
                                        Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" FontSize="11" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Name}" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- D6 — AI Analysis: from whfmt aiHints -->
                <StackPanel Margin="0,6,0,0"
                            Visibility="{Binding FormatInfo.HasAiHints,
                                         Converter={StaticResource BoolToVisibilityConverter}}">

                    <!-- D6 header -->
                    <Border Padding="6,4"
                            Background="{DynamicResource WF_AiHintSectionHeaderBrush}"
                            CornerRadius="3,3,0,0"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource PFP_BorderBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon + label -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12" Margin="0,0,5,0"
                                           Foreground="{DynamicResource WF_AiHintAccentBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="AI Analysis"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WF_AiHintAccentBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Count badge (visible when collapsed) -->
                            <Border Grid.Column="1"
                                    CornerRadius="8" Padding="5,1" Margin="0,0,4,0"
                                    Background="{DynamicResource WF_AiHintAccentBrush}"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding FormatInfo.IsAiSectionExpanded,
                                                 Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding FormatInfo.AiHintsBadge}"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>

                            <!-- Copy AI Prompt button (visible when expanded) -->
                            <Button Grid.Column="1"
                                    x:Name="CopyAiPromptButton"
                                    Click="CopyAiPromptButton_Click"
                                    ToolTip="Copy ready-to-paste AI analysis prompt to clipboard"
                                    Style="{StaticResource PFP_NavBookmarkButtonStyle}"
                                    Padding="5,1" Margin="0,0,4,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding FormatInfo.IsAiSectionExpanded,
                                                 Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Text="&#xE8C8;" Margin="0,0,3,0"/>
                                    <TextBlock x:Name="CopyAiPromptLabel"
                                               Text="Copy AI Prompt" FontSize="9"/>
                                </StackPanel>
                            </Button>

                            <!-- Chevron toggle -->
                            <Button Grid.Column="2"
                                    Click="AiSectionToggleButton_Click"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="4,0"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource PFP_NavBookmarkButtonStyle}">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Text="{Binding FormatInfo.IsAiSectionExpanded,
                                                  Converter={StaticResource BoolToChevronConverter}}"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- D6 body -->
                    <StackPanel Visibility="{Binding FormatInfo.IsAiSectionExpanded,
                                             Converter={StaticResource BoolToVisibilityConverter}}">

                        <!-- Analysis Context -->
                        <Border Margin="0,0,0,0" Padding="8,5"
                                BorderThickness="1,0,1,0"
                                BorderBrush="{DynamicResource PFP_BorderBrush}"
                                Visibility="{Binding FormatInfo.AiHintsData.HasAnalysisContext,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Analysis Context"
                                           FontSize="9" FontWeight="SemiBold" Margin="0,0,0,3"
                                           Foreground="{DynamicResource WF_AiHintAccentBrush}"
                                           Opacity="0.85"/>
                                <TextBlock Text="{Binding FormatInfo.AiHintsData.AnalysisContext}"
                                           FontSize="10" FontStyle="Italic" TextWrapping="Wrap"
                                           Foreground="{DynamicResource PFP_SubTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Known Vulnerabilities -->
                        <Border Margin="0,1,0,0" Padding="8,5"
                                BorderThickness="1,0,1,0"
                                BorderBrush="{DynamicResource PFP_BorderBrush}"
                                Visibility="{Binding FormatInfo.AiHintsData.HasVulnerabilities,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Known Vulnerabilities"
                                           FontSize="9" FontWeight="SemiBold" Margin="0,0,0,3"
                                           Foreground="{DynamicResource WF_AiHintAccentBrush}"
                                           Opacity="0.85"/>
                                <ItemsControl ItemsSource="{Binding FormatInfo.AiVulnerabilities}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="7,2" Margin="0,0,5,4"
                                                    Background="{DynamicResource WF_AiHintSectionHeaderBrush}"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource WF_AiHintAccentBrush}">
                                                <TextBlock FontSize="10"
                                                           Foreground="{DynamicResource WF_AiHintAccentBrush}">
                                                    <Run Text="{Binding Icon, Mode=OneWay}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Text, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Suggested Inspections (checklist) -->
                        <Border Margin="0,1,0,0" Padding="8,5"
                                BorderThickness="1,0,1,0"
                                BorderBrush="{DynamicResource PFP_BorderBrush}"
                                Visibility="{Binding FormatInfo.AiHintsData.HasInspections,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Suggested Inspections"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WF_AiHintAccentBrush}"
                                               Opacity="0.85" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            x:Name="CopyChecklistButton"
                                            Click="CopyChecklistButton_Click"
                                            ToolTip="Copy unchecked inspections to clipboard"
                                            Style="{StaticResource PFP_NavBookmarkButtonStyle}"
                                            Padding="4,1" FontSize="9">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;"
                                                       FontSize="9" Margin="0,0,3,0"/>
                                            <TextBlock x:Name="CopyChecklistLabel" Text="Copy Checklist"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding FormatInfo.AiInspections}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding Text}"
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Forensic Context -->
                        <Border Margin="0,1,0,0" Padding="8,5"
                                BorderThickness="1,0,1,1"
                                CornerRadius="0,0,3,3"
                                BorderBrush="{DynamicResource PFP_BorderBrush}"
                                Visibility="{Binding FormatInfo.AiHintsData.HasForensicContext,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Forensic Context"
                                           FontSize="9" FontWeight="SemiBold" Margin="0,0,0,3"
                                           Foreground="{DynamicResource WF_AiHintAccentBrush}"
                                           Opacity="0.85"/>
                                <TextBlock Text="{Binding FormatInfo.AiHintsData.ForensicContext}"
                                           FontSize="10" TextWrapping="Wrap" Opacity="0.75"
                                           Foreground="{DynamicResource PFP_SubTextBrush}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Key Insights Strip -->
        <Border x:Name="KeyInsightsSection"
                Grid.Row="3"
                Background="{DynamicResource PFP_InsightSectionBackgroundBrush}"
                Padding="10,6"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource PFP_InsightSectionBorderBrush}"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Key Insights"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PFP_InsightTitleBrush}"
                           Margin="0,0,0,4"/>
                <ItemsControl x:Name="InsightsItemsControl"
                              ItemsSource="{Binding InsightChips}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10"
                                    Padding="8,3"
                                    Margin="0,0,6,4"
                                    Background="{Binding Background}">
                                <TextBlock FontSize="11"
                                           Foreground="{Binding TextForeground}">
                                    <Run Text="{Binding Icon, Mode=OneWay}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Value, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Byte Coverage Bar -->
        <Border x:Name="CoverageBarSection"
                Grid.Row="4"
                Background="{DynamicResource PFP_PanelBackgroundBrush}"
                Padding="10,4"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Height="8">
                    <Border CornerRadius="4" Background="{DynamicResource PFP_CoverageTrackBrush}"/>
                    <ProgressBar x:Name="CoverageProgressBar"
                                 Height="8"
                                 Minimum="0" Maximum="100" Value="0"
                                 Foreground="{DynamicResource PFP_CoverageProgressBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"/>
                </Grid>
                <TextBlock x:Name="CoverageText"
                           Grid.Column="1"
                           FontSize="10"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Text="0% parsed"/>
            </Grid>
        </Border>

        <!-- Hidden backing ListBox — keeps FilteredFields in sync so existing context-menu
             click handlers (FieldsListBox.SelectedItem) continue to work unchanged. (C1) -->
        <ListBox x:Name="FieldsListBox"
                 Grid.Row="5"
                 ItemsSource="{Binding FilteredFields}"
                 ItemTemplate="{StaticResource FieldTemplate}"
                 ItemContainerStyle="{StaticResource FieldItemStyle}"
                 SelectionChanged="FieldsListBox_SelectionChanged"
                 KeyDown="FieldsListBox_KeyDown"
                 Visibility="Collapsed"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Background="{DynamicResource PFP_PanelBackgroundBrush}"
                 BorderThickness="0"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.CacheLength="20,20"
                 VirtualizingPanel.CacheLengthUnit="Item">
            <!-- Group Style preserved for backward compat (panel hidden) -->
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="{x:Type GroupItem}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                        <Expander IsExpanded="{Binding Name, Mode=OneTime,
                                                             Converter={StaticResource GroupNameToExpandedConverter}}"
                                                  BorderThickness="0"
                                                  Margin="0,2,0,0">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="Bold"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource PFP_AccentBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <Border CornerRadius="8"
                                                            Background="{DynamicResource PFP_GroupBadgeBackgroundBrush}"
                                                            Padding="6,1"
                                                            Margin="6,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ItemCount}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource PFP_TextBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                            </Expander.Header>
                                            <ItemsPresenter/>
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit Value..." Click="EditValue_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="✏️" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Toggle Bookmark" Click="ToggleBookmark_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="⭐" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Copy Offset" Click="CopyOffset_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📌" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Jump to Offset..." Click="JumpToOffset_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🔍" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Copy Value">
                        <MenuItem.Icon>
                            <TextBlock Text="📋" FontSize="14"/>
                        </MenuItem.Icon>
                        <MenuItem Header="As Displayed" Click="CopyValue_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📄" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As Hex" Click="CopyValueHex_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="🔢" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As Decimal" Click="CopyValueDecimal_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="🔟" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As Binary" Click="CopyValueBinary_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="01" FontSize="12" FontFamily="Consolas"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                    <MenuItem Header="Copy Details" Click="CopyDetails_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📄" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Find Similar Values..." Click="FindSimilar_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🔍" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Show in Data Inspector" Click="ShowInDataInspector_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🔬" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Export All Fields...">
                        <MenuItem.Icon>
                            <TextBlock Text="💾" FontSize="14"/>
                        </MenuItem.Icon>
                        <MenuItem Header="As Text" Click="ExportAsText_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📄" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As JSON" Click="ExportAsJson_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="{}{}" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As CSV" Click="ExportAsCsv_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📊" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As XML" Click="ExportAsXml_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📋" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As HTML" Click="ExportAsHtml_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="🌐" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="As Markdown" Click="ExportAsMarkdown_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📝" FontSize="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.Style>
                <Style TargetType="ListBox">
                    <Style.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBox">
                                        <Border Background="{DynamicResource PFP_PanelBackgroundBrush}">
                                            <TextBlock Text="No fields parsed yet.&#x0a;Open a file to see its structure."
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     TextAlignment="Center"
                                                     Foreground="{DynamicResource PFP_PlaceholderBrush}"
                                                     FontSize="12"
                                                     Margin="20"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
        </ListBox>

        <!-- ═══════════════════════════════════════════════════════════════════════
             TreeView — hierarchical structure view (C1)
             Group nodes (IsGroup=true) show expandable sections with child count.
             Leaf nodes reuse the existing FieldTemplate via ContentPresenter.
             The hidden ListBox above stays in sync for context-menu handler compat.
             ═══════════════════════════════════════════════════════════════════════ -->
        <TreeView x:Name="FieldsTreeView"
                  Grid.Row="5"
                  ItemsSource="{Binding TreeRootItems}"
                  SelectedItemChanged="FieldsTreeView_SelectedItemChanged"
                  KeyDown="FieldsTreeView_KeyDown"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  Background="{DynamicResource PFP_PanelBackgroundBrush}"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">

            <!-- ── Container style: expand/collapse + selection/hover colors ── -->
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded"  Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="IsSelected"  Value="{Binding IsSelected, Mode=TwoWay}"/>
                    <Setter Property="Padding"     Value="0"/>
                    <Setter Property="Margin"      Value="0,1,0,0"/>
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="Foreground"  Value="{DynamicResource PFP_TextBrush}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <EventSetter Event="MouseDoubleClick" Handler="FieldItem_MouseDoubleClick"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Panel_ItemSelectedForegroundBrush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{DynamicResource Panel_ItemSelectedBrush}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{DynamicResource Panel_ItemHoverBrush}"/>
                        </MultiTrigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>

            <!-- ── HierarchicalDataTemplate: group header OR field leaf ── -->
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding ChildItems}">
                    <Grid>
                        <!-- ── Group node (IsGroup=true) ────────────────────── -->
                        <Border Padding="6,5"
                                Visibility="{Binding IsGroup, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <!-- Color strip -->
                                <Border Width="4" Margin="0,0,8,0"
                                        Background="{Binding Color}"
                                        CornerRadius="2"
                                        VerticalAlignment="Stretch"/>
                                <!-- Icon -->
                                <TextBlock Text="{Binding FieldIcon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           Margin="0,0,5,0"
                                           VerticalAlignment="Center"/>
                                <!-- Group name + entry count -->
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource PFP_AccentBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource Panel_ItemSelectedForegroundBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border CornerRadius="8"
                                        Background="{DynamicResource PFP_GroupBadgeBackgroundBrush}"
                                        Padding="6,1"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PFP_TextBrush}">
                                        <Run Text="{Binding ChildItems.Count, Mode=OneWay, FallbackValue=0}"/>
                                        <Run Text="entries"/>
                                    </TextBlock>
                                </Border>
                                <!-- Validation badge for group (shows if any child has errors) -->
                                <TextBlock Text="&#x26A0;"
                                           FontSize="11"
                                           Margin="6,0,0,0"
                                           Foreground="{DynamicResource WF_AssertionWarningBrush}"
                                           VerticalAlignment="Center"
                                           ToolTip="This group contains fields with validation errors"
                                           Visibility="{Binding IsValid, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Field leaf (IsGroup=false): reuses FieldTemplate ── -->
                        <ContentPresenter
                            ContentTemplate="{StaticResource FieldTemplate}"
                            Content="{Binding}"
                            Visibility="{Binding IsGroup, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    </Grid>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>

            <!-- ── Context menu (mirrors ListBox context menu for tree items) ── -->
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit Value..." Click="EditValue_Click">
                        <MenuItem.Icon><TextBlock Text="&#x270F;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Toggle Bookmark" Click="ToggleBookmark_Click">
                        <MenuItem.Icon><TextBlock Text="&#x2B50;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Copy Offset" Click="CopyOffset_Click">
                        <MenuItem.Icon><TextBlock Text="&#x1F4CC;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Jump to Offset..." Click="JumpToOffset_Click">
                        <MenuItem.Icon><TextBlock Text="&#x1F50D;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Copy Value">
                        <MenuItem.Icon><TextBlock Text="&#x1F4CB;" FontSize="14"/></MenuItem.Icon>
                        <MenuItem Header="As Displayed"  Click="CopyValue_Click"/>
                        <MenuItem Header="As Hex"        Click="CopyValueHex_Click"/>
                        <MenuItem Header="As Decimal"    Click="CopyValueDecimal_Click"/>
                        <MenuItem Header="As Binary"     Click="CopyValueBinary_Click"/>
                        <MenuItem Header="As C# bytes"   Click="CopyValueCSharpBytes_Click"/>
                        <MenuItem Header="As Python bytes" Click="CopyValuePythonBytes_Click"/>
                    </MenuItem>
                    <MenuItem Header="Copy Details" Click="CopyDetails_Click">
                        <MenuItem.Icon><TextBlock Text="&#x1F4C4;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Find Similar Values..." Click="FindSimilar_Click">
                        <MenuItem.Icon><TextBlock Text="&#x1F50D;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Show in Data Inspector" Click="ShowInDataInspector_Click">
                        <MenuItem.Icon><TextBlock Text="&#x1F52C;" FontSize="14"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Expand All Groups"   Click="ExpandAllGroups_Click"/>
                    <MenuItem Header="Collapse All Groups" Click="CollapseAllGroups_Click"/>
                    <Separator/>
                    <MenuItem Header="Export All Fields...">
                        <MenuItem.Icon><TextBlock Text="&#x1F4BE;" FontSize="14"/></MenuItem.Icon>
                        <MenuItem Header="As Text"     Click="ExportAsText_Click"/>
                        <MenuItem Header="As JSON"     Click="ExportAsJson_Click"/>
                        <MenuItem Header="As CSV"      Click="ExportAsCsv_Click"/>
                        <MenuItem Header="As XML"      Click="ExportAsXml_Click"/>
                        <MenuItem Header="As HTML"     Click="ExportAsHtml_Click"/>
                        <MenuItem Header="As Markdown" Click="ExportAsMarkdown_Click"/>
                    </MenuItem>
                </ContextMenu>
            </TreeView.ContextMenu>

            <!-- Empty-state template -->
            <TreeView.Style>
                <Style TargetType="TreeView">
                    <Style.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TreeView">
                                        <Border Background="{DynamicResource PFP_PanelBackgroundBrush}">
                                            <TextBlock Text="No fields parsed yet.&#x0a;Open a file to see its structure."
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Foreground="{DynamicResource PFP_PlaceholderBrush}"
                                                       FontSize="12"
                                                       Margin="20"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.Style>
        </TreeView>

        <!-- Status bar -->
        <Border Grid.Row="6"
                Background="{DynamicResource PFP_SectionBackgroundBrush}"
                Padding="12,6"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource PFP_BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           FontSize="11"
                           Foreground="{DynamicResource PFP_SubTextBrush}">
                    <Run Text="{Binding FilteredFields.Count, Mode=OneWay}"/>
                    <Run Text="/"/>
                    <Run Text="{Binding ParsedFields.Count, Mode=OneWay}"/>
                    <Run Text="field(s)"/>
                    <Run Text="{Binding SearchResultText, Mode=OneWay}" Foreground="#4CAF50" FontWeight="SemiBold"/>
                </TextBlock>

                <ComboBox x:Name="SortComboBox"
                          Grid.Column="1"
                          Width="110"
                          FontSize="10"
                          Margin="0,0,8,0"
                          SelectedIndex="0"
                          SelectionChanged="SortComboBox_SelectionChanged"
                          ToolTip="Sort fields">
                    <ComboBoxItem Content="Sort: Offset"/>
                    <ComboBoxItem Content="Sort: Name A-Z"/>
                    <ComboBoxItem Content="Sort: Name Z-A"/>
                    <ComboBoxItem Content="Sort: Type"/>
                    <ComboBoxItem Content="Sort: Size"/>
                </ComboBox>

                <ComboBox x:Name="FormatterComboBox"
                          Grid.Column="2"
                          Width="120"
                          FontSize="11"
                          SelectionChanged="FormatterComboBox_SelectionChanged"
                          ToolTip="Choose value display format">
                    <ComboBoxItem Content="Mixed (Smart)" Tag="mixed" IsSelected="True"/>
                    <ComboBoxItem Content="Hexadecimal" Tag="hex"/>
                    <ComboBoxItem Content="Decimal" Tag="decimal"/>
                    <ComboBoxItem Content="String" Tag="string"/>
                </ComboBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>

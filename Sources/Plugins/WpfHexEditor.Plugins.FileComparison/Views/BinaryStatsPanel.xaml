<UserControl x:Class="WpfHexEditor.Plugins.FileComparison.Views.BinaryStatsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pb="clr-namespace:WpfHexEditor.ProgressBar.Controls;assembly=WpfHexEditor.ProgressBar"
             xmlns:pbc="clr-namespace:WpfHexEditor.ProgressBar.Converters;assembly=WpfHexEditor.ProgressBar"
             xmlns:conv="clr-namespace:WpfHexEditor.Plugins.FileComparison.Converters"
             xmlns:filecompSvc="clr-namespace:WpfHexEditor.Plugins.FileComparison.Services">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <filecompSvc:FileComparisonLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12,8" MinWidth="220">

            <!-- ── Section 1: File info cards ── -->
            <TextBlock Text="{StaticResource FileComparison_FilesSection}" FontSize="9" FontWeight="SemiBold" Opacity="0.5"
                       Margin="0,0,0,4" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left file card -->
                <Border Grid.Column="0"
                        Background="{DynamicResource DF_HeaderBackgroundBrush}"
                        BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="8,6">
                    <StackPanel>
                        <TextBlock Text="{Binding LeftFileName}" FontSize="11" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        <TextBlock Text="{Binding LeftFileSizeText}" FontSize="10" Opacity="0.6" Margin="0,2,0,0"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        <TextBlock Text="{Binding AvgEntropyLeftText}" FontSize="10" Opacity="0.6" Margin="0,1,0,0"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        <Border Background="{DynamicResource DockAccentBrush}"
                                CornerRadius="3" Padding="4,1" Margin="0,3,0,0"
                                HorizontalAlignment="Left"
                                Visibility="{Binding HasLeftFormatBadge, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding LeftFormatBadge}" Foreground="White" FontSize="9"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Right file card -->
                <Border Grid.Column="2"
                        Background="{DynamicResource DF_HeaderBackgroundBrush}"
                        BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="8,6">
                    <StackPanel>
                        <TextBlock Text="{Binding RightFileName}" FontSize="11" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        <TextBlock Text="{Binding RightFileSizeText}" FontSize="10" Opacity="0.6" Margin="0,2,0,0"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        <TextBlock Text="{Binding AvgEntropyRightText}" FontSize="10" Opacity="0.6" Margin="0,1,0,0"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        <Border Background="{DynamicResource DockAccentBrush}"
                                CornerRadius="3" Padding="4,1" Margin="0,3,0,0"
                                HorizontalAlignment="Left"
                                Visibility="{Binding HasRightFormatBadge, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding RightFormatBadge}" Foreground="White" FontSize="9"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Section 2: Diff summary ── -->
            <TextBlock Text="{StaticResource FileComparison_DiffSummary}" FontSize="9" FontWeight="SemiBold" Opacity="0.5"
                       Margin="0,0,0,4" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <StackPanel Margin="0,0,0,12">
                <!-- Modified -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{StaticResource FileComparison_ModifiedLabel}" FontSize="10"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" VerticalAlignment="Center"/>
                    <pb:LinearProgressBar Grid.Column="1" Progress="{Binding ModifiedPercent, Mode=OneWay, Converter={x:Static pbc:ValueToProgressConverter.Instance}, ConverterParameter=100}"
                                          Height="6" BarHeight="6" VerticalAlignment="Center"
                                          ProgressBrush="{DynamicResource DF_ModifiedLineBrush}"/>
                    <TextBlock Grid.Column="2" Text="{Binding ModifiedPercent, StringFormat='{}{0:F1}%'}"
                               FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                </Grid>
                <!-- Inserted -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{StaticResource FileComparison_InsertedLabel}" FontSize="10"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" VerticalAlignment="Center"/>
                    <pb:LinearProgressBar Grid.Column="1" Progress="{Binding InsertedPercent, Mode=OneWay, Converter={x:Static pbc:ValueToProgressConverter.Instance}, ConverterParameter=100}"
                                          Height="6" BarHeight="6" VerticalAlignment="Center"
                                          ProgressBrush="{DynamicResource DF_InsertedLineBrush}"/>
                    <TextBlock Grid.Column="2" Text="{Binding InsertedPercent, StringFormat='{}{0:F1}%'}"
                               FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                </Grid>
                <!-- Deleted -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{StaticResource FileComparison_DeletedLabel}" FontSize="10"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" VerticalAlignment="Center"/>
                    <pb:LinearProgressBar Grid.Column="1" Progress="{Binding DeletedPercent, Mode=OneWay, Converter={x:Static pbc:ValueToProgressConverter.Instance}, ConverterParameter=100}"
                                          Height="6" BarHeight="6" VerticalAlignment="Center"
                                          ProgressBrush="{DynamicResource DF_DeletedLineBrush}"/>
                    <TextBlock Grid.Column="2" Text="{Binding DeletedPercent, StringFormat='{}{0:F1}%'}"
                               FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                </Grid>
            </StackPanel>

            <!-- ── Section 3: Byte frequency histogram ── -->
            <TextBlock Text="{StaticResource FileComparison_ByteFrequency}" FontSize="9" FontWeight="SemiBold" Opacity="0.5"
                       Margin="0,0,0,4" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <Canvas x:Name="HistogramCanvas" Height="80" Margin="0,0,0,4"
                    SizeChanged="OnHistogramSizeChanged"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Rectangle Width="10" Height="10" Fill="{DynamicResource DF_InsertedLineBrush}" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding LeftFileName, StringFormat='Left ({0})'}" FontSize="9"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Rectangle Width="10" Height="10" Fill="{DynamicResource DF_DeletedLineBrush}" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding RightFileName, StringFormat='Right ({0})'}" FontSize="9"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>

            <!-- ── Section 4: Shannon entropy chart ── -->
            <TextBlock Text="{StaticResource FileComparison_ShannonEntropy}" FontSize="9" FontWeight="SemiBold"
                       Opacity="0.5" Margin="0,0,0,4"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <Canvas x:Name="EntropyCanvas" Height="60" Margin="0,0,0,4"
                    SizeChanged="OnEntropySizeChanged"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding AvgEntropyLeftText}" FontSize="9" Opacity="0.6"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding AvgEntropyRightText}" FontSize="9" Opacity="0.6"
                           HorizontalAlignment="Right"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>

</UserControl>

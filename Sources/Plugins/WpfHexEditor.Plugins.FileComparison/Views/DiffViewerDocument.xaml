<UserControl x:Class="WpfHexEditor.Plugins.FileComparison.Views.DiffViewerDocument"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.FileComparison.ViewModels"
             xmlns:views="clr-namespace:WpfHexEditor.Plugins.FileComparison.Views"
             xmlns:ctrl="clr-namespace:WpfHexEditor.Plugins.FileComparison.Views.Controls"
             xmlns:conv="clr-namespace:WpfHexEditor.Plugins.FileComparison.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter    x:Key="BoolToVis"/>
        <conv:NotBoolToVisibilityConverter x:Key="NotBoolToVis"/>
        <conv:KindToBrushConverter         x:Key="KindToBrush"/>
        <conv:BinaryByteKindToBrushConverter  x:Key="ByteKindToBrush"/>
        <conv:AsciiPrintableToColorConverter  x:Key="AsciiColorConv"/>
    </UserControl.Resources>

    <Grid x:Name="OuterGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="240" MinWidth="180" MaxWidth="400"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>   <!-- F4 mismatch banner -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0: Stats toolbar ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource DockTabBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="8,3">

                <!-- Left: navigation + view toggle + binary context combo -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{DynamicResource XD_ToolbarIconButtonStyle}"
                            Width="Auto" Padding="6,2" Margin="0,0,2,0"
                            Command="{Binding PrevDiffCommand}"
                            ToolTip="Previous difference (Alt+Up)">
                        <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                    </Button>
                    <Button Style="{DynamicResource XD_ToolbarIconButtonStyle}"
                            Width="Auto" Padding="6,2" Margin="0,0,6,0"
                            Command="{Binding NextDiffCommand}"
                            ToolTip="Next difference (Alt+Down)">
                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                    </Button>
                    <TextBlock Text="{Binding DiffBlockCount, StringFormat='{}0/{0}'}"
                               FontSize="11" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Separator Width="1" Height="16"
                               Background="{DynamicResource DockBorderBrush}" Margin="0,0,8,0"/>
                    <!-- Text mode: Side by side toggle -->
                    <ToggleButton Style="{DynamicResource XD_ToolbarToggleButtonStyle}"
                                  Width="Auto" Padding="6,2"
                                  IsChecked="{Binding IsSideBySide}"
                                  Visibility="{Binding IsBinaryMode, Converter={StaticResource NotBoolToVis}}"
                                  ToolTip="Side by side / Unified">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock Text="Side by side" FontSize="11" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </ToggleButton>
                    <!-- Text mode: Ignore whitespace toggle -->
                    <ToggleButton Style="{DynamicResource XD_ToolbarToggleButtonStyle}"
                                  Width="Auto" Padding="6,2" Margin="4,0,0,0"
                                  IsChecked="{Binding IgnoreWhitespace}"
                                  Visibility="{Binding IsBinaryMode, Converter={StaticResource NotBoolToVis}}"
                                  ToolTip="Ignore leading/trailing whitespace when comparing lines">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock Text="Ignore WS" FontSize="11" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </ToggleButton>
                    <!-- Binary mode: Context lines selector -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsBinaryMode, Converter={StaticResource BoolToVis}}"
                                VerticalAlignment="Center">
                        <TextBlock Text="Context:" FontSize="11" Opacity="0.7"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="ContextLinesCombo"
                                  FontSize="11" Width="56"
                                  SelectionChanged="OnContextLinesChanged">
                            <ComboBoxItem Tag="0"  Content="0 lines"/>
                            <ComboBoxItem Tag="3"  Content="3 lines" IsSelected="True"/>
                            <ComboBoxItem Tag="8"  Content="8 lines"/>
                            <ComboBoxItem Tag="-1" Content="All"/>
                        </ComboBox>
                        <Button Style="{DynamicResource XD_ToolbarIconButtonStyle}"
                                Width="Auto" Padding="6,2" Margin="4,0,0,0"
                                x:Name="CopyHexButton"
                                Click="OnCopyHexClicked"
                                ToolTip="Copy hex dump to clipboard">
                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                        </Button>
                        <Separator Width="1" Height="16"
                                   Background="{DynamicResource DockBorderBrush}" Margin="6,0"/>
                        <!-- Block-aligned algorithm toggle -->
                        <ToggleButton Style="{DynamicResource XD_ToolbarToggleButtonStyle}"
                                      Width="Auto" Padding="6,2"
                                      IsChecked="{Binding UseBlockAlignment}"
                                      ToolTip="Block-aligned diff: detects true byte insertions/deletions (slower)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="Block-aligned" FontSize="11" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>

                <!-- Right: stats pills -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border Background="{DynamicResource DF_ModifiedLineBrush}"
                            CornerRadius="3" Padding="6,1" Margin="2,0">
                        <TextBlock FontSize="11">
                            <Run Text="&#x2260; "/><Run Text="{Binding ModifiedCount, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>
                    <Border Background="{DynamicResource DF_InsertedLineBrush}"
                            CornerRadius="3" Padding="6,1" Margin="2,0">
                        <TextBlock FontSize="11">
                            <Run Text="+ "/><Run Text="{Binding AddedCount, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>
                    <Border Background="{DynamicResource DF_DeletedLineBrush}"
                            CornerRadius="3" Padding="6,1" Margin="2,0">
                        <TextBlock FontSize="11">
                            <Run Text="&#x2212; "/><Run Text="{Binding RemovedCount, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="{Binding SimilarityText}"
                               FontSize="11" Opacity="0.6"
                               VerticalAlignment="Center" Margin="6,0,4,0"/>
                    <Border Background="{DynamicResource DockAccentBrush}"
                            CornerRadius="3" Padding="5,1" Margin="2,0,0,0">
                        <TextBlock Text="{Binding EffectiveModeText}"
                                   Foreground="White" FontSize="9"/>
                    </Border>
                </StackPanel>

                <!-- Stats panel toggle -->
                <Button Style="{DynamicResource XD_ToolbarIconButtonStyle}"
                        Width="Auto" Padding="6,2"
                        Command="{Binding ToggleStatsCommand}"
                        ToolTip="Show/hide entropy and frequency stats"
                        Visibility="{Binding IsBinaryMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                </Button>

                <!-- F3 — Format overlay toggle -->
                <ToggleButton Style="{DynamicResource XD_ToolbarToggleButtonStyle}"
                              Width="Auto" Padding="6,2"
                              IsChecked="{Binding ShowFormatOverlay, Mode=TwoWay}"
                              ToolTip="Toggle whfmt format-field color overlay"
                              Visibility="{Binding IsBinaryMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                </ToggleButton>

                <!-- F2 — Structure Diff tab toggle -->
                <ToggleButton Style="{DynamicResource XD_ToolbarToggleButtonStyle}"
                              Width="Auto" Padding="6,2"
                              IsChecked="{Binding IsStructureDiffMode, Mode=TwoWay}"
                              Command="{Binding ToggleStructureDiffCommand}"
                              ToolTip="Show field-level structure diff (requires same format on both sides)"
                              Visibility="{Binding HasStructureDiff, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="11" Margin="0,0,4,0"/>
                        <TextBlock Text="Structure" FontSize="11" FontFamily="Segoe UI"/>
                    </StackPanel>
                </ToggleButton>

                <Grid/>
            </DockPanel>
        </Border>

        <!-- ── Row 1: F4 — Format mismatch warning banner ── -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="#FFD700" Padding="8,4"
                Visibility="{Binding IsFormatMismatch, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding FormatMismatchMessage}"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="#4A3700"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ── Row 2: File headers ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="{DynamicResource DF_HeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="0,0,0,1"
                    Padding="8,4">
                <DockPanel>
                    <Border DockPanel.Dock="Right"
                            Background="{DynamicResource DockAccentBrush}"
                            CornerRadius="3" Padding="5,1" Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasLeftFormat, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding LeftFormatBadge}" Foreground="White" FontSize="9"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="{Binding LeftFileName}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        <TextBlock Text="{Binding LeftPath}" FontSize="10" Opacity="0.6"
                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding LeftPath}"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </StackPanel>
                </DockPanel>
            </Border>
            <Border Grid.Column="2"
                    Background="{DynamicResource DF_HeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="0,0,0,1"
                    Padding="8,4">
                <DockPanel>
                    <Border DockPanel.Dock="Right"
                            Background="{DynamicResource DockAccentBrush}"
                            CornerRadius="3" Padding="5,1" Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasRightFormat, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding RightFormatBadge}" Foreground="White" FontSize="9"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="{Binding RightFileName}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        <TextBlock Text="{Binding RightPath}" FontSize="10" Opacity="0.6"
                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding RightPath}"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ── Row 3: Content area (text panes OR binary hex list) ── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
            </Grid.ColumnDefinitions>

            <!-- ── Text diff canvas (single element replaces dual ItemsControls) ── -->
            <ScrollViewer x:Name="TextDiffScroll"
                          Grid.Column="0" Grid.ColumnSpan="3"
                          ScrollChanged="OnTextDiffScrollChanged"
                          CanContentScroll="True"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsBinaryMode, Converter={StaticResource NotBoolToVis}}">
                <ctrl:TextDiffCanvas x:Name="TextDiffCanvas"
                                      LeftRows="{Binding LeftRows}"
                                      RightRows="{Binding RightRows}"
                                      ZoomLevel="{Binding ZoomLevel, Mode=TwoWay}"
                                      HexFontFamily="{Binding HexFontFamily}"
                                      HexFontSize="{Binding HexFontSize}"
                                      Focusable="True"/>
            </ScrollViewer>

            <!-- ── Binary hex dump pane (Grid.Column spans 0-2, hidden in text mode) ── -->
            <!-- CanContentScroll="True" routes scroll events to BinaryDiffCanvas.IScrollInfo -->
            <ScrollViewer x:Name="BinaryHexScroll"
                          Grid.Column="0" Grid.ColumnSpan="3"
                          ScrollChanged="OnBinaryHexScrollChanged"
                          CanContentScroll="True"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsBinaryMode, Converter={StaticResource BoolToVis}}">
                <ctrl:BinaryDiffCanvas x:Name="BinaryDiffCanvas"
                                       Rows="{Binding BinaryHexRows}"
                                       ZoomLevel="{Binding ZoomLevel, Mode=TwoWay}"
                                       FormatBlocksLeft="{Binding ActiveLeftFormatBlocks}"
                                       FormatBlocksRight="{Binding ActiveRightFormatBlocks}"
                                       HexFontFamily="{Binding HexFontFamily}"
                                       HexFontSize="{Binding HexFontSize}"
                                       Focusable="True"/>
            </ScrollViewer>

            <!-- Loading overlay — shown while background row-build is running -->
            <Border Grid.Column="0" Grid.ColumnSpan="3"
                    Background="{DynamicResource DockTabBackgroundBrush}"
                    Opacity="0.75"
                    IsHitTestVisible="False"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Building hex rows…" FontSize="13"
                               FontFamily="Segoe UI"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ── F2 Structure Diff canvas (spans columns 0-2, shown when IsStructureDiffMode) ── -->
            <ScrollViewer Grid.Column="0" Grid.ColumnSpan="3"
                          CanContentScroll="True"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsStructureDiffMode, Converter={StaticResource BoolToVis}}">
                <ctrl:StructureDiffCanvas x:Name="StructureDiffCanvas"
                                           Rows="{Binding StructureDiffRows}"
                                           LeftFileName="{Binding LeftFileName}"
                                           RightFileName="{Binding RightFileName}"
                                           ZoomLevel="{Binding ZoomLevel, Mode=TwoWay}"
                                           HexFontFamily="{Binding HexFontFamily}"
                                           HexFontSize="{Binding HexFontSize}"
                                           Focusable="True"/>
            </ScrollViewer>

            <!-- Overview ruler -->
            <Canvas x:Name="OverviewRuler" Grid.Column="3"
                    Background="{DynamicResource DF_OverviewRulerBackgroundBrush}"
                    MouseLeftButtonDown="OnRulerClicked"
                    MouseMove="OnRulerDragged"
                    MouseLeftButtonUp="OnRulerReleased"
                    Cursor="Hand"
                    SizeChanged="OnRulerSizeChanged"/>
        </Grid>

        <!-- ── Row 4: Status bar ── -->
        <Border Grid.Row="4"
                Background="{DynamicResource DockStatusBarBackgroundBrush}"
                BorderBrush="{DynamicResource DockSplitterBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBar" Padding="8,2" FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
        </Border>

        <!-- ── Stats panel drawer (Column 1, spans all rows) ── -->
        <GridSplitter Grid.Column="1" Grid.RowSpan="5"
                      Width="4" HorizontalAlignment="Left"
                      Background="{DynamicResource DockSplitterBrush}"
                      ResizeBehavior="PreviousAndCurrent"
                      Visibility="{Binding StatsPanel.IsVisible, Converter={StaticResource BoolToVis}}"/>
        <Border Grid.Column="1" Grid.RowSpan="5"
                HorizontalAlignment="Stretch"
                Background="{DynamicResource DockTabBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1,0,0,0"
                Margin="4,0,0,0"
                Visibility="{Binding StatsPanel.IsVisible, Converter={StaticResource BoolToVis}}">
            <views:BinaryStatsPanel DataContext="{Binding StatsPanel}"/>
        </Border>

    </Grid>
</UserControl>

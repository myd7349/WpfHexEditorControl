<UserControl x:Class="WpfHexEditor.Plugins.FileComparison.Views.DiffHubPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.FileComparison.ViewModels"
             xmlns:conv="clr-namespace:WpfHexEditor.Plugins.FileComparison.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:KindToGlyphConverter      x:Key="KindToGlyph"/>

        <!-- History row style -->
        <Style x:Key="HistoryRowStyle" TargetType="ListViewItem">
            <Setter Property="Padding"  Value="6,3,6,3"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Toolbar   -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: File inputs -->
            <RowDefinition Height="*"/>     <!-- Row 2: History   -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Toolbar ── -->
        <ToolBar Grid.Row="0" ToolBarTray.IsLocked="True" Band="0" BandIndex="0"
                 Background="{DynamicResource DockTabBackgroundBrush}">

            <Button Command="{Binding SwapCommand}"
                    ToolTip="Swap files" Padding="6,2,6,2">
                <TextBlock Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
            </Button>

            <Separator/>

            <Button Command="{Binding CompareCommand}"
                    Padding="8,2,8,2" ToolTip="Run comparison (Ctrl+Enter)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                               FontSize="12" Margin="0,0,4,0"/>
                    <TextBlock Text="Compare"/>
                </StackPanel>
            </Button>

            <Separator/>

            <Button Command="{Binding ClearCommand}"
                    ToolTip="Clear inputs" Padding="6,2,6,2">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
            </Button>

            <!-- Busy indicator -->
            <ProgressBar IsIndeterminate="True" Width="60" Height="3" Margin="4,0"
                         Visibility="{Binding IsComparing, Converter={StaticResource BoolToVis}}"/>
        </ToolBar>

        <!-- ── Row 1: File path inputs ── -->
        <Grid Grid.Row="1" Margin="6,4,6,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- File 1 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="File 1 (Left)" FontSize="10" Opacity="0.7" Margin="0,0,0,2"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding File1Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="24" FontSize="11" Padding="4,2"
                             AllowDrop="True" Drop="OnFile1Drop" DragOver="OnDragOver"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Style="{DynamicResource XD_ToolbarIconButtonStyle}"
                            Width="26" Height="24" Margin="2,0,0,0"
                            Click="OnBrowseFile1_Click" ToolTip="Browse…">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                    </Button>
                </Grid>
            </Grid>

            <!-- Swap indicator -->
            <TextBlock Grid.Column="1" Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets"
                       FontSize="14" Margin="6,12,6,0" VerticalAlignment="Center" Opacity="0.4"/>

            <!-- File 2 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="File 2 (Right)" FontSize="10" Opacity="0.7" Margin="0,0,0,2"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding File2Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="24" FontSize="11" Padding="4,2"
                             AllowDrop="True" Drop="OnFile2Drop" DragOver="OnDragOver"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Style="{DynamicResource XD_ToolbarIconButtonStyle}"
                            Width="26" Height="24" Margin="2,0,0,0"
                            Click="OnBrowseFile2_Click" ToolTip="Browse…">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <!-- ── Row 2: History list ── -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Section header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource DockTabBackgroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="0,1,0,1"
                    Padding="6,2">
                <TextBlock Text="Recent Comparisons"
                           FontSize="10" FontWeight="SemiBold" Opacity="0.7"/>
            </Border>

            <ListView x:Name="HistoryList" Grid.Row="1"
                      ItemsSource="{Binding History}"
                      ItemContainerStyle="{StaticResource HistoryRowStyle}"
                      MouseDoubleClick="OnHistoryDoubleClick"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Left" Width="140">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LeftFileName}"
                                               FontSize="11"
                                               ToolTip="{Binding LeftPath}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Right" Width="140">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RightFileName}"
                                               FontSize="11"
                                               ToolTip="{Binding RightPath}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Mode" Width="56"
                                        DisplayMemberBinding="{Binding Mode}"/>
                        <GridViewColumn Header="Last Used" Width="110"
                                        DisplayMemberBinding="{Binding LastUsed, StringFormat='{}{0:MM-dd HH:mm}'}"/>
                    </GridView>
                </ListView.View>

                <!-- Empty state -->
                <ListView.Style>
                    <Style TargetType="ListView">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding History.Count}" Value="0">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <Border Padding="16">
                                                <TextBlock Text="No recent comparisons.&#xA;Compare two files to build history."
                                                           TextAlignment="Center" Opacity="0.4"
                                                           FontSize="11" TextWrapping="Wrap"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>
            </ListView>
        </Grid>

    </Grid>
</UserControl>

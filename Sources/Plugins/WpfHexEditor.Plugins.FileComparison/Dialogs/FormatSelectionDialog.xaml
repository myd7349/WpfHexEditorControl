<ec:ThemedDialog x:Class="WpfHexEditor.Plugins.FileComparison.Dialogs.FormatSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pb="clr-namespace:WpfHexEditor.ProgressBar.Controls;assembly=WpfHexEditor.ProgressBar"
        xmlns:pbc="clr-namespace:WpfHexEditor.ProgressBar.Converters;assembly=WpfHexEditor.ProgressBar"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:WpfHexEditor.Plugins.FileComparison.Converters"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        xmlns:fcSvc="clr-namespace:WpfHexEditor.Plugins.FileComparison.Services"
        mc:Ignorable="d"
        Title="{DynamicResource FileComparison_FormatSelectionTitle}"
        Height="500" Width="650"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <ec:ThemedDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <fcSvc:FileComparisonLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <conv:ConfidenceToPercentageConverter x:Key="ConfidenceConverter"/>
            <conv:NullToBooleanConverter x:Key="NullToBoolConverter"/>
        </ResourceDictionary>
    </ec:ThemedDialog.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="{StaticResource FileComparison_MultipleFormatsHeader}"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBlock x:Name="MessageText"
                       Text="{StaticResource FileComparison_MultipleFormatsMessage}"
                       TextWrapping="Wrap"
                       Margin="0,5,0,0"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
        </StackPanel>

        <!-- Info Panel -->
        <Border Grid.Row="1"
                Background="{DynamicResource DockBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{StaticResource FileComparison_ConfidenceTip}"
                           FontSize="12"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <TextBlock Text="{StaticResource FileComparison_SelectFormatInfo}"
                           FontSize="12"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Candidates List -->
        <ListView x:Name="CandidatesListView"
                  Grid.Row="2"
                  SelectionMode="Single"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  BorderBrush="{DynamicResource DockBorderBrush}"
                  BorderThickness="1"
                  Background="{DynamicResource DockBackgroundBrush}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{DynamicResource DockBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10"
                            Background="Transparent">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SE_SelectedBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Format Name + Category -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="{Binding Format.FormatName}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                <TextBlock Text="{Binding Format.Category}"
                                           FontSize="12"
                                           Foreground="{DynamicResource PFP_SubTextBrush}"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Confidence Bar -->
                            <Grid Grid.Row="1" Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <pb:LinearProgressBar Grid.Column="0"
                                             Progress="{Binding ConfidenceScore, Converter={StaticResource ConfidenceConverter}, ConverterParameter=100}"
                                             Height="20" BarHeight="20"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ConfidenceScore, StringFormat={}{0:P0}}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                            </Grid>

                            <!-- Tier + Block Count -->
                            <TextBlock Grid.Row="2"
                                       Margin="0,5,0,0"
                                       FontSize="11"
                                       Foreground="{DynamicResource PFP_SubTextBrush}">
                                <Run Text="{StaticResource FileComparison_TierLabel}"/>
                                <Run Text="{Binding Tier}" FontWeight="SemiBold"/>
                                <Run Text=" • "/>
                                <Run Text="{Binding Blocks.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text="{StaticResource FileComparison_BlocksParsed}"/>
                            </TextBlock>

                            <!-- Confidence Factors -->
                            <ItemsControl Grid.Row="3"
                                          ItemsSource="{Binding ConfidenceFactors}"
                                          Margin="0,5,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                                   Margin="15,1,0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="SelectButton"
                    Content="{StaticResource FileComparison_SelectFormatButton}"
                    Width="120"
                    Height="30"
                    Margin="0,0,10,0"
                    IsDefault="True"
                    IsEnabled="{Binding SelectedItem, ElementName=CandidatesListView, Converter={StaticResource NullToBoolConverter}}"
                    Click="SelectButton_Click"/>
            <Button x:Name="CancelButton"
                    Content="{StaticResource FileComparison_CancelButton}"
                    Width="100"
                    Height="30"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</ec:ThemedDialog>

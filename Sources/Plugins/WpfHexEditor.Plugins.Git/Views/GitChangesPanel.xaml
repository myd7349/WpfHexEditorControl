<UserControl
    x:Class="WpfHexEditor.Plugins.Git.Views.GitChangesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:WpfHexEditor.Plugins.Git.ViewModels"
    Background="{DynamicResource DockBackgroundBrush}"
    Foreground="{DynamicResource DockMenuForegroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Section header style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding"    Value="6,4,4,2" />
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Opacity"    Value="0.7" />
        </Style>

        <!-- Change row template -->
        <DataTemplate DataType="{x:Type vm:GitChangeRow}">
            <Grid Margin="6,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding FileName}" ToolTip="{Binding FilePath}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <TextBlock Grid.Column="1" Text="{Binding KindLabel}"
                           FontSize="10" Opacity="0.5" Margin="4,0,0,0" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Toolbar -->
            <RowDefinition Height="Auto" />  <!-- Status -->
            <RowDefinition Height="*"    />  <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Background="Transparent" BorderThickness="0">
            <Button ToolTip="Refresh"
                    Command="{Binding RefreshCommand}"
                    Style="{DynamicResource DockDarkToolBarButtonStyle}">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" />
            </Button>
            <Separator />
            <Button ToolTip="Stage All"
                    Command="{Binding StageAllCommand}"
                    Style="{DynamicResource DockDarkToolBarButtonStyle}">
                <TextBlock Text="+" FontWeight="Bold" FontSize="13" />
            </Button>
            <Button ToolTip="Unstage All"
                    Command="{Binding UnstageAllCommand}"
                    Style="{DynamicResource DockDarkToolBarButtonStyle}">
                <TextBlock Text="&#x2212;" FontSize="13" />
            </Button>
            <Button ToolTip="Discard All Changes"
                    Command="{Binding DiscardAllCommand}"
                    Style="{DynamicResource DockDarkToolBarButtonStyle}">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
            </Button>
        </ToolBar>

        <!-- Status text -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource DockBorderBrush}" Padding="6,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets"
                           FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <ProgressBar IsIndeterminate="True" Width="60" Height="4" Margin="8,0,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Border>

        <!-- Scrollable change groups -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Staged -->
                <StackPanel Visibility="{Binding StagedFiles.Count, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="STAGED CHANGES" />
                    <ItemsControl ItemsSource="{Binding StagedFiles}" />
                </StackPanel>

                <!-- Modified -->
                <StackPanel Visibility="{Binding ModifiedFiles.Count, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="CHANGES" />
                    <ItemsControl ItemsSource="{Binding ModifiedFiles}" />
                </StackPanel>

                <!-- Untracked -->
                <StackPanel Visibility="{Binding UntrackedFiles.Count, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="UNTRACKED FILES" />
                    <ItemsControl ItemsSource="{Binding UntrackedFiles}" />
                </StackPanel>

                <!-- Empty state -->
                <TextBlock Text="No changes detected."
                           HorizontalAlignment="Center" Margin="0,20"
                           Opacity="0.45"
                           Foreground="{DynamicResource DockMenuForegroundBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding StagedFiles.Count}"    Value="0" />
                                        <Condition Binding="{Binding ModifiedFiles.Count}"  Value="0" />
                                        <Condition Binding="{Binding UntrackedFiles.Count}" Value="0" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

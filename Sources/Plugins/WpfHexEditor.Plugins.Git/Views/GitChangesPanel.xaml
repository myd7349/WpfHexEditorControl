<UserControl
    x:Class="WpfHexEditor.Plugins.Git.Views.GitChangesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pb="clr-namespace:WpfHexEditor.ProgressBar.Controls;assembly=WpfHexEditor.ProgressBar"
    xmlns:vm="clr-namespace:WpfHexEditor.Plugins.Git.ViewModels"
    Background="{DynamicResource DockBackgroundBrush}"
    Foreground="{DynamicResource DockMenuForegroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Dark TextBox — DockDarkTextBoxStyle does not exist in docking themes;
             define inline so the commit message area follows the panel theme. -->
        <Style x:Key="GC_CommitTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"   Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="CaretBrush"   Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource GC_CommitButtonBackground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Auto"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource GC_CommitButtonBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Commit button — default WPF Button template ignores Background DP on Aero2;
             define a themed template that respects it. -->
        <Style x:Key="GC_CommitButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="{DynamicResource GC_CommitButtonBackground}"/>
            <Setter Property="Foreground"   Value="{DynamicResource GC_CommitButtonForeground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="14,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding"    Value="6,5,4,2" />
            <Setter Property="Foreground" Value="{DynamicResource GC_SectionHeaderForeground}" />
        </Style>

        <!-- File change row template -->
        <DataTemplate DataType="{x:Type vm:GitChangeRow}">
            <Grid Margin="6,1" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding FileName}" ToolTip="{Binding FilePath}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <TextBlock Grid.Column="1" Text="{Binding KindLabel}" FontSize="10"
                           Opacity="0.55" Margin="6,0,0,0" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="Added">
                                    <Setter Property="Foreground" Value="{DynamicResource GC_AddedForeground}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind}" Value="Modified">
                                    <Setter Property="Foreground" Value="{DynamicResource GC_ModifiedForeground}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind}" Value="Deleted">
                                    <Setter Property="Foreground" Value="{DynamicResource GC_DeletedForeground}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind}" Value="Staged">
                                    <Setter Property="Foreground" Value="{DynamicResource GC_StagedForeground}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind}" Value="Untracked">
                                    <Setter Property="Foreground" Value="{DynamicResource GC_UntrackedForeground}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind}" Value="Conflicted">
                                    <Setter Property="Foreground" Value="{DynamicResource GC_ConflictForeground}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Grid.Column="2" ToolTip="Stage"
                        Command="{Binding DataContext.StageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}" Padding="4,0" Margin="2,0,0,0">
                    <TextBlock Text="+" FontSize="11"/>
                </Button>
                <Button Grid.Column="3" ToolTip="Discard"
                        Command="{Binding DataContext.DiscardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}" Padding="4,0">
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                </Button>
            </Grid>
        </DataTemplate>

        <!-- Stash entry row template -->
        <DataTemplate DataType="{x:Type vm:StashEntryRow}">
            <Grid Margin="6,1" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Message}" Foreground="{DynamicResource GC_StashForeground}"
                               FontSize="12" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding DateText}" FontSize="10" Opacity="0.5"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" />
                </StackPanel>
                <Button Grid.Column="1" Content="Pop"
                        Command="{Binding DataContext.StashPopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}" Padding="6,0" Margin="2,0,0,0"
                        FontSize="11"/>
                <Button Grid.Column="2" Content="Drop"
                        Command="{Binding DataContext.StashDropCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}" Padding="6,0" Margin="2,0,0,0"
                        FontSize="11"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <!-- ── Toolbar ───────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource PanelToolbarStyle}">
            <DockPanel LastChildFill="False">
                <Button Style="{StaticResource PanelIconButtonStyle}"
                        Content="&#xE72C;"
                        Command="{Binding RefreshCommand}"
                        ToolTip="Refresh"/>
                <Separator Width="1" Margin="2,4"
                           Background="{DynamicResource Panel_ToolbarBorderBrush}"/>
                <Button Style="{StaticResource PanelIconButtonStyle}"
                        Content="&#xE710;"
                        Command="{Binding StageAllCommand}"
                        ToolTip="Stage All"/>
                <Button Style="{StaticResource PanelIconButtonStyle}"
                        Content="&#xE738;"
                        Command="{Binding UnstageAllCommand}"
                        ToolTip="Unstage All"/>
                <Button Style="{StaticResource PanelIconButtonStyle}"
                        Content="&#xE74D;"
                        Command="{Binding DiscardAllCommand}"
                        ToolTip="Discard All Changes"/>
                <Separator Width="1" Margin="2,4"
                           Background="{DynamicResource Panel_ToolbarBorderBrush}"/>
                <Button Style="{StaticResource PanelIconButtonStyle}"
                        Content="&#xE72A;"
                        Command="{Binding StashCommand}"
                        ToolTip="Stash Changes"/>
            </DockPanel>
        </Border>

        <!-- ── Push / Pull bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource DockBorderBrush}" Padding="6,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x2191;" FontSize="13"
                               Foreground="{DynamicResource GC_AheadBadgeForeground}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Ahead}" Margin="0,0,6,0"
                               Foreground="{DynamicResource GC_AheadBadgeForeground}" VerticalAlignment="Center"/>
                    <TextBlock Text="&#x2193;" FontSize="13"
                               Foreground="{DynamicResource GC_BehindBadgeForeground}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Behind}"
                               Foreground="{DynamicResource GC_BehindBadgeForeground}" VerticalAlignment="Center"/>
                </StackPanel>
                <pb:LinearProgressBar Grid.Column="1" IsIndeterminate="True"
                                      Height="3" BarHeight="3" Margin="8,0"
                                      Visibility="{Binding IsRemoteOp, Converter={StaticResource BoolToVis}}"
                                      VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button ToolTip="Sync (Pull + Push)" Command="{Binding SyncCommand}"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}" Padding="5,2">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                    <Button ToolTip="Pull" Command="{Binding PullCommand}"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}" Padding="5,2">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                    <Button ToolTip="Push" Command="{Binding PushCommand}"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}" Padding="5,2">
                        <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                    <Button ToolTip="Fetch" Command="{Binding FetchCommand}"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}" Padding="5,2">
                        <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Status row (branch + loading indicator) ──────────────────────── -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource DockBorderBrush}" Padding="6,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets"
                           FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}" />
                <pb:LinearProgressBar IsIndeterminate="True" Width="60" Height="4" BarHeight="4" Margin="8,0,0,0"
                                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Border>

        <!-- ── Commit message area ───────────────────────────────────────────── -->
        <Border Grid.Row="3" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource DockBorderBrush}" Padding="6,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0"
                         Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" MaxLines="4" MinHeight="52"
                         TextWrapping="Wrap"
                         ToolTip="Commit message (Ctrl+Enter to commit)"
                         Style="{StaticResource GC_CommitTextBoxStyle}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Modifiers="Ctrl" Command="{Binding CommitCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Grid Grid.Row="1" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Content="Amend last" IsChecked="{Binding IsAmend}"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              VerticalAlignment="Center" FontSize="11"/>
                    <Button Grid.Column="1" Content="Commit"
                            Command="{Binding CommitCommand}"
                            Style="{StaticResource GC_CommitButtonStyle}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Scrollable change groups ─────────────────────────────────────── -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Conflicts -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConflictFiles.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="MERGE CONFLICTS"
                               Foreground="{DynamicResource GC_ConflictForeground}"/>
                    <ItemsControl ItemsSource="{Binding ConflictFiles}" />
                </StackPanel>

                <!-- Staged -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StagedFiles.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="STAGED CHANGES"/>
                    <ItemsControl ItemsSource="{Binding StagedFiles}" />
                </StackPanel>

                <!-- Modified -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ModifiedFiles.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="CHANGES"/>
                    <ItemsControl ItemsSource="{Binding ModifiedFiles}" />
                </StackPanel>

                <!-- Untracked -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UntrackedFiles.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="UNTRACKED FILES"/>
                    <ItemsControl ItemsSource="{Binding UntrackedFiles}" />
                </StackPanel>

                <!-- Stash -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StashEntries.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="STASH"/>
                    <ItemsControl ItemsSource="{Binding StashEntries}" />
                </StackPanel>

                <!-- Empty state -->
                <TextBlock Text="No changes detected."
                           HorizontalAlignment="Center" Margin="0,20"
                           Opacity="0.45"
                           Foreground="{DynamicResource DockMenuForegroundBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding StagedFiles.Count}"    Value="0" />
                                        <Condition Binding="{Binding ModifiedFiles.Count}"  Value="0" />
                                        <Condition Binding="{Binding UntrackedFiles.Count}" Value="0" />
                                        <Condition Binding="{Binding ConflictFiles.Count}"  Value="0" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

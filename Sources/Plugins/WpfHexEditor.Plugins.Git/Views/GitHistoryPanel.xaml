<UserControl
    x:Class="WpfHexEditor.Plugins.Git.Views.GitHistoryPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pb="clr-namespace:WpfHexEditor.ProgressBar.Controls;assembly=WpfHexEditor.ProgressBar"
    xmlns:vm="clr-namespace:WpfHexEditor.Plugins.Git.ViewModels"
    Background="{DynamicResource DockBackgroundBrush}"
    Foreground="{DynamicResource DockMenuForegroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar + filters -->
            <RowDefinition Height="*"/>     <!-- Content split -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ───────────────────────────────────────────────────────── -->
        <ToolBar Grid.Row="0" Background="Transparent" BorderThickness="0">
            <Button ToolTip="Refresh" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource DockDarkToolBarButtonStyle}">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
            </Button>
            <Separator/>
            <!-- File filter -->
            <TextBlock Text="File:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"
                       Foreground="{DynamicResource GC_SectionHeaderForeground}"/>
            <TextBox Text="{Binding FileFilter, UpdateSourceTrigger=PropertyChanged}"
                     Width="120" Style="{DynamicResource DockDarkTextBoxStyle}"
                     ToolTip="Filter by file path (leave empty for all commits)">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding RefreshCommand}"/>
                </TextBox.InputBindings>
            </TextBox>
            <!-- Author filter -->
            <TextBlock Text="Author:" VerticalAlignment="Center" FontSize="11" Margin="8,0,4,0"
                       Foreground="{DynamicResource GC_SectionHeaderForeground}"/>
            <TextBox Text="{Binding AuthorFilter, UpdateSourceTrigger=PropertyChanged}"
                     Width="90" Style="{DynamicResource DockDarkTextBoxStyle}"
                     ToolTip="Filter by author name">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding RefreshCommand}"/>
                </TextBox.InputBindings>
            </TextBox>
            <!-- Count -->
            <TextBlock Text="Max:" VerticalAlignment="Center" FontSize="11" Margin="8,0,4,0"
                       Foreground="{DynamicResource GC_SectionHeaderForeground}"/>
            <ComboBox SelectedValue="{Binding MaxCount}" Width="55"
                      Background="{DynamicResource DockBackgroundBrush}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}">
                <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">50</sys:Int32>
                <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">100</sys:Int32>
                <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">250</sys:Int32>
                <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">500</sys:Int32>
            </ComboBox>
            <!-- Loading indicator -->
            <pb:LinearProgressBar IsIndeterminate="True" Width="60" Height="4" BarHeight="4" Margin="8,0,0,0"
                                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                  VerticalAlignment="Center"/>
        </ToolBar>

        <!-- ── Content: commit list + diff pane ─────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Commit list -->
            <ListView Grid.Column="0"
                      ItemsSource="{Binding Commits}"
                      SelectedItem="{Binding SelectedCommit}"
                      Background="{DynamicResource DockBackgroundBrush}"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CommitRow}">
                        <Grid Margin="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <!-- Short hash pill -->
                            <Border Grid.Column="0" Background="{DynamicResource GC_CommitButtonBackground}"
                                    CornerRadius="3" Padding="4,1" Margin="0,0,6,0"
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ShortHash}" FontSize="10" FontFamily="Consolas"
                                           Foreground="{DynamicResource GC_CommitButtonForeground}"/>
                            </Border>
                            <!-- Message -->
                            <TextBlock Grid.Column="1" Text="{Binding Message}"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                            <!-- Author -->
                            <TextBlock Grid.Column="2" Text="{Binding AuthorName}" FontSize="10"
                                       Opacity="0.6" Margin="8,0,6,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource GC_BlameAuthorForeground}"/>
                            <!-- Date -->
                            <TextBlock Grid.Column="3" Text="{Binding DateText}" FontSize="10"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource GC_SectionHeaderForeground}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource GC_BranchPickerHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource GC_CommitButtonBackground}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          Background="{DynamicResource DockBorderBrush}"
                          VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

            <!-- Diff / commit details pane -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <TextBox Text="{Binding DiffText, Mode=OneWay}"
                         IsReadOnly="True" TextWrapping="NoWrap"
                         Background="Transparent" BorderThickness="0"
                         FontFamily="Consolas" FontSize="11"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         Padding="6"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

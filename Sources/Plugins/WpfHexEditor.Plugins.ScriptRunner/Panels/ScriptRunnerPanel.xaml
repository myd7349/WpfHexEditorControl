<UserControl x:Class="WpfHexEditor.Plugins.ScriptRunner.Panels.ScriptRunnerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Plugins.ScriptRunner.ViewModels"
             xmlns:ce="clr-namespace:WpfHexEditor.Editor.CodeEditor.Controls;assembly=WpfHexEditor.Editor.CodeEditor">

    <UserControl.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="32" />
            <!-- Code input -->
            <RowDefinition Height="*" MinHeight="60" />
            <!-- Splitter -->
            <RowDefinition Height="4" />
            <!-- Output pane -->
            <RowDefinition Height="120" MinHeight="40" />
            <!-- Status bar -->
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource SR_ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource DockSplitterBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">

                <!-- Run (F5) -->
                <Button Command="{Binding RunCommand}"
                        ToolTip="Run Script (F5)"
                        Width="28" Height="24" Margin="0,0,2,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource ForegroundBrush}">
                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" />
                </Button>

                <!-- Cancel -->
                <Button Command="{Binding CancelCommand}"
                        ToolTip="Cancel"
                        Width="28" Height="24" Margin="0,0,2,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource ForegroundBrush}">
                    <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="13" />
                </Button>

                <Separator Width="1" Margin="4,4" Background="{DynamicResource DockSplitterBrush}" />

                <!-- Clear output -->
                <Button Command="{Binding ClearCommand}"
                        ToolTip="Clear Output"
                        Width="28" Height="24" Margin="0,0,2,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource ForegroundBrush}">
                    <TextBlock Text="&#xED60;" FontFamily="Segoe MDL2 Assets" FontSize="13" />
                </Button>

                <Separator Width="1" Margin="4,4" Background="{DynamicResource DockSplitterBrush}" />

                <!-- Running spinner -->
                <TextBlock Text="&#xE8A2;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                           VerticalAlignment="Center" Margin="4,0"
                           Foreground="{DynamicResource SR_RunningForegroundBrush}"
                           Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="SpinnerTransform" Angle="0"
                                         CenterX="7" CenterY="7" />
                    </TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        Storyboard.TargetName="SpinnerTransform"
                                        Storyboard.TargetProperty="Angle"
                                        From="0" To="360"
                                        Duration="0:0:1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── Code Input (CodeEditorSplitHost — syntax + SmartComplete) ──── -->
        <ce:CodeEditorSplitHost Grid.Row="1"
                                x:Name="CodeBox"
                                ShowMinimap="False"
                                ShowLineNumbers="True"
                                KeyDown="OnCodeBoxKeyDown" />

        <!-- ── Splitter ────────────────────────────────────────────────────── -->
        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource DockSplitterBrush}"
                      ResizeDirection="Rows" />

        <!-- ── Output pane ────────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource DockSplitterBrush}"
                BorderThickness="0,1,0,0">
            <TextBox x:Name="OutputBox"
                     Text="{Binding Output, Mode=OneWay}"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="11"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     Foreground="{DynamicResource SR_OutputForegroundBrush}"
                     Background="{DynamicResource SR_OutputBackgroundBrush}"
                     BorderThickness="0"
                     Padding="6" />
        </Border>

        <!-- ── Status bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="4"
                Background="{DynamicResource SR_StatusBarBackgroundBrush}"
                BorderBrush="{DynamicResource DockSplitterBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       FontSize="11"
                       Foreground="{DynamicResource ForegroundBrush}" />
        </Border>
    </Grid>
</UserControl>

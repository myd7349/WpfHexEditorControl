<!--
    Project: WpfHexEditor.Panels.IDE
    File: PluginMonitoringPanel.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-06
    Description:
        Docking panel for real-time plugin health monitoring.
        Shows CPU% and Memory MB line charts (Canvas+Polyline, no external lib),
        a health summary header, and a per-plugin metrics table.
    Theme: DynamicResource only (PanelCommon.xaml via merged parent theme).
    ContentId: "plugin-monitor"
-->
<UserControl x:Class="WpfHexEditor.Panels.IDE.Panels.PluginMonitoringPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Panels.IDE.Panels"
             xmlns:vm="clr-namespace:WpfHexEditor.Panels.IDE.Panels.ViewModels"
             Background="{DynamicResource DockBackgroundBrush}">

    <UserControl.Resources>
        <!-- Converts ChartPoint collection + canvas size to a WPF PointCollection for Polyline -->
        <local:ChartPointsConverter x:Key="ChartPointsConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Dark-themed DataGrid column headers -->
        <Style x:Key="MonitorColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"                  Value="{DynamicResource Panel_ToolbarBrush}"/>
            <Setter Property="Foreground"                  Value="{DynamicResource Panel_ToolbarForegroundBrush}"/>
            <Setter Property="BorderBrush"                 Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness"             Value="0,0,1,1"/>
            <Setter Property="Padding"                     Value="6,4"/>
            <Setter Property="FontSize"                    Value="11"/>
            <Setter Property="FontWeight"                  Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment"  Value="Left"/>
        </Style>

        <!-- Dark-themed DataGrid cells -->
        <Style x:Key="MonitorCellStyle" TargetType="DataGridCell">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark-themed DataGrid rows — overrides WPF default blue selection -->
        <Style x:Key="MonitorRowStyle" TargetType="DataGridRow">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Panel_ToolbarBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="26"/>
            <!-- Health summary cards -->
            <RowDefinition Height="Auto"/>
            <!-- Adaptive content area (charts + splitter + table) -->
            <RowDefinition Height="*" MinHeight="90"/>
            <!-- Detail pane for selected plugin (collapses when nothing selected) -->
            <RowDefinition Height="Auto" MinHeight="0"/>
            <!-- Live event log (always visible, collapses when empty) -->
            <RowDefinition Height="Auto" MinHeight="0"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{DynamicResource PanelToolbarStyle}">
            <DockPanel VerticalAlignment="Center" Margin="4,0">

                <!-- Left: title + health badge -->
                <TextBlock DockPanel.Dock="Left"
                           Text="PLUGIN MONITOR" FontSize="10" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>

                <Border DockPanel.Dock="Left"
                        CornerRadius="3" Padding="5,1" Margin="8,0,8,0" VerticalAlignment="Center"
                        Background="{Binding HealthColor}">
                    <TextBlock Text="{Binding HealthLabel}" FontSize="10" Foreground="White"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Right: interval selector + start/stop + reset -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

                    <TextBlock Text="Interval:" FontSize="10" VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               Margin="0,0,4,0"/>
                    <ComboBox x:Name="IntervalComboBox" FontSize="11" Width="50" Height="20"
                              VerticalContentAlignment="Center"
                              Background="{DynamicResource Panel_ToolbarBrush}"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              BorderBrush="{DynamicResource DockBorderBrush}"
                              SelectionChanged="OnIntervalSelectionChanged">
                        <ComboBoxItem Content="1 s"  Tag="1"/>
                        <ComboBoxItem Content="5 s"  Tag="5" IsSelected="True"/>
                        <ComboBoxItem Content="10 s" Tag="10"/>
                        <ComboBoxItem Content="30 s" Tag="30"/>
                    </ComboBox>

                    <Rectangle Width="1" Height="14" Margin="6,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>

                    <!-- Start / Pause -->
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding StartStopCommand}"
                            ToolTip="{Binding StartStopLabel}">
                        <TextBlock Text="{Binding StartStopIcon}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Reset / Clear history -->
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ResetCommand}"
                            ToolTip="Clear chart history">
                        <TextBlock Text="&#xE777;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <Rectangle Width="1" Height="14" Margin="6,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"
                               Visibility="{Binding IsLandscape, Converter={StaticResource BoolToVis}}"/>

                    <!-- List side toggle — only visible in landscape (bottom-dock) mode -->
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ToggleListSideCommand}"
                            ToolTip="{Binding ListSideTooltip}"
                            Visibility="{Binding IsLandscape, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ListSideIcon}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <Rectangle Width="1" Height="14" Margin="6,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>

                    <!-- Search box — real-time filter on plugin name -->
                    <Grid Width="90" VerticalAlignment="Center">
                        <TextBox x:Name="SearchBox"
                                 Height="18" FontSize="10"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource Panel_ToolbarBrush}"
                                 Foreground="{DynamicResource DockMenuForegroundBrush}"
                                 BorderBrush="{DynamicResource DockBorderBrush}"
                                 BorderThickness="1" Padding="3,1" VerticalContentAlignment="Center"/>
                        <!-- Placeholder "Filter plugins..." — hidden when TextBox has text -->
                        <TextBlock Text="Filter plugins…" FontSize="10" Padding="4,1" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Rectangle Width="1" Height="14" Margin="6,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>

                    <!-- Reload selected plugin -->
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ReloadPluginCommand}"
                            ToolTip="Reload selected plugin"
                            IsEnabled="{Binding HasSelectedPlugin}">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Enable / Disable selected plugin -->
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding TogglePluginCommand}"
                            ToolTip="{Binding TogglePluginLabel}"
                            IsEnabled="{Binding HasSelectedPlugin}">
                        <TextBlock Text="{Binding TogglePluginIcon}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <Rectangle Width="1" Height="14" Margin="6,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>

                    <!-- Clear event log -->
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ClearLogCommand}"
                            ToolTip="Clear event log">
                        <TextBlock Text="&#xE74D;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Summary cards ─────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="6,4,6,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CPU -->
            <Border Grid.Column="0" Background="{DynamicResource Panel_ToolbarBrush}"
                    CornerRadius="4" Margin="0,0,3,0" Padding="8,6">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrentCpu, StringFormat={}{0:F1}%}"
                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <TextBlock Text="CPU" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </StackPanel>
            </Border>

            <!-- Memory -->
            <Border Grid.Column="1" Background="{DynamicResource Panel_ToolbarBrush}"
                    CornerRadius="4" Margin="3,0,3,0" Padding="8,6">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrentMemoryMb, StringFormat={}{0} MB}"
                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <TextBlock Text="Memory" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </StackPanel>
            </Border>

            <!-- Running -->
            <Border Grid.Column="2" Background="{DynamicResource Panel_ToolbarBrush}"
                    CornerRadius="4" Margin="3,0,3,0" Padding="8,6">
                <StackPanel HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding LoadedCount}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        <TextBlock Text="/" FontSize="18" Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        <TextBlock Text="{Binding TotalCount}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Running" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </StackPanel>
            </Border>

            <!-- Faults -->
            <Border Grid.Column="3" Background="{DynamicResource Panel_ToolbarBrush}"
                    CornerRadius="4" Margin="3,0,0,0" Padding="8,6">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding FaultCount}" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <TextBlock Text="Faults" FontSize="10" HorizontalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!--
            ── Adaptive content area ───────────────────────────────────────────
            ContentGrid starts in portrait layout (3 rows: charts / splitter / table).
            Code-behind rebuilds rows/columns on SizeChanged to switch between:
              Portrait  — charts top (2*), splitter (4px), table bottom (*)
              Landscape — charts left (*) | splitter (4px) | table right (*)
                          (or reversed when ListSide == Left)
        -->
        <Grid x:Name="ContentGrid" Grid.Row="2" Margin="6,4,6,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" MinHeight="60"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="*"  MinHeight="30"/>
            </Grid.RowDefinitions>

            <!-- Charts area — wraps the two chart canvases; repositioned by code-behind -->
            <Grid x:Name="ChartsArea" Grid.Row="0">

                <!-- Inner grid: portrait = 2 columns, landscape = 2 rows; rebuilt by code-behind -->
                <Grid x:Name="ChartsInnerGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CPU chart -->
                    <Grid x:Name="CpuChartGrid" Grid.Column="0">
                        <Border Background="{DynamicResource Panel_ToolbarBrush}" CornerRadius="4"/>
                        <TextBlock Text="CPU %" FontSize="9" FontWeight="SemiBold" Margin="6,4,0,0"
                                   VerticalAlignment="Top" HorizontalAlignment="Left"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        <Canvas x:Name="CpuChartCanvas" Margin="4,18,4,4" ClipToBounds="True">
                            <Polyline x:Name="CpuPolyline"
                                      Stroke="#22C55E" StrokeThickness="1.5"
                                      StrokeLineJoin="Round"/>
                        </Canvas>
                    </Grid>

                    <GridSplitter x:Name="ChartsInnerSplitter"
                                  Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource Panel_ToolbarBorderBrush}"/>

                    <!-- Memory chart -->
                    <Grid x:Name="MemChartGrid" Grid.Column="2">
                        <Border Background="{DynamicResource Panel_ToolbarBrush}" CornerRadius="4"/>
                        <TextBlock Text="Memory MB" FontSize="9" FontWeight="SemiBold" Margin="6,4,0,0"
                                   VerticalAlignment="Top" HorizontalAlignment="Left"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                        <Canvas x:Name="MemChartCanvas" Margin="4,18,4,4" ClipToBounds="True">
                            <Polyline x:Name="MemPolyline"
                                      Stroke="#60A5FA" StrokeThickness="1.5"
                                      StrokeLineJoin="Round"/>
                        </Canvas>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Main splitter between charts and plugin table; direction set by code-behind -->
            <GridSplitter x:Name="ContentSplitter"
                          Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Panel_ToolbarBorderBrush}"/>

            <!-- ── Plugin table ──────────────────────────────────────────────── -->
            <DataGrid x:Name="PluginsDataGrid"
                      Grid.Row="2"
                      ItemsSource="{Binding FilteredRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource Panel_ToolbarBrush}"
                      ColumnHeaderStyle="{StaticResource MonitorColumnHeaderStyle}"
                      CellStyle="{StaticResource MonitorCellStyle}"
                      RowStyle="{StaticResource MonitorRowStyle}"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionChanged="OnPluginSelectionChanged">
                <DataGrid.Columns>
                    <!-- Warning badge (slow / not responsive) -->
                    <DataGridTemplateColumn Header="" Width="22" CanUserResize="False" SortMemberPath="HasWarning">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WarningIcon}"
                                           FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{Binding WarningColor}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           ToolTip="{Binding WarningTooltip}"
                                           Visibility="{Binding HasWarning, Converter={StaticResource BoolToVis}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- State dot -->
                    <DataGridTemplateColumn Header="" Width="20" CanUserResize="False" SortMemberPath="StateColor">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center"
                                         Fill="{Binding StateColor}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Plugin"   Binding="{Binding Name}"                                           Width="*"/>

                    <!-- State with fault tooltip -->
                    <DataGridTemplateColumn Header="State" Width="80" SortMemberPath="State">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding State}"
                                           ToolTip="{Binding FaultMessage}"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           VerticalAlignment="Center" Margin="4,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="CPU%"     Binding="{Binding CpuPercent, StringFormat={}{0:F1}%}"             Width="55"/>
                    <DataGridTextColumn Header="Peak%"    Binding="{Binding PeakCpu,    StringFormat={}{0:F1}%}"             Width="55"/>
                    <DataGridTextColumn Header="Mem MB"   Binding="{Binding MemoryMb}"                                       Width="60"/>
                    <DataGridTextColumn Header="Uptime"   Binding="{Binding UptimeLabel}"                                    Width="65"/>
                    <DataGridTextColumn Header="Avg ms"   Binding="{Binding AvgExecMs,  StringFormat={}{0:F1}}"              Width="60"/>
                    <DataGridTextColumn Header="Init ms"  Binding="{Binding InitTimeMs, StringFormat={}{0:F0}}"              Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <!-- ── Plugin detail pane ───────────────────────────────────────────── -->
        <Border Grid.Row="3" MaxHeight="120" Margin="6,0,6,0"
                BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="0,1,0,0"
                Background="{DynamicResource Panel_ToolbarBrush}"
                Visibility="{Binding HasSelectedPlugin, Converter={StaticResource BoolToVis}}">
            <Grid DataContext="{Binding SelectedPluginDetail}" Margin="8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: name, version, trust badge -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{Binding StateColor}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Version, StringFormat=' v{0}'}" FontSize="10"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" VerticalAlignment="Center" Margin="4,0"/>
                    <Border CornerRadius="3" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center"
                            Background="{DynamicResource DockBorderBrush}">
                        <TextBlock Text="{Binding TrustLabel}" FontSize="9"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </Border>
                    <TextBlock Text="{Binding Author, StringFormat=' — by {0}'}" FontSize="10"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>

                <!-- Row 1: metrics grid -->
                <Grid Grid.Row="1" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="V"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="V"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Column pair 1 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Loaded" FontSize="9" VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LoadedAtLabel}" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,0,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Uptime" FontSize="9" VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UptimeLabel}" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>

                    <!-- Column pair 2 -->
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Init" FontSize="9" VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding InitTimeMsLabel}" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,0,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Avg exec" FontSize="9" VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding AvgExecMsLabel}" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>

                    <!-- Column pair 3 -->
                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Peak CPU" FontSize="9" VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="7" Text="{Binding PeakCpuLabel}" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,0,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="6" Text="Avg CPU" FontSize="9" VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}" Margin="0,0,4,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="7" Text="{Binding AvgCpuLabel}" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                </Grid>

                <!-- Row 2: permissions + optional fault message -->
                <StackPanel Grid.Row="2" Margin="0,4,0,0">
                    <TextBlock Text="{Binding PermissionsLabel, StringFormat='Permissions: {0}'}" FontSize="9"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding FaultMessage}" FontSize="9" Foreground="#EF4444"
                               TextWrapping="Wrap" MaxHeight="28" TextTrimming="CharacterEllipsis"
                               Visibility="{Binding HasFault, Converter={StaticResource BoolToVis}}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Live event log ────────────────────────────────────────────────── -->
        <Border x:Name="EventLogArea" Grid.Row="4" MaxHeight="90"
                BorderBrush="{DynamicResource DockBorderBrush}" BorderThickness="0,1,0,0"
                Background="{DynamicResource DockBackgroundBrush}" Margin="6,0,6,4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EventLog.Count, FallbackValue=0}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Log header bar -->
                <Border Grid.Row="0" Background="{DynamicResource Panel_ToolbarBrush}">
                    <TextBlock Text="EVENTS" FontSize="9" FontWeight="SemiBold" Margin="6,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </Border>
                <!-- Log entries -->
                <ListBox x:Name="EventLogListBox" Grid.Row="1"
                         ItemsSource="{Binding EventLog}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"          Value="0"/>
                            <Setter Property="Background"       Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,1">
                                <TextBlock Text="{Binding TimeLabel}" FontSize="9" Width="44"
                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{Binding Color}" Width="16" Margin="2,0"/>
                                <TextBlock Text="{Binding PluginName}" FontSize="9" FontWeight="SemiBold" Width="100"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="2,0"/>
                                <TextBlock Text="{Binding Message}" FontSize="9"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>

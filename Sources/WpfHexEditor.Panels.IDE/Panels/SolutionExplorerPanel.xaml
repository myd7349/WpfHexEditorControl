<UserControl x:Class="WpfHexEditor.Panels.IDE.SolutionExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.Panels.IDE.ViewModels"
             Background="{DynamicResource SE_BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Small toolbar icon button ── -->
        <Style x:Key="SE_IconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SE_HoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TreeViewItem — VS2026 style ── -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="IsExpanded"                 Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected"                 Value="{Binding IsSelected,  Mode=TwoWay}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <!-- Row -->
                            <Grid x:Name="RowGrid" Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Hover/selected background -->
                                <Border x:Name="RowBg" Grid.ColumnSpan="2"
                                        Background="Transparent" SnapsToDevicePixels="True"/>

                                <!-- Blue accent bar (selected only) -->
                                <Border x:Name="Accent" Grid.Column="0"
                                        Background="{DynamicResource SE_SelectionBorderBrush}"
                                        Visibility="Collapsed" SnapsToDevicePixels="True"/>

                                <!-- Content column -->
                                <DockPanel Grid.Column="1">
                                    <!-- Expand/Collapse arrow -->
                                    <ToggleButton x:Name="Expander"
                                                  DockPanel.Dock="Left"
                                                  Width="14" Height="14"
                                                  IsChecked="{Binding IsExpanded,
                                                      RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                                  Focusable="False">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Grid Background="Transparent" Width="14" Height="14">
                                                                <Path x:Name="Ar"
                                                                      Data="M 4,3 L 11,7 L 4,11 Z"
                                                                      Fill="{DynamicResource SE_ForegroundBrush}"
                                                                      Stretch="Uniform" Margin="3"
                                                                      RenderTransformOrigin="0.5,0.5">
                                                                    <Path.RenderTransform>
                                                                        <RotateTransform Angle="0"/>
                                                                    </Path.RenderTransform>
                                                                </Path>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Ar" Property="RenderTransform">
                                                                        <Setter.Value>
                                                                            <RotateTransform Angle="90"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>

                                    <!-- Node header -->
                                    <ContentPresenter x:Name="PART_Header"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Margin="2,0,4,0"/>
                                </DockPanel>
                            </Grid>

                            <!-- Children -->
                            <ItemsPresenter x:Name="ItemsHost" Margin="14,0,0,0"/>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBg"  Property="Background" Value="{DynamicResource SE_SelectedBrush}"/>
                                <Setter TargetName="Accent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource SE_HoverBrush}"/>
                            </MultiTrigger>
                            <Trigger Property="HasItems"  Value="False">
                                <Setter TargetName="Expander"   Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeView base -->
        <Style TargetType="TreeView">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0,4"/>
        </Style>

        <!-- Icon glyph -->
        <Style x:Key="NodeIcon" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,5,0"/>
        </Style>

        <!-- Label -->
        <Style x:Key="NodeLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="{DynamicResource SE_ForegroundBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        </Style>

        <!-- ── Show All Files toggle button ── -->
        <Style x:Key="SE_IconToggleButton" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SE_HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SE_SelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataTemplates -->

        <DataTemplate DataType="{x:Type vm:SolutionNodeVm}">
            <Grid>
                <!-- Normal display (IsEditing = false) -->
                <StackPanel x:Name="SolutionDisplayPanel" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource NodeIcon}" Text="&#xE8B7;" Foreground="#E8B25A"/>
                    <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding Label}" FontWeight="SemiBold"/>
                </StackPanel>
                <!-- Inline rename TextBox (IsEditing = true) -->
                <TextBox x:Name="SolutionInlineEditBox"
                         Visibility="Collapsed"
                         Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         MinWidth="100"
                         Background="{DynamicResource SE_SearchBoxBrush}"
                         Foreground="{DynamicResource SE_ForegroundBrush}"
                         BorderBrush="{DynamicResource SE_SelectionBorderBrush}"
                         BorderThickness="1"
                         Padding="2,1"
                         KeyDown="OnSolutionInlineEditKeyDown"
                         LostKeyboardFocus="OnSolutionInlineEditLostFocus"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="SolutionDisplayPanel"  Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="SolutionInlineEditBox" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProjectNodeVm}">
            <Grid>
                <!-- Normal display (IsEditing = false) -->
                <StackPanel x:Name="ProjectDisplayPanel" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource NodeIcon}" Text="{Binding Icon}" Foreground="#4EC9B0"/>
                    <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                </StackPanel>
                <!-- Inline rename TextBox (IsEditing = true) -->
                <TextBox x:Name="ProjectInlineEditBox"
                         Visibility="Collapsed"
                         Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         MinWidth="100"
                         Background="{DynamicResource SE_SearchBoxBrush}"
                         Foreground="{DynamicResource SE_ForegroundBrush}"
                         BorderBrush="{DynamicResource SE_SelectionBorderBrush}"
                         BorderThickness="1"
                         Padding="2,1"
                         KeyDown="OnProjectInlineEditKeyDown"
                         LostKeyboardFocus="OnProjectInlineEditLostFocus"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="ProjectDisplayPanel"  Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ProjectInlineEditBox" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FolderNodeVm}">
            <Grid>
                <!-- Normal display (IsEditing = false) -->
                <StackPanel x:Name="FolderDisplayPanel" Orientation="Horizontal"
                            ToolTip="Virtual folder">
                    <TextBlock x:Name="FolderIcon" Style="{StaticResource NodeIcon}"
                               Text="&#xE8D5;" Foreground="#6CA8C4"/>
                    <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
                </StackPanel>
                <!-- Inline rename TextBox (IsEditing = true) -->
                <TextBox x:Name="FolderInlineEditBox"
                         Visibility="Collapsed"
                         Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         MinWidth="100"
                         Background="{DynamicResource SE_SearchBoxBrush}"
                         Foreground="{DynamicResource SE_ForegroundBrush}"
                         BorderBrush="{DynamicResource SE_SelectionBorderBrush}"
                         BorderThickness="1"
                         Padding="2,1"
                         KeyDown="OnFolderInlineEditKeyDown"
                         LostKeyboardFocus="OnFolderInlineEditLostFocus"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="FolderDisplayPanel"  Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="FolderInlineEditBox" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <!-- Physical folder: gold icon + distinct tooltip -->
                <DataTrigger Binding="{Binding IsPhysicallyBacked}" Value="True">
                    <Setter TargetName="FolderIcon"          Property="Foreground" Value="#E8B25A"/>
                    <Setter TargetName="FolderDisplayPanel"  Property="ToolTip"    Value="Physical folder"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FileNodeVm}">
            <Grid>
                <!-- Normal display (IsEditing = false) -->
                <StackPanel x:Name="DisplayPanel" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource NodeIcon}" Text="{Binding Icon}"
                               Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource NodeLabel}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDefaultTbl}" Value="True">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Modified dot -->
                    <TextBlock Text=" &#x25CF;" FontSize="9"
                               Foreground="{DynamicResource SE_ModifiedIndicatorBrush}"
                               VerticalAlignment="Center"
                               ToolTip="Unsaved modifications"
                               Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}"/>
                    <!-- External-file badge -->
                    <TextBlock x:Name="ExternalBadge"
                               Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                               Foreground="#E8A419"
                               VerticalAlignment="Center" Margin="3,0,0,0"
                               ToolTip="File is located outside the project directory"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- Inline rename TextBox (IsEditing = true) -->
                <TextBox x:Name="InlineEditBox"
                         Visibility="Collapsed"
                         Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         MinWidth="100"
                         Background="{DynamicResource SE_SearchBoxBrush}"
                         Foreground="{DynamicResource SE_ForegroundBrush}"
                         BorderBrush="{DynamicResource SE_SelectionBorderBrush}"
                         BorderThickness="1"
                         Padding="2,1"
                         KeyDown="OnInlineEditKeyDown"
                         LostKeyboardFocus="OnInlineEditLostFocus"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter TargetName="DisplayPanel"   Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="InlineEditBox"  Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsExternal}" Value="True">
                    <Setter TargetName="ExternalBadge" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PhysicalFolderNodeVm}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource NodeIcon}" Text="&#xE8D5;" Foreground="#E8B25A" Opacity="0.75"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}" Opacity="0.85"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PhysicalFileNodeVm}">
            <StackPanel x:Name="PhysFilePanel" Orientation="Horizontal">
                <TextBlock Style="{StaticResource NodeIcon}" Text="{Binding Icon}"
                           Foreground="{DynamicResource SE_ForegroundBrush}"/>
                <TextBlock Style="{StaticResource NodeLabel}" Text="{Binding DisplayName}"/>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsInProject}" Value="False">
                    <Setter TargetName="PhysFilePanel" Property="Opacity" Value="0.45"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource SE_ToolbarBrush}"
                BorderBrush="{DynamicResource SE_SeparatorBrush}"
                BorderThickness="0,0,0,1" Padding="6,3">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <ToggleButton x:Name="ShowAllFilesButton"
                                  Style="{StaticResource SE_IconToggleButton}"
                                  ToolTip="Show All Files"
                                  Click="OnShowAllFiles">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </ToggleButton>
                    <Button Style="{StaticResource SE_IconButton}" ToolTip="Collapse All"          Click="OnCollapseAll">
                        <TextBlock Text="&#xF165;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Button>
                    <Button Style="{StaticResource SE_IconButton}" ToolTip="Sync with Active Document" Click="OnSyncWithActiveDocument">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Button>
                    <Button Style="{StaticResource SE_IconButton}" ToolTip="Refresh" Click="OnRefresh">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource SE_ForegroundBrush}"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Search box -->
        <Border Grid.Row="1" Margin="6,4"
                Background="{DynamicResource SE_SearchBoxBrush}"
                BorderBrush="{DynamicResource SE_SeparatorBrush}"
                BorderThickness="1" CornerRadius="2">
            <Grid Margin="6,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource SE_SearchBoxForegroundBrush}"
                         CaretBrush="{DynamicResource SE_SearchBoxForegroundBrush}"
                         VerticalAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus"/>
                <TextBlock x:Name="SearchPlaceholder" Grid.Column="0"
                           Text="Search Solution Explorer (Ctrl+;)"
                           Foreground="{DynamicResource SE_SearchBoxForegroundBrush}"
                           Opacity="0.45" IsHitTestVisible="False"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                           Foreground="{DynamicResource SE_ForegroundBrush}"
                           Opacity="0.6" VerticalAlignment="Center" Margin="4,0,0,0"
                           IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Tree -->
        <TreeView x:Name="SolutionTree" Grid.Row="2"
                  ItemsSource="{Binding Roots}"
                  SelectedItemChanged="OnSelectedItemChanged"
                  MouseDoubleClick="OnItemDoubleClick"
                  PreviewKeyDown="OnTreePreviewKeyDown"
                  ContextMenuOpening="OnContextMenuOpening"
                  AllowDrop="True"
                  PreviewMouseLeftButtonDown="OnTreeMouseLeftButtonDown"
                  MouseMove="OnTreeMouseMove"
                  DragOver="OnTreeDragOver"
                  Drop="OnTreeDrop"
                  Background="{DynamicResource SE_BackgroundBrush}"
                  Foreground="{DynamicResource SE_ForegroundBrush}">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <ContentPresenter Content="{Binding}"/>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>

            <TreeView.ContextMenu>
                <ContextMenu>
                    <ContextMenu.Resources>
                        <Style x:Key="MenuIcon" TargetType="TextBlock">
                            <Setter Property="FontFamily"        Value="Segoe MDL2 Assets"/>
                            <Setter Property="FontSize"          Value="13"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </ContextMenu.Resources>

                    <!-- Open / Open With (file, physFile-inProject) -->
                    <MenuItem x:Name="OpenMenuItem" Header="Open" Click="OnOpen">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8A7;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="OpenWithMenuItem" Header="Open With..." Click="OnOpenWith">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8C8;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="OpenSeparator"/>

                    <!-- Add operations (project / folder) -->
                    <MenuItem x:Name="AddNewItemMenuItem" Header="Add New Item..." Click="OnAddNewItem">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8A5;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="AddExistingItemMenuItem" Header="Add Existing Item..." Click="OnAddExistingItem">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8E5;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ImportFormatMenuItem" Header="Import Built-in Format..." Click="OnImportFormatDefinition">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE896;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="NewFolderMenuItem" Header="New Folder" Click="OnNewFolder">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8F4;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="NewPhysicalFolderMenuItem" Header="New Physical Folder" Click="OnNewPhysicalFolder">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8D5;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="AddFolderFromDiskMenuItem" Header="Add Existing Folder..." Click="OnAddFolderFromDisk">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8DA;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="AddSeparator"/>

                    <!-- Include in Project (Show All Files — physical file not yet tracked) -->
                    <MenuItem x:Name="IncludeInProjectMenuItem" Header="Include in Project" Click="OnIncludeInProject">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE710;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="IncludeSeparator"/>

                    <!-- TBL operations -->
                    <MenuItem x:Name="SetDefaultTblMenuItem" Header="Set as Default TBL" Click="OnSetDefaultTbl">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE735;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ClearDefaultTblMenuItem" Header="Clear Default TBL" Click="OnClearDefaultTbl">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE734;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ConvertToTblxMenuItem" Header="Convert to TBLX..." Click="OnConvertToTblx">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8AB;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="TblSeparator"/>

                    <!-- Navigation (all node types) -->
                    <MenuItem x:Name="OpenInExplorerMenuItem" Header="Open in File Explorer" Click="OnOpenInExplorer">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xEC50;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CopyPathMenuItem" Header="Copy Path" Click="OnCopyPath">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8C8;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="NavigationSeparator"/>

                    <!-- Rename / Remove / Exclude -->
                    <MenuItem x:Name="RenameMenuItem" Header="Rename" Click="OnRename">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8AC;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="RemoveMenuItem" Header="Remove from Project" Click="OnRemove">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE74D;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ExcludeFromProjectMenuItem" Header="Exclude from Project" Click="OnExcludeFromProject">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8F8;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <!-- Import external file into project directory -->
                    <Separator x:Name="ImportExternalSeparator"/>
                    <MenuItem x:Name="ImportExternalFileMenuItem" Header="Import into Project..." Click="OnImportExternalFile">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8B5;"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!-- Changeset (.whchg) actions -->
                    <Separator x:Name="ChangesetSeparator"/>
                    <MenuItem x:Name="WriteChangesetToDiskMenuItem" Header="Apply to Disk" Click="OnWriteChangesetToDisk">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE9F5;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="DiscardChangesetMenuItem" Header="Discard Changes" Click="OnDiscardChangeset">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE711;"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!-- Properties -->
                    <Separator x:Name="PropertiesSeparator"/>
                    <MenuItem x:Name="PropertiesMenuItem" Header="Properties" Click="OnProperties">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE946;"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!-- Solution bottom: Save All + Close Solution -->
                    <Separator x:Name="SolutionBottomSeparator"/>
                    <MenuItem x:Name="SaveAllMenuItem" Header="Save All" Click="OnSaveAll">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE792;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator x:Name="CloseSolutionSeparator"/>
                    <MenuItem x:Name="CloseSolutionMenuItem" Header="Close Solution" Click="OnCloseSolution">
                        <MenuItem.Icon>
                            <TextBlock Style="{StaticResource MenuIcon}" Text="&#xE8BB;"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>
    </Grid>
</UserControl>

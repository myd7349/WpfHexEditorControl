<UserControl x:Class="WpfHexEditor.Panels.IDE.Panels.ErrorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:WpfHexEditor.Editor.Core;assembly=WpfHexEditor.Editor.Core"
             Background="{DynamicResource ERR_BackgroundBrush}"
             Foreground="{DynamicResource ERR_ForegroundBrush}">

   <UserControl.Resources>

        <!-- ── ToggleButton style for severity filter ───────────────────────── -->
        <Style x:Key="ERR_FilterButton" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Padding"         Value="6,2"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground"      Value="{DynamicResource ERR_ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ERR_HoverRowBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource ERR_GridLinesBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ERR_FilterActiveBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource ERR_GridLinesBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ListView item style ─────────────────────────────────────────── -->
        <Style TargetType="ListViewItem">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource ERR_GridLinesBrush}"
                                BorderThickness="0,0,0,1"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background"
                                        Value="{DynamicResource ERR_HoverRowBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background"
                                        Value="{DynamicResource ERR_SelectedRowBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── GridViewColumnHeader style (custom template — suppresses WPF default blue) ── -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"   Value="{DynamicResource ERR_HeaderBrush}"/>
            <Setter Property="Foreground"   Value="{DynamicResource ERR_ForegroundBrush}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource ERR_GridLinesBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"      Value="6,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"       Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border x:Name="HeaderBd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="HeaderContent"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              SnapsToDevicePixels="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBd" Property="Background"
                                        Value="{DynamicResource ERR_HeaderHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderBd" Property="Background"
                                        Value="{DynamicResource ERR_HeaderPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="Role" Value="Floating">
                                <Setter TargetName="HeaderBd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="Role" Value="Padding">
                                <Setter TargetName="HeaderContent" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Severity icons (vector DrawingImage) ────────────────────────── -->

        <!-- Error icon — red circle with X -->
        <DrawingImage x:Key="ErrorIcon">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#E51400">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="8,8" RadiusX="7" RadiusY="7"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M 5,5 L 11,11 M 11,5 L 5,11"/>
                        </GeometryDrawing.Geometry>
                        <GeometryDrawing.Pen>
                            <Pen Brush="White" Thickness="1.8" StartLineCap="Round" EndLineCap="Round"/>
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <!-- Warning icon — yellow triangle with ! -->
        <DrawingImage x:Key="WarningIcon">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#F5C518">
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M 8,1 L 15,14 L 1,14 Z"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#333333">
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M 8,5 L 8,10 M 8,11 L 8,12"/>
                        </GeometryDrawing.Geometry>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#333333" Thickness="1.8" StartLineCap="Round" EndLineCap="Round"/>
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <!-- Message icon — blue circle with i -->
        <DrawingImage x:Key="MessageIcon">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#1E90FF">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="8,8" RadiusX="7" RadiusY="7"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M 8,5 L 8,5 M 8,7 L 8,12"/>
                        </GeometryDrawing.Geometry>
                        <GeometryDrawing.Pen>
                            <Pen Brush="White" Thickness="1.8" StartLineCap="Round" EndLineCap="Round"/>
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>   <!-- ListView -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource ERR_ToolbarBrush}"
                BorderBrush="{DynamicResource ERR_GridLinesBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="4,0" LastChildFill="False" VerticalAlignment="Center">

                <!-- Scope dropdown -->
                <ComboBox x:Name="ScopeCombo"
                          DockPanel.Dock="Left"
                          Height="22"
                          MinWidth="120"
                          Margin="0,0,6,0"
                          Background="{DynamicResource ERR_SearchBoxBrush}"
                          Foreground="{DynamicResource ERR_ForegroundBrush}"
                          BorderBrush="{DynamicResource ERR_GridLinesBrush}"
                          SelectionChanged="OnScopeChanged">
                    <ComboBoxItem Content="Entire Solution"  Tag="Solution"/>
                    <ComboBoxItem Content="Current Project"  Tag="CurrentProject"/>
                    <ComboBoxItem Content="Current Document" Tag="CurrentDocument"/>
                </ComboBox>

                <!-- Separator -->
                <Rectangle DockPanel.Dock="Left"
                           Width="1" Height="16"
                           Fill="{DynamicResource ERR_GridLinesBrush}"
                           Margin="2,0,6,0"/>

                <!-- Error filter toggle -->
                <ToggleButton x:Name="ErrorToggle"
                              DockPanel.Dock="Left"
                              Style="{StaticResource ERR_FilterButton}"
                              IsChecked="True"
                              Margin="0,0,2,0"
                              Checked="OnFilterChanged"
                              Unchecked="OnFilterChanged"
                              ToolTip="Show/hide errors">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource ErrorIcon}"
                               Width="14" Height="14"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"/>
                        <TextBlock x:Name="ErrorCountText"
                                   Text="0 Erreurs"
                                   VerticalAlignment="Center"
                                   FontSize="11"/>
                    </StackPanel>
                </ToggleButton>

                <!-- Warning filter toggle -->
                <ToggleButton x:Name="WarningToggle"
                              DockPanel.Dock="Left"
                              Style="{StaticResource ERR_FilterButton}"
                              IsChecked="True"
                              Margin="0,0,2,0"
                              Checked="OnFilterChanged"
                              Unchecked="OnFilterChanged"
                              ToolTip="Show/hide warnings">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource WarningIcon}"
                               Width="14" Height="14"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"/>
                        <TextBlock x:Name="WarningCountText"
                                   Text="0 Avertissements"
                                   VerticalAlignment="Center"
                                   FontSize="11"/>
                    </StackPanel>
                </ToggleButton>

                <!-- Message filter toggle -->
                <ToggleButton x:Name="MessageToggle"
                              DockPanel.Dock="Left"
                              Style="{StaticResource ERR_FilterButton}"
                              IsChecked="True"
                              Margin="0,0,2,0"
                              Checked="OnFilterChanged"
                              Unchecked="OnFilterChanged"
                              ToolTip="Show/hide messages">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource MessageIcon}"
                               Width="14" Height="14"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"/>
                        <TextBlock x:Name="MessageCountText"
                                   Text="0 Messages"
                                   VerticalAlignment="Center"
                                   FontSize="11"/>
                    </StackPanel>
                </ToggleButton>

                <!-- Search box (right-aligned) -->
                <Rectangle DockPanel.Dock="Right"
                           Width="1" Height="16"
                           Fill="{DynamicResource ERR_GridLinesBrush}"
                           Margin="6,0,2,0"/>
                <TextBox x:Name="SearchBox"
                         DockPanel.Dock="Right"
                         Width="160" Height="22"
                         Background="{DynamicResource ERR_SearchBoxBrush}"
                         Foreground="{DynamicResource ERR_ForegroundBrush}"
                         BorderBrush="{DynamicResource ERR_GridLinesBrush}"
                         BorderThickness="1"
                         Padding="4,2"
                         VerticalContentAlignment="Center"
                         FontSize="11"
                         TextChanged="OnSearchChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Resources>
                                <VisualBrush x:Key="Watermark" TileMode="None" Opacity="0.4" Stretch="None" AlignmentX="Left">
                                    <VisualBrush.Visual>
                                        <TextBlock Text="Search..."
                                                   Foreground="{DynamicResource ERR_ForegroundBrush}"
                                                   FontSize="11"
                                                   Padding="4,2"/>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Style.Resources>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background" Value="{StaticResource Watermark}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

            </DockPanel>
        </Border>

        <!-- ── Entry list ─────────────────────────────────────────────────── -->
        <ListView x:Name="EntryList"
                  Grid.Row="1"
                  Background="{DynamicResource ERR_BackgroundBrush}"
                  Foreground="{DynamicResource ERR_ForegroundBrush}"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  MouseDoubleClick="OnEntryDoubleClick"
                  KeyDown="OnEntryKeyDown"
                  ContextMenuOpening="OnErrListContextMenuOpening"
                  GridViewColumnHeader.Click="OnColumnHeaderClick">
            <ListView.View>
                <GridView>
                    <!-- Severity icon -->
                    <GridViewColumn Width="24">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image x:Name="SevIcon" Width="14" Height="14"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Entry.Severity}" Value="{x:Static core:DiagnosticSeverity.Error}">
                                                    <Setter Property="Source" Value="{StaticResource ErrorIcon}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Entry.Severity}" Value="{x:Static core:DiagnosticSeverity.Warning}">
                                                    <Setter Property="Source" Value="{StaticResource WarningIcon}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Entry.Severity}" Value="{x:Static core:DiagnosticSeverity.Message}">
                                                    <Setter Property="Source" Value="{StaticResource MessageIcon}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Code -->
                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Code" Content="Code"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Entry.Code}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Padding="2,0"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Entry.Code}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Description -->
                    <GridViewColumn Width="400">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Description" Content="Description"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Entry.Description}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Padding="2,0"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Entry.Description}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Project -->
                    <GridViewColumn Width="120">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="ProjectName" Content="Project"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Entry.ProjectName}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Padding="2,0"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Entry.ProjectName}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- File -->
                    <GridViewColumn Width="130">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="FileName" Content="File"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Entry.FileName}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Padding="2,0"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Entry.FilePath}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Offset -->
                    <GridViewColumn Width="90">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Offset" Content="Offset"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding OffsetDisplay}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Padding="2,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Line:Col -->
                    <GridViewColumn Width="80">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Tag="Line" Content="Line:Col"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LineColDisplay}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Padding="2,0"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                </GridView>
            </ListView.View>
        </ListView>

    </Grid>
</UserControl>

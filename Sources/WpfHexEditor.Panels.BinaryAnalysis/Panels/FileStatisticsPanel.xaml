<UserControl x:Class="WpfHexEditor.Panels.BinaryAnalysis.FileStatisticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="300">

    <UserControl.Resources>
        <!-- Semantic status brushes (constant across themes) -->
        <SolidColorBrush x:Key="GoodBrush"    Color="#7ED321"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F5A623"/>
        <SolidColorBrush x:Key="ErrorBrush"   Color="#FF6B6B"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#4A90E2"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="10"/>
            <Setter Property="Margin"          Value="0,0,0,6"/>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{DynamicResource PFP_AccentBrush}"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_SubTextBrush}"/>
            <Setter Property="Margin"     Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MetricRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PFP_PanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar (VS-style PanelCommon) ── -->
        <Border Grid.Row="0" Style="{StaticResource PanelToolbarStyle}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        x:Name="RefreshButton"
                        Style="{StaticResource PanelIconButtonStyle}"
                        Content="&#xE72C;"
                        ToolTip="Re-analyze"
                        Click="RefreshButton_Click"/>
                <TextBlock Text="File Statistics"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
            </DockPanel>
        </Border>

        <!-- ── Scrollable content ── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="8">

                <!-- File Info card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="File Information" Style="{StaticResource CardTitleStyle}"/>

                        <TextBlock x:Name="FileNameText"
                                   Text="No file loaded"
                                   FontWeight="Bold" FontSize="11"
                                   Foreground="{DynamicResource PFP_TextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,2"/>
                        <TextBlock x:Name="FilePathText"
                                   Text=""
                                   FontSize="9"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,6"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

                        <Grid Style="{StaticResource MetricRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Size:" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="FileSizeText" Text="0 bytes" Style="{StaticResource MetricValueStyle}"/>
                        </Grid>

                        <Grid Style="{StaticResource MetricRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Format:" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="FormatNameText" Text="Unknown" Style="{StaticResource MetricValueStyle}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Analyzed:" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="AnalysisDateText" Text="—" Style="{StaticResource MetricValueStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Data Type card -->
                <Border Style="{StaticResource CardStyle}" x:Name="DataTypeCard">
                    <StackPanel>
                        <TextBlock Text="Detected Data Type" Style="{StaticResource CardTitleStyle}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border x:Name="DataTypeBadge"
                                    Background="{DynamicResource Panel_ToolbarButtonActiveBrush}"
                                    BorderBrush="{DynamicResource PFP_BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10" Padding="10,4">
                                <TextBlock x:Name="DataTypeText"
                                           Text="Unknown"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource PFP_TextBrush}"/>
                            </Border>
                        </StackPanel>

                        <TextBlock x:Name="DataTypeDescText"
                                   Text=""
                                   FontSize="9" FontStyle="Italic"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Byte Composition card -->
                <Border Style="{StaticResource CardStyle}" x:Name="CompositionCard">
                    <StackPanel>
                        <TextBlock Text="Byte Composition" Style="{StaticResource CardTitleStyle}"/>

                        <!-- Null bytes -->
                        <Grid Style="{StaticResource MetricRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Null bytes:" Style="{StaticResource MetricLabelStyle}"/>
                            <ProgressBar Grid.Column="1" x:Name="NullBar" Height="6" Margin="0,0,6,0"
                                         Maximum="100" Foreground="{StaticResource ErrorBrush}"
                                         Background="{DynamicResource PFP_BorderBrush}"/>
                            <TextBlock Grid.Column="2" x:Name="NullPctText" Text="0.0%" Style="{StaticResource MetricValueStyle}"/>
                        </Grid>

                        <!-- Printable ASCII -->
                        <Grid Style="{StaticResource MetricRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Printable ASCII:" Style="{StaticResource MetricLabelStyle}"/>
                            <ProgressBar Grid.Column="1" x:Name="AsciiBar" Height="6" Margin="0,0,6,0"
                                         Maximum="100" Foreground="{StaticResource GoodBrush}"
                                         Background="{DynamicResource PFP_BorderBrush}"/>
                            <TextBlock Grid.Column="2" x:Name="AsciiPctText" Text="0.0%" Style="{StaticResource MetricValueStyle}"/>
                        </Grid>

                        <!-- Other bytes -->
                        <Grid Style="{StaticResource MetricRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Other bytes:" Style="{StaticResource MetricLabelStyle}"/>
                            <ProgressBar Grid.Column="1" x:Name="BinaryBar" Height="6" Margin="0,0,6,0"
                                         Maximum="100" Foreground="{StaticResource AccentBrush}"
                                         Background="{DynamicResource PFP_BorderBrush}"/>
                            <TextBlock Grid.Column="2" x:Name="BinaryPctText" Text="0.0%" Style="{StaticResource MetricValueStyle}"/>
                        </Grid>

                        <!-- Most common byte -->
                        <Grid Style="{StaticResource MetricRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Most common:" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="MostCommonByteText"
                                       Text="0x00 (0.0%)" FontFamily="Consolas" FontSize="10"
                                       Foreground="{DynamicResource PFP_ValueBrush}"/>
                        </Grid>

                        <!-- Unique bytes -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Unique bytes:" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="UniqueCountText"
                                       Text="0 / 256" FontSize="10"
                                       Foreground="{DynamicResource PFP_TextBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Health Score card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Overall Health" Style="{StaticResource CardTitleStyle}"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ProgressBar Grid.Column="0" x:Name="HealthScoreBar"
                                         Height="20" Value="95" Maximum="100"
                                         Foreground="{StaticResource GoodBrush}"/>
                            <TextBlock Grid.Column="1" x:Name="HealthScoreText"
                                       Text="95/100" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource PFP_TextBrush}"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock x:Name="HealthStatusText"
                                   Text="File structure is valid and healthy"
                                   FontSize="9" FontStyle="Italic"
                                   Foreground="{StaticResource GoodBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Entropy card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Entropy Analysis" Style="{StaticResource CardTitleStyle}"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Level:" Style="{StaticResource MetricLabelStyle}"/>
                            <ProgressBar Grid.Column="1" x:Name="EntropyBar"
                                         Height="8" Value="72" Maximum="100"
                                         Margin="0,0,8,0" Foreground="{StaticResource AccentBrush}"
                                         Background="{DynamicResource PFP_BorderBrush}"/>
                            <TextBlock Grid.Column="2" x:Name="EntropyText"
                                       Text="7.2/8.0" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource PFP_TextBrush}" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock x:Name="EntropyDescText"
                                   Text="Likely compressed or encrypted data"
                                   FontSize="9" FontStyle="Italic"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Structure & Checksums card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Validation" Style="{StaticResource CardTitleStyle}"/>

                        <Grid Style="{StaticResource MetricRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="StructureIcon" Text="✅" FontSize="14" Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Structure" FontWeight="SemiBold" FontSize="10"
                                           Foreground="{DynamicResource PFP_TextBrush}"/>
                                <TextBlock x:Name="StructureStatus" Text="Valid" FontSize="9"
                                           Foreground="{DynamicResource PFP_SubTextBrush}"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="ChecksumIcon" Text="✅" FontSize="14" Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Checksums" FontWeight="SemiBold" FontSize="10"
                                           Foreground="{DynamicResource PFP_TextBrush}"/>
                                <TextBlock x:Name="ChecksumStatus" Text="All pass" FontSize="9"
                                           Foreground="{DynamicResource PFP_SubTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Detected Issues card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Detected Issues" Style="{StaticResource CardTitleStyle}"/>

                        <ItemsControl x:Name="AnomaliesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Panel_WarningBackgroundBrush}"
                                            BorderBrush="{DynamicResource Panel_WarningBorderBrush}"
                                            BorderThickness="1" CornerRadius="3"
                                            Padding="6" Margin="0,0,0,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Panel_WarningTextBrush}"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="9" Foreground="{DynamicResource Panel_WarningTextBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoAnomaliesText" Text="✅ No issues detected"
                                   FontSize="10" Foreground="{StaticResource GoodBrush}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="WpfHexEditor.Panels.BinaryAnalysis.FileStatisticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="350">

    <UserControl.Resources>
        <!-- Semantic status brushes (constant across themes) -->
        <SolidColorBrush x:Key="GoodBrush"    Color="#7ED321"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F5A623"/>
        <SolidColorBrush x:Key="ErrorBrush"   Color="#FF6B6B"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#4A90E2"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="12"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_SubTextBrush}"/>
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PFP_PanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <TextBlock Text="File Statistics"
                       FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">

                <!-- Health Score Card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Overall Health"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PFP_AccentBrush}"
                                   Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ProgressBar Grid.Column="0" x:Name="HealthScoreBar"
                                        Height="24" Value="95" Maximum="100"
                                        Foreground="{StaticResource GoodBrush}"/>
                            <TextBlock Grid.Column="1" x:Name="HealthScoreText"
                                      Text="95/100" Style="{StaticResource MetricValueStyle}"
                                      Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock x:Name="HealthStatusText"
                                  Text="File structure is valid and healthy"
                                  FontSize="10" FontStyle="Italic"
                                  Foreground="{StaticResource GoodBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Structure Validation -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="✅" FontSize="16" Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Structure" FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource PFP_TextBrush}"/>
                            <TextBlock x:Name="StructureStatus" Text="Valid" FontSize="10"
                                       Foreground="{DynamicResource PFP_SubTextBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Checksums -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="ChecksumIcon" Text="✅" FontSize="16" Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Checksums" FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource PFP_TextBrush}"/>
                            <TextBlock x:Name="ChecksumStatus" Text="All pass" FontSize="10"
                                       Foreground="{DynamicResource PFP_SubTextBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Compression -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Compression" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource PFP_TextBrush}" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ratio:" Style="{StaticResource MetricLabelStyle}" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" x:Name="CompressionBar"
                                        Height="8" Value="87" Maximum="100"
                                        Margin="8,0,8,0" Foreground="{StaticResource WarningBrush}"/>
                            <TextBlock Grid.Column="2" x:Name="CompressionText"
                                      Text="87%" FontSize="10" FontWeight="Bold"
                                      Foreground="{DynamicResource PFP_TextBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="⚠️ Sub-optimal compression"
                                  FontSize="9" Foreground="{StaticResource WarningBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Entropy -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Entropy Analysis" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource PFP_TextBrush}" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Level:" Style="{StaticResource MetricLabelStyle}" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" x:Name="EntropyBar"
                                        Height="8" Value="72" Maximum="100"
                                        Margin="8,0,8,0" Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Grid.Column="2" x:Name="EntropyText"
                                      Text="7.2/8.0" FontSize="10" FontWeight="Bold"
                                      Foreground="{DynamicResource PFP_TextBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Likely compressed or encrypted data"
                                  FontSize="9" Foreground="{DynamicResource PFP_SubTextBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Anomalies (yellow warning — semantic, kept constant) -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Detected Issues" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource PFP_TextBrush}" Margin="0,0,0,8"/>

                        <ItemsControl x:Name="AnomaliesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF3CD" BorderBrush="#FFC107"
                                            BorderThickness="1" CornerRadius="3"
                                            Padding="6" Margin="0,0,0,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                      FontSize="10" FontWeight="SemiBold" Foreground="#5D4037"/>
                                            <TextBlock Text="{Binding Description}"
                                                      FontSize="9" Foreground="#856404"
                                                      TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoAnomaliesText" Text="✅ No issues detected"
                                  FontSize="10" Foreground="{StaticResource GoodBrush}"/>
                    </StackPanel>
                </Border>

                <!-- File Info Summary -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="File Information" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource PFP_TextBrush}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Size:"   Style="{StaticResource MetricLabelStyle}" Margin="0,0,8,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="FileSizeText"  Text="0 bytes" FontSize="10" Margin="0,0,0,4" Foreground="{DynamicResource PFP_TextBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Fields:" Style="{StaticResource MetricLabelStyle}" Margin="0,0,8,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="FieldCountText" Text="0"      FontSize="10" Margin="0,0,0,4" Foreground="{DynamicResource PFP_TextBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Format:" Style="{StaticResource MetricLabelStyle}" Margin="0,0,8,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="FormatNameText" Text="Unknown" FontSize="10" Foreground="{DynamicResource PFP_TextBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="WpfHexEditor.Panels.BinaryAnalysis.DataInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350">
    <UserControl.Resources>
        <!-- Category Color Brushes -->
        <SolidColorBrush x:Key="CategoryIntegerBrush" Color="#4A90E2"/>
        <SolidColorBrush x:Key="CategoryFloatBrush" Color="#7ED321"/>
        <SolidColorBrush x:Key="CategoryDateTimeBrush" Color="#F5A623"/>
        <SolidColorBrush x:Key="CategoryNetworkBrush" Color="#BD10E0"/>
        <SolidColorBrush x:Key="CategoryGuidBrush" Color="#50E3C2"/>
        <SolidColorBrush x:Key="CategoryColorBrush" Color="#FF6B6B"/>
        <SolidColorBrush x:Key="CategoryBasicBrush" Color="#95A5A6"/>
        <SolidColorBrush x:Key="CategoryBitsBrush" Color="#34495E"/>

        <!-- Style for category indicators -->
        <Style x:Key="CategoryIndicatorStyle" TargetType="Border">
            <Setter Property="Width" Value="4"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- Data Template for Inspector Values -->
        <DataTemplate x:Key="InspectorValueTemplate">
            <Border Padding="8,6" Margin="0,0,0,1"
                    Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Category Color Indicator -->
                    <Border Grid.Column="0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource CategoryIndicatorStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Category}" Value="Integer">
                                        <Setter Property="Background" Value="{StaticResource CategoryIntegerBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Float">
                                        <Setter Property="Background" Value="{StaticResource CategoryFloatBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Date/Time">
                                        <Setter Property="Background" Value="{StaticResource CategoryDateTimeBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Network">
                                        <Setter Property="Background" Value="{StaticResource CategoryNetworkBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="GUID">
                                        <Setter Property="Background" Value="{StaticResource CategoryGuidBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Color">
                                        <Setter Property="Background" Value="{StaticResource CategoryColorBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Basic">
                                        <Setter Property="Background" Value="{StaticResource CategoryBasicBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Category}" Value="Bits">
                                        <Setter Property="Background" Value="{StaticResource CategoryBitsBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Value Content -->
                    <StackPanel Grid.Column="1">
                        <!-- Format Name -->
                        <TextBlock Text="{Binding Format}"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>

                        <!-- Interpreted Value -->
                        <TextBlock Text="{Binding Value}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Margin="0,2,0,2"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>

                        <!-- Hex Value (smaller, grayed out) -->
                        <TextBlock Text="{Binding HexValue, StringFormat='Raw: {0}'}"
                                   FontFamily="Consolas"
                                   FontSize="9"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="🔍"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBlock Grid.Column="1"
                           Text="Data Inspector"
                           FontSize="14"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
            </Grid>
        </Border>

        <!-- Filters Toolbar -->
        <Border Grid.Row="1"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Category Filter -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                    <TextBlock Text="Category:"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"
                               FontSize="11"
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                    <ComboBox x:Name="CategoryFilterComboBox"
                              Width="120"
                              FontSize="11"
                              SelectedValue="{Binding SelectedCategory, Mode=TwoWay}">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="Integer"/>
                        <ComboBoxItem Content="Float"/>
                        <ComboBoxItem Content="Date/Time"/>
                        <ComboBoxItem Content="Network"/>
                        <ComboBoxItem Content="GUID"/>
                        <ComboBoxItem Content="Color"/>
                        <ComboBoxItem Content="Basic"/>
                        <ComboBoxItem Content="Bits"/>
                    </ComboBox>
                </StackPanel>

                <!-- Show All Formats CheckBox -->
                <CheckBox Grid.Column="2"
                          Content="Show all formats"
                          VerticalAlignment="Center"
                          IsChecked="{Binding ShowAllFormats, Mode=TwoWay}"
                          FontSize="11"
                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
            </Grid>
        </Border>

        <!-- Values List -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
            <ItemsControl x:Name="ValuesItemsControl"
                          ItemsSource="{Binding Values}"
                          ItemTemplate="{StaticResource InspectorValueTemplate}">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </ItemsControl.Template>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <TextBlock FontSize="10"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}">
                <Run Text="Interpretations: "/>
                <Run Text="{Binding Values.Count, Mode=OneWay}" FontWeight="Bold"/>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>

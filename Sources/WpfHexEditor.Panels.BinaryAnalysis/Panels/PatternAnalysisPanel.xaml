<UserControl x:Class="WpfHexEditor.Panels.BinaryAnalysis.PatternAnalysisPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350">

    <UserControl.Resources>
        <!-- Semantic brushes (constant for all themes) -->
        <SolidColorBrush x:Key="LowEntropyBrush"    Color="#7ED321"/>
        <SolidColorBrush x:Key="MediumEntropyBrush" Color="#F5A623"/>
        <SolidColorBrush x:Key="HighEntropyBrush"   Color="#FF6B6B"/>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{DynamicResource PFP_AccentBrush}"/>
            <Setter Property="Margin"       Value="0,16,0,8"/>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_SubTextBrush}"/>
            <Setter Property="Margin"     Value="0,0,8,0"/>
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"       Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="4"/>
            <Setter Property="Padding"          Value="12"/>
            <Setter Property="Margin"           Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PFP_PanelBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12">

                <!-- Header -->
                <TextBlock Text="Pattern Analysis"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource PFP_TextBrush}"
                           Margin="0,0,0,12"/>

                <!-- Analysis Status Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="StatusCard">
                    <StackPanel>
                        <TextBlock x:Name="StatusTextBlock"
                                   Text="Click 'Analyze' to start"
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"/>
                        <Button x:Name="AnalyzeButton"
                                Content="Analyze Selection"
                                Height="32" Margin="0,8,0,0"
                                Background="{DynamicResource Panel_ToolbarBrush}"
                                BorderBrush="{DynamicResource PFP_BorderBrush}"
                                Foreground="{DynamicResource PFP_TextBrush}"
                                Click="AnalyzeButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- Entropy Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="EntropyCard" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Entropy Analysis" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Entropy:" Style="{StaticResource MetricLabelStyle}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock x:Name="EntropyValueText" Text="0.00" Style="{StaticResource MetricValueStyle}"/>
                                <TextBlock Text="/ 8.0 bits" FontSize="10"
                                           Foreground="{DynamicResource PFP_SubTextBrush}"
                                           Margin="4,0,0,0" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
                            </StackPanel>
                        </Grid>

                        <!-- Entropy progress track -->
                        <Border Height="8" Background="{DynamicResource PFP_BorderBrush}" CornerRadius="4" Margin="0,0,0,8">
                            <Border x:Name="EntropyBar"
                                    HorizontalAlignment="Left"
                                    CornerRadius="4"
                                    Background="{StaticResource MediumEntropyBrush}"/>
                        </Border>

                        <TextBlock x:Name="EntropyInterpretation"
                                   Text="Medium randomness"
                                   FontSize="10" FontStyle="Italic"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Byte Distribution Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="DistributionCard" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Byte Distribution" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>

                        <Border Height="150"
                                Background="{DynamicResource PFP_PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource PFP_BorderBrush}"
                                BorderThickness="1" Padding="4" Margin="0,0,0,8">
                            <Canvas x:Name="HistogramCanvas"/>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Most frequent:" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="MostFrequentByteText"
                                       Text="0x00" FontFamily="Consolas"
                                       Foreground="{DynamicResource PFP_TextBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Unique bytes:" Style="{StaticResource MetricLabelStyle}" Margin="0,4,8,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="UniqueBytesText"
                                       Text="0 / 256" Margin="0,4,0,0"
                                       Foreground="{DynamicResource PFP_TextBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Detected Patterns Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="PatternsCard" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Detected Patterns" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>

                        <ItemsControl x:Name="PatternsListBox">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource PFP_ItemHoverBrush}"
                                            BorderBrush="{DynamicResource PFP_BorderBrush}"
                                            BorderThickness="1" CornerRadius="3"
                                            Padding="8" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Pattern}"
                                                           FontFamily="Consolas" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PFP_TextBrush}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="9" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource PFP_SubTextBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoPatternsText"
                                   Text="No significant patterns detected"
                                   FontSize="10" FontStyle="Italic"
                                   Foreground="{DynamicResource PFP_SubTextBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Anomalies Card (yellow warning — semantic, kept constant) -->
                <Border Style="{StaticResource CardStyle}" x:Name="AnomaliesCard" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⚠️ Anomalies" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>

                        <ItemsControl x:Name="AnomaliesListBox">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF3CD" BorderBrush="#FFC107"
                                            BorderThickness="1" CornerRadius="3"
                                            Padding="8" Margin="0,0,0,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold" FontSize="10"
                                                       Foreground="#5D4037"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="9" Foreground="#856404"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoAnomaliesText"
                                   Text="✅ No anomalies detected"
                                   FontSize="10"
                                   Foreground="{DynamicResource PFP_AccentBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

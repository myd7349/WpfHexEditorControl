<Window x:Class="WpfHexEditor.ProjectSystem.Dialogs.AddNewItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Item"
        Width="560" Height="300"
        MinWidth="460" MinHeight="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,5" />
            <Setter Property="MinWidth" Value="80" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Template picker -->
        <Label Grid.Row="0" Grid.Column="0" Content="_Template:"
               VerticalAlignment="Top" Padding="0,4,8,0"/>
        <ListBox x:Name="TemplateList"
                 Grid.Row="0" Grid.Column="1"
                 Background="{DynamicResource DockBackgroundBrush}"
                 BorderBrush="{DynamicResource DockBorderBrush}"
                 SelectionChanged="OnTemplateSelectionChanged" />

        <!-- File name -->
        <Label Grid.Row="2" Grid.Column="0" Content="_Name:" Target="{Binding ElementName=NameBox}" />
        <TextBox x:Name="NameBox" Grid.Row="2" Grid.Column="1"
                 TextChanged="OnInputChanged" />

        <!-- Virtual folder -->
        <Label Grid.Row="4" Grid.Column="0" Content="_Folder:" />
        <ComboBox x:Name="FolderCombo" Grid.Row="4" Grid.Column="1" />

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="Add" IsDefault="True"
                    IsEnabled="False" Click="OnOk" Margin="0,0,8,0" />
            <Button Content="Cancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="WpfHexEditor.ProjectSystem.Dialogs.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Project"
        Width="520" Height="240"
        MinWidth="400" MinHeight="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,5" />
            <Setter Property="MinWidth" Value="80" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Name -->
        <Label Grid.Row="0" Grid.Column="0" Content="_Name:" Target="{Binding ElementName=NameBox}" />
        <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                 TextChanged="OnNameOrLocationChanged" />

        <!-- Location -->
        <Label Grid.Row="2" Grid.Column="0" Content="_Location:" Target="{Binding ElementName=LocationBox}" />
        <TextBox x:Name="LocationBox" Grid.Row="2" Grid.Column="1"
                 TextChanged="OnNameOrLocationChanged" />
        <Button Grid.Row="2" Grid.Column="3" Content="..." Width="30" Padding="0"
                Click="OnBrowseLocation" ToolTip="Browse for folder" />

        <!-- Preview -->
        <Label Grid.Row="4" Grid.Column="0" Content="Will create:" />
        <TextBlock x:Name="PreviewText" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                   Foreground="{DynamicResource DockTabTextBrush}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   FontStyle="Italic" />

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="4"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="OK" IsDefault="True"
                    IsEnabled="False" Click="OnOk" Margin="0,0,8,0" />
            <Button Content="Cancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="WpfHexEditor.ProjectSystem.Dialogs.NewFileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New File"
        Width="560" Height="320"
        MinWidth="460" MinHeight="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,5" />
            <Setter Property="MinWidth" Value="80" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Template picker -->
        <Label Grid.Row="0" Grid.Column="0" Content="_Template:"
               VerticalAlignment="Top" Padding="0,4,8,0"/>
        <ListBox x:Name="TemplateList"
                 Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                 Background="{DynamicResource DockBackgroundBrush}"
                 BorderBrush="{DynamicResource DockBorderBrush}"
                 SelectionChanged="OnTemplateSelectionChanged" />

        <!-- File name -->
        <Label Grid.Row="2" Grid.Column="0" Content="_Name:" Target="{Binding ElementName=NameBox}" />
        <TextBox x:Name="NameBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                 TextChanged="OnInputChanged" />

        <!-- Location (optional — disabled when "save later" is checked) -->
        <CheckBox x:Name="SaveLaterCheck"
                  Grid.Row="4" Grid.Column="0"
                  Content="_Save later"
                  ToolTip="Create document in memory; save location chosen on first Ctrl+S"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  VerticalAlignment="Center"
                  Checked="OnSaveLaterChanged"
                  Unchecked="OnSaveLaterChanged" />
        <TextBox x:Name="LocationBox" Grid.Row="4" Grid.Column="1"
                 TextChanged="OnInputChanged" />
        <Button x:Name="BrowseButton" Grid.Row="4" Grid.Column="3" Content="..." Width="30" Padding="0"
                Click="OnBrowseLocation" ToolTip="Browse for folder" />

        <!-- Add to project row -->
        <CheckBox x:Name="AddToProjectCheck"
                  Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                  Content="Add to _project:"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  VerticalAlignment="Center"
                  Checked="OnAddToProjectChanged"
                  Unchecked="OnAddToProjectChanged" />
        <ComboBox x:Name="ProjectCombo"
                  Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="2"
                  IsEnabled="False"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Background="{DynamicResource DockBackgroundBrush}"
                  BorderBrush="{DynamicResource DockBorderBrush}" />

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="4"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="OK" IsDefault="True"
                    IsEnabled="False" Click="OnOk" Margin="0,0,8,0" />
            <Button Content="Cancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>

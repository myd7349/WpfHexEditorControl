<Window x:Class="WpfHexEditor.ProjectSystem.Dialogs.ImportEmbeddedFormatDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Built-in Format Definition"
        Width="920" Height="540"
        MinWidth="680" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.ProjectSystem;component/Themes/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Search box — overrides base with Padding=6,3 -->
            <Style TargetType="TextBox">
                <Setter Property="Foreground"               Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Setter Property="Background"               Value="{DynamicResource DockBackgroundBrush}"/>
                <Setter Property="BorderBrush"              Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="CaretBrush"               Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Setter Property="Padding"                  Value="6,3"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

        <!-- ── ListView item — ErrorPanel style ─────────────────────────── -->
        <Style TargetType="ListViewItem">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource ERR_GridLinesBrush}"
                                BorderThickness="0,0,0,1"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  Margin="4,3"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background"
                                        Value="{DynamicResource ERR_HoverRowBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background"
                                        Value="{DynamicResource ERR_SelectedRowBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"   Value="True"/>
                                    <Condition Property="IsMouseOver"  Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBd" Property="Background"
                                        Value="{DynamicResource ERR_SelectedRowBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── GridView column header ────────────────────────────────────── -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"  Value="{DynamicResource ERR_HeaderBrush}"/>
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding"     Value="8,4"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ERR_GridLinesBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border x:Name="Hd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Hd" Property="Background"
                                        Value="{DynamicResource ERR_HeaderHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Filter bar -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>     <!-- List + description -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>  <!-- Folder picker -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>  <!-- Status + buttons -->
        </Grid.RowDefinitions>

        <!-- ── Filter bar ──────────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="_Category:"/>
            <ComboBox x:Name="CategoryCombo" Grid.Column="1"
                      Style="{StaticResource DockComboBoxStyle}"
                      SelectionChanged="OnFilterChanged"/>
            <Label Grid.Column="3" Content="_Search:"/>
            <TextBox x:Name="SearchBox" Grid.Column="4"
                     TextChanged="OnFilterChanged"/>
        </Grid>

        <!-- ── List + description ─────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <!-- Grouped multi-select ListView -->
            <ListView x:Name="FormatList"
                      Grid.Column="0"
                      SelectionMode="Extended"
                      Background="{DynamicResource DockBackgroundBrush}"
                      BorderBrush="{DynamicResource DockBorderBrush}"
                      BorderThickness="1"
                      VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                      SelectionChanged="OnSelectionChanged">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name"       Width="210"
                                        DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Extensions" Width="110"
                                        DisplayMemberBinding="{Binding ExtensionsDisplay}"/>
                        <GridViewColumn Header="Quality"    Width="65"
                                        DisplayMemberBinding="{Binding QualityDisplay}"/>
                    </GridView>
                </ListView.View>

                <!-- Category group headers -->
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <StackPanel>
                                                <Border Background="{DynamicResource ERR_HeaderBrush}"
                                                        BorderBrush="{DynamicResource ERR_GridLinesBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="10,4">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                                </Border>
                                                <ItemsPresenter/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListView.GroupStyle>
            </ListView>

            <!-- ── Detail panel ──────────────────────────────────────── -->
            <Border Grid.Column="2"
                    Background="{DynamicResource DockBackgroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel>

                        <!-- Name -->
                        <TextBlock x:Name="DescNameText"
                                   FontWeight="SemiBold" FontSize="14"
                                   TextWrapping="Wrap" Margin="0,0,0,2"/>

                        <!-- Category -->
                        <TextBlock x:Name="DescCategoryText"
                                   FontStyle="Italic" Opacity="0.65"
                                   FontSize="11" Margin="0,0,0,8"/>

                        <!-- Separator -->
                        <Rectangle Height="1" Margin="0,0,0,8"
                                   Fill="{DynamicResource DockBorderBrush}"/>

                        <!-- Description -->
                        <TextBlock x:Name="DescText"
                                   TextWrapping="Wrap" FontSize="12"
                                   Margin="0,0,0,10"/>

                        <!-- Version (collapsed when empty) -->
                        <Grid x:Name="DescVersionRow" Margin="0,0,0,3"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Version:" Opacity="0.65" FontSize="11"/>
                            <TextBlock x:Name="DescVersionText" Grid.Column="1"
                                       FontSize="11" TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Author (collapsed when empty) -->
                        <Grid x:Name="DescAuthorRow" Margin="0,0,0,10"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Author:" Opacity="0.65" FontSize="11"/>
                            <TextBlock x:Name="DescAuthorText" Grid.Column="1"
                                       FontSize="11" TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Extensions label -->
                        <TextBlock Text="Extensions" Opacity="0.65"
                                   FontSize="11" Margin="0,0,0,4"/>

                        <!-- Extension badges (populated in code-behind) -->
                        <WrapPanel x:Name="DescExtWrap" Margin="0,0,0,10"/>

                        <!-- Quality label -->
                        <TextBlock Text="Quality" Opacity="0.65"
                                   FontSize="11" Margin="0,0,0,4"/>

                        <!-- Quality bar + percentage -->
                        <Grid>
                            <ProgressBar x:Name="DescQualityBar"
                                         Minimum="0" Maximum="100"
                                         Height="6" Value="0"
                                         Foreground="{DynamicResource AccentBrush}"
                                         Background="{DynamicResource ERR_GridLinesBrush}"
                                         BorderThickness="0"/>
                        </Grid>
                        <TextBlock x:Name="DescQualityText"
                                   FontSize="11" Opacity="0.8"
                                   Margin="0,3,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Target folder ──────────────────────────────────────────── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="_Destination folder:"/>
            <ComboBox x:Name="FolderCombo" Grid.Column="1"
                      Style="{StaticResource DockComboBoxStyle}"/>
        </Grid>

        <!-- ── Status + buttons ───────────────────────────────────────── -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="SelectionCountText"
                       VerticalAlignment="Center" Opacity="0.7"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="ImportButton" Content="_Import" IsDefault="True"
                        IsEnabled="False" Click="OnImport" Margin="0,0,8,0"/>
                <Button Content="Cancel" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

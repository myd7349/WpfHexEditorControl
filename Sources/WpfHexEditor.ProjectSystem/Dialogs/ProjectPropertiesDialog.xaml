<Window x:Class="WpfHexEditor.ProjectSystem.Dialogs.ProjectPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project Properties"
        Width="480" Height="320"
        MinWidth="380" MinHeight="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.ProjectSystem;component/Themes/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- TextBlock uses DockTabTextBrush in this dialog -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground"        Value="{DynamicResource DockTabTextBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin"     Value="0,0,0,6" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" x:Name="ProjectTitleText"
                   FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,16" />

        <!-- Properties grid -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="Name:" />
            <TextBlock x:Name="NameText" Grid.Row="0" Grid.Column="1" />

            <Label Grid.Row="1" Grid.Column="0" Content="Project file:" />
            <TextBlock x:Name="FilePathText" Grid.Row="1" Grid.Column="1"
                       TextTrimming="CharacterEllipsis"
                       ToolTipService.ShowDuration="10000">
                <TextBlock.ToolTip>
                    <ToolTip>
                        <TextBlock x:Name="FilePathTooltip" />
                    </ToolTip>
                </TextBlock.ToolTip>
            </TextBlock>

            <Label Grid.Row="2" Grid.Column="0" Content="Directory:" />
            <TextBlock x:Name="DirectoryText" Grid.Row="2" Grid.Column="1"
                       TextTrimming="CharacterEllipsis" />

            <Label Grid.Row="3" Grid.Column="0" Content="Files:" />
            <TextBlock x:Name="ItemCountText" Grid.Row="3" Grid.Column="1" />

            <Label Grid.Row="4" Grid.Column="0" Content="Default TBL:" />
            <TextBlock x:Name="DefaultTblText" Grid.Row="4" Grid.Column="1" />

            <Label Grid.Row="5" Grid.Column="0" Content="Modified:" />
            <TextBlock x:Name="IsModifiedText" Grid.Row="5" Grid.Column="1" />
        </Grid>

        <!-- Close button -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" IsCancel="True" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>

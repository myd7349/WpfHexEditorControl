      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "version": "",
    "entityCount": 0,
    "layerCount": 0,
    "ole2Signature": "",
    "minorVersion": 0,
    "majorVersion": 0
  },
  "blocks": [

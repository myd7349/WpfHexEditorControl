{
  "formatName": "Windows Shortcut",
  "version": "1.12",
  "extensions": [
    ".lnk"
  ],
  "description": "Windows shell link (shortcut)",
  "category": "System",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Windows Shortcut Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/LNK"
    ]
  },
  "detection": {
    "signature": "4C0000000114020000000000C0000000",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 16,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "flags": 0,
    "attributes": 0,
    "targetSize": 0,
    "iconIndex": 0,
    "headerSize": 0,
    "linkClsid": "",
    "linkFlags": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "Header Size",
      "offset": 0,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Size of header (0x0000004C = 76 bytes)",
      "storeAs": "headerSize",
      "valueType": "uint32"
    },
    {
      "type": "signature",
      "name": "Link CLSID",
      "offset": 4,
      "length": 16,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Shell link class identifier",
      "storeAs": "linkClsid",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Link Flags",
      "offset": 20,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Shortcut flags",
      "storeAs": "linkFlags",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "Flags",
      "variable": "flags",
      "description": "Flags"
    },
    {
      "type": "metadata",
      "name": "File Attributes",
      "variable": "attributes",
      "description": "File Attributes"
    }
  ],
  "software": [
    "Windows Explorer",
    "LNK analyzers",
    "Forensic tools"
  ],
  "format_relationships": {

{
  "formatName": "Java KeyStore (JKS)",
  "version": "1.12",
  "extensions": [
    ".jks",
    ".keystore"
  ],
  "description": "Java KeyStore - Encrypted key and certificate storage",
  "category": "Crypto",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Java KeyStore (JKS) Format Specification",
      "Java Cryptography Architecture (JCA)",
      "KeyTool Documentation"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/Java_KeyStore",
      "https://docs.oracle.com/cd/E19509-01/820-3503/ggfen/index.html",
      "https://www.baeldung.com/java-keystore",
      "https://pyjks.readthedocs.io/en/latest/_modules/jks/jks.html"
    ]
  },
  "detection": {
    "signature": "FEEDFEED",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 4,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "version": 0,
    "serialNumber": "",
    "issuer": "",
    "subject": "",
    "jksMagic": "",
    "entryCount": 0,
    "entryType": "",
    "aliasLength": 0,
    "alias": "",
    "timestamp": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "JKS Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "JKS magic number (0xFEEDFEED)",
      "storeAs": "jksMagic",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Version",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "KeyStore version (2)",
      "storeAs": "version",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Entry Count",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Number of entries in keystore",
      "storeAs": "entryCount",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Entry Type",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "First entry type (1=private, 2=trusted cert)",
      "storeAs": "entryType",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Alias Length",
      "offset": 16,
      "length": 2,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "UTF-16 length of entry alias",
      "storeAs": "aliasLength",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Alias",
      "offset": 18,
      "length": 64,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Entry alias (UTF-16)",
      "storeAs": "alias",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Timestamp",
      "offset": 82,
      "length": 8,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Entry creation timestamp (milliseconds)",
      "storeAs": "timestamp",
      "valueType": "uint64"
    },
    {
      "type": "metadata",
      "name": "Version",
      "variable": "version",
      "description": "Version"
    },
    {
      "type": "metadata",
      "name": "Serial Number",
      "variable": "serialNumber",
      "description": "Serial Number"
    },
    {
      "type": "metadata",
      "name": "Subject",
      "variable": "subject",
      "description": "Subject"
    }
  ],
  "software": [
    "Common file viewers",
    "Specialized software"
  ],
  "format_relationships": {
    "category": "Crypto",
    "extensions": [
      ".jks",
      ".keystore"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Hex Editor",
    "File Viewer",
    "Archive Manager"
  ],
  "UseCases": [
    "File storage",
    "Data exchange",
    "Archive"
  ],
  "QualityMetrics": {
    "CompletenessScore": 56,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 10,
    "ValidationRules": 0,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt32BE": "Read certificate",
    "extractASCIIString": "Read subject"
  }
}

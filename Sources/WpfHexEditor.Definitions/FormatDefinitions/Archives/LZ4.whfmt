    "flgByte": 0,
    "bdByte": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "LZ4 Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "LZ4 frame header",
      "storeAs": "lz4Magic",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "FLG Byte",
      "offset": 4,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Frame flags",
      "storeAs": "flgByte",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "BD Byte",
      "offset": 5,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Block descriptor",
      "storeAs": "bdByte",
      "valueType": "uint8"
    },
    {
      "type": "metadata",
      "name": "Frame Flags",
      "variable": "frameFlags",
      "description": "LZ4 frame configuration flags"
    },
    {
      "type": "metadata",
      "name": "Block Descriptor",
      "variable": "blockDescriptor",
      "description": "Block size and independence flags"

      "max_signature_offset": 1024
    }
  },
  "functions": {
    "calculateCRC32": "Calculate CRC-32 for frame integrity"
  },
  "variables": {
    "currentOffset": 0,
    "frameFlags": 0,
    "blockDescriptor": 0,

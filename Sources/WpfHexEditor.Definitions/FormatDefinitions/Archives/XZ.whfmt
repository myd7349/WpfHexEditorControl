      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Stream Flags",
      "offset": 6,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Stream header flags",
      "storeAs": "streamFlags",
      "valueType": "uint16"
    },
    {
      "type": "metadata",
      "name": "Stream Flags",

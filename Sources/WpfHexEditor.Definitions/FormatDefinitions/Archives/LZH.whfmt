{
  "formatName": "LZH Archive",
  "version": "1.11",
  "extensions": [
    ".lzh",
    ".lha"
  ],
  "description": "LHA/LZH compressed archive",
  "category": "Archives",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "LHA/LZH Archive Format - Haruyasu Yoshizaki",
      "LZH Compression Algorithm Specification",
      "LZSS and Huffman Encoding in LHA"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/LHA_(file_format)",
      "http://fileformats.archiveteam.org/wiki/LHA",
      "https://github.com/jca02266/lha",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000339.shtml"
    ]
  },
  "detection": {
    "signature": "2D6C68",
    "offset": 2,
    "required": true,
    "validation": {
      "min_file_size": 3,
      "max_signature_offset": 1024
    }
  },
  "functions": {
    "calculateCRC32": "Calculate header checksum",
    "extractASCIIString": "Extract compression method ID"
  },
  "variables": {
    "currentOffset": 0,
    "headerSize": 0,
    "headerChecksum": 0,
    "methodID": "",
    "methodId": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "Header Size",
      "offset": 0,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Size of header",
      "storeAs": "headerSize",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Header Checksum",
      "offset": 1,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Header checksum",
      "storeAs": "headerChecksum",
      "valueType": "uint8"
    },
    {
      "type": "signature",
      "name": "Method ID",
      "offset": 2,
      "length": 3,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "-lh compression method",
      "storeAs": "methodId",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Header Size",
      "variable": "headerSize",
      "description": "Size of the LZH header"
    },
    {
      "type": "metadata",
      "name": "Compression Method",
      "variable": "methodID",
      "description": "Compression method identifier (e.g., -lh5-, -lh6-)"
    }
  ],
  "software": [
    "LHA",
    "7-Zip",
    "WinRAR"
  ],
  "format_relationships": {
    "legacy_format": true,
    "popular_in": "Japan",
    "related": [
      "LHA"
    ]
  },
  "MimeTypes": [
    "application/x-lzh-compressed"
  ],
  "Software": [
    "7-Zip",
    "WinRAR",
    "WinZip",
    "PeaZip",
    "The Unarchiver"
  ],
  "UseCases": [
    "File compression",
    "Archive storage",
    "Backup",
    "Distribution"
  ],
  "QualityMetrics": {
    "CompletenessScore": 38,
    "DocumentationLevel": "standard",
    "BlocksDefined": 5,
    "ValidationRules": 0,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {
    "ArchivesFormat": true,
    "SupportsEncryption": false
  }
}

{
  "formatName": "ARJ Archive",
  "version": "1.10",
  "extensions": [
    ".arj"
  ],
  "description": "ARJ compressed archive format",
  "category": "Archives",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ARJ Archive Format Specification - Robert K. Jung",
      "ARJ File Format Technical Documentation",
      "ARJ Compression Algorithm"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/ARJ",
      "http://fileformats.archiveteam.org/wiki/ARJ",
      "https://github.com/FarGroup/FarManager/blob/master/plugins/multiarc/arc.doc/arj.txt",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000337.shtml"
    ]
  },
  "detection": {
    "signature": "60EA",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 2,
      "max_signature_offset": 1024
    }
  },
  "functions": {
    "calculateCRC32": "Calculate CRC-32 for archive integrity"
  },
  "variables": {
    "currentOffset": 0,
    "headerID": 0,
    "arjSignature": 0,
    "headerId": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "ARJ Signature",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "ARJ archive marker",
      "storeAs": "arjSignature",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Header ID",
      "offset": 2,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Basic header ID",
      "storeAs": "headerId",
      "valueType": "uint16"
    },
    {
      "type": "metadata",
      "name": "Header ID",
      "variable": "headerID",
      "description": "ARJ basic header identifier"
    }
  ],
  "software": [
    "ARJ",
    "7-Zip",
    "WinRAR"
  ],
  "format_relationships": {
    "category": "Archives",
    "extensions": [
      ".arj"
    ]
  },
  "MimeTypes": [
    "application/x-arj-compressed"
  ],
  "Software": [
    "7-Zip",
    "WinRAR",
    "WinZip",
    "PeaZip",
    "The Unarchiver"
  ],
  "UseCases": [
    "File compression",
    "Archive storage",
    "Backup",
    "Distribution"
  ],
  "QualityMetrics": {
    "CompletenessScore": 32,
    "DocumentationLevel": "standard",
    "BlocksDefined": 3,
    "ValidationRules": 0,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {
    "ArchivesFormat": true,
    "SupportsEncryption": false
  }
}

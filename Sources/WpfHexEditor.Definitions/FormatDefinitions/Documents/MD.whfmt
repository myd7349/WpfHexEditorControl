{
  "formatName": "Markdown Document",
  "version": "1.0",
  "extensions": [".md", ".markdown", ".mkd", ".mdx"],
  "description": "GitHub-Flavored Markdown document with support for tables, task lists, Mermaid diagrams, and code fences.",
  "category": "Documents",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "markdown-editor",
  "detection": {
    "isTextFormat": true,
    "required": false
  },
  "QualityMetrics": {
    "CompletenessScore": 90,
    "DocumentationLevel": "standard",
    "BlocksDefined": 0,
    "ValidationRules": 0,
    "LastUpdated": "2026-03-22",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "MimeTypes": [
    "text/markdown",
    "text/x-markdown"
  ],
  "Software": [
    "Visual Studio Code",
    "Typora",
    "Obsidian",
    "GitHub",
    "GitLab"
  ],
  "UseCases": [
    "Documentation",
    "README files",
    "Technical writing",
    "Note taking",
    "Changelogs"
  ]
}

  "detection": {
    "signature": "FEEDFACE",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 4,
      "max_signature_offset": 1024
    }
  },
  "functions": {
    "readUInt32BE": "Read 32-bit big-endian for magic, CPU type, file type",
    "readUInt32LE": "Read 32-bit little-endian (depends on endianness)",
    "readUInt64BE": "Read 64-bit values in 64-bit Mach-O files",
    "calculateSHA256": "Calculate SHA256 hash for code signing verification"
  },
  "variables": {
    "currentOffset": 0,
    "magic": "Unknown",
    "cpuType": "Unknown",
    "cpuSubtype": "Unknown",
    "fileType": "Unknown",
    "loadCommands": 0,
    "is64Bit": false,
    "entryPoint": 0,
    "machOMagic32Bit": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Mach-O Magic (32-bit)",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "0xFEEDFACE for 32-bit, 0xFEEDFACF for 64-bit",
      "storeAs": "machOMagic32Bit",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "CPU Type",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Target CPU architecture",
      "storeAs": "cpuType",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "CPU Subtype",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Machine specifier",
      "storeAs": "cpuSubtype",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "File Type",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Object, Execute, Library, etc.",
      "storeAs": "fileType",
      "valueType": "ascii"
    }
  ],
  "software": [

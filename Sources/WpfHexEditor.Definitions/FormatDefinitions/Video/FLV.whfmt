      "name": "Data Offset",
      "offset": 5,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Offset to first tag",
      "storeAs": "dataOffset",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "Total Pixels",
      "variable": "totalPixels",
      "description": "Width x Height"

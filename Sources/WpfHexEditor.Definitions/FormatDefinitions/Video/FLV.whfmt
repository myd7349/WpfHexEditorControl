      "type": "field",
      "name": "Type Flags",
      "offset": 4,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Audio/Video presence flags",
      "storeAs": "typeFlags",
      "valueType": "uint8"
    },

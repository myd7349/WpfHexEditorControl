{
  "formatName": "JSON Data",
  "version": "2.0",
  "extensions": [
    ".json"
  ],
  "description": "JavaScript Object Notation - a lightweight text-based data interchange format. JSON files begin with either an opening brace { for objects or an opening bracket [ for arrays. Optionally preceded by a UTF-8 BOM.",
  "category": "Data",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ECMA-404 - The JSON Data Interchange Standard",
      "RFC 8259 - The JavaScript Object Notation (JSON) Data Interchange Format",
      "ISO/IEC 21778:2017 - Information technology - JSON"
    ],
    "WebLinks": [
      "https://www.json.org/json-en.html",
      "https://www.ecma-international.org/publications-and-standards/standards/ecma-404/",
      "https://datatracker.ietf.org/doc/html/rfc8259",
      "https://en.wikipedia.org/wiki/JSON"
    ]
  },
  "detection": {
    "signature": "7B",
    "offset": 0,
    "required": false,
    "validation": {
      "minFileSize": 2,
      "maxSignatureOffset": 3
    }
  },
  "variables": {
    "currentOffset": 0,
    "openingCharacter": 0,
    "firstContentCharacter": 0
  },
  "functions": {
    "detectBOM": "Detect byte order mark (EF BB BF for UTF-8) that may precede JSON content and adjust parsing offset accordingly"
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Opening Character",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "First structural character: { (0x7B) for a JSON object or [ (0x5B) for a JSON array",
      "storeAs": "openingCharacter",
      "valueType": "uint8",
      "valueMap": {
        "123": "Object {",
        "91": "Array ["
      }
    },
    {
      "type": "field",
      "name": "First Content Character",
      "offset": 1,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "First character after the opening delimiter - typically a quote (\"), whitespace, or nested structure character",
      "storeAs": "firstContentCharacter",
      "valueType": "uint8"
    }
  ],
  "MimeTypes": [
    "application/json"
  ],
  "Software": [
    "Text editors (VS Code, Notepad++, Sublime Text)",
    "Web browsers (Chrome, Firefox, Edge)",
    "REST clients (Postman, Insomnia)",
    "All modern programming languages"
  ],
  "UseCases": [
    "REST API request and response payloads",
    "Application configuration (package.json, tsconfig.json)",
    "Data exchange between services",
    "NoSQL database storage (MongoDB, CouchDB)"
  ],
  "QualityMetrics": {
    "CompletenessScore": 38,
    "DocumentationLevel": "standard",
    "BlocksDefined": 2,
    "ValidationRules": 2,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "TextFormat": true,
    "Encoding": "UTF-8 (required by RFC 8259)",
    "StrictSyntax": true,
    "TrailingCommas": "Not allowed per specification",
    "Comments": "Not allowed per specification"
  }
}
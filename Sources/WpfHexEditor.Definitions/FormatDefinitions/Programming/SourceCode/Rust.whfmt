{
  "formatName": "Rust Source File",
  "version": "2.0",
  "extensions": [
    ".rs"
  ],
  "description": "Rust programming language source file.",
  "category": "Programming",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "code-editor",
  "detection": {
    "isTextFormat": true,
    "required": false
  },
  "QualityMetrics": {
    "CompletenessScore": 80,
    "DocumentationLevel": "standard",
    "BlocksDefined": 0,
    "ValidationRules": 0,
    "LastUpdated": "2026-03-22",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "MimeTypes": [
    "text/x-rustsrc"
  ],
  "Software": [
    "VS Code",
    "CLion",
    "RustRover"
  ],
  "UseCases": [
    "Systems programming",
    "WebAssembly",
    "Embedded development"
  ],
  "syntaxDefinition": {
    "id": "rust",
    "name": "Rust",
    "extensions": [
      ".rs"
    ],
    "lineCommentPrefix": "//",
    "blockCommentStart": "/*",
    "blockCommentEnd": "*/",
    "rules": [
      {
        "type": "BlockComment",
        "pattern": "/\\*[\\s\\S]*?\\*/",
        "colorKey": "TE_Comment"
      },
      {
        "type": "String",
        "pattern": "(r#*\"[\\s\\S]*?\"#*|b?\"(?:[^\"\\\\]|\\\\.)*\"|b?'(?:[^'\\\\]|\\\\.)*')",
        "colorKey": "TE_String"
      },
      {
        "type": "Comment",
        "pattern": "//.*$",
        "colorKey": "TE_Comment"
      },
      {
        "type": "Keyword",
        "pattern": "\\b(as|async|await|break|const|continue|crate|dyn|else|enum|extern|false|fn|for|if|impl|in|let|loop|match|mod|move|mut|pub|ref|return|self|Self|static|struct|super|trait|true|type|unsafe|use|where|while|abstract|become|box|do|final|macro|override|priv|try|typeof|unsized|virtual|yield)\\b",
        "colorKey": "TE_Keyword"
      },
      {
        "type": "Type",
        "pattern": "\\b(bool|char|f32|f64|i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|str|String|Vec|Box|Option|Result|HashMap|HashSet|BTreeMap|BTreeSet|Rc|Arc|Cell|RefCell|Mutex|RwLock|Cow)\\b",
        "colorKey": "TE_Type"
      },
      {
        "type": "Macro",
        "pattern": "\\b[a-z_][a-z0-9_]*!",
        "colorKey": "TE_Directive"
      },
      {
        "type": "Attribute",
        "pattern": "#!?\\[.*?\\]",
        "colorKey": "TE_Directive"
      },
      {
        "type": "Lifetime",
        "pattern": "'[a-zA-Z_][a-zA-Z0-9_]*\\b",
        "colorKey": "TE_Label"
      },
      {
        "type": "Number",
        "pattern": "\\b(0x[0-9A-Fa-f_]+[uif]?(?:8|16|32|64|128|size)?|0b[01_]+[uif]?(?:8|16|32|64|128|size)?|0o[0-7_]+[uif]?(?:8|16|32|64|128|size)?|[0-9][0-9_]*(?:\\.[0-9_]+)?(?:[eE][+-]?[0-9_]+)?[uif]?(?:8|16|32|64|128|size)?)\\b",
        "colorKey": "TE_Number"
      },
      {
        "type": "MethodCall",
        "pattern": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()",
        "colorKey": "TE_Label"
      }
    ],
    "foldingRules": {
      "startPatterns": [
        "\\{"
      ],
      "endPatterns": [
        "\\}"
      ]
    }
  }
}

    "ValidationRules": 0,
    "LastUpdated": "2026-03-07",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "MimeTypes": ["text/markdown"],
  "Software": ["VS Code", "Typora", "Obsidian"],
  "UseCases": ["Documentation", "README files", "Static site content"]
}

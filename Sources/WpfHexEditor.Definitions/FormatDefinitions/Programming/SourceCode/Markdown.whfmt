{
  "formatName": "Markdown Document",
  "version": "1.0",
  "extensions": [".md", ".markdown", ".mkd", ".mdx"],
  "description": "Markdown lightweight markup language document.",
  "category": "Programming",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "text-editor",
  "detection": {
    "isTextFormat": true,
    "required": false

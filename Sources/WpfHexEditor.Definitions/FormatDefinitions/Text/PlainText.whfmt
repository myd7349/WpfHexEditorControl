{
  "formatName": "Plain Text",
  "version": "1.5",
  "extensions": [
    ".txt",
    ".text"
  ],
  "description": "Plain text document with character encoding support (ASCII, UTF-8, UTF-16)",
  "author": "Derek Tremblay",
  "preferredEditor": "text-editor",
  "category": "Text Documents",
  "detection": {
    "signature": null,
    "offset": 0,
    "required": false,
    "strength": 0,
    "isTextFormat": true,
    "contentPatterns": [
      "^[\\x20-\\x7E\\x09\\x0A\\x0D]+$",
      "^[\\w\\s\\p{P}]+$"
    ],
    "minConfidenceThreshold": 0.7
  },
  "mimeTypes": [
    "text/plain",
    "text/plain; charset=utf-8",
    "application/txt",
    "text/x-log",
    "text/markdown",
    "text/csv"
  ],
  "useCases": [
    "Configuration files (.ini, .conf, .cfg)",
    "Log files and debugging output",
    "Source code files (.cs, .js, .py, .java)",
    "Documentation and README files",
    "Data export/import (CSV, TSV)",
    "Notes and memos",
    "Scripts and batch files"
  ],
  "qualityMetrics": {
    "completenessScore": 90,
    "documentationLevel": "Comprehensive",
    "blocksDefined": 5,
    "validationRules": 3,
    "lastUpdated": "2026-02-23",
    "priorityFormat": false,
    "autoRefined": true
  },
  "references": {
    "specifications": [
      "ASCII - ANSI X3.4-1986",
      "UTF-8 - RFC 3629",
      "UTF-16 - RFC 2781",
      "Unicode Standard 15.0"
    ],
    "webLinks": [
      "https://en.wikipedia.org/wiki/Plain_text",
      "https://en.wikipedia.org/wiki/UTF-8",
      "https://www.unicode.org/standard/standard.html"
    ]
  },
  "technicalDetails": {
    "encoding": "ASCII, UTF-8, UTF-16LE, UTF-16BE, ISO-8859-1",
    "lineEndings": "LF (\\n), CRLF (\\r\\n), CR (\\r)",
    "byteOrderMark": "Optional - UTF-8: EF BB BF, UTF-16LE: FF FE, UTF-16BE: FE FF",
    "maxFileSize": "Unlimited (performance depends on editor)",
    "compression": "None (plain uncompressed text)",
    "structure": "Linear sequence of characters with line breaks",
    "specialFeatures": "Human-readable, universal compatibility, no proprietary format"
  },
  "formatRelationships": {
    "category": "Text",
    "extensions": [
      ".md",
      ".rst",
      ".adoc",
      ".csv",
      ".tsv",
      ".json",
      ".xml",
      ".yaml",
      ".yml",
      ".ini",
      ".conf"
    ]
  },
  "variables": {
    "encoding": "UTF-8",
    "bomDetected": false,
    "lineCount": 0,
    "characterCount": 0,
    "lineEnding": "Mixed",
    "textRatio": 1.0
  },
  "blocks": [
    {
      "type": "field",
      "name": "Text Content",
      "offset": "0",
      "length": "var:fileSize",
      "valueType": "utf8",
      "color": "Transparent",
      "description": "Plain text file content",
      "tags": [
        "text"
      ]
    },
    {
      "type": "metadata",
      "name": "Encoding",
      "variable": "encoding",
      "description": "Detected text encoding (UTF-8, UTF-16LE, etc.)"
    },
    {
      "type": "metadata",
      "name": "BOM Detected",
      "variable": "bomDetected",
      "description": "Whether a Byte Order Mark was found"
    },
    {
      "type": "metadata",
      "name": "BOM Size",
      "variable": "bomSize",
      "description": "Size of the Byte Order Mark in bytes"
    },
    {
      "type": "metadata",
      "name": "Line Count",
      "variable": "lineCount",
      "description": "Total number of lines (LF count)"
    },
    {
      "type": "metadata",
      "name": "Line Ending",
      "variable": "lineEnding",
      "description": "Detected line ending style (LF, CRLF, CR, or None)"
    }
  ],
  "functions": {
    "detectBOM": "Detects Byte Order Mark (BOM) and sets encoding, bomDetected, and bomSize variables. Supports UTF-8, UTF-16LE/BE, UTF-32LE/BE.",
    "countLines": "Counts the number of lines in the file by counting line feed (LF, 0x0A) characters. Sets lineCount variable.",
    "detectLineEnding": "Analyzes first 8KB to detect predominant line ending style. Sets lineEnding, lfCount, crlfCount, and crCount variables."
  },
  "QualityMetrics": {
    "CompletenessScore": 14,
    "DocumentationLevel": "basic",
    "BlocksDefined": 6,
    "ValidationRules": 0,
    "LastUpdated": "2026-02-24"
  }
}

{
  "formatName": "sFlow",
  "version": "1.12",
  "extensions": [
    ".sflow"
  ],
  "description": "sFlow network monitoring - Sampled flow data",
  "category": "Network",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "sFlow Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/SFLOW"
    ]
  },
  "detection": {
    "signature": "00000005",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 4,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "version": 0,
    "agentAddress": 0,
    "sampleCount": 0,
    "uptime": 0,
    "sflowVersion": "",
    "agentAddressType": "",
    "subAgentId": "",
    "sequenceNumber": 0,
    "systemUptime": 0,
    "numberOfSamples": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "sFlow Version",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Version 5 (0x00000005)",
      "storeAs": "sflowVersion",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Agent Address Type",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "IP version (1=IPv4, 2=IPv6)",
      "storeAs": "agentAddressType",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Agent Address",
      "offset": 8,
      "length": 16,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "IP address of sFlow agent",
      "storeAs": "agentAddress",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Sub-Agent ID",
      "offset": 24,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Sub-agent identifier",
      "storeAs": "subAgentId",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Sequence Number",
      "offset": 28,
      "length": 4,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "Datagram sequence number",
      "storeAs": "sequenceNumber",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "System Uptime",
      "offset": 32,
      "length": 4,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Milliseconds since device boot",
      "storeAs": "systemUptime",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Number of Samples",
      "offset": 36,
      "length": 4,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Number of flow/counter samples",
      "storeAs": "numberOfSamples",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "Version",
      "variable": "version",
      "description": "Version"
    },
    {
      "type": "metadata",
      "name": "Sample Count",
      "variable": "sampleCount",
      "description": "Sample Count"
    }
  ],
  "software": [
    "Wireshark",
    "tcpdump"
  ],
  "format_relationships": {
    "category": "Network",
    "extensions": [
      ".sflow"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Wireshark",
    "tcpdump",
    "NetworkMiner",
    "Fiddler",
    "Charles Proxy"
  ],
  "UseCases": [
    "Network analysis",
    "Packet capture",
    "Debugging",
    "Security analysis"
  ],
  "QualityMetrics": {
    "CompletenessScore": 56,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 9,
    "ValidationRules": 0,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt32BE": "Read sFlow datagram header",
    "readUInt16BE": "Read version"
  }
}

{
  "formatName": "MDL Molfile",
  "version": "1.13",
  "extensions": [
    ".mol"
  ],
  "description": "MDL Molfile chemical structure format",
  "category": "Science",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "MDL Molfile Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/MOL"
    ]
  },
  "detection": {
    "signature": "00",
    "offset": 0,
    "required": false,
    "validation": {
      "min_file_size": 1,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "fileSize": 0,
    "version": 0,
    "format": "",
    "moleculeName": "",
    "headerLine2": "",
    "comment": "",
    "formattedSize": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "Molecule Name",
      "offset": 0,
      "length": 80,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "First line: molecule name",
      "storeAs": "moleculeName",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Header Line 2",
      "offset": 80,
      "length": 80,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "User/program/date/etc",
      "storeAs": "headerLine2",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Comment",
      "offset": 160,
      "length": 80,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Comment line",
      "storeAs": "comment",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "File Size",
      "variable": "fileSize",
      "description": "File Size"
    },
    {
      "type": "metadata",
      "name": "Version",
      "variable": "version",
      "description": "Version"
    },
    {
      "type": "metadata",
      "name": "Formatted Size",
      "variable": "formattedSize",
      "description": "Human-readable file size"
    }
  ],
  "software": [
    "Common file viewers",
    "Specialized software"
  ],
  "format_relationships": {
    "category": "Science",
    "extensions": [
      ".mol"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Hex Editor",
    "File Viewer",
    "Archive Manager"
  ],
  "UseCases": [
    "File storage",
    "Data exchange",
    "Archive"
  ],
  "QualityMetrics": {
    "CompletenessScore": 33,
    "DocumentationLevel": "standard",
    "BlocksDefined": 6,
    "ValidationRules": 0,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt32LE": "Read file header",
    "formatFileSize(var:fileSize)": "Format fileSize as readable size"
  }

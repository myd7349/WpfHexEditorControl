      "https://en.wikipedia.org/wiki/SGY"
    ]
  },
  "detection": {
    "signature": "C0C0C0C0",
    "offset": 3200,
    "required": false,
    "validation": {
      "min_file_size": 4,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "dimensions": 0,
    "dataType": "",
    "arrayCount": 0,
    "textHeader": "",
    "binaryHeader": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "Text Header",
      "offset": 0,
      "length": 3200,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "3200-byte EBCDIC text header",
      "storeAs": "textHeader",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Binary Header",
      "offset": 3200,
      "length": 400,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "400-byte binary header",
      "storeAs": "binaryHeader",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Dimensions",
      "variable": "dimensions",
      "description": "Dimensions"
    },
    {
      "type": "metadata",
      "name": "Data Type",
      "variable": "dataType",
      "description": "Data Type"
    },
    {
      "type": "metadata",
      "name": "Array Count",
      "variable": "arrayCount",
      "description": "Array Count"
    }
  ],
  "software": [

{
  "formatName": "SEG-Y Seismic Data",
  "version": "1.11",
  "extensions": [
    ".sgy",
    ".segy"
  ],
  "description": "Society of Exploration Geophysicists Y format for seismic data",
  "category": "Science",
  "author": "WPFHexaEditor Team",

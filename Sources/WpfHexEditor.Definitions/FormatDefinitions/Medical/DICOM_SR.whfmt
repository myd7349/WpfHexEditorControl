{
  "formatName": "DICOM Structured Report",
  "version": "1.13",
  "extensions": [
    ".dcm",
    ".sr"
  ],
  "description": "DICOM Structured Report for medical data",
  "category": "Medical",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "DICOM Structured Report Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/DCM"
    ]
  },
  "detection": {
    "signature": "4449434D",
    "offset": 128,
    "required": true,
    "validation": {
      "min_file_size": 4,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "imageWidth": 0,
    "imageHeight": 0,
    "totalPixels": 0,
    "bitsPerPixel": 0,
    "preamble": "",
    "dicmMagic": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "Preamble",
      "offset": 0,
      "length": 128,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "128-byte preamble",
      "storeAs": "preamble",
      "valueType": "ascii"
    },
    {
      "type": "signature",
      "name": "DICM Magic",
      "offset": 128,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "DICM signature",
      "storeAs": "dicmMagic",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "Image Width",
      "variable": "imageWidth",
      "description": "Image width in pixels"
    },
    {
      "type": "metadata",
      "name": "Image Height",
      "variable": "imageHeight",
      "description": "Image height in pixels"
    },
    {
      "type": "metadata",
      "name": "Total Pixels",
      "variable": "totalPixels",
      "description": "Width × Height"
    },
    {
      "type": "metadata",
      "name": "Bits Per Pixel",
      "variable": "bitsPerPixel",
      "description": "Color depth"
    }
  ],
  "software": [
    "Common file viewers",
    "Specialized software"
  ],
  "format_relationships": {
    "category": "Medical",
    "extensions": [
      ".dcm",
      ".sr"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Hex Editor",
    "File Viewer",
    "Archive Manager"
  ],
  "UseCases": [
    "File storage",
    "Data exchange",
    "Archive"
  ],
  "QualityMetrics": {
    "CompletenessScore": 32,
    "DocumentationLevel": "standard",
    "BlocksDefined": 6,
    "ValidationRules": 0,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt32LE": "Read width and height",
    "multiply": "Calculate total pixels",
    "computeFromVariables(imageWidth * imageHeight, totalPixels)": "Calculate total pixels"
  }
}

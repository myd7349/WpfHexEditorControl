  ],
  "QualityMetrics": {
    "CompletenessScore": 69,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 17,
    "ValidationRules": 2,
    "LastUpdated": "2026-03-01",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {
    "Platform": "Game Boy"
  },
  "functions": {
    "readUInt32LE": "Read game header",
    "extractASCIIString": "Read file list"
  }
}

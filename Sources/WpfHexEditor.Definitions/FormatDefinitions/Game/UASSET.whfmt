{
  "formatName": "Unreal Engine Asset",
  "version": "1.12",
  "extensions": [
    ".uasset"
  ],
  "description": "Unreal Engine 4/5 asset file format",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Unreal Engine Asset Package Format",
      "UE4/UE5 Binary Asset Structure",
      "Epic Games Asset Serialization"
    ],
    "WebLinks": [
      "https://docs.fileformat.com/game/uasset/",

      "https://docs.rs/uasset",
      "https://unofficial-modding-guide.com/posts/uassetmodding/"
    ]
  },
  "detection": {
    "signature": "C1832A9E",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 4,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "fileCount": 0,
    "version": "",
    "indexOffset": 0,
    "packageTag": "",
    "legacyUe3Version": "",
    "ue4Version": "",
    "fileVersion": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Package Tag",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Unreal package signature",
      "storeAs": "packageTag",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Legacy UE3 Version",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Legacy version from UE3",
      "storeAs": "legacyUe3Version",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "UE4 Version",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Unreal Engine 4 version number",
      "storeAs": "ue4Version",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "File Version",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Package file version",
      "storeAs": "fileVersion",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "File Count",
      "variable": "fileCount",
      "description": "File Count"
    },
    {
      "type": "metadata",
      "name": "Version",
      "variable": "version",
      "description": "Version"
    },
    {
      "type": "metadata",
      "name": "Index Offset",
      "variable": "indexOffset",
      "description": "Index Offset"
    }
  ],
  "software": [
    "Emulators",
    "Game engines"
  ],

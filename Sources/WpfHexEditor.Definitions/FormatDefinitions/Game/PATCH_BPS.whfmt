      "https://www.romhacking.net/utilities/893/",
      "https://forums.nesdev.org/viewtopic.php?t=16803"
    ]
  },
  "detection": {
    "signature": "42505331",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 4,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "srcSizeByte": 0,
    "machineType": "",
    "sectionCount": 0,
    "entryPoint": 0,
    "bpsMagic": "",
    "patchHeaderData": "",
    "patchCommandsRegion": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "BPS Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "BPS1 magic identifier - Beat Patching System format (created by byuu/Near)",
      "storeAs": "bpsMagic",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Source Size (VLI)",
      "offset": 4,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "uint8",
      "storeAs": "srcSizeByte",
      "description": "First byte of VLI source file size. LSB=continuation bit, remaining 7 bits=data"
    },
    {
      "type": "field",
      "name": "Patch Header Data",
      "offset": 5,
      "length": 16,
      "color": "#95E1D3",
      "opacity": 0.3,
      "valueType": "ascii",
      "description": "VLI-encoded target size, metadata length, and metadata content (variable structure)",
      "storeAs": "patchHeaderData"
    },
    {
      "type": "field",
      "name": "Patch Commands Region",
      "offset": 21,
      "length": 100,
      "color": "#FFE66D",
      "opacity": 0.2,
      "valueType": "ascii",
      "description": "Variable-length patch commands: SourceRead(0), TargetRead(1), SourceCopy(2), TargetCopy(3)",
      "storeAs": "patchCommandsRegion"
    },
    {
      "type": "metadata",
      "name": "Machine",
      "variable": "machineType",
      "description": "Machine"
    },
    {
      "type": "metadata",
      "name": "Sections",
      "variable": "sectionCount",
      "description": "Sections"
    }
  ],

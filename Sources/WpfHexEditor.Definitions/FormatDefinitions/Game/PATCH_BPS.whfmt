{
  "formatName": "BPS Patch",
  "version": "1.11",
  "extensions": [
    ".bps"
  ],
  "description": "Beat Patching System (BPS) format - Modern ROM patching with metadata support, CRC32 validation, and optimal compression",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Beat Patching System (BPS) Format",
      "BPS v1 Specification by byuu/Near",
      "BPS ROM Patch Standard"
    ],
    "WebLinks": [
      "https://github.com/blakesmith/rombp/blob/master/docs/bps_spec.md",

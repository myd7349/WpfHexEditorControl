{
  "formatName": "Unreal Plugin",
  "version": "1.12",
  "extensions": [
    ".uplugin"
  ],
  "description": "Unreal Engine plugin descriptor file (JSON format)",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Unreal Engine Plugin Descriptor",
      "FPluginDescriptor JSON Format",

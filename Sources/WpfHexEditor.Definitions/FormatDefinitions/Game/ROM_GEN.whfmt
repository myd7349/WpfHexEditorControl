{
  "formatName": "Sega Genesis/Mega Drive ROM",
  "version": "1.11",
  "extensions": [
    ".md",
    ".bin",
    ".gen",
    ".smd"
  ],
  "description": "Sega Genesis / Mega Drive ROM cartridge format",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "references": {
    "specifications": [
      "Sega Mega Drive ROM Header Specification",
      "Genesis Technical Overview",
      "MegaDrive ROM Header Format"
    ],
    "WebLinks": [
      "https://plutiedev.com/rom-header",
      "https://wiki.megadrive.org/index.php?title=MD_Rom_Header",
      "https://datacrystal.tcrf.net/wiki/Sega_Genesis",
      "https://github.com/sikthehedgehog/mdtools/blob/master/headgen/doc/header"
    ]
  },
  "detection": {
    "signature": "5345474120",
    "offset": 256,
    "required": false,
    "validation": {
      "min_file_size": 5,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "domesticTitle": "",
    "overseasTitle": "",
    "checksum": 0,
    "romEnd": 0,
    "machineType": "",
    "sectionCount": 0,
    "entryPoint": 0,
    "consoleName": "",
    "copyright": "",
    "serialNumber": "",
    "deviceSupport": "",
    "romStart": 0,
    "ramStart": 0,
    "ramEnd": 0,
    "backupRamInfo": 0,
    "sramStart": 0,
    "sramEnd": 0,
    "modemData": "",
    "notes": "",
    "countryCodes": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Console Name",
      "offset": 256,
      "length": 16,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "valueType": "ascii",
      "description": "SEGA MEGA DRIVE or SEGA GENESIS (must be one of these)",
      "storeAs": "consoleName"
    },
    {
      "type": "field",
      "name": "Copyright",
      "offset": 272,
      "length": 16,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "ascii",
      "description": "Publisher and year: (C)SEGA YYYY.MMM",
      "storeAs": "copyright"
    },
    {
      "type": "field",
      "name": "Domestic Title",
      "offset": 288,
      "length": 48,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "ascii",
      "storeAs": "domesticTitle",
      "description": "Japanese game title (ASCII, space-padded)"
    },
    {
      "type": "field",
      "name": "Overseas Title",
      "offset": 336,
      "length": 48,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "ascii",
      "storeAs": "overseasTitle",
      "description": "International game title (ASCII, space-padded)"
    },
    {
      "type": "field",
      "name": "Serial Number",
      "offset": 384,
      "length": 14,
      "color": "#FFE66D",
      "opacity": 0.3,
      "valueType": "ascii",
      "description": "Product serial number and revision: GM XXXXXXX-XX",
      "storeAs": "serialNumber"
    },
    {
      "type": "field",
      "name": "Checksum",
      "offset": 398,
      "length": 2,
      "color": "#FF6B9D",
      "opacity": 0.3,
      "valueType": "uint16",
      "storeAs": "checksum",
      "description": "16-bit big-endian checksum of ROM bytes 0x200 onward"
    },
    {
      "type": "field",
      "name": "Device Support",
      "offset": 400,
      "length": 16,
      "color": "#FFE66D",
      "opacity": 0.3,
      "valueType": "ascii",
      "description": "Supported controllers: J=3-btn, 6=6-btn, K=keyboard, P=printer, T=tablet",
      "storeAs": "deviceSupport"
    },
    {
      "type": "field",
      "name": "ROM Start",
      "offset": 416,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "valueType": "uint32",
      "description": "ROM address start (0x00000000)",
      "storeAs": "romStart"
    },
    {
      "type": "field",
      "name": "ROM End",
      "offset": 420,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "valueType": "uint32",
      "storeAs": "romEnd",
      "description": "ROM address end (file size - 1)"
    },
    {
      "type": "field",
      "name": "RAM Start",
      "offset": 424,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "valueType": "uint32",
      "description": "RAM start address (0xFF0000)",
      "storeAs": "ramStart"
    },
    {
      "type": "field",
      "name": "RAM End",
      "offset": 428,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "valueType": "uint32",
      "description": "RAM end address (0xFFFFFF)",
      "storeAs": "ramEnd"
    },
    {
      "type": "field",
      "name": "Backup RAM Info",
      "offset": 432,
      "length": 4,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "uint32",
      "description": "SRAM type: 'RA' + flags if cartridge has save RAM",
      "storeAs": "backupRamInfo"
    },
    {
      "type": "field",
      "name": "SRAM Start",
      "offset": 436,
      "length": 4,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "uint32",
      "description": "SRAM start address",
      "storeAs": "sramStart"
    },
    {
      "type": "field",
      "name": "SRAM End",
      "offset": 440,
      "length": 4,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "uint32",
      "description": "SRAM end address",
      "storeAs": "sramEnd"
    },
    {
      "type": "field",
      "name": "Modem Data",
      "offset": 444,
      "length": 12,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "ascii",
      "description": "Modem support data (empty if no modem)",
      "storeAs": "modemData"
    },
    {
      "type": "field",
      "name": "Notes",
      "offset": 456,
      "length": 40,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "ascii",
      "hidden": true,
      "description": "Developer notes/memo field",
      "storeAs": "notes"
    },
    {
      "type": "field",
      "name": "Country Codes",
      "offset": 496,
      "length": 16,
      "color": "#FFE66D",
      "opacity": 0.3,
      "valueType": "ascii",
      "description": "Region support: J=Japan, U=USA, E=Europe",
      "storeAs": "countryCodes"
    },
    {
      "type": "metadata",
      "name": "Machine",
      "variable": "machineType",
      "description": "Machine"
    },
    {
      "type": "metadata",
      "name": "Sections",
      "variable": "sectionCount",
      "description": "Sections"
    }
  ],

<!--
    Project: WpfHexEditor.Plugins.ClassDiagram
    File: Panels/ClassOutlinePanel.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-19
    Description:
        VS-Like dockable panel that lists all class nodes in the active
        diagram document. Supports text search and single-node selection.
        Theme tokens: CD_* (from WpfHexEditor.Editor.ClassDiagram Themes/Generic.xaml).
-->
<UserControl x:Class="WpfHexEditor.Plugins.ClassDiagram.Panels.ClassOutlinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockMenuBackgroundBrush}">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockToolBarBorderBrush}"
                Padding="4,3">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="SearchBox"
                         Width="140"
                         Style="{DynamicResource PanelSearchBoxStyle}"
                         Tag="Search class names and kinds"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Border>

        <!-- Class list -->
        <ListBox x:Name="NodeList"
                 ItemsSource="{Binding FilteredNodes}"
                 SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                 Background="{DynamicResource DockMenuBackgroundBrush}"
                 Foreground="{DynamicResource DockMenuForegroundBrush}"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2,2,2,2">
                        <!-- Kind badge (e.g. «interface», «enum») — empty for plain class -->
                        <TextBlock Text="{Binding KindLabel}"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource CD_NodeHeaderForeground}"
                                   Margin="0,0,5,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Name}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>

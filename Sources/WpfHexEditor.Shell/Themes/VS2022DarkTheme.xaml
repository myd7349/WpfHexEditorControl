<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: VS2022DarkTheme.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-06
     Description:
         Visual Studio 2022 Dark theme for the WpfHexEditor.Docking system.
         Uses the exact VS2022 color palette from VS2022Dark/Colors.xaml while
         reusing the shared Dark/ control templates for menus and tab controls.

     Architecture Notes:
         ResourceDictionary. Merges VS2022Dark/Colors.xaml + Dark/Menu.xaml +
         Dark/TabControl.xaml + Dark/ContentControls.xaml + PanelCommon.xaml.
         Achieves pixel-accurate VS2022 fidelity by overriding only the color
         definitions, not the control templates.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- VS2022 Dark Theme — exact Visual Studio 2022 color palette -->
    <!-- Reuses shared tab/menu/content templates from Dark/ with VS2022-specific colors -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="VS2022Dark/Colors.xaml" />
        <ResourceDictionary Source="Dark/Menu.xaml" />
        <ResourceDictionary Source="Dark/TabControl.xaml" />
        <ResourceDictionary Source="Dark/ContentControls.xaml" />
        <ResourceDictionary Source="PanelCommon.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>

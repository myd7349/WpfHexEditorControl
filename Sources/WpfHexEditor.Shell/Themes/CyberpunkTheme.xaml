<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: CyberpunkTheme.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-06
     Description:
         Cyberpunk theme for the WpfHexEditor.Docking system. Features neon
         pink, purple, and cyan accents on a near-black background, inspired
         by retro-futuristic cyberpunk aesthetics.

     Architecture Notes:
         ResourceDictionary. Merges Cyberpunk/Colors.xaml + Dark/ shared templates
         + PanelCommon.xaml. Color palette defined entirely in Cyberpunk/Colors.xaml.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cyberpunk Theme — Neon Pink/Purple/Cyan, reuses Dark templates -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Cyberpunk/Colors.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Dark/Menu.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Dark/TabControl.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Dark/ContentControls.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/PanelCommon.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>

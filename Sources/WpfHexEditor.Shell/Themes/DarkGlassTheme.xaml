<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: DarkGlassTheme.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-06
     Description:
         Dark Glassmorphism theme for the WpfHexEditor.Docking system. Features
         cyan and teal accents with semi-transparent glass-like surfaces on a
         dark background.

     Architecture Notes:
         ResourceDictionary. Merges DarkGlass/Colors.xaml + Dark/ shared templates
         + PanelCommon.xaml. Glass effect achieved via opacity and border brushes
         in DarkGlass/Colors.xaml.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Glassmorphism Theme — Cyan/Teal accents, reuses Dark templates -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="DarkGlass/Colors.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Dark/Menu.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Dark/TabControl.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Dark/ContentControls.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/PanelCommon.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>

<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: Generic.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-06
     Description:
         Default (Light) theme entry point for the WpfHexEditor.Docking system.
         Merges Light/Colors.xaml, Light/Menu.xaml, Light/TabControl.xaml,
         Light/ContentControls.xaml, and PanelCommon.xaml into a single dictionary.

     Architecture Notes:
         ResourceDictionary. Acts as the fallback theme for WPF Generic.xaml lookup.
         Composed of sub-dictionaries for maintainability. All color keys are defined
         in Light/Colors.xaml; control templates in the TabControl/Menu/ContentControls files.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Default (Light) Theme for WpfHexEditor.Docking -->
    <!-- Split into composable sub-files for maintainability -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Light/Colors.xaml" />
        <ResourceDictionary Source="Light/Menu.xaml" />
        <ResourceDictionary Source="Light/TabControl.xaml" />
        <ResourceDictionary Source="Light/ContentControls.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>

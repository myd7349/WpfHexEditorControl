<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: MinimalTheme.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-06
     Description:
         Minimal theme for the WpfHexEditor.Docking system. Ultra-clean
         monochrome design with minimal decorations, maximum whitespace, and
         reduced visual noise for distraction-free editing.

     Architecture Notes:
         ResourceDictionary. Merges Minimal/Colors.xaml + Light/ shared templates
         + PanelCommon.xaml. Monochrome palette with subtle gray-scale variations.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Minimal Theme — Ultra-clean monochrome, reuses Light templates -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Minimal/Colors.xaml" />
        <ResourceDictionary Source="Light/Menu.xaml" />
        <ResourceDictionary Source="Light/TabControl.xaml" />
        <ResourceDictionary Source="Light/ContentControls.xaml" />
        <ResourceDictionary Source="PanelCommon.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>

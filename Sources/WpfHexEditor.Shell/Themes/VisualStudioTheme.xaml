<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: VisualStudioTheme.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-06
     Description:
         Visual Studio Professional dark theme for the WpfHexEditor.Docking system.
         Combines VisualStudio/Colors.xaml with shared Dark/ templates for a
         professional VS2022 dark appearance with slightly warmer tones.

     Architecture Notes:
         ResourceDictionary. Merges VisualStudio/Colors.xaml + Dark/Menu.xaml +
         Dark/TabControl.xaml + Dark/ContentControls.xaml + PanelCommon.xaml.
         Distinct from VS2022DarkTheme in its specific color tuning.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Visual Studio Theme — Professional dark, reuses Dark templates -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="VisualStudio/Colors.xaml" />
        <ResourceDictionary Source="Dark/Menu.xaml" />
        <ResourceDictionary Source="Dark/TabControl.xaml" />
        <ResourceDictionary Source="Dark/ContentControls.xaml" />
        <ResourceDictionary Source="PanelCommon.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>

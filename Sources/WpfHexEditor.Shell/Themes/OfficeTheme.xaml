<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: OfficeTheme.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-06
     Description:
         Office theme for the WpfHexEditor.Docking system. Inspired by Microsoft
         Office 2021/365 light theme with clean whites, subtle grays, and Microsoft
         blue accents.

     Architecture Notes:
         ResourceDictionary. Merges Office/Colors.xaml + Light/ shared templates
         + PanelCommon.xaml. Light palette optimized for productivity applications.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Office Theme — Microsoft Office 2021/365 light, reuses Light templates -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Office/Colors.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Light/Menu.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Light/TabControl.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/Light/ContentControls.xaml" />
        <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.Docking.Wpf;component/Themes/PanelCommon.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>

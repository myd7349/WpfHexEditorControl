<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: Dark/ContentControls.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-06
     Description:
         Overrides for standard WPF content controls (Label, TextBox, ComboBox,
         Button, ScrollBar, etc.) to ensure readable foreground text on dark
         backgrounds inside docked panels and floating windows.

     Architecture Notes:
         ResourceDictionary. Provides implicit styles that override WPF defaults.
         Colors are bound to DockForegroundBrush / DockBackgroundBrush DynamicResource
         keys so all dark themes automatically benefit from these overrides.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Content control overrides: ensure readable text in dark-themed panels -->
    <Style TargetType="{x:Type TreeView}" BasedOn="{StaticResource {x:Type TreeView}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource {x:Type TreeViewItem}}">
        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource DockMenuForegroundBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource DockTabActiveBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
    </Style>

    <!-- CheckBox: full themed template is in PanelCommon.xaml (merged after this file) -->

    <Style TargetType="{x:Type Label}" BasedOn="{StaticResource {x:Type Label}}">
        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
    </Style>

    <!-- ═══ Themed ScrollBar (VS Code-style: thin, no arrow buttons) ════════════ -->

    <!-- Thumb: rounded gray pill -->
    <Style x:Key="DockScrollBarThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="Bd" CornerRadius="3" Margin="2" Background="#686868"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#9E9E9E"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#C0C0C0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Page buttons: transparent click zones (no arrow buttons) -->
    <Style x:Key="DockScrollBarPageButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Implicit ScrollBar style — applies to all ScrollBars in scope -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Width"    Value="12"/>
        <Setter Property="MinWidth" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <!-- Vertical template (default) -->
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Border SnapsToDevicePixels="True" Background="#1E1E1E">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource DockScrollBarPageButtonStyle}"
                                              Command="ScrollBar.PageUpCommand"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource DockScrollBarPageButtonStyle}"
                                              Command="ScrollBar.PageDownCommand"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource DockScrollBarThumbStyle}"/>
                            </Track.Thumb>
                        </Track>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width"     Value="Auto"/>
                <Setter Property="Height"    Value="12"/>
                <Setter Property="MinWidth"  Value="0"/>
                <Setter Property="MinHeight" Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <!-- Horizontal template -->
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Border SnapsToDevicePixels="True" Background="#1E1E1E">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource DockScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageLeftCommand"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource DockScrollBarPageButtonStyle}"
                                                      Command="ScrollBar.PageRightCommand"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource DockScrollBarThumbStyle}"/>
                                    </Track.Thumb>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: Dark/Menu.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-06
     Description:
         ContextMenu and MenuItem control templates for dark-themed docking menus.
         Used by all dark-variant themes (DarkTheme, VS2022DarkTheme, VisualStudioTheme,
         CyberpunkTheme, DarkGlassTheme).

     Architecture Notes:
         ResourceDictionary. All colors bound via DynamicResource to Dock* keys
         defined in the consuming theme's Colors.xaml so that one template serves
         multiple dark palettes.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark menu styles (VS2022-style) -->

    <Style x:Key="DockDarkMenuStyle" TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource DockMenuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
        <Setter Property="ItemContainerStyle" Value="{DynamicResource DockDarkMenuItemStyle}" />
    </Style>

    <Style x:Key="DockDarkMenuItemStyle" TargetType="{x:Type MenuItem}">
        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ItemContainerStyle" Value="{DynamicResource DockDarkMenuItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="templateRoot"
                            SnapsToDevicePixels="True"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid x:Name="Grid" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemIconGroup" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="MenuItemIGTGroup" />
                                <ColumnDefinition Width="20" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="Icon" Grid.Column="0" ContentSource="Icon"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                              VerticalAlignment="Center" HorizontalAlignment="Center"
                                              Width="16" Height="16" Margin="4,2" />
                            <Border x:Name="GlyphPanel" Grid.Column="0" Visibility="Collapsed"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Width="16" Height="16" Margin="4,2">
                                <Path Data="M1,5 L4,8 L8,1"
                                      Stroke="{DynamicResource DockMenuForegroundBrush}"
                                      StrokeThickness="1.5" Stretch="Uniform" />
                            </Border>
                            <ContentPresenter x:Name="menuHeaderContainer" Grid.Column="1"
                                              ContentSource="Header" RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                              VerticalAlignment="Center" Margin="4,4" />
                            <TextBlock x:Name="menuGestureText" Grid.Column="2"
                                       VerticalAlignment="Center" Margin="8,4,0,4"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}" Opacity="0.6" />
                            <Path x:Name="RightArrow" Grid.Column="3"
                                  Data="M0,0 L4,3.5 L0,7 Z" Fill="{TemplateBinding Foreground}"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"
                                  Margin="0,0,6,0" Visibility="Collapsed" />
                            <Popup x:Name="PART_Popup" Grid.Column="0" Grid.ColumnSpan="4"
                                   AllowsTransparency="True" Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                <!-- Margin reserves space for the drop shadow around all 4 sides -->
                                <Grid Margin="8">
                                    <!-- Layer 1: shadow — opaque background so the effect has a shape to shadow -->
                                    <Border CornerRadius="4"
                                            Background="{DynamicResource DockMenuBackgroundBrush}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="10"
                                                              ShadowDepth="0" Opacity="0.5" />
                                        </Border.Effect>
                                    </Border>
                                    <!-- Layer 2: content — clipped to rounded corners, no effect -->
                                    <Border CornerRadius="4"
                                            Background="{DynamicResource DockMenuBackgroundBrush}"
                                            BorderBrush="{DynamicResource DockMenuBorderBrush}"
                                            BorderThickness="1" Padding="0,2"
                                            ClipToBounds="True"
                                            SnapsToDevicePixels="True" Grid.IsSharedSizeScope="True">
                                        <ScrollViewer CanContentScroll="True"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="GlyphPanel" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="GlyphPanel" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RightArrow" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="menuGestureText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="menuHeaderContainer" Property="Grid.Column" Value="0" />
                            <Setter TargetName="menuHeaderContainer" Property="Grid.ColumnSpan" Value="3" />
                            <Setter TargetName="menuHeaderContainer" Property="Margin" Value="8,3" />
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                        </Trigger>
                        <Trigger Property="Role" Value="TopLevelItem">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="GlyphPanel" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RightArrow" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="menuGestureText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="menuHeaderContainer" Property="Grid.Column" Value="0" />
                            <Setter TargetName="menuHeaderContainer" Property="Grid.ColumnSpan" Value="4" />
                            <Setter TargetName="menuHeaderContainer" Property="Margin" Value="8,3" />
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="RightArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                        </Trigger>
                        <!-- Submenu items: highlight background only -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource DockMenuHighlightBrush}" />
                        </Trigger>
                        <!-- Top-level header: show 1px border rectangle on hover (VS2022 style) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Role" Value="TopLevelHeader" />
                                <Condition Property="IsHighlighted" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource DockMenuHighlightBrush}" />
                            <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource DockMenuHighlightBorderBrush}" />
                            <Setter TargetName="templateRoot" Property="BorderThickness" Value="1" />
                        </MultiTrigger>
                        <!-- Top-level item (non-submenu): same border on hover -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Role" Value="TopLevelItem" />
                                <Condition Property="IsHighlighted" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource DockMenuHighlightBrush}" />
                            <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource DockMenuHighlightBorderBrush}" />
                            <Setter TargetName="templateRoot" Property="BorderThickness" Value="1" />
                        </MultiTrigger>
                        <!-- Top-level header: keep highlighted when submenu is open -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Role" Value="TopLevelHeader" />
                                <Condition Property="IsSubmenuOpen" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource DockMenuHighlightBrush}" />
                            <Setter TargetName="templateRoot" Property="BorderBrush" Value="{DynamicResource DockMenuHighlightBorderBrush}" />
                            <Setter TargetName="templateRoot" Property="BorderThickness" Value="1" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="templateRoot" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Themed ContextMenu popup used by status bar items and other host popups -->
    <Style x:Key="DockDarkContextMenuStyle" TargetType="{x:Type ContextMenu}">
        <Setter Property="Background"  Value="{DynamicResource DockMenuBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DockMenuBorderBrush}"/>
        <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            Padding="0,2"
                            SnapsToDevicePixels="True"
                            Grid.IsSharedSizeScope="True">
                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DockDarkMenuSeparatorStyle" TargetType="{x:Type Separator}">
        <Setter Property="Background" Value="{DynamicResource DockMenuBorderBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Height="1" Margin="24,2,4,2" Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- VS2026-style ToolBar: compact, no grip, no overflow chrome, 1px bottom border -->
    <Style x:Key="DockDarkToolBarStyle" TargetType="ToolBar">
        <Setter Property="Background" Value="{DynamicResource DockToolBarBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="3,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolBar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource DockMenuBorderBrush}"
                            BorderThickness="0,0,0,1"
                            SnapsToDevicePixels="True">
                        <DockPanel>
                            <!-- Overflow button — visible only when items don't fit -->
                            <Grid x:Name="OverflowGrid" DockPanel.Dock="Right" Width="14" Visibility="Collapsed">
                                <ToggleButton x:Name="OverflowButton"
                                              IsEnabled="{TemplateBinding HasOverflowItems}"
                                              Focusable="False"
                                              IsChecked="{Binding IsOverflowOpen,
                                                  RelativeSource={RelativeSource TemplatedParent},
                                                  Mode=TwoWay}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              VerticalAlignment="Stretch">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="2" Padding="1,4">
                                                <Path Data="M0,0 L4,4 L8,0"
                                                      Stroke="{DynamicResource DockMenuForegroundBrush}"
                                                      StrokeThickness="1.2" Stretch="Uniform"
                                                      Width="8" Height="5"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource DockMenuHighlightBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup x:Name="OverflowPopup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsOverflowOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       PopupAnimation="Slide"
                                       PlacementTarget="{Binding ElementName=OverflowButton}">
                                    <Border Background="{DynamicResource DockMenuBackgroundBrush}"
                                            BorderBrush="{DynamicResource DockMenuBorderBrush}"
                                            BorderThickness="1" CornerRadius="4" Padding="0,2">
                                        <ToolBarOverflowPanel x:Name="PART_ToolBarOverflowPanel"
                                                              WrapWidth="200" Focusable="True"
                                                              FocusVisualStyle="{x:Null}"
                                                              KeyboardNavigation.TabNavigation="Cycle"
                                                              KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Border>
                                </Popup>
                            </Grid>
                            <!-- Main items panel -->
                            <ToolBarPanel x:Name="PART_ToolBarPanel"
                                          IsItemsHost="True"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasOverflowItems" Value="True">
                            <Setter TargetName="OverflowGrid" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════
         VS2026 "Pod" toolbar pattern
         ─────────────────────────────────────────────────────────────────
         DockToolBarPodStyle         → Border container (reçoit l'effet raised)
         DockDarkToolBarButtonStyle  → Bouton DANS un pod (flat, hover seul)
         DockToolBarPodDividerStyle  → Séparateur vertical fin DANS un pod
         DockDarkToolBarSeparatorStyle → Espace entre pods (séparateur externe)
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Pod container : raised block groupant des boutons liés.
         La border + shadow est portée par le conteneur, PAS par chaque bouton. -->
    <Style x:Key="DockToolBarPodStyle" TargetType="Border">
        <Setter Property="Background"        Value="#18FFFFFF"/>
        <Setter Property="BorderBrush"       Value="#50808080"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="CornerRadius"      Value="4"/>
        <Setter Property="Padding"           Value="1,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin"            Value="1,2"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="2" BlurRadius="4"
                                  Opacity="0.50" Direction="270" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bouton à l'intérieur d'un pod : AUCUNE border individuelle.
         Hover = highlight arrondi. Pressed = 1px border accent + bg sombre.
         Supporte : icon seul, icon+texte, ou tout autre contenu. -->
    <Style x:Key="DockDarkToolBarButtonStyle" TargetType="Button">
        <Setter Property="Foreground"        Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="Background"        Value="Transparent"/>
        <Setter Property="BorderThickness"   Value="0"/>
        <Setter Property="Padding"           Value="5,3"/>
        <Setter Property="Cursor"            Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource DockMenuHighlightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource DockTabHoverBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{DynamicResource DockTabActiveBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Séparateur FIN entre boutons à l'intérieur d'un même pod -->
    <Style x:Key="DockToolBarPodDividerStyle" TargetType="Separator">
        <Setter Property="Background" Value="#30808080"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Width="1" Margin="0,4" Background="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Dropdown button à l'intérieur d'un pod : flat comme DockDarkToolBarButtonStyle
         mais avec un chevron-bas (&#xE70D;) ajouté à droite du contenu.
         Clic gauche → le handler code-behind ouvre le ContextMenu attaché. -->
    <Style x:Key="DockToolBarPodDropDownButtonStyle" TargetType="Button">
        <Setter Property="Foreground"        Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="Background"        Value="Transparent"/>
        <Setter Property="BorderThickness"   Value="0"/>
        <Setter Property="Padding"           Value="5,3"/>
        <Setter Property="Cursor"            Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ContentPresenter VerticalAlignment="Center"/>
                            <!-- Chevron ▾ via Segoe MDL2 "ChevronDown" -->
                            <TextBlock Text="&#xE70D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="7"
                                       VerticalAlignment="Center"
                                       Margin="3,1,0,0"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource DockMenuHighlightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource DockTabHoverBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{DynamicResource DockTabActiveBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Séparateur EXTERNE entre pods (espace + trait fin) -->
    <Style x:Key="DockDarkToolBarSeparatorStyle" TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource DockMenuBorderBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Width="1" Margin="3,5" Background="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Themed ToolTip — matches menu background/foreground (VS2026-style) -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Background"      Value="{DynamicResource DockMenuBackgroundBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource DockMenuBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="6,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Implicit styles — wired here where the named keys are defined -->
    <Style TargetType="{x:Type ContextMenu}" BasedOn="{StaticResource DockDarkContextMenuStyle}"/>
    <Style TargetType="{x:Type MenuItem}"    BasedOn="{StaticResource DockDarkMenuItemStyle}"/>
    <Style TargetType="{x:Type Separator}"   BasedOn="{StaticResource DockDarkMenuSeparatorStyle}"/>

</ResourceDictionary>

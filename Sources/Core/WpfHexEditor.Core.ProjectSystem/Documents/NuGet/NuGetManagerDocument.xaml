<UserControl x:Class="WpfHexEditor.Core.ProjectSystem.Documents.NuGet.NuGetManagerDocument"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Core.ProjectSystem.Documents.NuGet"
             Background="{DynamicResource DockMenuBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}"
             FontFamily="Segoe UI"
             FontSize="13">

    <!--
        NuGet Manager Document — VS-Like NuGet Package Manager
        Theme: DockMenuBackgroundBrush / DockMenuForegroundBrush / DockWindowBackgroundBrush /
               DockBorderBrush / DockTabHoverBrush / DockTabActiveBrush / DockTabTextBrush
        Architecture: MVVM — DataContext = NuGetManagerViewModel
    -->

    <UserControl.Resources>

        <!-- ── ComboBox ──────────────────────────────────────────────────── -->

        <ControlTemplate x:Key="NM_ComboBoxToggleTemplate" TargetType="ToggleButton">
            <Border x:Name="Bd"
                    Background="{DynamicResource DockWindowBackgroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="0" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                               FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource DockTabActiveBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="NM_ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background"       Value="{DynamicResource DockWindowBackgroundBrush}"/>
            <Setter Property="Foreground"       Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="MinHeight"        Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource NM_ComboBoxToggleTemplate}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter Margin="8,0,24,0" VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource DockMenuBackgroundBrush}"
                                        BorderBrush="{DynamicResource DockBorderBrush}"
                                        BorderThickness="1"
                                        MaxHeight="300">
                                    <ScrollViewer Background="{DynamicResource DockMenuBackgroundBrush}">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NM_ComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding"     Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"  Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── TextBox ───────────────────────────────────────────────────── -->

        <Style x:Key="NM_TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"     Value="{DynamicResource DockWindowBackgroundBrush}"/>
            <Setter Property="Foreground"     Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"    Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"        Value="6,4"/>
            <Setter Property="CaretBrush"     Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource DockTabActiveBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Button ────────────────────────────────────────────────────── -->

        <Style x:Key="NM_PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"    Value="{DynamicResource DockTabActiveBrush}"/>
            <Setter Property="Foreground"    Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="14,5"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NM_SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="10,4"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TabControl ────────────────────────────────────────────────── -->

        <Style x:Key="NM_TabControlStyle" TargetType="TabControl">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="0"/>
        </Style>

        <Style x:Key="NM_TabItemStyle" TargetType="TabItem">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"    Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"   Value="{DynamicResource DockTabActiveBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── CheckBox ──────────────────────────────────────────────────── -->

        <Style x:Key="NM_CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── ScrollBar override ────────────────────────────────────────── -->

        <Style x:Key="NM_ScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="Background"                           Value="Transparent"/>
            <Setter Property="HorizontalScrollBarVisibility"        Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility"          Value="Auto"/>
        </Style>

        <!-- ── ListBox (package list) ────────────────────────────────────── -->

        <Style x:Key="NM_ListBoxStyle" TargetType="ListBox">
            <Setter Property="Background"      Value="{DynamicResource DockWindowBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="NM_ListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource DockBorderBrush}"
                                Padding="10,8">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Converters ────────────────────────────────────────────────── -->

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>   <!-- Top toolbar -->
            <RowDefinition Height="*"/>    <!-- Content area -->
            <RowDefinition Height="26"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- Row 0 — Top Toolbar                                             -->
        <!-- ════════════════════════════════════════════════════════════════ -->

        <Border Grid.Row="0"
                Background="{DynamicResource DockWindowBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">

                <TextBlock Text="Package source:" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="0,0,6,0" FontSize="12"/>

                <ComboBox Style="{StaticResource NM_ComboBoxStyle}"
                          ItemContainerStyle="{StaticResource NM_ComboBoxItemStyle}"
                          MinWidth="140" SelectedIndex="0"
                          Foreground="{DynamicResource DockMenuForegroundBrush}">
                    <ComboBoxItem Foreground="{DynamicResource DockMenuForegroundBrush}">nuget.org</ComboBoxItem>
                </ComboBox>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="10,4" Width="1"
                           Background="{DynamicResource DockBorderBrush}"/>

                <CheckBox Style="{StaticResource NM_CheckBoxStyle}"
                          IsChecked="{Binding IncludePrerelease}"
                          Content="Include prerelease"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- Row 1 — Content (Left panel | Splitter | Right detail panel)   -->
        <!-- ════════════════════════════════════════════════════════════════ -->

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200" MaxWidth="500"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- ── Col 0 : Left panel ──────────────────────────────────── -->

            <Grid Grid.Column="0" Background="{DynamicResource DockWindowBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Tab strip -->
                    <RowDefinition Height="Auto"/>   <!-- Search box -->
                    <RowDefinition Height="*"/>      <!-- Package list -->
                    <RowDefinition Height="Auto"/>   <!-- Load more -->
                </Grid.RowDefinitions>

                <!-- Tab strip: Browse / Installed / Updates -->
                <TabControl Grid.Row="0"
                            Style="{StaticResource NM_TabControlStyle}"
                            ItemContainerStyle="{StaticResource NM_TabItemStyle}"
                            SelectedIndex="{Binding ActiveTabIndex}"
                            Background="{DynamicResource DockWindowBackgroundBrush}"
                            Foreground="{DynamicResource DockMenuForegroundBrush}">
                    <TabItem Header="Browse"/>
                    <TabItem Header="Installed"/>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Updates" VerticalAlignment="Center"/>
                                <Border CornerRadius="9" MinWidth="18" Height="18"
                                        Margin="5,0,0,0" Padding="4,0"
                                        Background="{DynamicResource DockTabActiveBrush}"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UpdateCount}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding UpdateCount}"
                                               Foreground="White"
                                               FontSize="10" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                </TabControl>

                <!-- Search box -->
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource DockBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Style="{StaticResource NM_TextBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 Padding="8,6"
                                 x:Name="SearchBox">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <!-- Search icon button -->
                        <Button Grid.Column="1"
                                Command="{Binding SearchCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Search">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Package list -->
                <ListBox Grid.Row="2"
                         Style="{StaticResource NM_ListBoxStyle}"
                         ItemContainerStyle="{StaticResource NM_ListBoxItemStyle}"
                         ItemsSource="{Binding PackageList}"
                         SelectedItem="{Binding SelectedPackage}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:NuGetPackageViewModel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: color dot + id + version + update badge -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding StatusBrush}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Id}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding LatestVersion, StringFormat=' · v{0}'}"
                                               Foreground="{DynamicResource DockTabTextBrush}"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="2,0,0,0"/>
                                    <Border Background="#2DD68910" CornerRadius="2"
                                            Margin="6,0,0,0" Padding="4,1"
                                            Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Update" FontSize="10"
                                                   Foreground="#D68910"/>
                                    </Border>
                                </StackPanel>

                                <!-- Row 1: description (truncated) -->
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Description}"
                                           FontSize="11"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           Opacity="0.65"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="32"
                                           Margin="14,2,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Load more button -->
                <Button Grid.Row="3"
                        Content="Load more…"
                        Style="{StaticResource NM_SecondaryButtonStyle}"
                        Command="{Binding LoadMoreCommand}"
                        Visibility="{Binding HasMoreResults, Converter={StaticResource BoolToVis}}"
                        Margin="8,4" HorizontalAlignment="Center"/>
            </Grid>

            <!-- ── Col 1 : Grid Splitter ───────────────────────────────── -->

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"
                          ShowsPreview="True"/>

            <!-- ── Col 2 : Right detail panel ──────────────────────────── -->

            <Grid Grid.Column="2"
                  Background="{DynamicResource DockMenuBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Package header -->
                    <RowDefinition Height="*"/>      <!-- Description + metadata -->
                    <RowDefinition Height="Auto"/>   <!-- Version selector -->
                    <RowDefinition Height="Auto"/>   <!-- Action buttons -->
                </Grid.RowDefinitions>

                <!-- Placeholder when nothing is selected -->
                <TextBlock Grid.RowSpan="4"
                           Text="Select a package to view details."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Opacity="0.45"
                           FontSize="13"
                           Visibility="{Binding HasSelectedPackage, Converter={StaticResource BoolToVis}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedPackage}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasSelectedPackage}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Detail panel (visible only when a package is selected) -->
                <StackPanel Grid.RowSpan="4">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedPackage}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- ── Package header ── -->
                    <Border BorderBrush="{DynamicResource DockBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon placeholder -->
                            <Border Grid.Column="0"
                                    Width="40" Height="40"
                                    CornerRadius="4"
                                    Background="{DynamicResource DockTabHoverBrush}"
                                    VerticalAlignment="Top">
                                <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="20" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#C8A018"/>
                            </Border>

                            <!-- Package name + authors -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedPackage.Id}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding SelectedPackage.Authors}"
                                           FontSize="11"
                                           Foreground="{DynamicResource DockTabTextBrush}"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Description + metadata ── -->
                    <ScrollViewer Style="{StaticResource NM_ScrollViewerStyle}"
                                  MaxHeight="200">
                        <StackPanel Margin="14,10">

                            <!-- Description -->
                            <TextBlock Text="Description"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedPackage.Description}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Opacity="0.85"/>

                            <!-- Downloads -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Downloads: "
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                <TextBlock Text="{Binding SelectedPackage.TotalDownloads, StringFormat=N0}"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                            </StackPanel>

                            <!-- Installed version badge -->
                            <Border Margin="0,8,0,0"
                                    Visibility="{Binding SelectedPackage.IsInstalled, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="11" Margin="0,0,4,0"
                                               Foreground="#4EC9B0" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="11"
                                               Foreground="#4EC9B0">
                                        <Run Text="Installed: v"/>
                                        <Run Text="{Binding SelectedPackage.InstalledVersion}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── Version selector ── -->
                    <Border BorderBrush="{DynamicResource DockBorderBrush}"
                            BorderThickness="0,1,0,1"
                            Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Version:"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Margin="0,0,8,0"/>
                            <ComboBox Style="{StaticResource NM_ComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource NM_ComboBoxItemStyle}"
                                      ItemsSource="{Binding AvailableVersions}"
                                      SelectedItem="{Binding SelectedVersion}"
                                      MinWidth="160"
                                      Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Action buttons ── -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="14,10">

                        <!-- Install (shown when NOT installed) -->
                        <Button Content="Install"
                                Command="{Binding InstallCommand}"
                                Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NM_PrimaryButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPackage.IsInstalled}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Update (shown when HasUpdate) -->
                        <Button Content="Update"
                                Command="{Binding UpdateCommand}"
                                Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NM_PrimaryButtonStyle}">
                                    <Setter Property="Background" Value="#D68910"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPackage.HasUpdate}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Uninstall (shown when installed) -->
                        <Button Content="Uninstall"
                                Command="{Binding UninstallCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NM_PrimaryButtonStyle}">
                                    <Setter Property="Background" Value="#C0392B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPackage.IsInstalled}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- Row 2 — Status Bar                                              -->
        <!-- ════════════════════════════════════════════════════════════════ -->

        <Border Grid.Row="2"
                Background="{DynamicResource DockWindowBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Busy indicator -->
                <ProgressBar Grid.Column="0"
                             Width="80" Height="4"
                             IsIndeterminate="True"
                             Margin="8,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Foreground="{DynamicResource DockTabActiveBrush}"
                             Background="Transparent"
                             BorderThickness="0"/>

                <!-- Status text -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           FontSize="11"
                           Margin="4,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>

                <!-- Package count -->
                <TextBlock Grid.Column="2"
                           FontSize="11"
                           Margin="8,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockTabTextBrush}">
                    <Run Text="{Binding PackageList.Count, Mode=OneWay}"/>
                    <Run Text=" package(s)"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>

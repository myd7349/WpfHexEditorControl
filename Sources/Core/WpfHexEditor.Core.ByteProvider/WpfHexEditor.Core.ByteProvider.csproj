<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <UseWPF>false</UseWPF>
    <RootNamespace>WpfHexEditor.Core</RootNamespace>
    <AssemblyName>WpfHexEditor.Core.ByteProvider</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- NuGet metadata -->
    <PackageId>WpfHexEditor.Core.ByteProvider</PackageId>
    <Version>1.3.0</Version>
    <AssemblyVersion>1.3.0.0</AssemblyVersion>
    <FileVersion>1.3.0</FileVersion>
    <Authors>Derek Tremblay;Claude Sonnet 4.6</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Product>WpfHexEditor.Core.ByteProvider</Product>
    <Copyright>GNU Affero General Public License v3.0 - 2026</Copyright>
    <Description>
      Cross-platform byte provider for gigabyte-scale binary files — zero WPF dependency.

      Provides high-performance services for reading, writing, and editing binary data:
      • ByteProvider — ultra-fast file I/O with virtual/physical position mapping
      • IByteProvider — public interface for mocking and decorator patterns
      • ByteProviderOptions — fluent configuration (MMF threshold, undo depth, cache size)
      • MemoryMappedFileProvider — automatic memory-mapped I/O for files &gt; 512 MB
      • EditsManager — in-memory edit tracking (modify, insert, delete)
      • UndoRedoManager — full undo/redo with named transactions
      • SearchEngine — pattern search (text, hex, wildcard, relative, regex-over-binary)
      • KnownPatterns — pre-built magic-byte arrays (PE, ELF, ZIP, PNG, PDF, SQLite…)
      • ChangesetSnapshot — import/export/checkpoint support with JSON serialization
      • ByteProviderDiff — binary diff engine (Compare + ApplyDiff)
      • Async I/O — OpenFileAsync, SaveAsync, GetBytesAsync, FindAllAsync
      • Streaming reads — ReadLinesAsync, CopyToAsync, ReadBytesStream
      • Rich events — ByteModified, BytesInserted, BytesDeleted, SaveCompleted
      • IByteProviderFactory — DI-friendly factory (file / stream / memory)
      • ByteProviderDecorator — abstract base for AOP decorators (logging, metrics, encryption)
      • ByteSlice — zero-allocation span-like view over a virtual range
      • IByteProviderMetrics — telemetry hooks; NullByteProviderMetrics for zero-overhead default

      Targets .NET 8.0+ (no Windows-specific APIs).
      Usable in WPF, WinForms, console, ASP.NET and cross-platform applications.
    </Description>
    <PackageTags>binary;hex;byte-provider;undo-redo;search;cross-platform;file-io;changeset;diff;async;memory-mapped;factory;decorator;metrics</PackageTags>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorControl</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorControl</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>

    <!-- Packaging -->
    <PackageOutputPath>$(MSBuildThisFileDirectory)..\..\..\artifacts\nuget</PackageOutputPath>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>1.3.0 — DI/AOP/Slice/Metrics tier: IByteProviderFactory + ByteProviderFactory (create-and-open in one call, DI-registrable); ByteProviderDecorator abstract base (forward-all pattern, subclass to intercept); ByteSlice zero-allocation span-like view (index, sub-slice, SequenceEqual, CopyTo); IByteProviderMetrics telemetry hooks wired into OpenFile/Close/Modify/Insert/Delete/Save/Search with NullByteProviderMetrics singleton as zero-overhead default; ByteProviderOptions.WithMetrics() fluent injection. 1.2.0 — IByteProvider public interface; ByteProviderOptions fluent config; MemoryMappedFileProvider auto-switch (&gt;512 MB); rich events (ByteModified, BytesInserted, BytesDeleted, SaveCompleted); ExportChangesetJson/ImportChangesetJson/checkpoints; ByteProviderDiff; KnownPatterns; async streaming (FindAllAsync, SearchStreamAsync, ReadLinesAsync, CopyToAsync); SearchRegex/SearchRegexAsync. 1.1.1 — Completed undo/redo unification (issue #107). 1.1.0 — IUndoAwareEditor contract + HexByteUndoEntry; regression test suite.</PackageReleaseNotes>

    <!-- SourceLink: enables step-through debugging for NuGet consumers -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <DebugType>embedded</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.*" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <None Include="icon.png" Pack="true" PackagePath="\" />
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="WpfHexEditor-Core-ByteProvider-guide.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <UseWPF>false</UseWPF>
    <RootNamespace>WpfHexEditor.Core</RootNamespace>
    <AssemblyName>WpfHexEditor.Core.ByteProvider</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- NuGet metadata -->
    <PackageId>WpfHexEditor.Core.ByteProvider</PackageId>
    <Version>1.1.1</Version>
    <AssemblyVersion>1.1.1.0</AssemblyVersion>
    <FileVersion>1.1.1</FileVersion>
    <Authors>Derek Tremblay;Claude Sonnet 4.6</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Product>WpfHexEditor.Core.ByteProvider</Product>
    <Copyright>GNU Affero General Public License v3.0 - 2026</Copyright>
    <Description>
      Cross-platform byte provider for gigabyte-scale binary files — zero WPF dependency.

      Provides high-performance services for reading, writing, and editing binary data:
      • ByteProvider — ultra-fast file I/O with virtual/physical position mapping
      • EditsManager — in-memory edit tracking (modify, insert, delete)
      • UndoRedoManager — full undo/redo support
      • SearchEngine — pattern search (text, hex, wildcard, relative, regex)
      • ChangesetSnapshot — immutable snapshot of pending edits for serialization

      Targets .NET 8.0+ (no Windows-specific APIs).
      Usable in WPF, WinForms, console, ASP.NET and cross-platform applications.
    </Description>
    <PackageTags>binary;hex;byte-provider;undo-redo;search;cross-platform;file-io;changeset</PackageTags>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorControl</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorControl</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>

    <!-- Packaging -->
    <PackageOutputPath>$(MSBuildThisFileDirectory)..\..\..\artifacts\nuget</PackageOutputPath>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>1.1.1 — Completed undo/redo unification (issue #107): HexEditor ↔ CodeEditor now share a single UndoEngine via the IUndoAwareEditor contract. Bundled with the NuGet wave v0.6.5.15. No public API changes. 1.1.0 — IUndoAwareEditor contract + HexByteUndoEntry for shared undo engine; DocumentBuffer undo wiring; regression test suite added (ByteProvider, UndoRedo, Search, Edits, Changeset).</PackageReleaseNotes>

    <!-- SourceLink: enables step-through debugging for NuGet consumers -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <DebugType>embedded</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.*" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <None Include="icon.png" Pack="true" PackagePath="\" />
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="WpfHexEditor-Core-ByteProvider-guide.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>

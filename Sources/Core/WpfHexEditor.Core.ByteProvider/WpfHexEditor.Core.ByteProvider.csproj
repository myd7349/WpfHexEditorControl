<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <UseWPF>false</UseWPF>
    <RootNamespace>WpfHexEditor.Core</RootNamespace>
    <AssemblyName>WpfHexEditor.Core.ByteProvider</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- NuGet metadata -->
    <PackageId>WpfHexEditor.Core.ByteProvider</PackageId>
    <Version>1.0.1</Version>
    <AssemblyVersion>1.0.1.0</AssemblyVersion>
    <FileVersion>1.0.1</FileVersion>
    <Authors>Derek Tremblay;Claude Sonnet 4.6</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Product>WpfHexEditor.Core.ByteProvider</Product>
    <Copyright>GNU Affero General Public License v3.0 - 2026</Copyright>
    <Description>
      Cross-platform byte provider for gigabyte-scale binary files — zero WPF dependency.

      Provides high-performance services for reading, writing, and editing binary data:
      • ByteProvider — ultra-fast file I/O with virtual/physical position mapping
      • EditsManager — in-memory edit tracking (modify, insert, delete)
      • UndoRedoManager — full undo/redo support
      • SearchEngine — pattern search (text, hex, wildcard, relative, regex)
      • ChangesetSnapshot — immutable snapshot of pending edits for serialization

      Targets .NET 8.0+ (no Windows-specific APIs).
      Usable in WPF, WinForms, console, ASP.NET and cross-platform applications.
    </Description>
    <PackageTags>binary;hex;byte-provider;undo-redo;search;cross-platform;file-io;changeset</PackageTags>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorControl</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorControl</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>

    <!-- Packaging -->
    <PackageOutputPath>$(MSBuildThisFileDirectory)..\..\..\artifacts\nuget</PackageOutputPath>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>1.0.1 — README corrections: OpenFile/GetBytes/SearchText/SearchHex examples, batch undo transaction example, changeset iteration example.</PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup>
    <None Include="icon.png" Pack="true" PackagePath="\" />
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>

    Project     : WpfHexEditor.Core.Localization
    Description : Shared localization micro-package. Provides common UI strings,
                  LocalizedResourceDictionary (generic, multi-source), and ILocalizationService.
                  Zero dependencies. Each NuGet-published UI package references this.
-->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>WpfHexEditor.Core.Localization</RootNamespace>
    <AssemblyName>WpfHexEditor.Core.Localization</AssemblyName>
    <Title>WpfHexEditor.Core.Localization - Shared localization infrastructure</Title>
    <PackageId>WpfHexEditor.Core.Localization</PackageId>
    <IsPackable>false</IsPackable>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <Authors>Derek Tremblay</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Description>
      Shared localization infrastructure for WpfHexEditorControl NuGet packages.
      Provides common UI strings (OK, Cancel, Close, Save…), a generic
      LocalizedResourceDictionary supporting multiple ResourceManagers, and
      ILocalizationService for runtime culture switching without app restart.
      Supports 18 languages: ar-SA, de-DE, es-ES, es-419, fr-CA, fr-FR,
      hi-IN, it-IT, ja-JP, ko-KR, nl-NL, pl-PL, pt-BR, pt-PT, ru-RU,
      sv-SE, tr-TR, zh-CN.
    </Description>
    <Copyright>GNU AGPL v3.0 - 2016-2026</Copyright>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0</FileVersion>
    <Version>1.0.0</Version>
    <PackageTags>localization;i18n;l10n;wpf;resources;culture;satellite-assemblies</PackageTags>
    <LangVersion>preview</LangVersion>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorControl</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorControl</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
    <NeutralLanguage>en-US</NeutralLanguage>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)'=='Release' and '$(TargetFramework)'=='net8.0-windows'">
    <TieredCompilation>true</TieredCompilation>
    <TieredPGO>true</TieredPGO>
    <DebugType>embedded</DebugType>
    <Optimize>true</Optimize>
  </PropertyGroup>

  <ItemGroup>
    <Compile Update="Properties\CommonResources.Designer.cs">
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
      <DependentUpon>CommonResources.resx</DependentUpon>
      <DesignTime>True</DesignTime>
    </Compile>
    <EmbeddedResource Update="Properties\CommonResources.resx">
      <SubType>Designer</SubType>
      <LastGenOutput>CommonResources.Designer.cs</LastGenOutput>
      <Generator>PublicResXFileCodeGenerator</Generator>
    </EmbeddedResource>
  </ItemGroup>

  <!-- Pack satellite assemblies into NuGet package -->
  <Target Name="PackSatelliteAssemblies" AfterTargets="Build">
    <ItemGroup>
      <SatelliteDlls Include="$(OutputPath)*\$(AssemblyName).resources.dll" />
    </ItemGroup>
  </Target>

</Project>

{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "ONNX Neural Network Model",
  "formatId": "ONNX",
  "version": "1.0.1",
  "extensions": [".onnx"],
  "description": "Open Neural Network Exchange (ONNX) model file using Protocol Buffers serialization. ONNX provides cross-framework ML model interoperability between PyTorch, TensorFlow, and inference runtimes such as ONNX Runtime, TensorRT, and OpenVINO. Files are serialized ModelProto protobuf messages with no fixed magic bytes; detection relies on protobuf tag heuristics and file extension.",
  "category": "MachineLearning",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://onnx.ai/",
    "https://github.com/onnx/onnx/blob/main/docs/IR.md",
    "https://github.com/onnx/onnx/blob/main/onnx/onnx.proto",
    "https://en.wikipedia.org/wiki/Open_Neural_Network_Exchange"
  ],
  "detection": {
    "signatures": [
      {
        "offset": 0,
        "value": "08",
        "label": "Protobuf field 1 tag (ir_version varint) — common ONNX start byte 0x08",
        "weight": 0.5
      },
      {
        "offset": 0,
        "value": "0A",
        "label": "Protobuf field 1 length-delimited — alternative ONNX start",
        "weight": 0.3
      }
    ],
    "matchMode": "best",
    "MinimumScore": 0.3,
    "Strength": "Weak",
    "EntropyHint": "Mixed — protobuf structural metadata at moderate entropy (4.0-5.5); initializer weight tensors at high entropy (6.5-8.0)"
  },
  "variables": [
    {
      "name": "onnxProtoTag",
      "offset": 0,
      "size": 1,
      "type": "uint8",
      "description": "First protobuf tag byte; 0x08 = field 1 varint (ir_version)"
    },
    {
      "name": "onnxFirstValue",
      "offset": 1,
      "size": 4,
      "type": "hex",
      "description": "First 4 bytes after the tag — varint-encoded ir_version"
    },
    {
      "name": "onnxIrVersion",
      "offset": 1,
      "size": 1,
      "type": "uint8",
      "description": "ONNX IR version (single-byte varint for values 1-127)",
      "valueMap": {
        "3": "ONNX IR v3 (ONNX 1.2)",
        "4": "ONNX IR v4 (ONNX 1.3)",
        "5": "ONNX IR v5 (ONNX 1.4)",
        "6": "ONNX IR v6 (ONNX 1.6)",
        "7": "ONNX IR v7 (ONNX 1.7)",
        "8": "ONNX IR v8 (ONNX 1.8)",
        "9": "ONNX IR v9 (ONNX 1.14)",
        "10": "ONNX IR v10 (ONNX 1.15+)"
      }
    },
    {
      "name": "onnxNextTag",
      "offset": 2,
      "size": 1,
      "type": "uint8",
      "description": "Second protobuf tag: 0x12 = producer_name (field 2), 0x42 = opset_import (field 8)"
    }
  ],
  "blocks": [
    {
      "name": "ProtobufTag",
      "offset": 0,
      "size": 1,
      "description": "First protobuf field tag byte; 0x08 for ir_version (field 1, wire type 0)"
    },
    {
      "name": "IRVersion",
      "offset": 1,
      "size": 1,
      "description": "Varint-encoded ONNX Intermediate Representation version"
    },
    {
      "name": "ProducerMetadata",
      "offset": 2,
      "size": 32,
      "description": "Producer name and version fields (field 2, 3) identifying the originating framework"
    },
    {
      "name": "OpsetImport",
      "offset": 34,
      "size": 16,
      "description": "Opset import table (field 8) specifying operator set domain and version"
    },
    {
      "name": "GraphProto",
      "offset": 50,
      "size": 64,
      "description": "GraphProto (field 7) containing node[], initializer[], input[], output[] definitions"
    },
    {
      "name": "InitializerTensors",
      "offset": 114,
      "size": 128,
      "description": "Weight tensor data in initializer[] — constitutes the majority of file size for non-trivial models"
    }
  ],
  "assertions": [
    {
      "variable": "onnxProtoTag",
      "operator": "==",
      "value": 8,
      "description": "First byte should be 0x08 (protobuf field 1, varint wire type)",
      "level": "Warning"
    },
    {
      "variable": "onnxIrVersion",
      "operator": "between",
      "value": [1, 15],
      "description": "IR version should be in range 1-15",
      "level": "Warning"
    },
    {
      "variable": "onnxIrVersion",
      "operator": ">",
      "value": 0,
      "description": "IR version must be positive",
      "level": "Error"
    },
    {
      "variable": "onnxProtoTag",
      "operator": "in",
      "value": [8, 10, 18, 26, 34, 42, 50, 58, 66],
      "description": "First tag byte must be a valid protobuf wire type 0 or 2 tag",
      "level": "Info"
    }
  ],
  "navigation": {
    "entryPoint": 0,
    "sections": [
      { "name": "Protobuf Tag", "offset": 0, "size": 1 },
      { "name": "IR Version", "offset": 1, "size": 1 },
      { "name": "Producer Metadata", "offset": 2, "size": 32 }
    ]
  },
  "inspector": {
    "badge": "ONNX",
    "primaryField": "onnxIrVersion",
    "groups": [
      {
        "name": "Protobuf Header",
        "fields": ["onnxProtoTag", "onnxIrVersion", "onnxNextTag"]
      },
      {
        "name": "Model Bytes",
        "fields": ["onnxFirstValue"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "ONNX Header Summary",
      "format": "text",
      "template": "Format: ONNX Model\nTag Byte: 0x{onnxProtoTag:X2}\nIR Version: {onnxIrVersion}\nNext Tag: 0x{onnxNextTag:X2}"
    },
    {
      "name": "ONNX JSON Report",
      "format": "json",
      "template": "{ \"format\": \"ONNX\", \"protoTag\": {onnxProtoTag}, \"irVersion\": {onnxIrVersion} }"
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "notes": "ONNX files are passive ML model definitions and do not execute code directly. Risk arises from large initializer tensors that may inadvertently contain training data fragments.",
    "suspiciousPatterns": [
      "Unusually large initializer tensors (>2 GB) may indicate LLM weights or unoptimized graphs",
      "Custom operator domain strings may indicate proprietary or experimental operators with unknown behavior",
      "Embedded metadata_props may contain training configuration or dataset provenance information",
      "Producer name 'unknown' or missing may indicate manual file construction or obfuscation"
    ]
  },
  "aiHints": {
    "analysisContext": "ONNX files are Protocol Buffers (protobuf) serializations of a ModelProto message. No fixed magic bytes exist; the first byte is typically 0x08 (protobuf field 1 tag for ir_version varint). The graph contains nodes (operators), initializer tensors (weights), and input/output shape information. Use Netron for visual graph inspection.",
    "suggestedInspections": [
      "Check the first byte: 0x08 indicates field 1 (ir_version) present; decode the following varint to get the ONNX IR version.",
      "Scan for producer_name string (protobuf field 2) to identify the originating framework: 'pytorch', 'tf2onnx', 'onnxmltools', 'onnxruntime'.",
      "Examine opset_import entries (field 8) to verify operator set compatibility with the target inference runtime and detect non-standard domains.",
      "Estimate model complexity by counting node entries in the GraphProto (field 7); locate initializer tensors to determine model size distribution.",
      "Check metadata_props (repeated key-value pairs) for training dataset info, license strings, or model card data.",
      "For large files (>2 GB), look for external data format where tensor data is stored in separate files referenced by the ONNX protobuf."
    ]
  },
  "software": [
    { "name": "Netron", "platform": "Windows/macOS/Linux/Web", "url": "https://netron.app/" },
    { "name": "ONNX Runtime", "platform": "Windows/macOS/Linux", "url": "https://onnxruntime.ai/" },
    { "name": "PyTorch (torch.onnx.export)", "platform": "Windows/macOS/Linux", "url": "https://pytorch.org/" },
    { "name": "tf2onnx", "platform": "Windows/macOS/Linux", "url": "https://github.com/onnx/tensorflow-onnx" },
    { "name": "TensorRT", "platform": "Linux/Windows", "url": "https://developer.nvidia.com/tensorrt" }
  ],
  "formatRelationships": [
    { "format": "JOBLIB", "relationship": "alternative", "note": "JOBLIB/pickle is scikit-learn's serialization; ONNX is framework-neutral protobuf" },
    { "format": "PMML", "relationship": "alternative", "note": "PMML is XML-based ML model interchange; ONNX is protobuf binary and supports deep learning" }
  ],
  "MimeTypes": ["application/octet-stream", "application/x-onnx"],
  "UseCases": [
    "Cross-framework ML model interchange between PyTorch, TensorFlow, and other training frameworks",
    "Optimized inference deployment via ONNX Runtime, TensorRT, and OpenVINO",
    "Edge AI and mobile inference with model quantization and optimization",
    "Model validation, visualization, and architecture inspection"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  },
  "TechnicalDetails": {
    "serializationFormat": "Google Protocol Buffers (protobuf) wire format",
    "schemaFile": "github.com/onnx/onnx/blob/main/onnx/onnx.proto",
    "endianness": "Protobuf-defined (varint encoding; fixed-width tensor fields are little-endian)",
    "modelStructure": {
      "ModelProto": "ir_version, opset_import[], producer_name, producer_version, domain, model_version, graph, metadata_props[]",
      "GraphProto": "node[] (operators), initializer[] (weight tensors), input[], output[], value_info[]",
      "NodeProto": "op_type, input[], output[], attribute[], domain",
      "TensorProto": "dims[], data_type, raw_data or typed float/int arrays"
    },
    "externalDataNote": "Models > 2 GB use external data format: tensor data in separate files alongside the .onnx protobuf"
  }
}




    }
  ],
  "forensic": {
    "category": "game",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "PPF format: 'PPF10/20/30'(5B) + description(50B ASCII). PPF2.0+ adds encoding_method(1B) + image_type(1B) + block_check(1B) + undo_flag(1B). PPF3.0 adds sector_size(1B) + file_id_count(4B LE). Records: offset(4B or 8B LE) + data_len(1B) + data. Designed for PS1 BIN disc images.",
    "suggestedInspections": [
      "Read bytes 0-4 for magic: 'PPF10'=v1, 'PPF20'=v2, 'PPF30'=v3",
      "Read description at bytes 5-54 (50-byte null-padded ASCII) for patch identification",
      "For PPF 2.0/3.0: read encoding_method at offset 55 (0=raw, 1=GZip) and image_type at offset 56 (0=BIN/CUE, 1=IMG)",
      "For PPF 3.0: check sector_size_id at offset 60 (1=2352-byte raw sectors, 2=2048-byte cooked)"
    ]
  },
  "software": [
    "PPF-O-MATIC v3 (Windows PPF patch application tool)",
    "UniPatcher (Android — supports PPF)",
    "CDmage (PS1 disc image manager with PPF support)",
    "ImgBurn (can apply PPF patches to disc images)"
  ],
  "formatRelationships": {
    "category": "RomHacking",
    "extensions": [".ppf"],
    "relatedFormats": ["IPS", "UPS"],
    "note": "PPF was specifically designed for PlayStation 1 BIN disc images. Unlike IPS, PPF supports 4-byte (PPF 2.0) or 8-byte (PPF 3.0) file offsets, enabling patching of full PS1 disc images up to 650 MB."
  },
  "MimeTypes": ["application/octet-stream"],
  "UseCases": [
    "Applying fan translation patches to PlayStation 1 disc images",
    "Distributing bug-fix patches for PSX game releases",
    "ROM hacking patches for PlayStation 1 games in BIN/CUE format",
    "Applying multiplayer and modding patches to PS1 games"
  ],

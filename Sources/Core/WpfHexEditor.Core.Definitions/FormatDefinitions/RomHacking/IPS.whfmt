    }
  ],
  "forensic": {
    "category": "game",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "IPS format: 'PATCH'(5B ASCII) + records + 'EOF'(3B=0x454F46). Record: offset(3B BE) + size(2B BE); if size>0: data(size bytes); if size==0: rleCount(2B BE) + rleValue(1B). End: when offset field reads 0x454F46 ('EOF'). No CRC, no source hash. Max target offset: 0xFFFFFF (16 MB). Minimum valid file: 8 bytes.",
    "suggestedInspections": [
      "Bytes 0-4: must be ASCII 'PATCH' (0x50 0x41 0x54 0x43 0x48)",
      "Bytes 5-7: first record target offset in ROM (3B BE uint24, 0x454F46='EOF' means empty patch)",
      "Bytes 8-9: first record size (uint16 BE: 0=RLE record, >0=raw data length in bytes)",
      "Scan file backwards: last 3 bytes must be 'EOF' (0x45 0x4F 0x46) end-of-patch marker"
    ]
  },
  "software": [
    "Lunar IPS (Windows IPS patch tool — most popular)",
    "Floating IPS / flips (cross-platform, also applies BPS)",
    "UniPatcher (Android ROM patch application)",
    "RetroArch (built-in IPS soft-patching on ROM load)"
  ],
  "formatRelationships": {
    "category": "RomHacking",
    "extensions": [".ips"],
    "relatedFormats": ["UPS", "PATCH_BPS", "PPF"],
    "note": "IPS is the oldest widely-used ROM patch format (1990s). Limitations: 16 MB max address, no integrity checks, cannot truncate target. BPS supersedes IPS with CRC32 validation. UPS supports unlimited target size. PPF targets PS1 disc images."
  },
  "MimeTypes": ["application/octet-stream"],
  "UseCases": [
    "Distributing fan translation patches for SNES, NES, and GBA games",
    "Sharing ROM hacks and bug-fix patches via ROMhacking.net",
    "Applying gameplay modification patches to retro console ROMs",
    "Legacy patch distribution for classic console emulation"
  ],
  "QualityMetrics": {

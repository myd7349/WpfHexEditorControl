    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Magic": "'PATCH' ASCII (5 bytes) at offset 0; 'EOF' (3 bytes 0x454F46) end marker",
    "RecordFormat": "offset(3B BE) + size(2B BE) + [data(size B) | rleCount(2B BE) + rleVal(1B)]",
    "MaxTargetOffset": "0xFFFFFF (16,777,215 bytes = 16 MB)",
    "Integrity": "None — no CRC or source hash",
    "Successor": "BPS (Beat Patching System) with CRC32 validation"
  }

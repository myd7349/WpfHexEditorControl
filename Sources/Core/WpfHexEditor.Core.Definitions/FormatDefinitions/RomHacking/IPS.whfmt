    "primaryField": "firstRecordOffset",
    "showQualityScore": true,
    "groups": [
      {
        "title": "IPS Patch Header",
        "icon": "\uE71B",
        "fields": ["ipsHeader", "firstRecordOffset", "firstRecordSize"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "IPS Patch Header (JSON)",
      "format": "json",
      "fields": ["ipsHeader", "firstRecordOffset", "firstRecordSize"]
    },
    {
      "name": "IPS Patch Summary (CSV)",

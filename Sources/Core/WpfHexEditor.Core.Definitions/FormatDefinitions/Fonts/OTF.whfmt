{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "OpenType Font",
  "formatId": "OTF",
  "version": "2.02",
  "extensions": [
    ".otf"
  ],
  "description": "OpenType Font format with CFF (Compact Font Format) outlines - a cross-platform font standard jointly developed by Microsoft and Adobe. Identified by the 'OTTO' signature (0x4F54544F), indicating PostScript/CFF-based outlines (cubic Bezier curves) rather than TrueType quadratic outlines. The file structure mirrors TrueType with an Offset Table header followed by a Table Directory containing 16-byte entries per table. OpenType CFF fonts typically include CFF/CFF2 (outline data), GPOS (glyph positioning for kerning, mark attachment), GSUB (glyph substitution for ligatures, alternates), and GDEF (glyph class definitions) tables for advanced typographic features.",
  "category": "Fonts",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "OpenType Specification 1.9",
      "ISO/IEC 14496-22:2019 - Open Font Format",
      "Adobe CFF (Compact Font Format) Specification",
      "Microsoft OpenType Font File Specification"
    ],
    "WebLinks": [
      "https://docs.microsoft.com/en-us/typography/opentype/spec/",
      "https://en.wikipedia.org/wiki/OpenType",
      "https://learn.microsoft.com/en-us/typography/opentype/spec/cff",
      "https://adobe-type-tools.github.io/font-tech-notes/pdfs/5176.CFF.pdf"
    ]
  },
  "lastUpdated": "2026-05-20",
  "signatures": [
    {
      "value": "4F54544F",
      "offset": 0,
      "label": "OTTO — OpenType CFF font (PostScript cubic Bezier outlines)",
      "weight": 1.0,
      "strength": "Strong"
    }
  ],
  "maxSignatureOffset": 0,
  "structure": {
    "fields": [
      {
        "name": "sfntVersion",
        "type": "ascii",
        "offset": 0,
        "length": 4,
        "description": "sfnt version / signature: 'OTTO' for CFF OpenType"
      },
      {
        "name": "numTables",
        "type": "uint16be",
        "offset": 4,
        "length": 2,
        "description": "Number of font tables"
      },
      {
        "name": "searchRange",
        "type": "uint16be",
        "offset": 6,
        "length": 2,
        "description": "Binary search optimization: (maxPow2 <= numTables) * 16"
      },
      {
        "name": "entrySelector",
        "type": "uint16be",
        "offset": 8,
        "length": 2,
        "description": "log2(maxPow2 <= numTables)"
      },
      {
        "name": "rangeShift",
        "type": "uint16be",
        "offset": 10,
        "length": 2,
        "description": "(numTables * 16) - searchRange"
      },
      {
        "name": "tableDirectory",
        "type": "struct[]",
        "offset": 12,
        "length": -1,
        "description": "Array of numTables 16-byte table records (tag+checksum+offset+length)"
      }
    ]
  },
  "assertions": [
    {
      "name": "sfnt version is OTTO",
      "expression": "otfSignature == 'OTTO'",
      "severity": "error",
      "message": "OpenType CFF font must start with 'OTTO' (0x4F54544F) at offset 0"
    },
    {
      "name": "numTables > 0",
      "expression": "numberOfTables > 0",
      "severity": "error",
      "message": "OpenType font must have at least one table"
    },
    {
      "name": "numTables within range",
      "expression": "numberOfTables <= 100",
      "severity": "warning",
      "message": "OpenType font has an unusually high number of tables (> 100)"
    }
  ],
  "exportTemplates": [
    {
      "name": "OTF Header (JSON)",
      "format": "json",
      "fields": [
        "otfSignature",
        "numberOfTables",
        "searchRange",
        "entrySelector",
        "rangeShift"
      ]
    },
    {
      "name": "OTF Table Directory (Text)",
      "format": "text",
      "fields": [
        "otfSignature",
        "numberOfTables",
        "table1Tag",
        "table2Tag",
        "table3Tag"
      ]
    }
  ],
  "detection": {
    "signature": "4F54544F",
    "offset": 0,
    "required": true,
    "validation": {
      "minFileSize": 12,
      "maxSignatureOffset": 0
    }
  },
  "variables": {
    "currentOffset": 0,
    "otfSignature": "",
    "numberOfTables": 0,
    "searchRange": 0,
    "entrySelector": 0,
    "rangeShift": 0,
    "table1Tag": "",
    "table1Checksum": 0,
    "table1Offset": 0,
    "table1Length": 0,
    "table2Tag": "",
    "table2Checksum": 0,
    "table2Offset": 0,
    "table2Length": 0,
    "table3Tag": "",
    "table3Checksum": 0,
    "table3Offset": 0,
    "table3Length": 0,
    "numGlyphs": 0,
    "unitsPerEm": 0,
    "fontName": "",
    "tableCount": 0,
    "hasCFF": 0,
    "hasGPOS": 0,
    "hasGSUB": 0,
    "totalTableSize": 0,
    "formattedTotalSize": ""
  },
  "functions": {
    "formatFileSize(var:totalTableSize)": "Format total size of all font tables as human-readable string with units",
    "computeFromVariables(table1Length + table2Length + table3Length, totalTableSize)": "Compute combined size of the first three font tables for size overview",
    "validateFieldRange(numberOfTables, 1, 100)": "Validate table count is within reasonable range (OTF fonts typically have 10-30 tables)",
    "validateFieldRange(entrySelector, 0, 16)": "Validate entry selector is a valid log2 value"
  },
  "blocks": [
    {
      "type": "signature",
      "name": "OpenType Signature (OTTO)",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "OpenType CFF signature 'OTTO' (0x4F54544F). This 4-byte ASCII tag identifies the font as an OpenType font with PostScript CFF outlines (cubic Bezier curves). Distinguishes from TrueType-outline OpenType fonts which use 0x00010000.",
      "storeAs": "otfSignature",
      "valueType": "ascii",
      "validation": {
        "expectedValue": "OTTO"
      },
      "valueMap": {
        "OTTO": "OpenType with CFF outlines (PostScript cubic Bezier)"
      }
    },
    {
      "type": "field",
      "name": "Number of Tables",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Total number of font tables in this OpenType file. OpenType CFF fonts typically contain 10-30 tables including CFF/CFF2 (outlines), GPOS (positioning), GSUB (substitution), GDEF (glyph classes), OS/2, cmap, head, hhea, hmtx, maxp, name, and post.",
      "storeAs": "numberOfTables",
      "valueType": "uint16",
      "endianness": "big",
      "validationRules": {
        "minValue": 1,
        "maxValue": 100
      }
    },
    {
      "type": "field",
      "name": "Search Range",
      "offset": 6,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Binary search optimization value: (maximum power of 2 <= numTables) * 16. Identical algorithm to TrueType offset table. Used for efficient binary search of the table directory.",
      "storeAs": "searchRange",
      "valueType": "uint16",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Entry Selector",
      "offset": 8,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Binary search optimization value: log2(maximum power of 2 <= numTables). Number of binary search iterations needed to search the table directory.",
      "storeAs": "entrySelector",
      "valueType": "uint16",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Range Shift",
      "offset": 10,
      "length": 2,
      "color": "#DDA0DD",
      "opacity": 0.3,
      "description": "Binary search optimization value: (numTables * 16) - searchRange. Initial comparison offset for the binary search algorithm over table directory entries.",
      "storeAs": "rangeShift",
      "valueType": "uint16",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Table 1 - Tag",
      "offset": 12,
      "length": 4,
      "color": "#87CEEB",
      "opacity": 0.3,
      "description": "4-byte ASCII tag identifying the first table in the directory. Tables are sorted alphabetically by tag. For OpenType CFF fonts, common early tables include 'CFF ' (CFF outline data), 'DSIG' (digital signature), 'GDEF' (glyph definition), 'GPOS' (glyph positioning), 'GSUB' (glyph substitution).",
      "storeAs": "table1Tag",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Table 1 - Checksum",
      "offset": 16,
      "length": 4,
      "color": "#96CEB4",
      "opacity": 0.3,
      "description": "Checksum of the first table's data. Computed by summing the table data as an array of uint32 values (big-endian). The 'head' table uses a special checksumAdjustment field so the entire file checksum equals 0xB1B0AFBA.",
      "storeAs": "table1Checksum",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Table 1 - Offset",
      "offset": 20,
      "length": 4,
      "color": "#FFEAA7",
      "opacity": 0.3,
      "description": "Byte offset from the beginning of the font file to the start of the first table's data. Tables are padded to 4-byte boundaries in storage.",
      "storeAs": "table1Offset",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Table 1 - Length",
      "offset": 24,
      "length": 4,
      "color": "#FF8C69",
      "opacity": 0.3,
      "description": "Length of the first table's data in bytes (unpadded). The CFF table is often the largest, containing all glyph outline data in PostScript format.",
      "storeAs": "table1Length",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Table 2 - Tag",
      "offset": 28,
      "length": 4,
      "color": "#87CEEB",
      "opacity": 0.35,
      "description": "4-byte ASCII tag for the second table directory entry. In OpenType CFF fonts, the GPOS table provides glyph positioning data for kerning, mark-to-base attachment, and cursive connections.",
      "storeAs": "table2Tag",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Table 2 - Checksum",
      "offset": 32,
      "length": 4,
      "color": "#96CEB4",
      "opacity": 0.35,
      "description": "Checksum of the second table's data, computed using the same uint32 summation algorithm.",
      "storeAs": "table2Checksum",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Table 2 - Offset",
      "offset": 36,
      "length": 4,
      "color": "#FFEAA7",
      "opacity": 0.35,
      "description": "Byte offset from the beginning of the font file to the start of the second table's data.",
      "storeAs": "table2Offset",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Table 2 - Length",
      "offset": 40,
      "length": 4,
      "color": "#FF8C69",
      "opacity": 0.35,
      "description": "Length of the second table's data in bytes (unpadded).",
      "storeAs": "table2Length",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Table 3 - Tag",
      "offset": 44,
      "length": 4,
      "color": "#87CEEB",
      "opacity": 0.4,
      "description": "4-byte ASCII tag for the third table directory entry. The GSUB table contains glyph substitution data for ligatures, contextual alternates, stylistic sets, and other advanced OpenType features.",
      "storeAs": "table3Tag",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Table 3 - Checksum + Offset + Length",
      "offset": 48,
      "length": 12,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Checksum (4 bytes), offset (4 bytes), and length (4 bytes) for the third table directory entry. Same 16-byte structure as all other table directory entries.",
      "storeAs": "table3Checksum",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "computeFromVariables",
      "name": "Table Directory Size",
      "expression": "numberOfTables * 16",
      "storeAs": "totalTableSize",
      "description": "Total size of the table directory in bytes. Each of the numberOfTables entries is exactly 16 bytes (4-byte tag + 4-byte checksum + 4-byte offset + 4-byte length). The directory occupies bytes 12 through 12 + (numberOfTables * 16) - 1."
    },
    {
      "type": "conditional",
      "name": "Advanced Typography Check",
      "condition": "numberOfTables > 15",
      "trueLabel": "Feature-rich OpenType font (> 15 tables - likely includes GPOS, GSUB, GDEF for advanced layout)",
      "falseLabel": "Basic OpenType font (<= 15 tables - core tables with limited advanced features)",
      "description": "Determines whether the OpenType font includes a rich set of advanced typographic tables. Fonts with GPOS/GSUB support kerning, ligatures, contextual alternates, stylistic sets, and complex script shaping."
    },
    {
      "type": "conditional",
      "name": "CFF Version Check",
      "condition": "hasCFF == 1",
      "trueLabel": "Contains CFF outline data (PostScript cubic Bezier curves)",
      "falseLabel": "CFF table not yet detected - scanning table directory required",
      "description": "Checks whether the CFF (Compact Font Format) table has been located. CFF contains the PostScript Type 2 charstrings defining glyph outlines using cubic Bezier curves, offering higher precision than TrueType quadratic outlines."
    },
    {
      "type": "metadata",
      "name": "Number of Tables",
      "variable": "numberOfTables",
      "description": "Total number of font tables present in this OpenType CFF file"
    },
    {
      "type": "metadata",
      "name": "Glyph Count",
      "variable": "numGlyphs",
      "description": "Total number of glyphs in the font (from 'maxp' table)"
    },
    {
      "type": "metadata",
      "name": "Units Per Em",
      "variable": "unitsPerEm",
      "description": "Font design units per em square (from 'head' table, typically 1000 for CFF fonts)"
    },
    {
      "type": "metadata",
      "name": "Font Name",
      "variable": "fontName",
      "description": "Full font name extracted from the 'name' table (name ID 4)"
    },
    {
      "type": "metadata",
      "name": "Has CFF Outlines",
      "variable": "hasCFF",
      "description": "Whether the font contains a CFF or CFF2 table with PostScript outline data"
    },
    {
      "type": "metadata",
      "name": "Table Directory Size",
      "variable": "formattedTotalSize",
      "description": "Total size of the table directory region formatted with units"
    }
  ],
  "MimeTypes": [
    "font/otf",
    "application/x-font-opentype"
  ],
  "Software": [
    "All operating systems",
    "Adobe products",
    "Font editors",
    "FontForge",
    "Microsoft Word",
    "Adobe InDesign"
  ],
  "UseCases": [
    "Professional fonts",
    "Print design",
    "Advanced typography",
    "Multi-language typesetting",
    "Web fonts (WOFF/WOFF2)"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "comprehensive",
    "BlocksDefined": 24,
    "ValidationRules": 4,
    "LastUpdated": "2026-05-20",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "forensic": {
    "category": "font",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": [
    "OpenType CFF font starts with 'OTTO' (4F54544F) — distinguishes from TrueType (00010000)",
    "Offset table at byte 0: sfntVersion(4) + numTables(2) + searchRange(2) + entrySelector(2) + rangeShift(2)",
    "Table directory at byte 12: numTables entries of 16 bytes (tag[4]+checksum[4]+offset[4]+length[4])",
    "Required CFF tables: CFF (or CFF2), cmap, head, hhea, hmtx, maxp, name, OS/2, post",
    "GPOS and GSUB tables enable advanced typography: kerning, ligatures, contextual alternates",
    "head table checksumAdjustment: whole-file CRC must equal 0xB1B0AFBA for valid font"
  ],
  "navigation": {
    "bookmarks": [
      {
        "name": "Offset Table",
        "offsetVar": "currentOffset",
        "icon": ""
      },
      {
        "name": "Table 1 Data",
        "offsetVar": "table1Offset",
        "icon": ""
      },
      {
        "name": "Table 2 Data",
        "offsetVar": "table2Offset",
        "icon": ""
      }
    ]
  },
  "TechnicalDetails": {
    "FontFormat": true,
    "primary_extension": ".otf",
    "defined_fields": 24,
    "OutlineType": "CFF/PostScript (cubic Bezier curves)",
    "Endianness": "big-endian",
    "OffsetTableSize": 12,
    "TableDirEntrySize": 16,
    "Signature": "OTTO (0x4F54544F)",
    "RequiredTables": "CFF, cmap, head, hhea, hmtx, maxp, name, OS/2, post",
    "AdvancedTables": "GPOS, GSUB, GDEF, BASE, JSTF, MATH",
    "ChecksumAdjustment": "0xB1B0AFBA",
    "Alignment": "4-byte boundary"
  },
  "diff": {
    "keyFields": [
      "otfSignature",
      "numberOfTables",
      "table1Tag"
    ],
    "ignoreFields": [
      "searchRange",
      "entrySelector",
      "rangeShift"
    ],
    "groupBy": "numberOfTables",
    "note": "OTTO signature and table count distinguish CFF OpenType from TrueType; binary search fields are computed constants with no diff value"
  },
  "repair": [
    {
      "name": "FixOttoSignature",
      "trigger": "otfSignature != 'OTTO'",
      "action": "set_value",
      "target": "otfSignature",
      "value": "4F54544F",
      "description": "Restore the 'OTTO' (0x4F54544F) signature at offset 0 to identify the file as an OpenType CFF font"
    },
    {
      "name": "FixSearchRange",
      "trigger": "searchRange invalid for numberOfTables",
      "action": "set_value",
      "target": "searchRange",
      "value": "computed",
      "description": "Recompute searchRange as (maxPow2 <= numberOfTables) * 16 to restore correct binary search optimization"
    }
  ],
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "otfSignature",
        "mutation": "corrupt_signature",
        "weight": 3,
        "description": "Corrupt the 'OTTO' signature to test font engine handling of unrecognized OpenType font flavors"
      },
      {
        "field": "numberOfTables",
        "mutation": "boundary_values",
        "weight": 2,
        "description": "Test table counts of 0, 1, and 100 to probe table directory parsing and allocation limits"
      },
      {
        "field": "table1Offset",
        "mutation": "overflow",
        "weight": 2,
        "description": "Overflow the CFF table offset to trigger out-of-bounds reads in CFF charstring parsers"
      },
      {
        "field": "table1Tag",
        "mutation": "random_bytes",
        "weight": 1,
        "description": "Randomize the first table tag to test unknown table handling in OpenType layout engines"
      },
      {
        "field": "searchRange",
        "mutation": "bit_flip",
        "rate": 0.001,
        "weight": 1,
        "description": "Bit-flip the binary search optimization values to test parser tolerance for inconsistent header fields"
      }
    ]
  },
  "migration": [
    {
      "from": "opentype_cff1",
      "to": "opentype_cff2",
      "description": "Upgrade OpenType font from CFF (CFF version 1) to CFF2 outline format for variable font support",
      "changes": [
        {
          "field": "table1Tag",
          "changeType": "set_value",
          "value": "43464632",
          "description": "Replace 'CFF ' (0x43464620) table tag with 'CFF2' (0x43464632) to declare CFF version 2 outlines"
        }
      ]
    }
  ],
  "inspector": {
    "displayFields": [
      "otfSignature",
      "numberOfTables",
      "searchRange",
      "entrySelector",
      "rangeShift"
    ],
    "valueMaps": {},
    "tooltips": {
      "otfSignature": "sfnt version / scaler type identifying font format and outline type",
      "numberOfTables": "Number of tables in the font file",
      "searchRange": "Binary search optimization: (maxPow2 <= numTables) * 16"
    }
  }
}



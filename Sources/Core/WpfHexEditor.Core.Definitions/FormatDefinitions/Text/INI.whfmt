{
  "diffMode": "text",
  "formatName": "INI Configuration File",
  "version": "1.0",
  "extensions": [ ".ini", ".cfg", ".conf", ".inf" ],
  "description": "INI configuration file format. Sections delimited by [SectionName] headers, key-value pairs written as key=value or key:value, with comments introduced by semicolons (;) or hash symbols (#). No binary magic — pure text. Encoding: typically ASCII or UTF-8, sometimes UTF-16 LE (Windows with BOM FF FE). Used extensively in Windows application configuration, game settings, Windows Setup .inf files, and system configuration files. No formal specification — implementations vary in case sensitivity, multiline support, and duplicate handling.",
  "category": "Text",
  "author": "WPFHexaEditor Team",
  "LastUpdated": "2026-04-15",
  "preferredEditor": "CodeEditor",
  "references": [
    "https://en.wikipedia.org/wiki/INI_file",
    "https://docs.python.org/3/library/configparser.html"
  ],
  "detection": {
    "signatures": [
      {
        "value": "5B",
        "offset": 0,
        "label": "[ — INI section header opening bracket at offset 0",
        "weight": 0.5
      },
      {
        "value": "23",
        "offset": 0,
        "label": "# — INI comment line using hash character at offset 0",
        "weight": 0.3
      },
      {
        "value": "3B",
        "offset": 0,
        "label": "; — INI comment line using semicolon character at offset 0",
        "weight": 0.3
      },
      {
        "value": "FFFE",
        "offset": 0,
        "label": "UTF-16 LE BOM — Windows INI file in UTF-16 Little Endian encoding",
        "weight": 0.3
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.2,
    "Strength": "Weak"
  },
  "variables": {},
  "blocks": [
    {
      "name": "firstByte",
      "offset": 0,
      "size": 1,
      "type": "uint8",
      "description": "First byte of the INI file at offset 0 — typically 0x5B ('[') for a file beginning with a section header, 0x3B (';') for a comment, 0x23 ('#') for a hash comment, or 0xFF for UTF-16 BOM; printable ASCII characters indicate a key-value pair before the first section",
      "storeAs": "firstByte"
    },
    {
      "name": "secondByte",
      "offset": 1,
      "size": 1,
      "type": "uint8",
      "description": "Second byte of the INI file at offset 1 — part of the BOM sequence for UTF-16 LE files (0xFE following 0xFF), or the second character of the first section header, comment, or key name",
      "storeAs": "secondByte"
    }
  ],
  "assertions": [
    {
      "name": "FirstByteTextLike",
      "expression": "firstByte < 128 || firstByte == 0xFF || firstByte == 0xFE || firstByte == 0xEF",
      "severity": "warning",
      "message": "First byte suggests non-text content; INI files should begin with ASCII text or a recognized Unicode BOM"
    },
    {
      "name": "NotBinaryContent",
      "expression": "firstByte != 0x00",
      "severity": "warning",
      "message": "First byte is null (0x00); INI files should not contain null bytes at the start; this may be a binary file with an .ini extension"
    }
  ],
  "navigation": {
    "anchors": [
      { "name": "File Start", "offset": 0, "size": 512, "description": "Opening comments, first section header, and initial key-value pairs" }
    ]
  },
  "inspector": {
    "badge": "INI",
    "primaryField": "firstByte",
    "showQualityScore": true,
    "groups": [
      {
        "name": "File Start",
        "fields": [ "firstByte", "secondByte" ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "File Summary",
      "format": "text",
      "template": "INI Configuration File\nFirst Byte: 0x{firstByte:X2}\nFormat: Section/key-value plain text configuration\nEncoding: ASCII, UTF-8, or UTF-16 LE"
    },
    {
      "name": "Header CSV",
      "format": "csv",
      "template": "Field,Value\nFirstByte,{firstByte}\nSecondByte,{secondByte}"
    }
  ],
  "forensic": {
    "riskLevel": "low",
    "notes": "INI configuration text file. No executable content. May expose application paths, credentials, API keys, or other sensitive configuration data depending on the application."
  },
  "aiHints": {
    "analysisContext": "INI files have no binary magic. Detection is extension-based with text content validation. Look for '[SectionName]' patterns, 'key=value' or 'key:value' pairs, and ';' or '#' comment lines. Windows .inf files use the same format with specific section names like [Version] and [Strings]. UTF-16 LE encoding (BOM FF FE) is common in Windows system INI files.",
    "suggestedInspections": [
      "Check for UTF-16 LE BOM (0xFF 0xFE) at offset 0 indicating Windows system INI",
      "Scan for first '[' character to locate the opening section header",
      "List all section names by finding lines matching the [SectionName] pattern",
      "Look for 'password', 'key', 'secret', or 'token' key names for sensitive data",
      "Check for Windows .inf specific sections: [Version], [Strings], [DefaultInstall]",
      "Validate that key=value pairs use consistent delimiter (= vs :)"
    ]
  },
  "software": [
    { "name": "Notepad", "url": "https://apps.microsoft.com/store/detail/windows-notepad/", "role": "text editor" },
    { "name": "Notepad++", "url": "https://notepad-plus-plus.org/", "role": "text editor" }
  ],
  "formatRelationships": [
    { "format": "PROPERTIES", "relation": "sibling — Java .properties files use similar key=value syntax without section headers" },
    { "format": "CSV", "relation": "sibling text format — CSV uses columnar structure, INI uses hierarchical sections" }
  ],
  "MimeTypes": [ "text/plain", "application/x-ini" ],
  "UseCases": [
    "Windows application configuration storage",
    "Game settings and preferences files",
    "Windows Setup driver and install information (.inf) files"
  ],
  "QualityMetrics": {
    "CompletenessScore": 72,
    "DocumentationLevel": "detailed",
    "LastUpdated": "2026-04-15"
  },
  "TechnicalDetails": {
    "encoding": "ASCII, UTF-8, or UTF-16 LE",
    "endianness": "N/A (text format)",
    "notes": "No formal specification. Section names are case-insensitive in most implementations. Duplicate keys within a section are handled differently by different parsers — last-write-wins is most common. Windows .inf files are a superset with install directives."
  }
}

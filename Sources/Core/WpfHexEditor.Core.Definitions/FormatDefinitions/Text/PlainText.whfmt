{
  "diffMode": "text",
  "formatName": "Plain Text",
  "version": "1.53",
  "extensions": [".txt", ".text", ".log", ".md", ".csv", ".tsv", ".ini", ".cfg", ".conf"],
  "description": "Plain text files contain human-readable character data with no binary structure. Detection relies on BOM (Byte Order Mark) presence and file extension. UTF-8 BOM: EF BB BF (3 bytes). UTF-16 LE BOM: FF FE. UTF-16 BE BOM: FE FF. UTF-32 LE BOM: FF FE 00 00. UTF-32 BE BOM: 00 00 FE FF. Without a BOM, encoding is inferred from byte patterns: pure ASCII (bytes 0x20-0x7E plus line endings), valid UTF-8 sequences, or extended encodings. Line endings: LF (0x0A, Unix), CRLF (0x0D 0x0A, Windows), CR (0x0D, legacy Mac). Plain text has no defined binary format — it is a catch-all for human-readable files.",
  "category": "Documents",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": ["RFC 3629 — UTF-8 encoding", "Unicode Standard — BOM usage"],
    "WebLinks": ["https://www.unicode.org/faq/utf_bom.html", "https://www.rfc-editor.org/rfc/rfc3629"]
  },
  "detection": {
    "signatures": [
      { "value": "EFBBBF", "offset": 0, "label": "UTF-8 BOM (EF BB BF)", "weight": 0.9 },
      { "value": "FFFE", "offset": 0, "label": "UTF-16 LE BOM (FF FE)", "weight": 0.8 },
      { "value": "FEFF", "offset": 0, "label": "UTF-16 BE BOM (FE FF)", "weight": 0.8 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.3,
    "required": false,
    "Strength": "Weak",
    "EntropyHint": { "min": 3.5, "max": 6.0 },
    "validation": {
      "minFileSize": 0,
      "maxSignatureOffset": 0,
      "note": "Plain text has no required magic bytes. BOM is optional. Detection by file extension and low-entropy byte content."
    }
  },
  "variables": { "bomByte0": 0, "bomByte1": 0, "bomByte2": 0 },
  "blocks": [
    {
      "type": "field", "name": "BOM Byte 0", "offset": 0, "length": 1,
      "color": "#4ECDC4", "opacity": 0.35,
      "description": "First byte — may be a BOM (Byte Order Mark) indicating text encoding. 0xEF = start of UTF-8 BOM (EF BB BF). 0xFF = UTF-16 LE BOM start (FF FE). 0xFE = UTF-16 BE BOM start (FE FF). Other = no BOM, encoding inferred from content.",
      "storeAs": "bomByte0", "valueType": "uint8",
      "valueMap": { "239": "0xEF — UTF-8 BOM start", "255": "0xFF — UTF-16 LE BOM start", "254": "0xFE — UTF-16 BE BOM start" }
    },
    {
      "type": "field", "name": "BOM Byte 1", "offset": 1, "length": 1,
      "color": "#4ECDC4", "opacity": 0.25,
      "description": "Second byte — continues BOM identification. 0xBB after 0xEF = UTF-8 BOM continuing. 0xFE after 0xFF = UTF-16 LE BOM. 0xFF after 0xFE = UTF-16 BE BOM.",
      "storeAs": "bomByte1", "valueType": "uint8"
    },
    {
      "type": "field", "name": "BOM Byte 2", "offset": 2, "length": 1,
      "color": "#4ECDC4", "opacity": 0.2,
      "description": "Third byte — completes UTF-8 BOM. 0xBF after 0xEF 0xBB = UTF-8 BOM confirmed (EF BB BF = 3 bytes). If first 3 bytes are not a recognized BOM, the file starts directly with text content.",
      "storeAs": "bomByte2", "valueType": "uint8"
    },
    { "type": "metadata", "name": "BOM Start", "variable": "bomByte0", "description": "First byte — BOM marker or text data start" }
  ],
  "assertions": [
    { "name": "UTF-8 BOM integrity", "expression": "bomByte0 != 239 || (bomByte1 == 187 && bomByte2 == 191)", "severity": "warning", "message": "Incomplete UTF-8 BOM (EF without following BB BF)" }
  ],
  "navigation": { "bookmarks": [{ "name": "File Start / BOM", "offset": 0, "icon": "\uE8A5", "color": "#4ECDC4" }] },
  "inspector": {
    "badge": "bomByte0", "primaryField": "bomByte0", "showQualityScore": true,
    "groups": [{ "title": "Text Encoding (BOM)", "icon": "\uE8A5", "fields": ["bomByte0", "bomByte1", "bomByte2"] }]
  },
  "exportTemplates": [{ "name": "BOM Info (JSON)", "format": "json", "fields": ["bomByte0", "bomByte1", "bomByte2"] }],
  "forensic": { "category": "document", "riskLevel": "low", "suspiciousPatterns": [] },
  "aiHints": {
    "analysisContext": "Plain text: no magic. BOM: UTF-8=EF BB BF, UTF-16 LE=FF FE, UTF-16 BE=FE FF. Low entropy (3.5-6.0). Line endings: 0x0A=LF(Unix), 0x0D 0x0A=CRLF(Windows), 0x0D=CR(Mac). Detection by extension: .txt .log .md .csv .ini .conf.",
    "suggestedInspections": [
      "Bytes 0-2: BOM check (EF BB BF=UTF-8, FF FE=UTF-16 LE, FE FF=UTF-16 BE)",
      "Scan for line endings: 0x0A=LF, 0x0D 0x0A=CRLF",
      "Byte range 0x20-0x7E = printable ASCII — check ratio for encoding confidence",
      "Low entropy (< 6 bits/byte) confirms readable text"
    ]
  },
  "software": ["Any text editor (Notepad, VS Code, Sublime Text)", "Hex editor for encoding analysis"],
  "formatRelationships": { "category": "Documents", "extensions": [".txt", ".text", ".log", ".md", ".csv", ".ini"], "relatedFormats": [], "note": "Universal catch-all for human-readable files. No binary structure. Encoding: ASCII, UTF-8 (most common), UTF-16, Latin-1." },
  "MimeTypes": ["text/plain"],
  "UseCases": ["Log file analysis", "Configuration file inspection", "CSV/TSV data files", "Markdown and documentation files"],
  "QualityMetrics": { "CompletenessScore": 55, "DocumentationLevel": "detailed", "BlocksDefined": 4, "ValidationRules": 1, "LastUpdated": "2026-04-14", "PriorityFormat": false, "AutoRefined": false },
  "TechnicalDetails": { "Format": "Plain text (no binary structure)", "BOM": "Optional: UTF-8=EF BB BF, UTF-16 LE=FF FE, UTF-16 BE=FE FF", "LineEndings": "LF (Unix), CRLF (Windows), CR (legacy Mac)" }
}

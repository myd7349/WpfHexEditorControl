    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "ImagesFormat": true,
    "BitDepth": 12,
    "ByteOrder": "little-endian",
    "Container": "TIFF-derived (non-standard magic)",
    "MakerNotePrefix": "Panasonic\\x00\\x00\\x00",
    "SensorType": "Bayer (RGGB)",
    "Compression": "uncompressed or lossless"
  }
}

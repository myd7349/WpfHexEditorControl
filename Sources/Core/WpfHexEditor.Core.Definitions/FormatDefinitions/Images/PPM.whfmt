  },
  "functions": {
    "extractASCIIString": "Extract width, height, maxval from ASCII header"
  },
  "variables": {
    "magicNumber": "",
    "ppmMagic": 0,
    "header": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "PPM Magic",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "P3 or P6 magic number",
      "storeAs": "ppmMagic",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Header",
      "offset": 2,
      "length": 32,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "ASCII header (width, height, maxval)",
      "storeAs": "header",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Magic Number",
      "variable": "magicNumber",
      "description": "P3 (ASCII) or P6 (binary)"
    }
  ],

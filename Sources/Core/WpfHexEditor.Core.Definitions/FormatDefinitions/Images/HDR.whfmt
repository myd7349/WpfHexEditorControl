{
  "diffMode": "text",
  "formatName": "Radiance HDR (RGBE)",
  "version": "1.0",
  "extensions": [".hdr", ".rgbe", ".pic"],
  "description": "Radiance RGBE HDR image format designed by Greg Ward in 1989 for the Radiance lighting simulation system. The file begins with a text header. The primary magic string is '#?RADIANCE' followed by a newline (0x0A); the variant '#?RGBE' is also accepted. The header contains FORMAT=32-bit_rle_rgbe, optional EXPOSURE, COLORCORR, SOFTWARE, PIXASPECT fields, and ends with a blank line. A resolution string follows (e.g., '-Y 512 +X 1024'). Binary pixel data: each pixel is 4 bytes in RGBE format — three mantissa bytes (R, G, B) plus a shared binary exponent byte (E). Run-length encoding is applied per scanline using sentinel bytes 0x02 0x02 followed by the scanline width in 2 bytes. Used for image-based lighting (IBL), PBR rendering environment maps, and HDR photography workflows.",
  "category": "Images",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "image-viewer",
  "references": {
    "specifications": [
      "Radiance HDR File Format — Greg Ward, Lawrence Berkeley Lab",
      "RGBE Encoding — IEEE Computer Graphics and Applications 1991",
      "Physically Based Rendering (Pharr, Jakob, Humphreys) — HDR chapter"
    ],
    "WebLinks": [
      "https://radsite.lbl.gov/radiance/refer/filefmts.pdf",
      "https://en.wikipedia.org/wiki/RGBE_image_format",
      "https://www.graphics.cornell.edu/~bjw/rgbe.html",
      "https://filesamples.com/formats/hdr"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "233F52414449414E43450A", "offset": 0, "label": "#?RADIANCE\\n — primary Radiance HDR text header magic", "weight": 1.0 },
      { "value": "233F524742450A", "offset": 0, "label": "#?RGBE\\n — Radiance RGBE header variant magic", "weight": 0.9 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.8,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 2.5, "max": 7.5 },
    "validation": {
      "minFileSize": 20,
      "maxSignatureOffset": 0,
      "note": "File must start with '#?RADIANCE' or '#?RGBE' text strings followed immediately by a newline 0x0A."
    }
  },
  "variables": {
    "firstByte": 0,
    "hdrMagic": "",
    "formatLine": "",
    "exposureValue": 0.0
  },
  "blocks": [
    {
      "type": "field",
      "name": "First Byte",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "First byte of the HDR text header; must be 0x23 (ASCII '#') for both '#?RADIANCE' and '#?RGBE' header variants. Used as a fast pre-filter before performing full magic string comparison against both recognized header strings.",
      "storeAs": "firstByte",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "HDR Magic String",
      "offset": 0,
      "length": 11,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Text magic string at the start of every Radiance HDR file. Primary value is '#?RADIANCE' (10 bytes + newline); alternative '#?RGBE' (6 bytes + newline) is used by older or simplified writers. The '?' character distinguishes Radiance files from other '#'-prefixed text image formats.",
      "storeAs": "hdrMagic",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Header Fields Block",
      "offset": 11,
      "description": "Variable-length text header fields following the magic line. FORMAT=32-bit_rle_rgbe declares the pixel encoding method. EXPOSURE=float applies a global luminance scaling factor. COLORCORR=r g b applies per-channel color correction. PIXASPECT=float gives pixel aspect ratio. SOFTWARE=string identifies the creating application. The header terminates with a blank line (two consecutive newline characters)."
    },
    {
      "type": "metadata",
      "name": "Resolution String",
      "offset": 0,
      "description": "Resolution specification string immediately following the blank line that ends the text header. Standard format is '-Y height +X width' for top-down left-to-right orientation. Alternative orientations are possible. Both dimensions are decimal ASCII integers separated by spaces. The resolution string itself ends with a newline before binary pixel data begins."
    }
  ],
  "assertions": [
    {
      "name": "ValidFirstByte",
      "expression": "firstByte == 35",
      "severity": "error",
      "message": "First byte must be 0x23 ASCII '#'. This file does not begin with a recognized Radiance HDR header magic string."
    },
    {
      "name": "ValidMagicPrefix",
      "expression": "hdrMagic.startsWith('#?')",
      "severity": "error",
      "message": "HDR magic must begin with '#?' followed by 'RADIANCE' or 'RGBE'. The header format is not recognized as a valid Radiance HDR file."
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "Magic Header", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "Header Fields", "offset": 11, "icon": "\uE8B7", "color": "#FFE66D" }
    ]
  },
  "inspector": {
    "badge": "hdrMagic",
    "primaryField": "hdrMagic",
    "showQualityScore": true,
    "groups": [
      {
        "title": "File Identification",
        "icon": "\uE71B",
        "fields": ["firstByte", "hdrMagic"]
      },
      {
        "title": "Header Metadata",
        "icon": "\uE8B7",
        "fields": ["formatLine", "exposureValue"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "HDR Header (JSON)",
      "format": "json",
      "fields": ["hdrMagic", "formatLine", "exposureValue"]
    },
    {
      "name": "HDR Summary (CSV)",
      "format": "csv",
      "fields": ["hdrMagic", "exposureValue"]
    }
  ],
  "forensic": {
    "category": "images",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Malformed EXPOSURE float value could trigger parsing issues in vulnerable readers",
      "Extremely large resolution dimensions may cause memory exhaustion in naive parsers"
    ]
  },
  "aiHints": {
    "analysisContext": "Radiance RGBE HDR format with text header and binary pixel body. File starts with '#?RADIANCE' or '#?RGBE' followed by key=value lines and a blank line separator. Pixel data is 4 bytes per pixel: R, G, B mantissa bytes plus shared exponent E.",
    "suggestedInspections": [
      "Verify text magic '#?RADIANCE' or '#?RGBE' at offset 0 with trailing 0x0A newline for format confirmation",
      "Scan header text for FORMAT= line to confirm 32-bit_rle_rgbe encoding and extract optional EXPOSURE factor",
      "Locate the blank line (double newline 0x0A 0x0A) marking the header end and beginning of the resolution string",
      "Parse resolution string dimensions for memory allocation sanity check against file size",
      "Check scanline RLE sentinel bytes 0x02 0x02 to verify pixel data integrity and detect potential corruption"
    ]
  },
  "software": [
    "Radiance (LBNL)",
    "HDRShop",
    "Photomatix Pro",
    "Blender (Cycles environment maps)",
    "OpenImageIO",
    "darktable",
    "GIMP (with HDR plugin)"
  ],
  "formatRelationships": {
    "category": "Images",
    "extensions": [".hdr", ".rgbe", ".pic"],
    "relatedFormats": ["EXR", "TIFF", "JXL"],
    "note": "Legacy HDR format; EXR is the modern VFX successor with multi-channel, tiled, and deep data support"
  },
  "MimeTypes": ["image/vnd.radiance", "image/x-hdr"],
  "UseCases": [
    "Image-based lighting (IBL) environment maps for PBR rendering",
    "HDR photography tone-mapping source files",
    "Lighting simulation with Radiance ray tracer",
    "Real-time graphics engine environment cube maps"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 4,
    "ValidationRules": 2,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "encoding": "text-header-plus-binary-pixel-data",
    "pixelEncoding": "RGBE (4 bytes: R mantissa, G mantissa, B mantissa, shared binary exponent)",
    "compressionMethod": "Per-scanline RLE with 0x02 0x02 width sentinel",
    "magicVariants": ["#?RADIANCE", "#?RGBE"]
  }
}

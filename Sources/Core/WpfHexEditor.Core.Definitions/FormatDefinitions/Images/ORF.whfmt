{
  "diffMode": "binary",
  "formatName": "Olympus RAW Format",
  "version": "1.14",
  "extensions": [
    ".orf"
  ],
  "description": "ORF (Olympus RAW Format) is Olympus's proprietary RAW camera image format used in Olympus and OM System DSLR/mirrorless cameras. ORF uses two TIFF byte order variants: 0x4F52 ('OR') for some Olympus cameras, and the standard TIFF 0x4949 ('II') little-endian with ORF-specific magic values 0x4952 or 0x4F52 or 0x524F instead of standard TIFF magic 42. The Olympus magic word distinguishes ORF from standard TIFF and other RAW formats. IFD0 contains standard EXIF tags plus Olympus MakerNote (tag 0x927C) starting with 'OLYMP\\x00' or 'OLYMPUS\\x00II'.",
  "category": "Images",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "image-viewer",
  "references": {
    "specifications": [
      "Olympus RAW Format (ORF) — Modified TIFF",
      "TIFF 6.0 Specification — Adobe Systems"
    ],
    "WebLinks": [
      "https://libopenraw.freedesktop.org/formats/orf/",
      "https://exiftool.org/TagNames/Olympus.html",
      "https://docs.fileformat.com/image/orf/"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "49495249", "offset": 0, "label": "'IIRI' — Olympus ORF LE with magic 0x4952", "weight": 1.0 },
      { "value": "49494F52", "offset": 0, "label": "'IIOR' — Olympus ORF variant magic 0x4F52", "weight": 1.0 },
      { "value": "4F524F52", "offset": 0, "label": "'OROR' — older Olympus ORF magic", "weight": 0.9 },
      { "value": "49492A00", "offset": 0, "label": "TIFF LE — some Olympus ORF use standard magic", "weight": 0.5 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.5,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 4.5, "max": 7.5 },
    "validation": {
      "minFileSize": 8,
      "maxSignatureOffset": 0,
      "note": "ORF has unique magic values 0x4952 or 0x4F52 instead of standard TIFF magic 42. Combined with .orf extension this is strong identification."
    }
  },
  "variables": {
    "byteOrderMark": 0,
    "orfMagic": 0,
    "ifdOffset": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Byte Order Mark",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "TIFF/ORF byte order mark. Olympus ORF uses: 0x4949 ('II') = little-endian (standard TIFF, modern Olympus), 0x4F52 ('OR') = Olympus-specific variant (older cameras). Determines integer interpretation throughout the file.",
      "storeAs": "byteOrderMark",
      "valueType": "uint16",
      "endianness": "little",
      "valueMap": {
        "18761": "Little-endian 'II' — modern Olympus ORF",
        "20306": "'OR' byte order — older Olympus camera variant"
      }
    },
    {
      "type": "field",
      "name": "ORF Magic",
      "offset": 2,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Olympus RAW magic number. Unlike standard TIFF (magic=42), Olympus ORF uses proprietary magic values: 0x5249='RI', 0x524F='RO', or 0x4F52='OR'. Standard TIFF magic 42 is also used in some Olympus models.",
      "storeAs": "orfMagic",
      "valueType": "uint16",
      "endianness": "little",
      "valueMap": {
        "42": "Standard TIFF magic — some Olympus models",
        "18769": "ORF magic 0x4952 'RI'",
        "20562": "ORF magic 0x4F52 'OR'",
        "21071": "ORF magic 0x524F 'RO'"
      }
    },
    {
      "type": "field",
      "name": "IFD0 Offset",
      "offset": 4,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "Byte offset to first Image File Directory (IFD0). Contains image width/height, EXIF pointer (tag 0x8769), and Olympus MakerNote (tag 0x927C).",
      "storeAs": "ifdOffset",
      "valueType": "uint32",
      "endianness": "little"
    },
    {
      "type": "metadata",
      "name": "Byte Order",
      "variable": "byteOrderMark",
      "description": "ORF byte order: 18761='II' LE, 20306='OR' Olympus"
    },
    {
      "type": "metadata",
      "name": "ORF Magic",
      "variable": "orfMagic",
      "description": "Olympus RAW magic: 42=TIFF std, 18769/20562/21071=ORF proprietary"
    }
  ],
  "assertions": [
    {
      "name": "Byte order valid",
      "expression": "byteOrderMark == 18761 || byteOrderMark == 20306",
      "severity": "error",
      "message": "ORF byte order must be 0x4949 ('II') or 0x4F52 ('OR')"
    },
    {
      "name": "ORF or TIFF magic valid",
      "expression": "orfMagic == 42 || orfMagic == 18769 || orfMagic == 20562 || orfMagic == 21071",
      "severity": "warning",
      "message": "ORF magic should be 42, 0x4952, 0x4F52, or 0x524F"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "ORF Header", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" }
    ]
  },
  "inspector": {
    "badge": "orfMagic",
    "primaryField": "byteOrderMark",
    "showQualityScore": true,
    "groups": [
      {
        "title": "ORF Header",
        "icon": "\uE71B",
        "fields": ["byteOrderMark", "orfMagic", "ifdOffset"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "ORF Header (JSON)",
      "format": "json",
      "fields": ["byteOrderMark", "orfMagic", "ifdOffset"]
    }
  ],
  "forensic": {
    "category": "image",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Olympus ORF: bytes 0-1=byteOrder(4949=II, 4F52=OR), bytes 2-3=magic(4952/4F52/524F or 2A00). IFD0 at offset 8. Key tags: 0x0100=Width, 0x0101=Height, 0x8769=ExifIFD, 0x927C=MakerNote. Olympus MakerNote starts with 'OLYMP\\x00' + self-contained TIFF IFD. RAW data in SubIFD (tag 0x014A).",
    "suggestedInspections": [
      "Check bytes 0-3: 4949+5249/4F52/524F = ORF specific magic combination",
      "Olympus MakerNote (tag 0x927C) starts with 'OLYMP\\x00' — confirms ORF",
      "SubIFD (tag 0x014A) offset points to 12-bit Bayer RAW sensor data"
    ]
  },
  "software": [
    "Olympus Workspace",
    "Adobe Lightroom / Camera Raw",
    "Capture One",
    "darktable",
    "RawTherapee"
  ],
  "formatRelationships": {
    "category": "Images",
    "extensions": [".orf"],
    "relatedFormats": ["TIFF", "DNG"],
    "note": "ORF is used by Olympus (now OM System) cameras. Non-standard magic values distinguish ORF from other TIFF-based RAW formats. Can be converted to DNG with Adobe DNG Converter."
  },
  "MimeTypes": [
    "image/x-olympus-orf",
    "image/orf"
  ],
  "UseCases": [
    "Olympus/OM System DSLR and mirrorless RAW capture",
    "Micro Four Thirds camera RAW workflow",
    "Photo editing with full RAW flexibility"
  ],
  "QualityMetrics": {

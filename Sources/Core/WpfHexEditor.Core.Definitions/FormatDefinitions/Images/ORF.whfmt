    "DocumentationLevel": "detailed",
    "BlocksDefined": 5,
    "ValidationRules": 2,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "ImageFormat": true,
    "ContainerFormat": "Modified TIFF with Olympus proprietary magic values",
    "Endianness": "little-endian or big-endian depending on camera",
    "RawEncoding": "12-bit Bayer sensor data, lossless or uncompressed",
    "OlympusMagicValues": "0x4952, 0x4F52, 0x524F (distinguishes from standard TIFF)"
  }
}

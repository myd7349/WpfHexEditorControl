  "aiHints": {
    "analysisContext": "OpenEXR High Dynamic Range image format",
    "suggestedInspections": [
      "Validate OpenEXR Image signature, image dimensions, and color model",
      "Check pixel data offset, compression type, and scanline alignment",
      "Inspect color profile (ICC), EXIF metadata, and chunk CRCs"
    ]
  },
  "functions": {
    "readUInt32LE": "Read dimensions",
    "multiply": "Calculate pixels",
    "computeFromVariables(width * height, totalPixels)": "Calculate total pixels"
  },
  "inspector": {
    "badge": "exrMagic",
    "primaryField": "version",
    "showQualityScore": true,
    "groups": [

  "extensions": [
    ".exr"
  ],
  "description": "OpenEXR High Dynamic Range image format",
  "category": "Images",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "image-viewer",
  "references": {
    "specifications": [
      "OpenEXR Format Specification - ILM",

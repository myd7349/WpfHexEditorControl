{
  "diffMode": "binary",
  "formatName": "PNG Image",
  "version": "2.02",
  "extensions": [
    ".png"
  ],
  "description": "Portable Network Graphics (PNG) is a lossless raster image format that uses DEFLATE compression. The file begins with an 8-byte signature followed by a series of typed chunks. The first chunk must be IHDR, which contains the image dimensions, bit depth, color type, and rendering methods.",
  "category": "Images",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "image-viewer",
  "references": {
    "specifications": [
      "RFC 2083 - PNG (Portable Network Graphics) Specification Version 1.0",
      "ISO/IEC 15948:2004 - Portable Network Graphics (PNG) Functional Specification",
      "W3C PNG Specification (Third Edition)"
    ],
    "WebLinks": [
      "https://www.w3.org/TR/PNG/",
      "https://www.ietf.org/rfc/rfc2083.txt",
      "https://en.wikipedia.org/wiki/Portable_Network_Graphics"
    ]
  },
  "detection": {
    "signature": "89504E470D0A1A0A",
    "offset": 0,
    "required": true,
    "validation": {
      "minFileSize": 33,
      "maxSignatureOffset": 0
    }
  },
  "variables": {
    "currentOffset": 0,
    "pngSignature": "",
    "ihdrChunkLength": 0,
    "ihdrChunkType": "",
    "imageWidth": 0,
    "imageHeight": 0,
    "bitDepth": 0,
    "colorType": 0,
    "compressionMethod": 0,
    "filterMethod": 0,
    "interlaceMethod": 0,
    "ihdrCrc": 0,
    "calculatedCRC32": 0,
    "crc32Valid": false,
    "totalPixels": 0,
    "colorTypeName": "",
    "bitsPerPixel": 0,
    "hasAlphaChannel": false,
    "isIndexedColor": false,
    "samplesPerPixel": 0,
    "formattedSize": ""
  },
  "functions": {
    "readPNGDimensions": "Read image width and height from IHDR chunk (big-endian uint32 at offsets 16 and 20)",
    "validatePNGIHDR": "Validate IHDR chunk CRC-32 integrity by computing CRC over chunk type + data bytes (offsets 12-28) and comparing against stored CRC at offset 29",
    "interpretColorType(var:colorType, png)": "Map color type integer to human-readable name and determine samples per pixel",
    "computeFromVariables(imageWidth * imageHeight, totalPixels)": "Calculate total pixel count from width and height",
    "formatFileSize(var:totalPixels)": "Format total pixel count as human-readable string"
  },
  "blocks": [
    {
      "type": "signature",
      "name": "PNG File Signature",
      "offset": 0,
      "length": 8,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "8-byte PNG magic signature: 0x89 'P' 'N' 'G' 0x0D 0x0A 0x1A 0x0A. The high bit (0x89) detects transmission systems that strip bit 7, the CR-LF sequence detects line-ending conversion, and 0x1A stops display under DOS.",
      "storeAs": "pngSignature",
      "valueType": "hex",
      "validation": {
        "expectedValue": "0x89504E470D0A1A0A"
      }
    },
    {
      "type": "field",
      "name": "IHDR Chunk Data Length",
      "offset": 8,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Length of the IHDR chunk data section in bytes. This value is always 13 (0x0000000D) for a valid PNG, as IHDR contains exactly 13 bytes of image header data.",
      "storeAs": "ihdrChunkLength",
      "valueType": "uint32",
      "endianness": "big",
      "validation": {
        "expectedValue": "0x0000000D"
      }
    },
    {
      "type": "field",
      "name": "IHDR Chunk Type Code",
      "offset": 12,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Four-byte ASCII chunk type code 'IHDR' (0x49484452). This is a critical chunk that must appear first. Bit 5 of each byte encodes: ancillary/critical, public/private, reserved, safe-to-copy flags.",
      "storeAs": "ihdrChunkType",
      "valueType": "ascii",
      "validation": {
        "expectedValue": "IHDR"
      }
    },
    {
      "type": "field",
      "name": "Image Width",
      "offset": 16,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Image width in pixels, stored as a big-endian unsigned 32-bit integer. Valid range is 1 to 2^31 - 1. A value of 0 is invalid per the PNG specification.",
      "storeAs": "imageWidth",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Image Height",
      "offset": 20,
      "length": 4,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "Image height in pixels, stored as a big-endian unsigned 32-bit integer. Valid range is 1 to 2^31 - 1. A value of 0 is invalid per the PNG specification.",
      "storeAs": "imageHeight",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Bit Depth",
      "offset": 24,
      "length": 1,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Number of bits per sample or per palette index. Valid values depend on color type: Grayscale allows 1,2,4,8,16; RGB allows 8,16; Indexed allows 1,2,4,8; Gray+Alpha allows 8,16; RGBA allows 8,16.",
      "storeAs": "bitDepth",
      "valueType": "uint8",
      "valueMap": {
        "1": "1-bit (2 levels)",
        "2": "2-bit (4 levels)",
        "4": "4-bit (16 levels)",
        "8": "8-bit (256 levels)",
        "16": "16-bit (65536 levels)"
      }
    },
    {
      "type": "field",
      "name": "Color Type",
      "offset": 25,
      "length": 1,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Defines the PNG image type. The value is a bitmask: bit 0 = palette used, bit 1 = color used, bit 2 = alpha channel used. Only specific combinations are valid per the specification.",
      "storeAs": "colorType",
      "valueType": "uint8",
      "valueMap": {
        "0": "Grayscale",
        "2": "Truecolor (RGB)",
        "3": "Indexed-color (Palette)",
        "4": "Grayscale with Alpha",
        "6": "Truecolor with Alpha (RGBA)"
      },
      "bitfields": [
        {
          "bit": 0,
          "name": "Palette Used",
          "description": "If set, a PLTE chunk is required and pixel values are palette indices",
          "valueMap": {
            "0": "No palette",
            "1": "Palette-based"
          }
        },
        {
          "bit": 1,
          "name": "Color Used",
          "description": "If set, the image uses color (RGB triples); if clear, the image is grayscale",
          "valueMap": {
            "0": "Grayscale",
            "1": "Color (RGB)"
          }
        },
        {
          "bit": 2,
          "name": "Alpha Channel",
          "description": "If set, an alpha channel is included providing per-pixel transparency",
          "valueMap": {
            "0": "No alpha channel",
            "1": "Alpha channel present"
          }
        }
      ]
    },
    {
      "type": "field",
      "name": "Compression Method",
      "offset": 26,
      "length": 1,
      "color": "#FF6B9D",
      "opacity": 0.3,
      "description": "Compression method used for image data. Currently only method 0 (deflate/inflate with a sliding window of at most 32768 bytes) is defined in the PNG specification.",
      "storeAs": "compressionMethod",
      "valueType": "uint8",
      "valueMap": {
        "0": "Deflate/Inflate (zlib)"
      }
    },
    {
      "type": "field",
      "name": "Filter Method",
      "offset": 27,
      "length": 1,
      "color": "#C44569",
      "opacity": 0.3,
      "description": "Preprocessing method applied to image data before compression. Method 0 defines five adaptive filter types (None, Sub, Up, Average, Paeth) selected per scanline to improve compression.",
      "storeAs": "filterMethod",
      "valueType": "uint8",
      "valueMap": {
        "0": "Adaptive filtering (5 basic filter types)"
      }
    },
    {
      "type": "field",
      "name": "Interlace Method",
      "offset": 28,
      "length": 1,
      "color": "#98D8C8",
      "opacity": 0.3,
      "description": "Transmission order of the image data. Method 0 sends scanlines sequentially from top to bottom. Method 1 (Adam7) transmits in seven passes for progressive display, showing a low-resolution preview early.",
      "storeAs": "interlaceMethod",
      "valueType": "uint8",
      "valueMap": {
        "0": "No interlace (sequential scanlines)",
        "1": "Adam7 interlace (7-pass progressive)"
      }
    },
    {
      "type": "field",
      "name": "IHDR Chunk CRC-32",
      "offset": 29,
      "length": 4,
      "color": "#A8E6CF",
      "opacity": 0.3,
      "description": "CRC-32 checksum computed over the chunk type code and chunk data (bytes 12-28, 17 bytes total). Uses the CRC polynomial defined in ISO 3309 and ITU-T V.42. Used to verify chunk integrity.",
      "storeAs": "ihdrCrc",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "computeFromVariables",
      "name": "Total Pixel Count",
      "expression": "imageWidth * imageHeight",
      "storeAs": "totalPixels",
      "description": "Calculates the total number of pixels in the image by multiplying width by height. Used to estimate memory requirements and uncompressed data size."
    },
    {
      "type": "computeFromVariables",
      "name": "Bits Per Pixel",
      "expression": "colorType == 0 ? bitDepth : (colorType == 2 ? bitDepth * 3 : (colorType == 3 ? bitDepth : (colorType == 4 ? bitDepth * 2 : bitDepth * 4)))",
      "storeAs": "bitsPerPixel",
      "description": "Calculates effective bits per pixel based on color type and bit depth. Grayscale=bitDepth, RGB=bitDepth*3, Indexed=bitDepth, GrayAlpha=bitDepth*2, RGBA=bitDepth*4."
    },
    {
      "type": "conditional",
      "name": "Alpha Channel Detection",
      "condition": "colorType == 4 || colorType == 6",
      "trueLabel": "This PNG image contains an alpha channel for transparency",
      "falseLabel": "This PNG image does not have an alpha channel (transparency may be provided by tRNS chunk)",
      "description": "Checks if the color type includes an alpha channel (color types 4 and 6 have per-pixel alpha)"
    },
    {
      "type": "conditional",
      "name": "Interlace Detection",
      "condition": "interlaceMethod == 1",
      "trueLabel": "This PNG uses Adam7 interlacing for progressive rendering",
      "falseLabel": "This PNG uses standard sequential scanline ordering",
      "description": "Checks whether the image uses Adam7 interlacing, which allows progressive display during download"
    },
    {
      "type": "metadata",
      "name": "Image Width (pixels)",
      "variable": "imageWidth",
      "description": "Image width in pixels from the IHDR chunk (big-endian uint32 at offset 16)"
    },
    {
      "type": "metadata",
      "name": "Image Height (pixels)",
      "variable": "imageHeight",
      "description": "Image height in pixels from the IHDR chunk (big-endian uint32 at offset 20)"
    },
    {
      "type": "metadata",
      "name": "Total Pixels",
      "variable": "totalPixels",
      "description": "Total pixel count computed as imageWidth * imageHeight"
    },
    {
      "type": "metadata",
      "name": "Color Type Name",
      "variable": "colorTypeName",
      "description": "Human-readable color type name interpreted from the color type byte"
    },
    {
      "type": "metadata",
      "name": "Bits Per Pixel",
      "variable": "bitsPerPixel",
      "description": "Effective bits per pixel computed from color type and bit depth"
    },
    {
      "type": "metadata",
      "name": "IHDR CRC Validation",
      "variable": "crc32Valid",
      "description": "Result of CRC-32 integrity check: true if computed CRC matches stored CRC at offset 29"
    }
  ],
  "checksums": [
    {
      "name": "IHDR Chunk CRC-32",
      "algorithm": "crc32",
      "dataRange": { "fixedOffset": 12, "fixedLength": 17 },
      "storedAt": { "fixedOffset": 29, "length": 4, "endianness": "big" },
      "storedType": "uint32",
      "severity": "error"
    }
  ],
  "assertions": [
    {
      "name": "PNG signature valid",
      "expression": "pngSignature == '\\x89PNG\\r\\n\\x1A\\n'",
      "severity": "error",
      "message": "PNG magic signature is invalid — not a valid PNG file or transmission damage detected"
    },
    {
      "name": "IHDR chunk length is 13",
      "expression": "ihdrChunkLength == 13",
      "severity": "error",
      "message": "IHDR chunk data length must be exactly 13 bytes. Any other value indicates a malformed or crafted file."
    },
    {
      "name": "IHDR chunk type is IHDR",
      "expression": "ihdrChunkType == 'IHDR'",
      "severity": "error",
      "message": "First PNG chunk must be IHDR. A different chunk type indicates invalid chunk ordering."
    },
    {
      "name": "Image dimensions non-zero",
      "expression": "imageWidth > 0 && imageHeight > 0",
      "severity": "error",
      "message": "PNG image width and height must both be greater than 0. Zero dimensions violate the specification."
    },
    {
      "name": "Color type valid",
      "expression": "colorType == 0 || colorType == 2 || colorType == 3 || colorType == 4 || colorType == 6",
      "severity": "error",
      "message": "PNG color type must be 0 (grayscale), 2 (RGB), 3 (indexed), 4 (grayscale+alpha), or 6 (RGBA)"
    },
    {
      "name": "Compression method is 0",
      "expression": "compressionMethod == 0",
      "severity": "error",
      "message": "PNG compression method must be 0 (DEFLATE). Non-zero values are undefined."
    },
    {
      "name": "Interlace method is 0 or 1",
      "expression": "interlaceMethod == 0 || interlaceMethod == 1",
      "severity": "error",
      "message": "PNG interlace method must be 0 (no interlace) or 1 (Adam7). Any other value is invalid."
    }
  ],
    "navigation": {
    "bookmarks": [
      {
        "name": "PNG File Signature",
        "offset": 0,
        "icon": "",
        "color": "#FF6B6B"
      },
      {
        "name": "IHDR Chunk",
        "offset": 8,
        "icon": "",
        "color": "#4ECDC4"
      },
      {
        "name": "IHDR Data",
        "offset": 16,
        "icon": "",
        "color": "#FFE66D"
      }
    ]
  },
  "inspector": {
    "badge": "colorTypeName",
    "primaryField": "imageWidth",
    "showQualityScore": true,
    "groups": [
      {
        "title": "File Signature",
        "icon": "",
        "fields": ["pngSignature"]
      },
      {
        "title": "IHDR Chunk Header",
        "icon": "",
        "fields": ["ihdrChunkLength", "ihdrChunkType", "ihdrCrc", "crc32Valid"]
      },
      {
        "title": "Image Dimensions",
        "icon": "",
        "fields": ["imageWidth", "imageHeight", "totalPixels"]
      },
      {
        "title": "Color Profile",
        "icon": "",
        "fields": ["bitDepth", "colorType", "colorTypeName", "bitsPerPixel", "hasAlphaChannel", "isIndexedColor", "samplesPerPixel"]
      },
      {
        "title": "Rendering Methods",
        "icon": "",
        "fields": ["compressionMethod", "filterMethod", "interlaceMethod"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "PNG IHDR Summary (JSON)",
      "format": "json",
      "fields": ["imageWidth", "imageHeight", "bitDepth", "colorType", "compressionMethod", "filterMethod", "interlaceMethod", "totalPixels", "bitsPerPixel", "hasAlphaChannel", "crc32Valid"]
    },
    {
      "name": "PNG IHDR Chunk (C struct)",
      "format": "c-struct",
      "structName": "PNG_IHDR_CHUNK",
      "fields": ["ihdrChunkLength", "ihdrChunkType", "imageWidth", "imageHeight", "bitDepth", "colorType", "compressionMethod", "filterMethod", "interlaceMethod", "ihdrCrc"]
    },
    {
      "name": "PNG Dimensions (CSV)",
      "format": "csv",
      "fields": ["imageWidth", "imageHeight", "bitDepth", "colorType", "totalPixels", "bitsPerPixel"]
    },
    {
      "name": "Python PNG magic check",
      "format": "python-bytes",
      "fields": ["pngSignature", "ihdrChunkType"]
    }
  ],
  "forensic": {
    "category": "image",
    "riskLevel": "low",
    "suspiciousPatterns": [
      {
        "name": "Extremely large dimensions",
        "condition": "imageWidth > 65535 || imageHeight > 65535",
        "severity": "warning",
        "description": "Unusually large PNG dimensions (> 65535px) may trigger decompression memory exhaustion in vulnerable parsers"
      },
      {
        "name": "Potential decompression bomb",
        "condition": "imageWidth > 4096 && imageHeight > 4096 && (colorType == 2 || colorType == 6)",
        "severity": "info",
        "description": "Large high-color PNG may expand to significant memory: e.g. 32000x32000 RGBA = 4GB uncompressed"
      },
      {
        "name": "Non-standard filter method",
        "condition": "filterMethod != 0",
        "severity": "warning",
        "description": "Only filter method 0 is defined in PNG spec — non-zero indicates malformed or crafted file"
      },
      {
        "name": "Non-standard compression method",
        "condition": "compressionMethod != 0",
        "severity": "error",
        "description": "Only compression method 0 (DEFLATE/zlib) is defined in PNG spec — indicates malformed file"
      },
      {
        "name": "IHDR CRC validation failed",
        "condition": "crc32Valid == false",
        "severity": "error",
        "description": "IHDR chunk CRC-32 mismatch — header data is corrupted or intentionally modified"
      }
    ],
    "knownExploitVectors": [
      "PNG decompression bombs via extremely large uncompressed dimensions",
      "Chunk length integer overflow in parsers with insufficient bounds checking",
      "tEXt/iTXt metadata chunk abuse for hidden data or injection",
      "Palette (PLTE) chunk manipulation for steganography"
    ]
  },
  "aiHints": {
    "analysisContext": "PNG is a chunk-based lossless format: 8-byte signature + (Length+Type+Data+CRC-32) chunks. The mandatory IHDR at offset 8 defines all image properties. Key fields: imageWidth/imageHeight (decompression bomb risk), colorType (alpha/indexed), interlaceMethod (Adam7=progressive). IDAT chunk(s) hold DEFLATE-compressed filtered scanline data. All multi-byte values are big-endian.",
    "knownVulnerabilities": [
      "CVE-2021-29390: libpng integer overflow in spng_decode_chunks",
      "PNG decompression bombs: tiny compressed file expands to GB of RGBA scanline data",
      "LSB steganography in RGBA channels — undetectable without statistical analysis"
    ],
    "suggestedInspections": [
      "Verify IHDR CRC-32 matches computed CRC over bytes 12-28 (crc32Valid field)",
      "Compute imageWidth * imageHeight * (bitsPerPixel/8) — values > 500MB are suspicious",
      "Scan for tEXt/iTXt/zTXt chunks after IHDR — unvalidated metadata, used for steganography",
      "Verify IEND chunk is present and is the last chunk in the file",
      "For indexed-color (colorType=3): verify PLTE chunk is present before first IDAT"
    ]
  },
  "MimeTypes": [
    "image/png"
  ],
  "Software": [
    "Photoshop",
    "GIMP",
    "Paint.NET",
    "Preview",
    "Windows Photo Viewer"
  ],
  "UseCases": [
    "Web graphics",
    "Lossless image storage",
    "Screenshots",
    "Icons",
    "Transparency support"
  ],
  "QualityMetrics": {
    "CompletenessScore": 95,
    "DocumentationLevel": "comprehensive",
    "BlocksDefined": 21,
    "ValidationRules": 7,
    "LastUpdated": "2026-04-13",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "ImageFormat": true,
    "Endianness": "big-endian (network byte order)",
    "HeaderSize": 33,
    "ColorSpace": "RGB, RGBA, Grayscale, Grayscale+Alpha, Indexed",
    "CompressionMethod": "DEFLATE (zlib)",
    "LosslessCompression": true,
    "MaxBitDepth": 16,
    "SupportsTransparency": true,
    "SupportsAnimation": false,
    "ChunkBasedFormat": true
  }
}

  },
  "TechnicalDetails": {
    "Format": "XML text (SVG) or gzip-compressed XML (SVGZ)",
    "Magic": "No binary magic for SVG — '<svg' or '<?xml'; SVGZ uses gzip magic 1F 8B",
    "Standard": "SVG 2.0 — W3C Candidate Recommendation (2018) / SVG 1.1 Second Edition (2011)",

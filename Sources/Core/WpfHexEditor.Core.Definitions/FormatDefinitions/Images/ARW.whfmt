    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "ImageFormat": true,
    "ContainerFormat": "TIFF 6.0 (little-endian) with Sony private IFD extension",
    "Endianness": "little-endian",
    "RawEncoding": "Sony ARW lossy (compression=32767) or lossless (32770)",
    "BitDepth": "14-bit raw sensor data",
    "ARWVersions": "ARW 1.0, ARW 2.0 (Exmor+AES), ARW 2.1, ARW 2.2, ARW 2.3"
  }

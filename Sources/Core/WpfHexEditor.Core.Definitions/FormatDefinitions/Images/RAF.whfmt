{
  "diffMode": "binary",
  "formatName": "Fujifilm RAW",
  "version": "1.14",
  "extensions": [
    ".raf"
  ],
  "description": "RAF (RAW Fujifilm) is Fujifilm's proprietary RAW camera image format used in Fujifilm X-series, GFX, and FinePix cameras. Unlike most RAW formats, RAF does NOT use TIFF structure. RAF starts with a unique 16-byte ASCII header: 'FUJIFILMCCD-RAW ' (hex: 46 55 4A 49 46 49 4C 4D 43 43 44 2D 52 41 57 20). After the 16-byte magic, a 4-byte ASCII format version string follows (e.g., '0201'). At offset 20: a 32-byte null-padded ASCII camera model string. The JPEG preview and RAW sensor data are found via a directory at offset 84. Fujifilm X-Trans uses a unique 6x6 pixel repeating color filter array instead of the standard Bayer 2x2 pattern, requiring specialized demosaicing algorithms.",
  "category": "Images",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "image-viewer",
  "references": {
    "specifications": [
      "Fujifilm RAF RAW Format — proprietary non-TIFF",
      "Fujifilm X-Trans CFA Documentation"
    ],
    "WebLinks": [
      "https://libopenraw.freedesktop.org/formats/raf/",
      "https://exiftool.org/TagNames/FujiFilm.html",
      "https://www.rawdigger.com/howtouse/fuji-raf-format"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "46554A4946494C4D43434452415720", "offset": 0, "label": "'FUJIFILMCCD-RAW ' — Fujifilm RAF 15-byte magic", "weight": 1.0 },
      { "value": "46554A4946494C4D", "offset": 0, "label": "'FUJIFILM' — RAF first 8 bytes", "weight": 0.9 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.9,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 4.5, "max": 7.5 },
    "validation": {
      "minFileSize": 84,
      "maxSignatureOffset": 0,
      "note": "RAF has a completely unique ASCII header 'FUJIFILMCCD-RAW ' — NOT TIFF-based."
    }
  },
  "variables": {
    "rafMagic": "",
    "rafVersion": "",
    "cameraModel": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "RAF Magic Header",
      "offset": 0,
      "length": 16,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "Fujifilm RAF unique 16-byte ASCII magic: 'FUJIFILMCCD-RAW ' (46 55 4A 49 46 49 4C 4D 43 43 44 2D 52 41 57 20). The trailing space (0x20) at byte 15 is part of the magic and must be present. This header is completely unique to Fujifilm RAF and does not overlap with any TIFF-based format.",
      "storeAs": "rafMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Format Version",
      "offset": 16,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "4-byte ASCII format version string identifying the RAF format variant. '0100'=v1.0 (older FinePix), '0201'=v2.1 (X-series, most common), '0300'=v3.0 (newer X/GFX cameras).",
      "storeAs": "rafVersion",
      "valueType": "ascii",
      "valueMap": {
        "0100": "RAF v1.0 — older Fujifilm FinePix cameras",
        "0201": "RAF v2.1 — Fujifilm X-series (most common)",
        "0300": "RAF v3.0 — newer X-series/GFX cameras"
      }
    },
    {
      "type": "field",
      "name": "Camera Model",
      "offset": 20,
      "length": 32,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "ASCII camera model string null-padded to 32 bytes, e.g., 'X-T3', 'X100V', 'GFX 100S'. Uniquely identifies the Fujifilm camera that captured the RAW file.",
      "storeAs": "cameraModel",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "RAF Magic",
      "variable": "rafMagic",
      "description": "'FUJIFILMCCD-RAW ' — Fujifilm RAF unique identifier"
    },
    {
      "type": "metadata",
      "name": "Format Version",
      "variable": "rafVersion",
      "description": "RAF format version (e.g., '0201')"
    },
    {
      "type": "metadata",
      "name": "Camera Model",
      "variable": "cameraModel",
      "description": "Fujifilm camera model (e.g., 'X-T3', 'GFX 100S')"
    }
  ],
  "assertions": [
    {
      "name": "RAF magic valid",
      "expression": "rafMagic == 'FUJIFILMCCD-RAW '",
      "severity": "error",
      "message": "RAF must start with 'FUJIFILMCCD-RAW ' — not a valid Fujifilm RAF file"
    }
  ],
  "navigation": {
    "bookmarks": [

      }
    ]
  },
  "exportTemplates": [
    {
      "name": "RAF Header (JSON)",
      "format": "json",
      "fields": ["rafMagic", "rafVersion", "cameraModel"]
    }
  ],
  "forensic": {
    "category": "image",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Fujifilm RAF is NOT TIFF-based. Layout: magic(16,ASCII='FUJIFILMCCD-RAW ')+version(4,ASCII)+model(32,ASCII)+padding(32). At offset 84: directory with 3 entries (8B each: offset+length, 4B BE each) for JPEG preview, CFA RAW data, and EXIF data. RAW sensor: 12-bit Bayer (older) or 14-bit X-Trans 6x6 CFA (X-series). X-Trans 6x6 pattern requires non-standard demosaicing. RAF uses big-endian for directory offsets.",
    "suggestedInspections": [
      "Verify 'FUJIFILMCCD-RAW ' at offset 0 (16 bytes ASCII including trailing space)",
      "Version at offset 16 (4 bytes): '0201' = X-series, '0300' = newer GFX/X cameras",
      "Camera model at offset 20 (32 bytes ASCII, null-padded)",
      "Directory at offset 84: 3x (offset(4B BE)+length(4B BE)) for JPEG/RAW/EXIF"
    ]
  },
  "software": [
    "Fujifilm X RAW STUDIO",
    "Adobe Lightroom / Camera Raw",
    "Capture One",
    "darktable",
    "RawTherapee",
    "ExifTool"
  ],

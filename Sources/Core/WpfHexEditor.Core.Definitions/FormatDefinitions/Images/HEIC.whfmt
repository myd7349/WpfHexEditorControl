{
  "diffMode": "binary",
  "formatName": "HEIF/HEIC Image",
  "version": "1.0",
  "extensions": [".heic", ".heif", ".hif", ".avci"],
  "description": "HEIC/HEIF (High Efficiency Image File Format) is an ISOBMFF container for HEVC-encoded still images and image sequences, standardized as ISO 23008-12. The file begins with an ftyp box at offset 0: box_size (4 bytes, big-endian) + 'ftyp' (4 bytes, 0x66 0x74 0x79 0x70) + major_brand (4 bytes). HEIC brands: 'heic' (0x68 0x65 0x69 0x63) for HEVC single still image, 'heis' for HEVC single image with HDR, 'avci' (0x61 0x76 0x63 0x69) for AVC/H.264 still image. Compatible brands list: 'mif1', 'hevc', 'heic'. Image sequence brands: 'hevc', 'hevs'. The container holds an mdat box with compressed image data and meta/moov boxes for metadata. Exif and XMP metadata stored in iinf/iloc boxes. Apple uses HEIC for iPhone camera output (iOS 11+). Supports alpha channel, burst photography, depth maps, HDR (PQ/HLG transfer functions), wide color gamut (Display P3), and Live Photos ('qtff' compatible brand).",
  "category": "Images",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "image-viewer",
  "references": {
    "specifications": [
      "ISO/IEC 23008-12 High Efficiency Image File Format",
      "ISO/IEC 14496-12 Base Media File Format (ISOBMFF)",
      "ITU-T H.265 / HEVC Video Coding Standard"
    ],
    "WebLinks": [
      "https://nokiatech.github.io/heif/",
      "https://en.wikipedia.org/wiki/High_Efficiency_Image_File_Format",
      "https://github.com/strukturag/libheif",
      "https://developer.apple.com/documentation/heif"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "68656963", "offset": 8, "label": "heic — HEIC ftyp major brand at offset 8 (HEVC still image)", "weight": 1.0 },
      { "value": "68656966", "offset": 8, "label": "heif — HEIF ftyp major brand at offset 8", "weight": 0.9 },
      { "value": "61766369", "offset": 8, "label": "avci — AVC Image ftyp brand at offset 8 (H.264 still)", "weight": 0.8 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.7,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 4.0, "max": 7.8 },
    "validation": {
      "minFileSize": 16,
      "maxSignatureOffset": 8,
      "note": "Bytes 4-7 must be 'ftyp' (0x66747970). Major brand at offset 8 must be a known HEIF brand."
    }
  },
  "variables": {
    "boxSize": 0,
    "boxType": "",
    "majorBrand": "",
    "minorVersion": 0,
    "ftypValid": false
  },
  "blocks": [
    {
      "type": "field",
      "name": "Box Size",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "4-byte big-endian unsigned integer specifying the total byte size of the ftyp box including this 4-byte size field. For a standard ftyp box the size is typically 20-28 bytes depending on the number of compatible brand entries listed. A value of 0 means the box extends to end of file; a value of 1 signals a 64-bit extended size follows.",
      "storeAs": "boxSize",
      "valueType": "uint32be"
    },
    {
      "type": "field",
      "name": "Box Type",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "4-byte ASCII box type identifier. Must be 'ftyp' (0x66 0x74 0x79 0x70) for the mandatory file type box that appears at the beginning of every ISOBMFF-based container including HEIF/HEIC. The ftyp box declares the major brand and compatible brands for the file.",
      "storeAs": "boxType",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Major Brand",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "4-byte ASCII major brand code identifying the primary format of the file. Known HEIF brands: 'heic' = HEVC-encoded single still image (most common, used by iPhone), 'heis' = HEVC single image with HDR metadata, 'avci' = AVC/H.264 single still image, 'mif1' = HEIF multi-image file, 'hevc' = HEVC image sequence, 'hevs' = HEVC image sequence variant, 'msf1' = image sequence.",
      "storeAs": "majorBrand",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Minor Version",
      "offset": 12,
      "length": 4,
      "color": "#C3A6FF",
      "opacity": 0.35,
      "description": "4-byte big-endian minor version number of the ftyp box. Typically 0 for HEIC files. This field follows immediately after the major brand and precedes the list of compatible brands. Compatible brands extend the ftyp box until its declared size is reached.",
      "storeAs": "minorVersion",
      "valueType": "uint32be"
    },
    {
      "type": "metadata",
      "name": "Compatible Brands List",
      "offset": 16,
      "description": "List of 4-byte ASCII brand codes specifying all format specifications the file conforms to, beyond the major brand. Common entries for HEIC: 'mif1' (multi-image file), 'hevc', 'heic'. Live Photo files include 'qtff' for QuickTime compatibility. Apple ProRAW files may include 'dng ' brand. Each brand is 4 bytes with no separators; count = (box_size - 16) / 4."
    },
    {
      "type": "metadata",
      "name": "HEIF Container Boxes",
      "offset": 0,
      "description": "After the ftyp box, HEIF files contain: meta box (item location 'iloc', item info 'iinf', item reference 'iref', item properties 'iprp') for metadata and image item declarations; mdat box with compressed HEVC image bitstream data; optionally idat box for small inline image data. Exif metadata is referenced via iinf and fetched by iloc. XMP stored similarly as an additional item."
    }
  ],
  "assertions": [
    {
      "name": "ValidBoxType",
      "expression": "boxType == 'ftyp'",
      "severity": "error",
      "message": "Bytes 4-7 must be 'ftyp'. This file does not begin with an ISOBMFF ftyp box as required for HEIF/HEIC format."
    },
    {
      "name": "ValidMajorBrand",
      "expression": "majorBrand == 'heic' || majorBrand == 'heif' || majorBrand == 'avci' || majorBrand == 'heis' || majorBrand == 'mif1'",
      "severity": "warning",
      "message": "Major brand is not a recognized HEIF/HEIC brand. File may be a different ISOBMFF-based format."
    },
    {
      "name": "ValidBoxSize",
      "expression": "boxSize > 16",
      "severity": "error",
      "message": "ftyp box size must be greater than 16 bytes to accommodate the mandatory header fields. File may be corrupt."
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "ftyp Box", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "Major Brand", "offset": 8, "icon": "\uE946", "color": "#4ECDC4" },
      { "name": "Compatible Brands", "offset": 16, "icon": "\uE8B7", "color": "#FFE66D" }
    ]
  },
  "inspector": {
    "badge": "majorBrand",
    "primaryField": "majorBrand",
    "showQualityScore": true,
    "groups": [
      {
        "title": "ftyp Box",
        "icon": "\uE71B",
        "fields": ["boxSize", "boxType", "majorBrand", "minorVersion"]
      },
      {
        "title": "Format Flags",
        "icon": "\uE946",
        "fields": ["ftypValid"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "HEIC ftyp (JSON)",
      "format": "json",
      "fields": ["boxSize", "boxType", "majorBrand", "minorVersion"]
    },
    {
      "name": "HEIC Brands (CSV)",
      "format": "csv",
      "fields": ["majorBrand", "minorVersion", "boxSize"]
    }
  ],
  "forensic": {
    "category": "images",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "ftyp box size exceeding actual file size may indicate a corrupted or crafted header",
      "Unknown major brand in ISOBMFF container may indicate misidentified format or custom variant",
      "Missing mdat or idat box in container structure indicates an incomplete or truncated file"
    ]
  },
  "aiHints": {
    "analysisContext": "HEIF/HEIC uses an ISOBMFF container (ISO 14496-12). The ftyp box at offset 0 contains a 4-byte big-endian size, 'ftyp' type, major brand at offset 8, minor version at offset 12, then compatible brands. Primary brands: heic, heif, avci.",
    "suggestedInspections": [
      "Verify 'ftyp' at offset 4 and check major brand at offset 8 for heic/heif/avci identification",
      "Enumerate compatible brands from offset 16 to (offset + boxSize) to check for Live Photo 'qtff' brand",
      "Locate the meta box after the ftyp box to access item location (iloc) and item info (iinf) tables",
      "Find the mdat box containing the compressed HEVC image bitstream data",
      "Check for Exif and XMP items referenced by iinf entries for photography metadata extraction"
    ]
  },
  "software": [
    "Apple Photos (iOS 11+, macOS 10.13+)",
    "libheif (strukturag)",
    "ImageMagick 7+",
    "FFmpeg",
    "GIMP 2.10+",
    "Photoshop CC 2017+"
  ],
  "formatRelationships": {
    "category": "Images",
    "extensions": [".heic", ".heif", ".hif", ".avci"],
    "relatedFormats": ["AVIF", "JXL", "JPEG", "MP4"],
    "note": "HEIC uses HEVC compression in ISOBMFF; AVIF uses AV1 codec in the same ISOBMFF container model"
  },
  "MimeTypes": ["image/heic", "image/heif", "image/heic-sequence"],
  "UseCases": [
    "iPhone camera output (iOS 11+ default format)",
    "Apple Live Photos and burst photography storage",
    "HDR photography with PQ/HLG transfer function metadata",
    "Space-efficient image archiving with 2x better compression than JPEG"
  ],
  "QualityMetrics": {
    "CompletenessScore": 92,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 6,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "standard": "ISO/IEC 23008-12",
    "container": "ISOBMFF (ISO/IEC 14496-12)",
    "compression": "HEVC (H.265) for heic; AVC (H.264) for avci",
    "colorSpaces": ["sRGB", "Display P3", "Rec.2020"],
    "hdrTransferFunctions": ["PQ (SMPTE ST 2084)", "HLG (ARIB STD-B67)"],
    "features": ["alpha", "depth-map", "burst", "live-photo", "HDR", "wide-gamut"]
  }
}

    "AutoRefined": false
  },
  "TechnicalDetails": {
    "ImageFormat": true,
    "ContainerFormat": "TIFF 6.0 (little-endian) with Canon CR2 extension header at offset 8",
    "Endianness": "little-endian",
    "RawEncoding": "Lossless Huffman-coded 14-bit Bayer RGGB sensor data",
    "BitDepth": "14-bit RAW",
    "IFDLayout": "4 IFDs: IFD0=JPEG preview, IFD1=thumbnail, IFD2=14-bit RAW, IFD3=sRAW"
  }
}

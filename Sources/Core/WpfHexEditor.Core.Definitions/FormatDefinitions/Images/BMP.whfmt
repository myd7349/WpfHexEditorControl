    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Windows Bitmap (BMP) is an uncompressed or minimally compressed raster image format. The file consists of a ...",
    "suggestedInspections": [
      "Validate BMP Image signature, image dimensions, and color model",
      "Check pixel data offset, compression type, and scanline alignment",
      "Inspect color profile (ICC), EXIF metadata, and chunk CRCs"
    ]
  },
  "navigation": {
    "bookmarks": [
      {
        "name": "BMP File Header",
        "offsetVar": "currentOffset",
        "icon": ""
      },
      {
        "name": "DIB Header",
        "offsetVar": "dibHeaderSize",
        "icon": ""
      },
      {
        "name": "Pixel Data",
        "offsetVar": "pixelDataOffset",
        "icon": ""
      }
    ]
  },
  "TechnicalDetails": {
    "ImageFormat": true,
    "Endianness": "little-endian",
    "HeaderSize": 54,
    "FileHeaderSize": 14,
    "DIBHeaderSize": 40,
    "ColorSpace": "BGR, BGRA, Indexed, Monochrome",
    "CompressionMethod": "None (BI_RGB), RLE4, RLE8, BITFIELDS",
    "LosslessCompression": true,
    "MaxBitDepth": 32,
    "SupportsTransparency": true,
    "SupportsAnimation": false,
    "Platform": "Windows",
    "RowPadding": "4-byte aligned"
  }
}

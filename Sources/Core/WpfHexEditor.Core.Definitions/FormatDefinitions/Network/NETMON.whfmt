{
  "diffMode": "binary",
  "formatName": "Microsoft Network Monitor",
  "version": "1.14",
  "extensions": [
    ".cap"
  ],
  "description": "Microsoft Network Monitor capture format",
  "category": "Network",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Microsoft Network Monitor Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/CAP"
    ]
  },
  "detection": {
    "signature": "474D4255",
    "offset": 0,
    "required": true,
    "validation": {
      "minFileSize": 4,
      "maxSignatureOffset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "packetCount": 0,
    "snaplen": 0,
    "linkType": 0,
    "version": "",
    "netmonSignature": "",
    "versionMinor": 0,
    "versionMajor": 0,
    "networkType": 0,
    "timeDelta": 0,
    "frameTableOffset": 0,
    "frameTableLength": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "NetMon Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "GMBU signature",
      "storeAs": "netmonSignature",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Version Minor",
      "offset": 4,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Minor version number",
      "storeAs": "versionMinor",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Version Major",
      "offset": 5,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Major version number",
      "storeAs": "versionMajor",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Network Type",
      "offset": 6,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Link layer type",
      "storeAs": "networkType",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Time Delta",
      "offset": 8,
      "length": 8,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "Time offset from start",
      "storeAs": "timeDelta",
      "valueType": "uint64"
    },
    {
      "type": "field",
      "name": "Frame Table Offset",
      "offset": 16,
      "length": 4,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Offset to frame table",
      "storeAs": "frameTableOffset",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Frame Table Length",
      "offset": 20,
      "length": 4,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Length of frame table",
      "storeAs": "frameTableLength",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "Packet Count",
      "variable": "packetCount",
      "description": "Packet Count"
    },
    {
      "type": "metadata",
      "name": "Snapshot Length",
      "variable": "snaplen",
      "description": "Snapshot Length"
    },
    {
      "type": "metadata",
      "name": "Link Type",
      "variable": "linkType",
      "description": "Link Type"
    }
  ],
  "software": [
    "Wireshark",
    "tcpdump"
  ],
  "formatRelationships": {
    "category": "Network",
    "extensions": [
      ".cap"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Wireshark",
    "tcpdump",
    "NetworkMiner",
    "Fiddler",
    "Charles Proxy"
  ],
  "UseCases": [

    "divide": "Calculate duration"
  },
  "forensic": {
    "category": "network",
    "riskLevel": "medium",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Microsoft Network Monitor capture format",
    "suggestedInspections": [

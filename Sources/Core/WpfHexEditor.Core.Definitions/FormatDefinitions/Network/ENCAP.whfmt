  "blocks": [
    {
      "type": "field",
      "name": "Encapsulation Type",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Encapsulation protocol identifier",
      "storeAs": "encapsulationType",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Version",
      "offset": 2,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Encapsulation version",
      "storeAs": "version",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Flags",
      "offset": 3,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Encapsulation flags",
      "storeAs": "flags",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Total Length",
      "offset": 4,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Total packet length",
      "storeAs": "totalLength",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Header Length",
      "offset": 6,
      "length": 2,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "Encapsulation header length",
      "storeAs": "headerLength",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Protocol ID",
      "offset": 8,
      "length": 2,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Inner protocol identifier",
      "storeAs": "protocolId",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Sequence Number",
      "offset": 10,
      "length": 4,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Packet sequence number",
      "storeAs": "sequenceNumber",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Tunnel ID",
      "offset": 14,
      "length": 4,
      "color": "#98D8C8",
      "opacity": 0.3,
      "description": "Tunnel identifier",
      "storeAs": "tunnelId",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Packet Count",
      "variable": "packetCount",
      "description": "Packet Count"
    },
    {
      "type": "metadata",
      "name": "Snapshot Length",

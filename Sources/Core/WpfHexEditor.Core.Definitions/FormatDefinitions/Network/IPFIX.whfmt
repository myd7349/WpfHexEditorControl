{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v3.2.json",
  "diffMode": "binary",
  "formatName": "IPFIX",
  "formatId": "IPFIX",
  "version": "1.14",
  "extensions": [
    ".ipfix"
  ],
  "description": "IP Flow Information Export - Network flow monitoring protocol",
  "category": "Network",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "IPFIX Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/IPFIX"
    ]
  },
  "detection": {
    "signature": "000A",
    "offset": 0,
    "required": true,
    "validation": {
      "minFileSize": 2,
      "maxSignatureOffset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "version": 0,
    "messageLength": 0,
    "exportTime": 0,
    "sequenceNumber": 0,
    "ipfixVersion": 0,
    "observationDomainId": "",
    "setId": 0,
    "setLength": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "IPFIX Version",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Version 10 (0x000A)",
      "storeAs": "ipfixVersion",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Message Length",
      "offset": 2,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Total length of IPFIX message",
      "storeAs": "messageLength",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Export Time",
      "offset": 4,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Unix timestamp (seconds)",
      "storeAs": "exportTime",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Sequence Number",
      "offset": 8,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Incremental sequence counter",
      "storeAs": "sequenceNumber",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Observation Domain ID",
      "offset": 12,
      "length": 4,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "Source ID for flow data",
      "storeAs": "observationDomainId",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Set ID",
      "offset": 16,
      "length": 2,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Set identifier (2=template, 3=options, 256+=data)",
      "storeAs": "setId",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Set Length",
      "offset": 18,
      "length": 2,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Length of this set",
      "storeAs": "setLength",
      "valueType": "uint16"
    },
    {
      "type": "metadata",
      "name": "Version",
      "variable": "version",
      "description": "Version"
    },
    {
      "type": "metadata",
      "name": "Message Length",
      "variable": "messageLength",
      "description": "Message Length"
    }
  ],
  "software": [
    "Wireshark",
    "tcpdump"
  ],
  "formatRelationships": {
    "category": "Network",
    "extensions": [
      ".ipfix"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Wireshark",
    "tcpdump",
    "NetworkMiner",
    "Fiddler",
    "Charles Proxy"
  ],
  "UseCases": [
    "Network analysis",
    "Packet capture",
    "Debugging",
    "Security analysis"
  ],
  "protocolDefinition": {
    "transport": "udp",
    "defaultPort": 4739,
    "alternativePorts": [4740],
    "layerModel": "application",
    "layerStack": ["UDP/TCP/SCTP", "IPv4/IPv6"],
    "messageTypes": [
      { "id": "TEMPLATE_SET",     "name": "Template Set",     "direction": "request",  "description": "Field type definitions for data records" },
      { "id": "OPTIONS_SET",      "name": "Options Template",  "direction": "request",  "description": "Metadata and scope definitions" },
      { "id": "DATA_SET",         "name": "Data Set",          "direction": "request",  "description": "Flow measurement records" }
    ],
    "relatedProtocols": ["NETFLOW_V9", "SFLOW"]
  },
  "QualityMetrics": {
    "CompletenessScore": 56,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 9,
    "ValidationRules": 0,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt16BE": "Read message header",
    "readUInt32BE": "Read sequence numbers"
  },
  "forensic": {
    "category": "network",
    "riskLevel": "medium",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "IP Flow Information Export - Network flow monitoring protocol",
    "suggestedInspections": [
      "Validate IPFIX file header: magic, version, link-layer type",
      "Check packet record timestamps and capture lengths",
      "Inspect captured protocol headers (Ethernet/IP/TCP/UDP)"
    ]
  },
  "diff": {
    "keyFields": [
      "ipfix_version",
      "message_length",
      "set_length"
    ],
    "ignoreFields": [
      "export_time"
    ],
    "note": "Inferred semantic diff for IPFIX. Compare key structural fields; ignore volatile metadata."
  },
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "ipfix_version",
        "mutation": "corrupt_signature",
        "description": "Corrupt magic bytes at offset 0 — parser must reject."
      },
      {
        "field": "message_length",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      },
      {
        "field": "set_length",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      }
    ],
    "note": "Inferred fuzz strategies for IPFIX. Hand-tune weights/rates per format if needed."
  }
}




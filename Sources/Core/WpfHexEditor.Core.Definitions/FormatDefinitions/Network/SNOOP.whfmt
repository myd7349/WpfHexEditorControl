    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Format": "Binary big-endian Solaris snoop capture (RFC 1761)",
    "Magic": "'snoop\\0\\0\\0' (8 bytes ASCII) at offset 0",
    "ByteOrder": "Big-endian throughout (SPARC/Solaris origin)",
    "Version": "Version 2 (RFC 1761 standard); version 1 = legacy pre-RFC",
    "PacketRecord": "originalLen(4B) + includedLen(4B) + recordLen(4B) + drops(4B) + sec(4B) + usec(4B) + data"
  }

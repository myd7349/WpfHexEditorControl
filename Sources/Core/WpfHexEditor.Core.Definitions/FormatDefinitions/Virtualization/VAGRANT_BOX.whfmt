{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Vagrant Box",
  "formatId": "VAGRANT_BOX",
  "version": "1.0.1",
  "extensions": [".box"],
  "description": "Vagrant box package format — a gzip-compressed TAR archive containing a Vagrantfile, box.ovf virtual machine descriptor, and one or more VMDK disk images. Vagrant boxes are the base images used by HashiCorp Vagrant to provision reproducible development environments across VirtualBox, VMware, Hyper-V, and other providers.",
  "category": "Virtualization",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://developer.hashicorp.com/vagrant/docs/boxes/format",
    "https://app.vagrantup.com/boxes/search",
    "https://en.wikipedia.org/wiki/Vagrant_(software)"
  ],
  "detection": {
    "signatures": [
      {
        "value": "1F8B",
        "offset": 0,
        "label": "gzip compressed TAR (Vagrant box)",
        "weight": 0.4
      }
    ],
    "matchMode": "best",
    "MinimumScore": 0.3,
    "Strength": "Weak",
    "EntropyHint": "High — gzip-compressed content has near-random entropy distribution"
  },
  "variables": [
    {
      "name": "vagrantGzipMagic",
      "offset": 0,
      "size": 2,
      "type": "uint16",
      "endian": "BE",
      "description": "Gzip magic number 0x1F8B"
    }
  ],
  "blocks": [
    {
      "name": "GzipHeader",
      "offset": 0,
      "size": 10,
      "description": "Gzip file header with magic, method, flags, and timestamp"
    },
    {
      "name": "GzipMagic",
      "offset": 0,
      "size": 2,
      "description": "Gzip magic bytes 0x1F 0x8B"
    },
    {
      "name": "CompressionMethod",
      "offset": 2,
      "size": 1,
      "description": "Compression method — 0x08 for DEFLATE"
    },
    {
      "name": "CompressedPayload",
      "offset": 10,
      "size": 0,
      "description": "DEFLATE-compressed TAR payload containing Vagrantfile + box.ovf + *.vmdk"
    }
  ],
  "assertions": [
    {
      "variable": "vagrantGzipMagic",
      "operator": "==",
      "value": 8075,
      "description": "Gzip magic must be 0x1F8B (8075 decimal BE)",
      "level": "Error"
    },
    {
      "variable": "vagrantGzipMagic",
      "operator": "!=",
      "value": 0,
      "description": "Magic must not be zero",
      "level": "Error"
    },
    {
      "variable": "vagrantGzipMagic",
      "operator": ">",
      "value": 0,
      "description": "Valid gzip file must have non-zero magic",
      "level": "Warning"
    }
  ],
  "navigation": {
    "entryPoint": 0,
    "sections": [
      { "name": "Gzip Header", "offset": 0, "size": 10 },
      { "name": "Compressed TAR", "offset": 10, "size": 0 }
    ]
  },
  "inspector": {
    "badge": "VAGRANT",
    "primaryField": "vagrantGzipMagic",
    "groups": [
      {
        "name": "Container",
        "fields": ["vagrantGzipMagic"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Vagrant Box Summary",
      "format": "text",
      "template": "Format: Vagrant Box (.box)\nCompression: gzip\nMagic: {vagrantGzipMagic}"
    },
    {
      "name": "Vagrant Box JSON Report",
      "format": "json",
      "template": "{ \"format\": \"Vagrant Box\", \"compression\": \"gzip\", \"magic\": \"{vagrantGzipMagic}\" }"
    }
  ],
  "forensic": {
    "riskLevel": "MEDIUM",
    "notes": "Vagrant boxes contain full OS images. Untrusted boxes from third-party repositories may contain backdoors, cryptocurrency miners, or modified SSH keys.",
    "suspiciousPatterns": [
      "Vagrantfile with inline shell provisioner executing encoded scripts",
      "Box from untrusted source with pre-configured SSH authorized_keys",
      "Unexpected large VMDK size relative to declared base image"
    ]
  },
  "aiHints": {
    "analysisContext": "Vagrant boxes are gzip TAR archives used by HashiCorp Vagrant for reproducible dev environments. Contains Vagrantfile + OVF + VMDK.",
    "suggestedInspections": [
      "Verify gzip magic 0x1F8B at offset 0 to confirm compression.",
      "Decompress and inspect the TAR contents for expected files (Vagrantfile, box.ovf, *.vmdk).",
      "Check the embedded Vagrantfile for suspicious provisioning scripts.",
      "Validate the OVF descriptor for unexpected hardware or network configurations."
    ]
  },
  "software": [
    { "name": "HashiCorp Vagrant", "platform": "Windows/macOS/Linux", "url": "https://www.vagrantup.com/" },
    { "name": "Oracle VirtualBox", "platform": "Windows/macOS/Linux", "url": "https://www.virtualbox.org/" },
    { "name": "7-Zip", "platform": "Windows", "url": "https://www.7-zip.org/" }
  ],
  "formatRelationships": [
    { "format": "OVF", "relationship": "contained", "note": "Vagrant box contains box.ovf descriptor" },
    { "format": "OVA", "relationship": "similar", "note": "Both are TAR-based VM packaging formats" }
  ],
  "MimeTypes": ["application/gzip", "application/x-gzip"],
  "UseCases": [
    "Reproducible development environment provisioning",
    "Base image distribution for Vagrant providers",
    "Infrastructure-as-code development workflows"
  ],
  "QualityMetrics": {
    "CompletenessScore": 82,
    "LastUpdated": "2026-04-16",
    "ReviewedBy": "WPFHexaEditor Team"
  },
  "TechnicalDetails": {
    "containerFormat": "gzip-compressed TAR",
    "typicalContents": "Vagrantfile, box.ovf, *.vmdk, metadata.json",
    "compressionMethod": "DEFLATE (gzip)",
    "providers": "VirtualBox, VMware, Hyper-V, libvirt"
  }
}




  "forensic": {
    "category": "geospatial",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Classified or sensitive geographic data may be embedded in vector layers",
      "SQLite WAL (write-ahead log) file may contain undeleted sensitive features"
    ]
  },
  "aiHints": {
    "analysisContext": "GeoPackage is a single-file SQLite3 database. Key tables: gpkg_contents (layer name, data_type='features'/'tiles', last_change, min_x/y/max_x/y, srs_id), gpkg_geometry_columns (table_name, column_name, geometry_type_name, srs_id, z, m), gpkg_spatial_ref_sys (srs_id, organization='EPSG', organization_coordsys_id, definition WKT). Feature tables: geometry column (BLOB with GPKG header: magic GP 2B + version 1B + flags 1B + srs_id 4B + optional envelope + WKB) + attribute columns. Tile tables: zoom_level, tile_column, tile_row, tile_data (PNG or JPEG BLOB).",
    "suggestedInspections": [
      "Bytes 0-15: 'SQLite format 3' magic — confirms SQLite3 base format",
      "Bytes 16-17 (uint16 BE): page size — GeoPackage default is 4096 bytes",
      "Bytes 68-71 (uint32 BE): application_id — must be 0x47504B47 ('GPKG') for OGC GeoPackage",
      "SQLite page 1 contains master table listing all GPKG tables (SELECT name FROM sqlite_master)"
    ]
  },
  "software": [
    "QGIS (native GPKG support)",
    "ArcGIS Pro (read/write GPKG)",
    "GDAL (ogr2ogr GPKG driver)",
    "Geopandas (via fiona GPKG driver)",
    "SQLite browser (generic SQLite inspection)",
    "GeoTools (Java GIS library)"
  ],
  "formatRelationships": {
    "category": "GIS",
    "extensions": [".gpkg"],
    "relatedFormats": ["SHP", "GEOJSON", "GEOTIFF", "KML"],
    "note": "GeoPackage is the OGC-recommended modern replacement for ESRI Shapefile. Unlike Shapefile (multi-file), GPKG is a single file containing both geometry and attributes. GPKG also supports raster tiles (alternative to MBTiles). SpatiaLite is a competing SQLite-based format but lacks OGC standardization."
  },
  "MimeTypes": [
    "application/geopackage+sqlite3",
    "application/x-sqlite3"
  ],
  "UseCases": [
    "Mobile GIS field data collection (no network required)",
    "OpenStreetMap extract distribution (alternative to PBF for vector tiles)",
    "National mapping agency open data distribution",
    "Interoperable vector/raster data exchange in a single file",
    "NATO STANAG 2595 (GeoPackage for military data exchange)"
  ],

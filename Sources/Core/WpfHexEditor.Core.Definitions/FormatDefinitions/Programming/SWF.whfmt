    },
    {
      "type": "field",
      "name": "Version",
      "offset": 3,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Flash version",
      "storeAs": "version",
      "valueType": "uint8"
    },
    {
      "type": "field",

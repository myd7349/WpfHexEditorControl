{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Erlang BEAM Bytecode",
  "formatId": "BEAM",
  "version": "1.0.1",
  "extensions": [".beam"],
  "description": "BEAM (Bogdan/Bj\u00f6rn's Erlang Abstract Machine) bytecode file — an IFF-style container starting with 'FOR1' magic, followed by a 4-byte file size, and the form type 'BEAM' at offset 8. Contains named chunks for atoms, code, string tables, imports, exports, and other module metadata. Generated by the Erlang/OTP and Elixir compilers.",
  "category": "Programming",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://www.erlang.org/doc/apps/erts/beam_makeops",
    "https://blog.stenmans.org/theBeamBook/",
    "https://en.wikipedia.org/wiki/BEAM_(Erlang_virtual_machine)"
  ],
  "detection": {
    "signatures": [
      {
        "value": "464F5231",
        "offset": 0,
        "label": "'FOR1' IFF container for BEAM",
        "weight": 0.8
      },
      {
        "value": "4245414D",
        "offset": 8,
        "label": "'BEAM' form type at offset 8",
        "weight": 1.0
      }
    ],
    "matchMode": "best",
    "MinimumScore": 0.8,
    "Strength": "Strong",
    "EntropyHint": "Moderate — atom tables and string data are low entropy; bytecode sections have moderate entropy"
  },
  "variables": [
    {
      "name": "beamFor1Magic",
      "offset": 0,
      "size": 4,
      "type": "ascii",
      "description": "IFF magic — must be 'FOR1'"
    },
    {
      "name": "beamFileSize",
      "offset": 4,
      "size": 4,
      "type": "uint32",
      "endian": "BE",
      "description": "File size in bytes (excluding the first 8 bytes)"
    },
    {
      "name": "beamType",
      "offset": 8,
      "size": 4,
      "type": "ascii",
      "description": "Form type — must be 'BEAM'"
    },
    {
      "name": "beamFirstChunkId",
      "offset": 12,
      "size": 4,
      "type": "ascii",
      "description": "First chunk identifier (e.g., 'AtU8', 'Atom', 'Code')"
    }
  ],
  "blocks": [
    {
      "name": "IFFHeader",
      "offset": 0,
      "size": 12,
      "description": "'FOR1' + 4-byte size + 'BEAM' form type"
    },
    {
      "name": "FirstChunk",
      "offset": 12,
      "size": 8,
      "description": "First chunk header: 4-byte chunk ID + 4-byte chunk size"
    },
    {
      "name": "AtomTable",
      "offset": 0,
      "size": 0,
      "description": "AtU8/Atom chunk — module atom table with function and module names"
    },
    {
      "name": "CodeChunk",
      "offset": 0,
      "size": 0,
      "description": "Code chunk — BEAM bytecode instructions"
    },
    {
      "name": "ExportTable",
      "offset": 0,
      "size": 0,
      "description": "ExpT chunk — exported function table (name, arity, label)"
    }
  ],
  "assertions": [
    {
      "variable": "beamFor1Magic",
      "operator": "==",
      "value": "FOR1",
      "description": "IFF magic must be 'FOR1'",
      "level": "Error"
    },
    {
      "variable": "beamType",
      "operator": "==",
      "value": "BEAM",
      "description": "Form type must be 'BEAM'",
      "level": "Error"
    },
    {
      "variable": "beamFileSize",
      "operator": ">",
      "value": 0,
      "description": "File size must be greater than zero",
      "level": "Error"
    }
  ],
  "navigation": {
    "entryPoint": 0,
    "sections": [
      { "name": "IFF Header", "offset": 0, "size": 12 },
      { "name": "Chunks", "offset": 12, "size": 0 }
    ]
  },
  "inspector": {
    "badge": "BEAM",
    "primaryField": "beamType",
    "groups": [
      {
        "name": "Identity",
        "fields": ["beamFor1Magic", "beamType", "beamFirstChunkId"]
      },
      {
        "name": "Structure",
        "fields": ["beamFileSize"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "BEAM Summary",
      "format": "text",
      "template": "Format: Erlang BEAM Bytecode\nMagic: {beamFor1Magic}\nForm Type: {beamType}\nFile Size: {beamFileSize} bytes\nFirst Chunk: {beamFirstChunkId}"
    },
    {
      "name": "BEAM JSON Report",
      "format": "json",
      "template": "{ \"format\": \"BEAM\", \"magic\": \"{beamFor1Magic}\", \"formType\": \"{beamType}\", \"fileSize\": {beamFileSize}, \"firstChunk\": \"{beamFirstChunkId}\" }"
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "notes": "BEAM files are compiled Erlang/Elixir modules. Atom tables reveal module names and function exports. Decompilation is straightforward with beam_disasm.",
    "suspiciousPatterns": [
      "BEAM file with obfuscated atom names",
      "Unusually large code chunk relative to atom/export tables",
      "Module containing NIF (Native Implemented Function) references to unknown shared libraries"
    ]
  },
  "aiHints": {
    "analysisContext": "BEAM bytecode is an IFF container (FOR1 + BEAM) with named chunks. Compiled from Erlang (.erl) or Elixir (.ex) sources. The BEAM VM runs on the Erlang/OTP platform.",
    "suggestedInspections": [
      "Verify 'FOR1' at offset 0 and 'BEAM' at offset 8.",
      "Parse chunk headers (4-byte ID + 4-byte size) starting at offset 12.",
      "Extract the atom table (AtU8 or Atom chunk) for module and function names.",
      "List exported functions from the ExpT chunk (name atom index, arity, code label).",
      "Check for 'NIF' chunk indicating native library dependencies."
    ]
  },
  "software": [
    { "name": "Erlang/OTP", "platform": "Windows/macOS/Linux", "url": "https://www.erlang.org/" },
    { "name": "Elixir", "platform": "Windows/macOS/Linux", "url": "https://elixir-lang.org/" },
    { "name": "beam_disasm", "platform": "Windows/macOS/Linux", "url": "https://www.erlang.org/doc/man/beam_disasm" }
  ],
  "formatRelationships": [
    { "format": "IFF", "relationship": "parent", "note": "BEAM uses IFF (FOR1) container format" },
    { "format": "DALVIK_OAT", "relationship": "unrelated", "note": "Both are VM bytecode formats for different platforms" }
  ],
  "MimeTypes": ["application/x-erlang-beam", "application/octet-stream"],
  "UseCases": [
    "Erlang/Elixir compiled module distribution",
    "BEAM VM bytecode analysis and decompilation",
    "Hot code reloading in Erlang/OTP systems"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "LastUpdated": "2026-04-16",
    "ReviewedBy": "WPFHexaEditor Team"
  },
  "TechnicalDetails": {
    "magicBytes": "46 4F 52 31 (FOR1) at offset 0, 42 45 41 4D (BEAM) at offset 8",
    "containerFormat": "IFF (Interchange File Format)",
    "endianness": "Big-Endian for size fields",
    "chunkAlignment": "4-byte aligned with zero padding",
    "commonChunks": "AtU8 (atoms), Code (bytecode), StrT (strings), ImpT (imports), ExpT (exports), FunT (lambdas), LitT (literals)"
  }
}




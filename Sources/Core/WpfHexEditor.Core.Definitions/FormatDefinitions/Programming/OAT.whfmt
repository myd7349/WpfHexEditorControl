      "https://en.wikipedia.org/wiki/OAT"
    ]
  },
  "detection": {
    "required": true,
    "validation": {
      "minFileSize": 4,
      "maxSignatureOffset": 1024
    },
    "signatures": [
      {
        "value": "6F61740A",
        "offset": 0,
        "label": "OAT magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "Strength": "Strong"
  },
  "variables": {
    "zipFileCount": 0,
    "zipCentralDirSize": 0,
    "zipCommentLength": 0,
    "zipComment": "",
    "eocdOffset": -1,
    "isZip64": false,
    "oatMagic": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "OAT Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Magic bytes: 'oat' 0x0A",
      "storeAs": "oatMagic",
      "valueType": "uint32"
    },
    {
      "type": "data",
      "name": "OAT Version",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.4,
      "description": "OAT format version (e.g., '088' for Android 8.0)"
    },
    {
      "type": "data",
      "name": "DEX File Count",
      "offset": 8,
      "length": 4,
      "color": "#45B7D1",
      "opacity": 0.4,
      "description": "Number of DEX files (little-endian)"
    },
    {
      "type": "data",
      "name": "Executable Offset",
      "offset": 12,
      "length": 4,
      "color": "#96CEB4",
      "opacity": 0.4,
      "description": "Offset to executable section (little-endian)"
    },
    {
      "type": "metadata",
      "name": "Total Files",
      "variable": "zipFileCount",
      "description": "Total Files"
    },
    {
      "type": "metadata",
      "name": "Central Directory Size",
      "variable": "zipCentralDirSize",
      "description": "Central Directory Size"
    },
    {
      "type": "metadata",
      "name": "EOCD Offset",
      "variable": "eocdOffset",
      "description": "EOCD Offset"
    },
    {
      "type": "metadata",
      "name": "ZIP64 Format",
      "variable": "isZip64",
      "description": "ZIP64 Format"
    }

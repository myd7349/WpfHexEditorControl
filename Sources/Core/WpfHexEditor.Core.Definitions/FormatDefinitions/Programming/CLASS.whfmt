{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Java Class File",
  "formatId": "CLASS",
  "version": "1.14",
  "extensions": [
    ".class"
  ],
  "description": "Java compiled bytecode",
  "category": "Programming",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Java Class File Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/CLASS"
    ]
  },
  "detection": {
    "required": true,
    "validation": {
      "minFileSize": 4,
      "maxSignatureOffset": 1024
    },
    "signatures": [
      {
        "value": "CAFEBABE",
        "offset": 0,
        "label": "CLASS magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "Strength": "Strong"
  },
  "functions": {
    "readUInt32BE": "Read 32-bit big-endian for magic number",
    "readUInt16BE": "Read 16-bit big-endian for version numbers and constant pool count",
    "extractUTF8String": "Extract class name, method names from constant pool",
    "calculateSHA256": "Calculate SHA256 hash for class file verification"
  },
  "variables": {
    "currentOffset": 0,
    "minorVersion": 0,
    "majorVersion": 0,
    "constantPoolCount": 0,
    "className": "Unknown",
    "superClassName": "Unknown",
    "accessFlags": 0,
    "methods": 0,
    "javaMagic": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Java Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "CAFEBABE signature",
      "storeAs": "javaMagic",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Minor Version",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Class file minor version",
      "storeAs": "minorVersion",
      "valueType": "uint16",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Major Version",
      "offset": 6,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Class file major version",
      "storeAs": "majorVersion",
      "valueType": "uint16",
      "endianness": "big"
    }
  ],
  "assertions": [
    {
      "name": "CAFEBABE magic",
      "expression": "classMagic == -889275714",
      "severity": "error",
      "message": "Invalid Java class magic — expected 0xCAFEBABE"
    }
  ],
  "forensic": {
    "category": "programming",
    "riskLevel": "medium",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Java compiled bytecode",
    "suggestedInspections": [
      "Verify Java Class File magic number and format version identifier",
      "Check symbol/string table integrity and section boundaries",
      "Inspect code section offsets, relocations, and debug info"
    ]
  },
  "software": [
    "Java Virtual Machine",
    "Java IDEs",
    "Bytecode tools"
  ],
  "formatRelationships": {
    "java_format": true,
    "contained_in": "JAR",
    "jvm_bytecode": true
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Visual Studio",
    "GCC",
    "LLVM",
    "IDA Pro",
    "Ghidra"
  ],
  "UseCases": [
    "Software development",
    "Compilation",
    "Linking",
    "Analysis"
  ],
  "QualityMetrics": {
    "CompletenessScore": 63,
    "DocumentationLevel": "standard",
    "BlocksDefined": 3,
    "ValidationRules": 0,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {},
  "inspector": {
    "badge": "javaMagic",
    "primaryField": "minorVersion",
    "showQualityScore": true,
    "groups": [
      {
        "title": "Java Class File",
        "icon": "",
        "fields": [
          "javaMagic",
          "minorVersion",
          "majorVersion"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Java Class File Header (JSON)",
      "format": "json",
      "fields": [
        "javaMagic",
        "minorVersion",
        "majorVersion"
      ]
    }
  ],
  "diff": {
    "keyFields": ["majorVersion", "minorVersion", "javaMagic"],
    "ignoreFields": [],
    "groupBy": "majorVersion",
    "note": "Major version directly maps to the Java SE release that compiled the class; minor version distinguishes preview features. Magic is constant but included to catch corrupted files during bulk diffing."
  },
  "repair": [
    {
      "name": "FixJavaMagic",
      "trigger": "javaMagic != 0xCAFEBABE",
      "action": "set_value",
      "target": "javaMagic",
      "value": "CAFEBABE",
      "description": "Restore the 4-byte CAFEBABE magic at offset 0 (big-endian) when it has been truncated or overwritten"
    },
    {
      "name": "FixMinorVersionForRelease",
      "trigger": "minorVersion != 0 && minorVersion != 65535",
      "action": "set_value",
      "target": "minorVersion",
      "value": "0000",
      "description": "Reset minor version to 0 for standard release classes; 65535 (0xFFFF) is reserved for preview-feature classes only"
    }
  ],
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      { "field": "javaMagic",    "mutation": "corrupt_signature", "weight": 3, "description": "Corrupt CAFEBABE to test JVM class-loader rejection and hex-editor fallback detection" },
      { "field": "majorVersion", "mutation": "boundary_values",   "weight": 2, "description": "Test majorVersion at 0, 0xFFFF, and beyond the current max (67 for Java 23) to probe JVM version-gate logic" },
      { "field": "minorVersion", "mutation": "enum_sweep",        "weight": 2, "description": "Sweep 0, 65535, and intermediate values to probe preview-feature gating across JVM versions" },
      { "field": "majorVersion", "mutation": "overflow",          "weight": 2, "description": "Overflow the 16-bit major version field to expose integer truncation in class-file parsers" },
      { "field": "javaMagic",    "mutation": "bit_flip", "rate": 0.001, "weight": 1, "description": "Single-bit flip in the magic to find off-by-one class-file detection boundaries" }
    ]
  },
  "migration": [
    {
      "from": "Java 8 (major=52)",
      "to": "Java 17 LTS (major=61)",
      "description": "Upgrade the declared class-file version from Java 8 to Java 17 LTS; does not recompile bytecode — only updates the version gate",
      "changes": [
        { "field": "majorVersion", "changeType": "set_value", "value": "003D", "description": "Set majorVersion (BE) to 61 (0x003D) for Java 17 compatibility" },
        { "field": "minorVersion", "changeType": "set_value", "value": "0000", "description": "Clear minor version to 0 (standard release, not preview)" }
      ]
    },
    {
      "from": "Java 17 (major=61)",
      "to": "Java 21 LTS (major=65)",
      "description": "Upgrade declared version to Java 21 LTS",
      "changes": [
        { "field": "majorVersion", "changeType": "set_value", "value": "0041", "description": "Set majorVersion (BE) to 65 (0x0041) for Java 21 compatibility" }
      ]
    }
  ]
}



/*
   ============================================================
   Format:    Kotlin Source File
   Category:  Programming
   Ext:       .kt, .kts
   Editor:    code-editor
   Desc:      Kotlin programming language source files (JVM and Android).
   Updated:   2026-04-04
   ============================================================
*/
{
  "diffMode": "text",
  "formatName": "Kotlin Source File",
  "version": "2.1",
  "extensions": [
    ".kt",
    ".kts"
  ],
  "description": "Kotlin programming language source files (JVM and Android).",
  "category": "Programming",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "code-editor",
  "detection": {
    "isTextFormat": true,
    "required": false
  },
  "QualityMetrics": {
    "CompletenessScore": 80,
    "DocumentationLevel": "standard",
    "BlocksDefined": 0,
    "ValidationRules": 0,
    "LastUpdated": "2026-03-22",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "MimeTypes": [
    "text/x-kotlin"
  ],
  "Software": [
    "IntelliJ IDEA",
    "Android Studio"
  ],
  "UseCases": [
    "Android development",
    "JVM server-side development",
    "Multiplatform projects"
  ],
  "syntaxDefinition": {
    "diagnosticPrefix": "KT",
    "id": "kotlin",
    "name": "Kotlin",
    "extensions": [
      ".kt",
      ".kts"
    ],
    "lineCommentPrefix": "//",
    "blockCommentStart": "/*",
    "blockCommentEnd": "*/",
    "rules": [
      {
        "type": "BlockComment",
        "pattern": "/\\*[\\s\\S]*?\\*/",
        "colorKey": "TE_Comment"
      },
      {
        "type": "String",
        "pattern": "(\"\"\"|\"\"\"[\\s\\S]*?\"\"\"|\"(?:[^\"\\]|\\.)*\"|\\'(?:[^\\'\\]|\\.)*\\')",
        "colorKey": "TE_String"
      },
      {
        "type": "Comment",
        "pattern": "//.*$",
        "colorKey": "TE_Comment"
      },
      {
        "type": "Keyword",
        "pattern": "\\b(as|break|class|continue|do|else|false|for|fun|if|in|interface|is|null|object|package|return|super|this|throw|true|try|typealias|typeof|val|var|when|while|abstract|actual|annotation|by|catch|companion|const|constructor|crossinline|data|enum|expect|external|final|finally|get|import|infix|init|inline|inner|internal|lateinit|noinline|open|operator|out|override|private|protected|public|reified|sealed|set|suspend|tailrec|vararg|field|it|dynamic|where)\\b",
        "colorKey": "TE_Keyword"
      },
      {
        "type": "Type",
        "pattern": "\\b(Any|Boolean|Byte|Char|Double|Float|Int|Long|Nothing|Number|Short|String|Unit|Array|BooleanArray|ByteArray|CharArray|DoubleArray|FloatArray|IntArray|LongArray|ShortArray|List|MutableList|Set|MutableSet|Map|MutableMap|Pair|Triple|Sequence|Iterable|Iterator|MutableIterator|Collection|MutableCollection|Comparable|Throwable|Exception|Error|RuntimeException|IllegalArgumentException|IllegalStateException|NullPointerException|IndexOutOfBoundsException|HashMap|LinkedHashMap|HashSet|LinkedHashSet|ArrayList|StringBuilder|Regex|Result|Lazy|Sequence|Channel|Flow|StateFlow|SharedFlow|CoroutineScope|Job|Deferred|Dispatchers|async|launch|withContext|runBlocking)\\b",
        "colorKey": "TE_Type"
      },
      {
        "type": "Annotation",
        "pattern": "@[A-Za-z][A-Za-z0-9_]*",
        "colorKey": "TE_Directive"
      },
      {
        "type": "Number",
        "pattern": "\\b(0x[0-9A-Fa-f_]+[lL]?|0b[01_]+[lL]?|[0-9][0-9_]*(?:\\.[0-9_]+)?(?:[eE][+-]?[0-9]+)?[fF]?[lL]?)\\b",
        "colorKey": "TE_Number"
      },
      {
        "type": "MethodCall",
        "pattern": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()",
        "colorKey": "TE_Label"
      }
    ],
    "foldingRules": {
      "startPatterns": [
        "\\{"
      ],
      "endPatterns": [
        "\\}"
      ],
      "endOfBlockHint": {
        "enabled": true,
        "maxContextLines": 3,
        "triggerBrace": true,
        "triggerDirective": false
      }
    },
    "breakpointRules": {
      "nonExecutablePatterns": [
        "^\\s*//",
        "^\\s*/\\*",
        "^\\s*\\*",
        "^\\s*$",
        "^\\s*package\\b",
        "^\\s*import\\b"
      ],
      "statementContinuationPatterns": [
        "[^;{}]\\s*$"
      ]
    },
    "bracketPairs": [
      {
        "open": "(",
        "close": ")"
      },
      {
        "open": "[",
        "close": "]"
      },
      {
        "open": "{",
        "close": "}"
      }
    ],
    "columnRulers": [
      120
    ],
    "formattingRules": {
      "indentSize": 4,
      "useTabs": false,
      "trimTrailingWhitespace": true,
      "insertFinalNewline": true,
      "lineEnding": "lf",
      "braceStyle": "kr",
      "spaceBeforeOpenBrace": true,
      "spaceAfterKeywords": true,
      "spaceInsideParens": false,
      "indentCaseLabels": false,
      "maxConsecutiveBlankLines": 2,
      "blankLineBeforeMethod": true,
      "blankLineAfterImports": true,
      "spaceAroundBinaryOperators": true,
      "spaceAfterComma": true,
      "organizeImports": true,
      "separateSystemImports": false,
      "maxLineLength": 120
    },
    "previewSnippet": "import kotlin.io.*\nimport kotlin.math.*\n\nfun go(x:Int,y:Int){\nif(x>0){\nwhen(x){\n1->return\n}\n}\n}",
    "previewSamples": {
      "spaceAfterKeywords": {
        "before": "if(x>0){",
        "after": "if (x > 0) {"
      },
      "spaceAroundBinaryOperators": {
        "before": "a=b+c*2",
        "after": "a = b + c * 2"
      },
      "spaceAfterComma": {
        "before": "go(x,y,z)",
        "after": "go(x, y, z)"
      },
      "trimTrailingWhitespace": {
        "before": "val x = 1   ",
        "after": "val x = 1"
      },
      "insertFinalNewline": {
        "before": "}",
        "after": "}\n"
      }
    },
    "ideMetadata": {
      "isSourceFile": true,
      "aliases": [
        "kt",
        "kts"
      ],
      "iconGlyph": "",
      "diffMode": "semantic"
    }
  },
  "forensic": {
    "category": "other",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Kotlin programming language source files (JVM and Android).",
    "suggestedInspections": [
      "Verify Kotlin Source File file signature and header structure",
      "Check data integrity and field boundaries",
      "Inspect metadata and version information"
    ]
  }
}

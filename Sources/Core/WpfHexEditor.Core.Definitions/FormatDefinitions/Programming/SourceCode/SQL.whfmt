/*
   ============================================================
   Format:    SQL Source File
   Category:  Programming
   Ext:       .sql, .ddl, .dml
   Editor:    code-editor
   Desc:      Structured Query Language source files for databases.
   Updated:   2026-04-04
   ============================================================
*/
{
  "diffMode": "text",
  "formatName": "SQL Source File",
  "version": "2.1",
  "extensions": [
    ".sql",
    ".ddl",
    ".dml"
  ],
  "description": "Structured Query Language source files for databases.",
  "category": "Programming",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "code-editor",
  "detection": {
    "isTextFormat": true,
    "required": false
  },
  "QualityMetrics": {
    "CompletenessScore": 80,
    "DocumentationLevel": "standard",
    "BlocksDefined": 0,
    "ValidationRules": 0,
    "LastUpdated": "2026-03-22",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "MimeTypes": [
    "text/x-sql"
  ],
  "Software": [
    "DBeaver",
    "SQL Server Management Studio",
    "DataGrip"
  ],
  "UseCases": [
    "Database queries",
    "Schema migration",
    "Stored procedures"
  ],
  "syntaxDefinition": {
    "diagnosticPrefix": "SQL",
    "id": "sql",
    "name": "SQL",
    "extensions": [
      ".sql",
      ".ddl",
      ".dml"
    ],
    "lineCommentPrefix": "--",
    "blockCommentStart": "/*",
    "blockCommentEnd": "*/",
    "rules": [
      {
        "type": "Keyword",
        "pattern": "(?i)\\b(ADD|ALL|ALTER|AND|ANY|AS|ASC|BACKUP|BETWEEN|BY|CASE|CHECK|COLUMN|CONSTRAINT|CREATE|CROSS|DATABASE|DEFAULT|DELETE|DESC|DISTINCT|DROP|EXEC|EXISTS|FOREIGN|FROM|FULL|GROUP|HAVING|INNER|INSERT|INTO|IS|JOIN|KEY|LEFT|LIKE|LIMIT|NOT|NULL|NULLS|OF|OFFSET|ON|OR|ORDER|OUTER|PRIMARY|PROCEDURE|RIGHT|ROWNUM|SELECT|SET|SOME|TABLE|TOP|TRUNCATE|UNION|UNIQUE|UPDATE|VALUES|VIEW|WHERE|WITH|BEGIN|END|COMMIT|ROLLBACK|TRANSACTION|INDEX|TRIGGER|FUNCTION|RETURNS|RETURN|DECLARE|IF|ELSE|WHILE|LOOP|CURSOR|OPEN|FETCH|CLOSE|DEALLOCATE|GRANT|REVOKE|DENY|USE|SCHEMA|SEQUENCE|REPLACE|MERGE|CALL|EXECUTE|EXPLAIN|VACUUM|ANALYZE|REINDEX|ATTACH|DETACH)\\b",
        "colorKey": "TE_Keyword"
      },
      {
        "type": "Function",
        "pattern": "(?i)\\b(ABS|AVG|CAST|CEIL|COALESCE|CONCAT|COUNT|CURDATE|CURTIME|DATE|DATEDIFF|DAY|FLOOR|FORMAT|GETDATE|HOUR|ISNULL|LCASE|LEFT|LEN|LENGTH|LOWER|LTRIM|MAX|MIN|MOD|MONTH|NOW|NULLIF|NVIL|PATINDEX|RAND|REPLACE|REVERSE|RIGHT|ROUND|RTRIM|SIGN|SQRT|STR|STUFF|SUBSTR|SUBSTRING|SUM|SYSDATE|TRIM|UCASE|UPPER|YEAR|ROW_NUMBER|RANK|DENSE_RANK|NTILE|LAG|LEAD|FIRST_VALUE|LAST_VALUE|NTH_VALUE|JSON_EXTRACT|JSON_VALUE|JSON_QUERY|JSON_ARRAYAGG|JSON_OBJECTAGG|GROUP_CONCAT|STRING_AGG|LISTAGG|ARRAY_AGG)\\b",
        "colorKey": "TE_Type"
      },
      {
        "type": "DataType",
        "pattern": "(?i)\\b(BIGINT|BINARY|BIT|BLOB|BOOLEAN|CHAR|CHARACTER|CLOB|DATE|DATETIME|DECIMAL|DOUBLE|FLOAT|INT|INTEGER|LONGBLOB|LONGTEXT|MEDIUMBLOB|MEDIUMINT|MEDIUMTEXT|MONEY|NCHAR|NTEXT|NUMERIC|NVARCHAR|REAL|SMALLDATETIME|SMALLINT|SMALLMONEY|TEXT|TIME|TIMESTAMP|TINYINT|TINYTEXT|UNIQUEIDENTIFIER|VARBINARY|VARCHAR|XML|JSON|JSONB|UUID|SERIAL|BYTEA)\\b",
        "colorKey": "TE_Directive"
      },
      {
        "type": "Number",
        "pattern": "\\b(0x[0-9A-Fa-f]+|[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?)\\b",
        "colorKey": "TE_Number"
      },
      {
        "type": "String",
        "pattern": "(N?'(?:[^'\\\\]|\\\\.)*'|N?\"(?:[^\"\\\\]|\\\\.)*\")",
        "colorKey": "TE_String"
      },
      {
        "type": "Comment",
        "pattern": "--.*$",
        "colorKey": "TE_Comment"
      },
      {
        "type": "BlockComment",
        "pattern": "/\\*[\\s\\S]*?\\*/",
        "colorKey": "TE_Comment"
      }
    ],
    "foldingRules": {
      "startPatterns": [
        "\\bBEGIN\\b"
      ],
      "endPatterns": [
        "\\bEND\\b"
      ]
    },
    "columnRulers": [
      120
    ],
    "formattingRules": {
      "indentSize": 4,
      "useTabs": false,
      "trimTrailingWhitespace": true,
      "insertFinalNewline": true,
      "lineEnding": "lf",
      "spaceAfterKeywords": true,
      "spaceInsideParens": false,
      "maxConsecutiveBlankLines": 2,
      "blankLineBeforeMethod": false,
      "blankLineAfterImports": false,
      "spaceAroundBinaryOperators": true,
      "spaceAfterComma": true,
      "organizeImports": false,
      "separateSystemImports": false,
      "maxLineLength": 80,
      "sqlKeywordsUppercase": true
    },
    "previewSnippet": "select id,name,email\nfrom users\nwhere id>0\norder by name",
    "previewSamples": {
      "sqlKeywordsUppercase": {
        "before": "select id from users where id>0",
        "after": "SELECT id FROM users WHERE id > 0"
      },
      "spaceAfterKeywords": {
        "before": "WHERE(id>0)",
        "after": "WHERE (id > 0)"
      },
      "spaceAroundBinaryOperators": {
        "before": "id>0",
        "after": "id > 0"
      },
      "spaceAfterComma": {
        "before": "id,name,email",
        "after": "id, name, email"
      },
      "trimTrailingWhitespace": {
        "before": "SELECT id   ",
        "after": "SELECT id"
      },
      "insertFinalNewline": {
        "before": "ORDER BY name",
        "after": "ORDER BY name\n"
      }
    },
    "bracketPairs": [
      {
        "open": "(",
        "close": ")"
      },
      {
        "open": "[",
        "close": "]"
      }
    ],
    "breakpointRules": {
      "nonExecutablePatterns": [
        "^\\s*--",
        "^\\s*/\\*",
        "^\\s*$"
      ],
      "statementContinuationPatterns": [
        ",\\s*$",
        "\\bAND\\s*$",
        "\\bOR\\s*$"
      ]
    },
    "ideMetadata": {
      "isSourceFile": true,
      "aliases": [
        "sql"
      ],
      "iconGlyph": "",
      "diffMode": "text"
    }
  },
  "forensic": {
    "category": "other",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Structured Query Language source files for databases.",
    "suggestedInspections": [
      "Verify SQL Source File file signature and header structure",
      "Check data integrity and field boundaries",
      "Inspect metadata and version information"
    ]
  }
}

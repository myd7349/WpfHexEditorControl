/*
   ============================================================
   Format:    JavaScript Source File
   Category:  Programming
   Ext:       .js, .mjs, .cjs, .jsx
   Editor:    code-editor
   Desc:      JavaScript programming language source file (ECMAScript).
   Updated:   2026-04-04
   ============================================================
*/
{
  "diffMode": "text",
  "formatName": "JavaScript Source File",
  "version": "2.1",
  "extensions": [
    ".js",
    ".mjs",
    ".cjs",
    ".jsx"
  ],
  "description": "JavaScript programming language source file (ECMAScript).",
  "category": "Programming",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "code-editor",
  "detection": {
    "isTextFormat": true,
    "required": false
  },
  "QualityMetrics": {
    "CompletenessScore": 80,
    "DocumentationLevel": "standard",
    "BlocksDefined": 0,
    "ValidationRules": 0,
    "LastUpdated": "2026-03-22",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "MimeTypes": [
    "text/javascript"
  ],
  "Software": [
    "VS Code",
    "WebStorm",
    "Sublime Text"
  ],
  "UseCases": [
    "Web front-end development",
    "Node.js scripting",
    "React JSX components"
  ],
  "syntaxDefinition": {
    "diagnosticPrefix": "JS",
    "id": "javascript",
    "name": "JavaScript / TypeScript",
    "extensions": [
      ".js",
      ".mjs",
      ".cjs",
      ".ts",
      ".tsx",
      ".jsx"
    ],
    "lineCommentPrefix": "//",
    "blockCommentStart": "/*",
    "blockCommentEnd": "*/",
    "rules": [
      {
        "type": "BlockComment",
        "pattern": "/\\*[\\s\\S]*?\\*/"
      },
      {
        "type": "String",
        "pattern": "(`(?:[^`\\\\]|\\\\.)*`|\"(?:[^\"\\\\]|\\\\.)*\"|'(?:[^'\\\\]|\\\\.)*')"
      },
      {
        "type": "Comment",
        "pattern": "//.*$"
      },
      {
        "type": "Keyword",
        "pattern": "\\b(break|case|catch|class|const|continue|debugger|default|delete|do|else|export|extends|finally|for|function|if|import|in|instanceof|let|new|null|of|return|static|super|switch|this|throw|true|false|try|typeof|undefined|var|void|while|with|yield|async|await|from|as|type|interface|enum|namespace|abstract|declare|implements|module|require|satisfies|keyof|infer|asserts|is|never|unknown|any|readonly|override)\\b"
      },
      {
        "type": "Type",
        "pattern": "\\b(string|number|boolean|object|symbol|bigint|void|null|undefined|Array|Object|Function|Promise|Map|Set|WeakMap|WeakSet|Error|Date|RegExp|JSON|Math|console|window|document|process|Buffer|URL|URLSearchParams|FormData|Headers|Request|Response|fetch|setTimeout|setInterval|clearTimeout|clearInterval|parseInt|parseFloat|isNaN|isFinite|encodeURI|decodeURI)\\b"
      },
      {
        "type": "Decorator",
        "pattern": "@[A-Za-z][A-Za-z0-9_]*"
      },
      {
        "type": "JsxComponentTag",
        "pattern": "</?[A-Z][A-Za-z0-9.]*",
        "colorKey": "TE_Type"
      },
      {
        "type": "JsxBuiltinTag",
        "pattern": "</?(?:a|abbr|address|article|aside|audio|b|blockquote|body|br|button|canvas|caption|cite|code|col|colgroup|data|datalist|dd|del|details|dfn|dialog|div|dl|dt|em|embed|fieldset|figcaption|figure|footer|form|h1|h2|h3|h4|h5|h6|head|header|hgroup|hr|html|i|iframe|img|input|ins|kbd|label|legend|li|link|main|map|mark|menu|meta|meter|nav|noscript|object|ol|optgroup|option|output|p|picture|pre|progress|q|rp|rt|ruby|s|samp|script|section|select|small|source|span|strong|style|sub|summary|sup|table|tbody|td|template|textarea|tfoot|th|thead|time|title|tr|track|u|ul|var|video|wbr)(?=[\\s/>])",
        "colorKey": "TE_Keyword"
      },
      {
        "type": "JsxAttribute",
        "pattern": "\\b[a-zA-Z][a-zA-Z0-9-]*(?=\\s*=\\s*[{\"'])",
        "colorKey": "TE_Label"
      },
      {
        "type": "JsxSpreadAttribute",
        "pattern": "\\{\\.\\.\\.(?:[^}]*)\\}",
        "colorKey": "TE_Directive"
      },
      {
        "type": "Number",
        "pattern": "\\b(0x[0-9A-Fa-f]+n?|0b[01]+n?|0o[0-7]+n?|[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?n?)\\b"
      }
    ],
    "foldingRules": {
      "startPatterns": [
        "\\{",
        "\\(\\s*$",
        "<(?!/)(?!.*/>)[A-Za-z>]"
      ],
      "endPatterns": [
        "\\}",
        "^\\s*\\)",
        "/>",
        "</>",
        "</[A-Za-z]"
      ],
      "endOfBlockHint": {
        "enabled": true,
        "maxContextLines": 3,
        "triggerBrace": true,
        "triggerDirective": false
      }
    },
    "breakpointRules": {
      "nonExecutablePatterns": [
        "^\\s*//",
        "^\\s*/\\*",
        "^\\s*\\*",
        "^\\s*$",
        "^\\s*export\\s+(?:default\\s+)?(?:interface|type|enum)\\b"
      ],
      "statementContinuationPatterns": [
        "[^;{}]\\s*$"
      ]
    },
    "bracketPairs": [
      {
        "open": "(",
        "close": ")"
      },
      {
        "open": "[",
        "close": "]"
      },
      {
        "open": "{",
        "close": "}"
      }
    ],
    "columnRulers": [
      80
    ],
    "formattingRules": {
      "indentSize": 2,
      "useTabs": false,
      "trimTrailingWhitespace": true,
      "insertFinalNewline": true,
      "lineEnding": "lf",
      "braceStyle": "kr",
      "spaceBeforeOpenBrace": true,
      "spaceAfterKeywords": true,
      "spaceInsideParens": false,
      "indentCaseLabels": false,
      "maxConsecutiveBlankLines": 2,
      "blankLineBeforeMethod": true,
      "blankLineAfterImports": true,
      "spaceAroundBinaryOperators": true,
      "spaceAfterComma": true,
      "organizeImports": true,
      "separateSystemImports": false,
      "quoteStyle": "double",
      "trailingCommas": "es5",
      "maxLineLength": 100,
      "importKeywords": [
        "import",
        "require"
      ],
      "methodDeclKeywords": [
        "function",
        "async",
        "class",
        "export"
      ],
      "supportedRules": ["trimTrailingWhitespace", "insertFinalNewline", "spaceAfterKeywords", "spaceAroundBinaryOperators", "spaceAfterComma", "indentCaseLabels", "organizeImports"]
    },
    "colorLiteralPatterns": [
      "#[0-9A-Fa-f]{8}",
      "#[0-9A-Fa-f]{6}",
      "#[0-9A-Fa-f]{3}",
      "rgb\\(\\s*\\d+\\s*,\\s*\\d+\\s*,\\s*\\d+\\s*\\)"
    ],
    "previewSnippet": "import path from 'path';\nimport fs from 'fs';\n\nfunction go(x,y){\nif(x>0){\nswitch(x){\ncase 1:\nreturn;\n}\n}\n}",
    "previewSamples": {
      "spaceAfterKeywords": {
        "before": "if(x>0){",
        "after": "if (x > 0) {"
      },
      "spaceAroundBinaryOperators": {
        "before": "a=b+c*2;",
        "after": "a = b + c * 2;"
      },
      "spaceAfterComma": {
        "before": "go(x,y,z);",
        "after": "go(x, y, z);"
      },
      "organizeImports": {
        "before": "import path from 'path';\nimport fs from 'fs';",
        "after": "import fs from 'fs';\nimport path from 'path';"
      },
      "trimTrailingWhitespace": {
        "before": "let x = 1;   ",
        "after": "let x = 1;"
      },
      "insertFinalNewline": {
        "before": "}",
        "after": "}\n"
      }
    },
    "ideMetadata": {
      "isSourceFile": true,
      "isStructuredDataFile": false,
      "supportsClassDiagram": false,
      "supportsSourceOutline": false,
      "isProjectLanguage": false,
      "languageColor": "#F0DB4F",
      "aliases": [
        "js",
        "jsx"
      ],
      "iconGlyph": "",
      "diffMode": "text"
    }
  },
  "forensic": {
    "category": "other",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "JavaScript programming language source file (ECMAScript).",
    "suggestedInspections": [
      "Verify JavaScript Source File file signature and header structure",
      "Check data integrity and field boundaries",
      "Inspect metadata and version information"
    ]
  }
}

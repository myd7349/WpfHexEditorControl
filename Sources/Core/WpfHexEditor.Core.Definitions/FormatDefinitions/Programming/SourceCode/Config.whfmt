{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Configuration File",
  "formatId": "Config",
  "version": "2.13",
  "extensions": [
    ".ini",
    ".cfg",
    ".conf",
    ".config",
    ".properties",
    ".env",
    ".inf"
  ],
  "description": "Generic configuration and settings files in key-value or INI-style format.",
  "category": "Programming",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "code-editor",
  "detection": {
    "isTextFormat": true,
    "required": false
  },
  "QualityMetrics": {
    "CompletenessScore": 80,
    "DocumentationLevel": "standard",
    "BlocksDefined": 0,
    "ValidationRules": 0,
    "LastUpdated": "2026-03-07",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "MimeTypes": [
    "text/plain"
  ],
  "Software": [
    "Notepad",
    "VS Code"
  ],
  "UseCases": [
    "Application configuration",
    "Environment variables",
    "System settings"
  ],
  "forensic": {
    "category": "other",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Generic configuration and settings files in key-value or INI-style format.",
    "suggestedInspections": [
      "Verify Configuration File file signature and header structure",
      "Check data integrity and field boundaries",
      "Inspect metadata and version information"
    ]
  },
  "syntaxDefinition": {
    "id": "config",
    "name": "Config / INI",
    "extensions": [
      ".ini",
      ".cfg",
      ".conf",
      ".config",
      ".properties",
      ".env",
      ".inf"
    ],
    "lineCommentPrefix": "#",
    "rules": [
      {
        "type": "Comment",
        "pattern": "[#;].*$"
      },
      {
        "type": "Section",
        "pattern": "^\\s*\\[[^\\]]+\\]\\s*$"
      },
      {
        "type": "Key",
        "pattern": "^\\s*[A-Za-z0-9_.\\-]+(?=\\s*[=:])"
      },
      {
        "type": "String",
        "pattern": "(\"(?:[^\"\\]|\\.)*\"|'[^']*')"
      },
      {
        "type": "Number",
        "pattern": "\b(0x[0-9A-Fa-f]+|[0-9]+(?:\\.[0-9]+)?)\b"
      },
      {
        "type": "Keyword",
        "pattern": "\b(?i)(true|false|yes|no|on|off|null|none)\b"
      }
    ],
    "formattingRules": {
      "indentSize": 4,
      "useTabs": false,
      "trimTrailingWhitespace": true,
      "insertFinalNewline": true
    },
    "foldingRules": {
      "startPatterns": [
        "^\\s*\\["
      ],
      "endPatterns": [
        "^\\s*\\["
      ]
    },
    "ideMetadata": {
      "isSourceFile": false,
      "isStructuredDataFile": true,
      "supportsClassDiagram": false,
      "supportsSourceOutline": false,
      "isProjectLanguage": false,
      "aliases": [
        "ini",
        "properties",
        "dotenv"
      ],
      "iconGlyph": "",
      "diffMode": "text"
    }
  }
}



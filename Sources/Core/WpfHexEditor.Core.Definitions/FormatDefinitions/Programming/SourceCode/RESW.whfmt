{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Windows Store Resource File",
  "formatId": "RESW",
  "version": "2.13",
  "extensions": [
    ".resw"
  ],
  "description": "Windows Store app resource file using the same XML schema as .resx, used for UWP and WinUI 3 app localization.",
  "category": "Programming/SourceCode",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "resx-editor",
  "detection": {
    "isTextFormat": true,
    "required": false
  },
  "QualityMetrics": {
    "CompletenessScore": 90,
    "DocumentationLevel": "standard",
    "BlocksDefined": 0,
    "ValidationRules": 0,
    "LastUpdated": "2026-03-23",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "MimeTypes": [
    "text/xml",
    "application/xml"
  ],
  "Software": [
    "Visual Studio",
    "Rider",
    "WinUI 3",
    "UWP"
  ],
  "UseCases": [
    "UWP app localization",
    "WinUI 3 resource management",
    "Windows Store app strings"
  ],
  "forensic": {
    "category": "other",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Windows Store app resource file using the same XML schema as .resx, used for UWP and WinUI 3 app localizatio...",
    "suggestedInspections": [
      "Verify Windows Store Resource File file signature and header structure",
      "Check data integrity and field boundaries",
      "Inspect metadata and version information"
    ]
  },
  "syntaxDefinition": {
    "id": "resw",
    "name": "RESW (WinUI Resource)",
    "extensions": [
      ".resw"
    ],
    "blockCommentStart": "<!--",
    "blockCommentEnd": "-->",
    "rules": [
      {
        "type": "Comment",
        "pattern": "<!--[\\s\\S]*?-->"
      },
      {
        "type": "Tag",
        "pattern": "</?[A-Za-z][A-Za-z0-9:_.-]*(?:\\s[^>]*)?>"
      },
      {
        "type": "Attribute",
        "pattern": "\b[A-Za-z][A-Za-z0-9:_.-]*(?=\\s*=)"
      },
      {
        "type": "String",
        "pattern": "(\"[^\"]*\"|'[^']*')"
      },
      {
        "type": "CDataSection",
        "pattern": "<!\\[CDATA\\[[\\s\\S]*?\\]\\]>"
      },
      {
        "type": "Keyword",
        "pattern": "\b(name|value|comment|xml:space|xml:lang)\b"
      }
    ],
    "formattingRules": {
      "indentSize": 2,
      "useTabs": false,
      "trimTrailingWhitespace": true,
      "insertFinalNewline": true
    },
    "foldingRules": {
      "startPatterns": [
        "<(?!/)(?!\\?)[A-Za-z]"
      ],
      "endPatterns": [
        "</[A-Za-z]",
        "/>"
      ]
    },
    "ideMetadata": {
      "isSourceFile": false,
      "isStructuredDataFile": true,
      "supportsClassDiagram": false,
      "supportsSourceOutline": false,
      "isProjectLanguage": false,
      "aliases": [
        "winui-resource"
      ],
      "iconGlyph": "",
      "diffMode": "semantic"
    }
  }
}



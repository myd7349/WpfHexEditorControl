/*
   ============================================================
   Format:    Rust Source File
   Category:  Programming
   Ext:       .rs
   Editor:    code-editor
   Desc:      Rust programming language source file.
   Updated:   2026-04-04
   ============================================================
*/
{
  "diffMode": "text",
  "formatName": "Rust Source File",
  "version": "2.1",
  "extensions": [
    ".rs"
  ],
  "description": "Rust programming language source file.",
  "category": "Programming",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "code-editor",
  "detection": {
    "isTextFormat": true,
    "required": false
  },
  "QualityMetrics": {
    "CompletenessScore": 80,
    "DocumentationLevel": "standard",
    "BlocksDefined": 0,
    "ValidationRules": 0,
    "LastUpdated": "2026-03-22",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "MimeTypes": [
    "text/x-rustsrc"
  ],
  "Software": [
    "VS Code",
    "CLion",
    "RustRover"
  ],
  "UseCases": [
    "Systems programming",
    "WebAssembly",
    "Embedded development"
  ],
  "syntaxDefinition": {
    "diagnosticPrefix": "RS",
    "id": "rust",
    "name": "Rust",
    "extensions": [
      ".rs"
    ],
    "lineCommentPrefix": "//",
    "blockCommentStart": "/*",
    "blockCommentEnd": "*/",
    "rules": [
      {
        "type": "BlockComment",
        "pattern": "/\\*[\\s\\S]*?\\*/",
        "colorKey": "TE_Comment"
      },
      {
        "type": "String",
        "pattern": "(r#*\"[\\s\\S]*?\"#*|b?\"(?:[^\"\\\\]|\\\\.)*\"|b?'(?:[^'\\\\]|\\\\.)*')",
        "colorKey": "TE_String"
      },
      {
        "type": "Comment",
        "pattern": "//.*$",
        "colorKey": "TE_Comment"
      },
      {
        "type": "Keyword",
        "pattern": "\\b(as|async|await|break|const|continue|crate|dyn|else|enum|extern|false|fn|for|if|impl|in|let|loop|match|mod|move|mut|pub|ref|return|self|Self|static|struct|super|trait|true|type|unsafe|use|where|while|abstract|become|box|do|final|macro|override|priv|try|typeof|unsized|virtual|yield)\\b",
        "colorKey": "TE_Keyword"
      },
      {
        "type": "Type",
        "pattern": "\\b(bool|char|f32|f64|i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|str|String|Vec|Box|Option|Result|HashMap|HashSet|BTreeMap|BTreeSet|Rc|Arc|Cell|RefCell|Mutex|RwLock|Cow)\\b",
        "colorKey": "TE_Type"
      },
      {
        "type": "Macro",
        "pattern": "\\b[a-z_][a-z0-9_]*!",
        "colorKey": "TE_Directive"
      },
      {
        "type": "Attribute",
        "pattern": "#!?\\[.*?\\]",
        "colorKey": "TE_Directive"
      },
      {
        "type": "Lifetime",
        "pattern": "'[a-zA-Z_][a-zA-Z0-9_]*\\b",
        "colorKey": "TE_Label"
      },
      {
        "type": "Number",
        "pattern": "\\b(0x[0-9A-Fa-f_]+[uif]?(?:8|16|32|64|128|size)?|0b[01_]+[uif]?(?:8|16|32|64|128|size)?|0o[0-7_]+[uif]?(?:8|16|32|64|128|size)?|[0-9][0-9_]*(?:\\.[0-9_]+)?(?:[eE][+-]?[0-9_]+)?[uif]?(?:8|16|32|64|128|size)?)\\b",
        "colorKey": "TE_Number"
      },
      {
        "type": "MethodCall",
        "pattern": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()",
        "colorKey": "TE_Label"
      }
    ],
    "foldingRules": {
      "startPatterns": [
        "\\{"
      ],
      "endPatterns": [
        "\\}"
      ],
      "endOfBlockHint": {
        "enabled": true,
        "maxContextLines": 3,
        "triggerBrace": true,
        "triggerDirective": false
      }
    },
    "breakpointRules": {
      "nonExecutablePatterns": [
        "^\\s*//",
        "^\\s*/\\*",
        "^\\s*\\*",
        "^\\s*$",
        "^\\s*use\\s",
        "^\\s*mod\\s",
        "^\\s*extern\\s+crate\\b"
      ],
      "statementContinuationPatterns": [
        "[^;{}]\\s*$"
      ]
    },
    "bracketPairs": [
      {
        "open": "(",
        "close": ")"
      },
      {
        "open": "[",
        "close": "]"
      },
      {
        "open": "{",
        "close": "}"
      }
    ],
    "columnRulers": [
      100
    ],
    "formattingRules": {
      "indentSize": 4,
      "useTabs": false,
      "trimTrailingWhitespace": true,
      "insertFinalNewline": true,
      "lineEnding": "lf",
      "braceStyle": "kr",
      "spaceBeforeOpenBrace": true,
      "spaceAfterKeywords": true,
      "spaceInsideParens": false,
      "indentCaseLabels": false,
      "maxConsecutiveBlankLines": 2,
      "blankLineBeforeMethod": true,
      "blankLineAfterImports": true,
      "spaceAroundBinaryOperators": true,
      "spaceAfterComma": true,
      "organizeImports": true,
      "separateSystemImports": false,
      "quoteStyle": "double",
      "maxLineLength": 100,
      "keywordParenKeywords": [
        "if",
        "for",
        "while",
        "match"
      ],
      "importKeywords": [
        "use"
      ],
      "methodDeclKeywords": [
        "pub",
        "fn",
        "async",
        "impl",
        "struct",
        "enum",
        "trait"
      ],
      "supportedRules": ["trimTrailingWhitespace", "insertFinalNewline", "spaceAfterKeywords", "spaceAroundBinaryOperators", "spaceAfterComma", "indentCaseLabels", "organizeImports"]
    },
    "previewSnippet": "use std::io;\nuse std::fs;\n\nfn go(x:i32,y:i32){\nif x>0{\nmatch x{\n1=>return,\n_=>{}\n}\n}\n}",
    "previewSamples": {
      "spaceAfterKeywords": {
        "before": "if x>0{",
        "after": "if x > 0 {"
      },
      "spaceAroundBinaryOperators": {
        "before": "a=b+c*2;",
        "after": "a = b + c * 2;"
      },
      "spaceAfterComma": {
        "before": "go(x,y,z);",
        "after": "go(x, y, z);"
      },
      "organizeImports": {
        "before": "use std::io;\nuse std::fs;",
        "after": "use std::fs;\nuse std::io;"
      },
      "trimTrailingWhitespace": {
        "before": "let x = 1;   ",
        "after": "let x = 1;"
      },
      "insertFinalNewline": {
        "before": "}",
        "after": "}\n"
      }
    },
    "ideMetadata": {
      "isSourceFile": true,
      "aliases": [
        "rs"
      ],
      "iconGlyph": "",
      "diffMode": "semantic"
    }
  },
  "forensic": {
    "category": "other",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Rust programming language source file.",
    "suggestedInspections": [
      "Verify Rust Source File file signature and header structure",
      "Check data integrity and field boundaries",
      "Inspect metadata and version information"
    ]
  }
}

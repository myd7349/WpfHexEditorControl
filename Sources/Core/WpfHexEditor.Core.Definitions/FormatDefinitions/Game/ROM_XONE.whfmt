  "aiHints": {
    "analysisContext": "Xbox One XVD (Xbox Virtual Disk) format",
    "suggestedInspections": [
      "Validate Xbox One Package container magic and version header",
      "Check resource/asset table entries and data block offsets",
      "Inspect compression flags, checksums, and embedded file boundaries"
    ]
  },
  "inspector": {
    "badge": "xvdSignature",
    "primaryField": "contentSize",
    "showQualityScore": true,
    "groups": [
      {
        "title": "Xbox One Package",
        "icon": "",
        "fields": [
          "xvdSignature",
          "formatVersion",
          "flags",
          "contentSize",
          "contentId"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Xbox One Package Header (JSON)",
      "format": "json",
      "fields": [
        "xvdSignature",
        "formatVersion",
        "flags",
        "contentSize"
      ]
    }
  ],
  "assertions": [
    {
      "name": "ROM_XONE valid",
      "expression": "xvdSignature != ''",
      "severity": "warning",
      "message": "XVD signature field empty — may not be valid Xbox One XVD"
    }
  ]

  "aiHints": {
    "analysisContext": "N64 save: no magic. Type by file size: 512=EEPROM 4Kbit (8-byte pages), 2048=EEPROM 16Kbit, 32768=SRAM 256Kbit, 131072=Flash RAM 1Mbit. Byte order: N64 is big-endian MIPS. Emulator byte-order marker possible at offset 0: 0x80371240=Z64, 0x37804012=V64, 0x40123780=LE. Zelda OoT EEPROM 16K: save slots at fixed page offsets.",
    "suggestedInspections": [
      "Check file size to determine storage type: 512=EEPROM 4K (.eep), 2048=EEPROM 16K (.eep), 32768=SRAM (.sra), 131072=Flash (.fla)",
      "Check bytes 0-3 for emulator byte-order header: 0x80371240=Z64 BE, 0x37804012=V64 byteswapped, 0x40123780=LE",
      "For Zelda OoT (EEPROM 16K=2048 bytes): check for 0x00-prefixed page structure with checksum at end of each save slot",
      "For Pokemon Stadium 2 (Flash RAM=131072 bytes): look for save sector headers with game-specific magic patterns"
    ]
  },
  "software": [

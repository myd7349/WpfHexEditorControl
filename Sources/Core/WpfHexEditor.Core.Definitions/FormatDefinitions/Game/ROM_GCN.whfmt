{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Nintendo GameCube Disc",
  "formatId": "ROM_GCN",
  "version": "2.53",
  "extensions": [
    ".gcm",
    ".iso"
  ],
  "description": "Nintendo GameCube disc image format",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "lastUpdated": "2026-05-20",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Yet Another GameCube Documentation (YAGCD)",
      "GameCube Disc Image Format Specification",
      "GCM File Format"
    ],
    "WebLinks": [
      "https://www.gc-forever.com/yagcd/",
      "https://hitmen.c02.at/files/yagcd/yagcd/chap14.html",
      "https://www.retroreversing.com/gamecube-file-formats",
      "https://wit.wiimm.de/info/iso-images.html"
    ]
  },
  "signatures": [
    {
      "value": "C2339F3D",
      "offset": 28,
      "label": "GameCube disc magic word at 0x1C",
      "weight": 1.0,
      "strength": "Strong"
    }
  ],
  "maxSignatureOffset": 32,
  "structure": {
    "fields": [
      { "name": "disc_id",              "type": "ascii",    "offset": "0x00", "length": 1,  "description": "Console ID: G=GameCube, D=Demo, P=Promotional" },
      { "name": "game_code",            "type": "ascii",    "offset": "0x01", "length": 2,  "description": "Unique 2-char game identifier" },
      { "name": "country_code",         "type": "ascii",    "offset": "0x03", "length": 1,  "description": "Region: E=USA, P=Europe, J=Japan, K=Korea" },
      { "name": "maker_code",           "type": "ascii",    "offset": "0x04", "length": 2,  "description": "Publisher code: 01=Nintendo, 08=Capcom" },
      { "name": "disc_number",          "type": "uint8",    "offset": "0x06", "length": 1,  "description": "Disc number (0 for single-disc games)" },
      { "name": "disc_version",         "type": "uint8",    "offset": "0x07", "length": 1,  "description": "Game version/revision number" },
      { "name": "audio_streaming",      "type": "uint8",    "offset": "0x08", "length": 1,  "description": "0=No audio streaming, 1=Enabled" },
      { "name": "streaming_buf_size",   "type": "uint8",    "offset": "0x09", "length": 1,  "description": "Audio stream buffer size" },
      { "name": "magic",                "type": "uint32be", "offset": "0x1C", "length": 4,  "description": "GCN magic word: 0xC2339F3D" },
      { "name": "game_title",           "type": "ascii",    "offset": "0x20", "length": 64, "description": "Game title, null-terminated ASCII" }
    ]
  },
  "inspector": {
    "displayFields": ["disc_id", "game_code", "country_code", "maker_code", "disc_number", "disc_version"],
    "valueMaps": {
      "disc_id": {
        "G": "GameCube retail",
        "D": "Demo disc",
        "P": "Promotional disc",
        "R": "GameCube (alternate)"
      },
      "country_code": {
        "E": "USA (NTSC-U)",
        "J": "Japan (NTSC-J)",
        "P": "Europe/Australia (PAL)",
        "K": "Korea"
      }
    },
    "tooltips": {
      "magic": "0xC2339F3D at 0x1C uniquely identifies a GCN disc; Wii uses 0x5D1C9EA3 at the same offset",
      "maker_code": "01=Nintendo, 08=Capcom, 0Q=THQ, 4F=Eidos, 52=Activision",
      "disc_number": "Multi-disc games increment this; most games use 0"
    }
  },
  "assertions": [
    {
      "name": "GCN magic present",
      "expression": "bytes[0x1C..0x1F] == C2339F3D",
      "severity": "error",
      "message": "GameCube magic word 0xC2339F3D not found at offset 0x1C; not a valid GCN disc image"
    },
    {
      "name": "Disc ID is valid console marker",
      "expression": "disc_id == 'G' || disc_id == 'D' || disc_id == 'P'",
      "severity": "warning",
      "message": "Disc ID does not match expected GameCube console codes (G/D/P)"
    },
    {
      "name": "Country code is known",
      "expression": "country_code == 'E' || country_code == 'J' || country_code == 'P' || country_code == 'K'",
      "severity": "warning",
      "message": "Country code is not a standard GameCube region identifier"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "Disc ID",        "offset": 0,  "icon": "", "color": "#FFE66D" },
      { "name": "Game Code",      "offset": 1,  "icon": "", "color": "#FFE66D" },
      { "name": "Maker Code",     "offset": 4,  "icon": "", "color": "#C7CEEA" },
      { "name": "GCN Magic",      "offset": 28, "icon": "", "color": "#FF6B6B" },
      { "name": "Game Title",     "offset": 32, "icon": "", "color": "#4ECDC4" }
    ]
  },
  "exportTemplates": [
    {
      "name": "GCN Disc Header (JSON)",
      "format": "json",
      "fields": ["disc_id", "game_code", "country_code", "maker_code", "disc_version", "game_title"]
    },
    {
      "name": "GCN Disc Header (C struct)",
      "format": "c-struct",
      "structName": "GCN_DISC_HEADER",
      "fields": ["disc_id", "game_code", "country_code", "maker_code", "disc_number", "disc_version"]
    }
  ],
  "aiHints": [
    "Magic 0xC2339F3D at offset 0x1C is the definitive GameCube identifier; Wii disc uses 0x5D1C9EA3 at the same location",
    "The 6-char game code (disc_id + game_code + country_code + maker_code) uniquely identifies the title and region",
    "FST (File System Table) is located at the offset stored at 0x0424; boot.bin is at 0x2440",
    "Disc image size is either 1.35 GB (single layer) or 2.7 GB (dual layer GameCube media)",
    "Audio streaming flag at 0x08 and buffer size at 0x09 affect music playback performance"
  ],
  "variables": {
    "currentOffset": 0,
    "gameCode": "",
    "makerCode": "",
    "gameName": "",
    "fileCount": 0,
    "version": "",
    "indexOffset": 0,
    "discId": 0,
    "regionCode": 0,
    "discId6": 0,
    "audioStreaming": 0,
    "streamBufferSize": 0,
    "magicWord": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "Disc ID",
      "offset": 0,
      "length": 1,
      "color": "#FFE66D",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Console ID: G=GameCube, D=Demo disc, P=Promotional disc",
      "storeAs": "discId"
    },
    {
      "type": "field",
      "name": "Game Code",
      "offset": 1,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.3,
      "valueType": "ascii",
      "storeAs": "gameCode",
      "description": "Unique 2-character game identifier"
    },
    {
      "type": "field",
      "name": "Region Code",
      "offset": 3,
      "length": 1,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Region: E=USA, P=Europe/Australia, J=Japan, K=Korea",
      "storeAs": "regionCode"
    },
    {
      "type": "field",
      "name": "Maker Code",
      "offset": 4,
      "length": 2,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "ascii",
      "storeAs": "makerCode",
      "description": "Publisher code: 01=Nintendo, 08=Capcom, etc."
    },
    {
      "type": "field",
      "name": "Disc Number",
      "offset": 6,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Disc number (0 for single disc games)",
      "storeAs": "discId6"
    },
    {
      "type": "field",
      "name": "Version",
      "offset": 7,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Game version/revision number",
      "storeAs": "version"
    },
    {
      "type": "field",
      "name": "Audio Streaming",
      "offset": 8,
      "length": 1,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "0=No audio streaming, 1=Audio streaming enabled",
      "storeAs": "audioStreaming"
    },
    {
      "type": "field",
      "name": "Stream Buffer Size",
      "offset": 9,
      "length": 1,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Audio stream buffer size",
      "storeAs": "streamBufferSize"
    },
    {
      "type": "field",
      "name": "Reserved",
      "offset": 10,
      "length": 18,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "bytes",
      "hidden": true,
      "description": "Reserved/padding"
    },
    {
      "type": "signature",
      "name": "Magic Word",
      "offset": 28,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "GameCube disc magic: 0xC2339F3D",
      "storeAs": "magicWord",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Game Name",
      "offset": 32,
      "length": 992,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "ascii",
      "storeAs": "gameName",
      "description": "Game title (ASCII, null-terminated, max 992 bytes)"
    },
    {
      "type": "metadata",
      "name": "File Count",
      "variable": "fileCount",
      "description": "File Count"
    },
    {
      "type": "metadata",
      "name": "Version",
      "variable": "version",
      "description": "Version"
    },
    {
      "type": "metadata",
      "name": "Index Offset",
      "variable": "indexOffset",
      "description": "Index Offset"
    }
  ],
  "software": [
    "Dolphin Emulator",
    "Nintendont",
    "WIT (Wiimm ISO Tools)",
    "GCTool"
  ],
  "formatRelationships": [
    {
      "formatId": "ROM_WII",
      "relation": "predecessor",
      "note": "Wii discs extend the GCN format; Dolphin handles both; magic differs (0x5D1C9EA3 for Wii)"
    }
  ],
  "useCases": [
    "GameCube game preservation and archiving",
    "Disc image backup and restoration",
    "File extraction from FST for modding",
    "Emulation accuracy testing with Dolphin"
  ],
  "technicalDetails": "GameCube disc images are 1.35 GB GCM/ISO files. The disc header occupies the first 0x440 bytes. Boot files (boot.bin, bi2.bin, apploader.img) reside at fixed offsets. FST at offset stored in 0x0424 describes the file tree. GCN uses a 24-bit addressing scheme with an address shift of 2 (all offsets in the FST are multiplied by 4).",
  "completenessScore": 88,
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Emulator",
    "ROM Manager",
    "RetroArch",
    "Hex Editor",
    "Game Debugger"
  ],
  "UseCases": [
    "Gaming",
    "ROM hacking",
    "Emulation",
    "Preservation"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 14,
    "ValidationRules": 0,
    "LastUpdated": "2026-05-20",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {
    "Platform": "GameCube"
  },
  "functions": {
    "readUInt32LE": "Read game header",
    "extractASCIIString": "Read file list"
  },
  "forensic": {
    "riskLevel": "low",
    "notes": [
      "Missing or wrong magic at 0x1C is the most common indicator of a corrupt or improperly trimmed image",
      "Verify the boot.bin hash to detect tampered or region-converted disc images",
      "Non-Nintendo maker codes may indicate unlicensed or homebrew disc images"
    ]
  },
  "diff": {
    "keyFields": ["game_code", "country_code", "disc_version", "magic_word"],
    "ignoreFields": [],
    "note": "Inferred semantic diff for ROM_GCN. Compare key structural fields; ignore volatile metadata."
  },
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "magic_word",
        "mutation": "corrupt_signature",
        "description": "Corrupt magic bytes at offset 28 — parser must reject."
      },
      {
        "field": "stream_buffer_size",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      }
    ],
    "note": "Inferred fuzz strategies for ROM_GCN. Hand-tune weights/rates per format if needed."
  }
}




    }
  ],
  "forensic": {
    "category": "game",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "PC Engine / TurboGrafx-16 HuCard ROM. No standard magic. Copier-headered dumps start with 0x40 0x00 0x00 0x00 (512-byte copier header follows). Headerless dumps begin directly with HuC6280 CPU opcodes. ROM is banked in 8 KB pages via the MPR register. Sizes: 512 KB to 2.5 MB.",
    "suggestedInspections": [
      "Check bytes 0-3 for copier header magic 0x40 0x00 0x00 0x00 — if present, real ROM starts at offset 512",
      "Inspect first opcode: SEI (0x78), CLD (0xD8), or JMP (0x4C) indicate valid CPU code entry point",
      "Verify file size is a power-of-2 multiple of 8 KB (typical HuCard bank granularity)",
      "For CD-ROM images confirm 2048-byte sector alignment and look for ISO 9660 structures"
    ]
  },
  "software": [
    "Mednafen (multi-system emulator with accurate PCE core)",
    "RetroArch with Beetle PCE core",
    "Ootake (Windows PCE emulator)",
    "MagicEngine (commercial PCE emulator)"
  ],
  "formatRelationships": {
    "category": "Game",
    "extensions": [".pce"],
    "relatedFormats": ["ROM_SMS", "ROM_GEN"],
    "note": "PC Engine shares the NEC/Hudson Soft lineage. SuperGrafx (.sgx) is an enhanced PCE variant. CD-ROM games use ISO 9660 sectors but contain HuC6280 code."
  },
  "MimeTypes": ["application/octet-stream"],

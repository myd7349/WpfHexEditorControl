{
  "diffMode": "binary",
  "formatName": "PC Engine / TurboGrafx-16 ROM",
  "version": "1.0",
  "extensions": [".pce"],
  "description": "PC Engine (Japan) / TurboGrafx-16 (US) cartridge ROM (NEC/Hudson Soft, 1987). No fixed magic — raw binary HuC6280 CPU code. Some dumps include a 512-byte copier header with magic 0x40 0x00 0x00 0x00 at offset 0. Header-less ROMs begin directly with CPU code. ROM sizes range from 512 KB (Hu-card) to 2.5 MB (Super CD-ROM). Sector 0 of CD-ROM images: first 2048 bytes. Detection is primarily extension-based. Common first opcode: SEI (0x78), CLD, or JMP absolute (0x4C) for the reset vector.",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "HuCard ROM Cartridge Specification",
      "PC Engine Architecture Documentation",
      "HuC6280 CPU Reference Manual"
    ],
    "WebLinks": [
      "https://www.copetti.org/writings/consoles/pc-engine/",
      "https://en.wikipedia.org/wiki/HuCard",
      "https://wiki.batocera.org/systems:pcengine",
      "https://pcedev.blockos.org/"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "40000000",
        "offset": 0,
        "label": "PC Engine copier header magic at offset 0 (0x40 0x00 0x00 0x00)",
        "weight": 0.5
      },
      {
        "value": "78",
        "offset": 0,
        "label": "0x78 SEI — common first opcode in PC Engine ROMs without copier header",
        "weight": 0.2
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.1,
    "required": false,
    "Strength": "Weak",
    "validation": {
      "minFileSize": 512,
      "maxSignatureOffset": 4,
      "note": "PCE ROMs have no guaranteed magic. Detection is primarily extension-based (.pce). Copier-headered dumps start with 0x40 0x00 0x00 0x00; raw dumps begin with CPU opcodes."
    }
  },
  "variables": {
    "firstByte": 0,
    "secondByte": 0,
    "copierMagic": "",
    "romBank0": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "First Byte",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "valueType": "uint8",
      "description": "First byte of the PC Engine ROM image. For copier-headered dumps this is 0x40; for raw cartridge images this is typically a 6502-family opcode such as SEI (0x78) or JMP (0x4C) targeting the reset vector entry point.",
      "storeAs": "firstByte"
    },
    {
      "type": "field",
      "name": "Second Byte",
      "offset": 1,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Second byte of the ROM image. Together with the first byte this helps identify whether a 512-byte copier header (0x40 0x00 ...) is present or whether the image is a headerless HuCard dump beginning with CPU code.",
      "storeAs": "secondByte"
    },
    {
      "type": "field",
      "name": "Copier Header Magic",
      "offset": 0,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "valueType": "bytes",
      "description": "4-byte copier header magic (0x40 0x00 0x00 0x00) present on ROMs dumped with a PC Engine copier device. If these bytes are not present the dump is headerless and CPU code starts at offset 0.",
      "storeAs": "copierMagic"
    },
    {
      "type": "field",
      "name": "ROM Bank 0",
      "offset": 0,
      "length": 8192,
      "color": "#95E1D3",
      "opacity": 0.3,
      "valueType": "ascii",
      "description": "First 8 KB bank of the PC Engine ROM cartridge. HuCard ROMs are banked in 8 KB pages mapped into the HuC6280 address space via the Memory-Paging Register (MPR). Bank 0 typically contains the reset vector and initial game code.",
      "storeAs": "romBank0"
    },
    {
      "type": "metadata",
      "name": "First Byte",
      "variable": "firstByte",
      "description": "First byte of the ROM image (opcode or copier magic)"
    },
    {
      "type": "metadata",
      "name": "ROM Bank 0",
      "variable": "romBank0",
      "description": "First 8 KB ROM bank"
    }
  ],
  "assertions": [
    {
      "name": "Minimum ROM size",
      "expression": "fileSize >= 512",
      "severity": "warning",
      "message": "PC Engine ROMs should be at least 512 bytes (smallest valid HuCard image)"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "ROM Start / Copier Header", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "ROM Bank 0", "offset": 0, "icon": "\uE71B", "color": "#95E1D3" }
    ]
  },
  "inspector": {
    "badge": "firstByte",
    "primaryField": "romBank0",
    "showQualityScore": true,
    "groups": [
      {
        "title": "PC Engine ROM Header",

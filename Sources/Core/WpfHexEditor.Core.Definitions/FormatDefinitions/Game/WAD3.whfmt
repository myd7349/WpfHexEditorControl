  "TechnicalDetails": {
    "Format": "Binary little-endian Half-Life WAD3 texture archive (GoldSrc)",
    "Magic": "'WAD3' ASCII at offset 0",
    "Header": "12 bytes: magic(4B) + numLumps(4B LE) + dirOffset(4B LE)",
    "DirEntry": "32 bytes: offset(4B) + diskSize(4B) + size(4B) + type(1B) + compr(1B) + pad(2B) + name(16B)",

{
  "diffMode": "binary",
  "formatName": "UPS ROM Patch",
  "version": "1.14",
  "extensions": [
    ".ups"
  ],
  "description": "UPS (Universal Patching System) is a ROM patch format created by byuu/Near as a bidirectional improvement over IPS. UPS files start with 4 ASCII bytes 'UPS1' (55 50 53 31). The format uses Variable-Length Integer (VLI) encoding: inputSize (VLI), outputSize (VLI) encoded after the magic. Patch data consists of XOR-encoded delta records: each record begins with a VLI offset (relative to current position), then XOR data bytes terminated by a 0x00 byte. Bidirectionality: applying a UPS patch to the target produces the source, and applying to the source produces the target. The file ends with three CRC32 checksums (uint32 LE): inputCRC32, outputCRC32, patchCRC32. The patchCRC32 covers all bytes of the file except the last 4 bytes. UPS was superseded by BPS (Beat Patching System) which adds more delta command types.",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "UPS specification by byuu/Near"
    ],
    "WebLinks": [
      "https://www.romhacking.net/utilities/519/",
      "https://github.com/btimofeev/UniPatcher/wiki/UPS"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "55505331", "offset": 0, "label": "'UPS1' — Universal Patching System v1 magic", "weight": 1.0 }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 3.0, "max": 7.0 },
    "validation": {
      "minFileSize": 16,
      "maxSignatureOffset": 0,
      "note": "UPS files always start with 'UPS1' ASCII (4 bytes). The file ends with 3 CRC32 values (12 bytes): input CRC, output CRC, patch CRC."
    }
  },
  "variables": {
    "upsMagic": "",
    "upsInputSizeByte": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "UPS Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "UPS patch file magic: 4 ASCII bytes 'UPS1' (0x55 0x50 0x53 0x31). Created by byuu/Near. UPS (Universal Patching System) improves on IPS by: (1) bidirectional patching — applying to either source or target reconstructs the other; (2) VLI encoding (no 16MB limit); (3) CRC32 validation of input, output, and patch files; (4) XOR-based delta encoding for small changes in large ROMs. Used for SNES, GBA, NDS ROM hacking.",
      "storeAs": "upsMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Input Size (VLI first byte)",
      "offset": 4,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "First byte of the VLI-encoded input (source) ROM file size at offset 4. UPS uses Variable-Length Integers: bit 0 is the continuation flag (1=more bytes), bits 1-7 are data bits. Accumulate 7-bit groups LSB first. The input CRC32 at file end validates this against the actual source ROM file before patching.",
      "storeAs": "upsInputSizeByte",
      "valueType": "uint8"
    },
    {
      "type": "metadata",
      "name": "Magic",
      "variable": "upsMagic",
      "description": "'UPS1' — Universal Patching System identifier"
    },
    {
      "type": "metadata",
      "name": "Input Size (first VLI byte)",
      "variable": "upsInputSizeByte",
      "description": "First byte of VLI-encoded input file size"
    }
  ],
  "assertions": [
    {
      "name": "UPS magic valid",
      "expression": "upsMagic == 'UPS1'",
      "severity": "error",
      "message": "UPS patch must start with 'UPS1' magic — not a valid Universal Patching System patch"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "UPS Header", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "VLI Header Data", "offset": 4, "icon": "\uE71B", "color": "#4ECDC4" }
    ]
  },
  "inspector": {
    "badge": "upsMagic",
    "primaryField": "upsInputSizeByte",
    "showQualityScore": true,
    "groups": [
      {
        "title": "UPS Patch Header",
        "icon": "\uE71B",
        "fields": ["upsMagic", "upsInputSizeByte"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "UPS Header (JSON)",
      "format": "json",
      "fields": ["upsMagic", "upsInputSizeByte"]
    }
  ],
  "forensic": { "category": "game", "riskLevel": "low", "suspiciousPatterns": [] },
  "aiHints": {
    "analysisContext": "UPS format: 'UPS1'(4B) + inputSize(VLI) + outputSize(VLI) + patchData(XOR delta records) + inputCRC32(4B LE) + outputCRC32(4B LE) + patchCRC32(4B LE). VLI: bit0=continuation, bits1-7=data LSB first. Delta records: VLI relative offset + XOR bytes + 0x00 terminator. Bidirectional: patch(source)=target and patch(target)=source. File ends with 3x uint32 LE CRC32. Tool: beat, Floating IPS, UniPatcher.",
    "suggestedInspections": [
      "Bytes 0-3 (ASCII): 'UPS1' — Universal Patching System magic",
      "Bytes 4+: VLI-encoded input size, then output size",
      "Last 12 bytes (3x uint32 LE): input CRC32, output CRC32, patch CRC32",
      "Verify input CRC32 against your ROM before applying patch"
    ]
  },
  "software": [
    "beat (byuu/Near, reference patcher for UPS and BPS)",
    "Floating IPS / flips (supports UPS and IPS)",
    "UniPatcher (Android, supports UPS)",
    "ups-patcher (standalone UPS tool)"
  ],
  "formatRelationships": {
    "category": "Game",
    "extensions": [".ups"],
    "relatedFormats": ["PATCH_IPS", "PATCH_BPS"],
    "note": "UPS is a bidirectional ROM patch format: applying to source gives target, applying to target gives source. Superseded by BPS which adds SourceCopy/TargetCopy delta commands. Both UPS and BPS include CRC32 checksums; IPS does not."
  },
  "MimeTypes": ["application/octet-stream"],
  "UseCases": [
    "Applying bidirectional ROM patches with CRC32 validation",
    "Legacy ROM hacking patch distribution (pre-BPS era)",
    "SNES/GBA/NDS translation patch distribution",
    "ROM patching without the 16MB address limit of IPS"
  ],
  "QualityMetrics": {

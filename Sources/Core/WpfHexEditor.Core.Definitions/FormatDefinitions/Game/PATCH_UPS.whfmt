    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Format": "Binary UPS v1 ROM patch (Universal Patching System by byuu/Near)",
    "Magic": "'UPS1' ASCII at offset 0",
    "VLI": "Variable-Length Integer: bit0=continuation, bits1-7=7-bit data chunks (same as BPS)",
    "Delta": "XOR-encoded byte runs: VLI relative offset + XOR bytes + 0x00 terminator",
    "Checksums": "Three CRC32 LE at EOF: input, output, patch",
    "Bidirectional": "patch(source)=target; patch(target)=source"
  }

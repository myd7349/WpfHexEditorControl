{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "PlayStation 4 Package",
  "formatId": "ROM_PS4",
  "version": "2.43",
  "extensions": [
    ".pkg"
  ],
  "description": "PlayStation 4 PKG package format (encrypted game/update packages)",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "lastUpdated": "2026-05-20",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "PlayStation 4 PKG Package Format Specification",
      "OrbisOS PKG/PFS Structure",
      "LibOrbisPkg - PS4 PKG/SFO/PFS Library"
    ],
    "WebLinks": [
      "https://www.psdevwiki.com/ps4/PKG_files",
      "https://github.com/maxton/LibOrbisPkg",
      "https://github.com/pearlxcore/PS4-PKG-Tool",
      "https://www.psxhax.com/threads/ps4-pkg-information-on-playstation-4-packages-and-keys-via-maxton.7280/"
    ]
  },
  "signatures": [
    {
      "value": "7F434E54",
      "offset": 0,
      "label": "PS4 PKG magic \\x7FCNT",
      "weight": 1.0,
      "strength": "Strong"
    }
  ],
  "maxSignatureOffset": 4,
  "structure": {
    "fields": [
      { "name": "magic",                  "type": "uint32be", "offset": "0x00", "length": 4, "description": "CNT magic 0x7F434E54 (\\x7FCNT)" },
      { "name": "pkg_type",               "type": "uint32be", "offset": "0x04", "length": 4, "description": "Package type flags (PS4-specific)" },
      { "name": "pkg_file_count",         "type": "uint32be", "offset": "0x08", "length": 4, "description": "Number of files in the package" },
      { "name": "entry_count",            "type": "uint16be", "offset": "0x0C", "length": 2, "description": "Number of entry table entries" },
      { "name": "sc_entry_count",         "type": "uint16be", "offset": "0x0E", "length": 2, "description": "Number of SC entry table entries" },
      { "name": "entry_count2",           "type": "uint16be", "offset": "0x10", "length": 2, "description": "Secondary entry count" },
      { "name": "entry_table_offset",     "type": "uint32be", "offset": "0x12", "length": 4, "description": "Offset to the entry table" },
      { "name": "main_entry_data_size",   "type": "uint32be", "offset": "0x16", "length": 4, "description": "Size of main entry data" },
      { "name": "body_offset",            "type": "uint64be", "offset": "0x18", "length": 8, "description": "Offset to the package body" },
      { "name": "body_size",              "type": "uint64be", "offset": "0x20", "length": 8, "description": "Size of the package body" }
    ]
  },
  "inspector": {
    "displayFields": ["magic", "pkg_type", "pkg_file_count", "entry_count", "body_offset", "body_size"],
    "valueMaps": {
      "pkg_type": {
        "0x1A000000": "PS4 Game (Full)",
        "0x1B000000": "PS4 DLC",
        "0x1C000000": "PS4 License",
        "0x1D000000": "PS4 Patch/Update",
        "0x1E000000": "PS4 Theme"
      }
    },
    "tooltips": {
      "magic": "0x7F434E54 (CNT) is shared with PS5 PKG; pkg_content_type at 0x74 distinguishes PS4 vs PS5",
      "body_offset": "Points to the encrypted PFS image; decryption requires OrbisOS platform keys",
      "pkg_file_count": "Number of files declared in the PKG entry table"
    }
  },
  "assertions": [
    {
      "name": "CNT magic present",
      "expression": "bytes[0..3] == 7F434E54",
      "severity": "error",
      "message": "PS4 CNT magic 0x7F434E54 not found at offset 0; not a valid PS4 PKG file"
    },
    {
      "name": "Body offset within file",
      "expression": "body_offset < body_offset + body_size",
      "severity": "error",
      "message": "Package body size overflow; file is corrupt or truncated"
    },
    {
      "name": "File count positive",
      "expression": "pkg_file_count > 0",
      "severity": "warning",
      "message": "Package file count is zero; this may indicate an empty or invalid package"
    },
    {
      "name": "Entry table offset reasonable",
      "expression": "entry_table_offset >= 32",
      "severity": "warning",
      "message": "Entry table offset is less than 32 bytes; overlaps with PKG header"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "CNT Magic",         "offset": 0,  "icon": "", "color": "#FF6B6B" },
      { "name": "PKG Type",          "offset": 4,  "icon": "", "color": "#FFE66D" },
      { "name": "Entry Table Ptr",   "offset": 18, "icon": "", "color": "#4ECDC4" },
      { "name": "Body Offset",       "offset": 24, "icon": "", "color": "#95E1D3" },
      { "name": "Body Size",         "offset": 32, "icon": "", "color": "#95E1D3" }
    ]
  },
  "exportTemplates": [
    {
      "name": "PS4 PKG Header (JSON)",
      "format": "json",
      "fields": ["magic", "pkg_type", "pkg_file_count", "entry_count", "body_offset", "body_size"]
    },
    {
      "name": "PS4 PKG Header (C struct)",
      "format": "c-struct",
      "structName": "PS4_PKG_HEADER",
      "fields": ["magic", "pkg_type", "pkg_file_count", "body_offset", "body_size"]
    }
  ],
  "aiHints": [
    "Magic 0x7F434E54 ('\\x7FCNT') is shared with PS5 PKG; check pkg_content_type at 0x74 for platform: PS4 values are 0x1A–0x1E",
    "The encrypted PFS (PlayStation File System) image begins at body_offset and contains all game files",
    "Entry table at entry_table_offset lists all files with their offsets, sizes, and encryption info",
    "Content ID at offset 0x47 (36 bytes) follows format: UP####-CUSA#####_00-################",
    "PS4 PKG files use different encryption keys than PS3; requires OrbisOS or fpkg tooling to decrypt"
  ],
  "variables": {
    "currentOffset": 0,
    "crc32Valid": false,
    "originalSize": 0,
    "compressionRatio": 0,
    "cntMagic": "",
    "packageType": "",
    "packageFlags": 0,
    "fileOffset": 0,
    "fileCount": 0,
    "packageSize": 0,
    "contentId": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "CNT Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "valueType": "uint32",
      "description": "PS4 PKG magic: 0x7F 0x43 0x4E 0x54 (CNT)",
      "storeAs": "cntMagic"
    },
    {
      "type": "field",
      "name": "Package Type",
      "offset": 4,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "valueType": "ascii",
      "description": "Package type flags (PS4 specific)",
      "storeAs": "packageType"
    },
    {
      "type": "field",
      "name": "Package Flags",
      "offset": 8,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "valueType": "uint32",
      "description": "Package flags and encryption info",
      "storeAs": "packageFlags"
    },
    {
      "type": "field",
      "name": "File Offset",
      "offset": 12,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "uint32",
      "description": "Offset to file table",
      "storeAs": "fileOffset"
    },
    {
      "type": "field",
      "name": "File Count",
      "offset": 16,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "valueType": "uint32",
      "description": "Number of files in package",
      "storeAs": "fileCount"
    },
    {
      "type": "field",
      "name": "Package Size",
      "offset": 24,
      "length": 8,
      "color": "#95E1D3",
      "opacity": 0.3,
      "valueType": "uint64",
      "description": "Total package size (64-bit big-endian)",
      "storeAs": "packageSize"
    },
    {
      "type": "field",
      "name": "Content ID",
      "offset": 64,
      "length": 36,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "ascii",
      "description": "Content identifier (title ID)",
      "storeAs": "contentId"
    },
    {
      "type": "metadata",
      "name": "CRC Valid",
      "variable": "crc32Valid",
      "description": "CRC Valid"
    },
    {
      "type": "metadata",
      "name": "Original Size",
      "variable": "originalSize",
      "description": "Original Size"
    }
  ],
  "software": [
    "PS4 PKG Tool (pearlxcore)",
    "LibOrbisPkg (maxton)",
    "FPKG (fake-pkg tools)",
    "Goldhen PKG utilities"
  ],
  "formatRelationships": [
    {
      "formatId": "ROM_PS5",
      "relation": "predecessor",
      "note": "PS5 PKG uses the same CNT magic but different pkg_content_type values; PS5 can also run PS4 PKG"
    }
  ],
  "useCases": [
    "PS4 game and DLC installation from downloaded packages",
    "PKG content inspection for title ID and content type",
    "Forensic analysis of OrbisOS package structure",
    "Homebrew distribution via fake-PKG (fpkg) format"
  ],
  "technicalDetails": "PS4 PKG uses magic 0x7F434E54. The package body contains an encrypted PFS (Pseudo-File System) image. Entry table maps files to their encrypted offsets. pkg_content_type at 0x74 distinguishes PS4 (0x1A–0x1E) from PS5 (0x1F+) packages. Content ID format: UP####-CUSA#####_00-################.",
  "completenessScore": 84,
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Emulator",
    "ROM Manager",
    "RetroArch",
    "Hex Editor",
    "Game Debugger"
  ],
  "UseCases": [
    "Gaming",
    "ROM hacking",
    "Emulation",
    "Preservation"
  ],
  "QualityMetrics": {
    "CompletenessScore": 84,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 9,
    "ValidationRules": 0,
    "LastUpdated": "2026-05-20",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {
    "Platform": "PS4"
  },
  "functions": {
    "calculateCRC32": "Validate CRC",
    "readUInt32LE": "Read size"
  },
  "forensic": {
    "riskLevel": "medium",
    "notes": [
      "PS4 PKG content is encrypted with OrbisOS keys; hex inspection shows only the unencrypted header",
      "Shared CNT magic with PS5 requires checking pkg_content_type at 0x74 for definitive platform ID",
      "Fake-PKG (fpkg) files have modified headers to bypass signature verification"
    ]
  },
  "diff": {
    "keyFields": ["cnt_magic", "file_offset", "file_count", "package_size"],
    "ignoreFields": [],
    "note": "Inferred semantic diff for ROM_PS4. Compare key structural fields; ignore volatile metadata."
  },
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "cnt_magic",
        "mutation": "corrupt_signature",
        "description": "Corrupt magic bytes at offset 0 — parser must reject."
      },
      {
        "field": "file_offset",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      },
      {
        "field": "file_count",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      },
      {
        "field": "package_size",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      }
    ],
    "note": "Inferred fuzz strategies for ROM_PS4. Hand-tune weights/rates per format if needed."
  }
}




        "checksumComplement"
      ]
    }
  ],
  "forensic": {
    "category": "game",
    "riskLevel": "low",
    "suspiciousPatterns": [
      {
        "name": "Checksum mismatch (patched ROM)",
        "condition": "checksumTotal != 65535",
        "severity": "info",
        "description": "Checksum mismatch — ROM has been patched, hacked, or has a trainer. Also triggers if SMC copier header shifts offsets by 512 bytes."
      }
    ]
  },
  "aiHints": {
    "analysisContext": "SNES ROM: no fixed magic bytes. HiROM header at $FFB0 = file offset 65456 (headered .sfc) or 65968 (.smc + 512B copier header). SMC copier header present when: file_size % 1024 == 512. Header fields: title(21B)+mapMode($FFD5)+cartType($FFD6)+romSize($FFD7, log2KB)+ramSize($FFD8, log2KB)+region($FFD9)+devId($FFDA, 0x33=extended)+ver($FFDB)+checksumComp(2B LE $FFDC)+checksum(2B LE $FFDE). Checksum+complement=0xFFFF. SRAM saved as .srm (raw SRAM dump, same basename).",
    "suggestedInspections": [
      "Check file_size % 1024: if 512 -> 512B SMC copier header present, add 512 to all offsets",
      "Game title at offset 65456 (.sfc) or 65968 (.smc with header), 21 ASCII bytes",
      "Map mode at $FFD5: 0x20=LoROM, 0x21=HiROM, 0x25=ExHiROM",
      "Checksum at $FFDE + complement at $FFDC must sum to 0xFFFF — mismatch = patched ROM"
    ]
  },
  "software": [
    "Snes9x (saves SRAM as .srm alongside ROM)",
    "bsnes/higan (high-accuracy, same .srm naming)",
    "RetroArch (bsnes/snes9x cores)",
    "Mesen-S (debugging and accuracy)",
    "SNESROMInfo (ROM header viewer)"
  ],
  "formatRelationships": {
    "category": "Game",
    "extensions": [
      ".smc",
      ".sfc",
      ".fig",
      ".swc"
    ],
    "relatedFormats": [
      "PATCH_IPS",
      "PATCH_BPS",
      "PATCH_UPS",
      "ROM_SNES_SRM"
    ],
    "note": ".smc/.fig = ROM possibly with 512B copier header (file_size % 1024 == 512 confirms it). .sfc = headerless (canonical format). SRAM -> .srm files (same basename). IPS/BPS/UPS patches target headered or headerless ROMs separately — most patches target headered .smc."
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "UseCases": [
    "SNES game emulation and preservation",
    "ROM hacking and fan translation",
    "Applying IPS/BPS/UPS patches",
    "ROM header analysis and region identification"
  ],
  "QualityMetrics": {
    "CompletenessScore": 82,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 14,
    "ValidationRules": 2,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Format": "Binary SNES ROM (no fixed magic — header at HiROM $FFB0 or LoROM $7FB0)",
    "CopierHeader": ".smc/.fig: 512B copier header when file_size % 1024 == 512 — add 512 to all offsets",
    "HeaderOffset": "HiROM: $FFB0 = 65456 (.sfc) / 65968 (.smc); LoROM: $7FB0 = 32688 (.sfc) / 33200 (.smc)",
    "Checksum": "uint16 sum of all bytes mod 0x10000; checksum + complement = 0xFFFF",
    "SRAM": "Battery SRAM -> .srm (raw dump, same basename as ROM)"
  }
}
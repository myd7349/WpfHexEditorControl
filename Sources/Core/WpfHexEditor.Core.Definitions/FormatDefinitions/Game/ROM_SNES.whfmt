        "color": "#FF6B9D"
      }
    ]
  },
  "inspector": {
    "badge": "romLayout",
    "primaryField": "gameTitle",
    "showQualityScore": true,
    "groups": [
      {
        "title": "ROM Identity",
        "icon": "",

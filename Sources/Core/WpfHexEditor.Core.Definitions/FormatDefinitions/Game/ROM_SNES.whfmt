  },
  "exportTemplates": [
    {
      "name": "SNES ROM Header (JSON)",
      "format": "json",
      "fields": [
        "gameTitle",
        "romLayout",
        "romType",
        "romSize",
        "ramSize",
        "regionCode",
        "developerId",

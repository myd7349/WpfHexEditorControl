{
  "diffMode": "binary",
  "formatName": "Super Nintendo ROM",
  "version": "3.24",
  "extensions": [
    ".smc",
    ".sfc",
    ".fig",
    ".swc"
  ],
  "description": "Super Nintendo Entertainment System (SNES) ROM files. .smc and .fig files may include a 512-byte copier header prepended by Super Magicom or FIG hardware (detectable when file_size mod 1024 == 512). .sfc files are headerless (standard format). The internal ROM header (64 bytes) is at $FFB0-$FFFF in HiROM layout (file offset 0xFFB0 = 65456 for headered .sfc, or 0x101B0 = 65968 for .smc with 512B copier header). HiROM header fields: game title (21B ASCII at $FFB0), map mode (1B at $FFD5), cartridge type (1B at $FFD6), ROM size log2-KB (1B at $FFD7), SRAM size log2-KB (1B at $FFD8), region code (1B at $FFD9), developer ID (1B at $FFDA — 0x33=extended header), ROM version (1B at $FFDB), checksum complement (2B LE at $FFDC), checksum (2B LE at $FFDE). Checksum + complement must equal 0xFFFF.",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "SNES Internal ROM Header Specification — SNESdev Wiki"
    ],
    "WebLinks": [
      "https://snes.nesdev.org/wiki/ROM_header",
      "https://sneslab.net/wiki/SNES_ROM_Header",
      "https://wiki.superfamicom.org/writing-the-header"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "33",
        "offset": 65498,
        "label": "0x33 at $FFDA — HiROM developer ID (headerless .sfc)",
        "weight": 0.8
      },
      {
        "value": "33",
        "offset": 66010,
        "label": "0x33 at $FFDA+512 — HiROM developer ID (.smc with 512B copier header)",
        "weight": 0.8
      },
      {
        "value": "33",
        "offset": 33210,
        "label": "0x33 at $81BA — LoROM developer ID (headerless .sfc)",
        "weight": 0.6
      },
      {
        "value": "33",
        "offset": 33722,
        "label": "0x33 at $81BA+512 — LoROM developer ID (.smc with 512B copier header)",
        "weight": 0.6
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.6,
    "required": false,
    "Strength": "Weak",
    "EntropyHint": {
      "min": 5.0,
      "max": 7.5
    },
    "validation": {
      "minFileSize": 32768,
      "maxSignatureOffset": 66100,
      "note": "SNES ROMs have no fixed magic bytes. Detection uses the developer ID byte 0x33 at HiROM ($FFDA) or LoROM ($81BA) header positions. For .smc files with 512-byte copier header (file_size % 1024 == 512), add 512 to all offsets. Minimum 32KB."
    }
  },
  "variables": {
    "gameTitle": "",
    "romLayout": 0,
    "romType": 0,
    "romSize": 0,
    "ramSize": 0,
    "regionCode": 0,
    "developerId": 0,
    "romVersion": 0,
    "checksumComplement": 0,
    "checksum": 0,
    "nativeModeVectors": "",
    "checksumTotal": 0,
    "formattedSize": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "Game Title",
      "offset": 65456,
      "length": 21,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "valueType": "ascii",
      "storeAs": "gameTitle",
      "description": "Internal game title as 21 ASCII bytes space-padded, at $FFB0-$FFC4 in HiROM layout (file offset 65456 for headered .sfc; 65968 for .smc with 512B copier header). The title is set by the developer and may differ from the retail box title. Japanese ROMs often use katakana or romaji. This offset covers headered .sfc files — for .smc add 512."
    },
    {
      "type": "field",
      "name": "ROM Layout Mode",
      "offset": 65493,
      "length": 1,
      "color": "#FFE66D",
      "opacity": 0.35,
      "valueType": "uint8",
      "storeAs": "romLayout",
      "description": "ROM memory mapping mode byte at $FFD5 (file offset 65477 for .sfc; 65989 for .smc+512). Bits 0-4 define the mapping type; bit 5 sets FastROM (3.58MHz). 0x20=LoROM (32KB banks), 0x21=HiROM (64KB banks), 0x22=LoROM+S-DD1, 0x23=LoROM+SA-1, 0x25=ExHiROM (96KB/64KB banks for 32Mbit+ ROMs). Add 0x10 for FastROM variant.",
      "valueMap": {
        "32": "0x20 — LoROM (SlowROM, 2.68MHz)",
        "33": "0x21 — HiROM (SlowROM, 2.68MHz)",
        "34": "0x22 — LoROM + S-DD1",
        "35": "0x23 — LoROM + SA-1",
        "37": "0x25 — ExHiROM (32Mbit+)",
        "48": "0x30 — LoROM FastROM",
        "49": "0x31 — HiROM FastROM",
        "53": "0x35 — ExHiROM FastROM"
      }
    },
    {
      "type": "field",
      "name": "Cartridge Type",
      "offset": 65494,
      "length": 1,
      "color": "#FFE66D",
      "opacity": 0.35,
      "valueType": "uint8",
      "storeAs": "romType",
      "description": "Cartridge hardware type byte at $FFD6 (file offset 65478 for .sfc; 65990 for .smc+512). Lower nibble: 0=ROM only, 1=ROM+RAM, 2=ROM+SRAM+Battery (save game). Upper nibble coprocessor: 0=none, 1=DSP, 2=SuperFX, 3=OBC1, 4=SA-1.",
      "valueMap": {
        "0": "0x00 — ROM only",
        "1": "0x01 — ROM + RAM",
        "2": "0x02 — ROM + SRAM + Battery",
        "3": "0x03 — ROM + DSP",
        "5": "0x05 — ROM + DSP + SRAM + Battery",
        "19": "0x13 — ROM + SuperFX",
        "20": "0x14 — ROM + SuperFX + Battery",
        "32": "0x20 — ROM + SA-1",
        "34": "0x22 — ROM + SA-1 + SRAM + Battery"
      }
    },
    {
      "type": "field",
      "name": "ROM Size (log2 KB)",
      "offset": 65495,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.35,
      "valueType": "uint8",
      "storeAs": "romSize",
      "description": "ROM size as 2^N kilobytes at $FFD7 (file offset 65479 for .sfc; 65991 for .smc+512). Common values: 7=128KB, 8=256KB, 9=512KB, 10=1MB, 11=2MB, 12=4MB.",
      "valueMap": {
        "6": "64 KB",
        "7": "128 KB",
        "8": "256 KB",
        "9": "512 KB",
        "10": "1 MB",
        "11": "2 MB",
        "12": "4 MB",
        "13": "8 MB"
      }
    },
    {
      "type": "field",
      "name": "SRAM Size (log2 KB)",
      "offset": 65496,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.35,
      "valueType": "uint8",
      "storeAs": "ramSize",
      "description": "Battery-backed SRAM size as 2^N kilobytes at $FFD8 (file offset 65480 for .sfc; 65992 for .smc+512). Value 0x00 = no SRAM. Emulators save SRAM to .srm files with same basename as ROM.",
      "valueMap": {
        "0": "No SRAM",
        "1": "2 KB",
        "2": "4 KB",
        "3": "8 KB",
        "4": "16 KB",
        "5": "32 KB",
        "6": "64 KB",
        "7": "128 KB"
      }
    },
    {
      "type": "field",
      "name": "Region Code",
      "offset": 65497,
      "length": 1,
      "color": "#C7CEEA",
      "opacity": 0.35,
      "valueType": "uint8",
      "storeAs": "regionCode",
      "description": "Region/country code at $FFD9 (file offset 65481 for .sfc; 65993 for .smc+512). Determines TV standard: Japan/USA=NTSC 60Hz, Europe=PAL 50Hz.",
      "valueMap": {
        "0": "Japan (NTSC, 60Hz)",
        "1": "North America / USA (NTSC, 60Hz)",
        "2": "Europe (PAL, 50Hz)",
        "6": "France (PAL)",
        "9": "Germany (PAL)",
        "10": "Italy (PAL)",
        "13": "South Korea (NTSC)"
      }
    },
    {
      "type": "field",
      "name": "Developer ID",
      "offset": 65498,
      "length": 1,
      "color": "#C7CEEA",
      "opacity": 0.35,
      "valueType": "uint8",
      "storeAs": "developerId",
      "description": "Developer/licensee code at $FFDA (file offset 65482 for .sfc; 65994 for .smc+512). Value 0x33 signals extended header at $FFB0-$FFBF (2-char maker code + 4-char game code). 0x01=Nintendo internal."
    },
    {
      "type": "field",
      "name": "ROM Version",
      "offset": 65499,
      "length": 1,
      "color": "#C7CEEA",
      "opacity": 0.35,
      "valueType": "uint8",
      "storeAs": "romVersion",
      "description": "Mask ROM version number at $FFDB (file offset 65483 for .sfc; 65995 for .smc+512). 0x00 = first release, 0x01 = Rev.A, etc."
    },
    {
      "type": "field",
      "name": "Checksum Complement",
      "offset": 65500,
      "length": 2,
      "color": "#FF6B9D",
      "opacity": 0.35,
      "valueType": "uint16",
      "endianness": "little",
      "storeAs": "checksumComplement",
      "description": "Bitwise complement (NOT) of the ROM checksum as uint16 LE at $FFDC (file offset 65484 for .sfc; 65996 for .smc+512). checksum XOR checksumComplement must = 0xFFFF."
    },
    {
      "type": "field",
      "name": "Checksum",
      "offset": 65502,
      "length": 2,
      "color": "#FF6B9D",
      "opacity": 0.35,
      "valueType": "uint16",
      "endianness": "little",
      "storeAs": "checksum",
      "description": "16-bit sum of all ROM bytes mod 0x10000 at $FFDE (file offset 65486 for .sfc; 65998 for .smc+512). checksum + checksumComplement must = 0xFFFF (65535)."
    },
    {
      "type": "computeFromVariables",
      "expression": "checksum + checksumComplement",
      "storeAs": "checksumTotal"
    },
    {
      "type": "metadata",
      "name": "Title",
      "variable": "gameTitle",
      "description": "Internal 21-char game title from ROM header"
    },
    {
      "type": "metadata",
      "name": "Layout",
      "variable": "romLayout",
      "description": "ROM mapping mode (LoROM/HiROM/ExHiROM)"
    },
    {
      "type": "metadata",
      "name": "Region",
      "variable": "regionCode",
      "description": "Region code (0=Japan, 1=USA, 2=Europe)"
    },
    {
      "type": "metadata",
      "name": "Checksum Valid",
      "variable": "checksumTotal",
      "description": "Checksum + Complement (must equal 65535 / 0xFFFF)"
    }
  ],
  "assertions": [
    {
      "name": "Checksum pair valid",
      "expression": "checksumTotal == 65535",
      "severity": "warning",
      "message": "Checksum + complement != 0xFFFF — ROM is modified/patched, or offsets are wrong (check for 512B SMC copier header)"
    },
    {
      "name": "ROM layout plausible",
      "expression": "romLayout >= 32 && romLayout <= 55",
      "severity": "warning",
      "message": "ROM layout byte out of expected range — may be reading wrong offset (copier header offset mismatch?)"
    }
  ],
  "navigation": {
    "bookmarks": [
      {
        "name": "SMC Copier Header (.smc)",

{
  "diffMode": "binary",
  "formatName": "Amiga Disk Format (ADF)",
  "version": "1.0",
  "extensions": [ ".adf" ],
  "description": "Amiga floppy disk image in ADF (Amiga Disk Format). Standard double-density disk: 80 tracks × 2 sides × 11 sectors × 512 bytes = 901120 bytes. High-density variant: 80 × 2 × 22 × 512 = 1802240 bytes. OFS (Old Filing System) disks start with 'DOS' followed by 0x00-0x03. FFS (Fast Filing System) uses 0x01 or 0x05. The bootblock occupies the first two sectors (1024 bytes). The rootblock is at sector 880 (track 40, offset 450560). Disk type is in the first 4 bytes.",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "LastUpdated": "2026-04-15",
  "preferredEditor": "HexEditor",
  "references": [
    "http://lclevy.free.fr/adflib/adf_info.html",
    "https://wiki.amigaos.net/wiki/Amiga_Disk_Format"
  ],
  "detection": {
    "signatures": [
      {
        "value": "444F5300",
        "offset": 0,
        "label": "DOS\\x00 — OFS (Old File System) bootblock identifier",
        "weight": 0.9
      },
      {
        "value": "444F5301",
        "offset": 0,
        "label": "DOS\\x01 — FFS (Fast File System) bootblock identifier",
        "weight": 0.9
      },
      {
        "value": "444F5305",
        "offset": 0,
        "label": "DOS\\x05 — FFS+INTL bootblock identifier",
        "weight": 0.9
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.5,
    "Strength": "Medium"
  },
  "variables": {},
  "blocks": [
    {
      "name": "diskTypeMagic",
      "offset": 0,
      "size": 3,
      "type": "ascii",
      "description": "Disk type magic — 3-byte ASCII string at offset 0, always 'DOS' in all AmigaOS filesystem variants; the following byte distinguishes OFS from FFS and other filesystem flags",
      "storeAs": "diskTypeMagic"
    },
    {
      "name": "fsFlag",
      "offset": 3,
      "size": 1,
      "type": "uint8",
      "description": "Filesystem type flag — 1-byte value at offset 3 indicating the filesystem variant and features; bit 0 = FFS (1) vs OFS (0), bit 1 = INTL directory cache, bit 2 = DIRCACHE enabled",
      "storeAs": "fsFlag",
      "valueMap": {
        "0": "OFS (Old File System)",
        "1": "FFS (Fast File System)",
        "2": "OFS+INTL",
        "3": "FFS+INTL",
        "4": "OFS+DIRCACHE",
        "5": "FFS+DIRCACHE"
      }
    },
    {
      "name": "bootChecksum",
      "offset": 4,
      "size": 4,
      "type": "uint32",
      "endian": "BE",
      "description": "Boot block checksum — 4-byte big-endian unsigned integer at offset 4; computed as the one's complement sum of all 32-bit words in the 1024-byte boot block with this field itself set to 0; used by Kickstart to verify boot block integrity",
      "storeAs": "bootChecksum"
    },
    {
      "name": "rootBlockSector",
      "offset": 8,
      "size": 4,
      "type": "uint32",
      "endian": "BE",
      "description": "Root block sector number — 4-byte big-endian value at offset 8 in the boot block; for standard DD disks this is always sector 880 (offset 450560); the root block contains the disk name and the top-level directory hash table"
    },
    {
      "name": "bootCode",
      "offset": 12,
      "size": 1012,
      "type": "bytes",
      "description": "Boot code — 1012 bytes of 68000 executable boot code at offset 12 within the 1024-byte boot block; this code is loaded and executed by Kickstart if the disk type magic and checksum are valid"
    }
  ],
  "assertions": [
    {
      "name": "DiskMagicValid",
      "expression": "diskTypeMagic == 'DOS'",
      "severity": "error",
      "message": "Disk type magic at offset 0 must be 'DOS' (3 bytes); file does not appear to be a valid AmigaOS ADF disk image"
    },
    {
      "name": "FsFlagValid",
      "expression": "fsFlag >= 0 && fsFlag <= 7",
      "severity": "warning",
      "message": "Filesystem flag at offset 3 should be in range 0-7; value outside this range is not a recognized AmigaOS filesystem type"
    },
    {
      "name": "FileSizeValid",
      "expression": "fileSize == 901120 || fileSize == 1802240",
      "severity": "warning",
      "message": "ADF file size should be 901120 bytes (DD) or 1802240 bytes (HD); other sizes indicate a non-standard or truncated disk image"
    }
  ],
  "navigation": {
    "anchors": [
      { "name": "Bootblock", "offset": 0, "size": 1024, "description": "Sectors 0-1: boot block containing DOS magic, checksum, and optional boot code" },
      { "name": "Rootblock", "offset": 450560, "size": 512, "description": "Sector 880: root block containing disk name and top-level directory hash table" }
    ]
  },
  "inspector": {
    "badge": "ADF",
    "primaryField": "fsFlag",
    "showQualityScore": true,
    "groups": [
      {
        "name": "Filesystem",
        "fields": [ "diskTypeMagic", "fsFlag", "bootChecksum" ]
      },
      {
        "name": "Structure",
        "fields": [ "rootBlockSector" ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Disk Summary",
      "format": "text",
      "template": "Amiga ADF Disk Image\nFilesystem: DOS + flag {fsFlag}\nBoot Checksum: 0x{bootChecksum:X8}\nRoot Block at sector: {rootBlockSector}"
    },
    {
      "name": "Filesystem Header CSV",
      "format": "csv",
      "template": "Field,Value\nMagic,{diskTypeMagic}\nFsFlag,{fsFlag}\nBootChecksum,{bootChecksum}\nRootBlockSector,{rootBlockSector}"
    }
  ],
  "forensic": {
    "riskLevel": "low",
    "notes": "Amiga floppy disk image. Contains a 68000 executable bootblock that executed on original hardware. No threat to modern systems. Used for Amiga software and game preservation."
  },
  "aiHints": {
    "analysisContext": "ADF images use a block-based filesystem (OFS or FFS). The root block is always at sector 880 for standard DD disks. File names and directory structures are stored in hash tables within blocks. Big-endian byte order throughout. The boot checksum uses one's complement arithmetic over 32-bit words.",
    "suggestedInspections": [
      "Verify 'DOS' magic at offset 0 and check filesystem flag byte at offset 3",
      "Validate boot checksum at offset 4 using one's complement 32-bit word sum",
      "Navigate to sector 880 (offset 450560) to read the root block and disk name",
      "Check file size: 901120 bytes for DD, 1802240 bytes for HD disks",
      "Decode filesystem type from fsFlag: 0=OFS, 1=FFS, 5=FFS+DIRCACHE",
      "Enumerate the root directory hash table in the root block for file listing"
    ]
  },
  "software": [
    { "name": "WinUAE", "url": "https://www.winuae.net/", "role": "emulator" },
    { "name": "ADFOpus", "url": "https://adfopus.sourceforge.net/", "role": "disk image tool" },
    { "name": "FS-UAE", "url": "https://fs-uae.net/", "role": "emulator" }
  ],
  "formatRelationships": [
    { "format": "ROM_AMIGA_HDF", "relation": "sibling — HDF is the Amiga hard disk image format with similar block structure" }
  ],
  "MimeTypes": [ "application/x-amiga-disk-format" ],
  "UseCases": [
    "Amiga software and game preservation",
    "Emulation with WinUAE and FS-UAE",
    "File extraction from OFS and FFS Amiga disk images"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "detailed",
    "LastUpdated": "2026-04-15"
  },
  "TechnicalDetails": {
    "sectorSize": 512,
    "standardSizeDD": 901120,
    "standardSizeHD": 1802240,
    "rootBlockSector": 880,
    "endianness": "big-endian",
    "notes": "AmigaOS uses big-endian byte order (Motorola 68000). Bootblock checksum is one's complement sum of 32-bit words. Root block is always sector 880 on a standard 80-track DD disk."
  }
}

    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Format": "Binary little-endian Unreal Engine 4/5 serialized package",
    "Magic": "0x9E2A83C1 LE (bytes: C1 83 2A 9E) at offset 0",
    "LegacyVersion": "-8=UE5/UE4.27+; -7=UE4.20-4.26; -6=UE4.15-4.19",
    "AssetTypes": ".uasset=content, .umap=level, .uexp=bulk, .ucas/.utoc=IO Store",
    "Serialization": "FPackageFileSummary + Name table + Import table + Export table"
  }

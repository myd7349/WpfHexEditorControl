    }
  ],
  "forensic": {
    "category": "game",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "TI-99/4A ROM module: tag(2B BE) + size(2B BE, 8KB pages) + startAddr(2B BE) + menuEntry(2B BE). Tags: 0xAA01=ROM-only, 0xAA02=ROM+GROM. Cartridge ROM at 0x6000-0x7FFF. GROM at 0x9800 I/O. TMS9900 16-bit CPU with workspace-register model (R0-R15 in RAM). 256 bytes scratchpad RAM at 0x8300-0x83FF.",
    "suggestedInspections": [
      "Read bytes 0-1 as uint16 BE: 0xAA01 = ROM-only module, 0xAA02 = ROM+GROM module",
      "Read size at bytes 2-3 (uint16 BE): multiply by 8192 to get total ROM size in bytes",
      "Read start address at bytes 4-5 (uint16 BE): valid range 0x6000-0x7FFF for cartridge code",
      "Identify TMS9900 opcodes at start address: LI (0x0200), MOV (0xC000), BL (0x0680) are common entry patterns"
    ]
  },
  "software": [
    "Classic99 (Windows TI-99/4A emulator)",
    "JS99er (browser-based TI-99/4A emulator)",
    "MAME (TI-99/4A driver)",
    "MESS (predecessor to MAME)"
  ],
  "formatRelationships": {
    "category": "Game",
    "extensions": [".bin", ".rom", ".rpk"],
    "relatedFormats": ["ROM_COLECO"],
    "note": "TI-99/4A uses the unique TMS9900 16-bit CPU. GROM (Graphics ROM) is addressed via I/O ports at 0x9800 rather than memory-mapped. RPK is a MAME cartridge package format for TI-99/4A."
  },

{
  "diffMode": "binary",
  "formatName": "Sega Game Gear ROM",
  "version": "1.0",
  "extensions": [ ".gg" ],
  "description": "Sega Game Gear cartridge ROM image. Contains the standard 'TMR SEGA' header at offset 0x7FF0 (32752) within the ROM's last 16KB bank. The header layout is: 'TMR SEGA' (8B ASCII), product_code (3B BCD-encoded), version nibble, region/size byte (region bits 7-4, size bits 3-0), and checksum (2B LE). Identical header structure to the Sega Master System (SMS) format but the ROM executes only on Game Gear hardware.",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "LastUpdated": "2026-04-15",
  "preferredEditor": "HexEditor",
  "references": [
    "https://www.smspower.org/Development/ROMHeader",
    "https://segaretro.org/SDSC_header"
  ],
  "detection": {
    "signatures": [
      {
        "value": "544D522053454741",
        "offset": 32752,
        "label": "TMR SEGA — Sega ROM header magic at standard offset 0x7FF0 (32752)",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.5,
    "Strength": "Medium"
  },
  "variables": {},
  "blocks": [
    {
      "name": "firstByte",
      "offset": 0,
      "size": 1,
      "type": "uint8",
      "description": "First byte of ROM data at offset 0 — initial byte of the cartridge ROM payload before the header region; typically part of the ROM code or a jump instruction at the reset vector entry point",
      "storeAs": "firstByte"
    },
    {
      "name": "tmrSega",
      "offset": 32752,
      "size": 8,
      "type": "ascii",
      "description": "TMR SEGA header magic — 8-byte ASCII string at offset 0x7FF0 (32752) marking the beginning of the standard Sega ROM header; this string 'TMR SEGA' is required by the BIOS for cartridge validation",
      "storeAs": "tmrSega"
    },
    {
      "name": "productCode",
      "offset": 32760,
      "size": 3,
      "type": "bytes",
      "description": "Product code — 3 bytes at offset 32760 encoding the Sega product number in BCD (Binary-Coded Decimal) format; upper nibble of last byte encodes version; identifies the game title in Sega's catalog",
      "storeAs": "productCode"
    },
    {
      "name": "versionRegion",
      "offset": 32763,
      "size": 1,
      "type": "uint8",
      "description": "Version and region byte — 1-byte field at offset 32763; bits 7-4 encode the region code (3=SMS Japan, 4=SMS Export, 5=GG Japan, 6=GG Export, 7=GG International), bits 3-0 encode the ROM size code",
      "storeAs": "versionByte"
    },
    {
      "name": "checksum",
      "offset": 32764,
      "size": 2,
      "type": "uint16",
      "endian": "LE",
      "description": "ROM checksum — 2-byte little-endian unsigned integer at offset 32764; computed as the sum of all ROM bytes excluding the header region, used by the BIOS to verify ROM integrity on startup"
    }
  ],
  "assertions": [
    {
      "name": "TmrSegaValid",
      "expression": "tmrSega == 'TMR SEGA'",
      "severity": "error",
      "message": "Magic string at offset 0x7FF0 must be exactly 'TMR SEGA' (8 bytes); file does not contain a valid Sega ROM header"
    },
    {
      "name": "VersionByteValid",
      "expression": "versionByte >= 0x50 && versionByte <= 0x7F",
      "severity": "warning",
      "message": "Region/version byte at offset 32763 should be in the Game Gear range (0x50-0x7F); value outside this range may indicate an SMS ROM misidentified as Game Gear"
    },
    {
      "name": "FileSizeReasonable",
      "expression": "fileSize >= 32768",
      "severity": "warning",
      "message": "ROM file must be at least 32KB to contain the header at offset 0x7FF0; file is smaller than the minimum expected size"
    }
  ],
  "navigation": {
    "anchors": [
      { "name": "ROM Start", "offset": 0, "size": 32752, "description": "ROM code and data before the header region" },
      { "name": "TMR Header", "offset": 32752, "size": 16, "description": "16-byte Sega standard ROM header at offset 0x7FF0" }
    ]
  },
  "inspector": {
    "badge": "GG",
    "primaryField": "tmrSega",
    "showQualityScore": true,
    "groups": [
      {
        "name": "Header",
        "fields": [ "tmrSega", "productCode", "versionByte" ]
      },
      {
        "name": "Integrity",
        "fields": [ "checksum" ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "ROM Header Summary",
      "format": "text",
      "template": "Sega Game Gear ROM\nMagic: {tmrSega}\nVersion/Region Byte: 0x{versionByte:X2}\nProduct Code: {productCode}"
    },
    {
      "name": "Header Fields CSV",
      "format": "csv",
      "template": "Field,Value\nMagic,{tmrSega}\nVersionByte,{versionByte}\nChecksum,{checksum}"
    }
  ],
  "forensic": {
    "riskLevel": "low",
    "notes": "Sega Game Gear ROM image. Standard game preservation artifact. No executable threat to modern systems. Copyright applies to commercially released titles."
  },
  "aiHints": {
    "analysisContext": "Sega Game Gear ROM images share their header format with the Master System (SMS). The key discriminator is the region byte at offset 32763 — values 0x50-0x7F indicate Game Gear. Verify the TMR SEGA magic at offset 0x7FF0 and validate the checksum to confirm ROM integrity.",
    "suggestedInspections": [
      "Verify 'TMR SEGA' magic string at offset 0x7FF0 (32752)",
      "Decode region byte bits 7-4 to confirm Game Gear vs Master System region",
      "Decode ROM size from bits 3-0 of the version/region byte",
      "Validate the 2-byte checksum at offset 32764 against computed sum",
      "Check product code BCD bytes to identify game in Sega catalog",
      "Compare file size with expected size based on the size code field"
    ]
  },
  "software": [
    { "name": "Mednafen", "url": "https://mednafen.github.io/", "role": "emulator" },
    { "name": "Gens/GS", "url": "http://segaretro.org/Gens/GS", "role": "emulator" }
  ],
  "formatRelationships": [
    { "format": "ROM_SMS", "relation": "identical header structure — Game Gear uses the same TMR SEGA header as the Sega Master System; distinguished by region byte" }
  ],
  "MimeTypes": [ "application/x-gamegear-rom" ],
  "UseCases": [
    "Game preservation of Sega Game Gear cartridges",
    "Emulation and ROM research",
    "Header validation and region identification"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "detailed",
    "LastUpdated": "2026-04-15"
  },
  "TechnicalDetails": {
    "headerOffset": 32752,
    "headerSize": 16,
    "magicOffset": 32752,
    "magicBytes": "544D522053454741",
    "endianness": "little-endian",
    "notes": "Header is located at offset 0x7FF0 within the last 16KB page, not at the start of the file. Some ROMs with non-standard sizes place the header at different offsets."
  }
}

{
  "diffMode": "binary",
  "formatName": "IPS ROM Patch",
  "version": "1.13",
  "extensions": [
    ".ips"
  ],
  "description": "IPS (International Patching System) is a classic binary patch format widely used for ROM hacking and game translation patches. An IPS file starts with 5 ASCII bytes 'PATCH' (50 41 54 43 48), followed by a sequence of records, terminated by 'EOF' (45 4F 46, 3 bytes). Each record has: offset (3B big-endian, target file position), size (2B big-endian, number of bytes to write). If size > 0: the record is followed by 'size' bytes of patch data (raw replacement). If size == 0: the record is an RLE record with rleSize (2B BE, repetition count) and rleValue (1B, byte to repeat). The 'EOF' marker ends the patch sequence. IPS supports no integrity checking — the patcher must know the correct source ROM (usually validated by CRC32 or MD5 before patching). Maximum addressable offset is 0xFFFFFF (16MB). Superseded by BPS and UPS for large ROMs.",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "IPS Binary Patch Format — just-solve-the-file-format-problem.readthedocs.io"
    ],
    "WebLinks": [
      "http://justsolve.archiveteam.org/wiki/IPS_(binary_patch_format)",
      "https://www.romhacking.net/utilities/240/",
      "https://segaretro.org/IPS"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "5041544348", "offset": 0, "label": "'PATCH' — IPS ROM patch file magic", "weight": 1.0 }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 2.0, "max": 6.0 },
    "validation": {
      "minFileSize": 8,
      "maxSignatureOffset": 0,
      "note": "IPS files always start with ASCII 'PATCH' (5 bytes). The file ends with ASCII 'EOF' (3 bytes). Minimum valid IPS patch = 8 bytes ('PATCH' + 'EOF')."
    }
  },
  "variables": {
    "ipsHeader": "",
    "firstRecordOffset": 0,
    "firstRecordSize": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "IPS Magic",
      "offset": 0,
      "length": 5,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "IPS patch file magic: 5 ASCII bytes 'PATCH' (0x50 0x41 0x54 0x43 0x48). This magic identifies an IPS (International Patching System) ROM patch file. IPS was one of the first widely used binary patch formats for ROM hacking, originating in the SNES/NES era. The format is extremely simple — no checksum, no source/target validation, just a list of offset+data records. Application tools: Lunar IPS (Windows), Floating IPS (cross-platform), flips.",
      "storeAs": "ipsHeader",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "First Record Offset",
      "offset": 5,
      "length": 3,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "First patch record target offset in the ROM file as 3-byte (24-bit) big-endian unsigned integer at offset 5. Maximum addressable offset: 0xFFFFFF (16,777,215 bytes = 16MB — IPS limit). Records can be in any order within the file. The magic offset 0x454F46 ('EOF' bytes) signals end-of-patch instead of being a real record offset.",
      "storeAs": "firstRecordOffset",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "First Record Size",
      "offset": 8,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "Payload size of first patch record as uint16 big-endian at offset 8. Non-zero = raw data record: this many bytes of patch data follow. Zero = RLE record: next 2 bytes are RLE count (uint16 BE), then 1 byte is the value to repeat. RLE records are useful for filling large ROM regions (e.g., zeroing out an entire section).",
      "storeAs": "firstRecordSize",
      "valueType": "uint16",
      "endianness": "big"
    },
    {
      "type": "metadata",
      "name": "IPS Header",
      "variable": "ipsHeader",
      "description": "'PATCH' — IPS magic identifier"
    },
    {
      "type": "metadata",
      "name": "First Record Offset",
      "variable": "firstRecordOffset",
      "description": "First patch record target offset (24-bit BE)"
    },
    {
      "type": "metadata",
      "name": "First Record Size",
      "variable": "firstRecordSize",
      "description": "First record payload size (0=RLE)"
    }
  ],
  "assertions": [
    {
      "name": "IPS magic valid",
      "expression": "ipsHeader == 'PATCH'",
      "severity": "error",
      "message": "IPS patch file must start with 'PATCH' ASCII magic"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "IPS Header", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "First Patch Record", "offset": 5, "icon": "\uE71B", "color": "#4ECDC4" }
    ]
  },
  "inspector": {
    "badge": "ipsHeader",
    "primaryField": "firstRecordOffset",
    "showQualityScore": true,
    "groups": [
      {
        "title": "IPS Patch Header",
        "icon": "\uE71B",
        "fields": ["ipsHeader", "firstRecordOffset", "firstRecordSize"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "IPS Header (JSON)",
      "format": "json",
      "fields": ["ipsHeader", "firstRecordOffset", "firstRecordSize"]
    }
  ],
  "forensic": { "category": "game", "riskLevel": "low", "suspiciousPatterns": [] },
  "aiHints": {
    "analysisContext": "IPS format: 'PATCH'(5B) + records + 'EOF'(3B). Each record: offset(3B BE) + size(2B BE); if size>0: data(size bytes); if size==0: rleCount(2B BE) + rleValue(1B). End marker: when offset bytes read as 'EOF' (0x454F46). No integrity check — no CRC or source hash. Max target offset: 0xFFFFFF (16MB IPS limit). For larger ROMs use BPS or UPS.",
    "suggestedInspections": [
      "Bytes 0-4 (ASCII): 'PATCH' — IPS magic",
      "Bytes 5-7 (3B BE): first record offset in target ROM",
      "Bytes 8-9 (uint16 BE): record size (0=RLE, >0=raw data length)",
      "Scan for 0x454F46 ('EOF') bytes to find patch end marker"
    ]
  },
  "software": [
    "Lunar IPS (Windows patching tool)",
    "Floating IPS / flips (cross-platform)",
    "UniPatcher (Android)",
    "RetroArch (built-in IPS patching)"
  ],
  "formatRelationships": {
    "category": "Game",
    "extensions": [".ips"],
    "relatedFormats": ["PATCH_BPS", "PATCH_UPS"],
    "note": "IPS is the oldest/simplest ROM patch format. Limitations: max 16MB target offset, no source validation, no checksum. BPS (Beat Patching System) and UPS are modern successors with CRC32 validation and larger address space."
  },
  "MimeTypes": ["application/octet-stream"],
  "UseCases": [
    "Applying ROM translation patches (SNES, NES, GBA games)",
    "ROM hacking distribution via IPS patch files",
    "Bug-fix patches for classic console games",
    "Applying fan-made game modifications"
  ],
  "QualityMetrics": {
    "CompletenessScore": 62,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 6,
    "ValidationRules": 1,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Format": "Binary IPS ROM patch (International Patching System)",
    "Magic": "'PATCH' ASCII (5 bytes) at offset 0; 'EOF' (3 bytes) end marker",
    "RecordFormat": "offset(3B BE) + size(2B BE) + [data(size B) | rleCount(2B) + rleVal(1B)]",
    "Limitation": "Max target offset 0xFFFFFF (16MB); no source/target integrity checks",
    "Successor": "BPS (Beat Patching System) with CRC32 validation"
  }
}

  "aiHints": {
    "analysisContext": "ColecoVision ROM: 2-byte magic 0xAA55 or 0x55AA at offset 0, followed by program start address (uint16 LE). BIOS at power-on validates the magic at 0x8000 and jumps to the start address. Z80 CPU at 3.58 MHz. ROM mapped at 0x8000-0xFFFF. SN76489 PSG sound chip.",
    "suggestedInspections": [
      "Read bytes 0-1: 0xAA 0x55 (standard) or 0x55 0xAA (alternate) — invalid otherwise",
      "Read program start address at bytes 2-3 (uint16 LE): should be in range 0x8000-0xFFC0",
      "Check file size: standard sizes are 8 KB (8192), 16 KB (16384), or 32 KB (32768)",
      "Look for Z80 opcode patterns at program start offset relative to 0x8000 base address"
    ]
  },

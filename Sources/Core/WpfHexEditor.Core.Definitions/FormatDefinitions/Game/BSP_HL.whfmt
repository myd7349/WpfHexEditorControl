   Detection: signature=1E000000 @ offset 0
   Updated:   2026-02-24
   ============================================================ */
{
  "diffMode": "binary",
  "formatName": "Half-Life BSP",
  "version": "1.12",
  "extensions": [
    ".bsp"
  ],
  "description": "Half-Life/GoldSrc engine BSP map format",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "BSP v30 GoldSrc Format",

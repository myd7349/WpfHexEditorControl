    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Format": "Binary little-endian GoldSrc BSP map (Valve Half-Life)",
    "Magic": "No magic — version uint32 LE = 30 at offset 0",
    "Header": "124 bytes: version(4B LE) + 15 lump entries × 8B (offset+length)",
    "Extensions": "Over Quake 1 BSP: RGB lighting, WAD3 texture references, larger map limits",
    "TextureSystem": "Texture names are references to WAD3 files (not embedded)"
  }

      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "GoldSrc BSP version (30)",
      "storeAs": "bspVersion",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Entities Lump Offset",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Offset to entities lump",
      "storeAs": "entitiesLumpOffset",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Entities Lump Size",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Size of entities lump",
      "storeAs": "entitiesLumpSize",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "File Count",
      "variable": "fileCount",
      "description": "File Count"
    },
    {
      "type": "metadata",
      "name": "Version",

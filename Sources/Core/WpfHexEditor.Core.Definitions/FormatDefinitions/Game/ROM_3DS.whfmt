          "partitionsCryptType"
        ]
      },
      {
        "title": "Configuration",
        "icon": "settings",
        "fields": [
          "partitionsFsType",
          "flags",
          "additionalHeaderSize",
          "sectorZeroOffset"
        ]
      }
    ]
  },
  "exportTemplates": [
    {

      "https://www.atarimania.com/",
      "https://en.wikipedia.org/wiki/Atari_2600",
      "https://atariage.com/2600/programming/"
    ]
  },
  "detection": {
    "signatures": [],
    "matchMode": "any",
    "MinimumScore": 0.0,
    "required": false,
    "Strength": "Weak",
    "validation": {
      "minFileSize": 2048,
      "maxSignatureOffset": 0,
      "note": "Atari 2600 ROMs have no magic bytes — pure 6507 machine code. Detection relies on file extension (.a26) and file size being one of: 2048, 4096, 8192, 12288, 16384, 32768, or 65536 bytes."
    }
  },
  "variables": {
    "firstByte": 0,
    "secondByte": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "First Byte",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "valueType": "uint8",
      "description": "First byte of the Atari 2600 ROM image. Since the 6507 begins execution from the reset vector (at the end of the ROM), the first byte is typically part of game code or data rather than the entry point. Common values include 6502-family opcodes or static data tables.",
      "storeAs": "firstByte"
    },
    {
      "type": "field",
      "name": "Second Byte",
      "offset": 1,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Second byte of the ROM image. Together with the first byte this allows analysis tools to guess the bank-switching scheme from common byte patterns at the start of the ROM.",
      "storeAs": "secondByte"
    },
    {
      "type": "metadata",
      "name": "First Byte",
      "variable": "firstByte",
      "description": "First ROM byte (no magic)"
    },
    {
      "type": "metadata",
      "name": "File Size Class",
      "variable": "secondByte",
      "description": "Indicates ROM bank-switching class by file size"
    }
  ],
  "assertions": [
    {
      "name": "Valid ROM size",
      "expression": "fileSize == 2048 || fileSize == 4096 || fileSize == 8192 || fileSize == 12288 || fileSize == 16384 || fileSize == 32768 || fileSize == 65536",
      "severity": "warning",
      "message": "Atari 2600 ROM size should be 2 KB, 4 KB, 8 KB, 12 KB, 16 KB, 32 KB, or 64 KB"
    }

    "Magic": "No magic bytes — version uint32 LE at offset 0 (29 = Quake 1 standard)",
    "Header": "124 bytes: version(4B) + 15 lump entries × 8B (offset+length)",
    "Lumps": "ENTITIES, PLANES, TEXTURES, VERTICES, VISIBILITY, NODES, TEXINFO, FACES, LIGHTING, CLIPNODES, LEAFS, MARKSURFACES, EDGES, SURFEDGES, MODELS",
    "Compiler": "qbsp / ericw-tools compile .map → .bsp"

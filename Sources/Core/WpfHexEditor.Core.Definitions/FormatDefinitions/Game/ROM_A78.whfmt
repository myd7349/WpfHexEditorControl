      "name": "A78 ROM Header (JSON)",
      "format": "json",
      "fields": ["headerVersion", "atari7800Magic", "gameTitle", "romLength", "cartType", "tvType", "saveDataType"]
    },
    {
      "name": "A78 ROM Summary (CSV)",
      "format": "csv",
      "fields": ["gameTitle", "romLength", "cartType", "tvType"]
    }
  ],
  "forensic": {
    "category": "game",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "A78 header: 0x01(1B) + 'ATARI7800'(9B) + reserved(6B) + gameTitle(32B ASCII) + reserved(2B) + romLength(4B BE) + cartType(1B) + reserved(1B) + ctrl1(1B) + ctrl2(1B) + tvType(1B) + saveType(1B) + reserved(69B) = 128 bytes total. ROM data starts at offset 128.",
    "suggestedInspections": [
      "Verify 'ATARI7800' ASCII magic at offsets 1-9 (9 bytes)",
      "Read game title at offsets 16-47 (32-byte null-padded ASCII)",
      "Read ROM data length at offsets 49-52 (uint32 BE) — total file size should equal 128 + romLength",
      "Check TV type at offset 57: 0=NTSC, 1=PAL — PAL ROMs run at different clock speed"
    ]
  },
  "software": [
    "ProSystem (official Atari 7800 emulator)",
    "A7800 (RetroArch core for Atari 7800)",
    "MAME (Atari 7800 driver)",
    "Stella (also supports some 7800 games)"
  ],
  "formatRelationships": {
    "category": "Game",
    "extensions": [".a78"],
    "relatedFormats": ["ROM_ATARI2600"],
    "note": "The Atari 7800 is backward compatible with most Atari 2600 games. The MARIA graphics chip provides significantly improved sprite capability over the 2600 TIA chip. A78 is the universally accepted ROM container format for 7800 preservation."
  },
  "MimeTypes": ["application/octet-stream"],
  "UseCases": [

{
  "diffMode": "binary",
  "formatName": "Atari 7800 ROM",
  "version": "1.0",
  "extensions": [".a78"],
  "description": "Atari 7800 ProSystem cartridge ROM in the standardised A78 container format. The 128-byte header begins with 0x01 at offset 0 (reserved), followed by the 9-byte ASCII string 'ATARI7800' (0x41 0x54 0x41 0x52 0x49 0x37 0x38 0x30 0x30) at offsets 1-9, then 6 reserved bytes (offsets 10-15), followed by the cart_name (32 bytes ASCII, null-padded) at offsets 16-47, the ROM data length (uint32 BE) at offset 49, the cart_type byte at offset 53, the ctrl1 and ctrl2 bytes at offsets 55 and 56, the TV_type byte at offset 57, the save_type byte at offset 58, and 69 reserved bytes filling to offset 127. ROM data begins at offset 128. Cart types: 0=Normal, 1=SuperGame, 2=SuperGame with RAM. TV types: 0=NTSC, 1=PAL. Save types: 0=None, 1=High Score Cartridge, 2=SaveKey/AtariVox. The 6502C CPU runs at 1.79 MHz (NTSC). The MARIA chip provides 320x200 resolution with up to 25 sprites per scanline.",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Atari 7800 A78 Header Specification v1.0",
      "ProSystem Emulator A78 Header Documentation",
      "Atari 7800 Programming Reference Guide"
    ],
    "WebLinks": [
      "http://7800.8bitdev.org/index.php/A78_Header_Specification",
      "https://docs.libretro.com/library/prosystem/",
      "https://en.wikipedia.org/wiki/Atari_7800",
      "https://atariage.com/7800/"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "41544152493738303030",
        "offset": 1,
        "label": "'ATARI7800' — Atari 7800 ProSystem ROM header magic at offset 1",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.9,
    "required": true,
    "Strength": "Strong",
    "validation": {
      "minFileSize": 128,
      "maxSignatureOffset": 1,
      "note": "All valid .a78 ROM files have 'ATARI7800' starting at offset 1. Offset 0 is 0x01 (version/reserved). ROM data starts at offset 128 after the fixed 128-byte header."
    }
  },
  "variables": {
    "headerVersion": 0,
    "atari7800Magic": "",
    "gameTitle": "",
    "romLength": 0,
    "cartType": 0,
    "controller1": 0,
    "controller2": 0,
    "tvType": 0,
    "saveDataType": 0,
    "romDataStart": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "Header Version",
      "offset": 0,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Reserved byte at offset 0, value 0x01. Used as a format version indicator in the A78 header specification. Emulators check this byte along with the ATARI7800 magic string to validate the header.",
      "storeAs": "headerVersion"
    },
    {
      "type": "signature",
      "name": "ATARI7800 Magic",
      "offset": 1,
      "length": 9,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "valueType": "ascii",
      "description": "9-byte ASCII magic string 'ATARI7800' at offsets 1-9 identifying the Atari 7800 ProSystem A78 ROM header format. This string is followed by 6 reserved bytes (all 0x00) before the game title field at offset 16.",
      "storeAs": "atari7800Magic"
    },
    {
      "type": "field",
      "name": "Game Title",
      "offset": 16,
      "length": 32,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "ascii",
      "description": "32-byte null-padded ASCII game title string at offsets 16-47. Displayed by emulators in the ROM library. Examples: 'DESERT FALCON', 'NINJA GOLF', 'BALLBLAZER'.",
      "storeAs": "gameTitle"
    },
    {
      "type": "field",
      "name": "ROM Data Length",
      "offset": 49,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "valueType": "uint32",
      "endianness": "big",
      "description": "Size of the ROM data in bytes following the 128-byte header, stored as uint32 big-endian at offset 49. This is the actual ROM content size excluding the A78 header. Typical values: 16384 (16 KB), 32768 (32 KB), 49152 (48 KB).",
      "storeAs": "romLength",
      "validationRules": { "minValue": 1 }
    },
    {
      "type": "field",
      "name": "Cart Type",
      "offset": 53,
      "length": 1,
      "color": "#FFE66D",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Cartridge type byte at offset 53 indicating the ROM memory layout: 0=Normal ROM (linear), 1=SuperGame (512 KB banked), 2=SuperGame with RAM (banked + 16 KB RAM at 0x4000).",
      "storeAs": "cartType"
    },
    {
      "type": "field",
      "name": "Controller 1",
      "offset": 55,
      "length": 1,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Controller type for port 1 at offset 55: 0=Joystick, 1=Light gun, 2=Paddle, 3=Trackball, 4=Trak-Ball.",
      "storeAs": "controller1"
    },
    {
      "type": "field",
      "name": "Controller 2",
      "offset": 56,
      "length": 1,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Controller type for port 2 at offset 56. Same values as Controller 1.",
      "storeAs": "controller2"
    },
    {
      "type": "field",
      "name": "TV Type",
      "offset": 57,
      "length": 1,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "TV standard byte at offset 57: 0=NTSC (59.94 Hz, North America/Japan), 1=PAL (50 Hz, Europe). Used by emulators to set correct timing and colour palette.",
      "storeAs": "tvType",
      "validationRules": { "allowedValues": [0, 1] }
    },
    {
      "type": "field",
      "name": "Save Data Type",
      "offset": 58,
      "length": 1,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Save data device type at offset 58: 0=None, 1=High Score Cartridge (2 KB NVS RAM), 2=SaveKey or AtariVox (I2C EEPROM via joystick port).",
      "storeAs": "saveDataType"
    },
    {
      "type": "field",
      "name": "Reserved",
      "offset": 59,
      "length": 69,
      "color": "#E0E0E0",
      "opacity": 0.2,
      "valueType": "bytes",
      "hidden": true,
      "description": "69 reserved bytes at offsets 59-127 filling the 128-byte header to the ROM data boundary. Should be all 0x00."
    },
    {
      "type": "field",
      "name": "ROM Data Start",
      "offset": 128,
      "length": 4096,
      "color": "#95E1D3",
      "opacity": 0.25,
      "valueType": "ascii",
      "description": "Start of the Atari 7800 ROM code at offset 128, immediately following the fixed 128-byte A78 header. The full ROM length is given by the ROM Data Length field.",
      "storeAs": "romDataStart"
    },
    {
      "type": "metadata",
      "name": "Game Title",
      "variable": "gameTitle",
      "description": "Game name from A78 header"
    },
    {
      "type": "metadata",
      "name": "ROM Length",
      "variable": "romLength",
      "description": "ROM data size in bytes (after header)"
    },
    {
      "type": "metadata",
      "name": "TV Type",
      "variable": "tvType",
      "description": "0=NTSC, 1=PAL"
    }
  ],
  "assertions": [
    {
      "name": "ATARI7800 magic valid",
      "expression": "atari7800Magic == 'ATARI7800'",
      "severity": "error",
      "message": "A78 ROM must contain ASCII 'ATARI7800' at offset 1"
    },
    {
      "name": "ROM length positive",
      "expression": "romLength > 0",
      "severity": "error",
      "message": "A78 ROM data length must be greater than 0"
    },
    {
      "name": "TV type valid",
      "expression": "tvType == 0 || tvType == 1",
      "severity": "warning",
      "message": "TV type must be 0 (NTSC) or 1 (PAL)"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "A78 Header", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "Game Title", "offset": 16, "icon": "\uE71B", "color": "#4ECDC4" },
      { "name": "ROM Data", "offset": 128, "icon": "\uE71B", "color": "#95E1D3" }
    ]
  },
  "inspector": {
    "badge": "atari7800Magic",
    "primaryField": "gameTitle",
    "showQualityScore": true,
    "groups": [
      {
        "title": "A78 Header Identity",
        "icon": "\uE71B",

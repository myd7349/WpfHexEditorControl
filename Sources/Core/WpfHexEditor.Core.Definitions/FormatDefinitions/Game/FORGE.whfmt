  ],
  "forensic": {
    "category": "game",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Ubisoft FORGE format: 'scimago(NUL)'(8B) + version(4B LE) + fileSize(8B LE) + index table. Index table maps 8-byte resource UIDs to (offset, size, compressed size, type). Asset data compressed with zlib or LZ4. Game-specific parsing required — version number determines table layout. Tools: Blacksmith (GUI, AC Origins/Odyssey/Valhalla), Dunia Tools (Far Cry). QuickBMS scripts available for older AC titles.",
    "suggestedInspections": [
      "Bytes 0-7 (ASCII): 'scimago(NUL)' or 'scimago ' — Ubisoft FORGE magic",
      "Bytes 8-11 (uint32 LE): format version — determines parsing strategy",
      "Bytes 12-19 (uint64 LE): total file size in bytes",
      "Use Blacksmith tool for AC Origins/Odyssey/Valhalla FORGE files"
    ]
  },
  "software": [
    "Blacksmith (theawesomecoder61, GUI FORGE extractor for newer AC)",
    "Dunia Tools (FORGE extraction for Far Cry series)",
    "QuickBMS with Ubisoft FORGE script",
    "Ubisoft Modding Tools (official, limited release)"
  ],
  "formatRelationships": {
    "category": "Game",
    "extensions": [
      ".forge"
    ],
    "relatedFormats": [

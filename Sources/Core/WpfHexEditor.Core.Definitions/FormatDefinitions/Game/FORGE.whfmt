{
  "diffMode": "binary",
  "formatName": "Ubisoft FORGE Archive",
  "version": "1.16",
  "extensions": [
    ".forge"
  ],
  "description": "FORGE is the proprietary archive format used by Ubisoft's AnvilNext engine for games including Assassin's Creed series (AC3, Black Flag, Unity, Origins, Odyssey, Valhalla), Watch Dogs, and Far Cry series. FORGE files start with the magic 'scimago(NUL)' or 'scimago ' (ASCII at offset 0, 8 bytes). After the magic: formatVersion (uint32 LE at offset 8), fileSize (uint64 LE at offset 12), and an index table that maps resource IDs to file offsets. Assets inside FORGE may be Zlib/LZ4-compressed and are identified by 8-byte resource UIDs. The format evolved significantly across AC games — tools like Ubisoft's ForgeExtract or community tools are needed for specific game versions.",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Ubisoft FORGE format analysis — Assassin's Creed modding community"
    ],
    "WebLinks": [
      "https://github.com/theawesomecoder61/Blacksmith",
      "https://wiki.xentax.com/index.php/Ubisoft_Forge"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "7363696D61676F00",
        "offset": 0,
        "label": "'scimago(NUL)' — Ubisoft FORGE archive magic (null-terminated)",
        "weight": 1.0
      },
      {
        "value": "7363696D61676F20",
        "offset": 0,
        "label": "'scimago ' — Ubisoft FORGE archive magic (space variant)",
        "weight": 0.9
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.9,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": {
      "min": 4.0,
      "max": 7.5
    },
    "validation": {
      "minFileSize": 32,
      "maxSignatureOffset": 0,
      "note": "FORGE files start with 'scimago' followed by a null byte or space (8 bytes total). Format version at offset 8 varies by game."
    }
  },
  "variables": {
    "forgeMagic": "",
    "forgeVersion": 0,
    "forgeFileSize": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "FORGE Magic",
      "offset": 0,
      "length": 8,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "Ubisoft FORGE archive magic: 8 bytes 'scimago(NUL)' (0x73 0x63 0x69 0x6D 0x61 0x67 0x6F 0x00) or 'scimago ' (with trailing space). 'Scimago' is a reference to the Scimitar project name used internally at Ubisoft Montreal. Used in AnvilNext engine games: Assassin's Creed III through Valhalla, Watch Dogs 1/2, Far Cry 4/5, Ghost Recon Wildlands. Each FORGE file contains thousands of game assets indexed by unique 8-byte resource IDs.",
      "storeAs": "forgeMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Format Version",
      "offset": 8,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "FORGE format version as uint32 little-endian at offset 8. Version numbers correlate with game releases: earlier AC titles use lower version numbers, while AC Origins, Odyssey, and Valhalla use higher versions with extended resource metadata. The format version determines how the index table is parsed.",
      "storeAs": "forgeVersion",
      "valueType": "uint32",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "File Size",
      "offset": 12,
      "length": 8,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "Total FORGE archive file size as uint64 little-endian at offset 12. FORGE files can be very large (several GB each) as they contain entire game worlds' assets. AC games typically ship with 50-100+ FORGE files covering textures, meshes, animations, audio, and scripts.",
      "storeAs": "forgeFileSize",
      "valueType": "uint64",
      "endianness": "little"
    },
    {
      "type": "metadata",
      "name": "Magic",
      "variable": "forgeMagic",
      "description": "'scimago' — Ubisoft FORGE archive identifier"
    },
    {
      "type": "metadata",
      "name": "Version",
      "variable": "forgeVersion",
      "description": "FORGE format version number"
    },
    {
      "type": "metadata",
      "name": "File Size",
      "variable": "forgeFileSize",
      "description": "Total archive size in bytes"
    }
  ],
  "assertions": [
    {
      "name": "FORGE magic valid",
      "expression": "forgeMagic == 'scimago'",
      "severity": "error",
      "message": "FORGE archive must start with 'scimago' magic — not a valid Ubisoft FORGE archive"
    }
  ],
  "navigation": {
    "bookmarks": [

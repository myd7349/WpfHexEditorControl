{
  "diffMode": "binary",
  "formatName": "SNK Neo Geo Pocket ROM",
  "version": "1.0",
  "extensions": [ ".ngp", ".ngc" ],
  "description": "SNK Neo Geo Pocket and Neo Geo Pocket Color ROM image. No fixed binary magic — identified primarily by extension and header field values. Game title appears as a 12-byte ASCII string at offset 0. Fixed marker bytes at offsets 18-19 (0xAD, 0x01) serve as weak structural identifiers. NGP is the monochrome model (1998); NGC (Neo Geo Pocket Color) supports full color palette (1999). Both share the same ROM header format. Publisher code at offset 16.",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "LastUpdated": "2026-04-15",
  "preferredEditor": "HexEditor",
  "references": [
    "https://wiki.neogeopocket.com/index.php/ROM_Header",
    "https://www.zophar.net/fileuploads/2/10729yxtzd/ngp.txt"
  ],
  "detection": {
    "signatures": [
      {
        "value": "AD01",
        "offset": 18,
        "label": "Fixed header bytes 0xAD 0x01 at offsets 18-19 — weak structural marker in NGP/NGC ROM headers",
        "weight": 0.5
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.3,
    "Strength": "Weak"
  },
  "variables": {},
  "blocks": [
    {
      "name": "gameTitle",
      "offset": 0,
      "size": 12,
      "type": "ascii",
      "description": "Game title — 12-byte ASCII string at offset 0 containing the cartridge game name as programmed by the developer; right-padded with null bytes if the title is fewer than 12 characters long",
      "storeAs": "gameTitle"
    },
    {
      "name": "gameCode",
      "offset": 12,
      "size": 4,
      "type": "ascii",
      "description": "Game code — 4-byte ASCII product identifier at offset 12 assigned by SNK to uniquely identify this cartridge in their product catalog; format is typically alphanumeric",
      "storeAs": "gameCode"
    },
    {
      "name": "publisherCode",
      "offset": 16,
      "size": 2,
      "type": "uint16",
      "endian": "LE",
      "description": "Publisher code — 2-byte little-endian unsigned integer at offset 16 identifying the publisher or licensee; value 0x0000 indicates SNK as the publisher",
      "storeAs": "publisherCode"
    },
    {
      "name": "fixedMarker",
      "offset": 18,
      "size": 1,
      "type": "uint8",
      "description": "Fixed header marker byte — 1-byte value at offset 18 that is always 0xAD (173 decimal) in valid Neo Geo Pocket ROM headers; used as a weak structural check to distinguish NGP ROMs from random data",
      "storeAs": "fixedMarker"
    },
    {
      "name": "fixedMarker2",
      "offset": 19,
      "size": 1,
      "type": "uint8",
      "description": "Secondary fixed marker byte — 1-byte value at offset 19 that is always 0x01 in valid Neo Geo Pocket ROM headers; together with the byte at offset 18, forms a 2-byte structural marker 0xAD 0x01"
    }
  ],
  "assertions": [
    {
      "name": "FixedMarkerValid",
      "expression": "fixedMarker == 0xAD",
      "severity": "warning",
      "message": "Fixed marker byte at offset 18 should be 0xAD (173); value mismatch suggests this is not a valid Neo Geo Pocket ROM header"
    },
    {
      "name": "GameTitleReadable",
      "expression": "gameTitle != ''",
      "severity": "info",
      "message": "Game title at offset 0 appears empty; a valid NGP ROM should contain a non-empty ASCII title string in the header"
    }
  ],
  "navigation": {
    "anchors": [
      { "name": "ROM Header", "offset": 0, "size": 64, "description": "Neo Geo Pocket ROM header containing identity and metadata fields" },
      { "name": "ROM Code", "offset": 64, "size": -1, "description": "Executable ROM code and data following the header region" }
    ]
  },
  "inspector": {
    "badge": "NGP",
    "primaryField": "gameTitle",
    "showQualityScore": true,
    "groups": [
      {
        "name": "Identity",
        "fields": [ "gameTitle", "gameCode", "publisherCode" ]
      },
      {
        "name": "Structural Markers",
        "fields": [ "fixedMarker" ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "ROM Summary",
      "format": "text",
      "template": "SNK Neo Geo Pocket ROM\nTitle: {gameTitle}\nGame Code: {gameCode}\nPublisher Code: 0x{publisherCode:X4}\nFixed Marker: 0x{fixedMarker:X2}"
    },
    {
      "name": "Header CSV",
      "format": "csv",
      "template": "Field,Value\nGameTitle,{gameTitle}\nGameCode,{gameCode}\nPublisherCode,{publisherCode}\nFixedMarker,{fixedMarker}"
    }
  ],
  "forensic": {
    "riskLevel": "low",
    "notes": "SNK Neo Geo Pocket cartridge ROM image. Very small commercial library (~80 titles). Detection is weak due to no fixed binary magic. Extension is the primary discriminator."
  },
  "aiHints": {
    "analysisContext": "Neo Geo Pocket and Neo Geo Pocket Color ROMs share an identical header format. The .ngp extension indicates monochrome, .ngc indicates color. Weak detection — use the fixed marker 0xAD at offset 18 and the game title ASCII string as corroborating evidence.",
    "suggestedInspections": [
      "Check fixed marker byte at offset 18 for value 0xAD (173 decimal)",
      "Read game title ASCII string at offset 0 (12 bytes) for identification",
      "Inspect game code at offset 12 for the 4-character product identifier",
      "Check publisher code at offset 16 — 0x0000 indicates SNK first-party title",
      "Verify extension (.ngp vs .ngc) to distinguish monochrome from color hardware",
      "Cross-reference game code against the known NGP/NGC title catalog (~80 games)"
    ]
  },
  "software": [
    { "name": "Mednafen", "url": "https://mednafen.github.io/", "role": "emulator" },
    { "name": "RACE!", "url": "https://sourceforge.net/projects/race/", "role": "emulator" }
  ],
  "formatRelationships": [
    { "format": "ROM_LYNX", "relation": "similar era — both are late-1990s handheld cartridge ROM formats with small commercial libraries" }
  ],
  "MimeTypes": [ "application/x-ngp-rom", "application/x-ngc-rom" ],
  "UseCases": [
    "Game preservation of SNK Neo Geo Pocket cartridges",
    "Emulation and ROM research",
    "Distinguishing NGP (monochrome) from NGC (color) dumps"
  ],
  "QualityMetrics": {
    "CompletenessScore": 75,
    "DocumentationLevel": "detailed",
    "LastUpdated": "2026-04-15"
  },
  "TechnicalDetails": {
    "headerSize": 64,
    "magicOffset": 18,
    "magicBytes": "AD01",
    "endianness": "little-endian",
    "notes": "No conventional binary magic at offset 0. Detection relies on structural field values and file extension. The small game library (approximately 80 commercial titles) limits ambiguity."
  }
}

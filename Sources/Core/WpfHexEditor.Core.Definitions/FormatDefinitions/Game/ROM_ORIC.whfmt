  "aiHints": {
    "analysisContext": "Oric TAP: 256+ x 0x16 sync bytes + 0x16 (last sync) + file_type(1B: 0x00=BASIC, 0xFF=machine code) + auto_run(1B: 0x80=auto, 0x00=manual) + end_addr(2B BE) + start_addr(2B BE) + 0x00 + filename(up to 16B ASCII NUL-terminated) + data. ROM images: raw 16 KB or 48 KB binary. 6502A CPU at 1 MHz.",
    "suggestedInspections": [
      "Check first byte for 0x16 — if repeated, this is an Oric tape sync leader indicating a TAP tape image",
      "Skip all leading 0x16 sync bytes to find the file header: file_type (0x00=BASIC, 0xFF=machine code)",
      "Read file_type byte: 0x00=BASIC program, 0xFF=machine code; read auto_run byte: 0x80=auto-execute",
      "Read end_address (2B BE) and start_address (2B BE) to determine load range; filename follows at offset +5"
    ]
  },

{
  "diffMode": "binary",
  "formatName": "Oric Atmos Tape / ROM",
  "version": "1.0",
  "extensions": [".tap", ".oric", ".rom"],
  "description": "Tangerine Oric-1 / Oric Atmos tape image or ROM (Tangerine Computer Systems, 1983-1984). TAP format (used by the Euphoric emulator): the binary stream begins with 256 or more 0x16 sync bytes followed by a sync byte count indicator, then the file header block. File header structure: file_type (1B: 0x00=BASIC, 0xFF=machine code), auto_run (1B: 0x80=auto-run, 0x00=manual), end_address (2B big-endian), start_address (2B big-endian), then 0x00 byte, then filename (up to 16 bytes ASCII, NUL-terminated). Data bytes immediately follow the header. The Oric-1 uses a 6502A CPU at 1 MHz. The Oric Atmos (1984) improved the keyboard design; both have 16 KB or 48 KB RAM versions, AY-3-8912 3-channel PSG sound, and a 240x200 resolution mixed text/graphics display. The Oric was particularly popular in France and the UK. ROM images are raw 16 KB or 48 KB binary files containing the Oric BASIC ROM. Detection is primarily by extension due to the repeating 0x16 sync byte pattern being common.",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Oric TAP File Format — Euphoric Emulator Documentation",
      "Oric-1 / Oric Atmos Technical Reference Manual",
      "MOS 6502A CPU Reference Manual"
    ],
    "WebLinks": [
      "https://osdk.org/",
      "https://www.oric.org/",
      "https://en.wikipedia.org/wiki/Oric",
      "https://github.com/oric-software"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "16",
        "offset": 0,
        "label": "0x16 — Oric tape sync byte (repeated 256+ times at start of TAP file)",
        "weight": 0.3
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.1,
    "required": false,
    "Strength": "Weak",
    "validation": {
      "minFileSize": 256,
      "maxSignatureOffset": 1,
      "note": "Oric TAP files start with many 0x16 sync bytes before the actual data header. Detection is primarily by extension (.tap, .oric, .rom). ROM images are raw binary with no magic."
    }
  },
  "variables": {
    "syncByte": 0,
    "secondByte": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "Sync Byte",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "valueType": "uint8",
      "description": "First byte of the Oric TAP file. Should be 0x16 for tape image files (the standard sync/leader byte used by the Oric cassette interface). This byte is typically repeated 256 or more times as the tape lead-in before the actual file header appears. For raw ROM images, this is simply the first byte of the ROM code.",
      "storeAs": "syncByte"
    },
    {
      "type": "field",
      "name": "Second Byte",
      "offset": 1,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "valueType": "uint8",
      "description": "Second byte of the file. In an Oric TAP image this should also be 0x16 (continuing the sync leader). The transition from 0x16 sync bytes to the file header block 0x16 0x24 marker indicates the start of actual tape data.",
      "storeAs": "secondByte"
    },
    {
      "type": "metadata",
      "name": "Sync Byte",
      "variable": "syncByte",
      "description": "First byte (0x16=Oric sync byte)"
    },
    {
      "type": "metadata",
      "name": "Second Byte",
      "variable": "secondByte",
      "description": "Second byte (should also be 0x16 for TAP)"
    }
  ],
  "assertions": [
    {
      "name": "Sync byte pattern",
      "expression": "syncByte == 22",
      "severity": "warning",
      "message": "Oric TAP files should start with 0x16 (22 decimal) sync byte"
    }
  ],

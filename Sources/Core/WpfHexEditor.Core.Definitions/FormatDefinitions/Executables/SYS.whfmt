  "detection": {
    "signature": "4D5A",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 2,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "machineType": "",
    "sectionCount": 0,
    "timestamp": 0,
    "dosSignature": 0,
    "peHeaderOffset": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "DOS Signature",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "MZ DOS header",
      "storeAs": "dosSignature",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "PE Header Offset",
      "offset": 60,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Offset to PE header",
      "storeAs": "peHeaderOffset",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "Machine Type",
      "variable": "machineType",
      "description": "Machine Type"
    },
    {
      "type": "metadata",
      "name": "Section Count",
      "variable": "sectionCount",
      "description": "Section Count"
    }
  ],
  "software": [

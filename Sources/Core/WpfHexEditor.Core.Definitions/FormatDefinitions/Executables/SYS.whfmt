   ============================================================ */
{
  "diffMode": "binary",
  "formatName": "Windows System Driver",
  "version": "1.12",
  "extensions": [
    ".sys"
  ],
  "description": "Windows device driver file",
  "category": "Executables",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Portable Executable (PE) Format Specification",
      "Windows Driver Model (WDM) Architecture",
      "Kernel-Mode Driver Development"
    ],

{
  "diffMode": "binary",
  "formatName": "Windows Executable (PE)",
  "version": "2.02",
  "extensions": [
    ".exe",
    ".scr"
  ],
  "description": "Windows Portable Executable format. The PE format is the standard executable file format on Windows, consisting of a DOS MZ stub header followed by a PE signature, COFF file header, and Optional Header with data directories and section tables.",
  "category": "Executables",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Microsoft PE and COFF Specification",
      "Portable Executable Format",
      "Microsoft PE Format Documentation (rev 11.0)"
    ],
    "WebLinks": [
      "https://docs.microsoft.com/en-us/windows/win32/debug/pe-format",
      "https://en.wikipedia.org/wiki/Portable_Executable",
      "https://learn.microsoft.com/en-us/windows/win32/debug/pe-format"
    ]
  },
  "detection": {
    "signature": "4D5A",
    "offset": 0,
    "required": true,
    "validation": {
      "minFileSize": 64,
      "maxSignatureOffset": 0
    }
  },
  "variables": {
    "currentOffset": 0,
    "dosMzSignature": 0,
    "bytesOnLastPage": 0,
    "pagesInFile": 0,
    "relocations": 0,
    "headerParagraphs": 0,
    "minExtraParagraphs": 0,
    "maxExtraParagraphs": 0,
    "initialSs": 0,
    "initialSp": 0,
    "dosChecksum": 0,
    "initialIp": 0,
    "initialCs": 0,
    "relocTableOffset": 0,
    "overlayNumber": 0,
    "peHeaderOffset": 0,
    "peSignature": 0,
    "coffMachine": 0,
    "coffNumberOfSections": 0,
    "coffTimeDateStamp": 0,
    "coffPointerToSymbolTable": 0,
    "coffNumberOfSymbols": 0,
    "coffSizeOfOptionalHeader": 0,
    "coffCharacteristics": 0,
    "optionalMagic": 0,
    "majorLinkerVersion": 0,
    "minorLinkerVersion": 0,
    "sizeOfCode": 0,
    "sizeOfInitializedData": 0,
    "addressOfEntryPoint": 0,
    "headerSizeBytes": 0,
    "isDLL": false,
    "is64Bit": false,
    "machineName": "",
    "linkerVersionString": "",
    "peOffset": 0,
    "peMachineName": "",
    "peSubsystemName": "",
    "peIs64Bit": false,
    "peEntryPoint": 0,
    "peImageBase": 0,
    "peSectionCount": 0,
    "peMachine": 0
  },
  "functions": {
    "parsePEOptionalHeader(var:peHeaderOffset)": "Parse PE Optional Header including data directories and subsystem info",
    "formatFileSize(var:sizeOfCode)": "Format the code section size as human-readable string",
    "computeFromVariables(headerParagraphs * 16, headerSizeBytes)": "Calculate DOS header size in bytes from paragraph count",
    "computeFromVariables(majorLinkerVersion + '.' + minorLinkerVersion, linkerVersionString)": "Build linker version display string"
  },
  "blocks": [
    {
      "type": "signature",
      "name": "DOS MZ Signature",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "MZ magic bytes (0x5A4D LE) identifying a DOS executable stub",
      "storeAs": "dosMzSignature",
      "valueType": "uint16",
      "validation": {
        "expectedValue": "0x5A4D"
      }
    },
    {
      "type": "field",
      "name": "Bytes on Last Page",
      "offset": 2,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Number of bytes used on the last 512-byte page of the DOS executable (0 means entire page is used)",
      "storeAs": "bytesOnLastPage",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Pages in File",
      "offset": 4,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Total number of 512-byte pages in the DOS executable including the last partial page",
      "storeAs": "pagesInFile",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Relocations",
      "offset": 6,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Number of relocation entries in the DOS relocation table",
      "storeAs": "relocations",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Header Size in Paragraphs",
      "offset": 8,
      "length": 2,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "Size of the DOS header in 16-byte paragraphs (multiply by 16 for byte size)",
      "storeAs": "headerParagraphs",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Min Extra Paragraphs",
      "offset": 10,
      "length": 2,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Minimum number of extra 16-byte paragraphs of memory needed beyond the end of the program",
      "storeAs": "minExtraParagraphs",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Max Extra Paragraphs",
      "offset": 12,
      "length": 2,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Maximum number of extra 16-byte paragraphs of memory needed (0xFFFF = as much as available)",
      "storeAs": "maxExtraParagraphs",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Initial SS",
      "offset": 14,
      "length": 2,
      "color": "#FF6B9D",
      "opacity": 0.3,
      "description": "Initial stack segment value relative to the start of the loaded program",
      "storeAs": "initialSs",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Initial SP",
      "offset": 16,
      "length": 2,
      "color": "#C44569",
      "opacity": 0.3,
      "description": "Initial stack pointer value set when the DOS program begins execution",
      "storeAs": "initialSp",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "DOS Checksum",
      "offset": 18,
      "length": 2,
      "color": "#98D8C8",
      "opacity": 0.3,
      "description": "16-bit checksum of the DOS header (rarely verified, usually 0)",
      "storeAs": "dosChecksum",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Initial IP",
      "offset": 20,
      "length": 2,
      "color": "#A8E6CF",
      "opacity": 0.3,
      "description": "Initial instruction pointer value for the DOS stub entry point",
      "storeAs": "initialIp",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Initial CS",
      "offset": 22,
      "length": 2,
      "color": "#FFDDC1",
      "opacity": 0.3,
      "description": "Initial code segment value relative to the start of the loaded program",
      "storeAs": "initialCs",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Reloc Table Offset",
      "offset": 24,
      "length": 2,
      "color": "#FFC8DD",
      "opacity": 0.3,
      "description": "File offset of the DOS relocation table (0x40 or greater for PE files)",
      "storeAs": "relocTableOffset",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Overlay Number",
      "offset": 26,
      "length": 2,
      "color": "#BDB2FF",
      "opacity": 0.3,
      "description": "Overlay number for DOS overlay management (0 for the main executable)",
      "storeAs": "overlayNumber",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "PE Header Offset (e_lfanew)",
      "offset": 60,
      "length": 4,
      "color": "#FFC6FF",
      "opacity": 0.4,
      "description": "File offset to the PE signature (e_lfanew). Typical values are 0x80-0x100. This pointer bridges the DOS stub to the PE header.",
      "storeAs": "peHeaderOffset",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "PE Signature",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 0,
      "length": 4,
      "color": "#FF4444",
      "opacity": 0.4,
      "description": "PE\\0\\0 signature (0x00004550 LE) confirming this is a valid Portable Executable",
      "storeAs": "peSignature",
      "valueType": "uint32",
      "validation": {
        "expectedValue": "0x00004550"
      }
    },
    {
      "type": "field",
      "name": "COFF Machine",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 4,
      "length": 2,
      "color": "#45B7D1",
      "opacity": 0.3,
      "description": "Target machine architecture for this executable image",
      "storeAs": "coffMachine",
      "valueType": "uint16",
      "valueMap": {
        "0": "IMAGE_FILE_MACHINE_UNKNOWN",
        "332": "IMAGE_FILE_MACHINE_I386 (x86)",
        "512": "IMAGE_FILE_MACHINE_IA64 (Intel Itanium)",
        "34404": "IMAGE_FILE_MACHINE_AMD64 (x64)",
        "43620": "IMAGE_FILE_MACHINE_ARM64 (AArch64)",
        "452": "IMAGE_FILE_MACHINE_ARMNT (ARM Thumb-2 LE)"
      }
    },
    {
      "type": "field",
      "name": "Number of Sections",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 6,
      "length": 2,
      "color": "#96CEB4",
      "opacity": 0.3,
      "description": "Number of sections in the section table. Windows loader limits this to 96.",
      "storeAs": "coffNumberOfSections",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "TimeDateStamp",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 8,
      "length": 4,
      "color": "#FFEAA7",
      "opacity": 0.3,
      "description": "Unix epoch timestamp indicating when the image was created by the linker",
      "storeAs": "coffTimeDateStamp",
      "valueType": "unixtime32"
    },
    {
      "type": "field",
      "name": "Pointer to Symbol Table",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 12,
      "length": 4,
      "color": "#DDA0DD",
      "opacity": 0.3,
      "description": "File offset of the COFF symbol table (0 for PE images, used in COFF object files)",
      "storeAs": "coffPointerToSymbolTable",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Number of Symbols",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 16,
      "length": 4,
      "color": "#FF8C69",
      "opacity": 0.3,
      "description": "Number of entries in the COFF symbol table (0 for PE images)",
      "storeAs": "coffNumberOfSymbols",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Size of Optional Header",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 20,
      "length": 2,
      "color": "#87CEEB",
      "opacity": 0.3,
      "description": "Size of the Optional Header in bytes. Required for PE executables (typically 0xE0 for PE32, 0xF0 for PE32+).",
      "storeAs": "coffSizeOfOptionalHeader",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Characteristics",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 22,
      "length": 2,
      "color": "#F7DC6F",
      "opacity": 0.3,
      "description": "Flags indicating attributes of the PE file such as whether it is a DLL, executable, or supports large addresses",
      "storeAs": "coffCharacteristics",
      "valueType": "uint16",
      "bitfields": [
        {
          "bit": 0,
          "name": "RELOCS_STRIPPED",
          "description": "Relocation information was stripped from the file",
          "valueMap": {
            "0": "Relocations present",
            "1": "Relocations stripped"
          }
        },
        {
          "bit": 1,
          "name": "EXECUTABLE_IMAGE",
          "description": "File is a valid executable image (no unresolved external references)",
          "valueMap": {
            "0": "Not executable",
            "1": "Executable image"
          }
        },
        {
          "bit": 5,
          "name": "LARGE_ADDRESS_AWARE",
          "description": "Application can handle addresses larger than 2 GB",
          "valueMap": {
            "0": "Not large-address aware",
            "1": "Large-address aware"
          }
        },
        {
          "bit": 8,
          "name": "32BIT_MACHINE",
          "description": "Machine is based on a 32-bit word architecture",
          "valueMap": {
            "0": "Not 32-bit only",
            "1": "32-bit machine"
          }
        },
        {
          "bit": 9,
          "name": "DEBUG_STRIPPED",
          "description": "Debugging information has been removed from the image file",
          "valueMap": {
            "0": "Debug info may be present",
            "1": "Debug info stripped"
          }
        },
        {
          "bit": 13,
          "name": "DLL",
          "description": "Image is a Dynamic Link Library (DLL) rather than an executable program",
          "valueMap": {
            "0": "Not a DLL",
            "1": "DLL"
          }
        }
      ]
    },
    {
      "type": "field",
      "name": "Optional Header Magic",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 24,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.35,
      "description": "Magic number identifying the PE format variant: PE32 (32-bit) or PE32+ (64-bit)",
      "storeAs": "optionalMagic",
      "valueType": "uint16",
      "valueMap": {
        "267": "PE32 (32-bit executable)",
        "523": "PE32+ (64-bit executable)",
        "263": "ROM image"
      }
    },
    {
      "type": "field",
      "name": "Major Linker Version",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 26,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Major version number of the linker that produced the image",
      "storeAs": "majorLinkerVersion",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Minor Linker Version",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 27,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Minor version number of the linker that produced the image",
      "storeAs": "minorLinkerVersion",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Size of Code",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 28,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Total size of all code sections (.text) in bytes, rounded up to a multiple of FileAlignment",
      "storeAs": "sizeOfCode",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Size of Initialized Data",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 32,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Total size of all initialized data sections (.data, .rdata) in bytes",
      "storeAs": "sizeOfInitializedData",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Address of Entry Point",
      "offsetFrom": "peHeaderOffset",
      "offsetAdd": 40,
      "length": 4,
      "color": "#FF4444",
      "opacity": 0.35,
      "description": "Relative Virtual Address (RVA) of the entry point function. For executables this is the start address; for DLLs this is DllMain.",
      "storeAs": "addressOfEntryPoint",
      "valueType": "uint32"
    },
    {
      "type": "computeFromVariables",
      "name": "DOS Header Size (bytes)",
      "expression": "headerParagraphs * 16",
      "storeAs": "headerSizeBytes",
      "description": "Calculated size of the DOS header in bytes from the paragraph count (paragraphs x 16)"
    },
    {
      "type": "computeFromVariables",
      "name": "Section Table Offset",
      "expression": "peHeaderOffset + 24 + coffSizeOfOptionalHeader",
      "storeAs": "sectionTableOffset",
      "description": "Absolute file offset of the first PE section header"
    },
    {
      "type": "computeFromVariables",
      "name": "Is DLL Flag",
      "expression": "(coffCharacteristics & 8192) != 0",
      "storeAs": "isDLL",
      "description": "Determines if the PE file is a DLL by checking bit 13 of the COFF Characteristics flags"
    },
    {
      "type": "conditional",
      "name": "DLL Detection",
      "condition": "(coffCharacteristics & 8192) != 0",
      "trueLabel": "This file is a Dynamic Link Library (DLL)",
      "falseLabel": "This file is a standard executable (EXE)",
      "description": "Checks the DLL flag (bit 13) in COFF Characteristics to determine if the image is a DLL or EXE"
    },
    {
      "type": "conditional",
      "name": "PE Format Detection",
      "condition": "optionalMagic == 523",
      "trueLabel": "64-bit PE32+ executable",
      "falseLabel": "32-bit PE32 executable",
      "description": "Checks the Optional Header magic number to determine if this is a 32-bit (PE32, 0x10B) or 64-bit (PE32+, 0x20B) image"
    },
    {
      "type": "metadata",
      "name": "Machine Type",
      "variable": "coffMachine",
      "description": "Target CPU architecture for the PE image (e.g., x86, x64, ARM64)"
    },
    {
      "type": "metadata",
      "name": "Number of Sections",
      "variable": "coffNumberOfSections",
      "description": "Total number of sections defined in the PE section table"
    },
    {
      "type": "metadata",
      "name": "Is DLL",
      "variable": "isDLL",
      "description": "true if the PE image is a DLL, false if it is an executable"
    },
    {
      "type": "metadata",
      "name": "Is 64-bit",
      "variable": "peIs64Bit",
      "description": "true if PE32+ (64-bit image), false if PE32 (32-bit image)"
    },
    {
      "type": "metadata",
      "name": "Entry Point (RVA)",
      "variable": "addressOfEntryPoint",
      "description": "Relative Virtual Address of the program entry point"
    },
    {
      "type": "metadata",
      "name": "TimeDateStamp",
      "variable": "coffTimeDateStamp",
      "description": "Unix epoch timestamp when the PE image was linked"
    },
    {
      "type": "pointer",
      "name": "Follow e_lfanew",
      "targetVar": "peHeaderOffset",
      "label": "→ PE Header",
      "color": "#FFC6FF",
      "opacity": 0.4
    },
    {
      "type": "repeating",
      "name": "Section Table",
      "offsetFrom": "sectionTableOffset",
      "offsetAdd": 0,
      "count": "var:coffNumberOfSections",
      "maxIterations": 96,
      "entrySize": 40,
      "indexVar": "sectionIndex",
      "colorCycle": [
        "#FF6B6B",
        "#4ECDC4",
        "#FFE66D",
        "#95E1D3",
        "#FFA07A",
        "#A8E6CF",
        "#DDA0DD"
      ],
      "opacity": 0.2,
      "description": "PE Section [$iteration$]",
      "fields": [
        {
          "type": "field",
          "name": "Section Name",
          "offset": 0,
          "length": 8,
          "color": "#FF6B6B",
          "valueType": "ascii8",
          "storeAs": "sectionName",
          "opacity": 0.35
        },
        {
          "type": "field",
          "name": "Virtual Size",
          "offset": 8,
          "length": 4,
          "color": "#4ECDC4",
          "valueType": "uint32",
          "storeAs": "sectionVirtualSize",
          "opacity": 0.3
        },
        {
          "type": "field",
          "name": "Virtual Address",
          "offset": 12,
          "length": 4,
          "color": "#FFE66D",
          "valueType": "uint32",
          "storeAs": "sectionVirtualAddr",
          "opacity": 0.3
        },
        {
          "type": "field",
          "name": "Size of Raw Data",
          "offset": 16,
          "length": 4,
          "color": "#95E1D3",
          "valueType": "uint32",
          "storeAs": "sectionRawSize",
          "opacity": 0.3
        },
        {
          "type": "field",
          "name": "Ptr to Raw Data",
          "offset": 20,
          "length": 4,
          "color": "#FFA07A",
          "valueType": "uint32",
          "storeAs": "sectionRawOffset",
          "opacity": 0.3
        },
        {
          "type": "field",
          "name": "Characteristics",
          "offset": 36,
          "length": 4,
          "color": "#F7DC6F",
          "valueType": "uint32",
          "storeAs": "sectionCharacteristics",
          "opacity": 0.3
        }
      ]
    }
  ],
  "assertions": [
    {
      "name": "PE Signature valid",
      "expression": "peSignature == 17744",
      "severity": "error",
      "message": "Invalid PE signature — file may be corrupt or not a valid PE executable"
    },
    {
      "name": "Section count reasonable",
      "expression": "coffNumberOfSections <= 96",
      "severity": "warning",
      "message": "Section count exceeds Windows loader limit of 96"
    },
    {
      "name": "e_lfanew reasonable",
      "expression": "peHeaderOffset >= 64",
      "severity": "warning",
      "message": "e_lfanew < 64 — DOS header too small for a valid PE"
    }
  ],
    "navigation": {
    "bookmarks": [
      {
        "name": "DOS Header",
        "offset": 0,
        "icon": "\uE8A5",
        "color": "#4ECDC4"
      },
      {
        "name": "PE Header (e_lfanew)",
        "offsetVar": "peHeaderOffset",
        "icon": "\uE7EF",
        "color": "#FF6B6B"
      },
      {
        "name": "COFF Header",
        "offsetVar": "peHeaderOffset",
        "icon": "\uE8B7",
        "color": "#FFE66D"
      },
      {
        "name": "Section Table",
        "offsetVar": "sectionTableOffset",
        "icon": "\uE9D9",
        "color": "#C7CEEA"
      },
      {
        "name": "Entry Point",
        "offsetVar": "addressOfEntryPoint",
        "icon": "\uE72E",
        "color": "#FF4444"
      }
    ]
  },
  "inspector": {
    "badge": "peMachineName",
    "primaryField": "addressOfEntryPoint",
    "showQualityScore": true,
    "groups": [
      {
        "title": "DOS Header",
        "icon": "\uE8A5",
        "fields": ["dosMzSignature", "bytesOnLastPage", "pagesInFile", "relocations", "headerParagraphs", "initialSp", "dosChecksum", "peHeaderOffset"]
      },
      {
        "title": "COFF Header",
        "icon": "\uE7EF",
        "fields": ["peSignature", "coffMachine", "coffNumberOfSections", "coffTimeDateStamp", "coffSizeOfOptionalHeader", "coffCharacteristics"]
      },
      {
        "title": "Optional Header",
        "icon": "\uE946",
        "fields": ["optionalMagic", "majorLinkerVersion", "minorLinkerVersion", "sizeOfCode", "sizeOfInitializedData", "addressOfEntryPoint"]
      },
      {
        "title": "Derived Properties",
        "icon": "\uE72E",
        "fields": ["isDLL", "is64Bit", "headerSizeBytes", "sectionTableOffset"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "PE Header Summary (JSON)",
      "format": "json",
      "fields": ["dosMzSignature", "peHeaderOffset", "coffMachine", "coffNumberOfSections", "coffTimeDateStamp", "coffCharacteristics", "optionalMagic", "addressOfEntryPoint", "isDLL", "is64Bit"]
    },
    {
      "name": "Section Table (CSV)",
      "format": "csv",
      "source": "repeating:Section Table",
      "columns": ["sectionName", "sectionVirtualSize", "sectionVirtualAddr", "sectionRawSize", "sectionRawOffset", "sectionCharacteristics"]
    },
    {
      "name": "IMAGE_FILE_HEADER (C struct)",
      "format": "c-struct",
      "structName": "IMAGE_FILE_HEADER",
      "fields": ["coffMachine", "coffNumberOfSections", "coffTimeDateStamp", "coffPointerToSymbolTable", "coffNumberOfSymbols", "coffSizeOfOptionalHeader", "coffCharacteristics"]
    },
    {
      "name": "Python PE magic check",
      "format": "python-bytes",
      "fields": ["dosMzSignature", "peSignature", "optionalMagic", "coffMachine"]
    }
  ],
  "forensic": {
    "category": "executable",
    "riskLevel": "high",
    "suspiciousPatterns": [
      {
        "name": "Invalid e_lfanew",
        "condition": "peHeaderOffset < 64 || peHeaderOffset > 4096",
        "severity": "error",
        "description": "e_lfanew points outside the typical DOS header range -- possible corruption or packer tool"
      },
      {
        "name": "Empty code section",
        "condition": "sizeOfCode == 0",
        "severity": "warning",
        "description": "SizeOfCode is 0 -- may indicate a packed or hollowed executable where code has been removed from the header record"
      },
      {
        "name": "Zero section count",
        "condition": "coffNumberOfSections == 0",
        "severity": "error",
        "description": "No sections defined -- highly unusual for a valid PE image, indicates corruption or crafted file"
      },
      {
        "name": "Anomalous TimeDateStamp",
        "condition": "coffTimeDateStamp < 631152000 || coffTimeDateStamp > 2524608000",
        "severity": "warning",
        "description": "TimeDateStamp is before 1990 or after 2050 -- values outside this range indicate forging, zeroing, or max-value (0xFFFFFFFF) stamping common in malware"
      },
      {
        "name": "Suspicious section count",
        "condition": "coffNumberOfSections > 20",
        "severity": "warning",
        "description": "More than 20 sections is unusual -- typical PE has 4-8. High counts are common in packers and PE analysis evasion tools."
      },
      {
        "name": "Code-only binary (no data sections)",
        "condition": "sizeOfCode > 0 && sizeOfInitializedData == 0",
        "severity": "info",
        "description": "No initialized data section -- may indicate code-only packed binary or unusual linker output"
      }
    ],
    "knownExploitVectors": [
      "DLL hijacking -- replacing a legitimate DLL in the load path",
      "PE header manipulation to bypass AV signature scanning",
      "Entry point shellcode injection (EP patching)",
      "Section injection via expanded section raw size",
      "Import table poisoning (IAT hooking)"
    ]
  },
  "aiHints": {
    "analysisContext": "Windows PE is the primary executable format. Structure: DOS header (64 bytes) + DOS stub + PE signature at e_lfanew + COFF header (20 bytes) + Optional header (224/240 bytes PE32/PE32+) + Section table. Key fields: coffTimeDateStamp (may be zeroed/forged), optionalMagic (PE32 vs PE32+), coffCharacteristics DLL bit, addressOfEntryPoint. High section entropy (>7.2) suggests packing. Absent or minimal import table also suggests packing.",
    "knownVulnerabilities": [
      "Integer overflow in SizeOfOptionalHeader parsing allows bypassing section table bounds",
      "e_lfanew manipulation can cause parsers to read crafted data as COFF header",
      "Signed PE abuse: SIP hijacking for Authenticode bypass",
      "Overlay data after last section -- common carrier for second-stage payloads"
    ],
    "suggestedInspections": [
      "Verify coffTimeDateStamp is within 1990-2050 range -- zero or future dates indicate manipulation",
      "Check sizeOfCode vs total file size -- ratio < 10% suggests packed executable",
      "Inspect coffCharacteristics bit 13 (DLL) -- mismatch between extension and DLL flag is suspicious",
      "Review import table for: VirtualAlloc+WriteProcessMemory+CreateRemoteThread combo (injection)",
      "Check for overlay data: bytes after the last section raw end offset",
      "Verify no section RawOffset + RawSize extends beyond file size (truncated PE)"
    ]
  },

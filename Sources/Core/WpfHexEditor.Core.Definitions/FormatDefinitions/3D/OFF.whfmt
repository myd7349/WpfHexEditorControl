{
  "diffMode": "binary",
  "formatName": "Object File Format",
  "version": "1.15",
  "extensions": [
    ".off"
  ],
  "description": "Object File Format (OFF) is a simple text-based 3D polygon mesh format developed by Geomview. An OFF file begins with the keyword 'OFF' on the first line followed by a newline, then a count line specifying the number of vertices, faces, and edges, followed by vertex coordinates (one per line, 3 floats), and face definitions (starting with the vertex count followed by vertex indices). Optional header variants include COFF (with color), NOFF (with normals), and CNOFF (both). OFF is widely used in computational geometry and mesh processing research.",
  "category": "3D",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Geomview OFF File Format Reference"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/OFF_(file_format)",
      "https://segeval.cs.princeton.edu/public/off_format.html",
      "https://wiki.fileformat.com/3d/off/"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "4F46460A", "offset": 0, "label": "'OFF\\n' header signature", "weight": 0.8 },
      { "value": "4F464620", "offset": 0, "label": "'OFF ' header (space variant)", "weight": 0.6 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.6,
    "required": true,
    "Strength": "Medium",
    "EntropyHint": { "min": 2.5, "max": 5.5 },
    "validation": {
      "minFileSize": 8,
      "maxSignatureOffset": 0,
      "note": "First 3 bytes must be 'OFF' followed by newline or space. Optional prefixes COFF/NOFF also valid."
    }
  },
  "variables": {
    "offHeader": "",
    "countLine": "",
    "vertexCount": 0,
    "faceCount": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "OFF Header Keyword",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "4-byte ASCII string 'OFF\\n' (0x4F 0x46 0x46 0x0A) that opens every standard OFF file. The keyword 'OFF' identifies the format; the newline terminates the first line. Variants COFF, NOFF, CNOFF are also valid first lines.",
      "storeAs": "offHeader",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Count Line",
      "offset": 4,
      "length": 32,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Second line of the OFF file containing three space-separated integers: vertex count, face count, and edge count (edge count is optional and often 0). These values define the expected data block sizes.",
      "storeAs": "countLine",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "First Vertex Line",
      "offset": 36,
      "length": 48,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "Region containing the first vertex position line in the OFF file. Each vertex line has three floating-point coordinates X, Y, Z separated by spaces. Optional additional floats may represent RGBA color (COFF variant).",
      "storeAs": "vertexCount",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Face Data Region",
      "offset": 84,
      "length": 64,
      "color": "#FFE66D",
      "opacity": 0.35,
      "description": "Region of the file containing face definitions. Each face line begins with the number of vertices in the face followed by the zero-based vertex indices. Triangular faces start with 3, quads with 4, n-gons with their vertex count.",
      "storeAs": "faceCount",
      "valueType": "ascii"
    }
  ],
  "assertions": [
    {
      "name": "ValidOffHeader",
      "expression": "offHeader == 'OFF\\n' || offHeader == 'OFF '",
      "severity": "error",
      "message": "File does not begin with 'OFF' keyword. This is not a valid OFF file. Check for COFF or NOFF variants which begin with those prefixes instead."
    },
    {
      "name": "TextFile",
      "expression": "true",
      "severity": "warning",
      "message": "OFF is a text-based format. Ensure the file uses consistent line endings (LF or CRLF) as some parsers are sensitive to mixed line endings."
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "OFF Header", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "Counts Line", "offset": 4, "icon": "\uE946", "color": "#4ECDC4" },
      { "name": "Vertex Data", "offset": 36, "icon": "\uE8B7", "color": "#95E1D3" }
    ]
  },
  "inspector": {
    "badge": "offHeader",
    "primaryField": "countLine",
    "showQualityScore": true,
    "groups": [
      {
        "title": "File Header",
        "icon": "\uE71B",
        "fields": ["offHeader", "countLine"]
      },
      {
        "title": "Geometry Data",
        "icon": "\uE8B7",
        "fields": ["vertexCount", "faceCount"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "OFF Header (JSON)",
      "format": "json",
      "fields": ["offHeader", "countLine"]
    }
  ],
  "software": [
    "Geomview",
    "MeshLab",
    "Blender",
    "CGAL",
    "OpenMesh"
  ],
  "formatRelationships": {
    "category": "3D",
    "extensions": [".off"],
    "relatedFormats": ["PLY", "OBJ", "STL"],
    "note": "Simple text polygon format used in computational geometry research; variants include COFF, NOFF, CNOFF"
  },
  "MimeTypes": [
    "application/octet-stream",
    "text/plain"
  ],
  "UseCases": [

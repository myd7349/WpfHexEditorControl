    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Geomview Object File Format — simple ASCII polygon mesh starting with 'OFF' keyword. Second line has vertex/face/edge counts. Widely used in computational geometry research and mesh processing tools.",
    "suggestedInspections": [
      "Verify 'OFF' keyword on first line and check for variant prefixes like COFF or NOFF",
      "Parse the count line (second line) to determine mesh complexity",
      "Examine vertex and face data for consistency with the declared vertex and face counts"
    ]
  }

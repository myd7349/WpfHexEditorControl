    "BlocksDefined": 6,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "encoding": "binary-little-endian",
    "magicLength": 23,
    "nodeOffsetSize": "32-bit for version < 7500, 64-bit for version >= 7500",
    "asciiVariant": "starts with '; FBX' comment (no binary magic)",
    "propertyTypes": ["Y=int16", "C=bool", "I=int32", "F=float32", "D=float64", "L=int64", "f/d/l/i/b=typed arrays", "S=string", "R=raw"]
  }
}

    "extensions": [".fbx"],
    "relatedFormats": ["GLB", "USD", "COLLADA", "OBJ"],
    "note": "Proprietary binary format; de-facto game industry standard; glTF 2.0 is the open web-focused alternative"
  },
  "MimeTypes": ["application/octet-stream", "model/fbx"],
  "UseCases": [
    "Game engine 3D asset import/export (Unity, Unreal Engine)",
    "DCC tool interchange between Maya, 3ds Max, and Blender",
    "Character animation transfer with skeleton and blend shapes",
    "Film and VFX production asset delivery pipelines"
  ],
  "QualityMetrics": {

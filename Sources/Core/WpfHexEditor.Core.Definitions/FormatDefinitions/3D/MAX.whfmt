{
  "diffMode": "binary",
  "formatName": "3ds Max",
  "version": "1.15",
  "extensions": [
    ".max"
  ],
  "description": "Autodesk 3ds Max native scene file stored in an OLE2 Compound Document (Structured Storage) container — the same binary container format used by legacy Microsoft Office documents. The file begins with the standard OLE2 magic bytes D0 CF 11 E0 A1 B1 1A E1. Inside the container, 3ds Max stores its scene data in named streams. Detection requires noting that OLE2 magic is shared with .doc, .xls, and .ppt files; disambiguation relies on file extension or internal stream names. The format supports full 3ds Max scenes with geometry, modifiers, materials, lights, cameras, and animation.",
  "category": "3D",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Microsoft Compound File Binary Format (OLE2)",
      "Autodesk 3ds Max SDK Documentation"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/3ds_Max",
      "https://learn.microsoft.com/en-us/openspecs/windows_protocols/ms-cfb/",
      "https://wiki.fileformat.com/3d/max/"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "D0CF11E0A1B11AE1", "offset": 0, "label": "OLE2 Compound Document magic", "weight": 0.7 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.6,
    "required": true,
    "Strength": "Medium",
    "EntropyHint": { "min": 4.0, "max": 7.5 },
    "validation": {
      "minFileSize": 512,
      "maxSignatureOffset": 0,
      "note": "OLE2 magic is shared with .doc/.xls/.ppt. Disambiguation requires .max extension or checking internal stream names for 3ds Max identifiers."
    }
  },
  "variables": {
    "ole2Magic": "",
    "minorVersion": 0,
    "majorVersion": 0,
    "byteOrder": 0,
    "sectorSize": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "OLE2 Magic",
      "offset": 0,
      "length": 8,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "8-byte OLE2 Compound Document magic bytes D0 CF 11 E0 A1 B1 1A E1. This signature identifies any OLE2 structured storage container, including 3ds Max .max files, legacy Office documents, and other OLE2-based formats.",
      "storeAs": "ole2Magic",
      "valueType": "bytes"
    },
    {
      "type": "field",
      "name": "Minor Version",
      "offset": 24,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "OLE2 compound file minor version number at offset 24, stored as little-endian uint16. Typically 0x003E for standard compound files. Used by parsers to select compatible reading strategy.",
      "storeAs": "minorVersion",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Major Version",
      "offset": 26,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "OLE2 compound file major version number at offset 26, stored as little-endian uint16. Value 3 uses 512-byte sectors; value 4 uses 4096-byte mini-sectors. Determines the FAT sector layout.",
      "storeAs": "majorVersion",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Byte Order Mark",
      "offset": 28,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.35,
      "description": "Byte order identifier at offset 28. Value 0xFFFE indicates little-endian byte order (standard for all modern OLE2 files). Big-endian (0xFEFF) is theoretically defined but not used in practice.",
      "storeAs": "byteOrder",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Sector Size Power",
      "offset": 30,
      "length": 2,
      "color": "#C3A6FF",
      "opacity": 0.35,
      "description": "Sector size as a power of 2 at offset 30. Value 9 means 512-byte sectors (standard for version 3), value 12 means 4096-byte sectors (version 4). Determines the granularity of FAT allocation.",
      "storeAs": "sectorSize",
      "valueType": "uint16"
    }
  ],
  "assertions": [
    {
      "name": "ValidOle2Magic",
      "expression": "ole2Magic == 'D0CF11E0A1B11AE1'",
      "severity": "error",
      "message": "OLE2 magic bytes not found. This is not a valid OLE2 Compound Document container. The .max file may be corrupt or not a 3ds Max scene file."
    },
    {
      "name": "ValidByteOrder",
      "expression": "byteOrder == 0xFFFE",
      "severity": "warning",
      "message": "Byte order mark is not 0xFFFE (little-endian). Unexpected byte order in OLE2 container; file may be malformed."
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "OLE2 Header", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "Version Fields", "offset": 24, "icon": "\uE946", "color": "#4ECDC4" },
      { "name": "FAT Parameters", "offset": 28, "icon": "\uE8B7", "color": "#FFE66D" }
    ]
  },
  "inspector": {
    "badge": "majorVersion",
    "primaryField": "minorVersion",
    "showQualityScore": true,
    "groups": [
      {
        "title": "OLE2 Container",
        "icon": "\uE71B",
        "fields": ["ole2Magic", "minorVersion", "majorVersion"]
      },
      {
        "title": "Sector Layout",
        "icon": "\uE8B7",
        "fields": ["byteOrder", "sectorSize"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "MAX/OLE2 Header (JSON)",
      "format": "json",
      "fields": ["ole2Magic", "minorVersion", "majorVersion", "byteOrder", "sectorSize"]
    }
  ],
  "software": [
    "Autodesk 3ds Max"
  ],
  "formatRelationships": {
    "category": "3D",
    "extensions": [".max"],
    "relatedFormats": ["3DS", "FBX", "OBJ"],
    "note": "OLE2 magic shared with legacy Office formats; disambiguation by extension or internal stream names"
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "UseCases": [
    "3D scene authoring in 3ds Max",
    "Architectural visualization",
    "Game asset creation",
    "VFX scene storage"
  ],
  "QualityMetrics": {
    "CompletenessScore": 60,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 5,
    "ValidationRules": 2,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "container": "OLE2 Compound Document",
    "encoding": "binary-little-endian",
    "sectorBased": true,
    "sharedMagicWith": ["DOC", "XLS", "PPT"]
  },
  "forensic": {
    "category": "3d",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Autodesk 3ds Max scene file using OLE2 Compound Document container. Same magic as legacy Office files. Scene data stored in named internal streams. Sector size varies by OLE2 version.",
    "suggestedInspections": [
      "Confirm OLE2 magic and read major version to determine sector size (512 or 4096 bytes)",
      "Parse the directory stream to enumerate internal stream names and identify Max-specific streams",
      "Note that the OLE2 magic alone does not confirm .max — file extension is required for disambiguation"
    ]
  }
}

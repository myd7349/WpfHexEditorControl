  },
  "TechnicalDetails": {
    "encoding": "binary-proprietary",
    "specification": "undocumented",
    "detectionMethod": "extension + heuristic"
  },
  "forensic": {
    "category": "3d",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Proprietary Maxon Cinema 4D binary scene format with no public specification. Detection relies on file extension and weak byte heuristics. Full parsing requires the Maxon SDK.",
    "suggestedInspections": [
      "Identify file by extension since no reliable public magic bytes are documented",
      "Inspect first 128 bytes for recognizable string patterns such as 'MAXON' or 'C4D'",
      "Note that the format is proprietary; report only structural observations without assuming field semantics"
    ]
  }
}

    "ContainerFormat": "RIFF/AVI (Audio Video Interleaved)",
    "Endianness": "little-endian (all RIFF chunk sizes and AVI fields)",
    "VideoCodec": "MPEG-4 Part 2 ASP (FourCC: DIVX/DX50/DX40/DIV3)",
    "AudioCodecs": "MP3, AC-3, AAC (in later DivX versions)"
  }

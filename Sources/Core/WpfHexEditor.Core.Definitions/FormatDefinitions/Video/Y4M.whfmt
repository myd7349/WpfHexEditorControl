{
  "diffMode": "binary",
  "formatName": "YUV4MPEG2",
  "version": "2.32",
  "extensions": [
    ".y4m"
  ],
  "description": "YUV4MPEG2 (Y4M) is an uncompressed video container format used by the mjpegtools project and widely adopted by codec testing tools (x264, x265, FFmpeg, libaom). The file begins with an ASCII text header starting with 'YUV4MPEG2' followed by space-separated parameter tags (each a letter + value): W=width, H=height, F=frame_rate (numerator:denominator), I=interlacing (p=progressive, t=top-first, b=bottom-first), A=aspect_ratio (width:height), C=colorspace (420, 422, 444, mono). The header ends with a newline (0x0A). Each frame is preceded by the ASCII string 'FRAME' followed by optional frame parameters and a newline. Frame data is raw YCbCr planar data (Y plane first, then Cb, then Cr). Y4M provides lossless, exact uncompressed video for codec input/output comparison and quality analysis.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "YUV4MPEG2 Stream Format — mjpegtools project",
      "Y4M Format Documentation — wiki.multimedia.cx"
    ],
    "WebLinks": [
      "https://wiki.multimedia.cx/index.php/YUV4MPEG2",
      "https://linux.die.net/man/5/yuv4mpeg",
      "https://manpages.ubuntu.com/manpages/jammy/man5/yuv4mpeg.5.html"
    ]
  },
  "detection": {

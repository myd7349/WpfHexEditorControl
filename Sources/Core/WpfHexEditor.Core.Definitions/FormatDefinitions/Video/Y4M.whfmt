  "blocks": [
    {
      "type": "signature",
      "name": "Y4M Signature",
      "offset": 0,
      "length": 9,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "YUV4MPEG2 file signature: ASCII text 'YUV4MPEG2' (0x59 0x55 0x56 0x34 0x4D 0x50 0x45 0x47 0x32). This 9-byte ASCII header uniquely identifies Y4M uncompressed video files. Unlike binary formats, Y4M uses a human-readable text header for all parameters, making it easily inspectable in a text editor. The '4' in 'YUV4MPEG2' refers to YCbCr 4:x:x sampling; 'MPEG2' is the version identifier of this container format, not a reference to MPEG-2 video compression.",
      "storeAs": "y4mHeader",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Header Space Separator",
      "offset": 9,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.25,
      "description": "ASCII space (0x20) separating the signature from the first parameter tag. Y4M header is entirely ASCII text until the first 0x0A newline.",
      "storeAs": "videoWidth",
      "valueType": "uint8"
    },
    {
      "type": "metadata",
      "name": "Y4M Signature",

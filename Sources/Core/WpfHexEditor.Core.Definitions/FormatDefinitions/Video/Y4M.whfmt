  "aiHints": {
    "analysisContext": "Y4M header is plain ASCII until first 0x0A. Format: 'YUV4MPEG2 W<width> H<height> F<num>:<den> I<p|t|b|m> A<w>:<h> C<420|422|444|mono>\\n'. Example: 'YUV4MPEG2 W1920 H1080 F30:1 Ip A0:0 C420\\n'. After header: frames as 'FRAME\\n' + raw YCbCr planes. Frame size: Y plane = W×H, Cb = W/2×H/2 (4:2:0), Cr = same. Total frame size 4:2:0: W×H×1.5 bytes. FFmpeg output: ffmpeg -i input.mp4 output.y4m. Used by x264/x265 as input for quality testing. Very large files — 1920×1080 @30fps = ~178 MB/s.",
    "suggestedInspections": [
      "Read first line (until 0x0A): 'YUV4MPEG2 W<w> H<h> F<n>:<d> I<x> ...'",
      "Parse W= tag for width, H= tag for height",
      "Parse C= tag: '420' (most common), '422', '444', 'mono'",
      "First frame at (header_length+1): 'FRAME' + optional params + 0x0A + raw pixels"
    ]
  },
  "software": [

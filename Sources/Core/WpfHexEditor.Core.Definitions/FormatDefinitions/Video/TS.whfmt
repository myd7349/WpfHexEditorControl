    "AutoRefined": false
  },
  "TechnicalDetails": {
    "VideoFormat": true,
    "Endianness": "big-endian (all multi-bit fields in header)",
    "PacketSize": "188 bytes (TS) or 192 bytes (M2TS/MTS)",
    "SyncByte": "0x47 every 188 bytes",
    "PIDRange": "0x0000-0x1FFF (13 bits)",
    "MaxBitrate": "Theoretical unlimited; practical DVB-T2 up to 50 Mbps"
  }

{
  "diffMode": "binary",
  "formatName": "WebM Video",
  "version": "1.0",
  "extensions": [".webm"],
  "description": "WebM is an open, royalty-free media container format based on a subset of the Matroska container. Both WebM and Matroska use the EBML (Extensible Binary Meta Language) binary XML encoding, identified by the 4-byte element ID 1A 45 DF A3. WebM restricts the codec set to VP8, VP9, or AV1 for video and Vorbis or Opus for audio. The EBML header element is followed by a Segment element containing Cluster, Track, and Info elements. WebM is the primary video format for the HTML5 video element and is designed for efficient web delivery with low seek latency via WebM cues.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": {
    "specifications": [
      "WebM Container Guidelines — WebM Project (webmproject.org)",
      "EBML Specification: RFC 8794 — Extensible Binary Meta Language"
    ],
    "WebLinks": [
      "https://www.webmproject.org/",
      "https://en.wikipedia.org/wiki/WebM"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "1A45DFA3",
        "offset": 0,
        "label": "EBML element ID — header for WebM and Matroska containers",
        "weight": 1.0
      }
    ],
    "matchMode": "First",
    "MinimumScore": 0.9,
    "required": ["EBML element ID — header for WebM and Matroska containers"],
    "Strength": "Strong",
    "EntropyHint": {
      "min": 5.0,
      "max": 8.0,
      "comment": "VP8/VP9/AV1 compressed video exhibits high entropy"
    },
    "validation": {
      "notes": "EBML header at offset 0 must be 1A45DFA3; DocType string within EBML header must be 'webm' for WebM files (vs 'matroska' for MKV)"
    }
  },
  "variables": {
    "ebmlId": "",
    "ebmlSize": 0,
    "ebmlVersion": 0,
    "docTypeSize": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "ebmlId",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "EBML Document Type Header element ID — 0x1A45DFA3; this 4-byte Class D EBML element ID is universal across all EBML-based formats including WebM and Matroska; identical to MKV header",
      "storeAs": "ebmlId",
      "valueType": "bytes"
    },
    {
      "type": "field",
      "name": "ebmlSize",
      "offset": 4,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.75,
      "description": "EBML variable-length size byte for the EBML Header element — VINT encoded; first byte determines how many bytes the size occupies based on leading zeros; typical EBML headers are 26-35 bytes",
      "storeAs": "ebmlSize",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "ebmlVersion",
      "offset": 5,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.75,
      "description": "First byte of EBML header payload — begins with EBML sub-elements; the EBMLVersion element (ID 0x4286) typically appears here identifying the EBML specification version used (always 1 for WebM)",
      "storeAs": "ebmlVersion",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "docTypeSize",
      "offset": 6,
      "length": 1,
      "color": "#FFE66D",
      "opacity": 0.75,
      "description": "Continuation of EBML header payload — contains DocType sub-element; DocType string identifies container type as 'webm' for WebM files or 'matroska' for MKV files; this byte begins the EBMLVersion or DocType sub-element ID",
      "storeAs": "docTypeSize",
      "valueType": "uint8"
    }
  ],
  "assertions": [
    {
      "field": "ebmlId",
      "op": "eq",
      "value": "1A45DFA3",
      "message": "EBML element ID must be 0x1A45DFA3"
    },
    {
      "field": "ebmlSize",
      "op": "gte",
      "value": 1,
      "message": "EBML size field must be present"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "EBML Header ID", "offset": 0, "length": 4, "color": "#FF6B6B" },
      { "name": "EBML Size VINT", "offset": 4, "length": 1, "color": "#4ECDC4" },
      { "name": "EBML Version Sub-element", "offset": 5, "length": 1, "color": "#95E1D3" },
      { "name": "DocType Region", "offset": 6, "length": 1, "color": "#FFE66D" }
    ]
  },
  "inspector": {
    "badge": "WEBM",
    "primaryField": "ebmlId",
    "showQualityScore": true,
    "groups": [
      {
        "name": "EBML Header",
        "fields": ["ebmlId", "ebmlSize"]
      },
      {
        "name": "DocType",
        "fields": ["ebmlVersion", "docTypeSize"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "WebM Header Summary",
      "format": "text",
      "template": "EBML ID: {ebmlId} | Size: {ebmlSize} | Version byte: {ebmlVersion}"
    },
    {
      "name": "WebM JSON Report",
      "format": "json",
      "template": "{ \"ebmlId\": \"{ebmlId}\", \"ebmlSize\": {ebmlSize} }"
    }
  ],
  "forensic": {
    "category": "Video",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "DocType 'matroska' in file with .webm extension indicates mis-labeled Matroska",
      "Missing Cues element indicates no seek table; may cause browser buffering issues",
      "VP9/AV1 with wrong DocType claims may indicate file manipulation"
    ]
  },
  "aiHints": {
    "analysisContext": "WebM is a restricted subset of Matroska. Both use EBML ID 0x1A45DFA3 for the header. WebM DocType string is 'webm'; Matroska uses 'matroska'. After the EBML header, the Segment element (ID 0x18538067) contains all media data. WebM mandates VP8/VP9/AV1 video and Vorbis/Opus audio only.",
    "suggestedInspections": [
      "Verify EBML ID 0x1A45DFA3 at offset 0 for EBML container identification",
      "Decode VINT-encoded size at offset 4 to find EBML header payload extent",
      "Read DocType element (ID 0x4282) string: 'webm' vs 'matroska' distinguishes format",
      "Locate Segment element (0x18538067) after EBML header for media data access",
      "Parse Segment Info (0x1549A966) for duration, title, MuxingApp, WritingApp",
      "Find Tracks (0x1654AE6B) element to enumerate video/audio track codec IDs"
    ]
  },
  "software": [
    "FFmpeg",
    "VLC Media Player",
    "Chrome / Firefox (native HTML5)",
    "libwebm (Google)",
    "HandBrake",
    "OBS Studio"
  ],
  "formatRelationships": {
    "category": "Video",
    "extensions": [".webm"],
    "relatedFormats": ["MKV", "MKA", "VP8", "VP9", "AV1", "Opus"],
    "note": "WebM is a restricted Matroska subset; all WebM files are valid Matroska but not vice versa; DocType string 'webm' vs 'matroska' is the key distinction"
  },
  "MimeTypes": ["video/webm", "audio/webm"],
  "UseCases": [
    "HTML5 web video embedding (Chrome, Firefox)",
    "YouTube VP9 video delivery",
    "Open source video platform hosting",
    "WebRTC video recording",
    "Royalty-free streaming video"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 4,
    "ValidationRules": 2,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "containerBase": "EBML (Extensible Binary Meta Language) / Matroska subset",
    "ebmlHeaderId": "0x1A45DFA3",
    "docType": "webm",
    "allowedVideoCodecs": ["VP8", "VP9", "AV1"],
    "allowedAudioCodecs": ["Vorbis", "Opus"],
    "royaltyFree": true
  }
}

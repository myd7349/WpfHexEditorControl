{
  "diffMode": "binary",
  "formatName": "3GPP Multimedia",
  "version": "1.13",
  "extensions": [
    ".3gp",
    ".3g2",
    ".3gpp"
  ],
  "description": "3GP and 3G2 are multimedia container formats defined by 3GPP (Third Generation Partnership Project) for mobile device video recording and streaming. Both are profiles of the ISO Base Media File Format (ISO/IEC 14496-12). The file begins with an 'ftyp' (File Type) box: box size (4 bytes, big-endian), box type 'ftyp' (4 bytes), major brand (4 bytes), minor version (4 bytes), and compatible brands (variable). .3gp major brand is '3gp4'-'3gp7'; .3g2 major brand is '3g2a'-'3g2c'. Both support H.263, H.264, and MPEG-4 video; AMR-NB, AMR-WB, and AAC audio. 3GP is optimized for 3G cellular network streaming; 3G2 is the CDMA2000 variant used by Sprint/Verizon in North America. Both are used for mobile phone video recordings.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "3GPP TS 26.244 — 3GP file format (Release 17)",
      "3GPP2 C.S0050-A — 3G2 file format",
      "ISO/IEC 14496-12 — ISO Base Media File Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/3GP_and_3G2",
      "https://www.3gpp.org/technologies/keywords-acronyms/98-3gpp-file-format",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000176.shtml"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "66747970", "offset": 4, "label": "'ftyp' box type — ISOBMFF container", "weight": 0.6 },
      { "value": "3367703400000000", "offset": 8, "label": "'3gp4' major brand", "weight": 1.0 },
      { "value": "3367703500000000", "offset": 8, "label": "'3gp5' major brand", "weight": 1.0 },
      { "value": "3367703600000000", "offset": 8, "label": "'3gp6' major brand", "weight": 1.0 },
      { "value": "3367703700000000", "offset": 8, "label": "'3gp7' major brand", "weight": 1.0 },
      { "value": "33673261", "offset": 8, "label": "'3g2a' major brand (CDMA2000)", "weight": 1.0 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.6,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 4.0, "max": 7.5 },
    "validation": {
      "minFileSize": 20,
      "note": "3GP/3G2 files use the ISOBMFF container. 'ftyp' box must be at offset 4. Major brand at offset 8 identifies 3GP version ('3gp4'-'3gp7') or 3G2 variant ('3g2a'-'3g2c')."
    }
  },
  "variables": {
    "ftypBoxSize": 0,
    "ftypBoxType": "",
    "majorBrand": "",
    "minorVersion": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "ftyp Box Size",
      "offset": 0,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Size in bytes of the 'ftyp' (File Type) box including this size field (big-endian uint32). Minimum valid size is 20 bytes: 4 (size) + 4 ('ftyp') + 4 (major brand) + 4 (minor version) + any compatible brands (0 or more × 4 bytes each).",
      "storeAs": "ftypBoxSize",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "signature",
      "name": "ftyp Box Type",
      "offset": 4,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "ISOBMFF box type identifier 'ftyp' (0x66747970). The File Type box is mandatory as the first box in all ISOBMFF-derived formats (MP4, MOV, 3GP, M4A, HEIC, etc.). Its presence at offset 4 (after the 4-byte size) is the defining characteristic of the ISOBMFF container family.",
      "storeAs": "ftypBoxType",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Major Brand",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "4-byte ASCII brand string identifying the specific ISOBMFF profile. 3GP brands: '3gp4' (3GPP Release 4), '3gp5' (R5), '3gp6' (R6), '3gp7' (R7). 3G2 brands: '3g2a' (CDMA2000), '3g2b', '3g2c'. This field is the definitive 3GP vs 3G2 discriminator.",
      "storeAs": "majorBrand",
      "valueType": "ascii",
      "valueMap": {
        "3gp4": "3GP Release 4 — 3GPP TS 26.244 R4",
        "3gp5": "3GP Release 5 — 3GPP TS 26.244 R5",
        "3gp6": "3GP Release 6 — 3GPP TS 26.244 R6 (common mobile recording)",
        "3gp7": "3GP Release 7 — 3GPP TS 26.244 R7",
        "3g2a": "3G2 variant a — 3GPP2/CDMA2000 (Sprint/Verizon)",
        "3g2b": "3G2 variant b",
        "3g2c": "3G2 variant c"
      }
    },
    {
      "type": "field",
      "name": "Minor Version",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.25,
      "description": "Informational minor version of the major brand specification (big-endian uint32). Often 0x00000000 or a date-encoded version (e.g., 0x20040000 = year 2004). Not used for format detection.",
      "storeAs": "minorVersion",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "metadata",
      "name": "Major Brand",
      "variable": "majorBrand",
      "description": "3GP/3G2 brand: '3gp4'-'3gp7' = 3GP, '3g2a'-'3g2c' = 3G2"
    },
    {
      "type": "metadata",
      "name": "ftyp Box Size",
      "variable": "ftypBoxSize",
      "description": "Size of the ftyp box (minimum 20 bytes)"
    }
  ],
  "assertions": [
    {
      "name": "ftyp box type valid",
      "expression": "ftypBoxType == 'ftyp'",
      "severity": "error",
      "message": "Box type at offset 4 must be 'ftyp' (0x66747970) — not a valid ISOBMFF/3GP file"
    },
    {
      "name": "Major brand is 3GP or 3G2",
      "expression": "majorBrand == '3gp4' || majorBrand == '3gp5' || majorBrand == '3gp6' || majorBrand == '3gp7' || majorBrand == '3g2a' || majorBrand == '3g2b' || majorBrand == '3g2c'",
      "severity": "info",
      "message": "Major brand is not a known 3GP or 3G2 brand — may be another ISOBMFF derivative (MP4, MOV, M4A)"
    }
  ],
  "versionDetection": {
    "field": "majorBrand",
    "versions": {
      "3gp4": "3GP Release 4",
      "3gp5": "3GP Release 5",
      "3gp6": "3GP Release 6 (most common)",
      "3gp7": "3GP Release 7",
      "3g2a": "3G2/CDMA2000 variant a",
      "3g2b": "3G2/CDMA2000 variant b",
      "3g2c": "3G2/CDMA2000 variant c"
    }
  },

    }
  ],
  "forensic": {
    "category": "video",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "3GP/3G2 = ISOBMFF profile. ftyp box: size(4B BE) + 'ftyp'(4B) + majorBrand(4B) + minorVersion(4B BE) + compatibleBrands(4B × N). 3GP brands: '3gp4'-'3gp7'. 3G2: '3g2a'-'3g2c'. After ftyp: moov box (metadata) and mdat box (media data). Video codecs: 'h263' (H.263), 'avc1' (H.264/AVC), 'mp4v' (MPEG-4). Audio codecs: 'samr' (AMR-NB), 'sawb' (AMR-WB), 'mp4a' (AAC). Structure identical to MP4/MOV (ISOBMFF) — only the brand distinguishes 3GP.",
    "suggestedInspections": [
      "Verify 'ftyp' at offset 4",
      "Read major brand at offset 8: '3gp4'-'3gp7' (3GP) or '3g2a'-'3g2c' (3G2)",
      "Parse moov > trak > mdia > hdlr for track type ('vide'=video, 'soun'=audio)",
      "Look for AMR-NB ('samr') and AMR-WB ('sawb') audio codecs — signature for mobile recording"
    ]
  },
  "software": [
    "Mobile devices (Android, iOS — recording and playback)",
    "VLC media player",
    "FFmpeg (3gp/3g2 muxer)",
    "HandBrake",
    "Apple QuickTime Player"
  ],
  "formatRelationships": {
    "category": "Video",
    "extensions": [".3gp", ".3g2", ".3gpp"],
    "relatedFormats": ["MP4", "MOV", "M4V"],
    "note": "3GP and 3G2 are ISOBMFF profiles. 3GP is defined by 3GPP for GSM/UMTS devices; 3G2 is the 3GPP2/CDMA2000 variant. Both are structurally identical to MP4/MOV — the major brand is the only formal distinguisher. Modern smartphones still record in 3GP-compatible MP4 with H.264+AAC."
  },
  "MimeTypes": [
    "video/3gpp",
    "video/3gpp2",
    "audio/3gpp"
  ],
  "UseCases": [

{
  "diffMode": "binary",
  "formatName": "QuickTime Movie",
  "version": "2.02",
  "extensions": [
    ".mov",
    ".qt"
  ],
  "description": "Apple QuickTime Movie format based on the atom/box container structure that became the ancestor of ISO Base Media File Format (ISOBMFF). Files typically begin with a File Type Box (ftyp) with major brand 'qt  ', though legacy MOV files may start with 'moov', 'wide', or 'mdat' atoms. All data is organized in nested atoms, each prefixed by a 32-bit size and 4-byte type code.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Apple QuickTime File Format Specification",
      "ISO/IEC 14496-12 - ISO Base Media File Format",
      "MPEG-4 Part 12"
    ],
    "WebLinks": [
      "https://developer.apple.com/documentation/quicktime-file-format",
      "https://en.wikipedia.org/wiki/QuickTime_File_Format",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000052.shtml",
      "https://wiki.multimedia.cx/index.php/QuickTime_container"
    ]
  },
  "detection": {
    "signature": "6674797071742020",
    "offset": 4,
    "required": false,
    "validation": {
      "minFileSize": 20,
      "maxSignatureOffset": 1024,
      "expectedValue": "0x6674797071742020"
    }
  },
  "variables": {
    "currentOffset": 0,
    "firstAtomSize": 0,
    "firstAtomType": "",
    "ftypBrand": "",
    "brandName": "",
    "ftypMinorVer": 0,
    "compatBrand1": "",
    "compatBrand2": "",
    "compatBrand3": "",
    "compatBrand4": "",
    "nextAtomSize": 0,
    "nextAtomType": "",
    "nextAtomTypeName": "",
    "payloadSize": 0,
    "totalFileSize": 0,
    "formattedFileSize": "",
    "isLegacyFormat": false,
    "hasExtendedSize": false
  },
  "functions": {
    "formatFileSize(var:totalFileSize)": "Format total file size as human-readable string (KB/MB/GB)",
    "computeFromVariables(firstAtomSize - 8, payloadSize)": "Calculate ftyp atom payload size by subtracting atom header overhead"
  },
  "blocks": [
    {
      "type": "field",
      "name": "First Atom Size",
      "offset": 0,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Size of the first atom in bytes, stored as a big-endian unsigned 32-bit integer. This includes the 8-byte atom header (size + type) plus payload. A value of 0 means the atom extends to end-of-file; a value of 1 means a 64-bit extended size follows the type field.",
      "storeAs": "firstAtomSize",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "signature",
      "name": "First Atom Type",
      "offset": 4,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Four-byte ASCII atom type code. For modern QuickTime files this is 'ftyp' (0x66747970) indicating a File Type Box. Legacy MOV files may start with 'moov' (movie metadata), 'wide' (wide atom placeholder), or 'mdat' (media data) instead.",
      "storeAs": "firstAtomType",
      "valueType": "ascii",
      "valueMap": {
        "ftyp": "File Type Box (modern)",
        "moov": "Movie Metadata (legacy)",
        "wide": "Wide Atom Placeholder (legacy)",
        "mdat": "Media Data (legacy)",
        "free": "Free Space"
      }
    },
    {
      "type": "field",
      "name": "Major Brand",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Four-character brand code (FourCC) identifying the best-use specification for this file. For QuickTime movies this is typically 'qt  ' (0x71742020). Present only when the first atom is ftyp.",
      "storeAs": "ftypBrand",
      "valueType": "ascii",
      "valueMap": {
        "qt  ": "Apple QuickTime",
        "isom": "ISO Base Media File Format",
        "iso2": "ISO Base Media v2",
        "mp41": "MPEG-4 Part 14 v1",
        "mp42": "MPEG-4 Part 14 v2",
        "M4V ": "Apple iTunes Video",
        "M4A ": "Apple iTunes Audio (AAC)",
        "avc1": "AVC/H.264 Video",
        "MSNV": "Sony PSP Video",
        "3gp4": "3GPP Release 4",
        "3gp5": "3GPP Release 5",
        "dash": "MPEG-DASH Streaming"
      },
      "mappedValueStoreAs": "brandName"
    },
    {
      "type": "field",
      "name": "Minor Version",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Minor version of the major brand specification, stored as a big-endian unsigned 32-bit integer. For QuickTime brand 'qt  ', Apple uses this to encode the QuickTime version (e.g., 0x00000200 = QuickTime 2.0). A value of 0 typically indicates the base version.",
      "storeAs": "ftypMinorVer",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Compatible Brand 1",
      "offset": 16,
      "length": 4,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "First compatible brand FourCC. Lists additional specifications this file complies with. QuickTime files often list 'qt  ' here along with ISO base media brands for broader player compatibility.",
      "storeAs": "compatBrand1",
      "valueType": "ascii",
      "valueMap": {
        "qt  ": "QuickTime",
        "isom": "ISO Base Media",
        "iso2": "ISO Base Media v2",
        "mp41": "MP4 v1",
        "mp42": "MP4 v2",
        "avc1": "AVC/H.264",
        "M4V ": "iTunes Video",
        "M4A ": "iTunes Audio"
      }
    },
    {
      "type": "field",
      "name": "Compatible Brand 2",
      "offset": 20,
      "length": 4,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Second compatible brand FourCC. QuickTime files exported from professional Apple tools (Final Cut Pro, Compressor) often include multiple compatible brands for cross-platform playback.",
      "storeAs": "compatBrand2",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Compatible Brand 3",
      "offset": 24,
      "length": 4,
      "color": "#FF6B9D",
      "opacity": 0.3,
      "description": "Third compatible brand FourCC, if present. The number of compatible brands depends on the ftyp atom size: count = (atomSize - 16) / 4.",
      "storeAs": "compatBrand3",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Compatible Brand 4",
      "offset": 28,
      "length": 4,
      "color": "#C44569",
      "opacity": 0.3,
      "description": "Fourth compatible brand FourCC, if present within the ftyp atom payload. Professional QuickTime files may list ProRes, HEVC, or other codec-specific brands.",
      "storeAs": "compatBrand4",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Next Atom Size",
      "offset": 32,
      "length": 4,
      "color": "#A8E6CF",
      "opacity": 0.3,
      "description": "Size of the second atom in the file (at offset = first atom size, shown assuming ftyp is 32 bytes). In QuickTime files this is typically 'moov' (movie metadata with track headers, edit lists, and codec info) or 'wide' (8-byte placeholder preceding a large mdat atom).",
      "storeAs": "nextAtomSize",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Next Atom Type",
      "offset": 36,
      "length": 4,
      "color": "#98D8C8",
      "opacity": 0.3,
      "description": "Four-byte ASCII type of the second atom. Common second atoms in QuickTime: 'moov' (movie metadata), 'wide' (placeholder before large mdat), 'mdat' (media data), 'free' (free space).",
      "storeAs": "nextAtomType",
      "valueType": "ascii",
      "valueMap": {
        "moov": "Movie Metadata Atom",
        "mdat": "Media Data Atom",
        "wide": "Wide Atom (64-bit size placeholder)",
        "free": "Free Space Atom",
        "skip": "Skip Atom (Free Space)",
        "pnot": "Preview Atom (legacy QuickTime)",
        "uuid": "UUID Extension Atom"
      },
      "mappedValueStoreAs": "nextAtomTypeName"
    },
    {
      "type": "computeFromVariables",
      "name": "ftyp Payload Size",
      "expression": "firstAtomSize - 8",
      "storeAs": "payloadSize",
      "description": "Calculates the ftyp atom payload size by subtracting the 8-byte header (4 bytes size + 4 bytes type). The payload contains major brand (4), minor version (4), and compatible brands (variable)."
    },
    {
      "type": "computeFromVariables",
      "name": "Legacy Format Detection",
      "expression": "firstAtomType != 'ftyp' ? 1 : 0",
      "storeAs": "isLegacyFormat",
      "description": "Determines if this is a legacy QuickTime file by checking if the first atom is NOT ftyp. Legacy MOV files from older versions of QuickTime may start with moov, wide, or mdat atoms without an ftyp declaration."
    },
    {
      "type": "conditional",
      "name": "Legacy vs Modern QuickTime",
      "condition": "firstAtomType == 'ftyp'",
      "trueLabel": "Modern QuickTime format with ftyp atom declaring brand and compatibility",
      "falseLabel": "Legacy QuickTime format without ftyp atom - limited brand/version metadata available",
      "description": "Detects whether this is a modern QuickTime file (with ftyp brand declaration) or a legacy format. Legacy files lack brand information and may not be recognized by non-Apple players."
    },
    {
      "type": "conditional",
      "name": "Extended Size Detection",
      "condition": "firstAtomSize == 1",
      "trueLabel": "This QuickTime file uses 64-bit extended atom sizes (file may exceed 4 GB)",
      "falseLabel": "This QuickTime file uses standard 32-bit atom sizes",
      "description": "Checks if the first atom uses a 64-bit extended size field. An atom size of 1 signals that the real size is stored in the next 8 bytes as a 64-bit big-endian integer. Common for large ProRes video files."
    },
    {
      "type": "metadata",
      "name": "Major Brand",
      "variable": "ftypBrand",
      "description": "Four-character brand code from the ftyp atom identifying the file's primary specification"
    },
    {
      "type": "metadata",
      "name": "Brand Description",
      "variable": "brandName",
      "description": "Human-readable name of the major brand specification"
    },
    {
      "type": "metadata",
      "name": "Minor Version",
      "variable": "ftypMinorVer",
      "description": "Minor version number of the major brand (encodes QuickTime version for 'qt  ' brand)"
    },
    {
      "type": "metadata",
      "name": "First Atom Type",
      "variable": "firstAtomType",
      "description": "Type of the first atom in the file (ftyp for modern, moov/wide/mdat for legacy)"
    },
    {
      "type": "metadata",
      "name": "Next Atom Description",
      "variable": "nextAtomTypeName",
      "description": "Human-readable description of the second atom following the first atom"
    },
    {
      "type": "metadata",
      "name": "Formatted File Size",
      "variable": "formattedFileSize",
      "description": "Total file size formatted as a human-readable string (KB/MB/GB)"
    }
  ],
  "MimeTypes": [
    "video/quicktime"
  ],
  "Software": [
    "QuickTime Player",
    "VLC",
    "iMovie",
    "Final Cut Pro",
    "FFmpeg"
  ],
  "UseCases": [
    "Apple video editing",
    "Professional video",
    "iPhone/iPad recordings",
    "ProRes workflows"
  ],
  "QualityMetrics": {
    "CompletenessScore": 91,
    "DocumentationLevel": "comprehensive",
    "BlocksDefined": 20,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Container": "QuickTime (ISO BMFF ancestor)",
    "VideoFormat": true,
    "Endianness": "big-endian (network byte order)",
    "HeaderSize": "Variable (ftyp atom size, typically 20-40 bytes)",
    "AtomBasedFormat": true,
    "Platform": "macOS / iOS",
    "SupportsProRes": true,
    "SupportsHEVC": true,
    "MaxFileSize": "Unlimited (64-bit extended sizes)",
    "primary_extension": ".mov"
  },
  "assertions": [
    {
      "name": "First atom size is reasonable",
      "expression": "firstAtomSize > 0 && firstAtomSize < 268435456",
      "severity": "warning",
      "message": "First atom size is 0 or > 256MB — may indicate a malformed QuickTime file or extended 64-bit size (value=1)"
    },
    {
      "name": "First atom type is known",
      "expression": "firstAtomType == 'ftyp' || firstAtomType == 'moov' || firstAtomType == 'wide' || firstAtomType == 'mdat' || firstAtomType == 'free'",
      "severity": "warning",
      "message": "Unknown first atom type — expected ftyp, moov, wide, mdat, or free for a valid QuickTime file"
    },
    {
      "name": "Brand is known QuickTime variant",
      "expression": "ftypBrand == 'qt  ' || ftypBrand == 'isom' || ftypBrand == 'iso2' || ftypBrand == 'mp41' || ftypBrand == 'mp42' || ftypBrand == 'M4V ' || isLegacyFormat",
      "severity": "info",
      "message": "Major brand is not a commonly recognized QuickTime/MPEG-4 brand — may be a specialized QuickTime variant"
    }
  ],
  "versionDetection": {
    "field": "ftypBrand",
    "versions": {
      "qt  ": "QuickTime Movie (Apple native)",
      "isom": "ISO Base Media File Format",
      "iso2": "ISO Base Media File v2",
      "mp41": "MPEG-4 Part 14 v1",
      "mp42": "MPEG-4 Part 14 v2",
      "M4V ": "iTunes Video",
      "M4A ": "iTunes Audio"
    }
  },
  "navigation": {
    "bookmarks": [
      {
        "name": "First Atom",
        "offset": 0,
        "icon": "\uE71B",
        "color": "#FF6B6B"
      },
      {
        "name": "ftyp Major Brand",
        "offset": 8,
        "icon": "\uE8B7",
        "color": "#95E1D3"
      }
    ]
  },
  "inspector": {
    "badge": "ftypBrand",
    "primaryField": "firstAtomType",
    "showQualityScore": true,
    "groups": [
      {
        "title": "QuickTime Identity",
        "icon": "\uE71B",
        "fields": ["firstAtomType", "ftypBrand", "brandName", "ftypMinorVer"]
      },
      {
        "title": "Compatible Brands",
        "icon": "\uE8B7",
        "fields": ["compatBrand1", "compatBrand2", "compatBrand3", "compatBrand4"]
      },
      {
        "title": "Next Atom",
        "icon": "\uE9D9",
        "fields": ["nextAtomType", "nextAtomTypeName", "nextAtomSize"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "ftyp Atom (JSON)",
      "format": "json",
      "fields": ["firstAtomType", "firstAtomSize", "ftypBrand", "ftypMinorVer", "compatBrand1", "compatBrand2", "compatBrand3", "compatBrand4", "isLegacyFormat"]
    }
  ],
  "forensic": {
    "category": "video",
    "riskLevel": "low",
    "suspiciousPatterns": [
      {
        "name": "Legacy QuickTime without ftyp",
        "condition": "isLegacyFormat == 1",
        "severity": "info",
        "description": "File uses legacy QuickTime format without ftyp atom. Legacy MOV files may not be playable on non-Apple software. Common in files from QuickTime 6 and earlier."
      },
      {
        "name": "Extended 64-bit size used",
        "condition": "firstAtomSize == 1",
        "severity": "info",
        "description": "First atom uses 64-bit extended size (atom size field = 1). File likely exceeds 4 GB. Real size is stored at offset 8 as uint64 BE. Verify player support for large QuickTime files."
      }
    ],
    "knownExploitVectors": [
      "CVE-2016-4600: QuickTime for Windows memory corruption via crafted moov atom",
      "CVE-2010-1799: QuickTime heap overflow via crafted MPEG-4 track with malformed stss atom",
      "Atom size == 0 (extends to EOF) can confuse parsers that calculate next atom offset as current + size"
    ]
  },
  "aiHints": {
    "analysisContext": "QuickTime/MOV layout (all BE): atom_size(4,BE) + atom_type(4,ASCII) + payload. First atom typically 'ftyp': size(4,BE) + 'ftyp'(4) + majorBrand(4,ASCII) + minorVersion(4,BE) + compatBrands(4B each). 'qt  ' brand = QuickTime. After ftyp comes 'moov' (movie metadata) or 'mdat' (raw media data). moov atom contains: mvhd (movie header: timescale, duration), trak (track: tkhd=track header, mdia>minf>stbl>stsd for codec). Video codec in stsd: 'avc1'=H.264, 'hvc1'=H.265/HEVC, 'ap4h'=ProRes 4444, 'apch'=ProRes 422 HQ, 'apcn'=ProRes 422. 'free' atoms are padding. 'wide' (8 bytes) precedes large mdat for alignment. Atom size=1 means next 8 bytes are 64-bit size (for >4GB files).",
    "knownVulnerabilities": [
      "CVE-2016-4600: QuickTime Windows moov atom heap corruption",
      "CVE-2010-1799: Malformed stss atom heap overflow in QuickTime"
    ],
    "suggestedInspections": [
      "Verify first atom: size(4,BE) at 0, type(4,ASCII) at 4 — expect 'ftyp' for modern MOV",
      "Read major brand at offset 8: 'qt  ' = QuickTime, 'isom' = generic ISOBMFF",
      "For legacy MOV (no ftyp): scan for 'moov' atom to find movie metadata",
      "Check atom size == 1 at offset 0 for 64-bit extended size (large files)",
      "Navigate moov > trak > mdia > minf > stbl > stsd to find video codec FourCC"
    ]
  }
}

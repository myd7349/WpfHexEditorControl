{
  "diffMode": "binary",
  "formatName": "Digital Video",
  "version": "1.15",
  "extensions": [
    ".dv",
    ".dif"
  ],
  "description": "DV (Digital Video) is an international standard (IEC 61834) for encoding digital video, commonly used in consumer and professional camcorders from the 1990s-2000s. Raw DV files consist of a sequence of fixed-size DV frames (120000 bytes/frame at 25 Mbps for SD PAL, or 100800 bytes/frame for NTSC). Each DV frame is composed of Sequences (DIF blocks): a header DIF block (3 bytes: SCT=section type, STA=station, QNO=sequence number), then subcode, VAUX, and audio DIF blocks. The raw DV elementary stream starts with DIF block header byte 0x1F 0x07 0x00 for a header section. DV is also encapsulated in AVI (Type-1 or Type-2), QuickTime MOV, or MXF containers. The DIF section code distinguishes DV25 (2 channels), DVCPRO 25/50, and DVCPRO HD.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "IEC 61834 — Digital Video (DV) Standard (Parts 1-6)",
      "IEC 61834-2 — SD 25 Mbps Recording",
      "RFC 6469 — RTP Payload Format for DV (IEC 61834)"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/DV_(video_format)",
      "https://www.rfc-editor.org/rfc/rfc6469.html",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000183.shtml",
      "https://www.adamwilt.com/DV-tech.html"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "1F0700", "offset": 0, "label": "DV DIF header block (SCT=0x1F, STA=0x07, QNO=0x00)", "weight": 0.9 },
      { "value": "3F0700", "offset": 0, "label": "DV DIF subcode block start (alternate)", "weight": 0.6 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.6,
    "required": true,
    "Strength": "Medium",
    "EntropyHint": { "min": 5.0, "max": 7.5 },
    "validation": {
      "minFileSize": 120000,
      "note": "Raw DV elementary streams have 120000-byte PAL frames or 100800-byte NTSC frames. The first 3 bytes identify the DIF block header section. DV in AVI uses RIFF magic (52494646) instead."
    }
  },
  "variables": {
    "difSectionCode": 0,
    "difBlockNum": 0,
    "difSequenceNum": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "DIF Block Header",
      "offset": 0,
      "length": 3,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "DV DIF (Digital Interface Format) block header bytes. Byte 0 = section type (SCT, bits 7-5) + station (STA, bits 4-1) + flag (bit 0). Byte 1 = sequence number (QNO, bits 7-4) + DIF block number (DBN, bits 3-0). Byte 2 = reserved (0x00). SCT=0 (header section), STA=0x0F, QNO=0 is the standard header DIF block start. DV frames contain 12 sequences (NTSC) or 12 sequences (PAL) of 150 DIF blocks each.",
      "storeAs": "difSectionCode",
      "valueType": "uint8",
      "bitfields": [
        { "name": "Section Type (SCT)", "bits": "7-5", "description": "DIF block section type", "valueMap": { "0": "Header section", "1": "Subcode section", "2": "VAUX section", "3": "Audio section", "4": "Video section" } },
        { "name": "Station (STA)", "bits": "4-1", "description": "Station identifier" },
        { "name": "Reserved", "bits": "0", "description": "Must be 0" }
      ]
    },
    {
      "type": "field",
      "name": "Sequence / Block Number",
      "offset": 1,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.30,
      "description": "Sequence number (bits 7-4) and DIF block number within sequence (bits 3-0). Together with the section type, identifies the position of this DIF block within the DV frame structure.",
      "storeAs": "difBlockNum",
      "valueType": "uint8",
      "bitfields": [
        { "name": "Sequence Number", "bits": "7-4", "description": "Sequence number within DV frame (0-11 for PAL/NTSC)" },
        { "name": "DIF Block Number", "bits": "3-0", "description": "DIF block number within section" }
      ]
    },
    {
      "type": "metadata",
      "name": "DIF Section Code",
      "variable": "difSectionCode",
      "description": "DV DIF block section type (0=Header)"
    }
  ],
  "assertions": [
    {
      "name": "DIF section type is header",
      "expression": "(difSectionCode & 224) == 0",
      "severity": "warning",
      "message": "First DIF block section type should be Header (SCT=0, bits 7-5) for a raw DV elementary stream"
    }
  ],
  "navigation": {
    "bookmarks": [
      {
        "name": "First DIF Block",
        "offset": 0,
        "icon": "\uE71B",
        "color": "#FF6B6B"
      }
    ]
  },
  "inspector": {
    "badge": "difSectionCode",
    "primaryField": "difBlockNum",
    "showQualityScore": true,
    "groups": [

    }
  ],
  "forensic": {
    "category": "video",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Raw DV elementary stream (IEC 61834). Structure: sequence of 150-DIF-block sequences. Each DIF block = 80 bytes: 3B header (SCT+STA+QNO/DBN+reserved) + 77B data. Frame layout: 1 Header DIF + 2 Subcode DIF + 3 VAUX DIF + 9 Audio DIF + 135 Video DIF = 150 DIF blocks per sequence. PAL: 12 sequences × 150 × 80B = 144000B/frame at 25fps = 3.6 MB/s, 25 Mbps. NTSC: 10 sequences/frame = 120000B. DVCPRO50: 300 DIF blocks/sequence. Embedded audio: 2ch/4ch 48kHz 16-bit PCM in audio DIF blocks.",
    "suggestedInspections": [
      "Verify byte 0 bits 7-5 = 000 (Header section) for raw DV elementary stream",
      "Frame size: 120000 bytes (NTSC 30fps) or 144000 bytes (PAL 25fps)",
      "Look for VAUX data (section type 2) containing recording date/time",
      "Check sequence count for DV25 vs DVCPRO50 vs DVCPRO HD variants"
    ]
  },
  "software": [
    "FFmpeg (dv demuxer)",
    "VLC media player",
    "Kdenlive",
    "Final Cut Pro",
    "Adobe Premiere Pro",
    "dvgrab (Linux capture tool)"
  ],
  "formatRelationships": {
    "category": "Video",
    "extensions": [".dv", ".dif"],
    "relatedFormats": ["AVI", "MOV", "MXF"],
    "note": "Raw DV (.dv/.dif) is a headerless elementary bitstream. DV is also stored in AVI (Type-1 or Type-2 DV-AVI, detected by RIFF magic), QuickTime MOV (.mov), and MXF (.mxf). The raw DV format is identified only by the DIF block structure — no separate file header exists."
  },

{
  "diffMode": "binary",
  "formatName": "Digital Video (DV)",
  "version": "1.0",
  "extensions": [".dv", ".dif"],
  "description": "Digital Video (DV) is a digital video format introduced in 1996 by a consortium of electronics manufacturers including Sony, Panasonic, and JVC. DV stores video in fixed-size DIF (Digital Interface Format) frames. A standard-definition DV frame is 120,000 bytes (NTSC, 30fps) or 144,000 bytes (PAL, 25fps). Each DIF frame begins with a DIF block identifier byte whose upper nibble is typically 0x1F for header blocks. DV has no formal file magic — identification is purely structural. Files are typically raw DIF streams exported from DV camcorders via FireWire (IEEE 1394) or extracted from AVI/MOV containers.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": {
    "specifications": [
      "IEC 61834: Recording — Helical-scan digital video cassette recording system using 6.35 mm magnetic tape",
      "SMPTE 314M: Data Structure for DV-Based Audio, Data, and Compressed Video — 25 Mbps and 50 Mbps"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/DV",
      "https://www.ffmpeg.org/general.html#DV"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "1F",
        "offset": 0,
        "label": "DV DIF header block marker — first byte 0x1F indicates header DIF block",
        "weight": 0.5
      }
    ],
    "matchMode": "First",
    "MinimumScore": 0.3,
    "required": [],
    "Strength": "Medium",
    "EntropyHint": {
      "min": 5.0,
      "max": 8.0,
      "comment": "DV compressed video has moderate to high entropy; audio blocks have lower entropy"
    },
    "validation": {
      "notes": "File size should be a multiple of 120000 (NTSC) or 144000 (PAL) bytes; DIF block structure repeats every 80 bytes"
    }
  },
  "variables": {
    "firstDIFBlock": 0,
    "secondByte": 0,
    "thirdByte": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "firstDIFBlock",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "First byte of the first DIF block — the upper nibble (0x1) identifies the block as a DIF Header block; lower nibble carries the first sequence bits; value 0x1F is characteristic of standard DV DIF header blocks",
      "storeAs": "firstDIFBlock",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "secondByte",
      "offset": 1,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.75,
      "description": "Second byte of the first DIF block — encodes DIF block sequence number and type information; the upper 4 bits identify DIF block type within the DIF sequence structure",
      "storeAs": "secondByte",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "thirdByte",
      "offset": 2,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.75,
      "description": "Third byte of the first DIF block — carries the DIF block channel identifier and additional type bits; together with bytes 0-1 forms the DIF block identification header",
      "storeAs": "thirdByte",
      "valueType": "uint8"
    }
  ],
  "assertions": [
    {
      "field": "firstDIFBlock",
      "op": "eq",
      "value": "0x1F",
      "message": "First DIF block byte should be 0x1F for standard DV header block"
    },
    {
      "field": "fileSize",
      "op": "modulo",
      "divisor": 120000,
      "value": 0,
      "message": "NTSC DV file size should be multiple of 120000 bytes (or 144000 for PAL)"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "DIF Block 1 Start", "offset": 0, "length": 1, "color": "#FF6B6B" },
      { "name": "DIF Block 1 Byte 2", "offset": 1, "length": 1, "color": "#4ECDC4" },
      { "name": "DIF Block 1 Byte 3", "offset": 2, "length": 1, "color": "#95E1D3" },
      { "name": "DIF Block 2 Start", "offset": 80, "length": 1, "color": "#FF6B6B" }
    ]
  },
  "inspector": {
    "badge": "DV",
    "primaryField": "firstDIFBlock",
    "showQualityScore": true,
    "groups": [
      {
        "name": "First DIF Block",
        "fields": ["firstDIFBlock", "secondByte", "thirdByte"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "DV File Summary",
      "format": "text",
      "template": "First byte: {firstDIFBlock} | Byte 2: {secondByte} | Byte 3: {thirdByte}"
    },
    {
      "name": "DV JSON Report",
      "format": "json",
      "template": "{ \"firstDIFByte\": {firstDIFBlock}, \"difBlockSize\": 80 }"
    }
  ],
  "forensic": {
    "category": "Video",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "File size not divisible by 120000 (NTSC) or 144000 (PAL) indicates truncation or non-raw DV",
      "DIF block type inconsistencies indicate stream corruption from FireWire dropouts",
      "Audio DIF blocks with all-zero payload indicate audio dropout during recording"
    ]
  },
  "aiHints": {
    "analysisContext": "Raw DV files have no file header — they are pure DIF streams. A DV frame consists of 10 DIF sequences (NTSC) or 12 (PAL). Each DIF sequence contains: 1 Header block + 2 Subcode blocks + 3 VAUX blocks + 9 Audio blocks + 135 Video blocks, each 80 bytes. Total NTSC frame: 1500 * 80 = 120000 bytes.",
    "suggestedInspections": [
      "Verify file size divisible by 120000 (NTSC) or 144000 (PAL) bytes",
      "Walk DIF blocks every 80 bytes and verify block type bytes for structure validation",
      "Check Header DIF block for system (DV25/DVCAM/DVCPRO) and video format (NTSC/PAL)",
      "Parse VAUX DIF blocks for camera metadata: date, time, shutter speed",
      "Inspect Audio DIF blocks for audio sampling rate (32/44.1/48 kHz) and channel count",
      "Detect DVCPRO vs standard DV by checking shuffle pattern in video DIF blocks"
    ]
  },
  "software": [
    "FFmpeg",
    "VLC Media Player",
    "Adobe Premiere Pro",
    "Final Cut Pro",
    "Kino (Linux DV editor)",
    "dvgrab"
  ],
  "formatRelationships": {
    "category": "Video",
    "extensions": [".dv", ".dif"],
    "relatedFormats": ["AVI (DV-AVI)", "MOV (DV-MOV)", "DVCPRO", "DVCPRO HD", "MXF (DV-wrapped)"],
    "note": "Raw .dv files are pure DIF streams; DV is commonly wrapped in AVI (Type 1 or Type 2) or QuickTime MOV containers for NLE editing"
  },
  "MimeTypes": ["video/x-dv", "video/dv"],
  "UseCases": [

{
  "diffMode": "binary",
  "formatName": "DVD Video Object",
  "version": "1.0",
  "extensions": [".vob", ".mpg"],
  "description": "DVD Video Object (VOB) files are MPEG-2 Program Stream containers used on DVD-Video discs. Each file begins with the MPEG-2 pack start code 00 00 01 BA, which identifies the start of a Program Stream pack. The byte at offset 4 carries the SCR (System Clock Reference) in its upper 6 bits (with a 01 marker). The mux rate field at offset 10 (3 bytes) declares the multiplexed stream bitrate. VOB files on DVD contain interleaved video (MPEG-2), audio (AC-3, DTS, PCM, or MPEG Audio), and subpicture (subtitle) streams multiplexed together in Program Stream packs.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": {
    "specifications": [
      "ISO/IEC 13818-1: MPEG-2 Systems — Program Stream",
      "DVD Forum: DVD Specifications for Read-Only Disc Part 3 Video Specification"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/VOB",
      "https://en.wikipedia.org/wiki/MPEG_program_stream"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "000001BA",
        "offset": 0,
        "label": "MPEG-2 Program Stream pack start code 0x000001BA",
        "weight": 1.0
      }
    ],
    "matchMode": "First",
    "MinimumScore": 0.9,
    "required": ["MPEG-2 Program Stream pack start code 0x000001BA"],
    "Strength": "Strong",
    "EntropyHint": {
      "min": 5.5,
      "max": 8.0,
      "comment": "MPEG-2 compressed video multiplex exhibits high entropy"
    },
    "validation": {
      "notes": "Start code 0x000001BA must appear at offset 0; upper 2 bits of offset 4 must be '01' for MPEG-2"
    }
  },
  "variables": {
    "packStartCode": "",
    "scrByte": 0,
    "muxRate": 0,
    "stuffingLength": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "packStartCode",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "MPEG-2 Program Stream pack start code (4 bytes) — always 0x000001BA; marks the beginning of a PS pack which contains header fields and PES packets carrying audio/video elementary streams",
      "storeAs": "packStartCode",
      "valueType": "bytes"
    },
    {
      "type": "field",
      "name": "scrByte",
      "offset": 4,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.75,
      "description": "First byte of System Clock Reference (SCR) field — upper 2 bits must be '01' for MPEG-2 Program Stream (distinguishes from MPEG-1 which uses '0010'); SCR encodes the presentation timestamp",
      "storeAs": "scrByte",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "muxRate",
      "offset": 10,
      "length": 3,
      "color": "#95E1D3",
      "opacity": 0.75,
      "description": "Program Stream mux rate field (22-bit value in 3 bytes) — declares the combined bitrate of all multiplexed elementary streams in units of 50 bytes/second; used by demultiplexers for buffer management",
      "storeAs": "muxRate",
      "valueType": "uint24BE"
    },
    {
      "type": "field",
      "name": "stuffingLength",
      "offset": 13,
      "length": 1,
      "color": "#FFE66D",
      "opacity": 0.75,
      "description": "Pack stuffing length (lower 3 bits) — indicates number of 0xFF stuffing bytes appended after this field to pad the pack header to a required alignment; upper 5 bits are reserved marker bits",
      "storeAs": "stuffingLength",
      "valueType": "uint8"
    }
  ],
  "assertions": [
    {
      "field": "packStartCode",
      "op": "eq",
      "value": "000001BA",
      "message": "VOB pack start code must be 0x000001BA"
    },
    {
      "field": "scrByte",
      "op": "mask",
      "mask": "0xC0",
      "value": "0x40",
      "message": "Upper 2 bits of SCR byte must be '01' (MPEG-2 marker)"
    },
    {
      "field": "muxRate",
      "op": "gte",
      "value": 1,
      "message": "Mux rate must be non-zero"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "Pack Start Code", "offset": 0, "length": 4, "color": "#FF6B6B" },
      { "name": "SCR Byte", "offset": 4, "length": 1, "color": "#4ECDC4" },
      { "name": "Mux Rate", "offset": 10, "length": 3, "color": "#95E1D3" },
      { "name": "Stuffing Length", "offset": 13, "length": 1, "color": "#FFE66D" }
    ]
  },
  "inspector": {
    "badge": "VOB",
    "primaryField": "packStartCode",
    "showQualityScore": true,
    "groups": [
      {
        "name": "Pack Header",
        "fields": ["packStartCode", "scrByte"]
      },
      {
        "name": "Multiplex Info",
        "fields": ["muxRate", "stuffingLength"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "VOB Pack Summary",
      "format": "text",
      "template": "Start Code: {packStartCode} | SCR byte: {scrByte} | Mux Rate: {muxRate} | Stuffing: {stuffingLength}"
    },
    {
      "name": "VOB JSON Report",
      "format": "json",
      "template": "{ \"startCode\": \"{packStartCode}\", \"muxRate\": {muxRate} }"
    }
  ],
  "forensic": {
    "category": "Video",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Missing 0x000001BA at offset 0 indicates corrupted or non-standard VOB file",
      "SCR values not monotonically increasing indicate stream corruption or splicing",
      "Encrypted content (CSS) indicated by private stream 1 packets with encrypted flag"
    ]
  },
  "aiHints": {
    "analysisContext": "VOB files are MPEG-2 Program Streams. After the pack header, PES (Packetized Elementary Stream) packets follow. PES stream IDs: 0xE0-0xEF=video, 0xBD=private1 (AC-3/DTS/PCM audio), 0xC0-0xDF=MPEG audio. DVD CSS encryption protects VTS_01_1.VOB through VTS_01_x.VOB.",
    "suggestedInspections": [
      "Verify 0x000001BA pack start code at offset 0 for PS/VOB identification",
      "Check upper 2 bits of SCR byte: '01' = MPEG-2, '00' = MPEG-1 Program Stream",
      "Walk PES packets after pack header: identify stream IDs for video and audio tracks",
      "Detect AC-3 audio (stream ID 0x80 in private stream 1) vs DTS (0x88) vs PCM (0xA0)",
      "Locate System Header packets (0x000001BB) for overall stream configuration",
      "Check for CSS encryption by testing for scrambled PES payloads on video streams"
    ]
  },
  "software": [
    "FFmpeg",
    "VLC Media Player",
    "HandBrake",
    "DVD Decrypter",
    "DVDShrink",
    "MakeMKV"
  ],
  "formatRelationships": {
    "category": "Video",
    "extensions": [".vob", ".mpg"],
    "relatedFormats": ["MPEG-PS", "MPEG-TS", "MP4", "BUP", "IFO"],
    "note": "VOB files appear in VIDEO_TS folder alongside IFO (navigation) and BUP (backup) files on DVD-Video discs"
  },
  "MimeTypes": ["video/dvd", "video/mpeg", "video/x-vob"],
  "UseCases": [
    "DVD-Video disc primary video container",
    "MPEG-2 video archiving from broadcast captures",
    "DVD ripping source format for transcoding",
    "DVD menu and navigation video clips",
    "Legacy SVCD and DVD authoring"
  ],
  "QualityMetrics": {
    "CompletenessScore": 90,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 4,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "packStartCode": "0x000001BA",
    "mpeg2Marker": "upper 2 bits of SCR byte = 01",
    "muxRateUnit": "50 bytes/second",
    "streamIds": {
      "video": "0xE0-0xEF",
      "mpegAudio": "0xC0-0xDF",
      "privateStream1": "0xBD (AC-3/DTS/PCM)",
      "systemHeader": "0x000001BB"
    },
    "maxBitrate": "10.08 Mbps (single layer DVD)"
  }
}

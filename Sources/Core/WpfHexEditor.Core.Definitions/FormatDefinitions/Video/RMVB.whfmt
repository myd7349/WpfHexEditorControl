{
  "diffMode": "binary",
  "formatName": "RealMedia Variable Bitrate",
  "version": "1.15",
  "extensions": [
    ".rmvb"
  ],
  "description": "RMVB (RealMedia Variable Bitrate) is a variant of the RealMedia container format developed by RealNetworks. RMVB uses the same RMFF (RealMedia File Format) container as standard .rm files, beginning with the 4-byte magic '.RMF' (0x2E 0x52 0x4D 0x46). The difference from .rm is the use of variable bitrate encoding rather than constant bitrate — RMVB allocates more bits to complex scenes and fewer to simple scenes, achieving better quality at lower average bitrate. The RMFF header structure is identical to RM: magic '.RMF' + object size (uint32 BE) + object version (uint16 BE, 0 or 1) + file version (uint32 BE) + numHeaders (uint32 BE). Following objects include PROP (Properties with VBR flag), MDPR (Media Properties per stream with RV30/RV40 video codec), CONT (optional Content Description), and DATA objects. RMVB dominated Asian (particularly Chinese) online video distribution from 2000-2012.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "RealMedia File Format (RMFF) — RealNetworks",
      "RealMedia Variable Bitrate Technical Overview — RealNetworks",
      "wiki.multimedia.cx — RealMedia"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/RMVB",
      "https://wiki.multimedia.cx/index.php/RealMedia",
      "https://docs.fileformat.com/video/rmvb/"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "2E524D46", "offset": 0, "label": "'.RMF' RealMedia File magic (shared with .rm)", "weight": 1.0 }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 4.5, "max": 7.5 },
    "validation": {
      "minFileSize": 18,
      "maxSignatureOffset": 0,
      "note": "RMVB uses the same '.RMF' magic as .rm. Distinction requires inspecting PROP object VBR flag or MDPR stream codec (RV30/RV40 for RMVB vs RV10/RV20 for older .rm). File extension is the primary differentiator."
    }
  },
  "variables": {
    "rmfMagic": "",
    "objectSize": 0,
    "objectVersion": 0,
    "fileVersion": 0,
    "numHeaders": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "RMF Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "RealMedia File Format magic '.RMF' (0x2E 0x52 0x4D 0x46). Identical in both .rm (constant bitrate) and .rmvb (variable bitrate) files. The leading dot (0x2E) is a Unix file marker convention; 'R', 'M', 'F' identify RealMedia Format. All RMVB files use this magic — the VBR nature is indicated by the PROP object flags, not the magic bytes.",
      "storeAs": "rmfMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "RMF Object Size",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Total size in bytes of the RMFF header object including magic and this field (big-endian uint32). Standard value: 18 for RMFF version 0 (4+4+2+4+4).",
      "storeAs": "objectSize",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Object Version",
      "offset": 8,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.30,
      "description": "RMFF header object version (big-endian uint16). 0 = standard RealMedia (most RMVB files), 1 = extended header. Version 0 is standard for all RMVB content.",
      "storeAs": "objectVersion",
      "valueType": "uint16",
      "endianness": "big",
      "valueMap": {
        "0": "RMFF version 0 — standard (used by all RMVB)",
        "1": "RMFF version 1 — extended header"
      }
    },
    {
      "type": "field",
      "name": "Number of Headers",
      "offset": 14,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.25,
      "description": "Count of header objects following the RMFF header (big-endian uint32). Typical RMVB: PROP + 2 MDPR (video/audio) + optional CONT + DATA = 4-5 headers.",
      "storeAs": "numHeaders",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "metadata",
      "name": "RMF Magic",
      "variable": "rmfMagic",
      "description": "RealMedia magic '.RMF'"
    },
    {
      "type": "metadata",
      "name": "Number of Headers",
      "variable": "numHeaders",
      "description": "Count of RMFF header objects"
    }
  ],
  "assertions": [
    {
      "name": "RMF magic valid",
      "expression": "rmfMagic == '.RMF'",
      "severity": "error",
      "message": "RealMedia magic must be '.RMF' (2E 52 4D 46) — not a valid RMVB file"
    },
    {
      "name": "Object version is 0 or 1",
      "expression": "objectVersion == 0 || objectVersion == 1",
      "severity": "warning",
      "message": "RMFF object version must be 0 or 1"
    }
  ],
  "navigation": {

{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "id Software RoQ Video",
  "formatId": "ROQ",
  "version": "1.1.1",
  "extensions": [ ".roq" ],
  "diffMode": "binary",
  "description": "RoQ is a video format developed by Graeme Devine and used by id Software for Quake III Arena and subsequent games. Uses vector quantization for video and IMA ADPCM for audio.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://wiki.multimedia.cx/index.php/RoQ",
    "https://www.mendisco.com/roq_format.html"
  ],
  "MimeTypes": [ "video/x-roq", "video/roq" ],
  "UseCases": [
    "id Software game FMV playback (Quake III, Doom 3)",
    "Game asset extraction and analysis",
    "Vector-quantized video codec research",
    "Retro game modding"
  ],
  "software": [
    { "name": "ioquake3",   "role": "Open-source Quake III engine with RoQ support", "platform": "Multi", "url": "https://ioquake3.org" },
    { "name": "FFmpeg",     "role": "Open-source RoQ encoder/decoder",               "platform": "Multi", "url": "https://ffmpeg.org" },
    { "name": "VLC",        "role": "Playback via libavcodec",                        "platform": "Multi" },
    { "name": "RoQ Player", "role": "Standalone RoQ player",                         "platform": "Windows" }
  ],
  "detection": {
    "signatures": [
      {
        "value": "8410",
        "offset": 0,
        "label": "RoQ chunk ID 0x1084 (LE bytes: 84 10)",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 88,
    "Strength": "Strong",
    "EntropyHint": { "min": 5.0, "max": 7.5 }
  },
  "variables": [
    { "name": "roqChunkId",    "offset": 0, "size": 2, "type": "uint16", "endian": "LE", "storeAs": "roqChunkId",
      "description": "File identifier chunk ID, must be 0x1084 (4228)",
      "valueMap": { "4228": "RoQ file magic (0x1084)" } },
    { "name": "roqReserved",   "offset": 2, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "roqReserved",
      "description": "Reserved field, must be 0xFFFFFFFF (4294967295)" },
    { "name": "roqFrameRate",  "offset": 6, "size": 2, "type": "uint16", "endian": "LE", "storeAs": "roqFrameRate",
      "description": "Frame rate in frames per second (typically 30)" },
    { "name": "firstChunkId",  "offset": 8, "size": 2, "type": "uint16", "endian": "LE", "storeAs": "firstChunkId",
      "description": "First data chunk type ID",
      "valueMap": { "4098": "0x1002 RoQ codebook", "4099": "0x1003 RoQ quad VQ video frame", "8258": "0x2042 RoQ audio mono", "8259": "0x2044 RoQ audio stereo" } },
    { "name": "firstChunkSize","offset": 10,"size": 4, "type": "uint32", "endian": "LE", "storeAs": "firstChunkSize",
      "description": "Size of the first data chunk payload in bytes" },
    { "name": "firstChunkArg", "offset": 14,"size": 2, "type": "uint16", "endian": "LE", "storeAs": "firstChunkArg",
      "description": "First data chunk argument (chunk-type specific)" }
  ],
  "blocks": [
    {
      "name": "FileIdentifier",
      "offset": 0,
      "size": 8,
      "description": "8-byte RoQ file identifier with magic chunk ID (0x1084), reserved 0xFFFFFFFF and frame rate",
      "color": "#1E90FF",
      "fields": [ "roqChunkId", "roqReserved", "roqFrameRate" ]
    },
    {
      "name": "FirstChunkHeader",
      "offset": 8,
      "size": 8,
      "description": "First data chunk header: chunk type ID, size and argument",
      "color": "#32CD32",
      "fields": [ "firstChunkId", "firstChunkSize", "firstChunkArg" ]
    },
    {
      "name": "CodebookChunks",
      "offset": "variable, within ChunkData",
      "description": "Vector quantization codebook chunks (type 0x1002) containing 2x2 and 4x4 code vectors",
      "color": "#FF6347"
    },
    {
      "name": "VideoFrameChunks",
      "offset": "variable, within ChunkData",
      "description": "Video frame data chunks (0x1003 intra, 0x1004 inter) with VQ block indices",
      "color": "#9370DB"
    },
    {
      "name": "AudioChunks",
      "offset": "variable, within ChunkData",
      "description": "Audio chunks (0x2042 mono, 0x2044 stereo) encoded as IMA ADPCM",
      "color": "#DAA520"
    }
  ],
  "assertions": [
    { "id": "A1", "expression": "roqChunkId == 4228",        "severity": "error",   "message": "RoQ magic chunk ID must be 0x1084 (4228)" },
    { "id": "A2", "expression": "roqReserved == 4294967295", "severity": "error",   "message": "Reserved field must be 0xFFFFFFFF" },
    { "id": "A3", "expression": "roqFrameRate > 0",          "severity": "warning", "message": "Frame rate must be positive" },
    { "id": "A4", "expression": "firstChunkSize < file size","severity": "warning", "message": "First chunk size exceeds file bounds" },
    { "id": "A5", "expression": "roqFrameRate <= 60",        "severity": "warning", "message": "Frame rate > 60 is unusual for RoQ files" }
  ],
  "navigation": {
    "rootLabel": "RoQ Video",
    "entries": [
      { "label": "File Identifier",    "blockRef": "FileIdentifier" },
      { "label": "First Chunk Header", "blockRef": "FirstChunkHeader" },
      { "label": "Codebook Chunks",    "blockRef": "CodebookChunks" },
      { "label": "Video Frame Chunks", "blockRef": "VideoFrameChunks" },
      { "label": "Audio Chunks",       "blockRef": "AudioChunks" }
    ]
  },
  "inspector": {
    "badge": "ROQ",
    "primaryField": "roqFrameRate",
    "groups": [
      { "name": "File Identifier", "fields": [ "roqChunkId", "roqReserved", "roqFrameRate" ] },
      { "name": "First Chunk",     "fields": [ "firstChunkId", "firstChunkSize", "firstChunkArg" ] }
    ]
  },
  "exportTemplates": [
    {
      "name": "File Summary",
      "format": "text",
      "template": "Format: RoQ Video\nMagic: 0x{roqChunkId}\nFrame Rate: {roqFrameRate} fps\nFirst Chunk Type: {firstChunkId}\nFirst Chunk Size: {firstChunkSize} bytes"
    },
    {
      "name": "CSV Metadata",
      "format": "csv",
      "template": "Field,Value\nChunkId,{roqChunkId}\nReserved,{roqReserved}\nFrameRate,{roqFrameRate}\nFirstChunkId,{firstChunkId}\nFirstChunkSize,{firstChunkSize}"
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "suspiciousPatterns": [
      "roqChunkId != 0x1084 — wrong format or corrupt header",
      "roqReserved != 0xFFFFFFFF — magic tampered",
      "roqFrameRate == 0 — invalid file",
      "Chunk size extending beyond file bounds — truncated or corrupt"
    ],
    "hidingTechniques": [
      "Extra data appended after last chunk",
      "Oversized reserved chunk payload containing embedded data",
      "Non-standard chunk type IDs outside the known RoQ range"
    ],
    "timestampFields": [],
    "notes": "RoQ was notably used in Quake III Arena intro videos. Video dimensions are stored in the codebook chunk argument, not in the file header. All chunks follow the same 8-byte header structure (2B type, 4B size, 2B argument)."
  },
  "aiHints": {
    "analysisContext": "RoQ is a chunk-based format. The file begins with an 8-byte file identifier chunk (type 0x1084), then a sequence of data chunks each with an 8-byte header. Video dimensions are embedded in the codebook chunk. Parsing requires sequentially walking all chunks.",
    "suggestedInspections": [
      "Verify chunk ID 0x1084 at offset 0 and 0xFFFFFFFF reserved at offset 2",
      "Walk the chunk sequence verifying each chunk header size field stays within file bounds",
      "Identify the first codebook chunk (0x1002) to extract video width and height from its argument field",
      "Check audio chunk type (0x2042 mono vs 0x2044 stereo) for audio channel configuration",
      "Verify roqFrameRate is a standard rate (typically 30 fps for Quake III)"
    ]
  },
  "formatRelationships": [
    { "format": "BIK", "relationship": "sibling", "description": "Bink Video is a contemporaneous proprietary game video format" },
    { "format": "SMK", "relationship": "sibling", "description": "Smacker is another proprietary game FMV format from the same era" }
  ],
  "TechnicalDetails": {
    "endianness": "Little-Endian",
    "minimumFileSize": 16,
    "fileIdentifierSize": 8,
    "chunkHeaderSize": 8,
    "videoCodec": "Vector Quantization (2x2 and 4x4 blocks)",
    "audioCodec": "IMA ADPCM",
    "chunkTypes": {
      "0x1002": "Codebook (VQ palette)",
      "0x1003": "Intra video frame",
      "0x1004": "Inter video frame",
      "0x2042": "Audio mono",
      "0x2044": "Audio stereo"
    }
  },
  "QualityMetrics": {
    "CompletenessScore": 91,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team",
    "KnownLimitations": "Video dimensions are not in the file header; they appear in the codebook chunk argument requiring chunk-level parsing."
  }
}




{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "Bink Video (RAD Game Tools)",
  "formatId": "BIK",
  "version": "1.1",
  "extensions": [ ".bik", ".bk2", ".bik2" ],
  "diffMode": "binary",
  "description": "Bink Video is a proprietary video compression format by RAD Game Tools widely used in video games for full-motion video cutscenes. Supports Bink1 and Bink2 codecs.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://wiki.multimedia.cx/index.php/Bink_Video",
    "https://www.radgametools.com/bnkmain.htm"
  ],
  "MimeTypes": [ "video/vnd.radgametools.bink", "video/x-bink" ],
  "UseCases": [
    "Video game cutscene playback",
    "Game asset extraction and analysis",
    "Full-motion video reverse engineering",
    "Game modding and video replacement"
  ],
  "software": [
    { "name": "RAD Video Tools", "role": "Official encoder/decoder/player", "platform": "Windows", "url": "https://www.radgametools.com/bnkdown.htm" },
    { "name": "FFmpeg",          "role": "Open-source decoder",             "platform": "Multi",   "url": "https://ffmpeg.org" },
    { "name": "VLC",             "role": "Playback via libavcodec",          "platform": "Multi" },
    { "name": "BinkPlayer",      "role": "Standalone Bink player",           "platform": "Windows" }
  ],
  "detection": {
    "signatures": [
      { "value": "42494B66", "offset": 0, "label": "'BIKf' Bink1 variant f", "weight": 1.0 },
      { "value": "42494B62", "offset": 0, "label": "'BIKb' Bink1 variant b", "weight": 1.0 },
      { "value": "42494B64", "offset": 0, "label": "'BIKd' Bink1 variant d", "weight": 1.0 },
      { "value": "42494B67", "offset": 0, "label": "'BIKg' Bink1 variant g", "weight": 1.0 },
      { "value": "42494B68", "offset": 0, "label": "'BIKh' Bink1 variant h", "weight": 1.0 },
      { "value": "42494B69", "offset": 0, "label": "'BIKi' Bink1 variant i", "weight": 1.0 },
      { "value": "42493278", "offset": 0, "label": "'BI2x' Bink2 variant x", "weight": 1.0 },
      { "value": "4249326C", "offset": 0, "label": "'BI2l' Bink2 variant l", "weight": 0.9 }
    ],
    "matchMode": "any",
    "MinimumScore": 88,
    "Strength": "Strong",
    "EntropyHint": { "min": 5.5, "max": 7.8 }
  },
  "variables": [
    { "name": "bikMagic",        "offset": 0,  "size": 4, "type": "ascii",  "storeAs": "bikMagic",       "description": "4-byte magic identifying Bink version and variant" },
    { "name": "bikFileSize",     "offset": 4,  "size": 4, "type": "uint32", "endian": "LE", "storeAs": "bikFileSize",     "description": "File size minus 8 bytes" },
    { "name": "bikFrameCount",   "offset": 8,  "size": 4, "type": "uint32", "endian": "LE", "storeAs": "bikFrameCount",   "description": "Total number of video frames" },
    { "name": "bikLargestFrame", "offset": 12, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "bikLargestFrame", "description": "Size of the largest frame in bytes" },
    { "name": "bikNumFrames2",   "offset": 16, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "bikNumFrames2",   "description": "Number of frames (alternate field, should equal bikFrameCount)" },
    { "name": "bikWidth",        "offset": 20, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "bikWidth",        "description": "Video width in pixels" },
    { "name": "bikHeight",       "offset": 24, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "bikHeight",       "description": "Video height in pixels" },
    { "name": "bikFpsNum",       "offset": 28, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "bikFpsNum",       "description": "Frame rate numerator" },
    { "name": "bikFpsDen",       "offset": 32, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "bikFpsDen",       "description": "Frame rate denominator" },
    { "name": "bikVideoFlags",   "offset": 36, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "bikVideoFlags",   "description": "Video flags: bit0=has alpha plane, bit8=has LoopFromFrame" },
    { "name": "bikNumTracks",    "offset": 40, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "bikNumTracks",    "description": "Number of audio tracks" }
  ],
  "blocks": [
    {
      "name": "FileHeader",
      "offset": 0,
      "size": 44,
      "description": "Bink fixed file header with magic, file size, frame count, dimensions and FPS",
      "color": "#1E90FF",
      "fields": [ "bikMagic", "bikFileSize", "bikFrameCount", "bikLargestFrame", "bikNumFrames2",
                  "bikWidth", "bikHeight", "bikFpsNum", "bikFpsDen", "bikVideoFlags", "bikNumTracks" ]
    },
    {
      "name": "AudioTrackHeaders",
      "offset": 44,
      "sizeExpression": "bikNumTracks * 12",
      "description": "Per-audio-track headers (sample rate, channel count, flags)",
      "color": "#32CD32"
    },
    {
      "name": "FrameOffsetTable",
      "offset": "after audio headers",
      "sizeExpression": "(bikFrameCount + 1) * 4",
      "description": "Frame offset table: (frameCount+1) entries of 4 bytes each giving absolute file offsets",
      "color": "#FFA500"
    },
    {
      "name": "FrameData",
      "offset": "after frame offset table",
      "description": "Compressed video and audio frame data blocks",
      "color": "#FF6347"
    }
  ],
  "assertions": [
    { "id": "A1", "expression": "bikFrameCount > 0",                   "severity": "error",   "message": "Frame count must be positive" },
    { "id": "A2", "expression": "bikWidth > 0",                        "severity": "error",   "message": "Video width must be positive" },
    { "id": "A3", "expression": "bikHeight > 0",                       "severity": "error",   "message": "Video height must be positive" },
    { "id": "A4", "expression": "bikFpsDen > 0",                       "severity": "error",   "message": "FPS denominator must be nonzero" },
    { "id": "A5", "expression": "bikFileSize + 8 == file size",        "severity": "warning", "message": "Declared file size does not match actual file size" }
  ],
  "navigation": {
    "rootLabel": "Bink Video",
    "entries": [
      { "label": "File Header",         "blockRef": "FileHeader" },
      { "label": "Audio Track Headers", "blockRef": "AudioTrackHeaders" },
      { "label": "Frame Offset Table",  "blockRef": "FrameOffsetTable" },
      { "label": "Frame Data",          "blockRef": "FrameData" }
    ]
  },
  "inspector": {
    "badge": "BIK",
    "primaryField": "bikMagic",
    "groups": [
      { "name": "Identity",  "fields": [ "bikMagic" ] },
      { "name": "Video",     "fields": [ "bikWidth", "bikHeight", "bikFpsNum", "bikFpsDen", "bikVideoFlags" ] },
      { "name": "Structure", "fields": [ "bikFrameCount", "bikLargestFrame", "bikFileSize", "bikNumTracks" ] }
    ]
  },
  "exportTemplates": [
    {
      "name": "Video Summary",
      "format": "text",
      "template": "Format: {bikMagic}\nResolution: {bikWidth}x{bikHeight}\nFrames: {bikFrameCount}\nFPS: {bikFpsNum}/{bikFpsDen}\nAudio Tracks: {bikNumTracks}\nLargest Frame: {bikLargestFrame} bytes"
    },
    {
      "name": "CSV Metadata",
      "format": "csv",
      "template": "Field,Value\nMagic,{bikMagic}\nWidth,{bikWidth}\nHeight,{bikHeight}\nFrameCount,{bikFrameCount}\nFpsNum,{bikFpsNum}\nFpsDen,{bikFpsDen}\nAudioTracks,{bikNumTracks}\nLargestFrame,{bikLargestFrame}"
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "suspiciousPatterns": [
      "bikFileSize + 8 does not match actual file size — truncated or padded",
      "bikFrameCount == 0 — invalid video",
      "bikLargestFrame larger than file size — corrupt header",
      "Frame offsets in table pointing outside file bounds — structural corruption"
    ],
    "hidingTechniques": [
      "Extra data appended after last frame block",
      "Padding between declared file size and actual EOF",
      "Embedded data within unused audio track slots"
    ],
    "timestampFields": [],
    "notes": "Bink1 and Bink2 have different internal frame structures. The 4th byte of the magic ('BIKx') identifies the variant. Bink2 files (.bk2) use 'BI2' prefix."
  },
  "aiHints": {
    "analysisContext": "Bink Video uses a compact fixed header followed by per-track audio headers, a frame offset table and compressed frame data. Frame positions are determined by the offset table; the last entry points past the last frame. Frame rate is stored as a numerator/denominator pair.",
    "suggestedInspections": [
      "Verify magic is 'BIK' or 'BI2' prefix and identify the codec variant from byte 3",
      "Validate bikFileSize + 8 matches actual file size",
      "Inspect frame offset table: confirm entries are monotonically increasing and last entry == file size",
      "Check bikWidth and bikHeight are nonzero and within reasonable video dimensions",
      "Compute FPS as bikFpsNum/bikFpsDen and verify it is a standard frame rate (24, 25, 29.97, 30, 60)"
    ]
  },
  "formatRelationships": [
    { "format": "SMK", "relationship": "sibling", "description": "Smacker Video is the predecessor format from the same RAD Game Tools" },
    { "format": "AVI", "relationship": "sibling", "description": "AVI is a contemporaneous PC video container format" }
  ],
  "TechnicalDetails": {
    "endianness": "Little-Endian",
    "minimumFileSize": 44,
    "headerSize": 44,
    "frameOffsetEntries": "frameCount + 1",
    "bink1Variants": [ "BIKb", "BIKd", "BIKf", "BIKg", "BIKh", "BIKi" ],
    "bink2Variants": [ "BI2x", "BI2l", "BI2f" ],
    "compressionType": "Proprietary RAD Bink codec",
    "audioCodecs": [ "Bink Audio (DCT)", "Bink Audio (RDFT)" ]
  },
  "QualityMetrics": {
    "CompletenessScore": 91,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team",
    "KnownLimitations": "Audio track header layout differs between Bink1 and Bink2; exact audio fields require codec-specific parsing."
  }
}




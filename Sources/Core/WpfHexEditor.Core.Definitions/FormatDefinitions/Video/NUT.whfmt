{
  "formatName": "NUT Multimedia Container",
  "version": "1.0",
  "author": "WPFHexaEditor Team",
  "lastUpdated": "2026-04-15",
  "description": "NUT open multimedia container format (.nut) — designed by the FFmpeg and MPlayer communities as a simple, extensible alternative to AVI/MKV with CRC-32 error detection and variable-length integer encoding.",
  "extensions": [ ".nut" ],
  "category": "Video",
  "diffMode": "binary",
  "signatures": [
    {
      "value": "F6E2F4AD",
      "offset": 0,
      "label": "NUT file header magic — first 4 bytes of the 8-byte NUT container identifier",
      "weight": 1.0,
      "strength": "Strong"
    }
  ],
  "maxSignatureOffset": 4,
  "structure": {
    "fields": [
      { "offset": 0, "size": 8, "name": "file_magic", "type": "bytes", "description": "8-byte NUT file magic: 0xF6E2F4ADEC3B2B00", "storeAs": "nutMagic" }
    ],
    "notes": "NUT uses variable-length integer (vint) encoding similar to EBML. After the 8-byte file magic, the first packet is a main header containing stream count, time base list, and chapter info. Each packet has: 8-byte startcode + forward_ptr(vint) + checksum(CRC-32 4B) + data.",
    "packetStartcodes": [
      { "code": "0x7A561F5F4551B0F4", "name": "main_header",    "description": "Main file header with global stream metadata" },
      { "code": "0x11405BF2F9DBD794", "name": "stream_header",  "description": "Per-stream header (codec, time base, sample rate)" },
      { "code": "0xE4ADEECA4569F4D0", "name": "syncpoint",      "description": "Synchronisation point for seeking" },
      { "code": "0xDD672F23E64EDEA4", "name": "index",          "description": "Optional seekable index packet" },
      { "code": "0xAB68B596BA7786CB", "name": "info",           "description": "Optional metadata info packet (title, artist, etc.)" }
    ]
  },
  "inspector": {
    "displayFields": [ "nutMagic" ],
    "tooltips": {
      "nutMagic": "8-byte magic: F6 E2 F4 AD EC 3B 2B 00 — unique to NUT container format"
    }
  },
  "assertions": [
    { "id": "A1", "field": "nutMagic", "operator": "startsWith", "value": "F6E2F4AD", "description": "First 4 bytes must match NUT magic 0xF6E2F4AD" }
  ],
  "navigation": {
    "bookmarks": [
      { "offset": 0, "label": "NUT File Magic (8B)",      "color": "#E74C3C" },

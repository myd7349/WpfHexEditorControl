{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "NUT Multimedia Container",
  "formatId": "NUT",
  "version": "1.1.2",
  "extensions": [ ".nut" ],
  "diffMode": "binary",
  "description": "NUT is an open multimedia container format developed by the FFmpeg project. Designed for simplicity and seeking efficiency with variable-length integer encoding throughout.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://ffmpeg.org/~michael/nut.txt",
    "https://wiki.multimedia.cx/index.php/NUT"
  ],
  "MimeTypes": [ "video/x-nut", "application/x-nut" ],
  "UseCases": [
    "FFmpeg stream muxing and testing",
    "Open multimedia container research",
    "Lossless video archival",
    "Custom codec container packaging"
  ],
  "software": [
    { "name": "FFmpeg", "role": "Primary encoder/decoder/muxer/demuxer", "platform": "Multi", "url": "https://ffmpeg.org" },
    { "name": "mplayer","role": "NUT demuxer support",                   "platform": "Multi" },
    { "name": "VLC",    "role": "Limited NUT playback support",          "platform": "Multi" }
  ],
  "detection": {
    "signatures": [
      {
        "value": "F6E2F4ADEC3B2B00",
        "offset": 0,
        "label": "NUT file magic (8 bytes: F6 E2 F4 AD EC 3B 2B 00)",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 88,
    "Strength": "Strong",
    "EntropyHint": { "min": 4.5, "max": 7.5 }
  },
  "variables": [
    { "name": "nutMagic",        "offset": 0, "size": 8, "type": "bytes", "storeAs": "nutMagic",
      "description": "NUT file identifier: F6 E2 F4 AD EC 3B 2B 00" },
    { "name": "nutFirstType",    "offset": 8, "size": 1, "type": "uint8", "storeAs": "nutFirstType",
      "description": "First byte after magic, identifies first packet type prefix" },
    { "name": "nutVersion",      "offset": "variable", "size": "vint", "type": "int64", "storeAs": "nutVersion",
      "description": "NUT stream version (variable-length integer, typically 3)" },
    { "name": "nutStreamCount",  "offset": "variable", "size": "vint", "type": "int64", "storeAs": "nutStreamCount",
      "description": "Number of streams in the container" },
    { "name": "nutMaxDistance",  "offset": "variable", "size": "vint", "type": "int64", "storeAs": "nutMaxDistance",
      "description": "Maximum distance between keyframes for seeking" },
    { "name": "nutTimeBaseCount","offset": "variable", "size": "vint", "type": "int64", "storeAs": "nutTimeBaseCount",
      "description": "Number of time bases defined in main header" }
  ],
  "blocks": [
    {
      "name": "FileMagic",
      "offset": 0,
      "size": 8,
      "description": "8-byte NUT file magic identifier",
      "color": "#1E90FF",
      "fields": [ "nutMagic" ]
    },
    {
      "name": "MainHeader",
      "offset": 8,
      "description": "NUT main header packet containing version, stream count, time bases and frame table",
      "color": "#32CD32",
      "fields": [ "nutFirstType", "nutVersion", "nutStreamCount", "nutMaxDistance", "nutTimeBaseCount" ]
    },
    {
      "name": "StreamHeaders",
      "offset": "after main header",
      "description": "Per-stream header packets defining codec, dimensions, sample rate, etc.",
      "color": "#FFA500"
    },
    {
      "name": "SyncPoints",
      "offset": "interspersed",
      "description": "Sync point packets providing random-access seek positions",
      "color": "#FF6347"
    },
    {
      "name": "DataFrames",
      "offset": "after stream headers",
      "description": "Encoded media data frame packets (video/audio/subtitle)",
      "color": "#9370DB"
    },
    {
      "name": "Index",
      "offset": "near end of file",
      "description": "Optional NUT index packet for fast seeking",
      "color": "#20B2AA"
    }
  ],
  "assertions": [
    { "id": "A1", "expression": "nutMagic == [0xF6, 0xE2, 0xF4, 0xAD, 0xEC, 0x3B, 0x2B, 0x00]", "severity": "error",   "message": "NUT file magic must be F6 E2 F4 AD EC 3B 2B 00" },
    { "id": "A2", "expression": "nutVersion >= 2",                                                 "severity": "warning", "message": "NUT version should be >= 2" },
    { "id": "A3", "expression": "nutStreamCount >= 1",                                             "severity": "warning", "message": "NUT file should have at least one stream" },
    { "id": "A4", "expression": "nutMaxDistance > 0",                                              "severity": "warning", "message": "Max distance must be positive for seeking" },
    { "id": "A5", "expression": "nutTimeBaseCount >= 1",                                           "severity": "warning", "message": "At least one time base must be defined" }
  ],
  "navigation": {
    "rootLabel": "NUT Container",
    "entries": [
      { "label": "File Magic",     "blockRef": "FileMagic" },
      { "label": "Main Header",    "blockRef": "MainHeader" },
      { "label": "Stream Headers", "blockRef": "StreamHeaders" },
      { "label": "Sync Points",    "blockRef": "SyncPoints" },
      { "label": "Data Frames",    "blockRef": "DataFrames" },
      { "label": "Index",          "blockRef": "Index" }
    ]
  },
  "inspector": {
    "badge": "NUT",
    "primaryField": "nutVersion",
    "groups": [
      { "name": "Identity",       "fields": [ "nutMagic", "nutFirstType" ] },
      { "name": "Container Info", "fields": [ "nutVersion", "nutStreamCount", "nutMaxDistance", "nutTimeBaseCount" ] }
    ]
  },
  "exportTemplates": [
    {
      "name": "Container Summary",
      "format": "text",
      "template": "Format: NUT Multimedia Container\nVersion: {nutVersion}\nStreams: {nutStreamCount}\nTime Bases: {nutTimeBaseCount}\nMax Distance: {nutMaxDistance}"
    },
    {
      "name": "CSV Metadata",
      "format": "csv",
      "template": "Field,Value\nVersion,{nutVersion}\nStreamCount,{nutStreamCount}\nMaxDistance,{nutMaxDistance}\nTimeBaseCount,{nutTimeBaseCount}"
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "suspiciousPatterns": [
      "File magic mismatch — wrong format or corrupt",
      "Truncated main header — file cut before first stream header",
      "Inconsistent CRC in header packet — data corruption",
      "Frame packet sizes pointing outside file bounds"
    ],
    "hidingTechniques": [
      "Extra data in reserved fields of header packets",
      "Appended data after the index packet at end-of-file",
      "Non-standard packet type codes embedding arbitrary data"
    ],
    "timestampFields": [],
    "notes": "NUT uses variable-length integers (vint) and Elias coding throughout. All packets include a CRC-32 for integrity checking. The format was designed as an alternative to Matroska."
  },
  "aiHints": {
    "analysisContext": "NUT is a packet-based container where all fields after the 8-byte magic use variable-length integer encoding. Parsing requires sequential reading from the magic through the main header then stream headers. CRC checksums on all major packets enable corruption detection.",
    "suggestedInspections": [
      "Verify the 8-byte file magic F6 E2 F4 AD EC 3B 2B 00 at offset 0",
      "Parse the main header packet using variable-length integer decoder to extract version and stream count",
      "Verify CRC-32 of the main header packet",
      "Walk stream header packets to identify codec types, dimensions and sample rates",
      "Check for presence of index packet at end of file which enables efficient seeking"
    ]
  },
  "formatRelationships": [
    { "format": "MKV", "relationship": "sibling",  "description": "Matroska (MKV) was the alternative open container that NUT was designed to compete with" },
    { "format": "AVI", "relationship": "ancestor", "description": "AVI is the legacy container NUT aimed to improve upon" },
    { "format": "OGV", "relationship": "sibling",  "description": "Ogg/OGV is another open multimedia container format" }
  ],
  "TechnicalDetails": {
    "endianness": "Big-Endian for integers, variable-length encoded",
    "minimumFileSize": 9,
    "magicSize": 8,
    "integerEncoding": "Variable-length (vint / Elias gamma)",
    "checksumAlgorithm": "CRC-32",
    "syncPointInterval": "configurable via maxDistance",
    "specVersion": "3"
  },
  "QualityMetrics": {
    "CompletenessScore": 89,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team",
    "KnownLimitations": "Variable-length integer encoding throughout makes static offset-based field parsing impractical; fields are marked as 'variable' offset."
  }
}




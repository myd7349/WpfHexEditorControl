{
  "diffMode": "binary",
  "formatName": "Blu-ray MPEG-2 Transport Stream",
  "version": "1.0",
  "extensions": [".m2ts", ".mts", ".ts"],
  "description": "M2TS is the Blu-ray Disc container format based on MPEG-2 Transport Stream with a 4-byte Blu-ray source packet (timestamp) prefix prepended to each standard 188-byte TS packet, yielding 192-byte source packets. The MPEG-2 TS sync byte 0x47 appears at offset 4 of each 192-byte packet. Plain TS files (without Blu-ray header) have 0x47 at offset 0. The PID field (13 bits at bits 3-15 of the two bytes after the sync byte) identifies the elementary stream. M2TS is used on Blu-ray Discs and AVCHD camcorders for H.264 and VC-1 encoded high-definition video.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": {
    "specifications": [
      "ISO/IEC 13818-1: MPEG-2 Systems (Transport Stream)",
      "Blu-ray Disc Association: Blu-ray Disc Read-Only Format Part 3 Audio Visual Basic Specifications"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/MPEG_transport_stream",
      "https://en.wikipedia.org/wiki/BDAV_MPEG-2_transport_stream"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "47",
        "offset": 4,
        "label": "TS sync byte 0x47 at offset 4 — M2TS Blu-ray 192-byte packet",
        "weight": 0.9
      },
      {
        "value": "47",
        "offset": 0,
        "label": "TS sync byte 0x47 at offset 0 — plain 188-byte TS stream",
        "weight": 0.7
      }
    ],
    "matchMode": "Any",
    "MinimumScore": 0.5,
    "required": [],
    "Strength": "Medium",
    "EntropyHint": {
      "min": 5.0,
      "max": 8.0,
      "comment": "MPEG-2 compressed video/audio multiplex exhibits high entropy"
    },
    "validation": {
      "notes": "Sync byte 0x47 must appear every 192 bytes (M2TS) or every 188 bytes (TS); PID must be < 0x2000"
    }
  },
  "variables": {
    "timestamp": 0,
    "tsSyncByte": 0,
    "pid": 0,
    "continuityCounter": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "timestamp",
      "offset": 0,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.75,
      "description": "Blu-ray 4-byte source packet timestamp (big-endian uint32) — encodes a 30-bit arrival time stamp (ATS) in units of 1/27000000 seconds; present only in M2TS files, not in plain TS",
      "storeAs": "timestamp",
      "valueType": "uint32BE"
    },
    {
      "type": "field",
      "name": "tsSyncByte",
      "offset": 4,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "MPEG-2 TS synchronization byte — always 0x47; marks the start of the 188-byte TS packet payload within the 192-byte M2TS source packet; must appear at every 192-byte interval",
      "storeAs": "tsSyncByte",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "pid",
      "offset": 5,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.75,
      "description": "Packet Identifier (PID) — 13-bit value in bits 0-12 of the uint16BE at offset 5 (after masking upper 3 flag bits); identifies the elementary stream; PAT is PID 0x0000, PMT is defined in PAT",
      "storeAs": "pid",
      "valueType": "uint16BE"
    },
    {
      "type": "field",
      "name": "continuityCounter",
      "offset": 7,
      "length": 1,
      "color": "#FFE66D",
      "opacity": 0.75,
      "description": "Continuity counter — lower 4 bits of the byte at offset 7; increments per packet per PID; used to detect dropped or duplicate TS packets during transmission",
      "storeAs": "continuityCounter",
      "valueType": "uint8"
    }
  ],
  "assertions": [
    {
      "field": "tsSyncByte",
      "op": "eq",
      "value": "0x47",
      "message": "TS sync byte must be 0x47 at offset 4 (M2TS) or offset 0 (plain TS)"
    },
    {
      "field": "pid",
      "op": "lte",
      "value": "0x1FFF",
      "message": "PID must be < 0x2000 (13-bit field maximum)"
    },
    {
      "field": "timestamp",
      "op": "range",
      "min": 0,
      "max": 1073741823,
      "message": "M2TS timestamp must fit in 30-bit range"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "Blu-ray Timestamp", "offset": 0, "length": 4, "color": "#4ECDC4" },
      { "name": "TS Sync Byte (0x47)", "offset": 4, "length": 1, "color": "#FF6B6B" },
      { "name": "PID", "offset": 5, "length": 2, "color": "#95E1D3" },
      { "name": "Continuity Counter", "offset": 7, "length": 1, "color": "#FFE66D" },
      { "name": "Packet 2 Start", "offset": 192, "length": 4, "color": "#4ECDC4" }
    ]
  },
  "inspector": {
    "badge": "M2TS",
    "primaryField": "tsSyncByte",
    "showQualityScore": true,
    "groups": [
      {
        "name": "Blu-ray Header",
        "fields": ["timestamp"]
      },
      {
        "name": "TS Packet",
        "fields": ["tsSyncByte", "pid", "continuityCounter"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "M2TS Packet Summary",
      "format": "text",
      "template": "Timestamp: {timestamp} | Sync: 0x{tsSyncByte} | PID: {pid} | CC: {continuityCounter}"
    },
    {
      "name": "M2TS JSON Report",
      "format": "json",
      "template": "{ \"timestamp\": {timestamp}, \"pid\": {pid}, \"continuityCounter\": {continuityCounter} }"
    }
  ],
  "forensic": {
    "category": "Video",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Sync byte != 0x47 at expected packet boundaries indicates stream corruption",
      "Non-monotonic timestamps suggest packet reordering or stream manipulation",
      "Continuity counter discontinuity indicates dropped or inserted packets",
      "PID 0x1FFF (null packets) in high proportion indicates padding or stream stuffing"
    ]
  },
  "aiHints": {
    "analysisContext": "M2TS wraps standard 188-byte MPEG-2 TS packets with a 4-byte Blu-ray timestamp prefix. The TS payload starts at offset 4 with sync byte 0x47. PAT (PID 0) lists PMT PIDs; PMT lists video/audio/subtitle stream PIDs. AVCHD camcorders use identical M2TS structure.",
    "suggestedInspections": [
      "Confirm 0x47 sync at offset 4 and every 192 bytes thereafter for M2TS structure",
      "Parse PAT at PID 0x0000 to find PMT PID for this program",
      "Parse PMT to enumerate all elementary stream PIDs and their types",
      "Decode PID flags: bit 13-15 of PID word encode transport_error_indicator, payload_unit_start, transport_priority",
      "Calculate stream duration from PCR values (Program Clock Reference) in adaptation fields",
      "Detect AVCHD vs pure M2TS by examining PID structure and codec stream types"
    ]
  },
  "software": [
    "FFmpeg",
    "VLC Media Player",
    "MakeMKV",
    "tsMuxeR",
    "BDInfo",
    "Handbrake"
  ],
  "formatRelationships": {
    "category": "Video",
    "extensions": [".m2ts", ".mts", ".ts"],
    "relatedFormats": ["MPEG-TS", "MP4", "MKV", "VOB", "BDMV"],
    "note": "M2TS adds 4-byte Blu-ray timestamp to standard 188-byte MPEG-2 TS; .mts extension is used by Sony and Panasonic AVCHD camcorders"
  },
  "MimeTypes": ["video/mp2t", "video/x-m2ts"],
  "UseCases": [
    "Blu-ray Disc video storage and playback",
    "AVCHD camcorder HD recording format",
    "Digital broadcast TV capture and archiving",
    "High-definition video editing input",
    "Satellite and cable broadcast stream analysis"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 4,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "packetSizeM2TS": 192,
    "packetSizeTS": 188,
    "timestampPrefixBytes": 4,
    "syncByte": "0x47",
    "pidBits": 13,
    "nullPID": "0x1FFF",
    "patPID": "0x0000"
  }
}

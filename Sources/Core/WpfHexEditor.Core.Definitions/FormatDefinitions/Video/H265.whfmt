  "formatRelationships": {
    "category": "Video",
    "extensions": [".h265", ".265", ".hevc"],
    "relatedFormats": ["H264", "MP4", "MKV", "TS"],
    "note": "Raw H.265 Annex B elementary stream — typically encapsulated in MPEG-TS (.ts), MP4 (.mp4 with hvc1/hev1 codec box), or MKV (.mkv). In containers, H.265 may use length-prefixed (hvcC) format. Used in 4K/8K UHD broadcast, streaming (Netflix, YouTube 4K), and HEVC-encoded Blu-ray."
  },

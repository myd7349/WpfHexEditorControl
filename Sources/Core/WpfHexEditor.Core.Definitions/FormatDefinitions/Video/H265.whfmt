{
  "diffMode": "binary",
  "formatName": "Raw H.265/HEVC",
  "version": "1.15",
  "extensions": [
    ".h265",
    ".265",
    ".hevc"
  ],
  "description": "Raw H.265/HEVC (High Efficiency Video Coding) elementary bitstream as defined in ITU-T H.265 and ISO/IEC 23008-2. Like H.264, HEVC uses Annex B byte-stream format with start code prefixes (0x00 0x00 0x00 0x01 long or 0x00 0x00 0x01 short). H.265 uses a 2-byte NALU header: bits 15 (forbidden_zero_bit=0), bits 14-9 (nal_unit_type, 6 bits), bits 8-6 (nuh_layer_id), bits 5-0 (nuh_temporal_id_plus1). Key NALU types: 32=VPS (Video Parameter Set), 33=SPS, 34=PPS, 35=AUD, 1=TRAIL_R (inter), 19=IDR_W_RADL (keyframe). H.265 delivers 40-50% better compression than H.264 at equivalent quality, enabling 4K and 8K streaming. The SPS contains profile_tier_level with profile (Main, Main 10, Main Still Picture) and level.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ITU-T H.265 — High Efficiency Video Coding (HEVC)",
      "ISO/IEC 23008-2 — MPEG-H Part 2 HEVC",
      "ISO/IEC 14496-15 — HEVC File Format (hvcC)"
    ],
    "WebLinks": [
      "https://www.itu.int/rec/T-REC-H.265",
      "https://en.wikipedia.org/wiki/High_Efficiency_Video_Coding",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000530.shtml",
      "https://hevc.hhi.fraunhofer.de/"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "00000001", "offset": 0, "label": "H.265 Annex B long start code (4-byte)", "weight": 0.7 },
      { "value": "000001", "offset": 0, "label": "H.265 Annex B short start code (3-byte)", "weight": 0.5 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.5,
    "required": true,
    "Strength": "Medium",
    "EntropyHint": { "min": 5.5, "max": 7.8 },
    "validation": {
      "minFileSize": 6,
      "note": "H.265 Annex B start code is identical to H.264. Distinguish by NALU header: H.265 has 2-byte header (bits 14-9 = nal_unit_type). HEVC VPS/SPS/PPS types are 32/33/34 — H.264 only uses 7/8. H.265 nal_unit_type 32 (VPS) at stream start is a reliable differentiator."
    }
  },
  "variables": {
    "startCode": 0,
    "naluHeaderByte1": 0,
    "naluHeaderByte2": 0,
    "naluType": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Annex B Start Code",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "H.265 Annex B long start code prefix 0x00 0x00 0x00 0x01. Identical to H.264 Annex B start code. The 2-byte NALU header after this start code distinguishes H.265 from H.264 (H.265 uses 6-bit nal_unit_type in bits 14-9 of the 2-byte header). H.265 streams typically begin with VPS (type 32) + SPS (type 33) + PPS (type 34) before the first IDR frame.",
      "storeAs": "startCode",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "NALU Header Byte 1",
      "offset": 4,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "First byte of H.265 2-byte NALU header. Bit 7 = forbidden_zero_bit (must be 0). Bits 6-1 = nal_unit_type (6 bits, upper part). Bit 0 = nuh_layer_id upper bit. Key nal_unit_type values (from combined 2-byte header): 1=TRAIL_R (inter-frame), 19=IDR_W_RADL (keyframe), 32=VPS, 33=SPS, 34=PPS, 35=AUD.",
      "storeAs": "naluHeaderByte1",
      "valueType": "uint8",
      "bitfields": [
        { "name": "Forbidden Zero Bit", "bits": "7", "description": "Must be 0" },
        { "name": "NALU Type (bits 5-0 mapped to bits 6-1)", "bits": "6-1", "description": "H.265 6-bit NALU type", "valueMap": { "1": "TRAIL_R (non-keyframe)", "16": "BLA_W_LP", "19": "IDR_W_RADL (keyframe)", "20": "IDR_N_LP", "21": "CRA_NUT", "32": "VPS", "33": "SPS", "34": "PPS", "35": "AUD (Access Unit Delimiter)" } },
        { "name": "Layer ID (bit 5)", "bits": "0", "description": "Upper bit of nuh_layer_id (6 bits total)" }
      ]
    },
    {
      "type": "field",
      "name": "NALU Header Byte 2",
      "offset": 5,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.25,
      "description": "Second byte of H.265 2-byte NALU header. Bits 7-3 = nuh_layer_id lower 5 bits (for multi-layer HEVC, typically 0 for base layer). Bits 2-0 = nuh_temporal_id_plus1 (temporal sublayer ID + 1, minimum 1, must be non-zero).",
      "storeAs": "naluHeaderByte2",
      "valueType": "uint8",
      "bitfields": [
        { "name": "Layer ID", "bits": "7-3", "description": "nuh_layer_id lower 5 bits (0 for base layer)" },
        { "name": "Temporal ID + 1", "bits": "2-0", "description": "nuh_temporal_id_plus1 (must be >= 1; 1 = base temporal layer)" }
      ]
    },
    {
      "type": "metadata",
      "name": "Start Code",
      "variable": "startCode",
      "description": "Annex B start code (0x00000001 = 1)"
    },
    {
      "type": "metadata",
      "name": "NALU Header",
      "variable": "naluHeaderByte1",
      "description": "First NALU type (32=VPS, 33=SPS, 19=IDR)"
    }
  ],
  "assertions": [
    {
      "name": "Start code valid",
      "expression": "startCode == 1",
      "severity": "error",
      "message": "H.265 Annex B stream must start with 0x00 0x00 0x00 0x01 — not a valid raw HEVC stream"
    },
    {
      "name": "Forbidden zero bit is 0",
      "expression": "(naluHeaderByte1 & 128) == 0",
      "severity": "error",
      "message": "H.265 NALU header forbidden_zero_bit (bit 7) must be 0 — corrupt or non-HEVC data"
    },
    {
      "name": "Temporal ID plus1 is non-zero",
      "expression": "(naluHeaderByte2 & 7) >= 1",
      "severity": "warning",
      "message": "H.265 nuh_temporal_id_plus1 (bits 2-0 of header byte 2) must be >= 1"
    }
  ],
  "navigation": {
    "bookmarks": [
      {
        "name": "First NALU",
        "offset": 0,
        "icon": "\uE71B",
        "color": "#FF6B6B"
      }
    ]
  },

{
  "diffMode": "binary",
  "formatName": "Flash MP4 Video",
  "version": "1.14",
  "extensions": [
    ".f4v",
    ".f4p",
    ".f4a",
    ".f4b"
  ],
  "description": "F4V is an ISOBMFF (ISO Base Media File Format) based container developed by Adobe for Flash Player and Adobe Media Server. F4V superseded the older FLV format for H.264/AAC content in Flash Player 9.0.115+. F4V files begin with an 'ftyp' box: size (4B BE), 'ftyp' type (4B), major brand 'f4v ' (4B), minor version (4B BE), and compatible brands. The F4V major brand is 'f4v ' (0x66 0x34 0x76 0x20). F4V variants: .f4p = protected (Adobe Access DRM), .f4a = audio only, .f4b = audio book. F4V is structurally identical to MPEG-4 Part 14 (.mp4) with 'f4v '-specific compatible brand. The moov atom contains trak/mdia/minf/stbl boxes with H.264 video (avc1) and AAC audio (mp4a).",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ISO/IEC 14496-12 — ISO Base Media File Format",
      "ISO/IEC 14496-14 — MP4 File Format",
      "Adobe F4V File Format Specification v1.0"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/Flash_Video#F4V",
      "https://mpeg.chiariglione.org/standards/mpeg-4",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000341.shtml"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "66747970", "offset": 4, "label": "'ftyp' box type at offset 4 (ISOBMFF)", "weight": 0.6 },
      { "value": "66347620", "offset": 8, "label": "'f4v ' major brand — F4V Flash video", "weight": 1.0 },
      { "value": "66347670", "offset": 8, "label": "'f4vp' major brand — F4V protected", "weight": 1.0 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.6,
    "required": true,
    "Strength": "Medium",
    "EntropyHint": { "min": 4.5, "max": 7.5 },
    "validation": {
      "minFileSize": 16,
      "note": "'ftyp' at offset 4 shared with all ISOBMFF formats. 'f4v ' or 'f4vp' major brand at offset 8 identifies F4V specifically."
    }
  },
  "variables": {
    "ftypBoxSize": 0,
    "ftypBoxType": "",
    "majorBrand": "",
    "minorVersion": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "ftyp Box Size",
      "offset": 0,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Size in bytes of the 'ftyp' File Type box (big-endian uint32). Minimum 20 bytes (size + 'ftyp' + brand + version + 1 compat brand).",
      "storeAs": "ftypBoxSize",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "signature",
      "name": "ftyp Box Type",
      "offset": 4,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "ISOBMFF box type identifier 'ftyp' (0x66747970). Mandatory first box in all ISOBMFF-derived formats. F4V places 'ftyp' at offset 4 (after the 4-byte size), identical to MP4 and 3GP.",
      "storeAs": "ftypBoxType",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Major Brand",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "4-byte ASCII brand identifying the ISOBMFF profile. F4V brands: 'f4v ' = standard Adobe Flash Video, 'f4vp' = F4V with Adobe Access DRM protection. Compatible brands typically include 'mp42', 'isom'.",
      "storeAs": "majorBrand",
      "valueType": "ascii",
      "valueMap": {
        "f4v ": "F4V — Adobe Flash Video (H.264/AAC)",
        "f4vp": "F4VP — Adobe Flash Video Protected (Adobe Access DRM)",
        "f4a ": "F4A — Flash Audio only",
        "f4b ": "F4B — Flash Audio Book"
      }
    },
    {
      "type": "field",
      "name": "Minor Version",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.25,
      "description": "Informational minor version (big-endian uint32). Often 0.",
      "storeAs": "minorVersion",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "metadata",
      "name": "Major Brand",
      "variable": "majorBrand",
      "description": "'f4v '=Flash video, 'f4vp'=DRM protected"
    },
    {
      "type": "metadata",
      "name": "ftyp Box Size",
      "variable": "ftypBoxSize",
      "description": "File Type box size"
    }
  ],
  "assertions": [

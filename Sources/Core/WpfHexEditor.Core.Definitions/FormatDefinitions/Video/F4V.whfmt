  "aiHints": {
    "analysisContext": "F4V = ISOBMFF like MP4. ftyp: size(4B BE)+'ftyp'(4B)+brand(4B)+'f4v '(with space!)+version(4B BE)+compatBrands. Video: avc1 box (H.264/AVC). Audio: mp4a (AAC-LC). DRM: 'f4vp' brand + Adobe Access encryption in sinf box. Structure identical to MP4: moov > trak > mdia > minf > stbl contains sample tables. F4V uses 'moov' at end (streaming servers use 'moov' at start via fast-start). Adobe ended Flash support in 2020; F4V is legacy.",
    "suggestedInspections": [
      "Verify 'ftyp' at offset 4 and 'f4v ' at offset 8 (note trailing space in brand)",
      "Check compatible brands (offset 16+) for 'mp42', 'isom'",
      "moov box contains trak for video (avc1) and audio (mp4a)",
      "Look for 'f4vp' brand or Adobe Access 'sinf' box for DRM"
    ]
  },
  "software": [
    "Adobe Flash Player (legacy, EOL 2020)",
    "Adobe Media Server",
    "VLC media player",
    "FFmpeg (mp4 demuxer)"
  ],
  "formatRelationships": {
    "category": "Video",
    "extensions": [".f4v", ".f4p", ".f4a", ".f4b"],
    "relatedFormats": ["FLV", "MP4", "M4V"],
    "note": "F4V is an ISOBMFF/MP4 profile for Adobe Flash. Structurally identical to MP4 with 'f4v ' major brand. F4V superseded FLV for H.264 content in Flash Player. Adobe Flash EOL in 2020 makes F4V legacy — content typically migrated to MP4/HLS/DASH."
  },

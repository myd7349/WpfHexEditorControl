{
  "diffMode": "binary",
  "formatName": "Windows Media Video (WMV/ASF)",
  "version": "1.0",
  "extensions": [".wmv", ".asf"],
  "description": "Windows Media Video (WMV) is a family of video codecs developed by Microsoft, stored in the Advanced Systems Format (ASF) container. Like WMA audio, all WMV files begin with the 16-byte ASF Header Object GUID 3026B2758E66CF11A6D900AA0062CE6C. The header object size (uint64LE at offset 16) declares the total header region byte count. WMV variants include WMV7, WMV8, WMV9 (VC-1 profile), and WMV HD. The ASF container supports multiple stream types, enabling WMV files to carry video, audio, subtitles, and metadata simultaneously.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": {
    "specifications": [
      "Advanced Systems Format (ASF) Specification v01.20.03 — Microsoft Corporation",
      "SMPTE 421M: VC-1 Compressed Video Bitstream Format and Decoding Process"
    ],
    "WebLinks": [
      "https://docs.microsoft.com/en-us/windows/win32/wmformat/windows-media-format-sdk",
      "https://en.wikipedia.org/wiki/Windows_Media_Video"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "3026B2758E66CF11A6D900AA0062CE6C",
        "offset": 0,
        "label": "ASF Header Object GUID — identifies ASF/WMV/WMA container",
        "weight": 1.0
      }
    ],
    "matchMode": "First",
    "MinimumScore": 0.9,
    "required": ["ASF Header Object GUID — identifies ASF/WMV/WMA container"],
    "Strength": "Strong",
    "EntropyHint": {
      "min": 5.0,
      "max": 8.0,
      "comment": "WMV compressed video frames exhibit high entropy"
    },
    "validation": {
      "notes": "ASF GUID at offset 0 must match exactly; Stream Properties Object within header must declare video stream type"
    }
  },
  "variables": {
    "asfHeaderGuid": "",
    "headerObjectSize": 0,
    "headerObjectCount": 0,
    "reserved": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "asfHeaderGuid",
      "offset": 0,
      "length": 16,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "ASF Header Object GUID (16 bytes) — 3026B2758E66CF11A6D900AA0062CE6C; shared by all ASF containers including WMV video and WMA audio; video stream is distinguished by Stream Properties Object GUID inside the header",
      "storeAs": "asfHeaderGuid",
      "valueType": "bytes"
    },
    {
      "type": "field",
      "name": "headerObjectSize",
      "offset": 16,
      "length": 8,
      "color": "#4ECDC4",
      "opacity": 0.75,
      "description": "Total size of the ASF Header Object in bytes (little-endian uint64); includes all nested sub-objects; the Data Object containing video/audio packets immediately follows at this offset",
      "storeAs": "headerObjectSize",
      "valueType": "uint64LE"
    },
    {
      "type": "field",
      "name": "headerObjectCount",
      "offset": 24,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.75,
      "description": "Count of immediate child objects within the ASF Header Object (little-endian uint32); typical WMV files contain 4-8 sub-objects: Stream Properties, File Properties, Stream Bitrate Properties, Content Description",
      "storeAs": "headerObjectCount",
      "valueType": "uint32LE"
    },
    {
      "type": "field",
      "name": "reserved",
      "offset": 28,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.6,
      "description": "Reserved ASF header field (little-endian uint16) — must be 0x0201 per ASF specification v01.20.03; this 2-byte field terminates the fixed portion of the ASF Header Object preamble",
      "storeAs": "reserved",
      "valueType": "uint16LE"
    }
  ],
  "assertions": [
    {
      "field": "asfHeaderGuid",
      "op": "eq",
      "value": "3026B2758E66CF11A6D900AA0062CE6C",
      "message": "ASF Header GUID must match exactly for valid WMV/ASF file"
    },
    {
      "field": "headerObjectCount",
      "op": "gte",
      "value": 1,
      "message": "ASF header must contain at least one sub-object"
    },
    {
      "field": "headerObjectSize",
      "op": "gte",
      "value": 30,
      "message": "ASF header size must be at least 30 bytes"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "ASF Header GUID", "offset": 0, "length": 16, "color": "#FF6B6B" },
      { "name": "Header Object Size", "offset": 16, "length": 8, "color": "#4ECDC4" },
      { "name": "Sub-Object Count", "offset": 24, "length": 4, "color": "#95E1D3" },
      { "name": "Reserved (0x0201)", "offset": 28, "length": 2, "color": "#FFE66D" }
    ]
  },
  "inspector": {
    "badge": "WMV",
    "primaryField": "headerObjectCount",
    "showQualityScore": true,
    "groups": [
      {
        "name": "ASF Container Header",
        "fields": ["asfHeaderGuid", "headerObjectSize"]
      },
      {
        "name": "Object Structure",
        "fields": ["headerObjectCount", "reserved"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "WMV Header Summary",
      "format": "text",
      "template": "GUID: {asfHeaderGuid} | Size: {headerObjectSize} | Objects: {headerObjectCount}"
    },
    {
      "name": "WMV JSON Report",
      "format": "json",
      "template": "{ \"headerSize\": {headerObjectSize}, \"objectCount\": {headerObjectCount} }"
    }
  ],
  "forensic": {
    "category": "Video",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "ASF GUID mismatch indicates corrupted or spoofed container header",
      "DRM Encryption Object present in header indicates content protection",
      "Script Command Object in header may embed executable commands",
      "Embedded URLs in Content Description Object may indicate tracking pixels"
    ]
  },
  "aiHints": {
    "analysisContext": "WMV is an ASF container with video stream. The header sub-objects are navigated by iterating GUID+size pairs starting at offset 30. Stream Properties Object (GUID BC19EFC0...) identifies video streams. Extended Stream Properties Object may reference multiple bitrate profiles.",
    "suggestedInspections": [
      "Verify 16-byte ASF GUID at offset 0 matches WMV/ASF container identifier",
      "Iterate sub-objects from offset 30 using GUID+size structure to enumerate all metadata",
      "Locate Stream Properties Object to find video codec GUID (WMV1/WMV2/WMV3/WMVA)",
      "Check for Script Command Object — may embed embedded URLs or executable triggers",
      "Read File Properties Object for total play duration in 100ns units",
      "Detect DRM by presence of Content Encryption Object or Extended Content Encryption Object"
    ]
  },
  "software": [
    "Windows Media Player",
    "FFmpeg",
    "VLC Media Player",
    "HandBrake",
    "Windows Movie Maker",
    "MediaInfo"
  ],
  "formatRelationships": {
    "category": "Video",
    "extensions": [".wmv", ".asf"],
    "relatedFormats": ["WMA", "ASF", "AVI", "MP4", "MKV"],
    "note": "WMV and WMA are both ASF containers; file extension and Stream Properties Object GUID distinguish video from audio-only"
  },
  "MimeTypes": ["video/x-ms-wmv", "video/x-ms-asf", "video/asf"],
  "UseCases": [
    "Windows digital media video playback",
    "Streaming video via Windows Media Services",
    "DRM-protected video distribution (legacy)",
    "Screen recording and screencasts",
    "Corporate video communication and training"
  ],
  "QualityMetrics": {
    "CompletenessScore": 90,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 4,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "containerFormat": "Advanced Systems Format (ASF)",
    "headerGuid": "3026B2758E66CF11A6D900AA0062CE6C",
    "videoCodecs": ["WMV7 (WMV1)", "WMV8 (WMV2)", "WMV9 (WMV3/VC-1)", "WMV HD"],
    "drmSupport": true,
    "maxResolution": "1920x1080 (WMV HD)"
  }
}

{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "Smacker Video (RAD Game Tools)",
  "formatId": "SMK",
  "version": "1.1",
  "extensions": [ ".smk", ".smk2" ],
  "diffMode": "binary",
  "description": "Smacker Video is a proprietary video format by RAD Game Tools predecessor to Bink, widely used in DOS/early Windows games for compressed FMV cutscenes. Supports versions SMK2 and SMK4.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://wiki.multimedia.cx/index.php/Smacker_Video",
    "https://www.radgametools.com"
  ],
  "MimeTypes": [ "video/x-smacker", "video/x-smk" ],
  "UseCases": [
    "DOS and early Windows game FMV playback",
    "Game asset extraction and analysis",
    "Retro game modding and video replacement",
    "Legacy video format reverse engineering"
  ],
  "software": [
    { "name": "RAD Video Tools", "role": "Official encoder/decoder",        "platform": "Windows", "url": "https://www.radgametools.com" },
    { "name": "FFmpeg",          "role": "Open-source decoder",             "platform": "Multi",   "url": "https://ffmpeg.org" },
    { "name": "VLC",             "role": "Playback via libavcodec",          "platform": "Multi" },
    { "name": "ScummVM",         "role": "Game engine with SMK support",    "platform": "Multi",   "url": "https://www.scummvm.org" }
  ],
  "detection": {
    "signatures": [
      { "value": "534D4B32", "offset": 0, "label": "'SMK2' Smacker version 2", "weight": 1.0 },
      { "value": "534D4B34", "offset": 0, "label": "'SMK4' Smacker version 4", "weight": 1.0 }
    ],
    "matchMode": "any",
    "MinimumScore": 88,
    "Strength": "Strong",
    "EntropyHint": { "min": 5.0, "max": 7.8 }
  },
  "variables": [
    { "name": "smkMagic",            "offset": 0,  "size": 4, "type": "ascii",  "storeAs": "smkMagic",
      "description": "Magic: 'SMK2' or 'SMK4'",
      "valueMap": { "SMK2": "Smacker version 2", "SMK4": "Smacker version 4" } },
    { "name": "smkWidth",            "offset": 4,  "size": 4, "type": "uint32", "endian": "LE", "storeAs": "smkWidth",            "description": "Video width in pixels" },
    { "name": "smkHeight",           "offset": 8,  "size": 4, "type": "uint32", "endian": "LE", "storeAs": "smkHeight",           "description": "Video height in pixels" },
    { "name": "smkFrameCount",       "offset": 12, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "smkFrameCount",       "description": "Total number of frames" },
    { "name": "smkMsPerFrame",       "offset": 16, "size": 4, "type": "int32",  "endian": "LE", "storeAs": "smkMsPerFrame",       "description": "Milliseconds per frame (positive=ms, negative=fps inverse)" },
    { "name": "smkLargestFrame",     "offset": 20, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "smkLargestFrame",     "description": "Size of largest frame in bytes" },
    { "name": "smkFlags",            "offset": 24, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "smkFlags",            "description": "Flags: bit0=ring frame, bit1=Y-doubled, bit2=Y-interlaced" },
    { "name": "smkAudioSize0",       "offset": 28, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "smkAudioSize0",       "description": "Uncompressed size of audio track 0" },
    { "name": "smkAudioSize1",       "offset": 32, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "smkAudioSize1",       "description": "Uncompressed size of audio track 1" },
    { "name": "smkAudioSize2",       "offset": 36, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "smkAudioSize2",       "description": "Uncompressed size of audio track 2" },
    { "name": "smkTreeSize",         "offset": 64, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "smkTreeSize",         "description": "Total size of Huffman tree data" },
    { "name": "smkAudioTrackFlags",  "offset": 72, "size": 4, "type": "uint32", "endian": "LE", "storeAs": "smkAudioTrackFlags",  "description": "Audio track compression and channel flags" }
  ],
  "blocks": [
    {
      "name": "FileHeader",
      "offset": 0,
      "size": 104,
      "description": "104-byte Smacker fixed header with magic, dimensions, frame count and timing",
      "color": "#1E90FF",
      "fields": [ "smkMagic", "smkWidth", "smkHeight", "smkFrameCount", "smkMsPerFrame",
                  "smkLargestFrame", "smkFlags", "smkAudioSize0", "smkAudioSize1", "smkAudioSize2",
                  "smkTreeSize", "smkAudioTrackFlags" ]
    },
    {
      "name": "FrameSizeTable",
      "offset": 104,
      "sizeExpression": "smkFrameCount * 4",
      "description": "Per-frame size entries (4 bytes each, bit0 = keyframe flag)",
      "color": "#32CD32"
    },
    {
      "name": "FrameTypeTable",
      "offset": "after frame size table",
      "sizeExpression": "smkFrameCount",
      "description": "Per-frame type bytes indicating which audio tracks are present",
      "color": "#FFA500"
    },
    {
      "name": "HuffmanTrees",
      "offset": "after frame type table",
      "sizeExpression": "smkTreeSize",
      "description": "Packed Huffman trees used for video decompression",
      "color": "#FF6347"
    },
    {
      "name": "FrameData",
      "offset": "after Huffman trees",
      "description": "Compressed video and audio frame data",
      "color": "#9370DB"
    }
  ],
  "assertions": [
    { "id": "A1", "expression": "smkMagic == 'SMK2' or smkMagic == 'SMK4'", "severity": "error",   "message": "Magic must be 'SMK2' or 'SMK4'" },
    { "id": "A2", "expression": "smkWidth > 0",                              "severity": "error",   "message": "Video width must be positive" },
    { "id": "A3", "expression": "smkFrameCount > 0",                         "severity": "error",   "message": "Frame count must be positive" },
    { "id": "A4", "expression": "smkHeight > 0",                             "severity": "error",   "message": "Video height must be positive" },
    { "id": "A5", "expression": "smkLargestFrame < file size",               "severity": "warning", "message": "Largest frame exceeds file size — corrupt header" }
  ],
  "navigation": {
    "rootLabel": "Smacker Video",
    "entries": [
      { "label": "File Header",      "blockRef": "FileHeader" },
      { "label": "Frame Size Table", "blockRef": "FrameSizeTable" },
      { "label": "Frame Type Table", "blockRef": "FrameTypeTable" },
      { "label": "Huffman Trees",    "blockRef": "HuffmanTrees" },
      { "label": "Frame Data",       "blockRef": "FrameData" }
    ]
  },
  "inspector": {
    "badge": "SMK",
    "primaryField": "smkMagic",
    "groups": [
      { "name": "Identity",  "fields": [ "smkMagic" ] },
      { "name": "Video",     "fields": [ "smkWidth", "smkHeight", "smkFrameCount", "smkMsPerFrame", "smkFlags" ] },
      { "name": "Structure", "fields": [ "smkLargestFrame", "smkTreeSize" ] },
      { "name": "Audio",     "fields": [ "smkAudioSize0", "smkAudioSize1", "smkAudioSize2", "smkAudioTrackFlags" ] }
    ]
  },
  "exportTemplates": [
    {
      "name": "Video Summary",
      "format": "text",
      "template": "Format: {smkMagic}\nResolution: {smkWidth}x{smkHeight}\nFrames: {smkFrameCount}\nMs/Frame: {smkMsPerFrame}\nLargest Frame: {smkLargestFrame} bytes\nHuffman Tree Size: {smkTreeSize} bytes"
    },
    {
      "name": "CSV Metadata",
      "format": "csv",
      "template": "Field,Value\nMagic,{smkMagic}\nWidth,{smkWidth}\nHeight,{smkHeight}\nFrameCount,{smkFrameCount}\nMsPerFrame,{smkMsPerFrame}\nLargestFrame,{smkLargestFrame}\nTreeSize,{smkTreeSize}"
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "suspiciousPatterns": [
      "Unknown magic other than SMK2/SMK4 — wrong format or corrupt",
      "smkFrameCount == 0 — empty or invalid file",
      "smkLargestFrame > file size — corrupt header",
      "smkTreeSize == 0 — no Huffman trees, likely corrupt"
    ],
    "hidingTechniques": [
      "Extra data appended after last frame block",
      "Padding in audio track size fields",
      "Non-standard frame size table entries pointing to extra data"
    ],
    "timestampFields": [],
    "notes": "Smacker was the dominant game video format for DOS/Windows games from 1994-2000. The ring-frame flag enables seamless video looping."
  },
  "aiHints": {
    "analysisContext": "Smacker Video is structured as a fixed 104-byte header, per-frame size and type tables, Huffman trees then frame data. Frame timing is given in milliseconds per frame (positive) or as a rate (negative value). The Huffman trees are essential for video decompression.",
    "suggestedInspections": [
      "Verify magic is 'SMK2' or 'SMK4' at offset 0",
      "Validate smkFrameCount > 0 and smkWidth/smkHeight are reasonable video dimensions",
      "Inspect smkMsPerFrame: if negative, frame rate = abs(smkMsPerFrame) fps; if positive, ms per frame",
      "Check smkFlags for ring-frame (loop) and Y-doubling display mode bits",
      "Sum all frame sizes from the frame size table and verify total matches remaining file size"
    ]
  },
  "formatRelationships": [
    { "format": "BIK", "relationship": "descendant", "description": "Bink Video is the successor format from the same RAD Game Tools" },
    { "format": "AVI", "relationship": "sibling",    "description": "AVI was a contemporaneous PC video container standard" }
  ],
  "TechnicalDetails": {
    "endianness": "Little-Endian",
    "minimumFileSize": 104,
    "headerSize": 104,
    "maxAudioTracks": 7,
    "compressionType": "Proprietary Smacker Huffman codec",
    "audioCodecs": [ "Smacker Audio (DPCM)", "Smacker Audio (16-bit PCM)" ],
    "versions": [ "SMK2", "SMK4" ]
  },
  "QualityMetrics": {
    "CompletenessScore": 91,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team",
    "KnownLimitations": "SMK4 extended the format with additional audio track flags; exact per-version differences require further research."
  }
}




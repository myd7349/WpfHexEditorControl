{
  "diffMode": "binary",
  "formatName": "Raw H.264/AVC",
  "version": "1.15",
  "extensions": [
    ".h264",
    ".264",
    ".avc"
  ],
  "description": "Raw H.264/MPEG-4 AVC (Advanced Video Coding) elementary bitstream as defined in ITU-T H.264 and ISO/IEC 14496-10. Raw AVC bitstreams use Annex B byte-stream format: each Network Abstraction Layer Unit (NALU) is preceded by a start code prefix (0x00 0x00 0x00 0x01 for long start code, or 0x00 0x00 0x01 for short). The NALU header byte follows: bits 7 (forbidden_zero_bit, must be 0), bits 6-5 (nal_ref_idc: 0=non-reference, 1-3=reference), bits 4-0 (nal_unit_type: 1=P-slice, 5=IDR/keyframe, 7=SPS, 8=PPS, 9=AU delimiter). The Sequence Parameter Set (SPS, type 7) contains profile_idc, level_idc, and resolution. Raw H.264 files have no container overhead — they are pure elementary streams suitable for hardware decoders.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ITU-T H.264 — Advanced Video Coding (Rec. H.264)",
      "ISO/IEC 14496-10 — MPEG-4 Part 10 AVC",
      "ISO/IEC 14496-15 — AVC File Format"
    ],
    "WebLinks": [
      "https://www.itu.int/rec/T-REC-H.264",
      "https://en.wikipedia.org/wiki/Advanced_Video_Coding",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000081.shtml",
      "https://membrane.stream/learn/h264/2"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "00000001", "offset": 0, "label": "H.264 Annex B long start code (4-byte)", "weight": 0.7 },
      { "value": "000001", "offset": 0, "label": "H.264 Annex B short start code (3-byte)", "weight": 0.5 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.5,
    "required": true,
    "Strength": "Medium",
    "EntropyHint": { "min": 5.5, "max": 7.8 },
    "validation": {
      "minFileSize": 5,
      "note": "H.264 Annex B start code 0x000001 or 0x00000001 is shared with H.265/HEVC and other MPEG elementary streams. The NALU type byte after the start code distinguishes H.264 from H.265 (H.265 uses 2-byte NALU header)."
    }
  },
  "variables": {
    "startCode": 0,
    "naluHeaderByte": 0,
    "naluType": 0,
    "nalRefIdc": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Annex B Start Code",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "H.264 Annex B long start code prefix 0x00 0x00 0x00 0x01 (big-endian uint32 = 1). This 4-byte sequence precedes the first NALU in an Annex B byte-stream. Subsequent NALUs may use either the 4-byte (0x00 0x00 0x00 0x01) or 3-byte (0x00 0x00 0x01) start code. Start code emulation prevention bytes (0x03) prevent false start code matches within NALU data. The long start code is required for the first NALU and for random access points.",
      "storeAs": "startCode",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "NALU Header",
      "offset": 4,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "H.264 Network Abstraction Layer Unit (NALU) header byte. Bit 7 = forbidden_zero_bit (must be 0). Bits 6-5 = nal_ref_idc (0=non-reference, 1-3=priority increasing). Bits 4-0 = nal_unit_type (1=Coded slice non-IDR, 5=IDR keyframe, 6=SEI, 7=SPS, 8=PPS, 9=Access Unit delimiter).",
      "storeAs": "naluHeaderByte",
      "valueType": "uint8",
      "bitfields": [
        { "name": "Forbidden Zero Bit", "bits": "7", "description": "Must be 0 (H.264 spec violation if 1)" },
        { "name": "NAL Reference IDC", "bits": "6-5", "description": "0=non-reference, 1-3=reference priority", "valueMap": { "0": "Non-reference NALU", "1": "Low priority reference", "2": "Medium priority reference", "3": "High priority reference" } },
        { "name": "NALU Type", "bits": "4-0", "description": "Network Abstraction Layer Unit type", "valueMap": { "1": "Non-IDR coded slice (P/B frame)", "2": "Coded slice data partition A", "5": "IDR coded slice (I-frame/keyframe)", "6": "SEI (Supplemental Enhancement Info)", "7": "SPS (Sequence Parameter Set)", "8": "PPS (Picture Parameter Set)", "9": "Access Unit Delimiter", "10": "End of Sequence", "11": "End of Stream" } }
      ]
    },
    {
      "type": "metadata",
      "name": "Start Code",
      "variable": "startCode",
      "description": "Annex B start code (0x00000001 = 1)"
    },
    {
      "type": "metadata",
      "name": "NALU Type",
      "variable": "naluHeaderByte",
      "description": "First NALU type (7=SPS, 8=PPS, 5=IDR)"
    }
  ],
  "assertions": [
    {
      "name": "Start code valid",
      "expression": "startCode == 1",
      "severity": "error",
      "message": "H.264 Annex B stream must start with 0x00 0x00 0x00 0x01 — not a valid raw AVC stream"
    },
    {
      "name": "Forbidden zero bit is 0",
      "expression": "(naluHeaderByte & 128) == 0",
      "severity": "error",
      "message": "NALU header forbidden_zero_bit (bit 7) must be 0 — corrupt or non-H.264 data"
    }
  ],
  "navigation": {

{
  "diffMode": "binary",
  "formatName": "RealMedia (RM/RMVB)",
  "version": "1.0",
  "extensions": [".rm", ".rmvb", ".ra"],
  "description": "RealMedia is a proprietary multimedia container format developed by RealNetworks for streaming and downloading audio/video content. Files begin with the 4-byte ASCII magic '.RMF' (0x2E524D46) followed by a uint32BE header size field and a uint32BE version field (0 or 1). The numHeaders uint32BE field at offset 12 declares the number of top-level chunk objects. RMVB (RealMedia Variable Bitrate) is an extension supporting variable bitrate encoding for improved quality at lower average bitrates. RealMedia was dominant in early internet streaming during the late 1990s and 2000s.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": {
    "specifications": [
      "RealMedia File Format Specification — RealNetworks Inc.",
      "RealAudio and RealVideo Codec Documentation"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/RealMedia",
      "https://wiki.multimedia.cx/index.php/RealMedia"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "2E524D46",
        "offset": 0,
        "label": ".RMF — RealMedia file magic",
        "weight": 1.0
      }
    ],
    "matchMode": "First",
    "MinimumScore": 0.8,
    "required": [".RMF — RealMedia file magic"],
    "Strength": "Strong",
    "EntropyHint": {
      "min": 4.5,
      "max": 8.0,
      "comment": "RealVideo/RealAudio compressed content exhibits moderate to high entropy"
    },
    "validation": {
      "notes": "Magic must be '.RMF'; version must be 0 or 1; headerSize must be consistent with file structure"
    }
  },
  "variables": {
    "rmMagic": "",
    "headerSize": 0,
    "rmVersion": 0,
    "numHeaders": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "rmMagic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "RealMedia file signature — ASCII '.RMF' (0x2E524D46); identifies the file as a RealMedia container; .ra (RealAudio) files use the same magic and container structure as .rm files",
      "storeAs": "rmMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "headerSize",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.75,
      "description": "Size of the RealMedia file header chunk in bytes (big-endian uint32); includes the 4-byte magic, 4-byte size, and all subsequent fixed header fields; used to locate the first content chunk",
      "storeAs": "headerSize",
      "valueType": "uint32BE"
    },
    {
      "type": "field",
      "name": "rmVersion",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.75,
      "description": "RealMedia container version (big-endian uint32) — value 0 indicates version 1 format; value 1 indicates version 2 format with extended features including RMVB variable bitrate support",
      "storeAs": "rmVersion",
      "valueType": "uint32BE"
    },
    {
      "type": "field",
      "name": "numHeaders",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.75,
      "description": "Number of top-level header objects in this RealMedia file (big-endian uint32); each header chunk begins with a 4-byte type tag (PROP, MDPR, CONT, DATA, INDX) followed by size and payload",
      "storeAs": "numHeaders",
      "valueType": "uint32BE"
    }
  ],
  "assertions": [
    {
      "field": "rmMagic",
      "op": "eq",
      "value": ".RMF",
      "message": "RealMedia magic must be '.RMF'"
    },
    {
      "field": "rmVersion",
      "op": "in",
      "value": [0, 1],
      "message": "RealMedia version must be 0 or 1"
    },
    {
      "field": "numHeaders",
      "op": "gte",
      "value": 1,
      "message": "RealMedia file must contain at least one header chunk"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "RM Magic (.RMF)", "offset": 0, "length": 4, "color": "#FF6B6B" },
      { "name": "Header Size", "offset": 4, "length": 4, "color": "#4ECDC4" },
      { "name": "Version", "offset": 8, "length": 4, "color": "#95E1D3" },
      { "name": "Header Count", "offset": 12, "length": 4, "color": "#FFE66D" }
    ]
  },
  "inspector": {
    "badge": "RM",
    "primaryField": "rmVersion",
    "showQualityScore": true,
    "groups": [
      {
        "name": "File Header",
        "fields": ["rmMagic", "headerSize", "rmVersion"]
      },
      {
        "name": "Chunk Structure",
        "fields": ["numHeaders"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "RM Header Summary",
      "format": "text",
      "template": "Magic: {rmMagic} | Size: {headerSize} | Version: {rmVersion} | Chunks: {numHeaders}"
    },
    {
      "name": "RM JSON Report",
      "format": "json",
      "template": "{ \"magic\": \"{rmMagic}\", \"version\": {rmVersion}, \"numHeaders\": {numHeaders} }"
    }
  ],
  "forensic": {
    "category": "Video",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Unknown version value (not 0 or 1) indicates malformed or non-standard RealMedia file",
      "Malformed MDPR chunks may indicate tampered or corrupt stream descriptions",
      "Embedded URLs in RealMedia header may reference tracking servers"
    ]
  },
  "aiHints": {
    "analysisContext": "RealMedia uses tagged chunk structure. After the .RMF header, chunks follow: PROP (properties), MDPR (media description per stream), CONT (content info/metadata), DATA (audio/video data packets), INDX (seek index). RMVB files have additional BIT_RATE variable bitrate hints.",
    "suggestedInspections": [
      "Verify '.RMF' magic at offset 0 and version value at offset 8",
      "Parse PROP chunk to find file duration, bitrate, and stream configuration",
      "Enumerate MDPR chunks to list all audio and video stream descriptions",
      "Read CONT chunk for title, author, copyright, and comment metadata",
      "Locate DATA chunk to find the start of the media data region",
      "Check INDX chunk for seek table to assess random access capability"
    ]
  },
  "software": [
    "RealPlayer",
    "FFmpeg",
    "VLC Media Player",
    "MPlayer",
    "MediaInfo",
    "Helix Server (streaming)"
  ],
  "formatRelationships": {
    "category": "Video",
    "extensions": [".rm", ".rmvb", ".ra"],
    "relatedFormats": ["ASF", "MOV", "RealAudio (RA)", "RTSP streams"],
    "note": "RMVB extends RM with variable bitrate support; .ra (RealAudio) uses same container with audio-only streams; both are largely legacy formats replaced by MP4/MKV"
  },
  "MimeTypes": ["video/vnd.rn-realvideo", "application/vnd.rn-realmedia", "audio/vnd.rn-realaudio"],
  "UseCases": [
    "Legacy internet video streaming (RealPlayer era)",
    "Early video-on-demand services",
    "News and broadcast clips distribution (1990s-2000s)",
    "Educational video streaming platforms",
    "Archived streaming media content"
  ],
  "QualityMetrics": {
    "CompletenessScore": 90,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 4,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "chunkTypes": ["RMF", "PROP", "MDPR", "CONT", "DATA", "INDX"],
    "versionValues": { "0": "Version 1", "1": "Version 2 / RMVB" },
    "streamingProtocol": "RTSP/PNM",
    "legacyFormat": true
  }
}

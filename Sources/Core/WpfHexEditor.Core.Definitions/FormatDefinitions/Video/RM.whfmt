    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "VideoFormat": true,
    "ContainerFormat": "RealMedia File Format (RMFF)",
    "Endianness": "big-endian (all multi-byte fields)",
    "VideoCodecs": "RV10, RV20, RV30, RV40 (RealVideo)",
    "AudioCodecs": "Cook, ATRAC3, Sipro, ACELP",
    "Streaming": "Designed for real-time streaming over RTSP"
  }
}

{
  "diffMode": "binary",
  "formatName": "Flash Video (FLV/F4V)",
  "version": "1.0",
  "extensions": [".flv", ".f4v", ".f4a"],
  "description": "Flash Video (FLV) is a container format used to deliver video content via Adobe Flash Player. FLV files begin with the 4-byte magic sequence 'FLV' (ASCII 46 4C 56) followed by a version byte (0x01 for version 1). The flags byte at offset 4 uses bit 0 to indicate audio presence and bit 2 to indicate video presence. The data offset field at offset 5 (uint32BE) declares the byte offset to the first tag, typically 9. FLV tags consist of header, payload, and a previous tag size footer. F4V is an evolution using the ISO BMFF container with 'f4v ' brand. FLV was the dominant web video format prior to HTML5.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": {
    "specifications": [
      "Adobe Flash Video File Format Specification Version 10.1",
      "F4V File Format for Flash Platform"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/Flash_Video",
      "https://www.adobe.com/devnet/f4v.html"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "464C5601",
        "offset": 0,
        "label": "FLV magic 'FLV' + version 1 at offset 0",
        "weight": 1.0
      }
    ],
    "matchMode": "First",
    "MinimumScore": 0.9,
    "required": ["FLV magic 'FLV' + version 1 at offset 0"],
    "Strength": "Strong",
    "EntropyHint": {
      "min": 5.0,
      "max": 8.0,
      "comment": "FLV video payload (H.264/VP6/Sorenson Spark) exhibits high entropy"
    },
    "validation": {
      "notes": "Bytes 0-2 must be 'FLV', byte 3 must be 0x01 (version), dataOffset at offset 5 must be 9"
    }
  },
  "variables": {
    "flvMagic": "",
    "flvVersion": 0,
    "flvFlags": 0,
    "dataOffset": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "flvMagic",
      "offset": 0,
      "length": 3,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "FLV file signature — ASCII 'FLV' (0x464C56); identifies the file as a Flash Video container; combined with version byte at offset 3 forms the complete 4-byte FLV header identifier",
      "storeAs": "flvMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "flvVersion",
      "offset": 3,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.75,
      "description": "FLV format version (uint8) — always 0x01 for all known FLV files; other values are reserved and not used by Adobe Flash Player or common encoders",
      "storeAs": "flvVersion",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "flvFlags",
      "offset": 4,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.75,
      "description": "FLV stream flags (uint8) — bit 0 set indicates audio stream present; bit 2 set indicates video stream present; both may be set for a combined audio/video FLV file; other bits are reserved",
      "storeAs": "flvFlags",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "dataOffset",
      "offset": 5,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.75,
      "description": "Byte offset to first FLV tag (big-endian uint32) — always 9 for standard FLV files; any value other than 9 indicates a non-standard or extended FLV header with additional data before the first tag",
      "storeAs": "dataOffset",
      "valueType": "uint32BE"
    }
  ],
  "assertions": [
    {
      "field": "flvMagic",
      "op": "eq",
      "value": "FLV",
      "message": "FLV magic must be 'FLV' at offset 0"
    },
    {
      "field": "flvVersion",
      "op": "eq",
      "value": 1,
      "message": "FLV version must be 1"
    },
    {
      "field": "dataOffset",
      "op": "eq",
      "value": 9,
      "message": "FLV data offset must be 9 for standard files"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "FLV Magic", "offset": 0, "length": 3, "color": "#FF6B6B" },
      { "name": "Version", "offset": 3, "length": 1, "color": "#4ECDC4" },
      { "name": "Stream Flags", "offset": 4, "length": 1, "color": "#95E1D3" },
      { "name": "Data Offset", "offset": 5, "length": 4, "color": "#FFE66D" },
      { "name": "First Tag (offset 9)", "offset": 9, "length": 11, "color": "#A8E6CF" }
    ]
  },
  "inspector": {
    "badge": "FLV",
    "primaryField": "flvFlags",
    "showQualityScore": true,
    "groups": [
      {
        "name": "File Header",
        "fields": ["flvMagic", "flvVersion"]
      },
      {
        "name": "Stream Configuration",
        "fields": ["flvFlags", "dataOffset"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "FLV Header Summary",
      "format": "text",
      "template": "Magic: {flvMagic} | Version: {flvVersion} | Flags: {flvFlags} | DataOffset: {dataOffset}"
    },
    {
      "name": "FLV JSON Report",
      "format": "json",
      "template": "{ \"magic\": \"{flvMagic}\", \"version\": {flvVersion}, \"flags\": {flvFlags} }"
    }
  ],
  "forensic": {
    "category": "Video",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "dataOffset != 9 indicates non-standard FLV with embedded header data",
      "Script tags before video data may contain injected metadata or tracking info",
      "Flash Video files may carry ActionScript payload in onMetaData script tags"
    ]
  },
  "aiHints": {
    "analysisContext": "FLV consists of a 9-byte file header followed by a sequence of tags. Each tag has an 11-byte header: 1-byte type (8=audio, 9=video, 18=script), 3-byte data size, 3-byte timestamp, 1-byte timestamp extension, 3-byte stream ID. The first tag at offset 9 is typically a Script Data tag containing onMetaData.",
    "suggestedInspections": [
      "Verify 'FLV' magic and version 1 at offset 0-3",
      "Read flags byte at offset 4: bit 0=audio, bit 2=video, to identify stream types",
      "Parse first tag at offset 9: type 18 (0x12) is Script/metadata tag",
      "Decode onMetaData AMF object for duration, width, height, video/audio codec info",
      "Identify video codec from video tag header: CodecID 4=VP6, 7=H.264 (AVC)",
      "Check audio codec from audio tag header: SoundFormat 10=AAC, 2=MP3"
    ]
  },
  "software": [
    "FFmpeg",
    "VLC Media Player",
    "Adobe Flash Media Server",
    "YouTube (legacy upload format)",
    "HandBrake",
    "FLV Extract"
  ],
  "formatRelationships": {
    "category": "Video",
    "extensions": [".flv", ".f4v", ".f4a"],
    "relatedFormats": ["F4V", "MP4", "RTMP streams", "SWF"],
    "note": "F4V superseded FLV for H.264 content by using ISO BMFF container with 'f4v ' brand; FLV is largely legacy but widespread in archived web video"
  },
  "MimeTypes": ["video/x-flv", "video/x-f4v"],
  "UseCases": [
    "Legacy web video streaming via Flash Player",
    "Video platform archives (YouTube early era)",
    "RTMP streaming server input/output",
    "Screen recording with audio capture",
    "Video podcast and e-learning platforms (pre-HTML5)"
  ],
  "QualityMetrics": {
    "CompletenessScore": 90,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 4,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "headerSizeBytes": 9,
    "tagTypes": { "8": "Audio", "9": "Video", "18": "Script/Metadata" },
    "videoCodecs": { "2": "Sorenson Spark (H.263)", "4": "VP6", "5": "VP6 with alpha", "7": "H.264 (AVC)" },
    "audioCodecs": { "2": "MP3", "10": "AAC" },
    "legacyFormat": true
  }
}

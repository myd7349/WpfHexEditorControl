{
  "diffMode": "binary",
  "formatName": "MP4 Video",
  "version": "2.02",
  "extensions": [
    ".mp4",
    ".m4v",
    ".m4a"
  ],
  "description": "MPEG-4 Part 14 multimedia container based on ISO Base Media File Format (ISOBMFF). The file begins with a File Type Box (ftyp) that declares the major brand, minor version, and compatible brands. All data is organized in nested boxes (atoms), each prefixed by a 32-bit size and 4-byte type code. The ftyp box is followed by movie metadata (moov) and media data (mdat) boxes.",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ISO/IEC 14496-12 - ISO Base Media File Format",
      "ISO/IEC 14496-14 - MP4 File Format",
      "ISO/IEC 14496-15 - Carriage of NAL unit structured video in ISOBMFF"
    ],
    "WebLinks": [
      "https://mpeg.chiariglione.org/standards/mpeg-4",
      "https://en.wikipedia.org/wiki/MPEG-4_Part_14",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000155.shtml"
    ]
  },
  "detection": {
    "signature": "66747970",
    "offset": 4,
    "required": true,
    "validation": {
      "minFileSize": 20,
      "maxSignatureOffset": 4,
      "expectedValue": "0x66747970"
    }
  },
  "variables": {
    "currentOffset": 0,
    "ftypBoxSize": 0,
    "ftypBoxType": "",
    "majorBrand": "",
    "majorBrandName": "",
    "minorVersion": 0,
    "compatBrand1": "",
    "compatBrand2": "",
    "compatBrand3": "",
    "compatBrand4": "",
    "nextBoxSize": 0,
    "nextBoxType": "",
    "nextBoxTypeName": "",
    "totalFileSize": 0,
    "formattedFileSize": "",
    "payloadSize": 0,
    "isFragmented": false,
    "hasExtendedSize": false
  },
  "functions": {
    "formatFileSize(var:totalFileSize)": "Format total file size as human-readable string (KB/MB/GB)",
    "computeFromVariables(ftypBoxSize - 8, payloadSize)": "Calculate ftyp payload size by subtracting box header overhead"
  },
  "blocks": [
    {
      "type": "field",
      "name": "ftyp Box Size",
      "offset": 0,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Size of the File Type Box (ftyp) in bytes, stored as a big-endian unsigned 32-bit integer. This includes the 8-byte box header (size + type) plus the payload. A value of 0 means the box extends to end-of-file; a value of 1 means a 64-bit extended size follows the type field.",
      "storeAs": "ftypBoxSize",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "signature",
      "name": "ftyp Box Type",
      "offset": 4,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Four-byte ASCII box type code 'ftyp' (0x66747970). The File Type Box must be the first significant box in an ISO Base Media File Format file. It identifies the file's best-use specification and compatible specifications.",
      "storeAs": "ftypBoxType",
      "valueType": "ascii",
      "validation": {
        "expectedValue": "ftyp"
      }
    },
    {
      "type": "field",
      "name": "Major Brand",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Four-character code (FourCC) identifying the best-use specification for this file. Determines which features and codecs the file is optimized for. Common MP4 brands include 'isom' (generic ISO), 'mp41'/'mp42' (MPEG-4 v1/v2), and 'dash' (MPEG-DASH).",
      "storeAs": "majorBrand",
      "valueType": "ascii",
      "valueMap": {
        "isom": "ISO Base Media File Format",
        "iso2": "ISO Base Media File v2",
        "mp41": "MPEG-4 Part 14 v1 (MP4 v1)",
        "mp42": "MPEG-4 Part 14 v2 (MP4 v2)",
        "M4V ": "Apple iTunes Video",
        "M4A ": "Apple iTunes Audio (AAC)",
        "M4P ": "Apple iTunes Protected AAC",
        "M4B ": "Apple iTunes Audiobook",
        "avc1": "AVC/H.264 Video",
        "dash": "MPEG-DASH Streaming",
        "msdh": "MPEG-DASH (Microsoft)",
        "msix": "MPEG-DASH Index Segment",
        "f4v ": "Adobe Flash Video",
        "3gp4": "3GPP Release 4",
        "3gp5": "3GPP Release 5",
        "3gp6": "3GPP Release 6"
      },
      "mappedValueStoreAs": "majorBrandName"
    },
    {
      "type": "field",
      "name": "Minor Version",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Minor version of the major brand specification, stored as a big-endian unsigned 32-bit integer. This is informational and provides additional versioning detail for the major brand. A value of 0 typically indicates the base version.",
      "storeAs": "minorVersion",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Compatible Brand 1",
      "offset": 16,
      "length": 4,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "First compatible brand FourCC. Lists additional specifications with which this file complies. Players use the compatible brands list to determine if they can decode the file even if the major brand is unfamiliar.",
      "storeAs": "compatBrand1",
      "valueType": "ascii",
      "valueMap": {
        "isom": "ISO Base Media",
        "iso2": "ISO Base Media v2",
        "mp41": "MP4 v1",
        "mp42": "MP4 v2",
        "avc1": "AVC/H.264",
        "dash": "MPEG-DASH",
        "M4V ": "iTunes Video",
        "M4A ": "iTunes Audio"
      }
    },
    {
      "type": "field",
      "name": "Compatible Brand 2",
      "offset": 20,
      "length": 4,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Second compatible brand FourCC. Additional specification with which this file complies. The list of compatible brands typically includes the major brand itself plus broader format families.",
      "storeAs": "compatBrand2",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Compatible Brand 3",
      "offset": 24,
      "length": 4,
      "color": "#FF6B9D",
      "opacity": 0.3,
      "description": "Third compatible brand FourCC, if present within the ftyp box payload. The number of compatible brands depends on the ftyp box size: count = (boxSize - 16) / 4.",
      "storeAs": "compatBrand3",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Compatible Brand 4",
      "offset": 28,
      "length": 4,
      "color": "#C44569",
      "opacity": 0.3,
      "description": "Fourth compatible brand FourCC, if present. Many MP4 files include 3-5 compatible brands covering ISO base media, specific MPEG-4 profiles, and codec families.",
      "storeAs": "compatBrand4",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Next Box Size",
      "offset": 32,
      "length": 4,
      "color": "#A8E6CF",
      "opacity": 0.3,
      "description": "Size of the second box in the file (at offset = ftyp box size, shown here assuming ftyp is 32 bytes). Typically this is the moov (movie metadata), mdat (media data), or free (free space) box. Note: actual offset depends on ftyp box size.",
      "storeAs": "nextBoxSize",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Next Box Type",
      "offset": 36,
      "length": 4,
      "color": "#98D8C8",
      "opacity": 0.3,
      "description": "Four-byte ASCII type of the second box. Common second boxes: 'moov' (movie metadata with track info), 'mdat' (actual media data), 'free'/'skip' (padding), 'moof' (movie fragment for fragmented MP4).",
      "storeAs": "nextBoxType",
      "valueType": "ascii",
      "valueMap": {
        "moov": "Movie Metadata Box",
        "mdat": "Media Data Box",
        "free": "Free Space Box",
        "skip": "Skip Box (Free Space)",
        "moof": "Movie Fragment Box",
        "sidx": "Segment Index Box",
        "styp": "Segment Type Box",
        "pdin": "Progressive Download Info"
      },
      "mappedValueStoreAs": "nextBoxTypeName"
    },
    {
      "type": "computeFromVariables",
      "name": "ftyp Payload Size",
      "expression": "ftypBoxSize - 8",
      "storeAs": "payloadSize",
      "description": "Calculates the ftyp box payload size by subtracting the 8-byte header (4 bytes size + 4 bytes type). The payload contains major brand (4), minor version (4), and compatible brands (variable)."
    },
    {
      "type": "computeFromVariables",
      "name": "Fragmented MP4 Detection",
      "expression": "nextBoxType == 'moof' || nextBoxType == 'styp' ? 1 : 0",
      "storeAs": "isFragmented",
      "description": "Determines if the MP4 file is fragmented by checking if the second box is a Movie Fragment (moof) or Segment Type (styp) box. Fragmented MP4 is used for adaptive streaming (DASH, HLS)."
    },
    {
      "type": "conditional",
      "name": "Extended Size Detection",
      "condition": "ftypBoxSize == 1",
      "trueLabel": "This MP4 uses 64-bit extended box sizes (file may exceed 4 GB)",
      "falseLabel": "This MP4 uses standard 32-bit box sizes",
      "description": "Checks if the ftyp box uses a 64-bit extended size field. A box size of 1 signals that the real size is stored in the next 8 bytes as a 64-bit big-endian integer. Used for files exceeding 4 GB."
    },
    {
      "type": "conditional",
      "name": "Streaming Format Detection",
      "condition": "majorBrand == 'dash' || majorBrand == 'msdh' || majorBrand == 'msix'",
      "trueLabel": "This MP4 is optimized for MPEG-DASH adaptive streaming",
      "falseLabel": "This MP4 is a standard non-streaming container",
      "description": "Detects whether the file is an MPEG-DASH segment based on the major brand. DASH segments use fragmented MP4 with moof/mdat pairs for adaptive bitrate streaming."
    },
    {
      "type": "metadata",
      "name": "Major Brand",
      "variable": "majorBrand",
      "description": "Four-character brand code from the ftyp box identifying the file's primary specification"
    },
    {
      "type": "metadata",
      "name": "Major Brand Description",
      "variable": "majorBrandName",
      "description": "Human-readable name of the major brand specification"
    },
    {
      "type": "metadata",
      "name": "Minor Version",
      "variable": "minorVersion",
      "description": "Minor version number of the major brand specification"
    },
    {
      "type": "metadata",
      "name": "ftyp Box Size",
      "variable": "ftypBoxSize",
      "description": "Total size of the File Type Box in bytes, including the 8-byte header"
    },
    {
      "type": "metadata",
      "name": "Next Box Type",
      "variable": "nextBoxTypeName",
      "description": "Human-readable description of the second box following the ftyp box"
    },
    {
      "type": "metadata",
      "name": "Formatted File Size",
      "variable": "formattedFileSize",
      "description": "Total file size formatted as a human-readable string (KB/MB/GB)"
    }
  ],
  "assertions": [
    {
      "name": "ftyp box type is 'ftyp'",
      "expression": "ftypBoxType == 'ftyp'",
      "severity": "error",
      "message": "Box type at offset 4 must be 'ftyp' (0x66747970) — not a valid ISOBMFF/MP4 file"
    },
    {
      "name": "ftyp box size is reasonable",
      "expression": "ftypBoxSize >= 8 && ftypBoxSize <= 256",
      "severity": "warning",
      "message": "ftyp box size outside expected range (8-256 bytes) — malformed or non-standard ftyp"
    },
    {
      "name": "Major brand is known",
      "expression": "majorBrand == 'isom' || majorBrand == 'iso2' || majorBrand == 'mp41' || majorBrand == 'mp42' || majorBrand == 'M4V ' || majorBrand == 'M4A ' || majorBrand == 'dash' || majorBrand == 'avc1' || majorBrand == '3gp4' || majorBrand == '3gp5' || majorBrand == '3gp6'",
      "severity": "info",
      "message": "Major brand is not a commonly recognized ISOBMFF brand — may be a proprietary or specialized MP4 variant"
    }
  ],
  "versionDetection": {
    "field": "majorBrand",
    "versions": {
      "isom": "ISO Base Media File Format (generic)",
      "iso2": "ISO Base Media File v2",
      "mp41": "MPEG-4 Part 14 v1",
      "mp42": "MPEG-4 Part 14 v2",
      "M4V ": "Apple iTunes Video",
      "M4A ": "Apple iTunes Audio",
      "M4P ": "Apple FairPlay DRM",
      "dash": "MPEG-DASH adaptive streaming",
      "avc1": "AVC/H.264 video",
      "3gp4": "3GPP Release 4 (mobile)"
    }
  },
  "navigation": {
    "bookmarks": [
      {
        "name": "ftyp Box",
        "offset": 0,
        "icon": "\uE71B",
        "color": "#FF6B6B"
      },
      {
        "name": "Major Brand",
        "offset": 8,
        "icon": "\uE8B7",
        "color": "#95E1D3"
      }
    ]
  },
  "inspector": {
    "badge": "majorBrand",
    "primaryField": "ftypBoxSize",
    "showQualityScore": true,
    "groups": [
      {
        "title": "ISOBMFF ftyp Box",
        "icon": "\uE71B",
        "fields": ["ftypBoxType", "ftypBoxSize", "majorBrand", "majorBrandName", "minorVersion"]
      },
      {
        "title": "Compatible Brands",
        "icon": "\uE8B7",
        "fields": ["compatBrand1", "compatBrand2", "compatBrand3", "compatBrand4"]
      },
      {
        "title": "Container Structure",
        "icon": "\uE9D9",
        "fields": ["nextBoxType", "nextBoxTypeName", "isFragmented"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "ftyp Box (JSON)",
      "format": "json",
      "fields": ["ftypBoxType", "ftypBoxSize", "majorBrand", "majorBrandName", "minorVersion", "compatBrand1", "compatBrand2", "isFragmented"]
    },
    {
      "name": "ISOBMFF_FTYP_BOX (C struct)",
      "format": "c-struct",
      "structName": "isobmff_ftyp_box",
      "fields": ["ftypBoxSize", "ftypBoxType", "majorBrand", "minorVersion"]
    }
  ],
  "forensic": {
    "category": "video",
    "riskLevel": "low",
    "suspiciousPatterns": [
      {
        "name": "Fragmented MP4 (DASH segment)",
        "condition": "isFragmented == 1",
        "severity": "info",
        "description": "File is a fragmented MP4 (moof/mdat pairs). Used for MPEG-DASH/HLS adaptive streaming. Cannot be played directly without a manifest file. May be a streaming segment rather than a complete media file."
      },
      {
        "name": "DRM-protected content",
        "condition": "majorBrand == 'M4P '",
        "severity": "info",
        "description": "File has Apple FairPlay DRM major brand (M4P). Audio/video is encrypted and can only be played on authorized Apple devices. Raw media extraction requires FairPlay decryption keys."
      },
      {
        "name": "Extended 64-bit size",
        "condition": "ftypBoxSize == 1",
        "severity": "info",
        "description": "ftyp box uses 64-bit extended size (size field = 1). File likely exceeds 4 GB. Verify player support for large ISOBMFF files."
      }
    ],
    "knownExploitVectors": [
      "CVE-2021-30746: Apple CoreMedia MP4 parsing heap overflow via crafted stts atom",
      "CVE-2019-8627: iOS AVFoundation MP4 parsing OOB read via malformed esds atom",
      "Crafted tkhd atom with negative track duration can underflow duration calculations in some parsers",
      "Malformed moov atom with invalid sample table (stts, stsc, stco) offsets enables arbitrary memory reads"
    ]
  },
  "aiHints": {
    "analysisContext": "MP4/ISOBMFF layout (all BE): ftyp_box_size(4,BE) + 'ftyp'(4) + majorBrand(4,ASCII) + minorVersion(4,BE) + compatBrands(4B each, until box end). Common brands: 'isom'=generic, 'mp41'/'mp42'=MPEG-4, 'M4V '=iTunes video, 'M4A '=iTunes audio, 'dash'=DASH streaming. After ftyp: 'moov' (metadata) or 'mdat' (media data) box. moov > mvhd: timescale(4,BE) + duration(4,BE). moov > trak > tkhd > mdia > minf > stbl > stsd: video codec box ('avc1'=H.264, 'hev1'/'hvc1'=H.265, 'av01'=AV1, 'mp4v'=MPEG-4 Visual). Audio codec: 'mp4a' (AAC), 'ac-3' (AC-3), 'ec-3' (E-AC-3). Fragmented MP4 (fMP4): moof (Movie Fragment) + mdat pairs replace full moov+mdat. Used for DASH/HLS adaptive streaming.",
    "knownVulnerabilities": [
      "CVE-2021-30746: CoreMedia MP4 heap overflow via crafted stts atom",
      "CVE-2019-8627: AVFoundation OOB read via malformed esds atom",
      "Malformed stco (chunk offset table) with values > file size causes OOB reads"
    ],
    "suggestedInspections": [
      "Verify 'ftyp' at offset 4 (bytes 4-7 = 66 74 79 70)",
      "Read major brand at offset 8: 'isom'/'mp42' = generic MP4, 'M4V '/'M4A ' = iTunes",
      "Check if second box is 'moov' (progressive) or 'mdat' (requires full download before playback)",
      "For fragmented MP4: look for 'moof' box (Movie Fragment) after ftyp — used in DASH/HLS",
      "Scan moov > trak > mdia > minf > stbl > stsd for codec FourCC (avc1, hvc1, mp4a)"
    ]
  },
  "MimeTypes": [
    "video/mp4",
    "audio/mp4"
  ],
  "Software": [
    "VLC",
    "Windows Media Player",
    "QuickTime",
    "Chrome",
    "All modern browsers",
    "FFmpeg"
  ],
  "UseCases": [
    "Video streaming",
    "Mobile video",
    "Web video",
    "YouTube",
    "Social media"
  ],
  "QualityMetrics": {
    "CompletenessScore": 92,
    "DocumentationLevel": "comprehensive",
    "BlocksDefined": 20,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Container": "MPEG-4 Part 14 (ISO Base Media File Format)",
    "VideoFormat": true,
    "Endianness": "big-endian (network byte order)",
    "HeaderSize": "Variable (ftyp box size, typically 20-40 bytes)",
    "BoxBasedFormat": true,
    "SupportsEncryption": true,
    "SupportsStreaming": true,
    "SupportsFragmentation": true,
    "MaxFileSize": "Unlimited (64-bit extended sizes)"
  }
}

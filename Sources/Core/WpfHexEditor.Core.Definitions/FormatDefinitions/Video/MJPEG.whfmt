      { "value": "FFD8FFE0", "offset": 0, "label": "JPEG SOI + JFIF APP0 marker — MJPEG frame start", "weight": 1.0 },
      { "value": "FFD8FFE1", "offset": 0, "label": "JPEG SOI + EXIF APP1 marker — MJPEG frame start", "weight": 0.9 },
      { "value": "FFD8FF", "offset": 0, "label": "JPEG SOI marker (generic)", "weight": 0.6 }

{
  "diffMode": "binary",
  "formatName": "Motion JPEG",
  "version": "1.15",
  "extensions": [
    ".mjpeg",
    ".mjpg"
  ],
  "description": "Motion JPEG (MJPEG or M-JPEG) is a video compression format where each frame of video is independently compressed as a JPEG image. Unlike inter-frame codecs (H.264, MPEG-2), MJPEG has no temporal prediction — each frame is a self-contained JPEG. MJPEG files typically start with a JPEG SOI (Start of Image) marker 0xFF 0xD8, followed by the first JPEG segment marker. Common continuation markers: 0xFF 0xE0 (JFIF APP0), 0xFF 0xE1 (EXIF APP1), 0xFF 0xDB (DQT — quantization table), 0xFF 0xC0 (SOF0 — frame dimensions). MJPEG is stored raw (frame sequence without container), in AVI (MJPG FourCC), in QuickTime MOV (jpeg codec), or as multipart/x-mixed-replace streams (HTTP MJPEG streaming for IP cameras). Each JPEG frame ends with 0xFF 0xD9 (EOI).",
  "category": "Video",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ISO/IEC 10918-1 — JPEG Digital Compression and Coding",
      "ITU-T T.81 — JPEG Standard",
      "JFIF File Interchange Format v1.02"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/Motion_JPEG",
      "https://www.w3.org/Graphics/JPEG/",
      "https://jpeg.org/jpeg/"
    ]
  },

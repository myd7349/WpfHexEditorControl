  "blocks": [
    {
      "type": "signature",
      "name": "JPEG SOI Marker",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "JPEG Start of Image (SOI) marker 0xFF 0xD8. This 2-byte sequence marks the beginning of every JPEG data unit, including each frame in an MJPEG stream. Every JPEG/MJPEG frame starts with 0xFF 0xD8 and ends with EOI marker 0xFF 0xD9. In a raw MJPEG stream, consecutive SOI markers identify frame boundaries.",
      "storeAs": "jpegSoiMarker",
      "valueType": "uint16",
      "endianness": "big",
      "valueMap": { "65496": "JPEG SOI marker (0xFF 0xD8)" }
    },
    {
      "type": "field",
      "name": "First Segment Marker",
      "offset": 2,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "First JPEG segment marker after SOI. Common values: 0xFFE0 = JFIF APP0 (JFIF metadata), 0xFFE1 = APP1 (EXIF), 0xFFDB = DQT (quantization table, often first in MJPEG camera streams), 0xFFC0 = SOF0 (Baseline DCT frame header with width/height), 0xFFDA = SOS (Start of Scan).",
      "storeAs": "jpegApp0Marker",
      "valueType": "uint16",
      "endianness": "big",
      "valueMap": {
        "65504": "0xFFE0 APP0 — JFIF header",
        "65505": "0xFFE1 APP1 — EXIF/XMP",
        "65499": "0xFFDB DQT — quantization table",
        "65472": "0xFFC0 SOF0 — Baseline DCT frame header",
        "65498": "0xFFDA SOS — Start of Scan (compressed data)"
      }
    },
    {
      "type": "metadata",
      "name": "JPEG SOI",
      "variable": "jpegSoiMarker",
      "description": "JPEG Start of Image (0xFFD8 = 65496)"
    },
    {
      "type": "metadata",
      "name": "First Segment",
      "variable": "jpegApp0Marker",
      "description": "First JPEG segment marker"
    }

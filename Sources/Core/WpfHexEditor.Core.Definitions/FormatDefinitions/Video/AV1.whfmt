    "BlocksDefined": 11,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "VideoFormat": true,
    "ContainerFormat": "IVF (Indeo Video Format container)",
    "VideoCodec": "AV1 (AOMedia Video 1), VP8, or VP9",
    "Endianness": "little-endian (all IVF header fields)",
    "CompressionRatio": "30-50% better than VP9/H.265 at equivalent quality (AV1)"
  }

{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "FAT32 File System",
  "formatId": "FAT32",
  "version": "1.0",
  "diffMode": "binary",
  "extensions": [
    ".img",
    ".fat"
  ],
  "description": "FAT32 is the 32-bit variant of the File Allocation Table filesystem. The volume boot record contains the BIOS Parameter Block (BPB) with 'FAT32   ' OEM label at offset 82, and the boot sector signature 0x55 0xAA at offset 510.",
  "category": "Disk",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "MimeTypes": [
    "application/octet-stream"
  ],
  "UseCases": [
    "USB flash drives and SD cards formatted for cross-platform compatibility",
    "Embedded systems and removable media file storage",
    "Digital forensics: recovery of deleted files and slack space analysis"
  ],
  "references": [
    "https://docs.microsoft.com/en-us/windows/win32/fileio/fat-technical-reference",
    "https://www.pjrc.com/tech/8051/ide/fat32.html",
    "https://wiki.osdev.org/FAT"
  ],
  "software": [
    {
      "name": "mkfs.fat",
      "url": "https://linux.die.net/man/8/mkfs.fat",
      "role": "Linux FAT32 formatter"
    },
    {
      "name": "Disk Management",
      "url": "https://docs.microsoft.com/en-us/windows-server/storage/disk-management/overview-of-disk-management",
      "role": "Windows disk management"
    },
    {
      "name": "TestDisk",
      "url": "https://www.cgsecurity.org/wiki/TestDisk",
      "role": "Partition and filesystem recovery"
    }
  ],
  "formatRelationships": [
    {
      "format": "FAT16",
      "relationship": "FAT32 is an extension of FAT16 supporting larger volumes and 32-bit cluster entries"
    },
    {
      "format": "exFAT",
      "relationship": "exFAT supersedes FAT32 for flash media with larger file size support"
    },
    {
      "format": "NTFS",
      "relationship": "NTFS is the preferred Windows filesystem for fixed drives"
    }
  ],
  "detection": {
    "signatures": [
      {
        "offset": 82,
        "value": "46415433322020202020",
        "label": "'FAT32   ' filesystem type label in BPB",
        "weight": 1.0
      },
      {
        "offset": 510,
        "value": "55AA",
        "label": "Boot sector signature at offset 510",
        "weight": 0.7
      }
    ],
    "matchMode": "any",
    "MinimumScore": 82,
    "Strength": "Strong",
    "EntropyHint": {
      "min": 2.0,
      "max": 7.0,
      "note": "Boot record has low entropy; data clusters vary by content"
    },
    "validation": "Bytes at offset 82 must contain 'FAT32   '. Boot sector signature at offset 510-511 must be 0x55 0xAA. BytesPerSector at offset 11 must be 512, 1024, 2048, or 4096. NumFATs at offset 16 is typically 2."
  },
  "variables": [
    {
      "name": "fat32JmpBoot",
      "type": "hex",
      "offset": 0,
      "length": 3,
      "description": "Jump instruction at start of boot record"
    },
    {
      "name": "fat32OemName",
      "type": "ascii",
      "offset": 3,
      "length": 8,
      "description": "OEM Name string (e.g. MSDOS5.0, mkfs.fat)"
    },
    {
      "name": "fat32BytesPerSector",
      "type": "uint16",
      "offset": 11,
      "length": 2,
      "endian": "little",
      "description": "Bytes per sector",
      "valueMap": {
        "512": "512",
        "1024": "1024",
        "2048": "2048",
        "4096": "4096"
      }
    },
    {
      "name": "fat32SectorsPerCluster",
      "type": "uint8",
      "offset": 13,
      "length": 1,
      "description": "Sectors per cluster (must be power of 2)"
    },
    {
      "name": "fat32NumFATs",
      "type": "uint8",
      "offset": 16,
      "length": 1,
      "description": "Number of FAT copies (standard: 2)"
    }
  ],
  "blocks": [
    {
      "name": "BootSector",
      "offset": 0,
      "length": 512,
      "description": "Volume Boot Record: BPB + FAT32 BPB extension + boot code + 0x55AA signature",
      "fields": [
        {
          "name": "JmpBoot",
          "variable": "fat32JmpBoot",
          "offset": 0,
          "length": 3
        },
        {
          "name": "OemName",
          "variable": "fat32OemName",
          "offset": 3,
          "length": 8
        },
        {
          "name": "BytesPerSector",
          "variable": "fat32BytesPerSector",
          "offset": 11,
          "length": 2
        },
        {
          "name": "SectorsPerCluster",
          "variable": "fat32SectorsPerCluster",
          "offset": 13,
          "length": 1
        },
        {
          "name": "NumFATs",
          "variable": "fat32NumFATs",
          "offset": 16,
          "length": 1
        }
      ]
    },
    {
      "name": "FATTable1",
      "offset": -1,
      "length": -1,
      "description": "First File Allocation Table: 32-bit cluster chain entries"
    },
    {
      "name": "FATTable2",
      "offset": -1,
      "length": -1,
      "description": "Second FAT copy (mirror of FATTable1 for redundancy)"
    },
    {
      "name": "DataRegion",
      "offset": -1,
      "length": -1,
      "description": "Data clusters starting at cluster 2; contains root directory and all file data"
    }
  ],
  "assertions": [
    {
      "id": "A1",
      "description": "BytesPerSector must be 512, 1024, 2048, or 4096",
      "expression": "fat32BytesPerSector == 512 || fat32BytesPerSector == 1024 || fat32BytesPerSector == 2048 || fat32BytesPerSector == 4096"
    },
    {
      "id": "A2",
      "description": "NumFATs must be 2",
      "expression": "fat32NumFATs == 2"
    },
    {
      "id": "A3",
      "description": "SectorsPerCluster must be a power of 2 between 1 and 128",
      "expression": "fat32SectorsPerCluster >= 1 && fat32SectorsPerCluster <= 128"
    }
  ],
  "navigation": {
    "entryPoint": "BootSector",
    "structure": [
      "BootSector",
      "FATTable1",
      "FATTable2",
      "DataRegion"
    ],
    "notes": "Root directory cluster is stored at BPB offset 44 (4B LE). FAT region begins at ReservedSectorCount * BytesPerSector."
  },
  "inspector": {
    "badge": "F32",
    "primaryField": "fat32OemName",
    "groups": [
      {
        "name": "BPB Core",
        "fields": [
          "fat32JmpBoot",
          "fat32OemName",
          "fat32BytesPerSector",
          "fat32SectorsPerCluster"
        ]
      },
      {
        "name": "FAT Configuration",
        "fields": [
          "fat32NumFATs"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "BPB Summary CSV",
      "format": "csv",
      "fields": [
        "fat32OemName",
        "fat32BytesPerSector",
        "fat32SectorsPerCluster",
        "fat32NumFATs"
      ]
    },
    {
      "name": "Boot Sector JSON",
      "format": "json",
      "fields": [
        "fat32JmpBoot",
        "fat32OemName",
        "fat32BytesPerSector",
        "fat32SectorsPerCluster",
        "fat32NumFATs"
      ]
    }
  ],
  "forensic": {
    "riskLevel": "MEDIUM",
    "notes": "FAT32 volumes retain deleted file metadata and data in unallocated clusters until overwritten. Slack space may contain fragments of prior file content.",
    "suspiciousPatterns": [
      "OEM name set to an unusual value",
      "NumFATs set to 1 (reduced redundancy)",
      "SectorsPerCluster not a power of 2",
      "Boot code area modified (potential bootkit infection)",
      "Deleted directory entries (0xE5 first byte) for sensitive filenames"
    ]
  },
  "aiHints": {
    "analysisContext": "FAT32 volume structure: VBR at sector 0, backup VBR at sector 6, FSInfo at sector 1. FAT region follows reserved sectors. Root directory starts at cluster 2 in data region. 32-bit cluster entries with upper 4 bits masked.",
    "suggestedInspections": [
      "Parse BPB fields to calculate FAT region start (ReservedSectorCount * BytesPerSector) and data region start",
      "Walk the root directory cluster chain starting at BPB offset 44 to enumerate top-level entries",
      "Scan for deleted directory entries (first byte 0xE5) to recover filenames and cluster chains",
      "Compare FAT1 and FAT2 for inconsistencies indicating filesystem corruption or modification",
      "Analyze cluster slack space at end of each file last cluster for residual data fragments"
    ]
  },
  "TechnicalDetails": {
    "endianness": "Little-endian",
    "bootSectorSize": 512,
    "clusterEntrySize": "32-bit (upper 4 bits reserved)",
    "maxFileSize": "4 GB minus 1 byte",
    "maxVolumeSize": "2 TB with 512-byte sectors"
  },
  "QualityMetrics": {
    "CompletenessScore": 88,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  },
  "diff": {
    "keyFields": ["fat32OemName", "fat32BytesPerSector", "fat32SectorsPerCluster", "fat32NumFATs"],
    "ignoreFields": ["fat32JmpBoot"],
    "groupBy": "fat32OemName",
    "note": "OEM name identifies the formatting tool, sector/cluster geometry defines allocation unit size, NumFATs reflects redundancy configuration. JmpBoot varies by OS loader and is not meaningful for volume comparison"
  },
  "repair": [
    {
      "name": "FixFat32NumFATs",
      "trigger": "fat32NumFATs != 2",
      "action": "set_value",
      "target": "fat32NumFATs",
      "value": "02",
      "description": "Restore NumFATs to 2 — the FAT32 specification requires exactly 2 FAT copies for redundancy; 1 indicates non-standard or corrupted BPB"
    },
    {
      "name": "FixFat32BytesPerSector",
      "trigger": "fat32BytesPerSector != 512 && fat32BytesPerSector != 1024 && fat32BytesPerSector != 2048 && fat32BytesPerSector != 4096",
      "action": "set_value",
      "target": "fat32BytesPerSector",
      "value": "0002",
      "description": "Reset BytesPerSector to 512 (LE uint16 0x0200) — the most common valid value — when it holds an invalid non-power-of-2 value"
    }
  ],
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      { "field": "fat32OemName",          "mutation": "corrupt_signature", "weight": 3, "description": "Corrupt OEM name string to test whether FAT32 parsers fall back gracefully or reject volumes with non-standard formatter strings" },
      { "field": "fat32BytesPerSector",   "mutation": "boundary_values",   "weight": 2, "description": "Test extreme BytesPerSector values (0, 256, 8192) to probe BPB validation in filesystem drivers and recovery tools" },
      { "field": "fat32SectorsPerCluster","mutation": "overflow",          "weight": 2, "description": "Set SectorsPerCluster to non-power-of-2 values (e.g., 3, 255) to expose cluster size validation failures in FAT table size calculations" },
      { "field": "fat32NumFATs",          "mutation": "random_bytes",      "weight": 1, "description": "Set NumFATs to random values (0, 3, 255) to test parser handling of invalid FAT copy counts" },
      { "field": "fat32JmpBoot",          "mutation": "bit_flip", "rate": 0.001, "weight": 1, "description": "Flip bits in the jump instruction to probe whether boot loaders validate the x86 JMP opcode before execution" }
    ]
  },
  "migration": [
    {
      "from": "FAT16",
      "to": "FAT32",
      "description": "FAT16 to FAT32 upgrade — BPB extended at offset 36+ with FAT32-specific fields (FATSz32, ExtFlags, RootClus, FSInfo, BkBootSec); OEM name convention changes",
      "changes": [
        { "field": "fat32OemName", "changeType": "set_value", "value": "4D53444F53352E30", "description": "Set OEM name to 'MSDOS5.0' (8 ASCII bytes) — standard value for FAT32-formatted volumes created by Windows" }
      ]
    },
    {
      "from": "FAT32",
      "to": "exFAT",
      "description": "FAT32 to exFAT migration — exFAT uses a completely different BPB layout with 'EXFAT   ' at offset 3; not in-place — requires reformatting",
      "changes": [
        { "field": "fat32OemName", "changeType": "set_value", "value": "455846415420202020", "description": "exFAT OEM name is 'EXFAT   ' (8 bytes); this documents the format identity break requiring full reformatting" }
      ]
    }
  ]
}



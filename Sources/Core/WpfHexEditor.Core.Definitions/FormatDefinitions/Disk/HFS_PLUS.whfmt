{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "HFS+ File System",
  "formatId": "HFS_PLUS",
  "version": "1.0",
  "diffMode": "binary",
  "extensions": [
    ".dmg",
    ".hfs",
    ".img"
  ],
  "description": "HFS+ (Mac OS Extended) is Apple's journaling filesystem introduced in Mac OS 8.1. The volume header is located at byte offset 1024 and starts with the 2-byte signature 0x482B ('H+') for HFS+ or 0x4858 ('HX') for HFSX (case-sensitive variant).",
  "category": "Disk",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "MimeTypes": [
    "application/octet-stream",
    "application/x-apple-diskimage"
  ],
  "UseCases": [
    "macOS system volume and external drive filesystem",
    "Apple Time Machine backup disk images",
    "Digital forensics of macOS devices and disk images"
  ],
  "references": [
    "https://developer.apple.com/library/archive/technotes/tn/tn1150.html",
    "https://github.com/libyal/libhfsplus/blob/main/documentation/HFS+%20volume%20format.asciidoc",
    "https://www.nationalarchives.gov.uk/PRONOM/fmt/542"
  ],
  "software": [
    {
      "name": "hfsplus (Linux)",
      "url": "https://linux.die.net/man/8/mkfs.hfsplus",
      "role": "Linux HFS+ formatter and checker"
    },
    {
      "name": "Disk Utility (macOS)",
      "url": "https://support.apple.com/guide/disk-utility/",
      "role": "Apple disk management tool"
    },
    {
      "name": "The Sleuth Kit",
      "url": "https://www.sleuthkit.org/",
      "role": "Open-source forensic toolkit with HFS+ support"
    }
  ],
  "formatRelationships": [
    {
      "format": "HFS",
      "relationship": "HFS+ supersedes the original HFS (Mac OS Standard) filesystem"
    },
    {
      "format": "APFS",
      "relationship": "APFS replaces HFS+ on modern macOS (10.13+) and iOS devices"
    },
    {
      "format": "DMG",
      "relationship": "Apple Disk Images (.dmg) frequently contain HFS+ formatted volumes"
    }
  ],
  "detection": {
    "signatures": [
      {
        "offset": 1024,
        "value": "482B",
        "label": "'H+' HFS+ volume header signature",
        "weight": 1.0
      },
      {
        "offset": 1024,
        "value": "4858",
        "label": "'HX' HFSX case-sensitive volume header signature",
        "weight": 0.9
      }
    ],
    "matchMode": "any",
    "MinimumScore": 85,
    "Strength": "Strong",
    "EntropyHint": {
      "min": 4.0,
      "max": 8.0,
      "note": "Journaled volumes have moderate-to-high entropy"
    },
    "validation": "2-byte signature at offset 1024 must be 0x482B or 0x4858. Version at offset 1026 (2B BE) must be 4 or 5."
  },
  "variables": [
    {
      "name": "hfsPlusSig",
      "type": "ascii",
      "offset": 1024,
      "length": 2,
      "description": "Volume header signature: 'H+' or 'HX'"
    },
    {
      "name": "hfsPlusVersion",
      "type": "uint16",
      "offset": 1026,
      "length": 2,
      "endian": "big",
      "description": "Volume header version",
      "valueMap": {
        "4": "HFS+ v4",
        "5": "HFS+ v5 / HFSX"
      }
    },
    {
      "name": "hfsPlusFileCount",
      "type": "uint32",
      "offset": 1056,
      "length": 4,
      "endian": "big",
      "description": "Total number of files on volume"
    },
    {
      "name": "hfsPlusFolderCount",
      "type": "uint32",
      "offset": 1060,
      "length": 4,
      "endian": "big",
      "description": "Total number of folders on volume"
    }
  ],
  "blocks": [
    {
      "name": "ReservedBootArea",
      "offset": 0,
      "length": 1024,
      "description": "Reserved boot area (two 512-byte boot blocks, legacy from HFS)"
    },
    {
      "name": "VolumeHeader",
      "offset": 1024,
      "length": 512,
      "description": "HFS+ volume header: signature, version, attributes, file/folder counts, B-tree node descriptors",
      "fields": [
        {
          "name": "Signature",
          "variable": "hfsPlusSig",
          "offset": 0,
          "length": 2
        },
        {
          "name": "Version",
          "variable": "hfsPlusVersion",
          "offset": 2,
          "length": 2
        },
        {
          "name": "FileCount",
          "variable": "hfsPlusFileCount",
          "offset": 32,
          "length": 4
        },
        {
          "name": "FolderCount",
          "variable": "hfsPlusFolderCount",
          "offset": 36,
          "length": 4
        }
      ]
    },
    {
      "name": "AllocationFile",
      "offset": -1,
      "length": -1,
      "description": "Allocation bitmap file tracking used/free extents"
    },
    {
      "name": "CatalogFile",
      "offset": -1,
      "length": -1,
      "description": "Catalog B-tree file containing all file and directory records"
    }
  ],
  "assertions": [
    {
      "id": "A1",
      "description": "Signature must be 'H+' or 'HX'",
      "expression": "hfsPlusSig == 'H+' || hfsPlusSig == 'HX'"
    },
    {
      "id": "A2",
      "description": "Version must be 4 or 5",
      "expression": "hfsPlusVersion == 4 || hfsPlusVersion == 5"
    },
    {
      "id": "A3",
      "description": "FileCount must be non-negative",
      "expression": "hfsPlusFileCount >= 0"
    }
  ],
  "navigation": {
    "entryPoint": "VolumeHeader",
    "structure": [
      "ReservedBootArea",
      "VolumeHeader",
      "AllocationFile",
      "CatalogFile"
    ],
    "notes": "Volume header at offset 1024; alternate volume header at volume end minus 1024 bytes. Catalog B-tree root node found via CatalogFile extent in volume header. All multi-byte values are big-endian."
  },
  "inspector": {
    "badge": "HFS",
    "primaryField": "hfsPlusVersion",
    "groups": [
      {
        "name": "Volume Header",
        "fields": [
          "hfsPlusSig",
          "hfsPlusVersion"
        ]
      },
      {
        "name": "Volume Statistics",
        "fields": [
          "hfsPlusFileCount",
          "hfsPlusFolderCount"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Volume Summary CSV",
      "format": "csv",
      "fields": [
        "hfsPlusSig",
        "hfsPlusVersion",
        "hfsPlusFileCount",
        "hfsPlusFolderCount"
      ]
    },
    {
      "name": "Volume Header JSON",
      "format": "json",
      "fields": [
        "hfsPlusSig",
        "hfsPlusVersion",
        "hfsPlusFileCount",
        "hfsPlusFolderCount"
      ]
    }
  ],
  "forensic": {
    "riskLevel": "HIGH",
    "notes": "HFS+ supports resource forks and extended attributes that may hide data invisible to standard file browsers. The journal may contain recently deleted or modified data.",
    "suspiciousPatterns": [
      "Alternate volume header inconsistent with primary volume header",
      "Journal containing uncommitted transactions with sensitive file operations",
      "Extended attributes storing hidden data beyond normal file content",
      "Orphaned catalog nodes not reachable from the catalog B-tree root"
    ]
  },
  "aiHints": {
    "analysisContext": "HFS+ organizes data using B-trees: Catalog file for file/directory records, Extents Overflow for fragmented files, Attributes for extended attributes. All B-tree values are big-endian.",
    "suggestedInspections": [
      "Locate catalog B-tree via CatalogFile extent in volume header and traverse from root node to enumerate all files",
      "Check journal info block for uncommitted transactions revealing recent deleted file operations",
      "Scan extended attributes B-tree for hidden data streams attached to files",
      "Compare primary volume header at offset 1024 with alternate volume header at EOF-1024 for inconsistencies",
      "Analyze resource forks in catalog records for executable code or hidden payloads"
    ]
  },
  "TechnicalDetails": {
    "endianness": "Big-endian",
    "volumeHeaderOffset": 1024,
    "alternateVolumeHeaderOffset": "EOF - 1024 bytes",
    "btreeNodeSize": "Default 4096 bytes for catalog",
    "journalMagic": "0x4A4E4C78 ('JNLx')"
  },
  "QualityMetrics": {
    "CompletenessScore": 87,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  }
}



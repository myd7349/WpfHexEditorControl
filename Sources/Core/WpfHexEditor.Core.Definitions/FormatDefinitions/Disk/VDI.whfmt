{
  "diffMode": "binary",
  "formatName": "VirtualBox Disk Image",
  "version": "1.14",
  "extensions": [
    ".vdi"
  ],
  "description": "VirtualBox virtual disk format",
  "category": "Disk",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "VirtualBox Virtual Disk Image (VDI) Format",
      "Oracle VM VirtualBox Storage Documentation",
      "VDI Dynamic and Fixed Allocation"
    ],
    "WebLinks": [
      "https://docs.oracle.com/en/virtualization/virtualbox/6.0/user/vdidetails.html",
      "https://www.virtualbox.org/manual/ch05.html",
      "https://docs.fileformat.com/disc-and-media/vdi/",
      "https://docs.oracle.com/en/virtualization/virtualbox/7.0/user/storage.html"
    ]
  },
  "detection": {
    "required": true,
    "validation": {
      "minFileSize": 4,
      "maxSignatureOffset": 1024
    },
    "signatures": [
      {
        "value": "3C3C3C20",
        "offset": 0,
        "label": "VDI magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "Strength": "Strong"
  },
  "variables": {
    "currentOffset": 0,
    "sectorSize": 0,
    "sectorCount": 0,
    "capacity": 0,
    "format": "",
    "vdiSignature": "",
    "text": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "VDI Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "<<< signature",
      "storeAs": "vdiSignature",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Text",
      "offset": 64,
      "length": 32,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Oracle VM VirtualBox text",
      "storeAs": "text",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Sector Size",
      "variable": "sectorSize",
      "description": "Sector Size"
    },
    {
      "type": "metadata",
      "name": "Sector Count",
      "variable": "sectorCount",
      "description": "Sector Count"
    },
    {
      "type": "metadata",
      "name": "Capacity",
      "variable": "capacity",
      "description": "Capacity"
    },
    {
      "type": "metadata",
      "name": "Format",
      "variable": "format",
      "description": "Format"
    }
  ],
  "software": [
    "Common file viewers",
    "Specialized software"
  ],
  "formatRelationships": {
    "category": "Disk",
    "extensions": [
      ".vdi"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "DiskInternals",
    "R-Studio",
    "HxD",
    "FTK Imager",
    "Autopsy"
  ],
  "UseCases": [
    "Disk imaging",
    "Forensics",
    "Data recovery",
    "Analysis"
  ],
  "QualityMetrics": {
    "CompletenessScore": 57,
    "DocumentationLevel": "standard",
    "BlocksDefined": 6,
    "ValidationRules": 0,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt32LE": "Read disk header",
    "multiply": "Calculate capacity"
  },
  "forensic": {
    "category": "disk",
    "riskLevel": "medium",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "VirtualBox virtual disk format",
    "suggestedInspections": [
      "Verify VirtualBox Disk Image superblock/boot sector signature and version",
      "Check partition/volume layout and allocation bitmap",
      "Inspect filesystem journal and metadata consistency"
    ]
  },
  "inspector": {
    "badge": "vdiSignature",
    "primaryField": "text",
    "showQualityScore": true,
    "groups": [
      {
        "title": "VirtualBox Disk Image",
        "icon": "",
        "fields": [
          "vdiSignature",
          "text"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "VirtualBox Disk Image Header (JSON)",
      "format": "json",
      "fields": [
        "vdiSignature",
        "text"
      ]
    }
  ],
  "assertions": [
    {
      "name": "magic valid",
      "expression": "vdiSignature != 0",
      "severity": "warning",
      "message": "VDI magic field is zero — possible detection failure"
    }
  ]
}
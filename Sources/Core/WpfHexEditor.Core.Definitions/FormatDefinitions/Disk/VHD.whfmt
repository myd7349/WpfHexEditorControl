{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Virtual Hard Disk",
  "formatId": "VHD",
  "version": "1.14",
  "extensions": [
    ".vhd"
  ],
  "description": "Microsoft Virtual Hard Disk format",
  "category": "Disk",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Virtual Hard Disk (VHD) Image Format Specification",
      "Microsoft Hyper-V VHD Format",
      "Connectix Virtual PC Disk Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/VHD_(file_format)",
      "https://learn.microsoft.com/en-us/previous-versions/windows/it-pro/windows-server-2012-r2-and-2012/hh831446(v=ws.11)",
      "https://github.com/libyal/libvhdi/blob/main/documentation/Virtual%20Hard%20Disk%20(VHD)%20image%20format.asciidoc",
      "https://learn.microsoft.com/en-us/windows-server/storage/disk-management/manage-virtual-hard-disks"
    ]
  },
  "detection": {
    "required": true,
    "validation": {
      "minFileSize": 8,
      "maxSignatureOffset": 1024
    },
    "signatures": [
      {
        "value": "636F6E6563746978",
        "offset": 0,
        "label": "VHD magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "Strength": "Strong"
  },
  "variables": {
    "currentOffset": 0,
    "sectorSize": 0,
    "sectorCount": 0,
    "capacity": 0,
    "format": "",
    "vhdCookie": 0,
    "features": 0,
    "formatVersion": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "VHD Cookie",
      "offset": 0,
      "length": 8,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "conectix signature",
      "storeAs": "vhdCookie",
      "valueType": "uint64"
    },
    {
      "type": "field",
      "name": "Features",
      "offset": 8,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Feature flags",
      "storeAs": "features",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Format Version",
      "offset": 12,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "File format version",
      "storeAs": "formatVersion",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Sector Size",
      "variable": "sectorSize",
      "description": "Sector Size"
    },
    {
      "type": "metadata",
      "name": "Sector Count",
      "variable": "sectorCount",
      "description": "Sector Count"
    },
    {
      "type": "metadata",
      "name": "Capacity",
      "variable": "capacity",
      "description": "Capacity"
    },
    {
      "type": "metadata",
      "name": "Format",
      "variable": "format",
      "description": "Format"
    }
  ],
  "software": [
    "Common file viewers",
    "Specialized software"
  ],
  "formatRelationships": {
    "category": "Disk",
    "extensions": [
      ".vhd"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "DiskInternals",
    "R-Studio",
    "HxD",
    "FTK Imager",
    "Autopsy"
  ],
  "UseCases": [
    "Disk imaging",
    "Forensics",
    "Data recovery",
    "Analysis"
  ],
  "QualityMetrics": {
    "CompletenessScore": 63,
    "DocumentationLevel": "standard",
    "BlocksDefined": 7,
    "ValidationRules": 0,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "forensic": {
    "category": "disk",
    "riskLevel": "medium",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Microsoft Virtual Hard Disk format",
    "suggestedInspections": [
      "Verify Virtual Hard Disk superblock/boot sector signature and version",
      "Check partition/volume layout and allocation bitmap",
      "Inspect filesystem journal and metadata consistency"
    ]
  },
  "navigation": {
    "bookmarks": [
      {
        "name": "VHD Footer",
        "offsetVar": "currentOffset",
        "icon": ""
      }
    ]
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt32LE": "Read disk header",
    "multiply": "Calculate capacity"
  },
  "inspector": {
    "badge": "vhdCookie",
    "primaryField": "features",
    "showQualityScore": true,
    "groups": [
      {
        "title": "Virtual Hard Disk",
        "icon": "",
        "fields": [
          "vhdCookie",
          "features",
          "formatVersion"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Virtual Hard Disk Header (JSON)",
      "format": "json",
      "fields": [
        "vhdCookie",
        "features",
        "formatVersion"
      ]
    }
  ],
  "assertions": [
    {
      "name": "magic valid",
      "expression": "vhdCookie != 0",
      "severity": "warning",
      "message": "VHD magic field is zero — possible detection failure"
    }
  ],
  "diff": {
    "keyFields": ["vhdCookie", "formatVersion", "features"],
    "ignoreFields": [],
    "groupBy": "vhdCookie",
    "note": "Cookie identifies the format, formatVersion tracks spec revision, features flags distinguish fixed/dynamic/differencing disk types — all three together define the disk identity for comparison"
  },
  "repair": [
    {
      "name": "FixVhdCookie",
      "trigger": "vhdCookie == 0",
      "action": "set_value",
      "target": "vhdCookie",
      "value": "636F6E65637469780000",
      "description": "Restore the VHD footer cookie 'conectix' (8 ASCII bytes) at offset 0 when it is zeroed or corrupted"
    },
    {
      "name": "FixVhdFeatures",
      "trigger": "features == 0",
      "action": "set_value",
      "target": "features",
      "value": "00000002",
      "description": "Set features flags to 0x00000002 (Reserved bit must be set per VHD spec) when the field is invalid zero"
    }
  ],
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      { "field": "vhdCookie",     "mutation": "corrupt_signature", "weight": 3, "description": "Corrupt the 'conectix' cookie to verify that VHD parsers reject invalid footer cookies without crashing" },
      { "field": "features",      "mutation": "boundary_values",   "weight": 2, "description": "Test features field at 0x00000000 and 0xFFFFFFFF to probe flag validation in Hyper-V and third-party VHD loaders" },
      { "field": "formatVersion", "mutation": "overflow",          "weight": 2, "description": "Overflow the format version field to test parser resilience against unknown VHD format revisions" },
      { "field": "vhdCookie",     "mutation": "random_bytes",      "weight": 1, "description": "Replace cookie with random bytes to validate detection rejection of non-VHD files" },
      { "field": "features",      "mutation": "bit_flip", "rate": 0.001, "weight": 1, "description": "Flip individual bits in features flags to expose unhandled flag combinations in VHD disk type logic" }
    ]
  },
  "migration": [
    {
      "from": "VHD-Connectix",
      "to": "VHD-Microsoft",
      "description": "Connectix Virtual PC VHD to Microsoft Hyper-V VHD — same binary format but creator application field and UUID semantics differ",
      "changes": [
        { "field": "features", "changeType": "set_value", "value": "00000002", "description": "Ensure Reserved features bit (0x2) is set per Microsoft VHD spec; Connectix files may have this cleared" }
      ]
    },
    {
      "from": "VHD",
      "to": "VHDX",
      "description": "Legacy VHD to VHDX (new format introduced in Windows Server 2012 with 64 TB support, sector alignment, and journaling) — requires conversion tool, not in-place migration",
      "changes": [
        { "field": "vhdCookie", "changeType": "set_value", "value": "76686478 66696c65", "description": "VHDX uses 'vhdxfile' cookie (8 bytes); this field documents the format break" }
      ]
    }
  ]
}



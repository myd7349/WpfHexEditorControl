{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "NTFS Filesystem",
  "formatId": "NTFS",
  "version": "1.14",
  "extensions": [
    ".ntfs"
  ],
  "description": "Windows NT File System",
  "category": "Disk",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "NTFS Partition Boot Sector Specification",
      "NTFS Master File Table (MFT) Structure",
      "Windows NT File System Documentation"
    ],
    "WebLinks": [
      "http://ntfs.com/ntfs-partition-boot-sector.htm",
      "https://en.wikipedia.org/wiki/NTFS",
      "https://www.ntfs.com/ntfs-mft.htm",
      "https://learn.microsoft.com/en-us/previous-versions/windows/it-pro/windows-server-2003/cc781134(v=ws.10)"
    ]
  },
  "detection": {
    "required": true,
    "validation": {
      "minFileSize": 8,
      "maxSignatureOffset": 1024
    },
    "signatures": [
      {
        "value": "4E54465320202020",
        "offset": 3,
        "label": "NTFS magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "Strength": "Strong"
  },
  "variables": {
    "currentOffset": 0,
    "fileSize": 0,
    "version": 0,
    "format": "",
    "formattedSize": ""
  },
  "blocks": [
    {
      "type": "header",
      "name": "NTFS Boot Sector",
      "offset": 0,
      "length": 512,
      "color": "#0078D4",
      "opacity": 0.4,
      "description": "NTFS boot sector and BPB"
    },
    {
      "type": "metadata",
      "name": "File Size",
      "variable": "fileSize",
      "description": "File Size"
    },
    {
      "type": "metadata",
      "name": "Version",
      "variable": "version",
      "description": "Version"
    },
    {
      "type": "metadata",
      "name": "Formatted Size",
      "variable": "formattedSize",
      "description": "Human-readable file size"
    }
  ],
  "software": [
    "Common file viewers",
    "Specialized software"
  ],
  "formatRelationships": {
    "category": "Disk",
    "extensions": [
      ".ntfs"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "DiskInternals",
    "R-Studio",
    "HxD",
    "FTK Imager",
    "Autopsy"
  ],
  "UseCases": [
    "Disk imaging",
    "Forensics",
    "Data recovery",
    "Analysis"
  ],
  "QualityMetrics": {
    "CompletenessScore": 50,
    "DocumentationLevel": "basic",
    "BlocksDefined": 4,
    "ValidationRules": 0,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "forensic": {
    "category": "disk",
    "riskLevel": "medium",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Windows NT File System",
    "suggestedInspections": [
      "Verify NTFS Filesystem superblock/boot sector signature and version",
      "Check partition/volume layout and allocation bitmap",
      "Inspect filesystem journal and metadata consistency"
    ]
  },
  "navigation": {
    "bookmarks": [
      {
        "name": "Boot Sector (BPB)",
        "offsetVar": "currentOffset",
        "icon": ""
      }
    ]
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt32LE": "Read file header",
    "formatFileSize(var:fileSize)": "Format fileSize as readable size"
  },
  "diff": {
    "keyFields": ["version", "fileSize"],
    "ignoreFields": ["formattedSize"],
    "groupBy": "version",
    "note": "Version identifies the NTFS format revision; fileSize is the primary structural metric. formattedSize is a derived display string and is excluded from diff comparisons"
  },
  "repair": [
    {
      "name": "FixNtfsSignature",
      "trigger": "NTFSBootSector_signature != '4E544653'",
      "action": "set_value",
      "target": "NTFS Boot Sector",
      "value": "4E54465320202020",
      "description": "Restore the NTFS OEM ID 'NTFS    ' (8 ASCII bytes, 4E 54 46 53 20 20 20 20) at offset 3 of the boot sector when it is corrupt"
    },
    {
      "name": "FixBootSectorSignature",
      "trigger": "BootSectorEndSignature != '55AA'",
      "action": "set_value",
      "target": "NTFS Boot Sector",
      "value": "55AA",
      "description": "Restore the boot sector end signature 0x55 0xAA at offset 510 when it is zeroed or overwritten, enabling BIOS/UEFI to recognize the volume"
    }
  ],
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      { "field": "version",     "mutation": "corrupt_signature", "weight": 3, "description": "Corrupt the NTFS OEM ID at offset 3 to test NTFS driver and forensic tool detection rejection paths" },
      { "field": "fileSize",    "mutation": "boundary_values",   "weight": 2, "description": "Test fileSize at 0, max uint64 and typical MFT record size boundaries to probe NTFS partition size validation" },
      { "field": "version",     "mutation": "overflow",          "weight": 2, "description": "Overflow the version field to test handling of unrecognized NTFS versions in Windows and third-party drivers" },
      { "field": "fileSize",    "mutation": "random_bytes",      "weight": 1, "description": "Randomize fileSize to simulate corrupted BPB and test recovery tool resilience during volume size calculations" },
      { "field": "version",     "mutation": "bit_flip", "rate": 0.001, "weight": 1, "description": "Single-bit flips in version bytes to expose near-boundary version handling in chkdsk and ntfsfix" }
    ]
  },
  "migration": [
    {
      "from": "NTFS-v1.2",
      "to": "NTFS-v3.1",
      "description": "NTFS v1.2 (Windows NT 4.0) to NTFS v3.1 (Windows XP/2003+) — adds support for sparse files, reparse points, per-file encryption (EFS), and 64-bit MFT entries",
      "changes": [
        { "field": "version", "changeType": "set_value", "value": "0301", "description": "Update NTFS version bytes at BPB offset 0x3D-0x3E from 1.2 to 3.1 to indicate modern NTFS feature support" }
      ]
    }
  ]
}



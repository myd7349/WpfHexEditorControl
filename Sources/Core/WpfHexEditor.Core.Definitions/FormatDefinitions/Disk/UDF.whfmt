{
  "diffMode": "binary",
  "formatName": "UDF Filesystem",
  "version": "1.0",
  "extensions": [".udf", ".iso", ".img"],
  "description": "Universal Disk Format (ISO 13346 / ECMA-167) filesystem used on DVD-Video, Blu-ray, DVD-RAM, and CD-RW. Identified by NSR02 or NSR03 Volume Recognition Sequence at sector 16 (offset 32768 for 2048-byte sectors). Coexists with ISO 9660.",
  "category": "Disk",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ECMA-167: Volume and File Structure for Write-Once and Rewritable Media — 3rd Edition",
      "OSTA UDF Specification 2.60",
      "ISO 13346 — Volume and file structure for write-once and rewritable media"
    ],
    "WebLinks": [
      "http://www.osta.org/specs/index.htm",
      "https://en.wikipedia.org/wiki/Universal_Disk_Format",
      "https://ecma-international.org/publications-and-standards/standards/ecma-167/"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "4E53523032",
        "offset": 32768,
        "label": "'NSR02' — UDF 1.50/2.00 Volume Recognition Sequence at sector 16 (offset 32768 for 2048B sectors)",
        "weight": 1.0
      },
      {
        "value": "4E53523033",
        "offset": 32768,
        "label": "'NSR03' — UDF 2.01+ Volume Recognition Sequence at sector 16",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 1.0, "max": 7.5 },
    "validation": {
      "minFileSize": 32780,
      "maxSignatureOffset": 32773
    }
  },
  "variables": {
    "udfVrsType": 0,
    "udfStdId": "",
    "udfVersion": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "VRS Descriptor Type",
      "offset": 32761,
      "length": 1,
      "color": "#808080",
      "opacity": 0.2,
      "description": "Volume Structure Descriptor type byte at the start of the Volume Recognition Sequence descriptor at sector 16. Must be 0 for all Volume Structure Descriptors (BEA01, NSR02, NSR03, TEA01). Any non-zero value indicates a non-UDF or corrupted VRS.",
      "storeAs": "udfVrsType",
      "valueType": "uint8",
      "endianness": "little"
    },
    {
      "type": "signature",
      "name": "Standard Identifier",
      "offset": 32762,
      "length": 5,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "'NSR02' or 'NSR03' — 5-byte ECMA-167 standard identifier in the Volume Recognition Sequence at sector 16. NSR02 = UDF 1.50 or 2.00 (OSTA UDF revisions ≤ 2.00). NSR03 = UDF 2.01 through 2.60. This is the definitive UDF identifier within the ISO 9660 VRS framework.",
      "storeAs": "udfStdId",
      "valueType": "ascii",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "VRS Version",
      "offset": 32767,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Volume Recognition Sequence descriptor version. Must be 1 for all current ECMA-167 Volume Structure Descriptors. Stored at offset 7 within the 8-byte VRS descriptor (relative to sector 16 start at offset 32761).",
      "storeAs": "udfVersion",
      "valueType": "uint8",
      "endianness": "little"
    }
  ],
  "assertions": [
    {
      "name": "NSR standard ID valid",
      "expression": "udfStdId == 'NSR02' || udfStdId == 'NSR03'",
      "severity": "error",
      "message": "UDF Standard Identifier is not 'NSR02' or 'NSR03' at sector 16 — not a valid UDF volume"
    },
    {
      "name": "VRS type is zero",
      "expression": "udfVrsType == 0",
      "severity": "error",
      "message": "VRS descriptor type is not 0 — ECMA-167 requires type=0 for Volume Structure Descriptors"
    },
    {
      "name": "VRS version is 1",
      "expression": "udfVersion == 1",
      "severity": "warning",
      "message": "VRS version is not 1 — non-standard or future ECMA-167 revision detected"
    }
  ],
  "navigation": [
    {
      "name": "Volume Recognition Sequence",
      "offset": 32768,
      "icon": "\uE8B7",
      "color": "#FF6B6B"
    },
    {
      "name": "AVDP (Anchor VDP)",
      "offset": 524288,
      "icon": "\uE8A5",
      "color": "#4ECDC4"
    }
  ],
  "inspector": {
    "badge": "udfStdId",
    "primaryField": "udfVersion",
    "showQualityScore": true,
    "groups": [
      {
        "title": "UDF Recognition",
        "icon": "\uE8B7",
        "fields": ["udfVrsType", "udfStdId", "udfVersion"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "UDF VRS (JSON)",
      "format": "json",
      "fields": ["udfVrsType", "udfStdId", "udfVersion"]
    },
    {
      "name": "UDF VRS (text)",
      "format": "text",
      "fields": ["udfStdId", "udfVersion"]
    }
  ],
  "forensic": {
    "category": "disk",
    "riskLevel": "low",
    "suspiciousPatterns": [],
    "knownExploitVectors": [
      "UDF parsing vulnerabilities in kernel drivers (historical CVEs in Linux and Windows UDF drivers)",
      "Malformed UDF structures causing buffer overflows during automount"
    ]
  },
  "aiHints": {
    "analysisContext": "UDF VRS is at sector 16. For 2048B sectors: offset 32768. Anchor VDP (AVDP) at sector 256 (offset 524288). Contains pointers to Main VDS and Reserve VDS. Partition Descriptor + Logical Volume Descriptor + File Set Descriptor chain leads to files. UDF coexists with ISO 9660 on DVD-Video and Blu-ray.",
    "suggestedInspections": [
      "Check both NSR02 and NSR03 identifiers — some discs have both for backward compatibility",
      "Read Anchor VDP at offset 524288 (sector 256) to locate Main Volume Descriptor Sequence",
      "Verify ECMA-167 sector size (2048 bytes for optical, 512 bytes for hard disk UDF)",
      "Look for BEA01 and TEA01 extent markers at sectors 14 and 18 (Extended Area Descriptor)",
      "On DVD-Video, check for VIDEO_TS directory in UDF file system for content identification"
    ]
  },
  "software": ["mkudffs", "udftools", "ImgBurn", "Nero", "macOS (native)", "Windows (native DVD support)"],
  "formatRelationships": {
    "category": "Disk",
    "extensions": [".udf", ".iso", ".img"],
    "relatedFormats": ["ISO9660", "HFS_PLUS", "JOLIET", "DVD_VIDEO"]
  },
  "MimeTypes": ["application/x-udf", "application/x-iso9660-image"],
  "UseCases": [
    "DVD-Video and Blu-ray disc filesystem",
    "DVD-RAM and CD-RW rewritable media",
    "Optical disc mastering and archival",
    "Windows DVD burning (Vista and later uses UDF 2.50)"
  ],
  "TechnicalDetails": {
    "Standard": "ECMA-167 / ISO 13346 / OSTA UDF",
    "VRSLocation": "Sector 16 (offset 32768 for 2048B sectors)",
    "UDFRevisions": "1.02, 1.50, 2.00, 2.01, 2.50, 2.60",
    "NSR02Covers": "UDF 1.50 and 2.00",
    "NSR03Covers": "UDF 2.01 through 2.60",
    "AVDPLocation": "Sector 256 (or last sector - 256)",
    "CoexistsWithISO9660": true
  },
  "QualityMetrics": {

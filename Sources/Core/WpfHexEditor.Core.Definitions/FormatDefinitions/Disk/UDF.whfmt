{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "Universal Disk Format",
  "formatId": "UDF",
  "version": "1.0",
  "diffMode": "binary",
  "extensions": [
    ".udf",
    ".iso",
    ".img"
  ],
  "description": "UDF (Universal Disk Format, ECMA-167) is used on optical media such as DVD and Blu-ray. The Volume Recognition Sequence (VRS) at byte offset 32768 contains the identifier 'NSR02' for UDF 1.x or 'NSR03' for UDF 2.x.",
  "category": "Disk",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "MimeTypes": [
    "application/x-iso9660-image",
    "application/octet-stream"
  ],
  "UseCases": [
    "DVD and Blu-ray optical disc filesystem",
    "Packet-writing for rewritable optical media",
    "Cross-platform disc image distribution"
  ],
  "references": [
    "https://www.ecma-international.org/publications-and-standards/standards/ecma-167/",
    "https://www.osta.org/specs/index.htm"
  ],
  "software": [
    {
      "name": "mkudffs",
      "url": "https://github.com/pali/udftools",
      "role": "Linux UDF formatter"
    },
    {
      "name": "ImgBurn",
      "url": "https://www.imgburn.com/",
      "role": "Windows optical disc burning"
    },
    {
      "name": "The Sleuth Kit",
      "url": "https://www.sleuthkit.org/",
      "role": "Forensic toolkit with UDF analysis"
    }
  ],
  "formatRelationships": [
    {
      "format": "ISO9660",
      "relationship": "UDF often coexists with ISO 9660 on optical discs for backward compatibility"
    },
    {
      "format": "HFS+",
      "relationship": "Hybrid discs may include HFS+ volume for macOS compatibility"
    }
  ],
  "detection": {
    "signatures": [
      {
        "offset": 32768,
        "value": "4E53523032",
        "label": "'NSR02' UDF 1.x Volume Recognition Sequence",
        "weight": 1.0
      },
      {
        "offset": 32768,
        "value": "4E53523033",
        "label": "'NSR03' UDF 2.x Volume Recognition Sequence",
        "weight": 0.9
      }
    ],
    "matchMode": "any",
    "MinimumScore": 82,
    "Strength": "Strong",
    "EntropyHint": {
      "min": 3.0,
      "max": 8.0,
      "note": "System area before VRS has low entropy"
    },
    "validation": "5 bytes at offset 32768 must be 'NSR02' or 'NSR03'. System area (0-32767) should be zeros or ISO 9660 VDs."
  },
  "variables": [
    {
      "name": "udfVrsIdent",
      "type": "ascii",
      "offset": 32768,
      "length": 5,
      "description": "VRS identifier: 'NSR02' or 'NSR03'"
    },
    {
      "name": "udfStructType",
      "type": "uint8",
      "offset": 32773,
      "length": 1,
      "description": "Volume structure descriptor type"
    }
  ],
  "blocks": [
    {
      "name": "SystemArea",
      "offset": 0,
      "length": 32768,
      "description": "System area (16 sectors at 2048 B each): may contain ISO 9660 VDs or zeros"
    },
    {
      "name": "VRS",
      "offset": 32768,
      "length": 2048,
      "description": "Volume Recognition Sequence at sector 16",
      "fields": [
        {
          "name": "VrsIdent",
          "variable": "udfVrsIdent",
          "offset": 0,
          "length": 5
        },
        {
          "name": "StructType",
          "variable": "udfStructType",
          "offset": 5,
          "length": 1
        }
      ]
    },
    {
      "name": "VDS1",
      "offset": -1,
      "length": -1,
      "description": "Main Volume Descriptor Sequence: partition, logical volume, terminating descriptors"
    },
    {
      "name": "FileSetDescriptor",
      "offset": -1,
      "length": -1,
      "description": "File Set Descriptor pointing to root directory ICB"
    }
  ],
  "assertions": [
    {
      "id": "A1",
      "description": "VRS identifier must start with 'NSR0'",
      "expression": "udfVrsIdent starts with 'NSR0'"
    },
    {
      "id": "A2",
      "description": "VRS version must be '2' or '3'",
      "expression": "udfVrsIdent[4] == '2' || udfVrsIdent[4] == '3'"
    },
    {
      "id": "A3",
      "description": "udfStructType must be a valid byte value",
      "expression": "udfStructType >= 0"
    }
  ],
  "navigation": {
    "entryPoint": "VRS",
    "structure": [
      "SystemArea",
      "VRS",
      "VDS1",
      "FileSetDescriptor"
    ],
    "notes": "AVDP (Anchor Volume Descriptor Pointer) at sector 256 points to main and reserve VDS. UDF sector size is typically 2048 bytes."
  },
  "inspector": {
    "badge": "UDF",
    "primaryField": "udfVrsIdent",
    "groups": [
      {
        "name": "Volume Recognition",
        "fields": [
          "udfVrsIdent",
          "udfStructType"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "VRS Summary CSV",
      "format": "csv",
      "fields": [
        "udfVrsIdent",
        "udfStructType"
      ]
    },
    {
      "name": "VRS JSON",
      "format": "json",
      "fields": [
        "udfVrsIdent",
        "udfStructType"
      ]
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "notes": "Hybrid ISO9660+UDF images may expose different file content per filesystem driver, enabling steganographic hiding.",
    "suspiciousPatterns": [
      "Discrepancy between ISO9660 and UDF directory trees on a hybrid disc",
      "Non-zero system area containing unexpected data before the VRS",
      "Logical volume integrity descriptor flagging open (unmounted) state",
      "Invalid partition descriptor start/length values"
    ]
  },
  "aiHints": {
    "analysisContext": "UDF uses ECMA-167 structures: AVDP, VDS, LVD, FSD, and ICBs. Key structures located via sector offsets. All multi-byte values use mixed endianness per ECMA-167.",
    "suggestedInspections": [
      "Locate AVDP at sector 256 and extract Main VDS location to find partition and logical volume descriptors",
      "Parse Logical Volume Descriptor to identify partition map type (Type 1 simple, Type 2 virtual/sparable)",
      "Follow File Set Descriptor root ICB to enumerate root directory and subdirectories",
      "Check Logical Volume Integrity Descriptor for open/close state and recorded file count",
      "On hybrid discs compare ISO9660 directory tree with UDF directory tree for hidden content"
    ]
  },
  "TechnicalDetails": {
    "endianness": "Mixed per ECMA-167",
    "vrsOffset": 32768,
    "sectorSize": 2048,
    "avdpSector": 256,
    "ecmaStandard": "ECMA-167 3rd edition"
  },
  "QualityMetrics": {
    "CompletenessScore": 85,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  }
}



{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v3.2.json",
  "diffMode": "binary",
  "formatName": "Apache Parquet",
  "formatId": "PARQUET",
  "version": "1.0.1",
  "extensions": [".parquet", ".pq"],
  "description": "Apache Parquet is an open-source columnar storage format optimized for analytical workloads. Files begin with the 4-byte magic 'PAR1' (0x50415231) at offset 0 and also end with the same 4-byte magic at EOF-4, sandwiching a Thrift-encoded footer containing schema and row group metadata. The columnar layout enables high compression ratios and efficient predicate pushdown. Supports nested data via Dremel encoding.",
  "category": "Data",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://parquet.apache.org/docs/file-format/",
    "https://github.com/apache/parquet-format",
    "https://en.wikipedia.org/wiki/Apache_Parquet"
  ],
  "detection": {
    "signatures": [
      {
        "value": "50415231",
        "offset": 0,
        "label": "'PAR1' header magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.9,
    "Strength": "Strong",
    "EntropyHint": {
      "min": 4.0,
      "max": 8.0,
      "note": "Entropy varies widely depending on compression codec (SNAPPY/GZIP/ZSTD/LZ4)"
    },
    "validation": {
      "rules": [
        { "field": "parquetMagic", "operator": "equals", "value": "PAR1" }
      ]
    }
  },
  "variables": [
    {
      "name": "parquetMagic",
      "offset": 0,
      "size": 4,
      "type": "ascii",
      "storeAs": "parquetMagic",
      "description": "Header magic 'PAR1' at offset 0"
    },
    {
      "name": "firstDataByte",
      "offset": 4,
      "size": 1,
      "type": "uint8",
      "storeAs": "parquetFirstDataByte",
      "description": "First byte of first row group data region"
    },
    {
      "name": "footerLength",
      "offset": -8,
      "size": 4,
      "type": "uint32",
      "endian": "LE",
      "storeAs": "parquetFooterLength",
      "description": "Byte length of the Thrift-encoded FileMetaData footer (at EOF-8)"
    },
    {
      "name": "footerMagic",
      "offset": -4,
      "size": 4,
      "type": "ascii",
      "storeAs": "parquetFooterMagic",
      "description": "Duplicate 'PAR1' at EOF-4 confirming valid file termination"
    }
  ],
  "blocks": [
    {
      "name": "HeaderMagic",
      "offset": 0,
      "size": 4,
      "description": "ASCII 'PAR1' header magic identifying a Parquet file",
      "fields": [
        { "name": "Magic", "offset": 0, "size": 4, "type": "ascii" }
      ]
    },
    {
      "name": "RowGroupData",
      "offset": 4,
      "size": -1,
      "description": "One or more row groups containing column chunks with data pages",
      "fields": []
    },
    {
      "name": "FooterLength",
      "offset": -8,
      "size": 4,
      "description": "4-byte LE int32: byte length of the Thrift FileMetaData footer",
      "fields": [
        { "name": "FooterByteLength", "offset": -8, "size": 4, "type": "uint32", "endian": "LE" }
      ]
    },
    {
      "name": "FooterMagic",
      "offset": -4,
      "size": 4,
      "description": "Trailing 'PAR1' magic confirming file is complete",
      "fields": [
        { "name": "TrailingMagic", "offset": -4, "size": 4, "type": "ascii" }
      ]
    }
  ],
  "assertions": [
    {
      "id": "assert_header_magic",
      "field": "parquetMagic",
      "operator": "equals",
      "value": "PAR1",
      "severity": "error",
      "message": "Header magic must be 'PAR1' at offset 0"
    },
    {
      "id": "assert_footer_magic",
      "field": "parquetFooterMagic",
      "operator": "equals",
      "value": "PAR1",
      "severity": "error",
      "message": "Footer magic must be 'PAR1' at EOF-4; truncated or invalid file if absent"
    },
    {
      "id": "assert_footer_length_positive",
      "field": "parquetFooterLength",
      "operator": "greaterThan",
      "value": 0,
      "severity": "error",
      "message": "Footer length at EOF-8 must be greater than 0"
    }
  ],
  "navigation": {
    "entryPoints": [
      { "name": "Header Magic", "offset": 0 },
      { "name": "Row Group Data", "offset": 4 },
      { "name": "Footer (from pointer)", "offsetFrom": "parquetFooterLength" }
    ],
    "jumpTable": [
      { "label": "Header PAR1", "offset": 0 },
      { "label": "Footer Length (EOF-8)", "offset": -8 },
      { "label": "Footer Magic (EOF-4)", "offset": -4 }
    ]
  },
  "inspector": {
    "badge": "PQ",
    "primaryField": "parquetMagic",
    "groups": [
      {
        "name": "Identification",
        "fields": ["parquetMagic", "parquetFooterMagic"]
      },
      {
        "name": "Footer",
        "fields": ["parquetFooterLength"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Parquet File Summary",
      "format": "text",
      "template": "Apache Parquet File\nHeader Magic : {parquetMagic}\nFooter Magic : {parquetFooterMagic}\nFooter Length: {parquetFooterLength} bytes"
    },
    {
      "name": "Parquet Header CSV",
      "format": "csv",
      "template": "Field,Value\nHeaderMagic,{parquetMagic}\nFooterMagic,{parquetFooterMagic}\nFooterLength,{parquetFooterLength}"
    }
  ],
  "forensic": {
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Footer magic missing (EOF-4 != 'PAR1') — file truncated or tampered",
      "Footer length exceeds file size — corrupted footer pointer",
      "Unexpected column metadata in footer — possible data exfiltration encoding",
      "Nested schema depth > 16 — possible parser complexity attack"
    ]
  },
  "aiHints": {
    "analysisContext": "Parquet files have 'PAR1' magic at both offset 0 and EOF-4. The footer length (int32 LE) at EOF-8 indicates where the Thrift-encoded FileMetaData begins. The footer contains the full schema, row group offsets, and column statistics. Row group data lies between offset 4 and the footer start.",
    "suggestedInspections": [
      "Verify 'PAR1' at offset 0 and at EOF-4",
      "Read int32 LE at EOF-8 for footer byte length",
      "Navigate to file_size - 8 - footerLength to find Thrift FileMetaData start",
      "Parse Thrift FileMetaData for schema (Dremel nested), row group count, and total rows",
      "Inspect compression codec per column chunk (SNAPPY, GZIP, LZ4, ZSTD, BROTLI)",
      "Check column statistics (min/max/null_count) for data profiling"
    ]
  },
  "software": [
    { "name": "Apache Spark", "vendor": "Apache", "platform": "Cross-platform" },
    { "name": "DuckDB", "vendor": "DuckDB Labs", "platform": "Cross-platform" },
    { "name": "Apache Arrow / pyarrow", "vendor": "Apache", "platform": "Cross-platform" }
  ],
  "formatRelationships": [
    { "format": "AVRO", "relation": "sibling", "note": "Avro is row-oriented; Parquet is columnar" },
    { "format": "ORC", "relation": "sibling", "note": "ORC is an alternative columnar format in the Hadoop ecosystem" },
    { "format": "ARROW_IPC", "relation": "related", "note": "Apache Arrow provides in-memory columnar format; Parquet is the disk format" }
  ],
  "MimeTypes": [
    "application/octet-stream",
    "application/vnd.apache.parquet"
  ],
  "UseCases": [
    "Big data analytics and data lakehouse storage",
    "ETL pipeline intermediate format",
    "Machine learning training dataset storage",
    "Cloud data warehouse (AWS Athena, BigQuery, Snowflake)"
  ],
  "serializationProfile": {
    "schemaLanguage": "Apache Thrift schema",
    "selfDescribing": true,
    "payloadCompression": "snappy,gzip,lzo,brotli,zstd,lz4",
    "wireCompatibleFormats": ["ARROW_IPC", "ORC", "AVRO", "FEATHER"],
    "streamable": false
  },
  "QualityMetrics": {
    "CompletenessScore": 85,
    "LastUpdated": "2026-04-15"
  },
  "TechnicalDetails": {
    "headerSize": 4,
    "endian": "little",
    "signatureOffset": 0,
    "signatureLength": 4,
    "magicValue": "PAR1",
    "footerEncoding": "Apache Thrift compact protocol",
    "columnCompression": ["SNAPPY", "GZIP", "LZ4", "ZSTD", "BROTLI", "NONE"],
    "schemaEncoding": "Dremel nested columnar (repetition + definition levels)",
    "notes": "Both header magic at offset 0 and footer magic at EOF-4 must be 'PAR1'. Footer length (int32 LE) at EOF-8 locates the Thrift FileMetaData."
  }
}




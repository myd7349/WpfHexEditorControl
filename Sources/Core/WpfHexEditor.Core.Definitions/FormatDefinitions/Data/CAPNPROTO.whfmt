{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v3.2.json",
  "diffMode": "binary",
  "formatName": "Cap'n Proto Binary Message",
  "formatId": "CAPNPROTO",
  "version": "1.0",
  "extensions": [".capnp", ".bin"],
  "description": "Cap'n Proto binary serialization format (Kenton Varda, 2013). No magic bytes. A message starts with a uint32 LE segment_count (value = number of segments minus 1) at offset 0, then one uint32 LE size entry per segment (in 8-byte words), optional 4-byte padding to reach 8-byte alignment, then the segment data. The first word of segment 0 is the root struct pointer. Struct pointer: low 32 bits = signed word offset (type bits=00), high 32 bits = (data_word_count<<16)|pointer_word_count. Zero-copy: data is accessed directly from wire format without deserialization. Used in IPFS Bitswap, Sandstorm.io, Cloudflare Workers KV, and high-performance microservices.",
  "category": "Data",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://capnproto.org/encoding.html",
    "https://capnproto.org/language.html",
    "https://github.com/capnproto/capnproto",
    "https://en.wikipedia.org/wiki/Cap%27n_Proto"
  ],
  "detection": {
    "signatures": [
      {
        "value": "00000000",
        "offset": 0,
        "label": "Segment count = 0 (single-segment message — most common)",
        "weight": 0.3
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.2,
    "Strength": "Weak",
    "validation": {
      "rules": [
        { "field": "capnpSegmentCount", "operator": "lessThan", "value": 512, "severity": "warning" },
        { "field": "capnpSeg0Size", "operator": "greaterThan", "value": 0, "severity": "error" }
      ]
    }
  },
  "variables": [
    {
      "name": "capnpSegmentCount",
      "offset": 0,
      "size": 4,
      "type": "uint32",
      "endian": "LE",
      "storeAs": "capnpSegmentCount",
      "description": "Number of segments minus 1. Value 0 = single-segment message (most common)."
    },
    {
      "name": "capnpSeg0Size",
      "offset": 4,
      "size": 4,
      "type": "uint32",
      "endian": "LE",
      "storeAs": "capnpSeg0Size",
      "description": "Size of first segment in 64-bit words (multiply by 8 for bytes)"
    }
  ],
  "blocks": [
    {
      "name": "SegmentTable",
      "offset": 0,
      "size": 8,
      "description": "Segment table header: uint32 LE segment_count_minus_1, then uint32 LE size per segment (in words), then optional 4B padding for 8-byte alignment",
      "fields": [
        { "name": "SegmentCountMinus1", "offset": 0, "size": 4, "type": "uint32", "endian": "LE" },
        { "name": "Segment0SizeWords", "offset": 4, "size": 4, "type": "uint32", "endian": "LE" }
      ]
    },
    {
      "name": "RootStructPointer",
      "offset": 8,
      "size": 8,
      "description": "First 8-byte word of segment 0 is the root struct pointer. Low 32 bits: pointer type (bits 1-0=00 for struct) and signed word offset to struct data. High 32 bits: (data_word_count<<16) | pointer_word_count.",
      "fields": [
        { "name": "RootPointerLow", "offset": 8, "size": 4, "type": "uint32", "endian": "LE" },
        { "name": "RootPointerHigh", "offset": 12, "size": 4, "type": "uint32", "endian": "LE" }
      ]
    },
    {
      "name": "PointerTypeGuide",
      "offset": 0,
      "size": 0,
      "description": "Pointer types (low 2 bits of pointer word): 00=struct, 01=list, 10=inter-segment far pointer, 11=capability. Zero pointer (0x0000000000000000) = null. Struct pointer upper half: bits 31-16=data_word_count, bits 15-0=pointer_word_count.",
      "fields": []
    },
    {
      "name": "SegmentData",
      "offset": 8,
      "size": -1,
      "description": "Segment 0 data starting at offset 8 (for single-segment messages): capnpSeg0Size * 8 bytes of 8-byte-aligned word data",
      "fields": []
    }
  ],
  "assertions": [
    {
      "id": "assert_segment_count_sane",
      "field": "capnpSegmentCount",
      "operator": "lessThan",
      "value": 512,
      "severity": "warning",
      "message": "Segment count >= 512 is abnormal — likely not Cap'n Proto or a crafted message causing parser exhaustion"
    },
    {
      "id": "assert_seg0_size_positive",
      "field": "capnpSeg0Size",
      "operator": "greaterThan",
      "value": 0,
      "severity": "error",
      "message": "First segment size must be > 0 words"
    },
    {
      "id": "assert_size_consistent",
      "type": "info",
      "severity": "info",
      "message": "For a single-segment message: expected file size = 8 + capnpSeg0Size * 8 bytes"
    }
  ],
  "navigation": {
    "entryPoints": [
      { "name": "Segment Table", "offset": 0 },
      { "name": "Root Struct Pointer (Segment 0)", "offset": 8 }
    ],
    "jumpTable": [
      { "label": "Segment Count Minus 1", "offset": 0 },
      { "label": "Segment 0 Size (words)", "offset": 4 },
      { "label": "Root Struct Pointer", "offset": 8 }
    ]
  },
  "inspector": {
    "badge": "CP",
    "primaryField": "capnpSeg0Size",
    "groups": [
      {
        "name": "Segment Table",
        "fields": ["capnpSegmentCount", "capnpSeg0Size"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Cap'n Proto Segment Table Summary",
      "format": "text",
      "template": "Cap'n Proto Message\nSegment Count (actual): {capnpSegmentCount} + 1\nSegment 0 Size        : {capnpSeg0Size} words ({capnpSeg0Size} * 8 bytes)"
    },
    {
      "name": "Cap'n Proto Header CSV",
      "format": "csv",
      "template": "Field,Value\nSegmentCountMinus1,{capnpSegmentCount}\nSegment0SizeWords,{capnpSeg0Size}"
    }
  ],
  "forensic": {
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Segment count >= 512 — possible parser heap exhaustion via large segment table",
      "First segment size * 8 exceeds file size — truncated or malformed message",
      "Inter-segment far pointers (type=10) pointing outside segment bounds — possible read-beyond attack",
      "Capability pointer (type=11) outside expected RPC context — unexpected privilege escalation attempt"
    ]
  },
  "aiHints": {
    "analysisContext": "Cap'n Proto binary framing: [segment_count-1: uint32 LE] + [segment_0_size_words: uint32 LE] + ... + optional 4B padding + [segment 0 data: size*8 bytes] + .... First word of segment 0 is the root struct pointer. Pointer types (low 2 bits): 00=struct, 01=list, 10=far, 11=cap. Use 'capnp decode schema.capnp TypeName < file.bin' for inspection with schema.",
    "suggestedInspections": [
      "Read segmentCount (uint32 LE at offset 0): value 0 means single-segment message",
      "Read first segment size (uint32 LE at offset 4) in words; multiply by 8 for bytes",
      "Verify: segmentCount < 512 and seg0Size * 8 <= remaining file size",
      "Parse root struct pointer at offset 8: low bits type (should be 00=struct), high 32 bits = data/pointer word counts",
      "Use capnp CLI: 'capnp decode schema.capnp RootType < file.bin' to fully decode with schema",
      "Check for multi-segment messages: segment table has capnpSegmentCount+1 uint32 size entries"
    ]
  },
  "software": [
    { "name": "capnp CLI", "vendor": "capnproto.org", "platform": "Cross-platform" },
    { "name": "pycapnp", "vendor": "Open source", "platform": "Python" },
    { "name": "go-capnp", "vendor": "capnproto/go-capnp", "platform": "Go" }
  ],
  "formatRelationships": [
    { "format": "FLATBUF", "relation": "sibling", "note": "FlatBuffers is also zero-copy but has a different framing and no RPC support" },
    { "format": "PROTOBUF", "relation": "alternative", "note": "Protocol Buffers requires full deserialization; Cap'n Proto accesses data zero-copy" }
  ],
  "MimeTypes": [
    "application/octet-stream",
    "application/x-capnproto"
  ],
  "UseCases": [
    "High-performance microservice IPC without deserialization overhead",
    "IPFS Bitswap protocol message encoding",
    "Sandstorm.io application platform inter-process communication",
    "Cloudflare Workers KV value storage"
  ],
  "serializationProfile": {
    "schemaLanguage": "Cap'n Proto schema (.capnp)",
    "selfDescribing": false,
    "payloadCompression": null,
    "wireCompatibleFormats": ["FLATBUF", "PROTOBUF"],
    "streamable": true
  },
  "QualityMetrics": {
    "CompletenessScore": 84,
    "LastUpdated": "2026-04-15"
  },
  "TechnicalDetails": {
    "headerSize": 8,
    "endian": "little",
    "magic": "none",
    "framing": "uint32 segment_count-1 + uint32[] segment_size_words + 8B-aligned segment data",
    "pointerTypes": {
      "0": "struct pointer",
      "1": "list pointer",
      "2": "inter-segment far pointer",
      "3": "capability pointer (RPC)"
    },
    "zeroCopySupport": true,
    "rpcSupport": true,
    "notes": "For a single-segment message: file = 8 bytes segment table + seg0_size*8 bytes data. Root struct pointer is always at byte offset 8. capnpSegmentCount value 0 = one segment."
  }
}




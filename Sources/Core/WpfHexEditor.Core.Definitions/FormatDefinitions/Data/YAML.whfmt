{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v3.2.json",
  "diffMode": "semantic",
  "formatName": "YAML",
  "formatId": "YAML",
  "version": "2.5",
  "extensions": [
    ".yaml",
    ".yml"
  ],
  "description": "YAML Ain't Markup Language data serialization",
  "category": "Data",
  "author": "WPFHexaEditor Team",
  "lastUpdated": "2026-05-20",
  "preferredEditor": "code-editor",
  "references": {
    "specifications": [
      "YAML 1.2 Specification",
      "YAML 1.1 Specification (Ansible/Docker compatible)"
    ],
    "WebLinks": [
      "https://yaml.org/spec/1.2-old/spec.html",
      "https://yaml.org/",
      "https://en.wikipedia.org/wiki/YAML"
    ]
  },
  "signatures": [
    {
      "value": "2D2D2D",
      "offset": 0,
      "label": "YAML document start marker '---'",
      "weight": 0.7,
      "strength": "Medium"
    },
    {
      "value": "25594D4C",
      "offset": 0,
      "label": "YAML directive '%YML'",
      "weight": 0.6,
      "strength": "Medium"
    }
  ],
  "maxSignatureOffset": 4,
  "structure": {
    "fields": [
      { "name": "first_bytes",    "type": "bytes", "offset": "0x00", "length": 3, "description": "First 3 bytes: '---' = document start, '%YA' = directive, or key character" },
      { "name": "file_content",   "type": "bytes", "offset": "0x03", "length": 8, "description": "UTF-8 YAML content" }
    ]
  },
  "inspector": {
    "displayFields": ["first_bytes"],
    "valueMaps": {
      "document_markers": {
        "2D2D2D": "--- (document start)",
        "2E2E2E": "... (document end)",
        "25594D4C": "%YAML directive",
        "2D20": "- (sequence item at root)"
      }
    },
    "tooltips": {
      "first_bytes": "YAML is UTF-8 text; '---' starts a document, '...' ends it; multiple documents can appear in one file",
      "file_content": "YAML structure: indentation-based nesting, ':' separates keys from values, '-' marks sequence items"
    }
  },
  "assertions": [
    {
      "name": "File is valid UTF-8",
      "expression": "encoding == UTF-8",
      "severity": "error",
      "message": "YAML files must be valid UTF-8 (or UTF-16/UTF-32 with BOM per spec, though UTF-8 is standard)"
    },
    {
      "name": "File is not empty",
      "expression": "fileSize > 0",
      "severity": "info",
      "message": "YAML file is empty; an empty file is valid YAML (represents null document)"
    },
    {
      "name": "Document separator present",
      "expression": "bytes[0..2] == 2D2D2D || fileSize > 0",
      "severity": "info",
      "message": "YAML document separator '---' not present at start; single implicit document assumed"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "Document Start", "offset": 0, "icon": "", "color": "#CB4B16" }
    ]
  },
  "exportTemplates": [
    {
      "name": "YAML Content (JSON representation)",
      "format": "json",
      "fields": ["file_content"]
    },
    {
      "name": "YAML Raw Text",
      "format": "text",
      "fields": ["file_content"]
    }
  ],
  "aiHints": [
    "YAML is a UTF-8 text format with no binary magic; identified by '---' document marker or content heuristics",
    "YAML 1.1 (used by Ansible/Docker) interprets 'yes'/'no'/'on'/'off' as booleans; YAML 1.2 does not",
    "Multi-document YAML files use '---' to separate documents and optional '...' to end each document",
    "Anchors (&name) and aliases (*name) allow reference sharing; circular references are valid in YAML 1.2",
    "Block scalars: '|' preserves newlines (literal), '>' folds newlines (folded); both preserve trailing newlines"
  ],
  "variables": {
    "currentOffset": 0,
    "machineType": "",
    "sectionCount": 0,
    "timestamp": 0,
    "entryPoint": 0
  },
  "blocks": [
    {
      "type": "data",
      "name": "YAML Data",
      "offset": 0,
      "length": 256,
      "color": "#CB4B16",
      "opacity": 0.4,
      "description": "YAML serialized data"
    },
    {
      "type": "metadata",
      "name": "Machine Type",
      "variable": "machineType",
      "description": "Machine Type"
    },
    {
      "type": "metadata",
      "name": "Section Count",
      "variable": "sectionCount",
      "description": "Section Count"
    },
    {
      "type": "metadata",
      "name": "Entry Point",
      "variable": "entryPoint",
      "description": "Entry Point"
    }
  ],
  "software": [
    "Docker Compose (docker-compose.yml)",
    "Kubernetes (manifest files)",
    "Ansible (playbooks and inventory)",
    "GitHub Actions / GitLab CI (workflow files)"
  ],
  "formatRelationships": [
    {
      "formatId": "TOML",
      "relation": "alternative",
      "note": "YAML and TOML are both human-readable configuration formats; YAML is more expressive, TOML is less ambiguous"
    }
  ],
  "useCases": [
    "Kubernetes and Docker Compose configuration manifests",
    "Ansible automation playbooks and inventory files",
    "CI/CD pipeline definition files (GitHub Actions, GitLab CI)",
    "Application configuration with complex nested structures"
  ],
  "technicalDetails": "YAML is a superset of JSON (YAML 1.2). Documents are UTF-8 text delimited by '---' and '...'. Indentation defines structure (spaces only, not tabs). Keys are unquoted strings followed by ': '. Sequences use '- ' prefix. YAML supports anchors, aliases, multiple documents per file, and custom type tags. Security: yaml.safe_load() is required to avoid arbitrary code execution.",
  "completenessScore": 80,
  "MimeTypes": [
    "application/x-yaml",
    "text/yaml"
  ],
  "Software": [
    "Text editors",
    "Docker",
    "Kubernetes",
    "Ansible"
  ],
  "UseCases": [
    "Configuration",
    "Docker Compose",
    "Kubernetes",
    "CI/CD"
  ],
  "serializationProfile": {
    "schemaLanguage": "JSON Schema / YAML schema",
    "selfDescribing": true,
    "payloadCompression": null,
    "wireCompatibleFormats": ["JSON", "TOML", "CSON"],
    "streamable": true
  },
  "QualityMetrics": {
    "CompletenessScore": 80,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 4,
    "ValidationRules": 0,
    "LastUpdated": "2026-05-20",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Encoding": "UTF-8 text (UTF-16/UTF-32 with BOM also allowed by spec)",
    "Standard": "YAML 1.2 (recommended); YAML 1.1 still common in older tooling"
  },
  "functions": {
    "readUInt32LE": "Read executable header",
    "calculateCRC32": "Validate"
  },
  "syntaxDefinition": {
    "id": "yaml",
    "name": "YAML / TOML",
    "extensions": [".yaml", ".yml", ".toml"],
    "lineCommentPrefix": "#",
    "rules": [
      { "type": "DocumentMark", "pattern": "^---\\s*$|^\\.\\.\\.\\s*$", "colorKey": "TE_Directive" },
      { "type": "Section", "pattern": "^\\[[^\\]]+\\]$", "colorKey": "TE_Keyword" },
      { "type": "Key", "pattern": "^\\s*[^:\\s#][^:\n]*(?=\\s*:)", "colorKey": "TE_Type" },
      { "type": "Anchor", "pattern": "&[A-Za-z][A-Za-z0-9_-]*|\\*[A-Za-z][A-Za-z0-9_-]*", "colorKey": "TE_Label" },
      { "type": "Tag", "pattern": "!!?[A-Za-z][A-Za-z0-9_/:-]*", "colorKey": "TE_Directive" },
      { "type": "Boolean", "pattern": "\\b(?i)(true|false|yes|no|on|off|null|~)\\b", "colorKey": "TE_Keyword" },
      { "type": "Number", "pattern": "\\b(0x[0-9A-Fa-f]+|0o[0-7]+|0b[01]+|[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?|\\.(inf|nan))\\b", "colorKey": "TE_Number" },
      { "type": "String", "pattern": "(\"(?:[^\"\\]|\\.)*\"|'[^']*')", "colorKey": "TE_String" },
      { "type": "ListItem", "pattern": "^\\s*-\\s", "colorKey": "TE_Operator" },
      { "type": "Comment", "pattern": "#.*$", "colorKey": "TE_Comment" }
    ],
    "formattingRules": {
      "indentSize": 2,
      "useTabs": false,
      "trimTrailingWhitespace": true,
      "insertFinalNewline": true,
      "supportedRules": ["trimTrailingWhitespace", "insertFinalNewline"]
    },
    "foldingRules": { "indentBased": true, "indentTabWidth": 2 },
    "ideMetadata": {
      "isSourceFile": false,
      "isStructuredDataFile": true,
      "supportsClassDiagram": false,
      "supportsSourceOutline": false,
      "isProjectLanguage": false,
      "aliases": ["yml"],
      "iconGlyph": "",
      "diffMode": "semantic"
    }
  },
  "forensic": {
    "riskLevel": "medium",
    "notes": [
      "yaml.load() with default Loader is a known arbitrary code execution vector in Python; use yaml.safe_load()",
      "YAML files often contain credentials, tokens, and connection strings in CI/CD and config files",
      "YAML 1.1 bool coercion ('yes'/'no') causes silent data corruption when migrating to YAML 1.2 parsers"
    ]
  }
}




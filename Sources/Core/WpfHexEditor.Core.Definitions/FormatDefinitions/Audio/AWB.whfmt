  "formatRelationships": {
    "category": "Audio",
    "extensions": [".awb"],
    "relatedFormats": ["AMR", "3GP", "GSM"],
    "note": "AMR-WB (.awb) is the wideband variant of AMR-NB (.amr). AMR-WB operates at 16000 Hz (wideband) vs AMR-NB at 8000 Hz (narrowband). AMR-WB frame header '#!AMR-WB\\n' (9 bytes) vs AMR-NB '#!AMR\\n' (6 bytes). AMR-WB is ITU-T G.722.2 and the basis for EVS (Enhanced Voice Services) in 5G."
  },

    "validation": {
      "minFileSize": 9,
      "maxSignatureOffset": 0
    }
  },
  "variables": {
    "amrWbHeader": "",
    "firstFrameToc": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "AMR-WB File Header",
      "offset": 0,
      "length": 9,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "AMR-WB storage format magic '#!AMR-WB\\n' (0x23 0x21 0x41 0x4D 0x52 0x2D 0x57 0x42 0x0A). This 9-byte sequence is the 3GPP-standardized header for AMR-WB single-channel audio storage. Distinguishes wideband AMR-WB (.awb) from narrowband AMR-NB ('#!AMR\\n', 6 bytes).",
      "storeAs": "amrWbHeader",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "First Frame TOC",
      "offset": 9,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "First AMR-WB frame Table of Contents (TOC) byte. Bits 7-4 encode the frame type (AMR-WB mode 0-8 for bitrates 6.6-23.85 kbps). Bit 3 is the quality flag (1=good frame). Bits 2-0 are padding zeros.",
      "storeAs": "firstFrameToc",
      "valueType": "uint8",
      "bitfields": [
        {
          "name": "Frame Type (Mode)",
          "bits": "7-4",
          "description": "AMR-WB codec mode determining bitrate",
          "valueMap": {
            "0": "Mode 0 — 6.60 kbps",
            "1": "Mode 1 — 8.85 kbps",
            "2": "Mode 2 — 12.65 kbps",
            "3": "Mode 3 — 14.25 kbps",
            "4": "Mode 4 — 15.85 kbps",
            "5": "Mode 5 — 18.25 kbps",
            "6": "Mode 6 — 19.85 kbps",
            "7": "Mode 7 — 23.05 kbps",
            "8": "Mode 8 — 23.85 kbps (highest quality)",
            "9": "SID — Silence Insertion Descriptor",
            "15": "NO_DATA — empty frame"
          }
        },
        {
          "name": "Quality Flag",
          "bits": "3",
          "description": "Frame quality: 1=good, 0=bad (error concealment applied)",
          "valueMap": {
            "0": "Bad frame",
            "1": "Good frame"
          }
        }
      ]
    },
    {
      "type": "metadata",
      "name": "AMR-WB Header",
      "variable": "amrWbHeader",
      "description": "'#!AMR-WB\\n' — AMR Wideband file magic"
    },
    {
      "type": "metadata",
      "name": "First Frame TOC",
      "variable": "firstFrameToc",
      "description": "First frame TOC byte (bits 7-4 = mode, bit 3 = quality)"
    }
  ],

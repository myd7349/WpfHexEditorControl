{
  "diffMode": "binary",
  "formatName": "AMR-WB Audio",
  "version": "1.15",
  "extensions": [
    ".awb"
  ],
  "description": "AMR-WB (Adaptive Multi-Rate Wideband) — a wideband speech codec standardized by 3GPP (TS 26.171) for 3G/4G mobile networks, also known as G.722.2. The .awb file format starts with the 9-byte header '#!AMR-WB\\n' (0x2321414D522D57420A). Frames follow: each has a 1-byte TOC (Table of Contents) header where bits 7-4 encode the mode (0-8 for 6.6-23.85 kbps), bit 3 = quality flag (1=good), bits 2-0 = padding zeros. AMR-WB uses 16000 Hz sample rate (wideband vs AMR-NB at 8000 Hz), with 20ms frames of 320 samples. AMR-WB is used for HD Voice (VoLTE) in 4G/LTE networks. Note: .awb files are identical in structure to AMR-WB files (.amr with AMR-WB content).",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "audio-viewer",
  "references": {
    "specifications": [
      "3GPP TS 26.171 — AMR-WB General Description",
      "3GPP TS 26.173 — AMR-WB Speech Codec C-Source Code",
      "ITU-T G.722.2 — AMR-WB",
      "RFC 4867 — RTP Payload Format for AMR and AMR-WB"
    ],
    "WebLinks": [
      "https://www.tech-invite.com/3m26/tinv-3gpp-26-171.html",
      "https://en.wikipedia.org/wiki/Adaptive_Multi-Rate_Wideband",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000255.shtml"
    ]
  },
  "detection": {
    "signature": "2321414D522D57420A",
    "offset": 0,
    "required": true,

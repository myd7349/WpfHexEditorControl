{
  "diffMode": "binary",
  "formatName": "AMR Audio",
  "version": "1.0",
  "extensions": [".amr", ".3ga"],
  "description": "Adaptive Multi-Rate (AMR) is a speech-optimized lossy audio codec standardized by 3GPP for mobile telephony and VoIP applications. Narrowband AMR (AMR-NB) files begin with the 6-byte ASCII magic '#!AMR' followed by a newline byte 0x0A. Wideband AMR (AMR-WB) files begin with '#!AMR-WB' followed by 0x0A. AMR operates on 20ms speech frames with 8 codec modes (4.75-12.2 kbps for NB; 6.6-23.85 kbps for WB). Each frame byte starts with a 4-bit frame type (FT) and a quality indicator bit (Q). AMR is ubiquitous in mobile voice recording and 3GPP multimedia files.",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": {
    "specifications": [
      "3GPP TS 26.101: Mandatory speech CODEC speech processing functions — AMR speech CODEC frame structure",
      "3GPP TS 26.201: Speech codec speech processing functions — AMR Wideband speech codec frame structure"
    ],
    "WebLinks": [
      "https://www.3gpp.org/technologies/keywords-acronyms/100-the-3gpp-umts-standards",
      "https://en.wikipedia.org/wiki/Adaptive_Multi-Rate_audio_codec"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "2321414D520A",
        "offset": 0,
        "label": "#!AMR\\n — AMR Narrowband file header magic",
        "weight": 1.0
      },
      {
        "value": "2321414D522D57420A",
        "offset": 0,
        "label": "#!AMR-WB\\n — AMR Wideband file header magic",
        "weight": 1.0
      }
    ],
    "matchMode": "Any",
    "MinimumScore": 0.9,
    "required": [],
    "Strength": "Strong",
    "EntropyHint": {
      "min": 3.5,
      "max": 7.0,
      "comment": "Speech codec data has moderate entropy due to mode switching"
    },
    "validation": {
      "notes": "Magic must be '#!AMR\\n' (NB) or '#!AMR-WB\\n' (WB) including the 0x0A newline terminator"
    }
  },
  "variables": {
    "amrMagic": "",
    "wbFlag": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "amrMagic",
      "offset": 0,
      "length": 6,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "AMR file header magic — ASCII '#!AMR' (5 bytes) plus newline 0x0A; for AMR-WB files the magic is '#!AMR-WB' (8 bytes) plus 0x0A, making the narrowband form 6 bytes and wideband 9 bytes",
      "storeAs": "amrMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "wbFlag",
      "offset": 6,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.75,
      "description": "Byte at offset 6 distinguishes AMR variants: for NB files this is the first frame byte (frame type in upper nibble); for WB files this continues the '-WB' magic string; inspect in context of magic prefix",
      "storeAs": "wbFlag",
      "valueType": "uint8"
    }
  ],
  "assertions": [
    {
      "field": "amrMagic",
      "op": "startsWith",
      "value": "#!AMR",
      "message": "AMR file must start with '#!AMR' ASCII magic"
    },
    {
      "field": "wbFlag",
      "op": "noteq",
      "value": 0,
      "message": "Byte at offset 6 must not be null for valid AMR frame data"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "AMR Magic", "offset": 0, "length": 6, "color": "#FF6B6B" },
      { "name": "First Frame / WB Flag", "offset": 6, "length": 1, "color": "#4ECDC4" }
    ]
  },

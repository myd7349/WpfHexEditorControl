    },
    {
      "name": "AMR JSON Report",
      "format": "json",
      "template": "{ \"magic\": \"{amrMagic}\", \"wbFlag\": {wbFlag} }"
    }
  ],
  "forensic": {
    "category": "Audio",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Missing 0x0A newline terminator after '#!AMR' magic indicates malformed file",
      "Frame type nibble value 0xF (NO_DATA frame) throughout file indicates silent/tampered recording",
      "Quality indicator bit Q=0 on multiple frames indicates transmission errors in the original"
    ]
  },
  "aiHints": {
    "analysisContext": "AMR files have a minimal header (6 or 9 bytes) followed immediately by variable-length speech frames. Each frame byte begins with 4-bit frame type (mode 0-7 for NB, 0-8 for WB) and 1-bit quality flag. Frame sizes are fixed per mode — mode 7 (12.2 kbps NB) is 32 bytes per frame. AMR is frequently embedded inside 3GP/MP4 containers rather than as standalone files.",
    "suggestedInspections": [
      "Distinguish AMR-NB ('#!AMR\\n') from AMR-WB ('#!AMR-WB\\n') by header length",
      "Walk frames after the header: each starts with a TOC byte encoding frame type and quality",
      "Map frame types to bitrates: NB mode 0=4.75kbps through mode 7=12.2kbps",
      "Count Q=0 (bad quality) frames to assess recording quality from mobile device",
      "Calculate duration from frame count: each frame = 20ms of audio",
      "Check if file is standalone AMR or if .amr extension was extracted from 3GP container"
    ]
  },
  "software": [
    "FFmpeg",
    "VLC Media Player",
    "Android MediaRecorder API",
    "iOS AVAudioRecorder",
    "Audacity (via FFmpeg plugin)",
    "MediaInfo"
  ],
  "formatRelationships": {
    "category": "Audio",
    "extensions": [".amr", ".3ga"],
    "relatedFormats": ["3GP", "MP4", "AAC", "EVRC", "G.711"],
    "note": "AMR is commonly embedded as an audio track in 3GP files; standalone .amr is used by mobile voicemail and voice memo apps"
  },

{
  "diffMode": "binary",
  "formatName": "Musepack Audio",
  "version": "1.0",
  "extensions": [".mpc", ".mp+"],
  "description": "Musepack (MPC) is a lossy audio compression format derived from MPEG-1 Layer II with significant modifications for improved quality-per-bit. Stream Version 8 (SV8) files begin with the four-byte magic 'MPCK' (0x4D50434B) followed by variable-length key-length-value packets. Stream Version 7 (SV7) older files use the two-byte 'MP+' prefix. SV8 introduced key-value packet containers for the stream header (SH), replay gain (RG), and end-of-stream (ES) packets. Musepack excels at transparent quality at medium bitrates.",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": {
    "specifications": [
      "Musepack SV8 Stream Format Specification",
      "Musepack SV7 Legacy Format Documentation"
    ],
    "WebLinks": [
      "https://www.musepack.net/",
      "https://wiki.hydrogenaud.io/index.php?title=Musepack"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "4D50434B",
        "offset": 0,
        "label": "MPCK — Musepack SV8 stream magic",
        "weight": 1.0
      },
      {
        "value": "4D502B",
        "offset": 0,
        "label": "MP+ — Musepack SV7 legacy magic",
        "weight": 0.8
      }
    ],
    "matchMode": "Any",
    "MinimumScore": 0.5,
    "required": [],
    "Strength": "Strong",
    "EntropyHint": {
      "min": 5.0,
      "max": 8.0,
      "comment": "Lossy audio with moderate to high entropy"
    },
    "validation": {
      "notes": "SV8: check 'MPCK' at offset 0; SV7: check 'MP+' at offset 0"
    }
  },
  "variables": {
    "mpcMagic": "",
    "firstPacketKey": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "mpcMagic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "Musepack stream identifier — 'MPCK' (0x4D50434B) for SV8 streams or 'MP+' for legacy SV7; the four-byte SV8 form is the canonical current format magic",
      "storeAs": "mpcMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "firstPacketKey",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.75,
      "description": "Two-character ASCII key of the first SV8 KLV packet immediately after the MPCK magic; expected to be 'SH' (Stream Header), 'RG' (Replay Gain), or 'EI' (Encoder Info)",
      "storeAs": "firstPacketKey",
      "valueType": "ascii"
    }
  ],
  "assertions": [
    {
      "field": "mpcMagic",
      "op": "in",
      "value": ["MPCK", "MP+"],
      "message": "Musepack magic must be 'MPCK' (SV8) or 'MP+' (SV7)"
    },
    {
      "field": "firstPacketKey",
      "op": "in",
      "value": ["SH", "RG", "EI"],
      "message": "First SV8 packet key must be SH, RG, or EI"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "MPCK Magic", "offset": 0, "length": 4, "color": "#FF6B6B" },
      { "name": "First Packet Key", "offset": 4, "length": 2, "color": "#4ECDC4" }
    ]
  },
  "inspector": {
    "badge": "MPC",
    "primaryField": "mpcMagic",
    "showQualityScore": true,
    "groups": [
      {
        "name": "Stream Identity",
        "fields": ["mpcMagic", "firstPacketKey"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "MPC Stream Summary",
      "format": "text",
      "template": "Magic: {mpcMagic} | FirstPacket: {firstPacketKey}"
    },
    {
      "name": "MPC JSON Report",
      "format": "json",
      "template": "{ \"magic\": \"{mpcMagic}\", \"firstPacketKey\": \"{firstPacketKey}\" }"
    }
  ],
  "forensic": {
    "category": "Audio",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Missing MPCK or MP+ magic indicates corrupted or mis-identified file",
      "SV7 files with MP+ magic are legacy format; modern tools prefer SV8",
      "Invalid first packet key after MPCK may indicate truncated or hand-crafted file"
    ]
  },
  "aiHints": {
    "analysisContext": "Musepack SV8 uses a KLV packet container. After the 4-byte MPCK magic, each packet has a 2-char key, a variable-length size field, and a data payload. The SH (Stream Header) packet contains sample rate, channel count, and frame count. SV7 files have a fixed-layout header after 'MP+'.",
    "suggestedInspections": [
      "Distinguish SV8 ('MPCK') from SV7 ('MP+') by reading first 4 bytes",
      "For SV8: walk KLV packets starting at offset 4 to find SH stream header",
      "Decode stream header sample rate and channel count from SH packet payload",
      "Check for RG (Replay Gain) packet to find loudness normalization metadata",
      "Validate EI (Encoder Info) packet to identify encoder version and profile used",
      "Verify final ES (End of Stream) packet presence to confirm complete file"
    ]
  },
  "software": [
    "foobar2000",
    "Winamp (with plugin)",
    "FFmpeg",
    "VLC Media Player",
    "MPC-HC",
    "EAC (Exact Audio Copy) with MPC encoder"
  ],
  "formatRelationships": {
    "category": "Audio",
    "extensions": [".mpc", ".mp+"],
    "relatedFormats": ["MP3", "AAC", "OGG Vorbis", "Opus"],
    "note": "Musepack SV8 supersedes SV7 with KLV packet structure; both derive from MPEG-1 Layer II perceptual coding"
  },
  "MimeTypes": ["audio/x-musepack", "audio/musepack"],
  "UseCases": [
    "High-quality lossy audio archiving at medium bitrates",
    "Audiophile transparent-quality music distribution",
    "Legacy audio library conversion from SV7 to SV8"
  ],
  "QualityMetrics": {
    "CompletenessScore": 85,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 2,
    "ValidationRules": 2,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "streamVersions": {
      "SV7": "Legacy fixed-layout header, magic 'MP+'",
      "SV8": "KLV packet container, magic 'MPCK'"
    },
    "packetKeys": ["SH", "RG", "EI", "SO", "AP", "SE", "ES"],
    "derivedFrom": "MPEG-1 Layer II with psychoacoustic extensions",
    "lossless": false
  }
}

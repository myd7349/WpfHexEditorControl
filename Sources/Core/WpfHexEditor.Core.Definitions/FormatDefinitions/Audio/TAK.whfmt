  },
  "blocks": [
    {
      "type": "signature",
      "name": "TAK Magic Number",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "TAK file magic number 0x6BEA8D74 stored as 4 bytes (74 8D EA 6B in little-endian order). This unique 4-byte signature identifies every TAK lossless audio file. The magic was deliberately chosen to be unlikely to appear in other file formats. It encodes as 'tBaK' when the bytes are treated as an ASCII string (0x74='t', 0x42='B'... wait: actual bytes are 74 8D EA 6B which is not printable ASCII).",
      "storeAs": "takMagic",
      "valueType": "uint32",
      "endianness": "little"
    },
    {
      "type": "metadata",
      "name": "TAK Magic",
      "variable": "takMagic",
      "description": "TAK lossless audio file magic number (0x6BEA8D74 LE = bytes 74 8D EA 6B)"
    }
  ],
  "assertions": [
    {
      "name": "TAK magic valid",
      "expression": "takMagic == 1810009460",
      "severity": "error",
      "message": "TAK magic must be 0x6BEA8D74 (LE) at offset 0 — not a valid TAK lossless audio file"
    }
  ],

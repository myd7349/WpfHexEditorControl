{
  "diffMode": "binary",
  "formatName": "Tom's Audio Kompressor",
  "version": "1.15",
  "extensions": [
    ".tak"
  ],
  "description": "TAK (Tom's Audio Kompressor) — a high-performance lossless audio codec created by Thomas Becker. The file begins with a 4-byte little-endian magic identifier 0x6BEA8D74 (bytes: 74 8D EA 6B). TAK uses a block-based encoding with a Stream Info metadata block early in the file containing sample rate, bit depth, channel count, and total sample count. TAK offers competitive compression ratios comparable to FLAC with higher decoding speed. Metadata is stored in TAK metadata blocks with a type code, size, and CRC-32 checksum. The format supports all standard PCM parameters: 1-32 channels, 6-384 kHz sample rate, 8-32-bit depth.",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "audio-viewer",
  "references": {
    "specifications": [
      "TAK Lossless Audio Format — Thomas Becker",
      "TAK Audio Format Documentation — wiki.multimedia.cx"
    ],
    "WebLinks": [
      "https://wiki.hydrogenaudio.org/index.php?title=TAK",
      "https://wiki.multimedia.cx/index.php/TAK",
      "https://en.wikipedia.org/wiki/TAK_(audio_format)"
    ]
  },
  "detection": {
    "signature": "748DEA6B",
    "offset": 0,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 4.0, "max": 7.5 },
    "validation": {

{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "NES Sound Format (NSF)",
  "formatId": "NSF",
  "version": "1.1.1",
  "extensions": [ ".nsf", ".nsfe" ],
  "diffMode": "binary",
  "description": "NES Sound Format stores NES/Famicom music as 6502 machine code with a 128-byte header. NSFe is an extended variant with chunk-based metadata. Supports multiple expansion chips.",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://www.nesdev.org/wiki/NSF",
    "https://www.nesdev.org/wiki/NSFe"
  ],
  "MimeTypes": [ "audio/x-nsf", "audio/x-nes-sound" ],
  "UseCases": [
    "NES game music preservation and playback",
    "Retro video game audio analysis",
    "Chiptune authoring for NES hardware",
    "6502 audio routine research"
  ],
  "software": [
    { "name": "Nestopia UE", "role": "Accurate NES emulator with NSF player",  "platform": "Multi",   "url": "https://github.com/0ldsk00l/nestopia" },
    { "name": "VirtuaNSF",   "role": "Standalone NSF player",                  "platform": "Windows" },
    { "name": "FamiTracker", "role": "NES tracker that exports NSF",            "platform": "Windows", "url": "http://www.famitracker.com" },
    { "name": "NSFPlay",     "role": "NSF player with oscilloscope view",       "platform": "Windows", "url": "https://bbbradsmith.github.io/nsfplay/" }
  ],
  "detection": {
    "signatures": [
      {
        "value": "4E45534D1A",
        "offset": 0,
        "label": "'NESM' + 0x1A NSF magic (5 bytes)",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 88,
    "Strength": "Strong",
    "EntropyHint": { "min": 2.5, "max": 6.5 }
  },
  "variables": [
    { "name": "nsfMagic",        "offset": 0,   "size": 4,  "type": "ascii", "storeAs": "nsfMagic",        "description": "Magic string 'NESM'" },
    { "name": "nsfTerminator",   "offset": 4,   "size": 1,  "type": "uint8", "storeAs": "nsfTerminator",   "description": "Terminator byte, must be 0x1A" },
    { "name": "nsfVersion",      "offset": 5,   "size": 1,  "type": "uint8", "storeAs": "nsfVersion",      "description": "NSF version, should be 1" },
    { "name": "nsfTotalSongs",   "offset": 6,   "size": 1,  "type": "uint8", "storeAs": "nsfTotalSongs",   "description": "Total number of songs (1-255)" },
    { "name": "nsfStartSong",    "offset": 7,   "size": 1,  "type": "uint8", "storeAs": "nsfStartSong",    "description": "Default start song (1-based)" },
    { "name": "nsfLoadAddr",     "offset": 8,   "size": 2,  "type": "uint16","endian": "LE", "storeAs": "nsfLoadAddr",    "description": "Load address for music code (0x6000-0xFFFF)" },
    { "name": "nsfInitAddr",     "offset": 10,  "size": 2,  "type": "uint16","endian": "LE", "storeAs": "nsfInitAddr",    "description": "Init routine address (called once per song select)" },
    { "name": "nsfPlayAddr",     "offset": 12,  "size": 2,  "type": "uint16","endian": "LE", "storeAs": "nsfPlayAddr",    "description": "Play routine address (called each frame)" },
    { "name": "nsfSongName",     "offset": 14,  "size": 32, "type": "ascii", "storeAs": "nsfSongName",     "description": "Song name, null-terminated within 32 bytes" },
    { "name": "nsfArtist",       "offset": 46,  "size": 32, "type": "ascii", "storeAs": "nsfArtist",       "description": "Artist name, null-terminated within 32 bytes" },
    { "name": "nsfCopyright",    "offset": 78,  "size": 32, "type": "ascii", "storeAs": "nsfCopyright",    "description": "Copyright string, null-terminated within 32 bytes" },
    { "name": "nsfPlaySpeedNTSC","offset": 110, "size": 2,  "type": "uint16","endian": "LE", "storeAs": "nsfPlaySpeedNTSC","description": "Play speed for NTSC in microseconds between calls (16666 = 60 Hz)" },
    { "name": "nsfBankSwitch",   "offset": 112, "size": 8,  "type": "bytes", "storeAs": "nsfBankSwitch",   "description": "8 initial bank-switch values (all zero = no banking)" },
    { "name": "nsfPlaySpeedPAL", "offset": 120, "size": 2,  "type": "uint16","endian": "LE", "storeAs": "nsfPlaySpeedPAL","description": "Play speed for PAL in microseconds (20000 = 50 Hz)" },
    { "name": "nsfRegion",       "offset": 122, "size": 1,  "type": "uint8", "storeAs": "nsfRegion",
      "description": "Region flags: bit0=PAL, bit1=NTSC/PAL dual",
      "valueMap": { "0": "NTSC only", "1": "PAL only", "2": "NTSC and PAL", "3": "NTSC and PAL" } },
    { "name": "nsfExpansion",    "offset": 123, "size": 1,  "type": "uint8", "storeAs": "nsfExpansion",    "description": "Extra sound chip flags: bit0=VRC6, bit1=VRC7, bit2=FDS, bit3=MMC5, bit4=N163, bit5=Sunsoft5B" },
    { "name": "nsfPadding",      "offset": 124, "size": 4,  "type": "bytes", "storeAs": "nsfPadding",      "description": "Reserved padding bytes (must be 0x00)" }
  ],
  "blocks": [
    {
      "name": "FileHeader",
      "offset": 0,
      "size": 128,
      "description": "128-byte NSF header containing magic, version, song count, addresses, metadata and hardware flags",
      "color": "#1E90FF",
      "fields": [ "nsfMagic", "nsfTerminator", "nsfVersion", "nsfTotalSongs", "nsfStartSong",
                  "nsfLoadAddr", "nsfInitAddr", "nsfPlayAddr", "nsfSongName", "nsfArtist",
                  "nsfCopyright", "nsfPlaySpeedNTSC", "nsfBankSwitch", "nsfPlaySpeedPAL",
                  "nsfRegion", "nsfExpansion", "nsfPadding" ]
    },
    {
      "name": "MusicCode",
      "offset": 128,
      "description": "6502 NES music code loaded at nsfLoadAddr. If bankswitching is used, data is split into 4KB pages.",
      "color": "#FF6347"
    },
    {
      "name": "BankswitchPages",
      "offset": 128,
      "description": "Optional bank-switched 4KB pages (only if any nsfBankSwitch byte is non-zero)",
      "color": "#9370DB"
    }
  ],
  "assertions": [
    { "id": "A1", "expression": "nsfMagic == 'NESM'",                         "severity": "error",   "message": "Magic 'NESM' required at offset 0" },
    { "id": "A2", "expression": "nsfTerminator == 26",                        "severity": "error",   "message": "Terminator byte at offset 4 must be 0x1A" },
    { "id": "A3", "expression": "nsfVersion == 1",                            "severity": "warning", "message": "NSF version should be 1" },
    { "id": "A4", "expression": "nsfTotalSongs >= 1 and nsfTotalSongs <= 255","severity": "error",   "message": "Total songs must be 1-255" },
    { "id": "A5", "expression": "nsfStartSong <= nsfTotalSongs",              "severity": "error",   "message": "Start song must not exceed total songs" }
  ],
  "navigation": {
    "rootLabel": "NSF File",
    "entries": [
      { "label": "Header",           "blockRef": "FileHeader" },
      { "label": "Music Code",       "blockRef": "MusicCode" },
      { "label": "Bankswitch Pages", "blockRef": "BankswitchPages" }
    ]
  },
  "inspector": {
    "badge": "NSF",
    "primaryField": "nsfSongName",
    "groups": [
      { "name": "Metadata",      "fields": [ "nsfMagic", "nsfVersion", "nsfSongName", "nsfArtist", "nsfCopyright" ] },
      { "name": "Song Structure","fields": [ "nsfTotalSongs", "nsfStartSong" ] },
      { "name": "Addresses",     "fields": [ "nsfLoadAddr", "nsfInitAddr", "nsfPlayAddr" ] },
      { "name": "Hardware",      "fields": [ "nsfRegion", "nsfExpansion", "nsfPlaySpeedNTSC", "nsfPlaySpeedPAL", "nsfBankSwitch" ] }
    ]
  },
  "exportTemplates": [
    {
      "name": "Song Metadata",
      "format": "text",
      "template": "Name: {nsfSongName}\nArtist: {nsfArtist}\nCopyright: {nsfCopyright}\nVersion: {nsfVersion}  Songs: {nsfTotalSongs}  Default: {nsfStartSong}\nLoad: 0x{nsfLoadAddr}  Init: 0x{nsfInitAddr}  Play: 0x{nsfPlayAddr}\nRegion: {nsfRegion}  Expansion: 0x{nsfExpansion}"
    },
    {
      "name": "CSV Metadata",
      "format": "csv",
      "template": "Field,Value\nSongName,{nsfSongName}\nArtist,{nsfArtist}\nCopyright,{nsfCopyright}\nVersion,{nsfVersion}\nTotalSongs,{nsfTotalSongs}\nStartSong,{nsfStartSong}\nLoadAddr,{nsfLoadAddr}\nInitAddr,{nsfInitAddr}\nPlayAddr,{nsfPlayAddr}\nRegion,{nsfRegion}\nExpansion,{nsfExpansion}"
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "suspiciousPatterns": [
      "nsfTerminator != 0x1A — header tampered",
      "nsfLoadAddr < 0x6000 — invalid NES address, possible exploit",
      "nsfTotalSongs == 0 — invalid file",
      "Non-zero nsfPadding bytes — potential hidden data in reserved area"
    ],
    "hidingTechniques": [
      "Data hidden in unused song slots beyond nsfTotalSongs",
      "Non-printing bytes in text metadata fields",
      "Extra data appended after last music code page"
    ],
    "timestampFields": [ "nsfCopyright (text year, not machine-readable)" ],
    "notes": "NSF bankswitching allows up to 256 KB of music code via eight 4 KB selectable pages. The expansion chip byte indicates which extra sound hardware is required."
  },
  "aiHints": {
    "analysisContext": "NSF has a compact 128-byte fixed header followed by raw 6502 machine code. The three address fields define NES memory layout. Bankswitching presence is indicated by non-zero values in the 8-byte bankswitch table. Expansion chip flags require specific NES hardware or emulation.",
    "suggestedInspections": [
      "Verify 'NESM' at offset 0 and 0x1A at offset 4",
      "Check nsfTotalSongs >= 1 and nsfStartSong <= nsfTotalSongs",
      "Inspect nsfBankSwitch bytes: if any nonzero, verify music code is exactly n * 4096 bytes",
      "Check nsfExpansion flags against music code to verify expansion chip usage (VRC6/VRC7/FDS/MMC5/N163)",
      "Validate nsfLoadAddr and nsfInitAddr/PlayAddr fall within expected NES ROM address space (0x6000-0xFFFF)"
    ]
  },
  "formatRelationships": [
    { "format": "SID", "relationship": "sibling", "description": "SID is the C64 equivalent chip music container" },
    { "format": "GBS", "relationship": "sibling", "description": "GBS is the Game Boy equivalent for Z80 chip music" },
    { "format": "SPC", "relationship": "sibling", "description": "SPC is the SNES equivalent audio dump format" }
  ],
  "TechnicalDetails": {
    "endianness": "Little-Endian",
    "headerSize": 128,
    "minimumFileSize": 129,
    "targetCPU": "Ricoh 2A03 / 2A07 (6502 derivative)",
    "maxSongs": 255,
    "maxCodeSize": "262144 bytes (256 KB with bankswitching)",
    "bankPageSize": 4096,
    "bankCount": 8,
    "specVersion": "1.0"
  },
  "QualityMetrics": {
    "CompletenessScore": 93,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team",
    "KnownLimitations": "NSFe extended format uses a different chunk-based structure; this definition covers standard NSF v1 only."
  }
}




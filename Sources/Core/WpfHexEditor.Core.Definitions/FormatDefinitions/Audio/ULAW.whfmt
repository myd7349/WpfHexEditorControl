      "storeAs": "channels",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "metadata",
      "name": "Encoding",
      "variable": "encoding",
      "description": "AU encoding: 1 = G.711 μ-law, 27 = G.711 A-law"
    },
    {
      "type": "metadata",

{
  "diffMode": "binary",
  "formatName": "μ-law Audio",
  "version": "1.15",
  "extensions": [
    ".ulaw",
    ".ul",
    ".mu"
  ],
  "description": "μ-law (mu-law) — an ITU-T G.711 logarithmic companding algorithm for 8-bit PCM encoding of voice audio, used in North American and Japanese PSTN telephony. μ-law .ulaw/.ul files typically use the AU/SND container format starting with '.snd' (0x2E736E64), with the μ-law encoding specified in the AU header encoding field (value 1 = G.711 μ-law). Raw μ-law is headerless 8-bit encoded audio at 8000 Hz. The μ-law algorithm maps a 14-bit linear PCM value to 8 bits using a piecewise logarithmic compression curve. μ-law is used in North America (T1 circuits) and Japan; A-law is used in Europe (E1 circuits). Both produce 64 kbps at 8000 Hz mono.",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "audio-viewer",
  "references": {
    "specifications": [
      "ITU-T G.711 — PCM of Voice Frequencies",
      "μ-law logarithmic companding algorithm",
      "G.711 Telephony Codec Standard"
    ],
    "WebLinks": [
      "https://www.itu.int/rec/T-REC-G.711/",
      "https://en.wikipedia.org/wiki/G.711",
      "https://en.wikipedia.org/wiki/%CE%9C-law_algorithm",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000039.shtml"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "2E736E64", "offset": 0, "label": "'.snd' AU/SND container header (may contain μ-law)", "weight": 0.7 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.7,
    "required": true,
    "Strength": "Medium",
    "EntropyHint": { "min": 3.0, "max": 5.5 },
    "validation": {
      "minFileSize": 24,
      "note": "μ-law audio is typically stored in AU/SND container (0x2E736E64). Raw headerless μ-law has no magic bytes. AU encoding field value 1 = G.711 μ-law."
    }
  },
  "variables": {
    "sndMagic": "",
    "dataOffset": 0,
    "dataSize": 0,
    "encoding": 0,
    "sampleRate": 0,
    "channels": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "AU/SND Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "AU/SND file magic '.snd' (0x2E736E64). μ-law audio is commonly stored in the AU container format. The container's encoding field at offset 12 specifies the codec: value 1 = G.711 μ-law (North America/Japan PSTN).",
      "storeAs": "sndMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Data Offset",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Byte offset from the start of the file to the audio data, stored as a 32-bit big-endian unsigned integer. Minimum 24 bytes (fixed AU header size). Larger values indicate annotation text or padding between header and audio data.",
      "storeAs": "dataOffset",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Data Size",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "Size of the audio data in bytes as a 32-bit big-endian unsigned integer. Value 0xFFFFFFFF (4294967295) means unknown — used for streaming audio recorded without pre-determined length.",
      "storeAs": "dataSize",
      "valueType": "uint32",
      "endianness": "big",
      "valueMap": {
        "4294967295": "Unknown data size (streaming: 0xFFFFFFFF)"
      }
    },
    {
      "type": "field",
      "name": "Encoding",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.35,
      "description": "Audio encoding format as a 32-bit big-endian unsigned integer. Value 1 = G.711 μ-law (8-bit companded, 8000 Hz telephony). The μ-law algorithm maps a 14-bit linear PCM sample to 8 bits using a logarithmic compression curve defined in ITU-T G.711 Annex A.",
      "storeAs": "encoding",
      "valueType": "uint32",
      "endianness": "big",
      "valueMap": {
        "1": "μ-law (G.711 mu-law, North America/Japan PSTN)",
        "2": "8-bit linear PCM",
        "3": "16-bit linear PCM",
        "27": "A-law (G.711 A-law, European PSTN)"
      }
    },
    {
      "type": "field",
      "name": "Sample Rate",
      "offset": 16,
      "length": 4,
      "color": "#C7CEEA",
      "opacity": 0.30,
      "description": "Sample rate in Hz as a 32-bit big-endian unsigned integer. For G.711 μ-law telephony this is always 8000 Hz (the ITU-T G.711 standard for narrowband voice codec at 64 kbps).",
      "storeAs": "sampleRate",
      "valueType": "uint32",
      "endianness": "big",
      "valueMap": {
        "8000": "8000 Hz — G.711 narrowband telephony (64 kbps)"

    "DocumentationLevel": "detailed",
    "BlocksDefined": 9,
    "ValidationRules": 4,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "AudioFormat": true,
    "Endianness": "little-endian",
    "HeaderSize": "26 bytes",
    "BlockStructure": "type(1B) + size(3B LE 24-bit) + data",
    "SampleRateFormula": "SR = 1000000 / (256 - divisor) for block type 1",
    "SupportedCodecs": "8-bit unsigned PCM, 4-bit ADPCM 2-to-1, 3-bit ADPCM, 2-bit ADPCM",
    "EOFMarker": "0x1A (DOS Ctrl+Z)"
  }

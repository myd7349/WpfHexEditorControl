    "extensions": [".voc"],
    "relatedFormats": ["WAV", "RAW"],
    "note": "VOC was the native format of Creative Sound Blaster cards (1989-1995). It predates WAV and was the dominant PC audio format during the DOS gaming era."
  },
  "MimeTypes": [
    "audio/x-voc",
    "audio/voc"
  ],
  "UseCases": [

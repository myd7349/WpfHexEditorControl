      }
    ]
  },
  "exportTemplates": [
    {
      "name": "VOC Header (JSON)",
      "format": "json",
      "fields": ["vocSignature", "dataBlockOffset", "version", "versionCheck", "firstBlockType"]
    },
    {
      "name": "voc_header_t (C struct)",
      "format": "c-struct",
      "structName": "voc_header",
      "fields": ["vocSignature", "eofMarker", "dataBlockOffset", "version", "versionCheck"]
    }
  ],
  "forensic": {
    "category": "audio",
    "riskLevel": "low",
    "suspiciousPatterns": [
      {
        "name": "Version check mismatch",
        "condition": "false",
        "severity": "warning",
        "description": "VOC version check field should equal 0x1234 + (~version & 0xFFFF). A mismatch indicates a modified or corrupted header."
      }
    ]
  },
  "aiHints": {
    "analysisContext": "VOC header layout (26 bytes): 'Creative Voice File'(19B) + 0x1A(1B) + dataBlockOffset(2,LE) + version(2,LE: 0x010A=v1.10) + versionCheck(2,LE: must = 0x1234 + ~version). Data blocks at dataBlockOffset: type(1B) + size(3B LE 24-bit) + data. Block 1 (Sound Data): size(3B LE) + sampleRateDivisor(1B) + codec(1B: 0=8-bit unsigned PCM) + PCM_data. Sample rate = 1000000 / (256 - sampleRateDivisor). Block 8 (Extended for SBPro): timeConstant(2B LE) + packType(1B) + voiceMode(1B: 0=mono/1=stereo). Block 9 (new format): sampleRate(4B LE) + bitsPerSample(1B) + channels(1B) + codec(2B LE) + reserved(4B).",
    "suggestedInspections": [
      "Verify 'Creative Voice File' at offset 0",
      "Check 0x1A at offset 19",
      "Read version at offset 22 (LE uint16): 0x010A=v1.10, 0x0114=v1.20",
      "Verify version check: versionCheck + version should == 0x1235",
      "Read first block at dataBlockOffset — type byte 0=end, 1=sound data, 9=new format"
    ]
  },
  "software": [
    "Creative Sound Blaster (original)",
    "DOSBox",
    "Audacity",
    "VLC media player",
    "SDL_mixer",
    "DOS game engines (Duke Nukem 3D, Quake)"
  ],
  "formatRelationships": {

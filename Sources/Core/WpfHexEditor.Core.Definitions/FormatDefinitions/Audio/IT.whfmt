{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "Impulse Tracker Module (IT)",
  "formatId": "IT",
  "version": "1.1.1",
  "extensions": [ ".it" ],
  "diffMode": "binary",
  "description": "Impulse Tracker module format created by Jeffrey Lim. Supports up to 64 channels, advanced envelopes, NNA (New Note Actions), filters and compressed samples.",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://wiki.openmpt.org/Development:_Formats/IT",
    "https://github.com/schismtracker/schismtracker/wiki/ITTECH.TXT"
  ],
  "MimeTypes": [ "audio/it", "audio/x-it", "audio/x-tracker-module" ],
  "UseCases": [
    "PC demoscene music authoring",
    "Game music composition and playback",
    "Advanced tracker module archival",
    "Cross-platform chiptune player support"
  ],
  "software": [
    { "name": "Impulse Tracker", "role": "Original DOS authoring tool",          "platform": "DOS" },
    { "name": "OpenMPT",         "role": "Modern editor and player",              "platform": "Windows", "url": "https://openmpt.org" },
    { "name": "Schism Tracker",  "role": "Cross-platform IT-compatible editor",   "platform": "Multi",   "url": "https://schismtracker.org" },
    { "name": "ModPlug Player",  "role": "Legacy player",                         "platform": "Windows" }
  ],
  "detection": {
    "signatures": [
      {
        "value": "494D504D",
        "offset": 0,
        "label": "'IMPM' Impulse Tracker magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 88,
    "Strength": "Strong",
    "EntropyHint": { "min": 3.5, "max": 7.5 }
  },
  "variables": [
    { "name": "itMagic",          "offset": 0,   "size": 4,  "type": "ascii",  "storeAs": "itMagic",          "description": "Magic string 'IMPM'" },
    { "name": "itSongName",       "offset": 4,   "size": 26, "type": "ascii",  "storeAs": "itSongName",       "description": "Song name, null-padded to 26 bytes" },
    { "name": "itHighlight",      "offset": 30,  "size": 2,  "type": "uint16", "endian": "LE", "storeAs": "itHighlight",  "description": "Pattern row highlight values" },
    { "name": "itNumOrders",      "offset": 32,  "size": 2,  "type": "uint16", "endian": "LE", "storeAs": "itNumOrders",  "description": "Number of orders in song" },
    { "name": "itNumInstruments", "offset": 34,  "size": 2,  "type": "uint16", "endian": "LE", "storeAs": "itNumInstruments", "description": "Number of instruments (max 99)" },
    { "name": "itNumSamples",     "offset": 36,  "size": 2,  "type": "uint16", "endian": "LE", "storeAs": "itNumSamples",  "description": "Number of samples (max 99)" },
    { "name": "itNumPatterns",    "offset": 38,  "size": 2,  "type": "uint16", "endian": "LE", "storeAs": "itNumPatterns", "description": "Number of patterns" },
    { "name": "itVersion",        "offset": 40,  "size": 2,  "type": "uint16", "endian": "LE", "storeAs": "itVersion",
      "description": "Tracker version that created the file",
      "valueMap": { "532": "IT 2.14", "528": "IT 2.10", "514": "IT 2.02" } },
    { "name": "itCompatVersion",  "offset": 42,  "size": 2,  "type": "uint16", "endian": "LE", "storeAs": "itCompatVersion", "description": "Compatible-with version" },
    { "name": "itFlags",          "offset": 44,  "size": 2,  "type": "uint16", "endian": "LE", "storeAs": "itFlags",       "description": "Module flags (stereo, vol0Mix, instruments, linear freq, etc.)" },
    { "name": "itSpecial",        "offset": 46,  "size": 2,  "type": "uint16", "endian": "LE", "storeAs": "itSpecial",     "description": "Special flags (song message present, MIDI embedded)" },
    { "name": "itGlobalVol",      "offset": 48,  "size": 1,  "type": "uint8",  "storeAs": "itGlobalVol",     "description": "Global volume (0-128)" },
    { "name": "itMixVol",         "offset": 49,  "size": 1,  "type": "uint8",  "storeAs": "itMixVol",        "description": "Mix volume (0-128)" },
    { "name": "itInitialSpeed",   "offset": 50,  "size": 1,  "type": "uint8",  "storeAs": "itInitialSpeed",  "description": "Initial tempo (ticks per row)" },
    { "name": "itInitialBPM",     "offset": 51,  "size": 1,  "type": "uint8",  "storeAs": "itInitialBPM",    "description": "Initial BPM" },
    { "name": "itPanSep",         "offset": 52,  "size": 1,  "type": "uint8",  "storeAs": "itPanSep",        "description": "Panning separation (0-128)" },
    { "name": "itChannelVol",     "offset": 64,  "size": 64, "type": "bytes",  "storeAs": "itChannelVol",    "description": "64-byte channel volume array" },
    { "name": "itChannelPan",     "offset": 128, "size": 64, "type": "bytes",  "storeAs": "itChannelPan",    "description": "64-byte channel panning array" }
  ],
  "blocks": [
    {
      "name": "FileHeader",
      "offset": 0,
      "size": 192,
      "description": "Fixed IT header: magic, song name, counts, version, flags and channel initial settings",
      "color": "#1E90FF",
      "fields": [ "itMagic", "itSongName", "itNumOrders", "itNumInstruments", "itNumSamples",
                  "itNumPatterns", "itVersion", "itCompatVersion", "itFlags", "itSpecial",
                  "itGlobalVol", "itMixVol", "itInitialSpeed", "itInitialBPM", "itChannelVol", "itChannelPan" ]
    },
    {
      "name": "OrderList",
      "offset": 192,
      "sizeExpression": "itNumOrders",
      "description": "Pattern order sequence, one byte per entry (0xFE=skip, 0xFF=end)",
      "color": "#32CD32"
    },
    {
      "name": "InstrumentOffsets",
      "offset": "computed after orders",
      "sizeExpression": "itNumInstruments * 4",
      "description": "Array of 4-byte file offsets pointing to each instrument header",
      "color": "#FFA500"
    },
    {
      "name": "SampleOffsets",
      "offset": "computed after instrument offsets",
      "sizeExpression": "itNumSamples * 4",
      "description": "Array of 4-byte file offsets pointing to each sample header",
      "color": "#FF6347"
    },
    {
      "name": "PatternOffsets",
      "offset": "computed after sample offsets",
      "sizeExpression": "itNumPatterns * 4",
      "description": "Array of 4-byte file offsets pointing to each pattern block",
      "color": "#9370DB"
    },
    {
      "name": "InstrumentData",
      "offset": "per offset table",
      "description": "Variable-length instrument headers with envelope, NNA, DCT settings",
      "color": "#20B2AA"
    },
    {
      "name": "SampleData",
      "offset": "per offset table",
      "description": "Sample headers and optional compressed PCM or OPL data",
      "color": "#DAA520"
    }
  ],
  "assertions": [
    { "id": "A1", "expression": "itMagic == 'IMPM'",      "severity": "error",   "message": "Magic 'IMPM' required at offset 0" },
    { "id": "A2", "expression": "itNumOrders <= 256",     "severity": "warning", "message": "IT supports up to 256 orders" },
    { "id": "A3", "expression": "itNumSamples <= 99",     "severity": "warning", "message": "IT supports up to 99 samples" },
    { "id": "A4", "expression": "itNumInstruments <= 99", "severity": "warning", "message": "IT supports up to 99 instruments" },
    { "id": "A5", "expression": "itGlobalVol <= 128",     "severity": "warning", "message": "Global volume must be 0-128" }
  ],
  "navigation": {
    "rootLabel": "IT Module",
    "entries": [
      { "label": "File Header",        "blockRef": "FileHeader" },
      { "label": "Order List",         "blockRef": "OrderList" },
      { "label": "Instrument Offsets", "blockRef": "InstrumentOffsets" },
      { "label": "Sample Offsets",     "blockRef": "SampleOffsets" },
      { "label": "Pattern Offsets",    "blockRef": "PatternOffsets" },
      { "label": "Instrument Data",    "blockRef": "InstrumentData" },
      { "label": "Sample Data",        "blockRef": "SampleData" }
    ]
  },
  "inspector": {
    "badge": "IT",
    "primaryField": "itSongName",
    "groups": [
      { "name": "Identity",          "fields": [ "itMagic", "itSongName", "itVersion", "itCompatVersion" ] },
      { "name": "Structure Counts",  "fields": [ "itNumOrders", "itNumInstruments", "itNumSamples", "itNumPatterns" ] },
      { "name": "Playback Settings", "fields": [ "itGlobalVol", "itMixVol", "itInitialSpeed", "itInitialBPM", "itPanSep" ] },
      { "name": "Flags",             "fields": [ "itFlags", "itSpecial" ] }
    ]
  },
  "exportTemplates": [
    {
      "name": "Module Summary",
      "format": "text",
      "template": "Song: {itSongName}\nVersion: {itVersion}\nOrders: {itNumOrders}  Instruments: {itNumInstruments}  Samples: {itNumSamples}  Patterns: {itNumPatterns}\nBPM: {itInitialBPM}  Speed: {itInitialSpeed}  GlobalVol: {itGlobalVol}"
    },
    {
      "name": "CSV Metadata",
      "format": "csv",
      "template": "Field,Value\nSongName,{itSongName}\nVersion,{itVersion}\nOrders,{itNumOrders}\nInstruments,{itNumInstruments}\nSamples,{itNumSamples}\nPatterns,{itNumPatterns}\nBPM,{itInitialBPM}\nSpeed,{itInitialSpeed}"
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "suspiciousPatterns": [
      "itMagic != 'IMPM' — header tampered or wrong format",
      "itNumSamples or itNumInstruments > 99 — exceeds spec, possible exploit",
      "itSpecial bit1 set with no matching message block — corrupt metadata",
      "itVersion < 512 — very old or spoofed version, reduced feature support"
    ],
    "hidingTechniques": [
      "Data embedded after end of last sample/pattern block",
      "Song message field used to store encoded payload",
      "MIDI macro section abused to embed arbitrary bytes"
    ],
    "timestampFields": [],
    "notes": "IT supports optional compressed samples (IT2.14+) and MIDI macros; files may contain embedded text messages accessible via itSpecial flag."
  },
  "aiHints": {
    "analysisContext": "IT uses an offset-table architecture where instrument, sample and pattern blocks are located via arrays of 4-byte file pointers after the header. Validation requires checking all offset table entries fall within file bounds.",
    "suggestedInspections": [
      "Verify 'IMPM' magic at offset 0 and itCompatVersion against itVersion",
      "Validate all instrument, sample and pattern offsets fall within file size",
      "Check itNumSamples and itNumInstruments do not exceed 99",
      "Inspect itSpecial for embedded song message or MIDI configuration presence",
      "Scan sample headers for compressed-sample flags and validate decompressed sizes"
    ]
  },
  "formatRelationships": [
    { "format": "XM",  "relationship": "sibling",  "description": "XM is a contemporary format from FastTracker II with similar channel counts" },
    { "format": "S3M", "relationship": "ancestor",  "description": "IT evolved from ScreamTracker S3M by the same author" },
    { "format": "MOD", "relationship": "ancestor",  "description": "MOD is the original Amiga format that all PC tracker formats extend" }
  ],
  "TechnicalDetails": {
    "endianness": "Little-Endian",
    "minimumFileSize": 192,
    "headerSize": 192,
    "maxChannels": 64,
    "maxOrders": 256,
    "maxInstruments": 99,
    "maxSamples": 99,
    "maxPatterns": 200,
    "sampleCompression": "Optional IT2.14 bit-packing (ITCOMPR)",
    "specVersion": "2.14"
  },
  "QualityMetrics": {
    "CompletenessScore": 93,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team",
    "KnownLimitations": "Offset table entries are file-absolute; block layout depends on creation tool order which may vary."
  }
}




        "color": "#4ECDC4"
      }
    ]
  },
  "inspector": {
    "badge": "encoding",
    "primaryField": "sampleRate",
    "showQualityScore": true,
    "groups": [
      {
        "title": "AU/SND Header",
        "icon": "\uE71B",
        "fields": ["sndMagic", "dataOffset", "dataSize"]
      },

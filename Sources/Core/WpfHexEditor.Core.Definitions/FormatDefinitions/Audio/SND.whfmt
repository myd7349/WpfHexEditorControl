  "exportTemplates": [
    {
      "name": "AU Header (JSON)",
      "format": "json",
      "fields": ["sndMagic", "dataOffset", "dataSize", "encoding", "sampleRate", "channels"]
    }
  ],
  "forensic": {
    "category": "audio",
    "riskLevel": "low",
    "suspiciousPatterns": [
      {
        "name": "Data offset anomaly",
        "condition": "dataOffset < 24 || dataOffset > 65536",
        "severity": "warning",
        "description": "Data offset outside normal range. Values < 24 are structurally invalid; values > 64K suggest an unusually large annotation block or header manipulation."
      }
    ]
  },
  "aiHints": {
    "analysisContext": "AU/SND NeXT/Sun sound format: '.snd'(4B) + dataOffset(4,BE,min=24) + dataSize(4,BE,0xFFFFFFFF=streaming) + encoding(4,BE: 1=μ-law/3=16-bit PCM/27=A-law) + sampleRate(4,BE) + channels(4,BE). Audio samples start at dataOffset (typically 24). For μ-law/A-law (encoding 1/27): 8-bit companded samples, 8000 Hz, mono, 64 kbps — used in telephony and VoIP. For 16-bit PCM (encoding 3): big-endian signed shorts at any sample rate — common in Java audio and NeXT workstation recordings. Duration = dataSize / (sampleRate × channels × bytesPerSample). Java AudioInputStream commonly writes dataSize=0xFFFFFFFF (unknown).",
    "suggestedInspections": [
      "Verify '.snd' magic at offset 0: 2E 73 6E 64",
      "Read encoding at offset 12 (BE uint32): 1=μ-law, 3=16-bit PCM, 27=A-law",
      "Confirm dataOffset >= 24; annotation text (if any) at bytes 24..dataOffset-1",
      "For dataSize=0xFFFFFFFF: streaming file — compute duration from actual file size",
      "Duration (seconds) = dataSize / (sampleRate × channels × bytesPerSample)"
    ]
  },
  "software": [
    "Java (javax.sound.sampled — native AU format)",
    "SoX (Sound eXchange)",
    "Audacity",
    "FFmpeg (au muxer/demuxer)",
    "VLC media player",
    "NeXTSTEP/OpenStep audio subsystem"
  ],
  "formatRelationships": {
    "category": "Audio",
    "extensions": [".snd", ".au"],
    "relatedFormats": ["ULAW", "ALAW", "WAV", "AIFF"],
    "note": "AU/SND is the NeXT/Sun workstation audio format. The .snd extension is historically Unix; .au is the Java/cross-platform convention. Both share the same binary format. μ-law (encoding 1) and A-law (encoding 27) are the G.711 telephony variants; they distinguish ULAW.whfmt and ALAW.whfmt. The AU format is big-endian throughout (unlike WAV which is little-endian)."
  },
  "MimeTypes": [
    "audio/basic",
    "audio/x-au",
    "audio/au"
  ],
  "UseCases": [
    "Java application audio (javax.sound.sampled default format)",
    "NeXTSTEP and OpenStep workstation recordings",
    "Unix system sounds and alert tones",
    "VoIP G.711 μ-law and A-law telephony audio"
  ],

{
  "diffMode": "binary",
  "formatName": "NeXT/Sun Sound File",
  "version": "2.42",
  "extensions": [
    ".snd",
    ".au"
  ],
  "description": "AU/SND — the NeXT/Sun Microsystems audio file format, introduced with the NeXTSTEP operating system and adopted by Sun Microsystems. Files begin with the 4-byte magic '.snd' (0x2E736E64). The 24-byte fixed header contains: data offset (minimum 24), data size (0xFFFFFFFF = streaming), encoding type (1=μ-law, 2=8-bit PCM, 3=16-bit PCM, 4=24-bit, 5=32-bit, 6=float32, 7=float64, 27=A-law), sample rate in Hz, and channel count. All header fields are big-endian (network byte order). The AU format is the historical default audio format on Unix workstations and is still used by Java (javax.sound.sampled), Asterisk PBX, and legacy VoIP systems. Encodings 1 (μ-law) and 27 (A-law) are the G.711 telephony variants.",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "audio-viewer",
  "references": {
    "specifications": [
      "NeXTSTEP Sound Format — Apple/NeXT",
      "Sun Microsystems AU File Format",
      "ITU-T G.711 — PCM of Voice Frequencies (for μ-law and A-law encodings)"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/Au_file_format",
      "https://en.wikipedia.org/wiki/NeXTSTEP",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000119.shtml",
      "https://pubs.opengroup.org/external/auformat.html"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "2E736E64", "offset": 0, "label": "'.snd' AU/SND magic — NeXT/Sun sound file", "weight": 1.0 }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 2.5, "max": 6.5 },
    "validation": {
      "minFileSize": 24,
      "maxSignatureOffset": 0
    }
  },
  "variables": {
    "sndMagic": "",
    "dataOffset": 0,
    "dataSize": 0,
    "encoding": 0,
    "sampleRate": 0,
    "channels": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "AU/SND Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "AU/SND file magic '.snd' (0x2E736E64). The four ASCII bytes '.', 's', 'n', 'd' (0x2E, 0x73, 0x6E, 0x64) mark the start of a NeXT/Sun audio file. This format was the native audio format of NeXTSTEP (1989) and was adopted by Sun Microsystems for Solaris and other Unix workstations. Still the native format for Java audio (javax.sound.sampled.AudioSystem).",
      "storeAs": "sndMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Data Offset",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Byte offset from the start of the file to the audio sample data, as a 32-bit big-endian unsigned integer. The minimum legal value is 24 (the size of the fixed AU header). Values larger than 24 indicate that annotation text (null-terminated ASCII) follows the fixed header and precedes the audio samples.",
      "storeAs": "dataOffset",
      "valueType": "uint32",
      "endianness": "big"
    },
    {
      "type": "field",
      "name": "Data Size",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "Size of the audio sample data in bytes as a 32-bit big-endian unsigned integer. The sentinel value 0xFFFFFFFF (4294967295) means the data size is unknown — used for streaming audio or piped recordings where the total length is not determined at recording time. Java's AudioInputStream commonly produces AU files with this sentinel value.",
      "storeAs": "dataSize",
      "valueType": "uint32",
      "endianness": "big",
      "valueMap": {
        "4294967295": "Unknown/streaming (0xFFFFFFFF sentinel — common in Java AudioInputStream)"
      }
    },
    {
      "type": "field",
      "name": "Encoding",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.35,
      "description": "Audio encoding format as a 32-bit big-endian unsigned integer. Defines how each audio sample is stored. G.711 telephony variants (μ-law=1, A-law=27) are the most common. PCM variants (2=8-bit, 3=16-bit, 4=24-bit, 5=32-bit) provide uncompressed audio. Floating-point variants (6=float32, 7=float64) are used in professional audio. Encoding 3 (16-bit linear PCM, big-endian) is the most common lossless encoding for NeXT/Sun workstation audio.",
      "storeAs": "encoding",
      "valueType": "uint32",
      "endianness": "big",
      "valueMap": {
        "1": "G.711 μ-law (8-bit companded, North American/Japanese PSTN)",
        "2": "8-bit linear PCM (unsigned)",
        "3": "16-bit linear PCM (big-endian, signed)",
        "4": "24-bit linear PCM (big-endian, signed)",
        "5": "32-bit linear PCM (big-endian, signed)",
        "6": "32-bit IEEE 754 floating-point",
        "7": "64-bit IEEE 754 floating-point (double precision)",
        "23": "4-bit CCITT G.721 ADPCM (32 kbps)",
        "24": "CCITT G.722 ADPCM",
        "25": "CCITT G.723 ADPCM",
        "27": "G.711 A-law (8-bit companded, European PSTN)"
      }
    },
    {
      "type": "field",
      "name": "Sample Rate",
      "offset": 16,
      "length": 4,
      "color": "#C7CEEA",
      "opacity": 0.30,
      "description": "Sample rate in Hz as a 32-bit big-endian unsigned integer. Common values: 8000 Hz (G.711 telephony, VoIP), 22050 Hz (half CD quality), 44100 Hz (CD quality), 48000 Hz (professional/broadcast standard). The AU format supports any sample rate; the value is not constrained to standard rates.",
      "storeAs": "sampleRate",
      "valueType": "uint32",
      "endianness": "big",
      "valueMap": {
        "8000": "8000 Hz — G.711 telephony (μ-law/A-law VoIP)",
        "22050": "22050 Hz — half CD quality (multimedia)",
        "44100": "44100 Hz — CD quality",
        "48000": "48000 Hz — professional/broadcast standard"
      }
    },
    {
      "type": "field",
      "name": "Channels",
      "offset": 20,
      "length": 4,
      "color": "#B8B8FF",
      "opacity": 0.25,
      "description": "Number of audio channels as a 32-bit big-endian unsigned integer. Mono (1) is standard for G.711 telephony; stereo (2) is common for workstation music and multimedia. Samples are interleaved: left/right/left/right for stereo.",
      "storeAs": "channels",
      "valueType": "uint32",
      "endianness": "big",
      "valueMap": {
        "1": "Mono",
        "2": "Stereo (interleaved L/R)",
        "4": "Quadraphonic",
        "6": "5.1 surround"
      }
    },
    {
      "type": "metadata",
      "name": "Encoding",
      "variable": "encoding",
      "description": "AU encoding: 1=μ-law, 3=16-bit PCM, 27=A-law (see full valueMap)"
    },
    {
      "type": "metadata",
      "name": "Sample Rate",
      "variable": "sampleRate",
      "description": "Sample rate in Hz"
    },
    {
      "type": "metadata",
      "name": "Channels",
      "variable": "channels",
      "description": "Channel count (1=mono, 2=stereo)"
    }
  ],
  "assertions": [
    {
      "name": "AU magic valid",
      "expression": "sndMagic == '.snd'",
      "severity": "error",
      "message": "AU/SND file must start with '.snd' (0x2E736E64) — not a valid NeXT/Sun sound file"
    },
    {
      "name": "Data offset at least 24",
      "expression": "dataOffset >= 24",
      "severity": "error",
      "message": "Data offset must be >= 24 (minimum AU fixed header size) — invalid AU header"
    },
    {
      "name": "Encoding is known",
      "expression": "encoding >= 1 && encoding <= 27",
      "severity": "warning",
      "message": "Encoding value outside known AU encoding range (1-27) — may be an extended or proprietary encoding"
    }
  ],
  "navigation": {
    "bookmarks": [

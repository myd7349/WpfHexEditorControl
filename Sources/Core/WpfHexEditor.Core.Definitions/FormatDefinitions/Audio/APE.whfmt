{
  "diffMode": "binary",
  "formatName": "Monkey's Audio",
  "version": "1.0",
  "extensions": [".ape", ".mac"],
  "description": "Monkey's Audio (APE) is a lossless audio compression format developed by Matthew T. Welch. Files begin with the four-byte ASCII magic 'MAC ' (0x4D414320) followed by a 16-bit little-endian version number. Compression levels range from 1000 (Fast) to 5000 (Insane). The descriptor block records size information allowing decoders to seek directly to the header, seektable, and audio data sections. APE is widely used among audiophiles for archival quality audio storage without any quality loss.",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": {
    "specifications": [
      "Monkey's Audio SDK documentation (monkeysaudio.com)",
      "APE Tag v1.0 and v2.0 specifications"
    ],
    "WebLinks": [
      "https://www.monkeysaudio.com/",
      "https://wiki.hydrogenaud.io/index.php?title=Monkey%27s_Audio"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "4D414320",
        "offset": 0,
        "label": "MAC  — Monkey's Audio magic bytes",
        "weight": 1.0
      }
    ],
    "matchMode": "First",
    "MinimumScore": 0.9,
    "required": ["MAC  — Monkey's Audio magic bytes"],
    "Strength": "Strong",
    "EntropyHint": {
      "min": 3.0,
      "max": 7.5,
      "comment": "Lossless audio varies widely; low compression levels yield moderate entropy"
    },
    "validation": {
      "notes": "Magic must be 'MAC ' (with trailing space); version in range 3800-3990"
    }
  },
  "variables": {
    "apeMagic": "",
    "apeVersion": 0,
    "descriptorBytes": 0,
    "compressionLevel": 0,
    "channels": 0,
    "sampleRate": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "apeMagic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "Monkey's Audio file identifier — ASCII string 'MAC ' (0x4D414320); the trailing space is mandatory and distinguishes APE from other MAC-prefixed formats",
      "storeAs": "apeMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "apeVersion",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.75,
      "description": "APE format version as a little-endian uint16 multiplied by 1000; common values are 3800-3990+; version determines which header fields are present and their layout",
      "storeAs": "apeVersion",
      "valueType": "uint16LE"
    },
    {
      "type": "field",
      "name": "descriptorBytes",
      "offset": 6,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.75,
      "description": "Size of the APE descriptor block in bytes (little-endian); used to locate the header block which immediately follows the descriptor",
      "storeAs": "descriptorBytes",
      "valueType": "uint16LE"
    },
    {
      "type": "field",
      "name": "compressionLevel",
      "offset": 8,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.75,
      "description": "APE compression level: 1000=Fast, 2000=Normal, 3000=High, 4000=Extra High, 5000=Insane; higher levels yield smaller files at cost of encoding/decoding speed",
      "storeAs": "compressionLevel",
      "valueType": "uint16LE"
    },
    {
      "type": "field",
      "name": "channels",
      "offset": 10,
      "length": 2,
      "color": "#A8E6CF",
      "opacity": 0.75,
      "description": "Number of audio channels in the stream (little-endian uint16); 1=mono, 2=stereo; Monkey's Audio supports multi-channel in newer versions",
      "storeAs": "channels",
      "valueType": "uint16LE"
    },
    {
      "type": "field",
      "name": "sampleRate",
      "offset": 12,
      "length": 4,
      "color": "#DDA0DD",
      "opacity": 0.75,
      "description": "Audio sample rate in Hz stored as a little-endian uint32; common values are 44100, 48000, 88200, 96000 Hz for high-fidelity audio archiving",
      "storeAs": "sampleRate",
      "valueType": "uint32LE"
    }
  ],
  "assertions": [
    {
      "field": "apeMagic",
      "op": "eq",
      "value": "MAC ",
      "message": "APE magic must be 'MAC ' (with trailing space)"
    },
    {
      "field": "apeVersion",
      "op": "range",
      "min": 3800,
      "max": 9999,
      "message": "APE version must be >= 3800"
    },
    {
      "field": "compressionLevel",
      "op": "in",
      "value": [1000, 2000, 3000, 4000, 5000],
      "message": "Compression level must be one of 1000/2000/3000/4000/5000"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "APE Magic", "offset": 0, "length": 4, "color": "#FF6B6B" },
      { "name": "Format Version", "offset": 4, "length": 2, "color": "#4ECDC4" },
      { "name": "Descriptor Size", "offset": 6, "length": 2, "color": "#95E1D3" },
      { "name": "Compression Level", "offset": 8, "length": 2, "color": "#FFE66D" },
      { "name": "Channels", "offset": 10, "length": 2, "color": "#A8E6CF" },
      { "name": "Sample Rate", "offset": 12, "length": 4, "color": "#DDA0DD" }
    ]
  },
  "inspector": {
    "badge": "APE",
    "primaryField": "apeVersion",
    "showQualityScore": true,
    "groups": [
      {
        "name": "File Identity",
        "fields": ["apeMagic", "apeVersion"]
      },
      {
        "name": "Audio Properties",
        "fields": ["compressionLevel", "channels", "sampleRate"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "APE Header Summary",
      "format": "text",
      "template": "Magic: {apeMagic} | Version: {apeVersion} | Compression: {compressionLevel} | Channels: {channels} | SampleRate: {sampleRate}"
    },
    {
      "name": "APE JSON Report",
      "format": "json",
      "template": "{ \"version\": {apeVersion}, \"compressionLevel\": {compressionLevel}, \"channels\": {channels}, \"sampleRate\": {sampleRate} }"
    }
  ],
  "forensic": {
    "category": "Audio",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Version below 3800 may indicate corrupted or ancient incompatible file",
      "Unknown compression level value (not 1000/2000/3000/4000/5000) indicates malformed header",
      "Sample rate outside 8000-192000 Hz range is highly unusual for legitimate files"
    ]
  },
  "aiHints": {
    "analysisContext": "Monkey's Audio uses a descriptor + header + seektable + audio data layout. The descriptorBytes field points past the descriptor to the APE header. Compression level directly impacts decode speed and is important for performance analysis. Version 3990+ introduced descriptor-based layout.",
    "suggestedInspections": [
      "Verify 'MAC ' magic with trailing space at offset 0",
      "Read apeVersion to determine header layout (pre-3980 vs post-3980 formats differ)",
      "Decode compressionLevel to understand encoding tradeoff used",
      "Use descriptorBytes to locate the APE header and seektable positions",
      "Validate sampleRate against common audiophile rates (44100, 48000, 96000 Hz)",
      "Check for APE tag at end of file (ID3v1 or APEv2 tag structures)"
    ]
  },
  "software": [
    "Monkey's Audio (official encoder/decoder)",
    "foobar2000",
    "FFmpeg",
    "VLC Media Player",
    "dBpoweramp",
    "MediaInfo"
  ],
  "formatRelationships": {
    "category": "Audio",
    "extensions": [".ape", ".mac"],
    "relatedFormats": ["FLAC", "WavPack", "TTA", "WAV", "AIFF"],
    "note": "APE is a proprietary lossless format; FLAC is the open-source alternative with wider software support"
  },
  "MimeTypes": ["audio/x-ape", "audio/ape"],
  "UseCases": [
    "Audiophile lossless music archiving",
    "CD ripping with perfect reconstruction",
    "High-resolution audio (96kHz/24-bit) storage",
    "Music library management with metadata tags",
    "Long-term digital preservation of audio masters"
  ],
  "QualityMetrics": {
    "CompletenessScore": 90,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 6,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "compressionLevels": {
      "1000": "Fast",
      "2000": "Normal",
      "3000": "High",
      "4000": "Extra High",
      "5000": "Insane"
    },
    "typicalSampleRates": [44100, 48000, 88200, 96000],
    "minVersion": 3800,
    "lossless": true,
    "seekTableSupport": true
  }
}

    "audio/G711-alaw",
    "audio/alaw"
  ],
  "UseCases": [
    "European PSTN telephone voice recording",
    "VoIP G.711 A-law codec (SIP, H.323)",
    "Asterisk and FreeSWITCH telephony systems",
    "Legacy IVR and voicemail systems"
  ],

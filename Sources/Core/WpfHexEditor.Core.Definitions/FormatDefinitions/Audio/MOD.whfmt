{
  "formatName": "Amiga ProTracker Module",
  "version": "1.0",
  "author": "WPFHexaEditor Team",
  "lastUpdated": "2026-04-15",
  "description": "Amiga ProTracker MOD format — the original 4-channel tracker module with 31 samples, used extensively in the demoscene and early game audio on Amiga and DOS platforms.",
  "extensions": [ ".mod", ".nst", ".m15" ],
  "category": "Audio",
  "diffMode": "binary",
  "signatures": [
    { "value": "4D2E4B2E", "offset": 1080, "label": "'M.K.' — ProTracker 4-channel module",  "weight": 0.9, "strength": "Medium" },
    { "value": "43484E34", "offset": 1080, "label": "'4CHN' — 4-channel variant",             "weight": 0.8, "strength": "Medium" },
    { "value": "4348 4E36", "offset": 1080, "label": "'6CHN' — 6-channel module",             "weight": 0.8, "strength": "Medium" },
    { "value": "4348 4E38", "offset": 1080, "label": "'8CHN' — 8-channel module",             "weight": 0.8, "strength": "Medium" },
    { "value": "464C5434", "offset": 1080, "label": "'FLT4' — StarTracker 4-channel",         "weight": 0.7, "strength": "Medium" }
  ],
  "maxSignatureOffset": 1084,
  "structure": {
    "fields": [
      { "offset": 0,    "size": 20,  "name": "song_name",      "type": "ascii",   "description": "Song title (null-padded 20 bytes)",              "storeAs": "modTitle" },
      { "offset": 20,   "size": 930, "name": "sample_headers", "type": "bytes",   "description": "31 sample headers × 30 bytes each (name/length/finetune/vol/loop)" },
      { "offset": 950,  "size": 1,   "name": "song_length",    "type": "uint8",   "description": "Number of patterns in playback sequence (1–128)", "storeAs": "modLength" },
      { "offset": 951,  "size": 1,   "name": "restart_pos",    "type": "uint8",   "description": "Restart position or 0x7F (legacy Noisetracker)" },
      { "offset": 952,  "size": 128, "name": "pattern_table",  "type": "bytes",   "description": "128-byte pattern order sequence" },
      { "offset": 1080, "size": 4,   "name": "marker",         "type": "ascii",   "description": "Format marker: 'M.K.', '4CHN', '6CHN', '8CHN', 'FLT4', etc.", "storeAs": "modMarker" }
    ]
  },
  "inspector": {
    "displayFields": [ "modTitle", "modLength", "modMarker" ],
    "valueMaps": {
      "modMarker": {
        "M.K.": "ProTracker 4-channel",
        "4CHN": "4-channel (variant)",
        "6CHN": "6-channel",
        "8CHN": "8-channel",
        "FLT4": "StarTracker 4-channel",
        "FLT8": "StarTracker 8-channel",
        "M!K!": "ProTracker extended (>64 patterns)"
      }
    },
    "tooltips": {
      "modTitle":   "Song title stored as plain ASCII, up to 20 characters",
      "modLength":  "Must be 1–128; represents number of patterns in play sequence",
      "modMarker":  "4-byte tag at offset 1080 identifies channel count and sub-variant"
    }
  },
  "assertions": [
    { "id": "A1", "field": "modLength", "operator": "between",  "value": [1, 128], "description": "Song length must be between 1 and 128" },
    { "id": "A2", "field": "modMarker", "operator": "inSet",    "value": ["M.K.", "4CHN", "6CHN", "8CHN", "FLT4", "FLT8", "M!K!", "OCTA", "CD81"], "description": "Marker must be a recognised MOD variant tag" },
    { "id": "A3", "field": "restart_pos", "operator": "lte",    "value": 127,      "description": "Restart position must not exceed pattern table length" }
  ],
  "navigation": {
    "bookmarks": [
      { "offset": 0,    "label": "Song Title",          "color": "#3498DB" },
      { "offset": 20,   "label": "Sample Headers Start", "color": "#9B59B6" },
      { "offset": 950,  "label": "Song Length",          "color": "#F39C12" },
      { "offset": 952,  "label": "Pattern Order Table",  "color": "#27AE60" },
      { "offset": 1080, "label": "Format Marker (M.K.)", "color": "#E74C3C" },
      { "offset": 1084, "label": "Pattern Data Start",   "color": "#1ABC9C" }
    ]
  },
  "exportTemplates": [
    {
      "name": "MOD Header Summary",
      "fields": [ "modTitle", "modMarker", "modLength" ],
      "format": "text"
    },
    {
      "name": "MOD Metadata JSON",
      "fields": [ "modTitle", "modMarker", "modLength", "restart_pos" ],
      "format": "json"
    }
  ],
  "aiHints": [
    "The marker at offset 1080 is the most reliable detection point; files without a known marker may be 15-sample 'M15' MODs (no marker, only Noisetracker 1.x).",
    "The original Amiga MOD supports exactly 4 channels on hardware; 6CHN/8CHN markers indicate PC-era extensions not playable on real Amiga without software mixing.",
    "Each sample header (30 bytes) stores length as 16-bit big-endian word-count (multiply by 2 for byte size); finetune is in the low nibble of byte 24.",
    "Song length at offset 950 indicates how many entries of the 128-byte pattern table are used; bytes beyond that index are irrelevant filler.",
    "Pattern data follows immediately after offset 1084: each pattern is 64 rows × channel_count × 4 bytes = 1024 bytes for a 4-channel MOD.",
    "Signed 8-bit PCM sample data follows all pattern data at the tail of the file, in order of sample headers 1–31."
  ],
  "forensic": {
    "riskLevel": "low",
    "notes": [
      "MOD files contain only music data; no executable content.",
      "Song title and sample name fields (22 bytes each) sometimes contain hidden messages or credits.",
      "Buffer overflows in libmikmod/libxmp with very large sample counts have been patched; ensure library is up to date."
    ]
  },
  "formatRelationships": [
    { "format": "XM",  "relationship": "successor",    "note": "FastTracker 2 XM extends MOD with envelopes and 32 channels." },
    { "format": "S3M", "relationship": "contemporary",  "note": "ScreamTracker 3 S3M was inspired by MOD for PC platforms." },
    { "format": "IT",  "relationship": "successor",     "note": "Impulse Tracker IT is the most advanced evolution of the MOD lineage." }
  ],
  "software": [
    { "name": "ProTracker",   "role": "Original Amiga authoring tool (1987)" },
    { "name": "OpenMPT",      "role": "Modern multi-format tracker (Windows)" },
    { "name": "MilkyTracker", "role": "Cross-platform FT2/MOD editor" },
    { "name": "XMPlay",       "role": "Lightweight module player" },
    { "name": "DeliPlayer",   "role": "Amiga/Windows multi-format player" },
    { "name": "libxmp",       "role": "C library for module playback" }
  ],
  "useCases": [
    "Demoscene and Amiga chiptune archive playback",
    "Retro game music research and extraction",
    "Music education — learning tracker composition",
    "Lightweight audio for embedded or nostalgic applications"
  ],
  "technicalDetails": "Original Amiga module format originated with Ultimate Soundtracker (1987), refined by ProTracker. Fixed 4 channels on Amiga hardware using Paula chip DMA. 31 samples (15 for legacy M15/NST). Sample data is signed 8-bit PCM. Rows=64 per pattern; each cell encodes note (period), sample index, and effect command (4-bit + 12-bit). Finetune adjusts the sample pitch by ±7 semitone fractions using period table lookup.",
  "completenessScore": 84
}

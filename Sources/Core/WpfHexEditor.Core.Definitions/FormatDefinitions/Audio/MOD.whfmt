{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "ProTracker MOD Module",
  "formatId": "MOD",
  "version": "1.1",
  "extensions": [ ".mod" ],
  "diffMode": "binary",
  "description": "Amiga ProTracker MOD music module. Stores up to 31 samples, a pattern order table and packed pattern data. The 4-byte tag at offset 1080 identifies channel count and variant.",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://wiki.openmpt.org/Development:_Formats/MOD",
    "https://www.aes.id.au/modformat.html"
  ],
  "MimeTypes": [ "audio/mod", "audio/x-mod", "audio/x-protracker" ],
  "UseCases": [
    "Amiga game and demo music playback",
    "Chiptune preservation and archiving",
    "Cross-platform retro audio exchange",
    "Tracker music education"
  ],
  "software": [
    { "name": "ProTracker",   "role": "Original Amiga authoring tool",     "platform": "Amiga" },
    { "name": "OpenMPT",      "role": "Modern multi-format editor/player", "platform": "Windows", "url": "https://openmpt.org" },
    { "name": "MilkyTracker", "role": "Cross-platform MOD editor",         "platform": "Multi",   "url": "https://milkytracker.org" },
    { "name": "VLC",          "role": "Playback via libmodplug",            "platform": "Multi" }
  ],
  "detection": {
    "signatures": [
      { "value": "4D2E4B2E", "offset": 1080, "label": "'M.K.' ProTracker 4-channel",    "weight": 1.0 },
      { "value": "4D214B21", "offset": 1080, "label": "'M!K!' ProTracker >64 patterns", "weight": 0.9 },
      { "value": "464C5434", "offset": 1080, "label": "'FLT4' StarTrekker 4-channel",   "weight": 0.8 },
      { "value": "464C5438", "offset": 1080, "label": "'FLT8' StarTrekker 8-channel",   "weight": 0.8 },
      { "value": "36434851", "offset": 1080, "label": "'6CHN' 6-channel variant",        "weight": 0.7 },
      { "value": "38434851", "offset": 1080, "label": "'8CHN' 8-channel variant",        "weight": 0.7 }
    ],
    "matchMode": "any",
    "MinimumScore": 88,
    "Strength": "Strong",
    "EntropyHint": { "min": 3.0, "max": 7.0 }
  },
  "variables": [
    { "name": "modSongTitle",  "offset": 0,    "size": 20,  "type": "ascii", "storeAs": "modSongTitle",  "description": "Song title, null-padded to 20 bytes" },
    { "name": "modFormatTag",  "offset": 1080, "size": 4,   "type": "ascii", "storeAs": "modFormatTag",
      "description": "4-character tag identifying variant and channel count",
      "valueMap": { "M.K.": "ProTracker 4ch", "M!K!": "ProTracker 4ch >64 patterns", "FLT4": "StarTrekker 4ch", "FLT8": "StarTrekker 8ch", "6CHN": "6-channel", "8CHN": "8-channel" } },
    { "name": "modSongLength", "offset": 950,  "size": 1,   "type": "uint8", "storeAs": "modSongLength", "description": "Number of positions in the song (max 128)" },
    { "name": "modRestartPos", "offset": 951,  "size": 1,   "type": "uint8", "storeAs": "modRestartPos", "description": "Restart position (0x7F = no restart)" },
    { "name": "modOrderTable", "offset": 952,  "size": 128, "type": "bytes", "storeAs": "modOrderTable", "description": "Pattern play order, 128 bytes each holding a pattern index" },
    { "name": "modSample1Name","offset": 20,   "size": 22,  "type": "ascii", "storeAs": "modSample1Name","description": "First sample name (samples start at offset 20, 30 bytes each)" }
  ],
  "blocks": [
    {
      "name": "SongTitle",
      "offset": 0,
      "size": 20,
      "description": "Song title string, null-padded",
      "color": "#1E90FF",
      "fields": [ "modSongTitle" ]
    },
    {
      "name": "SampleHeaders",
      "offset": 20,
      "size": 930,
      "description": "31 sample headers of 30 bytes each (name 22B, length 2B, finetune 1B, volume 1B, repeat offset 2B, repeat length 2B)",
      "color": "#32CD32"
    },
    {
      "name": "SongInfo",
      "offset": 950,
      "size": 130,
      "description": "Song length, restart position and 128-byte order table",
      "color": "#FFA500",
      "fields": [ "modSongLength", "modRestartPos", "modOrderTable" ]
    },
    {
      "name": "FormatTag",
      "offset": 1080,
      "size": 4,
      "description": "4-byte tag identifying format variant and channel count",
      "color": "#FF6347",
      "fields": [ "modFormatTag" ]
    },
    {
      "name": "PatternData",
      "offset": 1084,
      "sizeExpression": "numPatterns * channels * 64 * 4",
      "description": "Raw pattern data: 64 rows per pattern, each row has one 4-byte note cell per channel",
      "color": "#9370DB"
    },
    {
      "name": "SampleData",
      "offset": "computed after patterns",
      "description": "Raw 8-bit signed PCM sample data for all 31 sample slots",
      "color": "#DAA520"
    }
  ],
  "assertions": [
    { "id": "A1", "expression": "modSongLength <= 128",      "severity": "error",   "message": "Song length must not exceed 128 positions" },
    { "id": "A2", "expression": "modFormatTag is known tag", "severity": "warning", "message": "Unrecognised format tag at offset 1080" },
    { "id": "A3", "expression": "modRestartPos <= 127",      "severity": "warning", "message": "Restart position should be <= 127 or 0x7F" }
  ],
  "navigation": {
    "rootLabel": "MOD Module",
    "entries": [
      { "label": "Song Title",    "blockRef": "SongTitle" },
      { "label": "Sample Headers","blockRef": "SampleHeaders" },
      { "label": "Song Info",     "blockRef": "SongInfo" },
      { "label": "Format Tag",    "blockRef": "FormatTag" },
      { "label": "Pattern Data",  "blockRef": "PatternData" },
      { "label": "Sample Data",   "blockRef": "SampleData" }
    ]
  },
  "inspector": {
    "badge": "MOD",
    "primaryField": "modSongTitle",
    "groups": [
      { "name": "Identity",      "fields": [ "modSongTitle", "modFormatTag" ] },
      { "name": "Song Structure","fields": [ "modSongLength", "modRestartPos" ] },
      { "name": "First Sample",  "fields": [ "modSample1Name" ] }
    ]
  },
  "exportTemplates": [
    {
      "name": "Module Summary",
      "format": "text",
      "template": "Title: {modSongTitle}\nFormat Tag: {modFormatTag}\nSong Length: {modSongLength}\nRestart Position: {modRestartPos}"
    },
    {
      "name": "CSV Metadata",
      "format": "csv",
      "template": "Field,Value\nSongTitle,{modSongTitle}\nFormatTag,{modFormatTag}\nSongLength,{modSongLength}\nRestartPos,{modRestartPos}"
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "suspiciousPatterns": [
      "Missing or unknown format tag at offset 1080 — may be a headerless or corrupted file",
      "modSongLength > 128 — corrupt or deliberately malformed",
      "Sample lengths summing beyond file size — truncated or fake sample descriptors"
    ],
    "hidingTechniques": [
      "Data appended after last sample block",
      "Steganographic payload in unused sample slots or zero-length sample headers",
      "Extra channels encoded in non-standard tags to confuse players"
    ],
    "timestampFields": [],
    "notes": "MOD is the original Amiga tracker format; thousands of demoscene and game files exist. No integrated timestamp or author metadata beyond the song title field."
  },
  "aiHints": {
    "analysisContext": "MOD is a simple binary tracker module: fixed 20-byte title, 31 sample descriptors of 30 bytes each, a 130-byte song/order section, a 4-byte format tag, then pattern data and sample PCM data. The format tag at 1080 is the primary structural identifier.",
    "suggestedInspections": [
      "Confirm format tag at offset 1080 is one of the known variants (M.K., M!K!, FLT4, FLT8, 6CHN, 8CHN)",
      "Validate modSongLength is in range 1-128 and that all order table entries reference valid patterns",
      "Check sample length fields against actual file size to detect truncation",
      "Inspect null bytes in sample name fields for steganographic content",
      "Count pattern data size based on highest pattern index in order table vs file size"
    ]
  },
  "formatRelationships": [
    { "format": "XM",  "relationship": "descendant", "description": "XM extends MOD with instruments, envelopes and 16-bit samples" },
    { "format": "S3M", "relationship": "sibling",    "description": "S3M uses a similar cell-based pattern layout with more channels" },
    { "format": "IT",  "relationship": "descendant", "description": "IT is a further evolution with advanced DSP and sample features" }
  ],
  "TechnicalDetails": {
    "endianness": "Big-Endian (Amiga origin)",
    "minimumFileSize": 1084,
    "headerSize": 1084,
    "patternCellSize": 4,
    "rowsPerPattern": 64,
    "maxSamples": 31,
    "maxPatternOrderEntries": 128,
    "sampleEncoding": "Signed 8-bit PCM",
    "specVariants": [ "M.K.", "M!K!", "FLT4", "FLT8", "6CHN", "8CHN", "CD81", "OKTA" ]
  },
  "QualityMetrics": {
    "CompletenessScore": 91,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team",
    "KnownLimitations": "Pattern count derived from max(orderTable)+1; exact sample offsets require cumulative size calculation."
  }
}




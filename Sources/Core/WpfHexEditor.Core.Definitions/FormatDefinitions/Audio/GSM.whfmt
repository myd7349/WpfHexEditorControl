{
  "diffMode": "binary",
  "formatName": "GSM 06.10 Audio",
  "version": "1.0",
  "extensions": [".gsm"],
  "description": "GSM 06.10 is a speech compression standard developed for digital cellular networks. Files consist of a raw sequence of 33-byte frames with no file-level header or magic bytes. Each frame begins with a byte whose upper nibble must equal 0xD (1101 in binary), serving as the only identification marker. The lower nibble carries the first 4 bits of encoded LPC parameters. GSM 06.10 encodes 160 samples of 8 kHz audio (20ms) per 33-byte frame at a fixed 13 kbps bitrate. The absence of a file header makes detection purely heuristic based on frame structure.",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": {
    "specifications": [
      "ETSI EN 300 961: Digital cellular telecommunications system — Full rate speech; Transcoding (GSM 06.10)",
      "ITU-T G.711 and G.728 related voice codec standards"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/Full_Rate",
      "https://www.etsi.org/deliver/etsi_en/300900_300999/300961/"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "D0",
        "offset": 0,
        "label": "GSM frame marker — upper nibble 0xD at offset 0",
        "weight": 0.7
      }
    ],
    "matchMode": "First",
    "MinimumScore": 0.4,
    "required": [],
    "Strength": "Medium",
    "EntropyHint": {
      "min": 4.0,
      "max": 7.5,
      "comment": "GSM encoded speech has moderate entropy; low values indicate silence frames"
    },
    "validation": {
      "notes": "Upper nibble of byte 0 must be 0xD; file size should be a multiple of 33 bytes"
    }
  },
  "variables": {
    "firstFrameByte": 0,
    "frame1byte2": 0,
    "frame1end": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "firstFrameByte",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "First byte of the first GSM 06.10 frame — upper nibble must be 0xD (binary 1101), serving as the only frame sync marker; lower nibble carries the first 4 LPC coefficient bits",
      "storeAs": "firstFrameByte",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "frame1byte2",
      "offset": 1,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.75,
      "description": "Second byte of the first GSM frame — continues LPC parameter encoding; no fixed pattern but part of the 33-byte frame payload that encodes 160 speech samples",
      "storeAs": "frame1byte2",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "frame1end",
      "offset": 32,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.75,
      "description": "Last byte of the first 33-byte GSM frame (offset 32); examining this byte confirms the complete frame structure and correct 33-byte frame boundary alignment",
      "storeAs": "frame1end",
      "valueType": "uint8"
    }
  ],
  "assertions": [
    {
      "field": "firstFrameByte",
      "op": "mask",
      "mask": "0xF0",
      "value": "0xD0",
      "message": "Upper nibble of first byte must be 0xD for valid GSM 06.10 frame"
    },
    {
      "field": "fileSize",
      "op": "modulo",
      "divisor": 33,
      "value": 0,
      "message": "File size must be a multiple of 33 bytes (one frame per 33 bytes)"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "Frame 1 Start", "offset": 0, "length": 1, "color": "#FF6B6B" },

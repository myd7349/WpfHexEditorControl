  "forensic": {
    "category": "Audio",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Upper nibble != 0xD at frame boundary offset indicates frame misalignment or corruption",
      "File size not a multiple of 33 indicates truncation or appended data",
      "All-zero frames indicate silent padding or deliberate erasure of voice data"
    ]
  },
  "aiHints": {
    "analysisContext": "GSM 06.10 has no file-level header — identification is purely structural. Each 33-byte frame starts with a byte whose upper nibble is 0xD. File size divisible by 33 strongly confirms GSM format. At 13 kbps (33 bytes per 20ms), duration = (fileSize / 33) * 0.02 seconds.",
    "suggestedInspections": [
      "Confirm upper nibble of byte 0 is 0xD — the only reliable GSM frame marker",
      "Verify file size is exactly divisible by 33 to confirm frame alignment",
      "Calculate duration: (fileSize / 33) * 20ms per frame gives total speech duration",
      "Walk every 33-byte boundary and verify upper nibble is 0xD for stream validation",
      "Compare against WAV/PCM version if available: GSM is 13 kbps vs 128 kbps PCM",
      "Check for embedded GSM in WAV files (format tag 0x0031 in RIFF WAV header)"
    ]
  },
  "software": [

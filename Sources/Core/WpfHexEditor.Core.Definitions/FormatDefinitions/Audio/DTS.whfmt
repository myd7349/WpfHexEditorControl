{
  "diffMode": "binary",
  "formatName": "DTS Audio",
  "version": "1.14",
  "extensions": [
    ".dts",
    ".dtshd"
  ],
  "description": "DTS (Digital Theater Systems) Coherent Acoustics — a lossy multi-channel audio codec used in cinema, Blu-ray, DVD, and home theater systems. Raw DTS Core files start with the 32-bit big-endian sync word 0x7FFE8001. The 5-byte frame header (after sync word) contains: FTYPE (frame type), SHORT (short audio frames count), CPF (CRC present flag), NBLKS (audio sample blocks per frame), FSIZE (frame byte count), AMODE (audio channel arrangement), SFREQ (sample rate), RATE (bitrate), and various coding flags. DTS supports up to 5.1 channels (DTS Core) and up to 7.1 channels with DTS-HD Master Audio (lossless extension). DTS-HD files may contain both the DTS Core substream and the DTS-HD extension substream.",
  "category": "Audio",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "audio-viewer",
  "references": {
    "specifications": [
      "ETSI TS 102 114 — DTS Coherent Acoustics Core",
      "DTS Digital Surround Specification",
      "DTS-HD Master Audio Format — Blu-ray Disc Association"
    ],
    "WebLinks": [
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000232.shtml",
      "https://en.wikipedia.org/wiki/DTS_(sound_system)",
      "https://en.wikipedia.org/wiki/DTS-HD_Master_Audio",
      "https://dts.com/"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "7FFE8001", "offset": 0, "label": "DTS Core sync word (big-endian)", "weight": 1.0 },
      { "value": "FE7F0180", "offset": 0, "label": "DTS Core sync word (16-bit LE byte-swapped)", "weight": 0.8 },
      { "value": "1FFFE800", "offset": 0, "label": "DTS Core sync word (14-bit packed)", "weight": 0.7 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.7,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 4.0, "max": 7.5 },
    "validation": {
      "minFileSize": 4,
      "maxSignatureOffset": 0
    }
  },
  "variables": {
    "dtsSyncWord": 0,
    "frameType": 0,
    "nblks": 0,
    "sfreq": 0,
    "amode": 0,
    "rate": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "DTS Core Sync Word",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "DTS Core substream synchronization word 0x7FFE8001 stored as a 32-bit big-endian unsigned integer. This 4-byte sync word marks the beginning of every DTS Core frame. In 16-bit little-endian byte-swapped mode (SPDIF/AES3 transport), the sync word becomes 0xFE7F0180. In 14-bit packed mode (older encoding) it is 0x1FFFE800.",
      "storeAs": "dtsSyncWord",
      "valueType": "uint32",
      "endianness": "big",
      "valueMap": {
        "2147450881": "0x7FFE8001 — DTS Core (big-endian)",
        "4285530112": "0xFF1F80E8 — DTS-HD substream sync (extension)",
        "528446464": "0x1FFFE800 — DTS Core (14-bit packed mode)"
      }
    },
    {
      "type": "field",
      "name": "Frame Header Word",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "First 32-bit big-endian word of the DTS frame header following the sync word. Contains multiple packed bitfields: FTYPE (bit 31, 1=normal/0=termination), SHORT (bits 30-26, number of deficient audio blocks), CPF (bit 25, CRC present), NBLKS (bits 24-18, audio sample blocks per frame: value+1, must be 5/6/7 or 8-127), and upper bits of FSIZE (frame size in bytes).",
      "storeAs": "frameType",
      "valueType": "uint32",
      "endianness": "big",
      "bitfields": [
        {
          "name": "Frame Type (FTYPE)",
          "bits": "31",
          "description": "Frame type: 1 = normal frame, 0 = termination frame (last in sequence)",
          "valueMap": {
            "0": "Termination frame",
            "1": "Normal frame"
          }
        },
        {
          "name": "CRC Present (CPF)",
          "bits": "25",
          "description": "CRC present flag: 1 = CRC-16 appended to core header, 0 = no CRC",
          "valueMap": {
            "0": "No CRC",
            "1": "CRC-16 present"
          }
        }
      ]
    },
    {
      "type": "metadata",
      "name": "DTS Sync Word",
      "variable": "dtsSyncWord",
      "description": "DTS Core substream sync word (0x7FFE8001)"
    }
  ],
  "assertions": [
    {
      "name": "DTS sync word valid",
      "expression": "dtsSyncWord == 2147450881",
      "severity": "error",
      "message": "DTS sync word must be 0x7FFE8001 at offset 0 — not a valid DTS Core audio file"
    }
  ],

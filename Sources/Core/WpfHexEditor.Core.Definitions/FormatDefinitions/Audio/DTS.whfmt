  "formatRelationships": {
    "category": "Audio",
    "extensions": [".dts", ".dtshd"],
    "relatedFormats": ["AC3", "EAC3", "TrueHD"],
    "note": "DTS Core (lossy, up to 5.1ch at 1.5Mbps) is the base layer. DTS-HD High Resolution Audio (lossy extension, up to 6Mbps) and DTS-HD Master Audio (lossless, up to 24.5Mbps) extend the Core stream. Blu-ray requires either TrueHD or DTS-HD MA for lossless audio."
  },

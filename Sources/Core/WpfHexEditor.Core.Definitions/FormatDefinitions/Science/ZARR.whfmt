      "color": "#FF6B6B",
      "opacity": 0.35,
      "description": "First byte of the .zarray or .zgroup metadata file. Expected to be 0x7B ('{') indicating the start of a JSON object. Zarr metadata files are always JSON objects. If this byte is not '{', the file is either a binary chunk file or not a valid Zarr metadata file.",
      "storeAs": "firstByte",
      "valueType": "uint8",
      "valueMap": {
        "123": "0x7B '{' — JSON object start (valid Zarr metadata)"
      }
    },
    {
      "type": "field",
      "name": "JSON Content Start",
      "offset": 0,
      "length": 8,
      "color": "#4ECDC4",
      "opacity": 0.30,
      "description": "First 8 bytes of the Zarr metadata JSON file. For .zarray files these bytes will be part of '{\"zarr_' or '{\"chunks\"' or '{\\n  \"zarr' depending on formatting. For .zgroup files they will be part of '{\"zarr_'. For Zarr v3 zarr.json they start with '{\"zarr_'. Used to distinguish Zarr metadata from other JSON files.",
      "storeAs": "jsonStart",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "JSON Start",
      "variable": "jsonStart",
      "description": "First 8 characters of Zarr JSON metadata file content"
    },
    {
      "type": "metadata",

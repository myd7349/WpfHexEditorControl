  "aiHints": {
    "analysisContext": "NumPy .npy files store exactly one ndarray with a Python dict header describing shape, dtype, and memory order. The header dict is a machine-readable source of all structural information needed to interpret the binary data.",
    "suggestedInspections": [
      "Verify magic 93 4E 55 4D 50 59 at offset 0",
      "Read major version at byte 6 to know if header length is 2 or 4 bytes",
      "Parse header dict string — extract 'descr', 'fortran_order', and 'shape' keys",
      "The 'descr' field is a NumPy dtype string: e.g. '<f4' = LE float32, '>i8' = BE int64",
      "Compute array data size = product(shape) * itemsize and validate against file length",
      "Array data starts at offset 6+2+header_len rounded up to next multiple of 64"
    ]
  }

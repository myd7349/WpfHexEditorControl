{
  "diffMode": "binary",
  "formatName": "NumPy Array",
  "version": "1.14",
  "extensions": [
    ".npy"
  ],
  "description": "NumPy .npy is the standard binary serialization format for a single NumPy ndarray. The format begins with a 6-byte magic (0x93 + ASCII 'NUMPY'), followed by a 1-byte major version (1 or 2), a 1-byte minor version (0), a 2-byte (v1) or 4-byte (v2) little-endian header length, and a Python-literal dictionary describing the array dtype, C/F memory order, and shape tuple. The data follows immediately after the header, padded to 64-byte alignment. The format is platform-independent and supports all NumPy dtypes including structured arrays. .npz files are zip archives of multiple .npy files, each named by variable.",
  "category": "Science",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "NumPy NEP 1 — Simple Format for Binary Storage of Arrays",
      "NumPy v1.26 npy format documentation"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/NumPy",
      "https://numpy.org/doc/stable/reference/generated/numpy.lib.format.html"
    ]
  },
  "detection": {
    "signature": "934E554D5059",
    "offset": 0,
    "required": true,
    "weight": 1.0,
    "validation": {
      "minFileSize": 128,
      "maxSignatureOffset": 0
    }
  },
  "variables": {
    "currentOffset": 0,
    "majorVersion": 0,
    "minorVersion": 0,
    "headerLength": 0,
    "headerDict": "",
    "numpyMagic": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "NumPy Magic",
      "offset": 0,
      "length": 6,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "6-byte NumPy magic sequence: 0x93 followed by ASCII 'NUMPY' (4E 55 4D 50 59) — unambiguously identifies a .npy file",
      "storeAs": "numpyMagic",
      "valueType": "hex"
    },
    {
      "type": "field",
      "name": "Format Version",
      "offset": 6,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.5,
      "description": "Two bytes: major version (byte 6) and minor version (byte 7); v1.0 = 01 00 uses 2-byte header length; v2.0 = 02 00 uses 4-byte header length for large headers",
      "storeAs": "formatVersion",
      "valueType": "bytes"
    },
    {
      "type": "field",
      "name": "Header Length",
      "offset": 8,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.4,
      "description": "Little-endian uint16 (v1.x) or uint32 (v2.x) byte length of the Python dict header string that follows; total header size = 6+2+2+HEADER_LEN padded to 64 bytes",
      "storeAs": "headerLength",
      "valueType": "uint16le"
    },
    {
      "type": "field",
      "name": "Header Dictionary",
      "offset": 10,
      "length": 118,
      "color": "#FFE66D",
      "opacity": 0.35,
      "description": "Python dict literal string containing 'descr' (dtype string), 'fortran_order' (bool), and 'shape' (tuple of ints) — defines the complete array structure",
      "storeAs": "headerDict",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Array Data",
      "offset": 128,
      "length": 0,
      "color": "#A8E6CF",
      "opacity": 0.25,
      "description": "Raw C-contiguous (or Fortran-contiguous) array data in the dtype specified by 'descr', with size = product(shape) * dtype.itemsize bytes",
      "storeAs": "arrayData",
      "valueType": "bytes"
    },
    {
      "type": "metadata",
      "name": "Header Dictionary",
      "variable": "headerDict",
      "description": "Python dict with dtype descriptor, memory order, and shape of the stored ndarray"
    }
  ],
  "assertions": [
    {
      "name": "ValidNumpyMagic",
      "description": "Bytes 0-5 must be 93 4E 55 4D 50 59 — the NumPy array magic constant; any deviation means the file is not a valid .npy array file",
      "offset": 0,
      "length": 6,
      "expectedHex": "934E554D5059",
      "severity": "error"
    },
    {
      "name": "ValidMajorVersion",
      "description": "Byte 6 must be 0x01 or 0x02; version 1 uses 2-byte header length, version 2 uses 4-byte header length for very large header dicts",
      "offset": 6,
      "length": 1,
      "validValues": [
        "01",
        "02"
      ],
      "severity": "warning"
    }
  ],

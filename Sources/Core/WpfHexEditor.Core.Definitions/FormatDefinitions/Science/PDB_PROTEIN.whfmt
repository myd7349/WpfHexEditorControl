    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Format": "Fixed-width ASCII text, 80 characters per line",
    "Magic": "'HEADER' (48 45 41 44 45 52) at offset 0 — most common first record",
    "Standard": "PDB File Format v3.30 — wwPDB (2008)",
    "Endianness": "N/A (ASCII text format)",
    "LineWidth": "Exactly 80 characters per record line"
  }

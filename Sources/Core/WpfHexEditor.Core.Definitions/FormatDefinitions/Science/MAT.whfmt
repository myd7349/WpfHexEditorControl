{
  "diffMode": "binary",
  "formatName": "MATLAB Data File",
  "version": "1.14",
  "extensions": [
    ".mat"
  ],
  "description": "MATLAB .mat files store workspace variables in a binary format. Version 5 (MAT-file Level 5), introduced in MATLAB 5.0, is the most common binary format. It begins with a 116-byte text description field (padded with spaces), followed by 8 bytes of subsystem data offset, a 2-byte version (0x0100 for level 5), and a 2-byte endian indicator ('MI' for little-endian). Each variable is stored as a data element with a 4-byte type tag, 4-byte byte count, and padded data payload. Supports arrays, cell arrays, structures, characters, and sparse matrices. Version 4 .mat files begin with a simple binary header without the 'MATLAB' string marker.",
  "category": "Science",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "MATLAB MAT-File Format R2023a",
      "MathWorks MAT-File Level 5 Specification"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/MATLAB",
      "https://www.mathworks.com/help/matlab/import_export/mat-file-versions.html"
    ]
  },
  "detection": {
    "signature": "4D41544C414220352E30",
    "offset": 0,
    "required": true,
    "weight": 0.9,
    "validation": {
      "minFileSize": 128,
      "maxSignatureOffset": 0
    }
  },
  "variables": {
    "currentOffset": 0,
    "description": "",
    "version": 0,
    "endianIndicator": "",
    "matlabHeader": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "MATLAB Description",
      "offset": 0,
      "length": 116,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "116-byte text field beginning with 'MATLAB 5.0 MAT-file' followed by optional user text, padded with spaces to exactly 116 bytes",
      "storeAs": "matlabHeader",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Subsystem Data Offset",
      "offset": 116,
      "length": 8,
      "color": "#4ECDC4",
      "opacity": 0.5,
      "description": "8-byte offset to the subsystem-specific data in the file; used by MATLAB internally; zero means no subsystem data",
      "storeAs": "subsystemOffset",
      "valueType": "uint64le"
    },
    {
      "type": "field",
      "name": "File Version",
      "offset": 124,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.4,
      "description": "MAT-file version: 0x0100 (256) for Level 5 files; this value is always 0x0100 in all current MATLAB versions",
      "storeAs": "version",
      "valueType": "uint16le"
    },
    {
      "type": "field",
      "name": "Endian Indicator",
      "offset": 126,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.35,
      "description": "2-byte endian mark: 'MI' (0x4D49) means little-endian (standard x86/ARM); 'IM' (0x494D) means big-endian (uncommon); used to detect byte-swapping on read",
      "storeAs": "endianIndicator",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "First Data Element Header",
      "offset": 128,
      "length": 8,
      "color": "#A8E6CF",
      "opacity": 0.3,
      "description": "First variable element: 4-byte type tag (e.g. 14 = miMATRIX) and 4-byte number of bytes; compressed elements use type 15 (miCOMPRESSED)",
      "storeAs": "firstElementHeader",
      "valueType": "bytes"
    },
    {
      "type": "metadata",
      "name": "File Version",
      "variable": "version",
      "description": "MAT-file level version (0x0100 = Level 5)"
    }
  ],
  "assertions": [
    {
      "name": "ValidMATLABPrefix",
      "description": "Bytes 0-9 must begin with ASCII 'MATLAB 5.0' (4D 41 54 4C 41 42 20 35 2E 30) to confirm a valid Level 5 MAT-file",
      "offset": 0,
      "length": 10,
      "expectedHex": "4D41544C414220352E30",
      "severity": "error"
    },
    {
      "name": "ValidEndianMark",
      "description": "Bytes 126-127 must be 'MI' (4D 49) for standard little-endian MATLAB files; 'IM' indicates big-endian byte-swapped data",
      "offset": 126,
      "length": 2,
      "validValues": [
        "4D49",
        "494D"
      ],
      "severity": "warning"
    }
  ],
  "inspector": {
    "groups": [
      {
        "name": "File Header",
        "fields": [
          {
            "label": "Description Text",
            "offset": 0,
            "length": 116,
            "format": "ascii"
          },
          {
            "label": "Subsystem Offset",
            "offset": 116,
            "length": 8,
            "format": "uint64le"
          },
          {
            "label": "Version",
            "offset": 124,
            "length": 2,
            "format": "hex"
          },
          {
            "label": "Endian Indicator",
            "offset": 126,
            "length": 2,
            "format": "ascii"
          }
        ]
      },
      {
        "name": "First Variable",
        "fields": [
          {
            "label": "Element Type Tag",
            "offset": 128,
            "length": 4,
            "format": "uint32le"
          },
          {
            "label": "Element Byte Count",
            "offset": 132,
            "length": 4,
            "format": "uint32le"
          }
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "MAT File Header",
      "fields": [
        "matlabHeader",
        "version",
        "endianIndicator"
      ]
    }
  ],
  "software": [

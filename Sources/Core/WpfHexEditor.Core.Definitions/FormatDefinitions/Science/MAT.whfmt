  "TechnicalDetails": {
    "endianness": "little-endian (default)",
    "headerSize": 128,
    "level5Version": "0x0100",
    "level73": "HDF5-based, detected by HDF5 magic"
  },
  "forensic": {
    "category": "science",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "MATLAB Level 5 MAT-files are the standard binary workspace format. Level 7.3 files (.mat with HDF5 magic) require HDF5 parsing. Check the endian indicator before reading any multi-byte fields.",
    "suggestedInspections": [
      "Verify bytes 0-9 are 'MATLAB 5.0' to confirm Level 5 format",
      "Read endian indicator at offset 126 to determine byte order for all subsequent reads",
      "Parse first data element type tag at offset 128 — type 15 = miCOMPRESSED (zlib-deflated variables)",
      "For compressed elements, decompress the payload then re-parse as a normal miMATRIX element",
      "Check for Level 7.3 by looking for HDF5 magic (89 48 44 46) at offset 0 — these are .mat v7.3",
      "Enumerate all top-level variables by iterating data element headers throughout the file"
    ]
  }
}

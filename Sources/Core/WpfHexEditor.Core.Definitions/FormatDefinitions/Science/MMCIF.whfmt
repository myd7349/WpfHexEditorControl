  "TechnicalDetails": {
    "Format": "Plain ASCII text, CIF syntax with PDBx/mmCIF dictionary",
    "TagNotation": "Category.item dot notation (e.g. _atom_site.Cartn_x)",
    "MaxAtoms": "No practical limit (replaces 99999-atom PDB format limit)",

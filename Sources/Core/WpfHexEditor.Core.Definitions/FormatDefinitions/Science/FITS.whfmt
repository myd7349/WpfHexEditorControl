  "forensic": {
    "category": "science-data",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Non-standard SIMPLE=F may indicate modified or non-conforming file",
      "Header block not multiple of 2880 bytes indicates corruption"
    ]
  },
  "aiHints": {
    "analysisContext": "FITS uses fixed 80-char ASCII header cards in 2880-byte blocks. Each card: keyword(8B, space-padded) + '= ' + value + ' /' + comment. END card terminates header. Primary HDU mandatory keywords in order: SIMPLE, BITPIX, NAXIS, NAXIS1..NAXISn, then optional keywords, then END. Data starts at next 2880-byte boundary. Multi-extension FITS (MEF): XTENSION keyword starts extension HDUs ('IMAGE','TABLE','BINTABLE'). Big-endian byte order for all numeric data.",
    "suggestedInspections": [
      "Bytes 0-79: SIMPLE card — 'SIMPLE  =                    T' confirms valid standard FITS",
      "Bytes 80-159: BITPIX card — value determines data array element type and byte size",
      "Bytes 160-239: NAXIS card — number of axes determines array dimensionality",
      "Offset 2880: first data pixel — big-endian format per BITPIX value"
    ]
  },
  "software": [
    "SAOImageDS9 (astronomical image viewer)",
    "CFITSIO library (NASA)",
    "Astropy (Python astronomy library)",
    "IRAF (Image Reduction and Analysis Facility)",
    "Fv (FITS viewer, NASA HEASARC)",
    "ESO MIDAS"
  ],
  "formatRelationships": {
    "category": "Science",
    "extensions": [".fits", ".fit", ".fts"],
    "relatedFormats": ["HDF5", "NETCDF", "HDF4"],
    "note": "FITS is the dominant format for astronomical data since 1981. HDF5 is being adopted for next-generation telescopes. VOTable (XML) is used for catalog data in Virtual Observatory contexts."
  },
  "MimeTypes": [
    "image/fits",
    "application/fits"

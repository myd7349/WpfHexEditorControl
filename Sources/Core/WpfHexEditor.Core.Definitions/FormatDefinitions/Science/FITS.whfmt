{
  "diffMode": "binary",
  "formatName": "FITS Astronomical Image",
  "version": "1.0",
  "extensions": [".fits", ".fit", ".fts"],
  "description": "FITS (Flexible Image Transport System) — standard astronomical data format (NASA, 1981, NOST 100-2.0). Magic: 'SIMPLE  =' (53 49 4D 50 4C 45 20 20 3D) at offset 0. Each header block is 2880 bytes = 36 x 80-character cards. Card format: keyword(8B) + '= ' + value + ' /' + comment. Required keywords: SIMPLE=T, BITPIX (bits per pixel: 8,16,32,64,-32,-64), NAXIS, NAXIS1..N, END. Data block follows, also padded to 2880-byte boundaries. BITPIX: 8=uint8, 16=int16 BE, 32=int32 BE, 64=int64 BE, -32=float32 BE, -64=float64 BE. Extensions: IMAGE, TABLE, BINTABLE. Used by Hubble, Chandra, JWST, VLT.",
  "category": "Science",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "FITS Standard 4.0 — NOST 100-2.0",
      "NASA/OSSA Flexible Image Transport System",
      "FITS Standard — IAU FITS Working Group (2018)"
    ],
    "WebLinks": [
      "https://fits.gsfc.nasa.gov/fits_standard.html",
      "https://en.wikipedia.org/wiki/FITS",
      "https://heasarc.gsfc.nasa.gov/docs/heasarc/fits.html"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "53494D504C4520203D",
        "offset": 0,
        "label": "SIMPLE  = — FITS primary header keyword at offset 0",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.9,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 3.0, "max": 7.5 },
    "validation": {
      "minFileSize": 2880,
      "maxSignatureOffset": 0,
      "note": "FITS files always begin with 'SIMPLE  =' (9 bytes). The primary HDU header block is exactly 2880 bytes. Extension HDUs also use 2880-byte blocks."
    }
  },
  "variables": {
    "fitsMagic": "",
    "simpleValue": "",
    "bitpixCard": "",
    "naxisCard": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "FITS Magic (SIMPLE keyword)",
      "offset": 0,
      "length": 9,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "FITS primary header mandatory keyword 'SIMPLE  =' at offset 0 (9 ASCII bytes). The keyword 'SIMPLE' is padded to 8 characters followed by '= ' forming the FITS card key-value separator. A value of 'T' (true) confirms this is a standard FITS file. The FITS card image is exactly 80 characters wide — the remaining 71 bytes contain the value, comment separator '/', and comment text.",
      "storeAs": "fitsMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "SIMPLE Card Value",
      "offset": 9,
      "length": 71,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Remainder of the FITS SIMPLE card (bytes 9-79, 71 ASCII characters). Should contain 'T' (true) indicating conformance to the FITS standard. The card value occupies columns 11-80 of the 80-character card image. A value of 'T' at column 30 is required for a standard FITS file as defined by the IAU FITS Working Group specification.",
      "storeAs": "simpleValue",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "BITPIX Card",
      "offset": 80,
      "length": 80,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "Second FITS header card at offset 80 (80 ASCII bytes). Must be the BITPIX keyword specifying bits per data pixel. Valid values: 8 (uint8), 16 (int16 big-endian), 32 (int32 big-endian), 64 (int64 big-endian), -32 (float32 IEEE 754 big-endian), -64 (float64 IEEE 754 big-endian). Negative BITPIX values indicate IEEE 754 floating-point data.",
      "storeAs": "bitpixCard",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "NAXIS Card",
      "offset": 160,
      "length": 80,
      "color": "#FFE66D",
      "opacity": 0.35,
      "description": "Third FITS header card at offset 160 (80 ASCII bytes). The NAXIS keyword specifies the number of data array dimensions (axes). Valid values: 0 (no data, header-only HDU), 1 (1D spectrum), 2 (2D image), 3 (3D data cube or spectral cube), 4+ (higher-dimensional data such as time series). For standard images, NAXIS=2 is typical.",
      "storeAs": "naxisCard",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "FITS Magic",
      "variable": "fitsMagic",
      "description": "'SIMPLE  =' — FITS primary header keyword confirming FITS format"
    },
    {
      "type": "metadata",
      "name": "SIMPLE Value",
      "variable": "simpleValue",
      "description": "SIMPLE card remainder — should contain 'T' for standard FITS conformance"
    },
    {
      "type": "metadata",
      "name": "BITPIX Card",
      "variable": "bitpixCard",
      "description": "Bits per pixel card — defines data type of the image array"
    },
    {
      "type": "metadata",
      "name": "NAXIS Card",
      "variable": "naxisCard",
      "description": "NAXIS card — number of dimensions in the data array"
    }
  ],
  "assertions": [
    {
      "name": "FITS magic valid",
      "expression": "fitsMagic == 'SIMPLE  ='",
      "severity": "error",
      "message": "FITS file must begin with 'SIMPLE  =' keyword — not a valid FITS file"
    },
    {
      "name": "SIMPLE value is T",
      "expression": "simpleValue contains 'T'",
      "severity": "warning",
      "message": "FITS SIMPLE keyword should be 'T' for standard conformance"
    },
    {
      "name": "BITPIX present",
      "expression": "bitpixCard starts with 'BITPIX'",
      "severity": "error",
      "message": "Second FITS header card must be BITPIX — file structure is invalid"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "Primary HDU Header", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "Primary Data Unit", "offset": 2880, "icon": "\uE8A5", "color": "#4ECDC4" }
    ]
  },
  "inspector": {
    "badge": "fitsMagic",
    "primaryField": "fitsMagic",
    "showQualityScore": true,
    "groups": [
      {
        "title": "FITS Primary Header",
        "icon": "\uE71B",
        "fields": ["fitsMagic", "simpleValue", "bitpixCard", "naxisCard"]
      }

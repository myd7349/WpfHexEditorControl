{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "GRIB Meteorological Data",
  "formatId": "GRIB",
  "version": "1.0.1",
  "extensions": [".grib", ".grb", ".grb2", ".grib2"],
  "description": "GRIdded Binary (GRIB) is a WMO (World Meteorological Organization) standard binary format for meteorological and climate gridded data. Each GRIB message begins with the 4-byte ASCII magic 'GRIB' (0x47524942), followed by message length fields and an edition number. GRIB edition 1 (legacy) uses 6 sections: Section 0 Indicator (magic + total length + edition), Section 1 Product Definition (parameter table, center, process ID, grid, level, date/time), optional Section 2 Grid Definition, optional Section 3 Bitmap, Section 4 Binary Data (packed integers with scale factor and reference value), and Section 5 '7777' end marker. GRIB edition 2 (modern) redesigns the section layout with discipline, category, and product subcategory fields for a broader range of geophysical parameters. GRIB is used globally by NWP centers including NOAA/NCEP (GFS), ECMWF, JMA, DWD, and CMC for forecast product dissemination.",
  "category": "Science",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "WMO Manual on Codes Volume I.2 - GRIB FM 92 Edition 1",
      "WMO Manual on Codes Volume I.2 - GRIB FM 92-XIV Edition 2",
      "NCEP GRIB2 Documentation — https://www.nco.ncep.noaa.gov/pmb/docs/grib2/grib2_doc/"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/GRIB",
      "https://www.nco.ncep.noaa.gov/pmb/docs/grib2/grib2_doc/",
      "https://confluence.ecmwf.int/display/ECC/GRIB+API"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "47524942",
        "offset": 0,
        "label": "'GRIB' ASCII magic — mandatory WMO GRIB message indicator",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.9,
    "Strength": "Strong",
    "EntropyHint": "High — packed integer data with scale factor and reference value encoding"
  },
  "variables": {
    "gribIndicator": "",
    "gribReserved": "",
    "gribDiscipline": 0,
    "gribEdition": 0,
    "gribMessageLength": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "GRIB Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.85,
      "description": "4-byte ASCII magic 'GRIB' (47 52 49 42) — mandatory first 4 bytes of every GRIB edition 1 and edition 2 message per WMO FM 92. This identifier is specified in WMO No. 306 and must appear at the absolute start of each GRIB message.",
      "storeAs": "gribIndicator",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Reserved / Discipline",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.5,
      "description": "Bytes 4-5. GRIB1: 2 reserved bytes (typically 00 00). GRIB2: byte 4 = reserved (0x00), byte 5 = reserved (0x00). Byte 6 = discipline in GRIB2 (moved; see gribDiscipline). In GRIB1, the total message length occupies bytes 4-6 as a 3-byte big-endian integer.",
      "storeAs": "gribReserved",
      "valueType": "hex"
    },
    {
      "type": "field",
      "name": "Discipline (GRIB2)",
      "offset": 6,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.4,
      "description": "GRIB2 byte 6: discipline code identifying the geophysical domain. 0=Meteorological, 1=Hydrological, 2=Land surface, 3=Space, 10=Oceanographic. In GRIB1, this byte is the third byte of the 3-byte total message length field.",
      "storeAs": "gribDiscipline",
      "valueType": "uint8",
      "valueMap": {
        "0": "Meteorological",
        "1": "Hydrological",
        "2": "Land surface",
        "3": "Space",
        "10": "Oceanographic"
      }
    },
    {
      "type": "field",
      "name": "Edition Number",
      "offset": 7,
      "length": 1,
      "color": "#FFE66D",
      "opacity": 0.45,
      "description": "GRIB edition number. 1=GRIB edition 1 (legacy WMO FM 92, widely used for historical datasets). 2=GRIB edition 2 (modern, used by NCEP GFS, ECMWF ERA5, NOAA HRRR). The edition determines the entire section layout and decoding algorithm.",
      "storeAs": "gribEdition",
      "valueType": "uint8",
      "valueMap": {
        "1": "GRIB1 (legacy)",
        "2": "GRIB2 (modern)"
      }
    },
    {
      "type": "field",
      "name": "Total Message Length",
      "offset": 8,
      "length": 8,
      "color": "#C3A6FF",
      "opacity": 0.35,
      "description": "GRIB2: 8-byte big-endian uint64 total message length including all sections. GRIB1: 3-byte BE uint at bytes 4-6 (not at offset 8). The total length includes the 16-byte GRIB2 indicator section, all intermediate sections, and the 4-byte '7777' end marker.",
      "storeAs": "gribMessageLength",
      "valueType": "uint64"
    }
  ],
  "assertions": [
    {
      "name": "ValidGRIBMagic",
      "expression": "gribIndicator == 'GRIB'",
      "severity": "error",
      "message": "Bytes 0-3 are not 'GRIB'. Not a valid GRIB message. Check for file offset or that a preceding GRIB message's 7777 end marker is correctly positioned."
    },
    {
      "name": "EditionInRange",
      "expression": "gribEdition == 1 || gribEdition == 2",
      "severity": "warning",
      "message": "GRIB edition is not 1 or 2. Only editions 1 and 2 are standardized. Use the appropriate GRIB1 or GRIB2 definition."
    },
    {
      "name": "EndMarker7777",
      "expression": "containsPattern('7777')",
      "severity": "info",
      "message": "End marker '7777' not found. GRIB messages must terminate with ASCII '7777' (0x37373737). File may be truncated."
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "GRIB Magic", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "Section 1 (Product)", "offset": 16, "icon": "\uE946", "color": "#4ECDC4" },
      { "name": "Section 4 (Data)", "offset": "dynamic", "icon": "\uE8B7", "color": "#C3A6FF" }
    ]
  },
  "inspector": {
    "badge": "GRIB",
    "primaryField": "gribIndicator",
    "groups": [
      {
        "title": "Section 0 — Indicator",
        "icon": "\uE71B",
        "fields": ["gribIndicator", "gribEdition", "gribMessageLength"]
      },
      {
        "title": "Section 1 — Product Definition",
        "icon": "\uE946",
        "fields": ["gribDiscipline", "parameterCategory", "parameterNumber", "refTime", "levelType"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "GRIB Message Header (JSON)",
      "format": "json",
      "fields": ["magic", "edition", "discipline", "messageLength", "parameterName", "levelType", "referenceTime"]
    },
    {
      "name": "Grid Points (CSV)",
      "format": "csv",
      "fields": ["latitude", "longitude", "value", "level", "referenceTime", "forecastHour"]
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "notes": "Meteorological data only; no PHI. Large files may contain multi-day forecast archives.",
    "suspiciousPatterns": [
      "Missing '7777' end marker (truncated or corrupt GRIB message)",
      "Mismatched declared vs actual grid point count in Section 2",
      "Section lengths summing to more than total message length"
    ]
  },
  "aiHints": {
    "analysisContext": "GRIB binary format. Magic 'GRIB' (4B) at message start. GRIB1 Section 0: magic(4) + totalLength(3B BE uint24) + edition(1B). GRIB2 Section 0: magic(4) + reserved(2) + discipline(1) + edition(1) + totalLength(8B BE uint64). GRIB1 Section 1 (PDS): length(3B) + version(1) + center(1) + process(1) + grid(1) + flags(1) + paramNumber(1) + levelType(1) + levelValue(2) + year/month/day/hour/min(each 1B) + P1/P2(each 1B) + timeRange(1) + ... GRIB2 has Section 1 (Identification), Section 3 (Grid Definition), Section 4 (Product Definition), Section 5 (Data Representation), Section 6 (Bitmap), Section 7 (Data). End: '7777' (0x37373737).",
    "suggestedInspections": [
      "Verify magic 'GRIB' at bytes 0-3 and read edition byte at offset 7 (1=GRIB1, 2=GRIB2)",
      "For GRIB1: read total message length from bytes 4-6 (3-byte BE uint) and validate against file/message size",
      "For GRIB2: read 8-byte BE uint64 total length at bytes 8-15; check discipline at byte 6",
      "In GRIB1 Section 1: read parameter table version and parameter number to identify the meteorological variable",
      "Read level type and level value to determine vertical coordinate (surface, isobaric, sigma, etc.)",
      "Verify end marker '7777' at the last 4 bytes of the message to confirm completeness"
    ]
  },
  "software": [
    "ecCodes (ECMWF C library + Python)",
    "wgrib / wgrib2 (NOAA/NCEP)",
    "cfgrib (Python xarray interface)",
    "CDO (Climate Data Operators)",
    "GDAL (GRIB driver)"
  ],
  "formatRelationships": [
    { "format": "BUFR", "relation": "sibling — WMO standard for observation (non-gridded) data" },
    { "format": "NETCDF", "relation": "alternative — NetCDF widely used for processed climate/reanalysis data" },
    { "format": "HDF_EOS", "relation": "sibling — HDF-EOS used for NASA satellite gridded products" }
  ],
  "MimeTypes": ["application/x-grib", "application/x-grib2", "application/octet-stream"],
  "UseCases": [
    "NWP model output distribution (GFS, ECMWF, ICON, GEM)",
    "Weather forecast product dissemination to national services",
    "Climate reanalysis dataset storage (ERA5, NCEP/NCAR, JRA-55)",
    "Severe weather alert and aviation METAR/TAF data",
    "Ocean wave and storm surge forecast output"
  ],
  "QualityMetrics": {
    "CompletenessScore": 84,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 5,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "endianness": "big-endian",
    "dataEncoding": "packed integer with scale factor and reference value",
    "endMarker": "37373737 (ASCII '7777')",
    "editions": "Edition 1 (3-byte length, 6 sections), Edition 2 (8-byte length, variable sections)",
    "wmoStandard": "FM 92-XIV GRIB"
  },
  "diff": {
    "keyFields": [
      "grib_indicator",
      "grib_discipline",
      "grib_edition",
      "grib_message_length"
    ],
    "ignoreFields": [
      "grib_reserved"
    ],
    "note": "Inferred semantic diff for GRIB. Compare key structural fields; ignore volatile metadata."
  },
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "grib_indicator",
        "mutation": "corrupt_signature",
        "description": "Corrupt magic bytes at offset 0 — parser must reject."
      },
      {
        "field": "grib_discipline",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      },
      {
        "field": "grib_edition",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      },
      {
        "field": "grib_message_length",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      }
    ],
    "note": "Inferred fuzz strategies for GRIB. Hand-tune weights/rates per format if needed."
  }
}




  "aiHints": [
    "ACCDB signature 'Standard ACE Database' (20 bytes) at offset 0 identifies Access 2007+ files",
    "ACE version byte at offset 20: 2=Access 2007, 3=Access 2010, 4=Access 2013, 5=Access 2016+",
    "ACCDB uses 4096-byte pages by default (vs 2048-byte pages in MDB/Jet 3)",
    "ACCDB supports complex data types, multi-valued fields, and attachment fields not available in MDB",
    "Password protection in ACCDB 2007 uses 128-bit AES encryption (stronger than MDB's RC4)"
  ],
  "forensic": {
    "riskLevel": "medium",
    "notes": [
      "ACCDB 2007+ uses 128-bit AES encryption — significantly harder to crack than MDB's RC4",
      "Deleted records may persist in unused page space until a compact operation is run",
      "MSysObjects and MSysACEs system tables contain schema and security ACL data"
    ],
    "suspiciousPatterns": []
  },
  "useCases": [
    "Microsoft Access 2007+ desktop database applications",
    "SharePoint integration with Access web databases",
    "Migration destination from legacy MDB format",
    "Forensic extraction from modern Microsoft Access applications"
  ],
  "technicalDetails": {
    "ACEVersions": { "2": "Access 2007", "3": "Access 2010", "4": "Access 2013", "5": "Access 2016+" },
    "DefaultPageSize": 4096,
    "EncryptionType": "AES 128-bit (Access 2007 default)",
    "MaxDatabaseSize": "2 GB"
  },
  "inspector": {
    "badge": "aceDbSignature",
    "primaryField": "aceDbSignature",
    "showQualityScore": true,
    "groups": [
      {
        "title": "Microsoft Access 2007+ Database",
        "icon": "",
        "fields": [
          "aceDbSignature"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Microsoft Access 2007+ Database Header (JSON)",
      "format": "json",
      "fields": ["aceDbSignature"]
    },
    {
      "name": "ACCDB Header Summary",
      "format": "text",
      "template": "Microsoft Access ACCDB\nSignature: {aceDbSignature}\nPage Size: {pageSize}\nVersion  : {version}"
    }
  ],
  "assertions": [
    {
      "name": "magic valid",
      "expression": "aceDbSignature != 0",
      "severity": "warning",
      "message": "ACCDB magic field is zero — possible detection failure"
    },
    {
      "name": "ACE version in valid range",
      "expression": "version_byte >= 2 && version_byte <= 6",
      "severity": "warning",
      "message": "ACCDB ACE version byte should be between 2 and 6"
    },
    {
      "name": "File size reasonable",
      "expression": "fileSize >= 4096",
      "severity": "error",
      "message": "ACCDB file must be at least one page (4096 bytes)"
    }
  ],
  "diff": {
    "keyFields": [
      "ace_db_signature"
    ],
    "ignoreFields": [],
    "note": "Inferred semantic diff for ACCDB. Compare key structural fields; ignore volatile metadata."
  },
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "ace_db_signature",
        "mutation": "corrupt_signature",
        "description": "Corrupt magic bytes at offset 0 — parser must reject."
      }
    ],
    "note": "Inferred fuzz strategies for ACCDB. Hand-tune weights/rates per format if needed."
  }

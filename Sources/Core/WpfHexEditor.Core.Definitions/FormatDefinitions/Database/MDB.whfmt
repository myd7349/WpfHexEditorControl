{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Microsoft Access Database",
  "formatId": "MDB",
  "version": "1.15",
  "lastUpdated": "2026-05-20",
  "completenessScore": 85,
  "maxSignatureOffset": 15,
  "signatures": [
    {
      "value": "5374616E64617264204A6574204442",
      "offset": 0,
      "label": "Jet DB magic string 'Standard Jet DB'",
      "weight": 1.0,
      "strength": "Strong"
    }
  ],
  "structure": {
    "fields": [
      { "name": "jet_magic", "offset": 0, "size": 15, "type": "ascii", "description": "Jet DB signature string 'Standard Jet DB'" },
      { "name": "version_byte", "offset": 20, "size": 1, "type": "uint8", "description": "Jet engine version: 0=Jet 3, 1=Jet 4 (Access 2000+)" },
      { "name": "page_size", "offset": 22, "size": 2, "type": "uint16le", "description": "Page size in bytes (typically 2048 or 4096)" },
      { "name": "rc4_key", "offset": 24, "size": 4, "type": "bytes", "description": "RC4 encryption key (XOR with 0xC5965A9B for Jet 3)" }
    ]
  },
  "extensions": [
    ".mdb"
  ],
  "description": "Microsoft Access database file (Jet format)",
  "category": "Database",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Microsoft Access Database Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/MDB"
    ]
  },
  "detection": {
    "required": true,
    "validation": {
      "minFileSize": 15,
      "maxSignatureOffset": 1024
    },
    "signatures": [
      {
        "value": "5374616E64617264204A6574204442",
        "offset": 0,
        "label": "MDB magic",
        "weight": 1.0

  },
  "forensic": {
    "category": "database",
    "riskLevel": "medium",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Microsoft Access database file (Jet format)",
    "suggestedInspections": [
      "Verify Microsoft Access Database file header, page size, and version fields",
      "Check B-tree/index page pointers and free page list",
      "Inspect record format, schema tables, and journal state"
    ]
  },
  "navigation": {
    "bookmarks": [
      { "offset": 0, "label": "OLE2 CFB Header", "color": "#E74C3C" },
      { "offset": 512, "label": "First Sector", "color": "#3498DB" },
      { "offset": 1024, "label": "Access Data Pages", "color": "#27AE60" }
    ]
  },
  "aiHints": [
    "MDB signature 'Standard Jet DB' (0x5374616E64617264204A657420444200) is at offset 0",
    "Jet version byte at offset 20: 0=Jet 3.x (Access 97), 1=Jet 4.x (Access 2000–2003)",
    "MDB uses a page-based structure with 2KB pages (Jet 3) or 4KB pages (Jet 4)",
    "RC4 encryption key at offset 24 is XORed with constant 0xC5965A9B for the database password",
    "System tables (MSysObjects, MSysACEs) contain the database schema and security settings"
  ],
  "forensic": {
    "riskLevel": "medium",
    "notes": [
      "MDB files use weak RC4 encryption — passwords are easily recoverable with known tools",
      "Deleted records may be recoverable from unused page space",
      "MSysACEs table contains workgroup security permissions — useful for privilege escalation analysis"
    ],
    "suspiciousPatterns": []
  },
  "useCases": [
    "Microsoft Access 97–2003 desktop database applications",
    "Legacy line-of-business databases on Windows",
    "Data migration source to SQL Server or ACCDB",
    "Forensic extraction of business data from legacy applications"
  ],
  "technicalDetails": {
    "JetVersions": { "0": "Jet 3.x (Access 97)", "1": "Jet 4.x (Access 2000-2003)" },
    "PageSizes": { "Jet3": 2048, "Jet4": 4096 },
    "Encryption": "RC4 (weak, recoverable)"
  },
  "inspector": {
    "badge": "jetDbSignature",
    "primaryField": "jetDbSignature",
    "showQualityScore": true,
    "groups": [
      {
        "title": "Microsoft Access Database",
        "icon": "",
        "fields": [
          "jetDbSignature"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Microsoft Access Database Header (JSON)",
      "format": "json",
      "fields": ["jetDbSignature"]
    },
    {
      "name": "MDB Header Summary",
      "format": "text",
      "template": "Microsoft Access MDB\nSignature: {jetDbSignature}\nPage Size: {pageSize}\nVersion  : {version}"
    }
  ],
  "assertions": [
    {
      "name": "magic valid",
      "expression": "jetDbSignature != 0",
      "severity": "warning",
      "message": "MDB magic field is zero — possible detection failure"
    },
    {
      "name": "Jet version known",
      "expression": "version_byte == 0 || version_byte == 1",
      "severity": "warning",
      "message": "Jet version byte at offset 20 should be 0 (Jet 3) or 1 (Jet 4)"
    },
    {
      "name": "File size reasonable",
      "expression": "fileSize >= 2048",
      "severity": "error",
      "message": "MDB file must be at least one page (2048 bytes)"
    }
  ],
  "diff": {
    "keyFields": [
      "jet_db_signature"
    ],
    "ignoreFields": [],
    "note": "Inferred semantic diff for MDB. Compare key structural fields; ignore volatile metadata."
  },
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "jet_db_signature",
        "mutation": "corrupt_signature",
        "description": "Corrupt magic bytes at offset 0 — parser must reject."
      }
    ],
    "note": "Inferred fuzz strategies for MDB. Hand-tune weights/rates per format if needed."
  }
}



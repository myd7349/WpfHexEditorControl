  },
  "forensic": {
    "category": "database",
    "riskLevel": "medium",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Microsoft Access 97-2003 compiled database format",
    "suggestedInspections": [
      "Verify Microsoft Access Compiled (Legacy) file header, page size, and version fields",
      "Check B-tree/index page pointers and free page list",
      "Inspect record format, schema tables, and journal state"
    ]
  },
  "navigation": {
    "bookmarks": [
      { "offset": 0, "label": "OLE2 CFB Header", "color": "#E74C3C" },
      { "offset": 512, "label": "First Sector", "color": "#3498DB" },
      { "offset": 1024, "label": "Access Compiled Data Pages", "color": "#27AE60" }
    ]
  },
  "aiHints": [
    "MDE is a compiled, locked version of an MDB — VBA source code is removed, only compiled bytecode remains",
    "The signature differs slightly from MDB: 'Standard  Jet' (two spaces) vs MDB's 'Standard Jet DB'",
    "MDE files cannot be modified to change forms or queries — design view is disabled",
    "Data tables in MDE are still readable and editable — only design objects are locked",
    "MDE files use the same page structure as MDB (2KB or 4KB pages depending on Jet version)"
  ],
  "forensic": {
    "riskLevel": "medium",
    "notes": [
      "MDE locks VBA source code but data remains fully accessible",
      "Converting MDE back to MDB source is non-trivial but possible with specialized tools",
      "Data recovery and forensic extraction proceed the same as with MDB files"
    ],
    "suspiciousPatterns": []
  },
  "useCases": [
    "Distributing locked Access applications without exposing source code",
    "Legacy compiled business application databases (Access 97–2003)",
    "Forensic data extraction from compiled Access applications",
    "Migration source to ACCDE or SQL Server"
  ],
  "technicalDetails": {
    "LockType": "VBA bytecode only — data tables remain editable",
    "JetVersion": "Jet 3.x or 4.x",
    "DifferentFromMDB": "Two spaces in signature string vs MDB one space"
  },
  "inspector": {
    "badge": "mdeSignature",
    "primaryField": "mdeSignature",
    "showQualityScore": true,
    "groups": [
      {
        "title": "Microsoft Access Compiled (Legacy)",
        "icon": "",
        "fields": [
          "mdeSignature"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Microsoft Access Compiled (Legacy) Header (JSON)",
      "format": "json",
      "fields": ["mdeSignature"]
    },
    {
      "name": "MDE Header Summary",
      "format": "text",
      "template": "Microsoft Access MDE\nSignature: {mdeSignature}\nPage Size: {pageSize}\nVersion  : {version}"
    }
  ],
  "assertions": [
    {
      "name": "magic valid",
      "expression": "mdeSignature != 0",
      "severity": "warning",
      "message": "MDE magic field is zero — possible detection failure"
    },
    {
      "name": "File size reasonable",
      "expression": "fileSize >= 2048",
      "severity": "error",
      "message": "MDE file must be at least one Jet page (2048 bytes)"
    },
    {
      "name": "Version byte known",
      "expression": "version_byte == 0 || version_byte == 1",
      "severity": "info",
      "message": "Jet version byte at offset 20 should be 0 (Jet 3) or 1 (Jet 4)"
    }
  ],
  "diff": {
    "keyFields": [
      "mde_signature"
    ],
    "ignoreFields": [],
    "note": "Inferred semantic diff for MDE. Compare key structural fields; ignore volatile metadata."
  },
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "mde_signature",
        "mutation": "corrupt_signature",
        "description": "Corrupt magic bytes at offset 0 — parser must reject."
      }
    ],
    "note": "Inferred fuzz strategies for MDE. Hand-tune weights/rates per format if needed."
  }
}



  ],
  "structure": {
    "fields": [
      { "name": "mde_magic", "offset": 0, "size": 13, "type": "ascii", "description": "MDE signature 'Standard  Jet' (two spaces between Standard and Jet)" },
      { "name": "version_byte", "offset": 20, "size": 1, "type": "uint8", "description": "Jet engine version" },
      { "name": "page_size", "offset": 22, "size": 2, "type": "uint16le", "description": "Page size in bytes" }
    ]

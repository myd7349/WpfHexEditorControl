      "https://en.wikipedia.org/wiki/DBF"
    ]
  },
  "detection": {
    "required": true,
    "validation": {
      "minFileSize": 1,
      "maxSignatureOffset": 1024
    },
    "signatures": [
      {
        "value": "03",
        "offset": 0,
        "label": "DBF magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "Strength": "Weak"
  },
  "variables": {
    "currentOffset": 0,
    "pageSize": 0,
    "pageCount": 0,
    "tableCount": 0,
    "version": 0,
    "dbfVersion": 0,
    "lastUpdateDate": "",
    "recordCount": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "DBF Version",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "dBASE III/IV version marker",
      "storeAs": "dbfVersion",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Last Update Date",
      "offset": 1,
      "length": 3,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "YY MM DD",
      "storeAs": "lastUpdateDate",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Record Count",
      "offset": 4,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Number of records",
      "storeAs": "recordCount",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "Page Size",
      "variable": "pageSize",
      "description": "Page Size"
    },
    {
      "type": "metadata",
      "name": "Page Count",
      "variable": "pageCount",
      "description": "Page Count"
    },
    {
      "type": "metadata",
      "name": "Table Count",
      "variable": "tableCount",
      "description": "Table Count"
    },
    {
      "type": "metadata",
      "name": "Version",
      "variable": "version",
      "description": "Version"
    }
  ],

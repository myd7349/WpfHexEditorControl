  "forensic": {
    "category": "medical-records",
    "riskLevel": "high",
    "suspiciousPatterns": [
      "PID segment (Patient Identification): contains name, DOB, SSN, address — HIPAA PHI",
      "PID-3 (Patient ID List): medical record numbers and SSN — critical PHI",
      "OBX segments may contain lab results and diagnoses — HIPAA PHI",
      "MSH-3/MSH-4 (sending application/facility): reveals internal system topology"
    ]
  },
  "aiHints": {
    "analysisContext": "HL7 v2 message structure: segments separated by CR (0x0D). Each segment: 3-letter segment ID + field separator + pipe-delimited fields. MSH fields: MSH-3=SendingApp, MSH-4=SendingFacility, MSH-5=ReceivingApp, MSH-6=ReceivingFacility, MSH-7=DateTime, MSH-9=MessageType (e.g. ADT^A01=Admit, ORU^R01=Lab Result), MSH-10=ControlID, MSH-11=ProcessingID, MSH-12=Version. PID fields: PID-2=PatientID(ext), PID-3=PatientIDList, PID-5=PatientName(PN), PID-7=DOB, PID-8=Sex, PID-11=Address, PID-13=Phone. OBX: OBX-3=ObservationID(CWE), OBX-5=ObservationValue, OBX-6=Units, OBX-7=ReferenceRange, OBX-8=AbnormalFlags, OBX-11=ResultStatus.",
    "suggestedInspections": [
      "Bytes 0-7: 'MSH|^~\\&' — confirms HL7 v2 and encoding characters",
      "Scan for CR (0x0D) segment terminators to count segments in message",
      "Find 'PID|' segment — contains patient PHI including name, DOB, SSN",
      "Find 'OBX|' segments — lab results, vital signs, diagnostic findings"
    ]
  },
  "software": [
    "Mirth Connect (open-source HL7 integration engine)",
    "InterSystems HealthShare",
    "Epic / Cerner EHR systems (HL7 interfaces)",
    "HL7 Inspector (open-source desktop viewer)",

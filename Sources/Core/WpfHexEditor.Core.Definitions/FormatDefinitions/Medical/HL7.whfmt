{
  "diffMode": "text",
  "formatName": "HL7 v2 Message",
  "version": "1.0",
  "extensions": [".hl7", ".txt"],
  "description": "HL7 v2 (Health Level Seven version 2) messaging standard — most widely deployed healthcare data format worldwide. Every message starts with MSH segment: 'MSH|^~\\&|' — MSH followed by field separator '|', encoding characters '^~\\&', then sender application, sending facility, receiving application, receiving facility, date/time, security, message type, message control ID, processing ID, version ID. Segments: MSH (header), PID (patient ID: name, DOB, SSN, address, phone), PV1 (visit info), OBR (observation request), OBX (observation result: lab values, vitals), ADT (admit/discharge/transfer), ORU (observation result unsolicited), ORM (order message). Segment separator: CR (0x0D). Field separator: | (0x7C). Critical PHI: patient name, SSN, address in PID segment.",
  "category": "Medical",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "text-editor",
  "references": {
    "specifications": [
      "HL7 v2.9 Specification — Health Level Seven International",
      "HIPAA Electronic Transactions and Code Sets (45 CFR Part 162)",
      "HL7 v2.x Implementation Guide"
    ],
    "WebLinks": [
      "https://www.hl7.org/implement/standards/product_brief.cfm?product_id=185",
      "https://en.wikipedia.org/wiki/Health_Level_7",
      "https://hl7-definition.caristix.com/"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "4D53487C5E7E5C26",
        "offset": 0,
        "label": "MSH|^~\\& — HL7 v2 message header mandatory start sequence",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.9,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 3.0, "max": 5.5 },
    "validation": {
      "minFileSize": 8,
      "maxSignatureOffset": 0,
      "note": "HL7 v2 messages must begin with 'MSH|^~\\&' (8 bytes). The first 4 bytes identify the segment type (MSH=Message Segment Header) and the next 4 bytes are the encoding characters defining field, component, repetition, escape, and subcomponent separators."
    }
  },
  "variables": {
    "hl7MSH": "",
    "fieldSep": 0,
    "componentSep": 0,
    "repetitionSep": 0,
    "escapeSep": 0,
    "subcompSep": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "HL7 MSH Magic",
      "offset": 0,
      "length": 8,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "HL7 v2 mandatory message header start sequence 'MSH|^~\\&' at offset 0 (8 ASCII bytes). 'MSH' identifies the Message Segment Header. Byte 3 is MSH-1 (field separator), always '|' (0x7C). Bytes 4-7 are MSH-2 (encoding characters): byte 4 = component separator '^' (0x5E), byte 5 = repetition separator '~' (0x7E), byte 6 = escape character '\\' (0x5C), byte 7 = subcomponent separator '&' (0x26). These encoding characters are configurable but '|^~\\&' is the universal standard.",
      "storeAs": "hl7MSH",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Field Separator",
      "offset": 3,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "HL7 v2 field separator character at offset 3 (1 byte, uint8). This is MSH-1 and defines the character used to separate fields within all segments. Standard value: '|' (0x7C = 124 decimal). This character separates all HL7 fields: MSH|SendingApp|SendingFacility|... etc. All subsequent segments in the message use this same field separator character.",
      "storeAs": "fieldSep",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Component Separator",
      "offset": 4,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "HL7 v2 component separator character at offset 4 (1 byte, uint8). First character of MSH-2 (encoding characters). Standard value: '^' (0x5E = 94 decimal). Separates components within a field. Example: PatientName uses components for family name, given name, middle initial, suffix, prefix — e.g. 'SMITH^JOHN^A^JR^DR'. CWE (Coded with Exceptions) fields also use components for code, text, coding system.",
      "storeAs": "componentSep",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Repetition Separator",
      "offset": 5,
      "length": 1,
      "color": "#FFE66D",
      "opacity": 0.35,
      "description": "HL7 v2 repetition separator character at offset 5 (1 byte, uint8). Second character of MSH-2 (encoding characters). Standard value: '~' (0x7E = 126 decimal). Separates multiple occurrences of a repeating field. Example: a patient with multiple phone numbers: '555-1234~555-5678'. Also used in OBX-2 when reporting multiple coded values for the same observation.",
      "storeAs": "repetitionSep",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Escape Character",
      "offset": 6,
      "length": 1,
      "color": "#A8E6CF",
      "opacity": 0.35,
      "description": "HL7 v2 escape character at offset 6 (1 byte, uint8). Third character of MSH-2. Standard value: '\\' (0x5C = 92 decimal). Used to escape special characters within field values. Escape sequences: \\F\\ = field separator, \\S\\ = component separator, \\R\\ = repetition separator, \\E\\ = escape itself, \\T\\ = subcomponent separator, \\Xhexhex\\ = hex data, \\Cxxx\\ = single-byte character set, \\Mxxx\\ = multi-byte character set.",
      "storeAs": "escapeSep",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Subcomponent Separator",
      "offset": 7,
      "length": 1,
      "color": "#FFB347",
      "opacity": 0.35,
      "description": "HL7 v2 subcomponent separator character at offset 7 (1 byte, uint8). Fourth character of MSH-2. Standard value: '&' (0x26 = 38 decimal). Separates subcomponents within a component — used in HD (Hierarchical Designator) and EI (Entity Identifier) data types. Example: Assigning Authority in PID-3 (patient ID list): 'MRN^&2.16.840.1.113883.19.4&ISO'. Less commonly used than field, component, and repetition separators.",
      "storeAs": "subcompSep",
      "valueType": "uint8"
    },
    {
      "type": "metadata",
      "name": "HL7 MSH Header",
      "variable": "hl7MSH",
      "description": "'MSH|^~\\&' — HL7 v2 message start with encoding characters"
    },
    {
      "type": "metadata",
      "name": "Field Separator",
      "variable": "fieldSep",
      "description": "Field separator byte — standard value 0x7C '|'"
    },
    {
      "type": "metadata",
      "name": "Component Separator",
      "variable": "componentSep",
      "description": "Component separator byte — standard value 0x5E '^'"
    },
    {
      "type": "metadata",
      "name": "Subcomponent Separator",
      "variable": "subcompSep",
      "description": "Subcomponent separator byte — standard value 0x26 '&'"
    }
  ],
  "assertions": [
    {
      "name": "HL7 magic valid",
      "expression": "hl7MSH == 'MSH|^~\\&'",
      "severity": "error",
      "message": "HL7 v2 message must begin with 'MSH|^~\\&' — not a valid HL7 v2 message"
    },
    {
      "name": "Field separator is pipe",
      "expression": "fieldSep == 0x7C",
      "severity": "warning",
      "message": "HL7 field separator should be '|' (0x7C) — non-standard separator in use"
    },
    {
      "name": "Component separator is caret",
      "expression": "componentSep == 0x5E",
      "severity": "warning",
      "message": "HL7 component separator should be '^' (0x5E) — non-standard separator in use"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "MSH Segment", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" }
    ]
  },
  "inspector": {

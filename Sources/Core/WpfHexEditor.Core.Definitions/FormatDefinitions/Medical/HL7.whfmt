    "NHapi (.NET HL7 library)"
  ],
  "formatRelationships": {
    "category": "Medical",
    "extensions": [".hl7", ".txt"],
    "relatedFormats": ["DICOM", "FHIR"],
    "note": "HL7 v2 is being gradually replaced by HL7 FHIR (Fast Healthcare Interoperability Resources, REST/JSON-based). HL7 v3/CDA (Clinical Document Architecture) uses XML. DICOM handles imaging; HL7 handles clinical messages, orders, results, and ADT events. ANSI X12 EDI is used for billing (837P, 835 remittance)."
  },
  "MimeTypes": [
    "application/hl7-v2",
    "text/plain"
  ],
  "UseCases": [

  "aiHints": {
    "analysisContext": "AFNI .HEAD is a plain-text file with 'type = X\\ncount = N\\nvalue_N = ...' attribute blocks. The DATASET_DIMENSIONS attribute gives nx/ny/nz. BYTEORDER_STRING specifies endianness of the .BRIK data. BRICK_TYPES integer codes map to voxel data types (1=short, 3=float, etc.).",
    "suggestedInspections": [
      "Verify .HEAD file starts with 'type =' ASCII prefix",
      "Parse DATASET_DIMENSIONS for nx/ny/nz voxel counts",
      "Read BYTEORDER_STRING to determine .BRIK endianness",
      "Check BRICK_TYPES for voxel data type per sub-brick",
      "Inspect BRICK_FLOAT_FACS for per-brick scale factors"
    ]
  },
  "functions": {
    "extractASCIIString": "Parse HEAD attribute key-value pairs"
  }
}

{
  "diffMode": "binary",
  "formatName": "AFNI BRIK/HEAD",
  "version": "1.13",
  "extensions": [
    ".head",
    ".brik"
  ],
  "description": "AFNI BRIK/HEAD is a paired neuroimaging format used by the AFNI (Analysis of Functional NeuroImages) software package. The .HEAD file is a plain-text attribute file containing key-value pairs for dataset metadata; it begins with the ASCII string 'type = ' describing the attribute type. The binary .BRIK file contains raw voxel data. Key attributes in .HEAD include DATASET_DIMENSIONS (x,y,z sizes), BRICK_FLOAT_FACS (scale factors), and ORIGIN/DELTA (voxel origin and spacing). Widely used in fMRI analysis and distributed with AFNI tutorial datasets.",
  "category": "Medical",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": [
    "AFNI BRIK/HEAD Format Documentation",
    "https://afni.nimh.nih.gov/pub/dist/doc/program_help/README.environment.html"
  ],
  "detection": {
    "signature": "7479706520",
    "offset": 0,
    "weight": 0.5,
    "strength": "Moderate",
    "required": true,
    "validation": {
      "minFileSize": 5,
      "maxSignatureOffset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "typeStr": "",
    "datasetDimensions": "",
    "brickType": "",
    "origin": "",
    "delta": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "HEAD Type Prefix",
      "offset": 0,
      "length": 5,
      "color": "#FF6B6B",
      "opacity": 0.6,
      "description": "ASCII 'type ' (0x74797065 20) prefix beginning the first attribute definition in the .HEAD plain-text file",
      "storeAs": "typeStr",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Attribute Name",
      "offset": 5,
      "length": 32,
      "color": "#4ECDC4",
      "opacity": 0.4,
      "description": "The attribute name on the first line, e.g. 'string-attribute', 'integer-attribute', or 'float-attribute'",
      "storeAs": "attrTypeName",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Dataset Dimensions",
      "offset": 0,
      "length": 48,
      "color": "#95E1D3",
      "opacity": 0.4,
      "description": "DATASET_DIMENSIONS attribute: 3 integers specifying nx, ny, nz voxel counts",
      "storeAs": "datasetDimensions",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Origin",
      "offset": 0,
      "length": 48,
      "color": "#FFE66D",
      "opacity": 0.4,
      "description": "ORIGIN attribute: x0, y0, z0 coordinates of the first voxel corner in mm",
      "storeAs": "origin",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Delta",
      "offset": 0,
      "length": 48,
      "color": "#A8DADC",
      "opacity": 0.4,
      "description": "DELTA attribute: dx, dy, dz voxel sizes in mm (may be negative indicating reversed axis)",
      "storeAs": "delta",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Type String",
      "variable": "typeStr",
      "description": "First token of HEAD file (should be 'type')"
    },
    {
      "type": "metadata",
      "name": "Dataset Dimensions",
      "variable": "datasetDimensions",
      "description": "DATASET_DIMENSIONS attribute: nx ny nz"
    },
    {
      "type": "metadata",
      "name": "Delta (Voxel Size)",
      "variable": "delta",
      "description": "DELTA attribute: voxel spacing in mm per axis"
    }
  ],
  "assertions": [
    {
      "name": "HEAD file starts with type",
      "expression": "typeStr == 'type '",
      "severity": "error",
      "message": "AFNI .HEAD files must begin with 'type = ' attribute declaration"
    },
    {
      "name": "File extension is HEAD",
      "expression": "extension == '.head'",
      "severity": "info",
      "message": "AFNI header is a .HEAD text file; paired .BRIK contains binary voxel data"
    }
  ],
  "inspector": {
    "groups": [
      {
        "name": "Format Identity",
        "fields": ["HEAD Type Prefix", "Attribute Name"]
      },
      {
        "name": "Volume Geometry",
        "fields": ["Dataset Dimensions", "Origin", "Delta"]
      },
      {
        "name": "Metadata",
        "fields": ["Type String", "Delta (Voxel Size)"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "AFNI HEAD Summary",
      "fields": ["typeStr", "datasetDimensions", "origin", "delta"]
    }
  ],
  "software": [
    "AFNI (Analysis of Functional NeuroImages)",
    "3d_nii_to_afni conversion scripts",
    "nibabel (Python)",
    "SUMA (AFNI surface mapper)"
  ],
  "formatRelationships": {

    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Format": "NetCDF Classic (MINC1) or HDF5 (MINC2) with MINC-specific variables and attributes",
    "Magic": "CDF\\x01 (43 44 46 01) for MINC1, HDF5 89 48 44 46 for MINC2",
    "Standard": "BIC-MNI MINC specification — McConnell Brain Imaging Centre",
    "Endianness": "big-endian for MINC1 (NetCDF), native for MINC2 (HDF5)",
    "SpatialModel": "Explicit direction cosines + step + start attributes for voxel-to-world transform"
  }

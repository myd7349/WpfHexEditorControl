      "maxSignatureOffset": 1024
    },
    "signatures": [
      {
        "value": "456C6646696C6500",
        "offset": 0,
        "label": "EVTX magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "Strength": "Strong"
  },
  "variables": {
    "currentOffset": 0,
    "timestamp": 0,
    "size": 0,
    "version": "",
    "type": "",
    "evtxMagic": "",
    "oldestChunk": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "EVTX Magic",
      "offset": 0,
      "length": 8,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "ElfFile\\0 signature",
      "storeAs": "evtxMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Oldest Chunk",
      "offset": 8,
      "length": 8,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Oldest chunk number",
      "storeAs": "oldestChunk",
      "valueType": "uint64"
    },
    {
      "type": "metadata",
      "name": "Timestamp",
      "variable": "timestamp",
      "description": "Timestamp"
    },
    {
      "type": "metadata",
      "name": "Size",

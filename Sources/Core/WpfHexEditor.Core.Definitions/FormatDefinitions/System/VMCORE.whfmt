{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "Linux Kernel Crash Dump (vmcore)",
  "formatId": "VMCORE",
  "version": "1.0",
  "diffMode": "binary",
  "extensions": [
    ".vmcore",
    ".kdump"
  ],
  "description": "Linux kernel crash dump files (vmcore) are generated by kdump when the kernel panics. makedumpfile-wrapped vmcores start with 'KDUMP   ' (4B 44 55 4D 50 20 20 20) at offset 0. Raw vmcores without the makedumpfile header are ELF files with magic 0x7F 0x45 0x4C 0x46.",
  "category": "System",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "MimeTypes": [
    "application/octet-stream"
  ],
  "UseCases": [
    "Linux kernel panic root cause analysis",
    "Production system crash investigation with crash utility",
    "Security incident response: kernel exploits and rootkit detection"
  ],
  "references": [
    "https://www.kernel.org/doc/html/latest/admin-guide/kdump/kdump.html",
    "https://github.com/makedumpfile/makedumpfile",
    "https://crash-utility.github.io/"
  ],
  "software": [
    {
      "name": "makedumpfile",
      "url": "https://github.com/makedumpfile/makedumpfile",
      "role": "Creates compressed/filtered kdump images"
    },
    {
      "name": "crash",
      "url": "https://crash-utility.github.io/",
      "role": "Interactive kernel crash dump analyzer"
    },
    {
      "name": "GDB",
      "url": "https://www.gnu.org/software/gdb/",
      "role": "Can analyze vmcore with vmlinux symbol file"
    }
  ],
  "formatRelationships": [
    {
      "format": "ELF",
      "relationship": "Raw vmcores are ELF core dumps (e_type=ET_CORE, 4) of the kernel address space"
    },
    {
      "format": "COREDUMP_ELF",
      "relationship": "vmcore and process core dumps both use ELF format but with different content and context"
    },
    {
      "format": "DMP",
      "relationship": "Windows crash dumps are the equivalent format on Windows (MINIDUMP/FULLDUMP)"
    }
  ],
  "detection": {
    "signatures": [
      {
        "offset": 0,
        "value": "4B44554D5020202020",
        "label": "'KDUMP   ' makedumpfile header magic",
        "weight": 0.9
      },
      {
        "offset": 0,
        "value": "7F454C46",
        "label": "ELF magic — raw vmcore without makedumpfile wrapper",
        "weight": 0.7
      }
    ],
    "matchMode": "any",
    "MinimumScore": 82,
    "Strength": "Strong",
    "EntropyHint": {
      "min": 5.0,
      "max": 8.0,
      "note": "Kernel memory content varies widely; compressed makedumpfile output near 8.0"
    },
    "validation": "First 8 bytes must be 'KDUMP   ' for makedumpfile format, or first 4 bytes 0x7F 'ELF' for raw ELF vmcore. File size is typically hundreds of MB to several GB."
  },
  "variables": [
    {
      "name": "vmcoreMagic",
      "type": "ascii",
      "offset": 0,
      "length": 8,
      "description": "File magic: 'KDUMP   ' for makedumpfile or '\\x7FELF' for raw ELF"
    },
    {
      "name": "vmcoreHeaderVersion",
      "type": "ascii",
      "offset": 8,
      "length": 16,
      "description": "makedumpfile header version string (e.g. 'makedumpfile-1.6')"
    },
    {
      "name": "vmcoreStatus",
      "type": "ascii",
      "offset": 24,
      "length": 8,
      "description": "makedumpfile dump status field"
    }
  ],
  "blocks": [
    {
      "name": "MakedumpfileHeader",
      "offset": 0,
      "length": 4096,
      "description": "makedumpfile disk dump header (4096 bytes): magic, version, header length, block size, dump level, memory bitmaps",
      "fields": [
        {
          "name": "Magic",
          "variable": "vmcoreMagic",
          "offset": 0,
          "length": 8
        },
        {
          "name": "HeaderVersion",
          "variable": "vmcoreHeaderVersion",
          "offset": 8,
          "length": 16
        },
        {
          "name": "Status",
          "variable": "vmcoreStatus",
          "offset": 24,
          "length": 8
        }
      ]
    },
    {
      "name": "ELFHeader",
      "offset": -1,
      "length": -1,
      "description": "ELF header describing program headers and kernel memory segments (for raw vmcore)"
    },
    {
      "name": "KernelMemory",
      "offset": -1,
      "length": -1,
      "description": "Kernel virtual address space contents including stack traces, page tables, and process list"
    },
    {
      "name": "BitmapSection",
      "offset": -1,
      "length": -1,
      "description": "makedumpfile memory bitmap indicating which pages are included in the dump"
    }
  ],
  "assertions": [
    {
      "id": "A1",
      "description": "Magic must be 'KDUMP   ' or ELF 0x7F454C46",
      "expression": "vmcoreMagic starts with 'KDUMP' || vmcoreMagic starts with '\\x7FELF'"
    },
    {
      "id": "A2",
      "description": "File size must be > 1 MB (valid crash dumps are large)",
      "expression": "fileSize > 1048576"
    },
    {
      "id": "A3",
      "description": "Header version must be non-empty for makedumpfile format",
      "expression": "vmcoreHeaderVersion != ''"
    }
  ],
  "navigation": {
    "entryPoint": "MakedumpfileHeader",
    "structure": [
      "MakedumpfileHeader",
      "ELFHeader",
      "KernelMemory",
      "BitmapSection"
    ],
    "notes": "Use 'crash vmlinux vmcore' for interactive analysis. makedumpfile header contains offset to embedded ELF header. Dump level controls included content: 0=all pages, 1=zero pages excluded, 31=kernel-only pages."
  },
  "inspector": {
    "badge": "KDU",
    "primaryField": "vmcoreMagic",
    "groups": [
      {
        "name": "Dump Header",
        "fields": [
          "vmcoreMagic",
          "vmcoreHeaderVersion",
          "vmcoreStatus"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Header Summary CSV",
      "format": "csv",
      "fields": [
        "vmcoreMagic",
        "vmcoreHeaderVersion",
        "vmcoreStatus"
      ]
    },
    {
      "name": "Header Summary JSON",
      "format": "json",
      "fields": [
        "vmcoreMagic",
        "vmcoreHeaderVersion",
        "vmcoreStatus"
      ]
    }
  ],
  "forensic": {
    "riskLevel": "HIGH",
    "notes": "vmcore files contain a complete snapshot of kernel memory at the time of crash. This includes encryption keys in memory, process credentials, network connections, file handles, and potentially sensitive user data from kernel buffers.",
    "suspiciousPatterns": [
      "Kernel panic triggered by unusual module or system call pattern (may indicate exploit attempt)",
      "Process list in kernel memory showing suspicious processes running at time of crash",
      "Network connection table showing unusual remote addresses",
      "Kernel symbol table modifications suggesting rootkit presence at crash time"
    ]
  },
  "aiHints": {
    "analysisContext": "vmcore captures kernel memory at crash time. With matching vmlinux (unstripped kernel binary), the 'crash' tool can show stack traces, process lists, kernel log buffer, and memory allocator state.",
    "suggestedInspections": [
      "Use 'crash' tool with matching vmlinux to decode stack trace from panic CPU register state",
      "Extract kernel log buffer (dmesg) from vmcore to see pre-crash kernel messages",
      "List running processes at crash time using 'ps' command in crash tool to identify suspicious activity",
      "Check module list for unknown or modified kernel modules indicating rootkit presence",
      "Examine network connection table for suspicious connections active at crash time"
    ]
  },
  "TechnicalDetails": {
    "makedumpfileHeaderSize": 4096,
    "dumpLevels": {
      "0": "all pages",
      "1": "exclude zero pages",
      "3": "exclude zero+cache",
      "31": "kernel-only"
    },
    "compressionFormats": [
      "lzo",
      "snappy",
      "zstd"
    ],
    "analysisTools": [
      "crash",
      "gdb",
      "drgn"
    ]
  },
  "QualityMetrics": {
    "CompletenessScore": 85,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  }
}



{
  "diffMode": "binary",
  "formatName": "ELF Core Dump",
  "version": "1.0",
  "extensions": [".core", ".coredump"],
  "description": "ELF Core Dump file (e_type=ET_CORE=4) generated by the Linux/Unix kernel on process signal (SIGSEGV, SIGABRT, SIGQUIT). Contains PT_NOTE segments (registers, process info, mapped files) and PT_LOAD segments (process address space). High forensic value.",
  "category": "System",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "System V ABI — ELF-64 Object File Format",
      "Linux core(5) manual page",
      "GDB internals — ELF core dump format"
    ],
    "WebLinks": [
      "https://man7.org/linux/man-pages/man5/core.5.html",
      "https://en.wikipedia.org/wiki/Core_dump",
      "https://refspecs.linuxbase.org/elf/elf.pdf"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "7F454C46",
        "offset": 0,
        "label": "ELF magic — check e_type at offset 16 for ET_CORE (4) to confirm this is a core dump",
        "weight": 0.6
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.6,
    "required": true,
    "Strength": "Medium",
    "EntropyHint": { "min": 4.0, "max": 8.0 },
    "validation": {
      "minFileSize": 64
    }
  },
  "variables": {
    "elfMagic": "",
    "elfClass": 0,
    "elfData": 0,
    "elfCoreType": 0,
    "elfMachine": 0,
    "elfVersion": 0,
    "elfEntry": 0,
    "elfPhoff": 0,
    "elfPhentsize": 0,
    "elfPhnum": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "ELF Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "0x7F 'E' 'L' 'F' — 4-byte ELF identification magic present in all ELF files regardless of type or architecture. Followed by class, data encoding, version, OS/ABI, and padding bytes in the 16-byte ELF identification header (e_ident).",
      "storeAs": "elfMagic",
      "valueType": "hex",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "ELF Class",
      "offset": 4,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "ELF file class byte. 1 = ELFCLASS32 (32-bit addresses and fields). 2 = ELFCLASS64 (64-bit addresses and fields). Modern Linux systems on x86_64/AArch64 produce 64-bit core dumps. 32-bit processes on 64-bit kernels produce 32-bit cores.",
      "storeAs": "elfClass",
      "valueType": "uint8",
      "endianness": "little",
      "valueMap": {
        "1": "ELFCLASS32 — 32-bit ELF core dump",
        "2": "ELFCLASS64 — 64-bit ELF core dump"
      }
    },
    {
      "type": "field",
      "name": "Data Encoding",
      "offset": 5,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "ELF data encoding. 1 = ELFDATA2LSB (little-endian, x86, ARM, RISC-V LE). 2 = ELFDATA2MSB (big-endian, SPARC, MIPS BE, PowerPC BE). Determines byte order of all multi-byte ELF fields.",
      "storeAs": "elfData",
      "valueType": "uint8",
      "endianness": "little",
      "valueMap": {
        "1": "ELFDATA2LSB — Little-endian (x86_64, ARM, RISC-V)",
        "2": "ELFDATA2MSB — Big-endian (SPARC, MIPS BE, PowerPC)"
      }
    },
    {
      "type": "field",
      "name": "ELF Type (e_type)",
      "offset": 16,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.5,
      "description": "ELF file type as uint16 LE. Must be 4 (ET_CORE) to confirm this is a core dump. Other values: 1=ET_REL (object file), 2=ET_EXEC (executable), 3=ET_DYN (shared library/PIE). This is the definitive discriminator for core dump identification.",
      "storeAs": "elfCoreType",
      "valueType": "uint16",
      "endianness": "little",
      "valueMap": {
        "1": "ET_REL — Relocatable object file",
        "2": "ET_EXEC — Executable file",
        "3": "ET_DYN — Shared library / Position-Independent Executable",
        "4": "ET_CORE — Core dump file"
      }
    },
    {
      "type": "field",
      "name": "Machine Architecture (e_machine)",
      "offset": 18,
      "length": 2,
      "color": "#A8E6CF",
      "opacity": 0.3,
      "description": "Target CPU architecture as uint16 LE. Required for correct register interpretation in PT_NOTE segments. 0x3E=x86_64, 0xB7=AArch64, 0x08=MIPS, 0x14=PowerPC, 0x28=ARM, 0xF3=RISC-V.",
      "storeAs": "elfMachine",
      "valueType": "uint16",
      "endianness": "little",
      "valueMap": {
        "3": "EM_386 — x86 (32-bit)",
        "8": "EM_MIPS — MIPS",
        "20": "EM_PPC — PowerPC 32-bit",
        "21": "EM_PPC64 — PowerPC 64-bit",
        "40": "EM_ARM — ARM 32-bit",
        "62": "EM_X86_64 — x86-64 / AMD64",
        "183": "EM_AARCH64 — ARM 64-bit (AArch64)",
        "243": "EM_RISCV — RISC-V"
      }
    },
    {
      "type": "field",
      "name": "Entry Point (e_entry)",
      "offset": 24,
      "length": 8,
      "color": "#FFE66D",
      "opacity": 0.2,
      "description": "Entry point address. Always 0 in ELF core dumps — there is no executable entry point in a core dump file. Non-zero values here indicate a possible mis-identification as a core dump.",
      "storeAs": "elfEntry",
      "valueType": "uint64",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Program Header Offset (e_phoff)",
      "offset": 32,
      "length": 8,
      "color": "#C5A3FF",
      "opacity": 0.3,
      "description": "File offset of the program header table as uint64 LE. For 64-bit ELF core dumps this is typically 64 (immediately after the ELF header). The program header table lists all PT_NOTE and PT_LOAD segments.",
      "storeAs": "elfPhoff",
      "valueType": "uint64",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Program Header Count (e_phnum)",
      "offset": 50,
      "length": 2,
      "color": "#FF8C94",
      "opacity": 0.3,
      "description": "Number of program header entries as uint16 LE. In a core dump: 1 PT_NOTE segment + N PT_LOAD segments (one per mapped memory region). Large processes may have hundreds of PT_LOAD segments. If e_phnum == 0xFFFF, see PN_XNUM in PT_NULL for the actual count.",
      "storeAs": "elfPhnum",
      "valueType": "uint16",
      "endianness": "little"
    }
  ],
  "assertions": [
    {
      "name": "ELF magic valid",
      "expression": "elfMagic == '7F454C46'",
      "severity": "error",
      "message": "ELF magic 0x7F454C46 not found — not a valid ELF file"
    },
    {
      "name": "e_type is ET_CORE",
      "expression": "elfCoreType == 4",
      "severity": "error",
      "message": "ELF e_type is not 4 (ET_CORE) — this ELF file is not a core dump (may be executable or shared library)"
    },
    {
      "name": "Program header count is positive",
      "expression": "elfPhnum > 0",
      "severity": "error",
      "message": "No program headers found — ELF core dump must have at least one PT_NOTE segment"
    }
  ],
  "navigation": {
    "bookmarks": [
      {
        "name": "ELF Header",
        "offset": 0,
        "icon": "\uE8B7",
        "color": "#FF6B6B"
      },
      {
        "name": "Program Header Table",
        "offsetVar": "elfPhoff",
        "icon": "\uE8A5",
        "color": "#4ECDC4"
      }
    ]
  },
  "inspector": {
    "badge": "elfCoreType",
    "primaryField": "elfMachine",
    "showQualityScore": true,
    "groups": [
      {
        "title": "ELF Identification",
        "icon": "\uE8B7",
        "fields": ["elfMagic", "elfClass", "elfData"]
      },
      {
        "title": "Core Dump Info",
        "icon": "\uE8A5",
        "fields": ["elfCoreType", "elfMachine", "elfPhnum"]
      },
      {
        "title": "Header Layout",
        "icon": "\uE9D9",
        "fields": ["elfPhoff", "elfPhentsize", "elfEntry"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "ELF Core Header (JSON)",
      "format": "json",
      "fields": ["elfMagic", "elfClass", "elfData", "elfCoreType", "elfMachine", "elfPhnum", "elfPhoff", "elfEntry"]
    },
    {
      "name": "ELF Core Summary (text)",
      "format": "text",
      "fields": ["elfClass", "elfMachine", "elfCoreType", "elfPhnum", "elfPhoff"]
    }
  ],
  "forensic": {
    "category": "system",
    "riskLevel": "high",
    "suspiciousPatterns": [
      {
        "name": "Full process memory dump",
        "condition": "true",
        "severity": "warning",
        "description": "ELF core dump contains the complete process address space at crash time. May include passwords, private keys, decrypted data, TLS session secrets, and any other data the process held in memory."
      }
    ],
    "knownExploitVectors": [
      "setuid program core dumps may expose privilege escalation artifacts",
      "Web server cores may contain HTTP request bodies with passwords in POST data",
      "OpenSSL process cores expose private keys and session secrets",
      "Database process cores contain query results including sensitive data fields"
    ]
  },
  "aiHints": {
    "analysisContext": "ELF core dump: 1 PT_NOTE + N PT_LOAD segments. PT_NOTE contains: NT_PRSTATUS (registers at crash per thread), NT_PRPSINFO (process name, PID, UID), NT_SIGINFO (signal that caused crash), NT_FILE (memory-mapped files with offsets), NT_AUXV (auxiliary vector). Use gdb: `gdb program core`.",
    "suggestedInspections": [
      "Load in gdb: `gdb /path/to/program core.PID` then `bt full` for full backtrace with local variables",
      "Read NT_PRPSINFO note for crashed process name, PID, UID, and command line arguments",
      "Examine NT_PRSTATUS for register state (rip/pc = crash address, rsp = stack pointer at crash)",
      "Read NT_FILE note to map virtual addresses to executable and shared library files on disk",
      "Use `readelf -n core` to dump all NOTE entries without loading into gdb"
    ]
  },
  "software": ["gdb", "crash", "eu-readelf", "readelf", "gcore", "volatility", "pwndbg"],
  "formatRelationships": {
    "category": "System",
    "extensions": [".core", ".coredump"],
    "relatedFormats": ["ELF", "VMCORE", "MINIDUMP"]
  },
  "MimeTypes": ["application/x-coredump"],
  "UseCases": [
    "Application crash post-mortem debugging",
    "Security vulnerability research (crash analysis for exploit development)",
    "Forensic investigation of compromised process state",
    "CI/CD automated crash triage and regression testing"
  ],
  "TechnicalDetails": {
    "EType": "ET_CORE = 4",
    "PTNoteContents": "NT_PRSTATUS, NT_PRPSINFO, NT_SIGINFO, NT_FILE, NT_AUXV (per thread and global)",
    "PTLoadSegments": "One per mapped memory region — code, heap, stack, mmap regions",
    "GdbUsage": "`gdb program core` then `bt full`, `info registers`, `x/20xg $rsp`",
    "CorePatternConfig": "/proc/sys/kernel/core_pattern (e.g., 'core.%p' or '/tmp/core_%e_%p')",
    "EType4Confirmation": "Always check e_type==4 to distinguish from ET_EXEC (2) or ET_DYN (3)"
  },
  "QualityMetrics": {
    "CompletenessScore": 85,
    "DocumentationLevel": "comprehensive",
    "BlocksDefined": 8,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  }
}

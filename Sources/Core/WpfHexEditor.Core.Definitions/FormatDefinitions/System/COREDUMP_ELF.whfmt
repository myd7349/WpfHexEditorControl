{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "ELF Process Core Dump",
  "formatId": "COREDUMP_ELF",
  "version": "1.0.1",
  "diffMode": "binary",
  "extensions": [
    ".core",
    ".coredump"
  ],
  "description": "ELF process core dumps are generated by Linux/Unix when a process terminates abnormally. They share the ELF magic (0x7F 0x45 0x4C 0x46) with executables but have e_type=4 (ET_CORE). They contain process memory segments, registers, and thread state at the time of crash.",
  "category": "System",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "MimeTypes": [
    "application/x-core",
    "application/octet-stream"
  ],
  "UseCases": [
    "Application crash analysis and debugging with GDB",
    "Security vulnerability research and exploit development",
    "Forensic memory analysis of crashed processes"
  ],
  "references": [
    "https://man7.org/linux/man-pages/man5/core.5.html",
    "https://refspecs.linuxbase.org/elf/elf.pdf",
    "https://sourceware.org/gdb/current/onlinedocs/gdb.html/Core-File-Generation.html"
  ],
  "software": [
    {
      "name": "GDB",
      "url": "https://www.gnu.org/software/gdb/",
      "role": "Primary tool for analyzing ELF core dumps"
    },
    {
      "name": "eu-stack",
      "url": "https://sourceware.org/elfutils/",
      "role": "elfutils stack trace from core dump"
    },
    {
      "name": "Volatility",
      "url": "https://www.volatilityfoundation.org/",
      "role": "Memory forensics framework for process dumps"
    }
  ],
  "formatRelationships": [
    {
      "format": "ELF",
      "relationship": "Core dumps use ELF container format; distinguished by e_type=4 (ET_CORE)"
    },
    {
      "format": "VMCORE",
      "relationship": "vmcore is a kernel-level ELF core dump; process core dumps contain user-space memory"
    },
    {
      "format": "MINIDUMP",
      "relationship": "Windows equivalent of Unix ELF core dump for process crash state"
    }
  ],
  "detection": {
    "signatures": [
      {
        "offset": 0,
        "value": "7F454C46",
        "label": "ELF magic 0x7F 'ELF'",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 82,
    "Strength": "Strong",
    "EntropyHint": {
      "min": 4.0,
      "max": 8.0,
      "note": "Process memory content varies; stack and heap regions may have high entropy"
    },
    "validation": "Bytes 0-3 must be 0x7F 0x45 0x4C 0x46. ELF type at offset 16 (2B LE) must be 4 (ET_CORE). Architecture class at offset 4: 1=ELF32, 2=ELF64."
  },
  "variables": [
    {
      "name": "coreElfMagic",
      "type": "hex",
      "offset": 0,
      "length": 4,
      "description": "ELF magic: 7F 45 4C 46"
    },
    {
      "name": "coreElfClass",
      "type": "uint8",
      "offset": 4,
      "length": 1,
      "description": "ELF class",
      "valueMap": {
        "1": "ELF32",
        "2": "ELF64"
      }
    },
    {
      "name": "coreElfData",
      "type": "uint8",
      "offset": 5,
      "length": 1,
      "description": "Data encoding",
      "valueMap": {
        "1": "Little-endian",
        "2": "Big-endian"
      }
    },
    {
      "name": "coreElfType",
      "type": "uint16",
      "offset": 16,
      "length": 2,
      "endian": "little",
      "description": "ELF type",
      "valueMap": {
        "1": "ET_REL",
        "2": "ET_EXEC",
        "3": "ET_DYN",
        "4": "ET_CORE (process core dump)"
      }
    }
  ],
  "blocks": [
    {
      "name": "ELFHeader",
      "offset": 0,
      "length": 64,
      "description": "ELF header (64 bytes for ELF64): magic, class, data, type (ET_CORE=4), machine, entry, phoff, shoff, flags, header sizes",
      "fields": [
        {
          "name": "Magic",
          "variable": "coreElfMagic",
          "offset": 0,
          "length": 4
        },
        {
          "name": "Class",
          "variable": "coreElfClass",
          "offset": 4,
          "length": 1
        },
        {
          "name": "Data",
          "variable": "coreElfData",
          "offset": 5,
          "length": 1
        },
        {
          "name": "Type",
          "variable": "coreElfType",
          "offset": 16,
          "length": 2
        }
      ]
    },
    {
      "name": "ProgramHeaders",
      "offset": 64,
      "length": -1,
      "description": "ELF program headers describing memory segments (PT_LOAD) and notes (PT_NOTE)"
    },
    {
      "name": "NoteSegment",
      "offset": -1,
      "length": -1,
      "description": "PT_NOTE segment: process info (NT_PRSTATUS, NT_PRPSINFO, NT_FILE, NT_SIGINFO, NT_AUXV)"
    },
    {
      "name": "MemorySegments",
      "offset": -1,
      "length": -1,
      "description": "PT_LOAD segments containing actual process memory content at crash time"
    }
  ],
  "assertions": [
    {
      "id": "A1",
      "description": "ELF magic must be 0x7F454C46",
      "expression": "coreElfMagic == '7F454C46'"
    },
    {
      "id": "A2",
      "description": "ELF type must be 4 (ET_CORE)",
      "expression": "coreElfType == 4"
    },
    {
      "id": "A3",
      "description": "ELF class must be 1 (ELF32) or 2 (ELF64)",
      "expression": "coreElfClass == 1 || coreElfClass == 2"
    }
  ],
  "navigation": {
    "entryPoint": "ELFHeader",
    "structure": [
      "ELFHeader",
      "ProgramHeaders",
      "NoteSegment",
      "MemorySegments"
    ],
    "notes": "Program header table offset (e_phoff) typically immediately follows ELF header. PT_NOTE (type 4) segment contains process state notes. PT_LOAD (type 1) segments contain memory regions. Use GDB: 'gdb binary corefile' for analysis."
  },
  "inspector": {
    "badge": "CRE",
    "primaryField": "coreElfType",
    "groups": [
      {
        "name": "ELF Identity",
        "fields": [
          "coreElfMagic",
          "coreElfClass",
          "coreElfData",
          "coreElfType"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "ELF Header CSV",
      "format": "csv",
      "fields": [
        "coreElfMagic",
        "coreElfClass",
        "coreElfData",
        "coreElfType"
      ]
    },
    {
      "name": "ELF Header JSON",
      "format": "json",
      "fields": [
        "coreElfMagic",
        "coreElfClass",
        "coreElfData",
        "coreElfType"
      ]
    }
  ],
  "forensic": {
    "riskLevel": "HIGH",
    "notes": "ELF core dumps contain a full snapshot of the process address space at crash time. This may include decrypted secrets, session tokens, passwords in memory, private keys, and sensitive application data.",
    "suspiciousPatterns": [
      "Core dump from a privileged process (setuid/setgid binary) containing credential material",
      "NT_FILE note listing memory-mapped files suggesting injected or unusual shared libraries",
      "Signal info (NT_SIGINFO) showing SIGSEGV at an address matching a known CVE exploitation pattern",
      "Heap memory containing decoded encryption keys or authentication tokens"
    ]
  },
  "aiHints": {
    "analysisContext": "ELF core dumps use PT_NOTE segments to carry process metadata (NT_PRSTATUS for register state, NT_PRPSINFO for process info, NT_FILE for memory-mapped file list) and PT_LOAD segments for memory content. ET_CORE type distinguishes them from executables.",
    "suggestedInspections": [
      "Parse PT_NOTE segment to extract NT_PRSTATUS (register state and signal info) to determine crash reason",
      "Extract NT_PRPSINFO to identify the crashed process name, PID, and UID",
      "Read NT_FILE note to list all memory-mapped files present at crash time (may reveal injected libraries)",
      "Examine NT_SIGINFO to determine exact signal number and fault address triggering the crash",
      "Search PT_LOAD memory segments for string patterns indicating credential material in heap/stack"
    ]
  },
  "TechnicalDetails": {
    "endianness": "From ELF header byte 5 (1=LE, 2=BE)",
    "elfHeaderSize64": 64,
    "programHeaderSize64": 56,
    "etCoreType": 4,
    "noteTypes": {
      "1": "NT_PRSTATUS (register state)",
      "3": "NT_PRPSINFO (process info)",
      "6": "NT_SIGINFO (signal info)",
      "16": "NT_FILE (memory-mapped files)",
      "17": "NT_AUXV (auxiliary vector)"
    }
  },
  "QualityMetrics": {
    "CompletenessScore": 88,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  }
}



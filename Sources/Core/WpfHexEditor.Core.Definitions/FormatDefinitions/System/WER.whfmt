{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "Windows Error Reporting File",
  "formatId": "WER",
  "version": "1.0",
  "diffMode": "text",
  "extensions": [
    ".wer"
  ],
  "description": "Windows Error Reporting (.wer) files are INI-style text files generated by Windows when an application crashes. They begin with a '[Version]' or '[Headers]' section and contain structured crash metadata including fault module, exception code, OS version, and minidump references.",
  "category": "System",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "code-editor",
  "MimeTypes": [
    "text/plain",
    "application/x-wer"
  ],
  "UseCases": [
    "Windows application crash diagnostics and root cause analysis",
    "IT operations monitoring of application reliability",
    "Forensic timeline reconstruction from system fault history"
  ],
  "references": [
    "https://docs.microsoft.com/en-us/windows/win32/wer/about-wer",
    "https://docs.microsoft.com/en-us/windows/win32/wer/wer-reference",
    "https://www.nirsoft.net/utils/app_crash_view.html"
  ],
  "software": [
    {
      "name": "Windows Event Viewer",
      "url": "https://docs.microsoft.com/en-us/windows-server/administration/windows-commands/eventvwr",
      "role": "View WER reports in event log"
    },
    {
      "name": "WinDbg",
      "url": "https://docs.microsoft.com/en-us/windows-hardware/drivers/debugger/debugger-download-tools",
      "role": "Debug minidumps referenced by WER files"
    },
    {
      "name": "AppCrashView (NirSoft)",
      "url": "https://www.nirsoft.net/utils/app_crash_view.html",
      "role": "Parse and display WER report content"
    }
  ],
  "formatRelationships": [
    {
      "format": "DMP",
      "relationship": "WER files often reference a .hdmp or .mdmp minidump file containing the crash dump"
    },
    {
      "format": "INI",
      "relationship": "WER files use an INI-style section/key=value text format"
    },
    {
      "format": "EVTX",
      "relationship": "Windows Event Log (.evtx) records crash events that correspond to WER files"
    }
  ],
  "detection": {
    "signatures": [
      {
        "offset": 0,
        "value": "5B56657273696F6E5D",
        "label": "'[Version]' WER file section header",
        "weight": 0.9
      },
      {
        "offset": 0,
        "value": "5B486561646572735D",
        "label": "'[Headers]' WER file section header",
        "weight": 0.6
      }
    ],
    "matchMode": "any",
    "MinimumScore": 80,
    "Strength": "Medium",
    "EntropyHint": {
      "min": 3.5,
      "max": 5.5,
      "note": "Text INI-style content has moderate entropy"
    },
    "validation": "First byte must be 0x5B ('[') indicating an INI section header. File should contain known WER section names: [Version], [Headers], [ProblemSignatures], [DynamicSignatures], [SystemInformation]."
  },
  "variables": [
    {
      "name": "werFirstSection",
      "type": "ascii",
      "offset": 0,
      "length": 9,
      "description": "First 9 bytes should be '[Version]' or '[Headers]'"
    },
    {
      "name": "werFirstByte",
      "type": "uint8",
      "offset": 0,
      "length": 1,
      "description": "First byte; must be 0x5B ('[') for valid INI section start"
    }
  ],
  "blocks": [
    {
      "name": "VersionSection",
      "offset": 0,
      "length": -1,
      "description": "[Version] section: Signature=WER2.0 line identifying the WER format version"
    },
    {
      "name": "HeadersSection",
      "offset": -1,
      "length": -1,
      "description": "[Headers] section: ProgramName, ProgramVersion, MachineId, OperatingSystem, Lang, etc."
    },
    {
      "name": "ProblemSignatures",
      "offset": -1,
      "length": -1,
      "description": "[ProblemSignatures] section: P1..P10 fields identifying the specific crash parameters"
    },
    {
      "name": "SystemInformation",
      "offset": -1,
      "length": -1,
      "description": "[SystemInformation] section: MachineId, OS version, fault module path and offset"
    }
  ],
  "assertions": [
    {
      "id": "A1",
      "description": "First byte must be '[' (0x5B)",
      "expression": "werFirstByte == 0x5B"
    },
    {
      "id": "A2",
      "description": "First section must be a known WER section name",
      "expression": "werFirstSection starts with '[V' || werFirstSection starts with '[H'"
    },
    {
      "id": "A3",
      "description": "File must contain 'Signature=WER' in version section",
      "expression": "file contains 'Signature=WER'"
    }
  ],
  "navigation": {
    "entryPoint": "VersionSection",
    "structure": [
      "VersionSection",
      "HeadersSection",
      "ProblemSignatures",
      "SystemInformation"
    ],
    "notes": "WER files are plain text with Windows line endings (CRLF). Key sections: [Version] identifies format, [Headers] contains application and machine info, [ProblemSignatures] has P1-P10 crash parameters, [DynamicSignatures] has runtime-collected data."
  },
  "inspector": {
    "badge": "WER",
    "primaryField": "werFirstSection",
    "groups": [
      {
        "name": "File Identity",
        "fields": [
          "werFirstSection",
          "werFirstByte"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Section Summary CSV",
      "format": "csv",
      "fields": [
        "werFirstSection",
        "werFirstByte"
      ]
    },
    {
      "name": "Section Summary JSON",
      "format": "json",
      "fields": [
        "werFirstSection",
        "werFirstByte"
      ]
    }
  ],
  "forensic": {
    "riskLevel": "MEDIUM",
    "notes": "WER files can reveal internal application paths, version numbers, machine identifiers, and crash addresses. They provide timeline evidence for forensic investigations. MachineId field may uniquely identify a system.",
    "suspiciousPatterns": [
      "WER file with unusual application path suggesting unauthorized software",
      "High frequency of WER files for the same application indicating targeted exploitation attempts",
      "FaultOffset matching known vulnerability exploitation patterns",
      "Machine ID mismatch between WER file and current system configuration"
    ]
  },
  "aiHints": {
    "analysisContext": "WER files are INI-format text files. The [ProblemSignatures] section P1-P10 fields encode crash details: P1=application name, P2=version, P3=timestamp, P4=fault module, P5=module version, P6=module timestamp, P7=exception code, P8=fault offset, P9=application path, P10=fault type.",
    "suggestedInspections": [
      "Extract P1 (application name) and P4 (fault module) from [ProblemSignatures] to identify crashing component",
      "Parse P7 (exception code) to classify crash type: 0xC0000005=access violation, 0x80000003=breakpoint, 0xC0000409=stack overflow",
      "Extract MachineId from [SystemInformation] for system identification in forensic timeline",
      "Check [Headers] section for application version and OS build to assess patch level",
      "Correlate fault offset P8 with module base address and known CVE vulnerability offsets"
    ]
  },
  "TechnicalDetails": {
    "encoding": "UTF-16 LE with BOM (0xFF 0xFE) or UTF-8 depending on Windows version",
    "lineEnding": "CRLF (Windows)",
    "sectionFormat": "[SectionName] followed by Key=Value pairs",
    "knownSections": [
      "[Version]",
      "[Headers]",
      "[ProblemSignatures]",
      "[DynamicSignatures]",
      "[SystemInformation]",
      "[OsVersionInformation]"
    ]
  },
  "QualityMetrics": {
    "CompletenessScore": 84,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  }
}



/* ============================================================
   Format:    Windows Minidump
   Category:  System
   Ext:       .dmp, .mdmp
   Editor:    hex-editor
   Desc:      Windows minidump crash file - Compact crash information
   Variables: currentOffset, timestamp, size, version, type, minidumpSignature, numberOfStreams, streamDirectoryRva, checksum, flags
   Detection: signature=4D444D5093A7 @ offset 0
   Updated:   2026-02-24
   ============================================================ */
{
  "diffMode": "binary",
  "formatName": "Windows Minidump",
  "version": "1.12",
  "extensions": [
    ".dmp",
    ".mdmp"
  ],
  "description": "Windows minidump crash file - Compact crash information",
  "category": "System",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Windows Minidump Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/DMP"
    ]
  },
  "detection": {
    "signature": "4D444D5093A7",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 6,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "timestamp": 0,
    "size": 0,
    "version": "",
    "type": "",
    "minidumpSignature": "",
    "numberOfStreams": 0,
    "streamDirectoryRva": 0,
    "checksum": 0,
    "flags": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Minidump Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "MDMP magic bytes",
      "storeAs": "minidumpSignature",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Version",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Minidump version (0x93A7)",
      "storeAs": "version",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Number of Streams",
      "offset": 6,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Count of data streams",
      "storeAs": "numberOfStreams",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Stream Directory RVA",
      "offset": 8,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Offset to stream directory",
      "storeAs": "streamDirectoryRva",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Checksum",
      "offset": 12,
      "length": 4,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "CRC checksum (usually 0)",
      "storeAs": "checksum",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Timestamp",
      "offset": 16,
      "length": 4,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Unix timestamp of dump creation",
      "storeAs": "timestamp",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Flags",
      "offset": 20,
      "length": 8,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Dump type flags",
      "storeAs": "flags",
      "valueType": "uint64"
    },
    {
      "type": "metadata",
      "name": "Timestamp",
      "variable": "timestamp",
      "description": "Timestamp"
    },
    {
      "type": "metadata",
      "name": "Size",
      "variable": "size",
      "description": "Size"
    },
    {
      "type": "metadata",
      "name": "Type",
      "variable": "type",
      "description": "Type"
    }
  ],
  "software": [
    "Common file viewers",
    "Specialized software"
  ],
  "format_relationships": {
    "category": "System",
    "extensions": [
      ".dmp",
      ".mdmp"
    ]
  },
  "MimeTypes": [

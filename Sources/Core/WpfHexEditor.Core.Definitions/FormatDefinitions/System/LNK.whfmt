{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Windows Shortcut",
  "formatId": "LNK",
  "version": "1.15",
  "extensions": [
    ".lnk"
  ],
  "description": "Windows shell link (shortcut)",
  "category": "System",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Windows Shortcut Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/LNK"
    ]
  },
  "detection": {
    "required": true,
    "validation": {
      "minFileSize": 16,
      "maxSignatureOffset": 1024
    },
    "signatures": [
      {
        "value": "4C0000000114020000000000C0000000",
        "offset": 0,
        "label": "LNK magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "Strength": "Strong"
  },
  "variables": {
    "currentOffset": 0,
    "flags": 0,
    "attributes": 0,
    "targetSize": 0,
    "iconIndex": 0,
    "headerSize": 0,
    "linkClsid": "",
    "linkFlags": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "Header Size",
      "offset": 0,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Size of header (0x0000004C = 76 bytes)",
      "storeAs": "headerSize",
      "valueType": "uint32"
    },
    {
      "type": "signature",
      "name": "Link CLSID",
      "offset": 4,
      "length": 16,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Shell link class identifier",
      "storeAs": "linkClsid",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Link Flags",
      "offset": 20,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Shortcut flags",
      "storeAs": "linkFlags",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "Flags",
      "variable": "flags",
      "description": "Flags"
    },
    {
      "type": "metadata",
      "name": "File Attributes",
      "variable": "attributes",
      "description": "File Attributes"
    }
  ],
  "software": [
    "Windows Explorer",
    "LNK analyzers",
    "Forensic tools"
  ],
  "formatRelationships": {
    "microsoft_format": true,
    "shell_link": true,
    "forensic_value": true
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Hex Editor",
    "File Viewer",
    "Archive Manager"
  ],
  "UseCases": [
    "File storage",
    "Data exchange",
    "Archive"
  ],
  "QualityMetrics": {
    "CompletenessScore": 63,
    "DocumentationLevel": "standard",
    "BlocksDefined": 5,
    "ValidationRules": 0,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt32LE": "Read Windows shortcut header",
    "extractUTF8String": "Extract target path"
  },
  "forensic": {
    "category": "system",
    "riskLevel": "medium",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Windows shell link (shortcut)",
    "suggestedInspections": [
      "Verify Windows Shortcut file signature and record/chunk header structure",
      "Check timestamp sequence for gaps or chronological anomalies",
      "Inspect event severity levels and source identifiers"
    ]
  },
  "inspector": {
    "badge": "headerSize",
    "primaryField": "linkClsid",
    "showQualityScore": true,
    "groups": [
      {
        "title": "Windows Shortcut",
        "icon": "",
        "fields": [
          "headerSize",
          "linkClsid",
          "linkFlags"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Windows Shortcut Header (JSON)",
      "format": "json",
      "fields": [
        "headerSize",
        "linkClsid",
        "linkFlags"
      ]
    }
  ],
  "assertions": [
    {
      "name": "magic valid",
      "expression": "headerSize != 0",
      "severity": "warning",
      "message": "LNK magic field is zero — possible detection failure"
    }
  ],
  "diff": {
    "keyFields": [
      "header_size",
      "link_clsid"
    ],
    "ignoreFields": [],
    "note": "Inferred semantic diff for LNK. Compare key structural fields; ignore volatile metadata."
  },
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "link_clsid",
        "mutation": "corrupt_signature",
        "description": "Corrupt magic bytes at offset 4 — parser must reject."
      },
      {
        "field": "header_size",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      }
    ],
    "note": "Inferred fuzz strategies for LNK. Hand-tune weights/rates per format if needed."
  }
}



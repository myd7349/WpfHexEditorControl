{
  "diffMode": "binary",
  "formatName": "Process Monitor Log (PML)",
  "version": "1.0",
  "extensions": [".pml"],
  "description": "Sysinternals Process Monitor binary log format. 'PML_' signature at offset 0. Captures file, registry, network, process, and thread operations with full call stacks. Invaluable for malware analysis, incident response, and software troubleshooting on Windows.",
  "category": "System",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Process Monitor PML format — reverse-engineered documentation",
      "PMParser project — Ben Hawkes / IOActive",
      "Process Monitor Sysinternals documentation — Microsoft"
    ],
    "WebLinks": [
      "https://docs.microsoft.com/en-us/sysinternals/downloads/procmon",
      "https://en.wikipedia.org/wiki/Process_Monitor",
      "https://github.com/eronnen/procmon-parser"
    ]
  },
  "detection": {
    "signatures": [
      {
        "value": "504D4C5F",
        "offset": 0,
        "label": "'PML_' — Process Monitor Log binary format signature at offset 0 (4 bytes)",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 3.0, "max": 6.5 },
    "validation": {
      "minFileSize": 560
    }
  },
  "variables": {
    "pmlSignature": "",
    "pmlVersion": 0,
    "pmlIs64Bit": 0,
    "pmlComputerName": "",
    "pmlSystemRoot": "",
    "pmlEventsOffset": 0,
    "pmlEventsCount": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "PML Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "'PML_' — 4-byte Process Monitor Log binary format signature. Present at the start of every PML file saved by Sysinternals Process Monitor. This signature distinguishes PML from CSV and XML export formats also supported by ProcMon.",
      "storeAs": "pmlSignature",
      "valueType": "ascii",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Format Version",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "PML file format version as uint32 LE. Versions vary by Process Monitor release. Common values: 9 (ProcMon v3.x), 10 (ProcMon v3.8+). Higher versions may include additional fields in event records.",
      "storeAs": "pmlVersion",
      "valueType": "uint32",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Is 64-bit Capture",
      "offset": 8,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Flag indicating whether the capture was made on a 64-bit (1) or 32-bit (0) Windows system. Affects pointer sizes and address widths in event records. Modern captures on Windows 10/11 64-bit will always be 1.",
      "storeAs": "pmlIs64Bit",
      "valueType": "uint8",
      "endianness": "little",
      "valueMap": {
        "0": "32-bit Windows capture",
        "1": "64-bit Windows capture"
      }
    },
    {
      "type": "field",
      "name": "Computer Name",
      "offset": 12,
      "length": 16,
      "color": "#A8E6CF",
      "opacity": 0.3,
      "description": "First 16 bytes of the 32-byte UTF-16 LE computer name of the capturing machine. Identifies which Windows system produced this PML log. Useful when analyzing PML files collected from multiple machines in an incident response engagement.",
      "storeAs": "pmlComputerName",
      "valueType": "utf16le",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Events Count",
      "offset": 552,
      "length": 4,
      "color": "#FF8C94",
      "opacity": 0.3,
      "description": "Total number of captured events in the PML file as uint32 LE. Large PML captures may contain millions of events. This count drives the event table iteration. PML files with 0 events are valid but contain only header information.",
      "storeAs": "pmlEventsCount",
      "valueType": "uint32",
      "endianness": "little"
    }
  ],
  "assertions": [
    {
      "name": "PML signature valid",
      "expression": "pmlSignature == 'PML_'",
      "severity": "error",
      "message": "'PML_' signature not found at offset 0 — not a valid Process Monitor log file"
    },
    {
      "name": "Events count is positive",
      "expression": "pmlEventsCount > 0",
      "severity": "warning",
      "message": "PML file contains 0 events — log may have been saved before any events were captured"
    },
    {
      "name": "Format version is positive",
      "expression": "pmlVersion > 0",
      "severity": "error",
      "message": "PML format version is 0 — invalid or corrupted PML header"
    }
  ],
  "navigation": {
    "bookmarks": [
      {
        "name": "PML Header",
        "offset": 0,
        "icon": "\uE8B7",
        "color": "#FF6B6B"
      },
      {
        "name": "Computer Name",
        "offset": 12,
        "icon": "\uE8A5",
        "color": "#A8E6CF"
      },
      {
        "name": "Events Array",
        "offsetVar": "pmlEventsOffset",
        "icon": "\uE9D9",
        "color": "#4ECDC4"
      }
    ]
  },
  "inspector": {
    "badge": "pmlVersion",
    "primaryField": "pmlEventsCount",
    "showQualityScore": true,
    "groups": [
      {
        "title": "PML Identity",
        "icon": "\uE8B7",
        "fields": ["pmlSignature", "pmlVersion", "pmlIs64Bit"]
      },
      {
        "title": "Capture Context",
        "icon": "\uE8A5",
        "fields": ["pmlComputerName", "pmlSystemRoot"]
      },
      {
        "title": "Event Data",
        "icon": "\uE9D9",
        "fields": ["pmlEventsCount", "pmlEventsOffset"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "PML Header (JSON)",
      "format": "json",
      "fields": ["pmlSignature", "pmlVersion", "pmlIs64Bit", "pmlComputerName", "pmlEventsCount", "pmlEventsOffset"]
    },
    {
      "name": "PML Summary (text)",
      "format": "text",
      "fields": ["pmlVersion", "pmlIs64Bit", "pmlComputerName", "pmlEventsCount"]
    }
  ],
  "forensic": {
    "category": "system",
    "riskLevel": "medium",
    "suspiciousPatterns": [
      {
        "name": "Malware analysis artifact",
        "condition": "true",
        "severity": "info",
        "description": "PML files from malware sandboxes capture the complete behavior of analyzed samples: file drops, registry persistence, C2 network connections, process injection attempts, and privilege escalation sequences."
      }
    ],
    "knownExploitVectors": [
      "PML files may contain sensitive data captured from monitored processes (passwords in registry writes)",
      "Large PML files (GB-scale) may cause memory exhaustion when opened in Process Monitor GUI",
      "Third-party PML parsers may be vulnerable to malformed event record structures"
    ]
  },
  "aiHints": {
    "analysisContext": "PML binary format: header (~560 bytes) + event offset table + event records. Each event: timestamp (FILETIME), PID, TID, process name, operation (RegOpenKey/ReadFile/etc.), path, result (NTSTATUS), detail. Call stacks optionally captured. Use procmon-parser Python library for programmatic access.",
    "suggestedInspections": [
      "Check pmlEventsCount — millions of events suggest broad system capture, not targeted tracing",
      "Filter for operation=='Process Create' events to identify all processes spawned during capture",
      "Look for registry writes to HKLM\\Software\\Microsoft\\Windows\\CurrentVersion\\Run (persistence)",
      "Identify network events (TCP Connect/Send) for C2 communication patterns in malware captures",
      "Search for file write operations creating .exe/.dll/.bat/.ps1 files in temp directories"
    ]
  },
  "software": ["Process Monitor (Sysinternals/Microsoft)", "procmon-parser (Python)", "PMParser", "Windows Sysinternals Suite"],
  "formatRelationships": {
    "category": "System",
    "extensions": [".pml"],
    "relatedFormats": ["ETL", "EVTX", "WER", "CSV"]
  },
  "MimeTypes": ["application/octet-stream"],
  "UseCases": [
    "Malware behavior analysis in Windows sandbox environments",
    "Software installation and deployment troubleshooting",
    "Incident response and forensic investigation on Windows",
    "Application compatibility and permission debugging"
  ],
  "TechnicalDetails": {
    "Signature": "'PML_' (4 bytes) at offset 0",
    "ComputerNameField": "UTF-16 LE at offset 12, 32 bytes (16 chars max)",
    "SystemRootField": "UTF-16 LE at offset 28, 520 bytes (260 chars = MAX_PATH)",
    "EventsCountOffset": "552 (uint32 LE)",
    "EventOperations": "File: ReadFile/WriteFile/CreateFile; Registry: RegOpenKey/RegSetValue; Network: TCP/UDP; Process: Process Create/Exit",
    "FileSize": "Can reach GB-scale for long captures; compressed option available in ProcMon"
  },
  "QualityMetrics": {
    "CompletenessScore": 78,
    "DocumentationLevel": "standard",
    "BlocksDefined": 5,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  }
}

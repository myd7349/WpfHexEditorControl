{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "Sysinternals Process Monitor Log",
  "formatId": "PROCMON_PML",
  "version": "1.0.1",
  "diffMode": "binary",
  "extensions": [
    ".pml"
  ],
  "description": "PML is the binary log format used by Sysinternals Process Monitor (ProcMon) to record process, registry, file system, and network activity on Windows. Files begin with the 4-byte ASCII magic 'PML_' (0x50 0x4D 0x4C 0x5F) followed by architecture, event count, and process count fields.",
  "category": "System",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "MimeTypes": [
    "application/octet-stream"
  ],
  "UseCases": [
    "Malware behavior analysis and Windows process activity monitoring",
    "Software installation or configuration change auditing",
    "Forensic investigation of Windows system activity"
  ],
  "references": [
    "https://docs.microsoft.com/en-us/sysinternals/downloads/procmon",
    "https://github.com/nicowillis/pmlparser",
    "https://github.com/eronnen/procmon-parser"
  ],
  "software": [
    {
      "name": "Process Monitor",
      "url": "https://docs.microsoft.com/en-us/sysinternals/downloads/procmon",
      "role": "Originating Sysinternals tool"
    },
    {
      "name": "procmon-parser",
      "url": "https://github.com/eronnen/procmon-parser",
      "role": "Python library for parsing PML files"
    },
    {
      "name": "pmlparser",
      "url": "https://github.com/nicowillis/pmlparser",
      "role": "PML format parser and converter"
    }
  ],
  "formatRelationships": [
    {
      "format": "CSV",
      "relationship": "ProcMon can export PML logs to CSV; the PML format is the native binary form"
    },
    {
      "format": "XML",
      "relationship": "ProcMon can export PML logs to XML for structured analysis"
    },
    {
      "format": "EVTX",
      "relationship": "Windows Event Log and PML both record system events; PML captures more detail for process activity"
    }
  ],
  "detection": {
    "signatures": [
      {
        "offset": 0,
        "value": "504D4C5F",
        "label": "'PML_' Process Monitor log magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 85,
    "Strength": "Strong",
    "EntropyHint": {
      "min": 3.0,
      "max": 7.0,
      "note": "Binary log with mixed structure and string data"
    },
    "validation": "First 4 bytes must be 50 4D 4C 5F ('PML_'). Architecture at offset 4 must be 1 (x86) or 2 (x64). EventCount at offset 8 must be > 0."
  },
  "variables": [
    {
      "name": "pmlMagic",
      "type": "ascii",
      "offset": 0,
      "length": 4,
      "description": "PML file magic 'PML_'"
    },
    {
      "name": "pmlArch",
      "type": "uint32",
      "offset": 4,
      "length": 4,
      "endian": "little",
      "description": "Architecture",
      "valueMap": {
        "1": "x86 32-bit",
        "2": "x64 64-bit"
      }
    },
    {
      "name": "pmlEventCount",
      "type": "uint32",
      "offset": 8,
      "length": 4,
      "endian": "little",
      "description": "Total number of events recorded"
    },
    {
      "name": "pmlProcessCount",
      "type": "uint32",
      "offset": 16,
      "length": 4,
      "endian": "little",
      "description": "Number of unique processes in the log"
    }
  ],
  "blocks": [
    {
      "name": "FileHeader",
      "offset": 0,
      "length": 64,
      "description": "PML file header: magic, architecture, event count, events offset, process offset, strings offset, icon offset",
      "fields": [
        {
          "name": "Magic",
          "variable": "pmlMagic",
          "offset": 0,
          "length": 4
        },
        {
          "name": "Architecture",
          "variable": "pmlArch",
          "offset": 4,
          "length": 4
        },
        {
          "name": "EventCount",
          "variable": "pmlEventCount",
          "offset": 8,
          "length": 4
        },
        {
          "name": "ProcessCount",
          "variable": "pmlProcessCount",
          "offset": 16,
          "length": 4
        }
      ]
    },
    {
      "name": "EventsArray",
      "offset": -1,
      "length": -1,
      "description": "Array of event records (variable size per event type): timestamp, PID, event class, path, result, detail"
    },
    {
      "name": "ProcessTable",
      "offset": -1,
      "length": -1,
      "description": "Process info table: PID, parent PID, process path, user account, start/exit time"
    },
    {
      "name": "StringsTable",
      "offset": -1,
      "length": -1,
      "description": "Interned strings table for path and process name deduplication"
    }
  ],
  "assertions": [
    {
      "id": "A1",
      "description": "Magic must be 'PML_'",
      "expression": "pmlMagic == 'PML_'"
    },
    {
      "id": "A2",
      "description": "EventCount must be > 0",
      "expression": "pmlEventCount > 0"
    },
    {
      "id": "A3",
      "description": "Architecture must be 1 or 2",
      "expression": "pmlArch == 1 || pmlArch == 2"
    }
  ],
  "navigation": {
    "entryPoint": "FileHeader",
    "structure": [
      "FileHeader",
      "EventsArray",
      "ProcessTable",
      "StringsTable"
    ],
    "notes": "Event offsets array is at the offset stored in the file header. Each event has a variable-length header + event-class-specific body. Process table and strings table offsets are also in the file header."
  },
  "inspector": {
    "badge": "PML",
    "primaryField": "pmlEventCount",
    "groups": [
      {
        "name": "Header",
        "fields": [
          "pmlMagic",
          "pmlArch",
          "pmlEventCount",
          "pmlProcessCount"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Header Summary CSV",
      "format": "csv",
      "fields": [
        "pmlMagic",
        "pmlArch",
        "pmlEventCount",
        "pmlProcessCount"
      ]
    },
    {
      "name": "Header Summary JSON",
      "format": "json",
      "fields": [
        "pmlMagic",
        "pmlArch",
        "pmlEventCount",
        "pmlProcessCount"
      ]
    }
  ],
  "forensic": {
    "riskLevel": "HIGH",
    "notes": "PML logs contain a complete record of process, registry, filesystem, and network operations on the monitored system. This is primary forensic evidence for malware analysis, incident response, and behavior tracking.",
    "suspiciousPatterns": [
      "Processes accessing HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run for persistence",
      "Unsigned processes injecting into system processes (CreateRemoteThread patterns in file access log)",
      "Network events showing connections to unusual IP addresses or domains",
      "File creation events in system directories from non-system processes"
    ]
  },
  "aiHints": {
    "analysisContext": "PML is a binary format with a fixed header pointing to event, process, string, and icon tables. Event classes: Process/Thread (1), Registry (2), File System (3), Network (4), Profiling (5). Each event has a timestamp (FILETIME), PID, TID, event class, path, result code, and detail.",
    "suggestedInspections": [
      "Extract process table to identify all recorded processes with their full paths and parent-child relationships",
      "Filter events by event class to isolate network events for C2 communication analysis",
      "Search file system events for writes to startup/persistence locations (Run keys, startup folder, task scheduler)",
      "Identify registry events for credential-related keys (LSA secrets, SAM, security hive accesses)",
      "Correlate process creation events (event class 1) with network connection events by PID to map process-to-connection"
    ]
  },
  "TechnicalDetails": {
    "endianness": "Little-endian",
    "magicSize": 4,
    "eventClasses": {
      "1": "Process/Thread",
      "2": "Registry",
      "3": "File System",
      "4": "Network",
      "5": "Profiling"
    },
    "timestampFormat": "Windows FILETIME (100-nanosecond intervals since 1601-01-01)"
  },
  "QualityMetrics": {
    "CompletenessScore": 87,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  }
}



{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "Linux Swap Space",
  "formatId": "SWAPFILE",
  "version": "1.0",
  "diffMode": "binary",
  "extensions": [
    ".swap",
    ".swp"
  ],
  "description": "Linux swap space is a dedicated partition or file used for virtual memory paging. Version 2 swap areas contain the string 'SWAPSPACE2\\0' at byte offset 4086 (page size - 10). Version 1 uses 'SWAPSPACE\\0' at offset 4086. The first 1 KiB contains kernel-version-specific header info.",
  "category": "System",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "MimeTypes": [
    "application/octet-stream"
  ],
  "UseCases": [
    "Linux virtual memory extension beyond physical RAM",
    "Hibernation support (suspend-to-disk) on Linux systems",
    "Forensic analysis: swap space may contain sensitive process memory pages"
  ],
  "references": [
    "https://www.kernel.org/doc/html/latest/admin-guide/sysctl/vm.html",
    "https://github.com/torvalds/linux/blob/master/include/linux/swap.h",
    "https://forensicswiki.xyz/wiki/index.php?title=Linux_swap"
  ],
  "software": [
    {
      "name": "mkswap",
      "url": "https://linux.die.net/man/8/mkswap",
      "role": "Formats a partition or file as swap space"
    },
    {
      "name": "swapon",
      "url": "https://linux.die.net/man/8/swapon",
      "role": "Enables a swap partition or file"
    },
    {
      "name": "Volatility",
      "url": "https://www.volatilityfoundation.org/",
      "role": "Memory forensics tool that can analyze swap content"
    }
  ],
  "formatRelationships": [
    {
      "format": "VMCORE",
      "relationship": "vmcore captures kernel memory; swap pages complement this with paged-out process memory"
    },
    {
      "format": "COREDUMP_ELF",
      "relationship": "Process core dumps capture in-RAM memory; swap may hold paged-out segments of the same process"
    }
  ],
  "detection": {
    "signatures": [
      {
        "offset": 4086,
        "value": "5357415053504143453200",
        "label": "'SWAPSPACE2\\0' Linux swap v2 signature",
        "weight": 1.0
      },
      {
        "offset": 4086,
        "value": "5357415053504143450000",
        "label": "'SWAPSPACE\\0' Linux swap v1 signature",
        "weight": 0.8
      }
    ],
    "matchMode": "any",
    "MinimumScore": 82,
    "Strength": "Strong",
    "EntropyHint": {
      "min": 4.0,
      "max": 8.0,
      "note": "Active swap areas have high entropy from paged-out process memory"
    },
    "validation": "Bytes at offset 4086 (10 bytes) must be 'SWAPSPACE2\\0' for v2 or 'SWAPSPACE\\0' for v1. Version at offset 1024 (4B LE) must be 1. LastPage at offset 1028 must be > 0."
  },
  "variables": [
    {
      "name": "swapFirstByte",
      "type": "uint8",
      "offset": 0,
      "length": 1,
      "description": "First byte of swap header area (raw kernel usage, no structured magic at offset 0)"
    },
    {
      "name": "swapVersion",
      "type": "uint32",
      "offset": 1024,
      "length": 4,
      "endian": "little",
      "description": "Swap header version",
      "valueMap": {
        "1": "Linux swap v1"
      }
    },
    {
      "name": "swapLastPage",
      "type": "uint32",
      "offset": 1028,
      "length": 4,
      "endian": "little",
      "description": "Last usable page number (swap size in pages minus 1)"
    },
    {
      "name": "swapBadPages",
      "type": "uint32",
      "offset": 1032,
      "length": 4,
      "endian": "little",
      "description": "Number of bad (unusable) pages"
    }
  ],
  "blocks": [
    {
      "name": "BootPage",
      "offset": 0,
      "length": 1024,
      "description": "First 1 KiB: traditionally unused or containing boot loader area; first 512 bytes may contain Linux sysv UUID"
    },
    {
      "name": "SwapHeader",
      "offset": 1024,
      "length": 3072,
      "description": "swap_header structure: version, last page, bad pages count, UUID, label, and bad page list",
      "fields": [
        {
          "name": "Version",
          "variable": "swapVersion",
          "offset": 0,
          "length": 4
        },
        {
          "name": "LastPage",
          "variable": "swapLastPage",
          "offset": 4,
          "length": 4
        },
        {
          "name": "BadPages",
          "variable": "swapBadPages",
          "offset": 8,
          "length": 4
        }
      ]
    },
    {
      "name": "SignaturePage",
      "offset": 4086,
      "length": 10,
      "description": "Swap signature at end of first page: 'SWAPSPACE2' or 'SWAPSPACE'"
    },
    {
      "name": "SwapPages",
      "offset": 4096,
      "length": -1,
      "description": "Paged-out process memory content (4096-byte pages each)"
    }
  ],
  "assertions": [
    {
      "id": "A1",
      "description": "Version must be 1",
      "expression": "swapVersion == 1"
    },
    {
      "id": "A2",
      "description": "LastPage must be > 0",
      "expression": "swapLastPage > 0"
    },
    {
      "id": "A3",
      "description": "BadPages must be >= 0",
      "expression": "swapBadPages >= 0"
    }
  ],
  "navigation": {
    "entryPoint": "SwapHeader",
    "structure": [
      "BootPage",
      "SwapHeader",
      "SignaturePage",
      "SwapPages"
    ],
    "notes": "Linux swap v1 header is in the second KiB (offset 1024). Signature is at end of first page (offset 4086). Swap pages begin at offset 4096. Each page is 4096 bytes. UUID is at offset 1036 (16 bytes). Label at offset 1052 (16 bytes)."
  },
  "inspector": {
    "badge": "SWP",
    "primaryField": "swapVersion",
    "groups": [
      {
        "name": "Swap Header",
        "fields": [
          "swapFirstByte",
          "swapVersion",
          "swapLastPage",
          "swapBadPages"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Header Summary CSV",
      "format": "csv",
      "fields": [
        "swapVersion",
        "swapLastPage",
        "swapBadPages"
      ]
    },
    {
      "name": "Header Summary JSON",
      "format": "json",
      "fields": [
        "swapFirstByte",
        "swapVersion",
        "swapLastPage",
        "swapBadPages"
      ]
    }
  ],
  "forensic": {
    "riskLevel": "MEDIUM",
    "notes": "Linux swap space may contain plaintext passwords, session tokens, encryption keys, and other sensitive data from paged-out process memory. Even after reboot, swap pages may not be zeroed and prior session data may be recoverable.",
    "suspiciousPatterns": [
      "Swap pages containing recognizable credential patterns (e.g., 'password=', 'token:', 'BEGIN RSA PRIVATE KEY')",
      "Paged-out heap memory from browser processes containing browsing history or form data",
      "Kernel stack frames in swap indicating high memory pressure during potential exploitation",
      "Pages with executable-like content (ELF headers or shellcode patterns) from code injection"
    ]
  },
  "aiHints": {
    "analysisContext": "Linux swap v1 stores a header in the second KiB with version, last page, bad page count, UUID, and label. Individual 4096-byte swap pages begin at offset 4096 and contain paged-out virtual memory from various processes without structural metadata per page.",
    "suggestedInspections": [
      "Read UUID at header offset 1036 (16 bytes) to correlate swap with specific system/volume",
      "Read volume label at header offset 1052 (16 bytes) for human-readable identification",
      "Calculate total swap size from LastPage field: (LastPage + 1) * 4096 bytes",
      "Scan page content for recognizable string patterns indicating sensitive data (passwords, keys, tokens)",
      "Search for ELF magic or x86/ARM shellcode instruction sequences in pages suggesting code injection artifacts"
    ]
  },
  "TechnicalDetails": {
    "endianness": "Little-endian",
    "pageSize": 4096,
    "headerOffset": 1024,
    "signatureOffset": 4086,
    "swapPagesStart": 4096,
    "uuidOffset": 1036,
    "labelOffset": 1052
  },
  "QualityMetrics": {
    "CompletenessScore": 86,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  }
}



{
  "diffMode": "binary",
  "formatName": "Windows Memory Dump",
  "version": "1.14",
  "extensions": [
    ".dmp"
  ],
  "description": "Windows crash dump/minidump file",
  "category": "System",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "Windows Memory Dump Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/DMP"
    ]
  },
  "detection": {
    "required": true,
    "validation": {
      "minFileSize": 6,
      "maxSignatureOffset": 1024
    },
    "signatures": [
      {
        "value": "504147454455",
        "offset": 0,
        "label": "DMP magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "Strength": "Strong"
  },
  "variables": {
    "currentOffset": 0,
    "timestamp": 0,
    "size": 0,
    "version": "",
    "type": "",
    "dumpSignature": "",
    "validDump": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Dump Signature",
      "offset": 0,
      "length": 6,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "PAGEDU or PAGEDUMP",
      "storeAs": "dumpSignature",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Valid Dump",
      "offset": 8,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Dump validation",
      "storeAs": "validDump",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Timestamp",
      "variable": "timestamp",
      "description": "Timestamp"
    },
    {
      "type": "metadata",
      "name": "Size",
      "variable": "size",
      "description": "Size"
    },
    {
      "type": "metadata",
      "name": "Type",
      "variable": "type",
      "description": "Type"
    }
  ],
  "software": [
    "Common file viewers",
    "Specialized software"
  ],
  "formatRelationships": {
    "category": "System",
    "extensions": [
      ".dmp"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Hex Editor",
    "File Viewer",
    "Archive Manager"
  ],
  "UseCases": [
    "File storage",
    "Data exchange",
    "Archive"
  ],
  "QualityMetrics": {
    "CompletenessScore": 57,
    "DocumentationLevel": "standard",
    "BlocksDefined": 5,
    "ValidationRules": 0,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt32LE": "Read system header",
    "extractASCIIString": "Read info"
  },
  "forensic": {
    "category": "system",
    "riskLevel": "medium",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Windows crash dump/minidump file",
    "suggestedInspections": [
      "Verify Windows Memory Dump file signature and record/chunk header structure",
      "Check timestamp sequence for gaps or chronological anomalies",
      "Inspect event severity levels and source identifiers"
    ]
  },
  "inspector": {
    "badge": "dumpSignature",
    "primaryField": "validDump",
    "showQualityScore": true,
    "groups": [
      {
        "title": "Windows Memory Dump",
        "icon": "",
        "fields": [
          "dumpSignature",
          "validDump"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Windows Memory Dump Header (JSON)",
      "format": "json",
      "fields": [
        "dumpSignature",
        "validDump"
      ]
    }
  ],
  "assertions": [
    {
      "name": "magic valid",
      "expression": "dumpSignature != 0",
      "severity": "warning",
      "message": "DMP magic field is zero — possible detection failure"
    }
  ]
}
    },
    {
      "formatId": "note",
      "relation": "MOBI/PRC is the base format; .azw is Amazon's DRM-protected variant. KF8 (Kindle Format 8) extended MOBI to support HTML5/CSS3 content in a dual-format file (.mobi with MOBI6+KF8 sections). Superseded by KFX format on modern Kindle devices.",
      "note": ""
    },
    {
      "formatId": "epub",
      "relation": "equivalent",
      "note": "EPUB is the open standard equivalent ebook format"
    },
    {
      "formatId": "azw3",
      "relation": "successor",
      "note": "AZW3/KF8 is the modern Amazon Kindle format"
    },
    {
      "formatId": "pdf",
      "relation": "alternative",
      "note": "PDF is a common alternative ebook distribution format"
    }
  ],
  "MimeTypes": [
    "application/x-mobipocket-ebook",
    "application/x-mobi8-ebook"
  ],
  "UseCases": [
    "Amazon Kindle eBook delivery",
    "Legacy Mobipocket Reader content",
    "eBook conversion (Calibre source/target)",
    "Digital textbooks and documents"
  ],
  "QualityMetrics": {
    "CompletenessScore": 85,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 12,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-13",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "DocumentFormat": true,
    "Endianness": "big-endian (PDB) + big-endian (MOBI header)",
    "Container": "Palm Database (PDB)",
    "Compression": "PalmDOC LZ77 or Huffdic",
    "HasHeader": true,
    "HeaderSize": "78 bytes PDB header + 8×recordCount bytes record list"
  },
  "diff": {
    "keyFields": [
      "pdb_attributes",
      "pdb_type",
      "record_count"
    ],
    "ignoreFields": [
      "pdb_creator"
    ],
    "note": "Inferred semantic diff for MOBI. Compare key structural fields; ignore volatile metadata."
  },
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "pdb_attributes",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      },
      {
        "field": "pdb_type",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      },
      {
        "field": "pdb_creator",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      },
      {
        "field": "record_count",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      }
    ],
    "note": "Inferred fuzz strategies for MOBI. Hand-tune weights/rates per format if needed."
  },
  "lastUpdated": "2026-05-20",
  "signatures": [
    {

    }
  ],
  "maxSignatureOffset": 68,
  "structure": {
    "fields": [
      {
        "name": "PDBHeader",
        "offset": 0,
        "size": 32,
        "type": "struct",
        "description": "Palm Database header: name[32], attributes, version, creation/modification dates"
      },
      {
        "name": "RecordList",
        "offset": 32,
        "size": -1,
        "type": "struct",
        "description": "Record list: 8 bytes per record (offset+attrs+uniqueID)"
      },
      {
        "name": "PalmDocHeader",
        "offset": -1,
        "size": 16,
        "type": "struct",
        "description": "PalmDOC record 0 header: compression, textLength, recordCount"
      },
      {
        "name": "MobiHeader",
        "offset": -1,
        "size": -1,
        "type": "struct",
        "description": "MOBI header: headerLength, mobiType, textEncoding, uniqueID, fileVersion"
      },
      {
        "name": "EXTHHeader",
        "offset": -1,
        "size": -1,
        "type": "struct",
        "description": "EXTH metadata block: identifier, headerLength, recordCount, followed by EXTH records"
      }

{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Compiled HTML Help",
  "formatId": "CHM",
  "version": "1.13",
  "extensions": [
    ".chm"
  ],
  "description": "Microsoft Compiled HTML Help (CHM) — a proprietary file format for compiled hypertext help systems. Built on the ITSF (ITS File System) container format. The ITSF header starts at offset 0 with the 4-byte magic 'ITSF', followed by a version field (always 3), a header length (always 96 for CHM v3), total content length, an unknown field (usually -1), and a LCID (Windows language identifier). The internal structure contains a virtual file system similar to a FAT-like directory tree, storing compressed HTML content in a proprietary LZX-compressed container ('::DataSpace/NameList', '::DataSpace/Storage/MSCompressed'). CHM files are mounted by hh.exe (Windows HTML Help viewer) and Internet Explorer.",
  "category": "Documents",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ITSF/ITS File System Format — Matthew Russotto's reverse-engineered specification",
      "Microsoft HTML Help 1.4 SDK Documentation",
      "Open-Source ITSF Implementation — chmlib"
    ],
    "WebLinks": [
      "https://www.nongnu.org/chmlib/",
      "https://en.wikipedia.org/wiki/Microsoft_Compiled_HTML_Help",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000448.shtml",
      "http://www.russotto.net/chm/itsfformat.html"
    ]
  },
  "detection": {
    "signature": "49545346",
    "offset": 0,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": {
      "min": 3.5,
      "max": 7.0
    },
    "validation": {
      "minFileSize": 96,
      "note": "CHM signature is 'ITSF' (0x49 0x54 0x53 0x46). Version at offset 4 (LE uint32) should be 3. Header length at offset 8 should be 96 for CHM v3."
    }
  },
  "variables": {
    "itsfSignature": "",
    "version": 0,
    "headerLength": 0,
    "totalLength": 0,
    "unknown": 0,
    "languageID": 0,
    "directoryOffset": 0,
    "contentOffset": 0,
    "isVersion3": false
  },
  "blocks": [
    {
      "type": "signature",
      "name": "ITSF Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "ITSF magic bytes: 'ITSF' (0x49 0x54 0x53 0x46 = ASCII I, T, S, F). ITSF stands for 'ITS File System' — the container format used by Microsoft HTML Help. All CHM files begin with these 4 bytes.",
      "storeAs": "itsfSignature",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "ITSF Version",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "ITSF format version (little-endian uint32). Always 3 for all known CHM files created by Microsoft HTML Help Workshop. Version 2 was used by an older ITS/IT format that was the precursor to CHM.",
      "storeAs": "version",
      "valueType": "uint32",
      "endianness": "little",
      "valueMap": {
        "2": "ITSF v2 — older ITS/IT format (rare)",
        "3": "ITSF v3 — standard CHM (HTML Help Workshop)"
      }
    },
    {
      "type": "field",
      "name": "Header Length",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Total length of the ITSF header in bytes (little-endian uint32). For ITSF version 3, this must be 96. The header contains all the offset and length information to locate the directory listing and content sections.",
      "storeAs": "headerLength",
      "valueType": "uint32",
      "endianness": "little",
      "valueMap": {
        "96": "96 bytes — standard ITSF v3 header"
      }
    },
    {
      "type": "field",
      "name": "Total File Length",
      "offset": 12,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.25,
      "description": "Total length of all file data in bytes (little-endian uint32). Should equal the actual file size on disk. A mismatch may indicate a truncated or corrupted CHM file.",
      "storeAs": "totalLength",
      "valueType": "uint32",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Unknown (-1)",
      "offset": 16,
      "length": 4,
      "color": "#C7CEEA",
      "opacity": 0.2,
      "description": "Unknown field (little-endian int32). Always -1 (0xFFFFFFFF) in all known valid CHM files. May be a reserved field or timestamp related.",
      "storeAs": "unknown",
      "valueType": "uint32",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Language ID (LCID)",
      "offset": 20,
      "length": 4,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "Windows Language Code Identifier (LCID) for the CHM file (little-endian uint32). Determines the system code page used by hh.exe to display content. Common values: 0x0409=English (US), 0x040C=French, 0x0407=German, 0x0411=Japanese.",
      "storeAs": "languageID",
      "valueType": "uint32",
      "endianness": "little",
      "valueMap": {
        "1033": "0x0409 — English (United States)",
        "1036": "0x040C — French (France)",
        "1031": "0x0407 — German (Germany)",
        "1041": "0x0411 — Japanese (Japan)",
        "2052": "0x0804 — Chinese (Simplified)",
        "1028": "0x0404 — Chinese (Traditional)",
        "1049": "0x0419 — Russian"
      }
    },
    {
      "type": "computeFromVariables",
      "name": "Is ITSF v3",
      "expression": "calc:version == 3 && headerLength == 96",
      "storeAs": "isVersion3",
      "description": "True when this is standard ITSF v3 with 96-byte header — all normal CHM files"
    },
    {
      "type": "metadata",
      "name": "ITSF Version",
      "variable": "version",
      "description": "ITSF format version (3 = standard CHM)"
    },
    {
      "type": "metadata",
      "name": "Header Length",
      "variable": "headerLength",
      "description": "ITSF header size in bytes (96 for v3)"
    },
    {
      "type": "metadata",
      "name": "Language ID",
      "variable": "languageID",
      "description": "Windows LCID for content display language"
    },
    {
      "type": "metadata",
      "name": "Total File Length",
      "variable": "totalLength",
      "description": "Declared total file size in bytes"
    }
  ],
  "assertions": [
    {
      "name": "ITSF signature valid",
      "expression": "itsfSignature == 'ITSF'",
      "severity": "error",
      "message": "CHM signature must be 'ITSF' (49 54 53 46) — not a valid CHM file"
    },
    {
      "name": "ITSF version is 3",
      "expression": "version == 3 || version == 2",
      "severity": "warning",
      "message": "ITSF version should be 2 or 3 for known CHM formats"
    },
    {
      "name": "Header length is 96 for v3",
      "expression": "version != 3 || headerLength == 96",
      "severity": "error",
      "message": "ITSF v3 header length must be exactly 96 bytes"
    }
  ],
  "navigation": {
    "bookmarks": [
      {
        "name": "ITSF Header",
        "offset": 0,
        "icon": "",
        "color": "#FF6B6B"
      },
      {
        "name": "Header Body",
        "offset": 24,
        "icon": "",
        "color": "#4ECDC4"
      },
      {
        "name": "File Start",
        "offset": 0,
        "description": "Beginning of file / magic bytes"
      }
    ]
  },
  "inspector": {
    "badge": "version",
    "primaryField": "languageID",
    "showQualityScore": true,
    "groups": [
      {
        "title": "ITSF Header",
        "icon": "",
        "fields": [
          "itsfSignature",
          "version",
          "headerLength",
          "isVersion3"
        ]
      },
      {
        "title": "Content Info",
        "icon": "",
        "fields": [
          "totalLength",
          "languageID",
          "unknown"
        ]
      }
    ],
    "displayFields": [
      "formatName",
      "version",
      "description"
    ],
    "valueMaps": {},
    "tooltips": {}
  },
  "exportTemplates": [
    {
      "name": "CHM ITSF Header (JSON)",
      "format": "json",
      "fields": [
        "itsfSignature",
        "version",
        "headerLength",
        "totalLength",
        "languageID",
        "isVersion3"
      ]
    },
    {
      "name": "Python CHM check",
      "format": "python-bytes",
      "fields": [
        "itsfSignature",
        "version"
      ]
    }
  ],
  "forensic": {
    "category": "document",
    "riskLevel": "high",
    "suspiciousPatterns": [
      {
        "name": "CHM file can execute code",
        "condition": "version == 3",
        "severity": "info",
        "description": "CHM files are rendered by Internet Explorer's Trident engine and can contain JavaScript, VBScript, and ActiveX controls. CHM files have been used to deliver malware (APT actors use CHM files as initial access payloads)."
      },
      {
        "name": "Non-standard ITSF version",
        "condition": "version != 3 && version != 2",
        "severity": "warning",
        "description": "ITSF version is not 2 or 3 — may indicate a corrupt or non-standard CHM file."
      },
      {
        "name": "Header length mismatch",
        "condition": "version == 3 && headerLength != 96",
        "severity": "error",
        "description": "ITSF v3 header length must be 96 bytes. A different value indicates header corruption."
      }
    ],
    "knownExploitVectors": [
      "CHM files render HTML with JavaScript/VBScript in IE's Trident engine — script-based malware delivery",
      "CVE-2010-1885: HtmlHelp shortcut vulnerability — .chm can open arbitrary programs via shortcut object",
      "CHM as APT delivery vector: GrimAgent, Lazarus Group, TA505 used CHM droppers (2021-2023)",
      "CHM can call ShellExecute via script: <OBJECT type='application/x-oleobject' classid='clsid:...'> CreateObject('WScript.Shell').Run(cmd)",
      "Path traversal in CHM internal file names targeting extract-to-disk operations"
    ],
    "notes": [
      "CHM files have historically been used as malware delivery vectors exploiting IE rendering.",
      "ActiveX and JavaScript execution within CHM help files bypass many sandboxing mechanisms.",
      "Zone.Identifier NTFS alternate data stream restricts internet-sourced CHM execution on Windows."
    ]
  },
  "aiHints": [
    "CHM = ITSF v3 container. Header (96B): 'ITSF' (4B) + version (4B LE uint32 = 3) + headerLen (4B = 96) + totalLen (4B) + unknown/timestamp (4B + 4B) + LCID (4B). Offsets 24-55: ITSF Header Section 0 (GUID + offset pair). Offsets 56-87: ITSF Header Section 1 (content section info). Offset 88: LE uint64 directory section offset. Offset 96: LE uint64 content section offset. Internal file system: directory at directoryOffset, LZX-compressed content at contentOffset. Key virtual files: '/#SYSTEM' (CHM metadata), '/#TOPICS' (topic list), '/#WINDOWS' (window definitions), '/#TOCIDX' (TOC), '/$FIftiMain' (full-text search index). Tools: chmlib, extract_chmLib, 7-Zip (can extract CHM), python-chm.",
    "Confirm 'ITSF' at offset 0 (49 54 53 46) and version=3 at offset 4",
    "Check LCID at offset 20 for language identification",
    "Extract internal HTML files and scan for JavaScript/VBScript content",
    "Look for <OBJECT> tags with ActiveX CLSIDs — potential arbitrary code execution",
    "Scan for ShellExecute, CreateObject, WScript.Shell patterns in scripts",
    "Check '/#SYSTEM' internal file for CHM metadata including default topic path",
    "CHM magic is 'ITSF' (49 54 53 46) at offset 0 followed by version number (typically 3).",
    "Internal HTML files may reference ActiveX controls or execute JavaScript with elevated IE trust.",
    "The ITSP B-tree directory lists all internal virtual paths — enumerate for hidden topic files.",
    "LZX compression parameters are in the LZXC reset table; decompression requires Microsoft's algorithm.",
    "CHM files from untrusted sources can exploit CVE-level IE rendering vulnerabilities.",
    "The languageID in the ITSF header (offset 20) identifies the locale of the help system."
  ],
  "software": [
    "Microsoft HTML Help Workshop (creator)",
    "hh.exe (Windows HTML Help viewer)",
    "xCHM (Linux/macOS viewer)",
    "ChmSee",
    "Sumatra PDF (CHM support)",
    "7-Zip (extraction)"
  ],
  "formatRelationships": [
    {
      "formatId": "category",
      "relation": "Documents",
      "note": ""
    },
    {
      "formatId": "extensions",
      "relation": "['.chm']",
      "note": ""
    },
    {
      "formatId": "note",
      "relation": "CHM replaced the older WinHelp (.hlp) format from Windows 98 onward. Rendered by Trident (IE engine) — security context depends on file location (mark-of-the-web). CHM from network shares or internet zones has restricted script execution. Local CHM files execute scripts with full local permissions.",
      "note": ""
    },
    {
      "formatId": "html",
      "relation": "contained",
      "note": "CHM internally stores HTML help topic files"
    },
    {
      "formatId": "hlp",
      "relation": "predecessor",
      "note": "WinHelp (.hlp) is the older Windows help format"
    },
    {
      "formatId": "pdf",
      "relation": "alternative",
      "note": "PDF is commonly used as a modern alternative to CHM"
    }
  ],
  "diff": {
    "keyFields": [
      "itsfSignature",
      "version",
      "headerLength",
      "languageID"
    ],
    "ignoreFields": [
      "unknown",
      "isVersion3"
    ],
    "groupBy": "ITSF Header",
    "note": "Signature, version, and LCID characterize the CHM variant; header length is a fixed structural invariant. The unknown field is always -1 and adds no diff value."
  },
  "repair": [
    {
      "name": "FixItsfSignature",
      "trigger": "itsfSignature != 'ITSF'",
      "action": "set_value",
      "target": "itsfSignature",
      "value": "49545346",
      "description": "Restore the ITSF magic bytes 'ITSF' (49 54 53 46) at offset 0"
    },
    {
      "name": "FixVersion",
      "trigger": "version != 3 && version != 2",
      "action": "set_value",
      "target": "version",
      "value": "03000000",
      "description": "Reset ITSF version to 3 (LE uint32) for standard CHM compatibility"
    },
    {
      "name": "FixHeaderLength",
      "trigger": "version == 3 && headerLength != 96",
      "action": "set_value",
      "target": "headerLength",
      "value": "60000000",
      "description": "Restore header length to 96 bytes (LE uint32 = 0x60) for ITSF v3"
    }
  ],
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "itsfSignature",
        "mutation": "corrupt_signature",
        "weight": 3,
        "description": "Corrupt 'ITSF' magic to test CHM parser rejection of invalid containers"
      },
      {
        "field": "version",
        "mutation": "boundary_values",
        "weight": 2,
        "description": "Test version values (0, 1, 4, 0xFF) to expose version-check edge cases in hh.exe"
      },
      {
        "field": "totalLength",
        "mutation": "overflow",
        "weight": 2,
        "description": "Overflow total file length to stress size validation in CHM loaders"
      },
      {
        "field": "languageID",
        "mutation": "random_bytes",
        "weight": 1,
        "description": "Randomize LCID to test code-page fallback behavior in HTML Help viewer"
      },
      {
        "field": "headerLength",
        "mutation": "bit_flip",
        "rate": 0.001,
        "weight": 1,
        "description": "Flip bits in header length to cause off-by-one directory offset errors"
      }
    ]
  },
  "migration": [
    {
      "from": "ITSF-v2",
      "to": "ITSF-v3",
      "description": "Upgrade older ITS/IT v2 format to standard CHM ITSF v3; header length changes from legacy to 96 bytes",
      "changes": [
        {
          "field": "version",
          "changeType": "set_value",
          "value": "03000000",
          "description": "Set version to 3 (LE uint32) for HTML Help Workshop compatibility"
        },
        {
          "field": "headerLength",
          "changeType": "set_value",
          "value": "60000000",
          "description": "Set header length to 96 bytes (0x60 LE) for ITSF v3 standard"
        }
      ]
    }
  ],
  "MimeTypes": [
    "application/vnd.ms-htmlhelp",
    "application/x-chm"
  ],
  "UseCases": [
    "Windows application help documentation",
    "Software manuals and technical references",
    "Legacy Windows SDK documentation"
  ],
  "QualityMetrics": {
    "CompletenessScore": 85,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 10,
    "ValidationRules": 3,
    "LastUpdated": "2026-04-13",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "DocumentFormat": true,
    "Endianness": "little-endian",
    "Container": "ITSF v3 (ITS File System)",
    "Compression": "LZX (internal content compression)",
    "HasHeader": true,
    "HeaderSize": "96 bytes (ITSF v3)",
    "ScriptCapable": true
  },
  "lastUpdated": "2026-05-20",
  "signatures": [
    {
      "value": "49545346",
      "offset": 0,
      "label": "CHM signature",
      "weight": 100,
      "strength": "strong"
    }
  ],
  "maxSignatureOffset": 4,
  "structure": {
    "fields": [
      {
        "name": "ITSFHeader",
        "offset": 0,
        "size": 96,
        "type": "struct",
        "description": "ITSF header: magic 'ITSF', version(4), headerLen(4), unknown(4), lastModified(8), languageID(4), GUIDs(32), sectionOffset(8), sectionLength(8)"
      },
      {
        "name": "ITSPHeader",
        "offset": -1,
        "size": 84,
        "type": "struct",
        "description": "ITSP directory header within the directory listing section"
      },
      {
        "name": "DirectoryListing",
        "offset": -1,
        "size": -1,
        "type": "struct",
        "description": "B-tree directory of internal file entries with offsets"
      },
      {
        "name": "ContentSection",
        "offset": -1,
        "size": -1,
        "type": "blob",
        "description": "Compressed content section (LZX or uncompressed)"
      },
      {
        "name": "HTMLFiles",
        "offset": -1,
        "size": -1,
        "type": "html",
        "description": "Internal HTML help topic files"
      }
    ]
  },
  "useCases": [
    "Windows application help documentation",
    "Software manuals and technical references",
    "Legacy Windows SDK documentation"
  ],
  "technicalDetails": "CHM (Compiled HTML Help, ITSF = ITS File) is a Microsoft proprietary format storing compressed HTML, images, and index files. The ITSF header at offset 0 is followed by an ITSP directory header. Content is LZX-compressed in sections. The internal file listing uses a B-tree structure. CHM execution is restricted by the Zone.Identifier ADS on Windows.",
  "completenessScore": 85
}




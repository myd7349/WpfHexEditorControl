  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "standard",
    "BlocksDefined": 2,
    "ValidationRules": 2,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "DocumentType": "Text-based contact interchange format",
    "EncodingStandard": "RFC 6350 (v4.0), RFC 2426 (v3.0), Versit 2.1",
    "TextEncoding": "UTF-8 (v3.0/v4.0); v2.1 supports CHARSET parameter",
    "LineEndings": "CRLF (RFC 6350 mandate); LF-only widely tolerated",
    "MultiVCard": "Multiple vCards concatenated directly in one file",
    "PhotoEncoding": "Inline base64 (ENCODING=b) or URI reference"
  },
  "syntaxDefinition": {
    "id": "vcard",
    "name": "vCard",
    "extensions": [
      ".vcf",
      ".vcard"
    ],
    "rules": [
      {
        "type": "Keyword",
        "pattern": "^(BEGIN|END|VERSION|FN|N|NICKNAME|PHOTO|BDAY|ADR|TEL|EMAIL|IMPP|LANG|TZ|GEO|TITLE|ROLE|LOGO|ORG|MEMBER|RELATED|CATEGORIES|NOTE|PRODID|REV|SOUND|UID|CLIENTPIDMAP|URL|KEY|FBURL|CALADRURI|CALURI|XML|SOURCE)(?=[:;])"
      },
      {
        "type": "Property",
        "pattern": "^[A-Z][A-Z0-9-]*(?=[:;])"
      },
      {
        "type": "Parameter",
        "pattern": ";[A-Z][A-Z0-9-]*(?==)"
      },
      {
        "type": "Directive",
        "pattern": "^X-[A-Z0-9-]+(?=[:;])"
      }
    ],
    "formattingRules": {
      "indentSize": 0,
      "useTabs": false,
      "trimTrailingWhitespace": false,
      "insertFinalNewline": true
    },
    "foldingRules": {
      "startPatterns": [
        "^BEGIN:VCARD"
      ],
      "endPatterns": [
        "^END:VCARD"
      ]
    },
    "ideMetadata": {
      "isSourceFile": false,
      "isStructuredDataFile": true,
      "supportsClassDiagram": false,
      "supportsSourceOutline": false,
      "isProjectLanguage": false,
      "aliases": [
        "vcf"
      ],
      "iconGlyph": "",
      "diffMode": "text"
    }
  },
  "diff": {
    "keyFields": [
      "vcard_magic",
      "next_byte"
    ],
    "ignoreFields": [],
    "note": "Inferred semantic diff for VCARD. Compare key structural fields; ignore volatile metadata."
  },
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "vcard_magic",
        "mutation": "corrupt_signature",
        "description": "Corrupt magic bytes at offset 0 — parser must reject."
      },
      {
        "field": "next_byte",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      }
    ],
    "note": "Inferred fuzz strategies for VCARD. Hand-tune weights/rates per format if needed."
  },

{
  "diffMode": "text",
  "formatName": "Flat ODF Text Document",
  "version": "1.0",
  "extensions": [
    ".fodt",
    ".fods",
    ".fodp",
    ".fodg"
  ],
  "description": "Flat ODF (Open Document Format) — single-file XML variant of ODF. Unlike standard ODF (ZIP-based .odt/.ods/.odp), Flat ODF stores the entire document as a single uncompressed XML file. Root element: <office:document> with namespace declarations for office:, style:, text:, draw:, fo: and others. Contains all ODF sections inline: <office:meta> (title, author, creation date), <office:settings>, <office:scripts>, <office:font-face-decls>, <office:styles>, <office:automatic-styles>, <office:master-styles>, <office:body> (actual document content). Supported by LibreOffice and OpenOffice. Easier to diff and version-control than ZIP-based ODF. MIME types: application/vnd.oasis.opendocument.text (.fodt), spreadsheet (.fods), presentation (.fodp), drawing (.fodg).",
  "category": "Documents",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "text-editor",
  "references": {
    "specifications": [
      "OASIS ODF 1.3 Specification — docs.oasis-open.org/office/OpenDocument/v1.3/",
      "ODF Flat XML Format — OASIS ODF TC specification part 3",
      "OpenDocument Format 1.2 — ISO/IEC 26300-1:2015"
    ],
    "WebLinks": [
      "https://docs.oasis-open.org/office/OpenDocument/v1.3/",
      "https://en.wikipedia.org/wiki/OpenDocument",
      "https://www.libreoffice.org/",
      "https://fileformats.archiveteam.org/wiki/Flat_ODF"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "3C3F786D6C", "offset": 0, "label": "<?xml — XML declaration for Flat ODF", "weight": 0.5 },
      { "value": "3C6F66666963653A646F63756D656E74", "offset": 0, "label": "<office:document — Flat ODF root element (no XML declaration)", "weight": 0.9 }
    ],
    "required": false,
    "Strength": "Medium",
    "MinimumScore": 0.4,
    "EntropyHint": { "min": 4.0, "max": 6.0 },
    "validation": {
      "minFileSize": 200
    }
  },
  "variables": {
    "firstByte": 0,
    "xmlDecl": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "First Byte (XML / BOM / root element)",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.35,
      "description": "First byte of the Flat ODF file. Value 0x3C ('<') indicates either the XML declaration '<?xml' or the root '<office:document' element directly. Value 0xEF indicates a UTF-8 BOM (EF BB BF) before the XML content — technically not recommended for XML but sometimes generated by older tools.",
      "storeAs": "firstByte",
      "valueType": "uint8",
      "valueMap": {
        "60": "0x3C '<' — XML declaration or root element start",
        "239": "0xEF — UTF-8 BOM (EF BB BF) before XML (non-standard)"
      }
    },
    {
      "type": "field",
      "name": "XML Declaration or Root Element",
      "offset": 0,
      "length": 5,
      "color": "#4ECDC4",
      "opacity": 0.30,
      "description": "First 5 bytes of the Flat ODF XML content. For files starting with an XML declaration: '<?xml' (3C 3F 78 6D 6C). For files without an XML declaration, this is the beginning of '<offi' from '<office:document'. Both are valid Flat ODF files — the XML declaration is optional in XML 1.0.",
      "storeAs": "xmlDecl",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "XML Start",
      "variable": "xmlDecl",
      "description": "First 5 bytes: '<?xml' for XML-declared files or '<offi' for direct root element"
    },
    {
      "type": "metadata",
      "name": "First Byte",
      "variable": "firstByte",
      "description": "First byte: 0x3C=XML content, 0xEF=UTF-8 BOM present"
    }
  ],
  "assertions": [
    {
      "name": "File must start with XML content",
      "expression": "firstByte == 60 || firstByte == 239",
      "severity": "warning",
      "message": "Flat ODF file should start with '<' (0x3C) for XML content or 0xEF for UTF-8 BOM — other values indicate invalid content"
    },
    {
      "name": "XML declaration or office root element",
      "expression": "xmlDecl == '<?xml' || xmlDecl == '<offi'",
      "severity": "info",
      "message": "Flat ODF should begin with XML declaration or <office:document root element"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "XML / Root Start", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" }
    ]
  },
  "inspector": {
    "badge": "xmlDecl",
    "primaryField": "xmlDecl",
    "showQualityScore": true,
    "groups": [
      {
        "title": "XML Structure",
        "icon": "\uE71B",
        "fields": ["xmlDecl", "firstByte"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Flat ODF header (JSON)",
      "format": "json",
      "fields": ["xmlDecl", "firstByte"]
    },
    {
      "name": "Flat ODF info (text)",
      "format": "text",
      "fields": ["xmlDecl"]
    }
  ],
  "forensic": {
    "category": "document",
    "riskLevel": "low",
    "suspiciousPatterns": [
      {
        "name": "Unexpected file start",
        "condition": "firstByte != 60 && firstByte != 239",
        "severity": "warning",
        "description": "Flat ODF file does not start with XML content marker. File may be corrupt or mis-identified."
      }
    ]
  },
  "aiHints": {
    "analysisContext": "Flat ODF is a large single XML document. Root element is <office:document xmlns:office='urn:oasis:names:tc:opendocument:xmlns:office:1.0' ...>. Key child elements: office:meta (title/author/date), office:styles (named styles), office:automatic-styles (formatting), office:body (content). Text documents use office:text, spreadsheets use office:spreadsheet, presentations use office:presentation. Easier to search with XML tools than ZIP-based .odt.",
    "suggestedInspections": [
      "Verify file starts with '<?xml' or '<office:document' element",
      "Find 'office:version' attribute on <office:document> to identify ODF version",
      "Search for <dc:title> in <office:meta> section for document title",
      "Check <office:body> child element type: office:text/spreadsheet/presentation/drawing",
      "Scan for macros in <office:scripts> element — potential security concern"
    ]
  },
  "software": [
    "LibreOffice Writer (fodt), Calc (fods), Impress (fodp), Draw (fodg)",
    "OpenOffice.org",
    "Calligra Suite",
    "AbiWord (partial support)",
    "GNOME Office"
  ],
  "formatRelationships": {
    "category": "Documents",
    "extensions": [".fodt", ".fods", ".fodp", ".fodg"],
    "relatedFormats": ["ODT", "ODS", "ODP", "DOCX"],
    "containerVariant": "Standard ODF: ZIP archive of XML files (.odt/.ods/.odp)"
  },
  "MimeTypes": [
    "application/vnd.oasis.opendocument.text-flat-xml",
    "application/vnd.oasis.opendocument.spreadsheet-flat-xml",
    "application/vnd.oasis.opendocument.presentation-flat-xml",
    "application/vnd.oasis.opendocument.graphics-flat-xml"
  ],
  "UseCases": [
    "Version-controlled document management (git-friendly vs .odt ZIP)",
    "Programmatic document generation without ZIP library",
    "Document diffs and patches in plain text workflows",
    "LibreOffice macro testing and debugging"
  ],
  "QualityMetrics": {
    "CompletenessScore": 75,
    "DocumentationLevel": "standard",
    "BlocksDefined": 2,
    "ValidationRules": 2,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "DocumentType": "Flat XML variant of ODF",
    "EncodingStandard": "OASIS ODF 1.2/1.3",
    "TextEncoding": "UTF-8",
    "Compression": "None (uncompressed XML, larger than .odt)",
    "Namespace": "urn:oasis:names:tc:opendocument:xmlns:office:1.0",
    "ContainerType": "Single XML file (not ZIP)"
  }
}

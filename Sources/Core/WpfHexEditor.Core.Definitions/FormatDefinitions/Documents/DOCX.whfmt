{
  "diffMode": "binary",
  "formatName": "Word Document (OOXML family)",
  "formatId": "DOCX",
  "version": "2.03",
  "extensions": [
    ".docx",
    ".docm",
    ".dotx",
    ".dotm"
  ],
  "description": "Microsoft Word Open XML document family (DOCX/DOCM/DOTX/DOTM). All four share the same wordprocessingml schema inside a ZIP container starting with a ZIP Local File Header. DOCM/DOTM additionally embed a vbaProject.bin macro stream; DOTX/DOTM are template variants.",
  "category": "Documents",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "document-editor",
  "references": {
    "specifications": [
      "ECMA-376 - Office Open XML File Formats",
      "ISO/IEC 29500 - Information Technology",
      "PKWARE APPNOTE.TXT - ZIP File Format Specification"
    ],
    "WebLinks": [
      "https://www.ecma-international.org/publications-and-standards/standards/ecma-376/",
      "https://en.wikipedia.org/wiki/Office_Open_XML",
      "https://pkware.cachefly.net/webdocs/casestudies/APPNOTE.TXT"
    ]
  },
  "detection": {
    "signature": "504B0304",
    "offset": 0,
    "required": true,
    "validation": {
      "minFileSize": 100,
      "maxSignatureOffset": 0
    }
  },
  "variables": {
    "currentOffset": 0,
    "fileCount": 0,
    "title": "Unknown",
    "author": "Unknown",
    "preferredEditor": "document-editor",
    "subject": "Unknown",
    "pages": 0,
    "words": 0,
    "characters": 0,
    "zipSignature": 0,
    "versionNeeded": 0,
    "generalPurposeFlags": 0,
    "compressionMethod": 0,
    "lastModTime": 0,
    "lastModDate": 0,
    "crc32": 0,
    "compressedSize": 0,
    "uncompressedSize": 0,
    "filenameLength": 0,
    "extraFieldLength": 0,
    "compressionRatio": 0,
    "zipFileCount": 0,
    "zipCentralDirSize": 0,
    "zipCommentLength": 0,
    "zipComment": "",
    "eocdOffset": -1,
    "isZip64": false,
    "formattedSize": "",
    "zipFirstEntryName": "",
    "zipEntryList": "",
    "zipTotalUncompressedSize": 0,
    "zipEntryCount": 0
  },
  "functions": {
    "parseZIPArchive": "Parse End of Central Directory for archive statistics",
    "parseZipEntries": "Parse Central Directory to extract entry names and total uncompressed size",
    "formatFileSize(var:zipCentralDirSize)": "Format central directory size"
  },
  "blocks": [
    {
      "type": "signature",
      "name": "ZIP Local File Header Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "PK\\x03\\x04 magic number identifying a ZIP Local File Header (0x04034B50 LE)",
      "storeAs": "zipSignature",
      "valueType": "uint32",
      "validation": {
        "expectedValue": "0x04034B50"
      }
    },
    {
      "type": "field",
      "name": "Version Needed to Extract",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Minimum ZIP specification version needed to extract this entry",
      "storeAs": "versionNeeded",
      "valueType": "uint16",
      "valueMap": {
        "10": "1.0 (Default)",
        "20": "2.0 (Deflate)",
        "45": "4.5 (ZIP64)",
        "63": "6.3 (LZMA)"
      }
    },
    {
      "type": "field",
      "name": "General Purpose Bit Flags",
      "offset": 6,
      "length": 2,
      "color": "#45B7D1",
      "opacity": 0.3,
      "description": "Bit flags controlling encryption, compression options, and data descriptor presence",
      "storeAs": "generalPurposeFlags",
      "valueType": "uint16",
      "bitfields": [
        {
          "bit": 0,
          "name": "Encrypted",
          "description": "If set, the file data is encrypted",
          "valueMap": {
            "0": "Not encrypted",
            "1": "Encrypted"
          }
        },
        {
          "bit": 3,
          "name": "Data Descriptor",
          "description": "If set, CRC-32 and sizes are in a data descriptor after the file data",
          "valueMap": {
            "0": "No data descriptor",
            "1": "Data descriptor follows file data"
          }
        }
      ]
    },
    {
      "type": "field",
      "name": "Compression Method",
      "offset": 8,
      "length": 2,
      "color": "#96CEB4",
      "opacity": 0.3,
      "description": "Algorithm used to compress the file data in this entry",
      "storeAs": "compressionMethod",
      "valueType": "uint16",
      "valueMap": {
        "0": "Stored (no compression)",
        "8": "Deflate",
        "14": "LZMA"
      }
    },
    {
      "type": "field",
      "name": "Last Modification Time",
      "offset": 10,
      "length": 2,
      "color": "#FFEAA7",
      "opacity": 0.3,
      "description": "File last modification time in MS-DOS format (5-bit hour, 6-bit minute, 5-bit second/2)",
      "storeAs": "lastModTime",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Last Modification Date",
      "offset": 12,
      "length": 2,
      "color": "#DDA0DD",
      "opacity": 0.3,
      "description": "File last modification date in MS-DOS format (7-bit year+1980, 4-bit month, 5-bit day)",
      "storeAs": "lastModDate",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "CRC-32",
      "offset": 14,
      "length": 4,
      "color": "#FF8C69",
      "opacity": 0.3,
      "description": "CRC-32 checksum of the uncompressed file data",
      "storeAs": "crc32",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Compressed Size",
      "offset": 18,
      "length": 4,
      "color": "#87CEEB",
      "opacity": 0.3,
      "description": "Size of the compressed file data in bytes (0xFFFFFFFF if ZIP64)",
      "storeAs": "compressedSize",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Uncompressed Size",
      "offset": 22,
      "length": 4,
      "color": "#98D8C8",
      "opacity": 0.3,
      "description": "Original uncompressed size of the file data in bytes (0xFFFFFFFF if ZIP64)",
      "storeAs": "uncompressedSize",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Filename Length",
      "offset": 26,
      "length": 2,
      "color": "#F7DC6F",
      "opacity": 0.3,
      "description": "Length of the filename field that follows this header",
      "storeAs": "filenameLength",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Extra Field Length",
      "offset": 28,
      "length": 2,
      "color": "#BB8FCE",
      "opacity": 0.3,
      "description": "Length of the extra field that follows the filename",
      "storeAs": "extraFieldLength",
      "valueType": "uint16"
    },
    {
      "type": "computeFromVariables",
      "name": "Compression Ratio",
      "expression": "uncompressedSize > 0 ? ((1 - compressedSize / uncompressedSize) * 100) : 0",
      "storeAs": "compressionRatio",
      "description": "Percentage reduction from compression of the first ZIP entry"
    },
    {
      "type": "conditional",
      "name": "Encryption Check",
      "condition": "(generalPurposeFlags & 1) == 1",
      "trueLabel": "This DOCX file is encrypted",
      "falseLabel": "This DOCX file is not encrypted",
      "description": "Checks bit 0 of general purpose flags to determine if the archive entry is encrypted"
    },
    {
      "type": "metadata",
      "name": "Total Files in Archive",
      "variable": "zipFileCount",
      "description": "Total number of files/entries in the OOXML package"
    },
    {
      "type": "metadata",
      "name": "Central Directory Size",
      "variable": "formattedSize",
      "description": "Human-readable size of the ZIP central directory"
    },
    {
      "type": "metadata",
      "name": "ZIP64 Format",
      "variable": "isZip64",
      "description": "true if ZIP64 format, false if standard ZIP"
    },
    {
      "type": "metadata",
      "name": "First Entry Name",
      "variable": "zipFirstEntryName",
      "description": "Name of the first file in the ZIP archive (typically [Content_Types].xml for OOXML)"
    },
    {
      "type": "metadata",
      "name": "Package Contents",
      "variable": "zipEntryList",
      "description": "List of all files/entries inside the DOCX package"
    },
    {
      "type": "metadata",
      "name": "Total Uncompressed Size",
      "variable": "zipTotalUncompressedSize",
      "description": "Total uncompressed size of all entries in the package (bytes)"
    }
  ],
  "forensic": {
    "category": "document",
    "riskLevel": "medium",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "Microsoft Word Open XML document stored as a ZIP container. The file begins with a ZIP Local File Header con...",
    "suggestedInspections": [
      "Validate Word Document file signature and container structure",
      "Check for embedded macros, scripts, or active content",
      "Inspect document metadata: author, timestamps, revisions"
    ]
  },
  "MimeTypes": [
    "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
    "application/vnd.ms-word.document.macroEnabled.12",
    "application/vnd.openxmlformats-officedocument.wordprocessingml.template",
    "application/vnd.ms-word.template.macroEnabled.12"
  ],
  "Software": [
    "Microsoft Word",
    "LibreOffice Writer",
    "Google Docs",
    "Apple Pages"
  ],
  "UseCases": [
    "Word processing",
    "Reports and proposals",
    "Resumes and CVs",
    "Letters and correspondence"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "comprehensive",
    "BlocksDefined": 19,
    "ValidationRules": 3,
    "LastUpdated": "2026-05-10",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "DocumentFormat": true,
    "Container": "ZIP (Office Open XML)",
    "Endianness": "little-endian",
    "HeaderSize": 30,
    "VariableLengthFields": "filename and extra field follow the fixed 30-byte header"
  },
  "diff": {
    "keyFields": ["zipSignature", "compressionMethod", "crc32"],
    "ignoreFields": ["lastModTime", "lastModDate", "compressionRatio"],
    "groupBy": "ZIP Local File Header",
    "note": "Signature and CRC identify content integrity; compression method affects reproducibility. Timestamps are noise for structural diffs."
  },
  "repair": [
    {
      "name": "FixZipSignature",
      "trigger": "zipSignature != 0x04034B50",
      "action": "set_value",
      "target": "zipSignature",
      "value": "504B0304",
      "description": "Restore the ZIP Local File Header magic bytes to 50 4B 03 04"
    },
    {
      "name": "FixCompressionMethod",
      "trigger": "compressionMethod > 14",
      "action": "set_value",
      "target": "compressionMethod",
      "value": "0800",
      "description": "Reset compression method to Deflate (8) when an unknown method is stored"
    },
    {
      "name": "ClearEncryptionFlag",
      "trigger": "(generalPurposeFlags & 1) == 1",
      "action": "set_value",
      "target": "generalPurposeFlags",
      "value": "0000",
      "description": "Clear the encryption bit so standard DOCX parsers can read the entry"
    }
  ],
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      { "field": "zipSignature",        "mutation": "corrupt_signature", "weight": 3, "description": "Corrupt the PK magic to test parser rejection logic" },
      { "field": "compressionMethod",   "mutation": "boundary_values",   "weight": 2, "description": "Test edge values (0, 14, 0xFFFF) for compression method handling" },
      { "field": "compressedSize",      "mutation": "overflow",          "weight": 2, "description": "Overflow compressed size to stress ZIP64 path and allocation guards" },
      { "field": "generalPurposeFlags", "mutation": "random_bytes",      "weight": 1, "description": "Randomize flag bits to surface unexpected parser code paths" },
      { "field": "crc32",               "mutation": "bit_flip", "rate": 0.001, "weight": 1, "description": "Single-bit CRC corruption to verify integrity validation" }
    ]
  },
  "migration": [
    {
      "from": "OOXML-2006",
      "to": "OOXML-2016",
      "description": "Office Open XML transitional to strict conformance; versionNeeded may increase from 20 to 45 for ZIP64 support",
      "changes": [
        { "field": "versionNeeded", "changeType": "set_value", "value": "2D00", "description": "Raise version needed to 4.5 (0x002D) for ZIP64-capable containers" }
      ]
    },
    {
      "from": "ZIP-standard",
      "to": "ZIP64",
      "description": "Upgrade large DOCX packages exceeding 4 GB to ZIP64 format",
      "changes": [
        { "field": "compressedSize",   "changeType": "set_value", "value": "FFFFFFFF", "description": "Set compressed size sentinel for ZIP64 extension" },
        { "field": "uncompressedSize", "changeType": "set_value", "value": "FFFFFFFF", "description": "Set uncompressed size sentinel for ZIP64 extension" }
      ]
    }
  ],
  "documentSchema": {
    "engine": "ooxml",
    "contentEntry": "word/document.xml",
    "namespace": "http://schemas.openxmlformats.org/wordprocessingml/2006/main",
    "namespacePrefix": "w",
    "blockMappings": [
      {
        "xmlElement": "w:p", "blockKind": "paragraph", "textSource": "w:r/w:t",
        "childMappings": [
          { "xmlElement": "w:r",         "blockKind": "run",       "textSource": "w:t" },
          { "xmlElement": "w:hyperlink", "blockKind": "hyperlink", "textSource": "w:r/w:t" }
        ],
        "attributeMappings": [
          { "xmlPath": "w:pPr/w:pStyle/@w:val",      "attribute": "style" },
          { "xmlPath": "w:pPr/w:jc/@w:val",          "attribute": "align" },
          { "xmlPath": "w:pPr/w:ind/@w:left",        "attribute": "indent",          "transform": "twipsToPoints" },
          { "xmlPath": "w:pPr/w:ind/@w:right",       "attribute": "indentRight",     "transform": "twipsToPoints" },
          { "xmlPath": "w:pPr/w:ind/@w:firstLine",   "attribute": "indentFirstLine", "transform": "twipsToPoints" }
        ]
      },
      {
        "xmlElement": "w:r", "blockKind": "run", "textSource": "w:t",
        "attributeMappings": [
          { "xmlPath": "w:rPr/w:b",            "attribute": "bold",          "presence": true },
          { "xmlPath": "w:rPr/w:i",            "attribute": "italic",        "presence": true },
          { "xmlPath": "w:rPr/w:u",            "attribute": "underline",     "presence": true },
          { "xmlPath": "w:rPr/w:strike",       "attribute": "strikethrough", "presence": true },
          { "xmlPath": "w:rPr/w:sz/@w:val",    "attribute": "fontSize",      "transform": "halfPointsToPoints" },
          { "xmlPath": "w:rPr/w:color/@w:val", "attribute": "color" }
        ]
      },
      {
        "xmlElement": "w:tbl", "blockKind": "table",
        "childMappings": [
          { "xmlElement": "w:tr", "blockKind": "table-row",
            "childMappings": [ { "xmlElement": "w:tc", "blockKind": "table-cell" } ] }
        ]
      },
      { "xmlElement": "w:sectPr",  "blockKind": "section" },
      { "xmlElement": "w:drawing", "blockKind": "image", "imageEntryPath": "word/media/{r:embed}" }
    ],
    "serializationRules": {
      "paragraph":  { "xmlElement": "w:p", "wrapChildren": true },
      "run":        { "xmlElement": "w:r", "textElement": "w:t" },
      "heading":    { "xmlElement": "w:p", "pStyle": "Heading{level}", "wrapChildren": true },
      "table":      { "xmlElement": "w:tbl" },
      "table-row":  { "xmlElement": "w:tr" },
      "table-cell": { "xmlElement": "w:tc", "textElement": "w:p/w:r/w:t" },
      "section":    { "xmlElement": "w:sectPr" }
    },
    "attributeSerializationRules": {
      "bold":          { "parent": "w:rPr", "xmlElement": "w:b" },
      "italic":        { "parent": "w:rPr", "xmlElement": "w:i" },
      "underline":     { "parent": "w:rPr", "xmlElement": "w:u", "attrs": { "w:val": "single" } },
      "strikethrough": { "parent": "w:rPr", "xmlElement": "w:strike" },
      "fontSize":      { "parent": "w:rPr", "xmlElement": "w:sz", "attr": "w:val", "transform": "pointsToHalfPoints" },
      "align":           { "parent": "w:pPr", "xmlElement": "w:jc",  "attr": "w:val" },
      "indent":          { "parent": "w:pPr", "xmlElement": "w:ind", "attr": "w:left",      "transform": "pointsToTwips" },
      "indentRight":     { "parent": "w:pPr", "xmlElement": "w:ind", "attr": "w:right",     "transform": "pointsToTwips" },
      "indentFirstLine": { "parent": "w:pPr", "xmlElement": "w:ind", "attr": "w:firstLine", "transform": "pointsToTwips" }
    }
  }
}

{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Microsoft Reader LIT e-Book",
  "formatId": "LIT",
  "version": "1.0.1",
  "extensions": [".lit"],
  "description": "Microsoft LIT is the proprietary e-book format for the discontinued Microsoft Reader application. It uses the ITSF (InfoTech Storage Format) container — the same format as CHM help files — with LIT-specific virtual section names and an optional DRM (Digital Rights Management) layer. The magic 'ITSF' at offset 0 is shared with CHM; LIT is distinguished by internal section names such as '/DRMStorage/' and '/content/'.",
  "category": "Documents",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "HexEditor",
  "references": [
    "https://en.wikipedia.org/wiki/LIT_(file_format)",
    "https://wiki.mobileread.com/wiki/LIT",
    "https://www.nongnu.org/chmspec/latest/",
    "http://www.russotto.net/chm/itsfformat.html"
  ],
  "detection": {
    "signatures": [
      {
        "offset": 0,
        "value": "49545346",
        "label": "'ITSF' container magic shared by LIT and CHM",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 0.8,
    "Strength": "Strong",
    "EntropyHint": "Mixed — HTML content and optional DRM-encrypted sections inside LZX-compressed ITSF container"
  },
  "variables": [
    {
      "name": "litMagic",
      "offset": 0,
      "size": 4,
      "type": "ascii",
      "description": "ITSF magic bytes — 'ITSF' (0x49545346); shared with CHM"
    },
    {
      "name": "litVersion",
      "offset": 4,
      "size": 4,
      "type": "uint32",
      "endian": "LE",
      "description": "ITSF version; LIT typically uses version 3",
      "valueMap": {
        "2": "ITSFv2 (uncommon for LIT)",
        "3": "ITSFv3 (standard for LIT)"
      }
    },
    {
      "name": "litHeaderLength",
      "offset": 8,
      "size": 4,
      "type": "uint32",
      "endian": "LE",
      "description": "Total header section length in bytes"
    },
    {
      "name": "litUnknown",
      "offset": 12,
      "size": 4,
      "type": "uint32",
      "endian": "LE",
      "description": "Unknown field; always 1 in observed files"
    },
    {
      "name": "litTimestamp",
      "offset": 16,
      "size": 4,
      "type": "uint32",
      "endian": "LE",
      "description": "Creation timestamp (Windows FILETIME high 32-bits)"
    },
    {
      "name": "litLanguageId",
      "offset": 20,
      "size": 4,
      "type": "uint32",
      "endian": "LE",
      "description": "Windows LCID for content language",
      "valueMap": {
        "1033": "en-US",
        "1036": "fr-FR",
        "1031": "de-DE",
        "1041": "ja-JP",
        "2052": "zh-CN"
      }
    }
  ],
  "blocks": [
    {
      "name": "ITSFHeader",
      "offset": 0,
      "size": 24,
      "description": "Primary ITSF header with magic, version, header length, and language ID"
    },
    {
      "name": "HeaderSection0",
      "offset": 24,
      "size": 8,
      "description": "Header section 0 — file offset and length of the first header segment"
    },
    {
      "name": "HeaderSection1",
      "offset": 32,
      "size": 8,
      "description": "Header section 1 — file offset and length of the directory segment"
    },
    {
      "name": "ContentDataOffset",
      "offset": 40,
      "size": 8,
      "description": "Absolute 64-bit offset to the first content data section"
    },
    {
      "name": "ITSPDirectoryHeader",
      "offset": 84,
      "size": 84,
      "description": "ITSP B-Tree directory header listing virtual files (including LIT-specific DRM sections)"
    }
  ],
  "assertions": [
    {
      "variable": "litMagic",
      "operator": "==",
      "value": "ITSF",
      "description": "Magic must be 'ITSF'",
      "level": "Error"
    },
    {
      "variable": "litVersion",
      "operator": "in",
      "value": [2, 3],
      "description": "LIT uses ITSF version 2 or 3",
      "level": "Warning"
    },
    {
      "variable": "litHeaderLength",
      "operator": ">",
      "value": 0,
      "description": "Header length must be non-zero",
      "level": "Error"
    }
  ],
  "navigation": {
    "entryPoint": 0,
    "sections": [
      { "name": "ITSF Header", "offset": 0, "size": 24 },
      { "name": "Header Section 0", "offset": 24, "size": 8 },
      { "name": "Header Section 1", "offset": 32, "size": 8 },
      { "name": "Content Offset", "offset": 40, "size": 8 },
      { "name": "ITSP Directory", "offset": 84, "size": 84 }
    ]
  },
  "inspector": {
    "badge": "LIT",
    "primaryField": "litVersion",
    "groups": [
      {
        "name": "Identity",
        "fields": ["litMagic", "litVersion"]
      },
      {
        "name": "Structure",
        "fields": ["litHeaderLength", "litUnknown"]
      },
      {
        "name": "Metadata",
        "fields": ["litTimestamp", "litLanguageId"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "LIT Header Summary",
      "format": "text",
      "template": "Format: {litMagic} v{litVersion}\nLanguage: {litLanguageId}\nTimestamp: {litTimestamp}\nHeader Length: {litHeaderLength}"
    },
    {
      "name": "LIT CSV Export",
      "format": "csv",
      "template": "Magic,Version,HeaderLength,Timestamp,LanguageId\n{litMagic},{litVersion},{litHeaderLength},{litTimestamp},{litLanguageId}"
    }
  ],
  "forensic": {
    "riskLevel": "MEDIUM",
    "notes": "LIT shares the ITSF container attack surface with CHM. DRM-stripped LIT files may violate licensing agreements. The ITSF directory can be used for path traversal attacks.",
    "suspiciousPatterns": [
      "ITSF magic present but internal sections lack '/DRMStorage/' or '/content/' — may be misidentified CHM",
      "litTimestamp of 0 indicating deliberate metadata scrubbing",
      "Header length exceeding file size — possible header corruption or exploit attempt",
      "DRM bypass tools may strip encryption leaving inconsistent section structures"
    ]
  },
  "aiHints": {
    "analysisContext": "LIT uses the ITSF container (identical magic to CHM). The key differentiator is internal virtual section names: LIT contains '/DRMStorage/', '/content/', and '/package/'. Calibre and ConvertLIT can handle non-DRM files. The format was discontinued in 2012.",
    "suggestedInspections": [
      "Verify 'ITSF' magic at offset 0; cross-reference with litVersion — v3 is expected for LIT.",
      "Inspect ITSP directory at offset 84 for LIT-specific virtual section names ('/DRMStorage/', '/content/', '/package/') to distinguish from CHM.",
      "Check litLanguageId against LCID table to determine declared content language; mismatch may indicate file manipulation.",
      "Look for '/DRMStorage/' presence to confirm DRM protection status — DRM-free LIT files are uncommon and may be pirated copies.",
      "Correlate litTimestamp with file system timestamps for back-dating detection."
    ]
  },
  "software": [
    { "name": "Microsoft Reader", "platform": "Windows (discontinued)", "url": "https://en.wikipedia.org/wiki/Microsoft_Reader" },
    { "name": "Calibre", "platform": "Windows/macOS/Linux", "url": "https://calibre-ebook.com/" },
    { "name": "ConvertLIT", "platform": "Windows/Linux", "url": "https://sourceforge.net/projects/convertlit/" },
    { "name": "7-Zip (partial)", "platform": "Windows/Linux", "url": "https://www.7-zip.org/" }
  ],
  "formatRelationships": [
    { "format": "CHM", "relationship": "sibling", "note": "Both LIT and CHM use the ITSF container with identical magic" },
    { "format": "EPUB", "relationship": "successor", "note": "EPUB is the modern XML/ZIP-based replacement for LIT" },
    { "format": "MOBI", "relationship": "contemporary", "note": "MOBI/PalmDOC was a competing e-book format from the same era" }
  ],
  "MimeTypes": ["application/x-ms-lit", "application/lit"],
  "UseCases": [
    "Legacy Microsoft Reader e-book reading (discontinued)",
    "e-Book library migration and conversion to modern formats",
    "Digital preservation of early-2000s e-book collections"
  ],
  "QualityMetrics": {
    "CompletenessScore": 87,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  },
  "TechnicalDetails": {
    "containerType": "ITSF (InfoTech Storage Format) — same as CHM",
    "compressionAlgorithm": "LZX (Microsoft variant of LZ77)",
    "drmSupport": "Microsoft DRM v1 (deprecated); file may also be unprotected",
    "endianness": "Little-Endian",
    "minimumHeaderSize": 24,
    "contentFormat": "HTML with inline images and OPF-style metadata sections"
  }
}




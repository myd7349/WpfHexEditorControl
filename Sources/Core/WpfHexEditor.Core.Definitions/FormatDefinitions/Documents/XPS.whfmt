{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "XML Paper Specification",
  "formatId": "XPS",
  "version": "2.02.1",
  "extensions": [
    ".xps",
    ".oxps"
  ],
  "description": "Microsoft XPS (XML Paper Specification) document format, a ZIP-based fixed-layout document format. The file begins with a ZIP Local File Header containing the first entry of the OOXML package.",
  "category": "Documents",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ECMA-388 - Open XML Paper Specification",
      "PKWARE APPNOTE.TXT - ZIP File Format Specification"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/Open_XML_Paper_Specification",
      "https://www.ecma-international.org/publications-and-standards/standards/ecma-388/"
    ]
  },
  "detection": {
    "signature": "504B0304",
    "offset": 0,
    "required": true,
    "validation": {
      "minFileSize": 100,
      "maxSignatureOffset": 0,
      "note": "Shares ZIP magic 504B0304 with OXPS, OOXML and other OPC packages. Discriminate via [Content_Types].xml entry: XPS uses ContentType 'application/vnd.ms-package.xps-fixeddocumentsequence+xml' and namespace 'http://schemas.microsoft.com/xps/2005/06'."
    }
  },
  "variables": {
    "currentOffset": 0,
    "fileCount": 0,
    "zipSignature": 0,
    "versionNeeded": 0,
    "generalPurposeFlags": 0,
    "compressionMethod": 0,
    "lastModTime": 0,
    "lastModDate": 0,
    "crc32": 0,
    "compressedSize": 0,
    "uncompressedSize": 0,
    "filenameLength": 0,
    "extraFieldLength": 0,
    "compressionRatio": 0,
    "zipFileCount": 0,
    "zipCentralDirSize": 0,
    "zipCommentLength": 0,
    "zipComment": "",
    "eocdOffset": -1,
    "isZip64": false,
    "formattedSize": "",
    "zipFirstEntryName": "",
    "zipEntryList": "",
    "zipTotalUncompressedSize": 0,
    "zipEntryCount": 0
  },
  "functions": {
    "parseZIPArchive": "Parse End of Central Directory for archive statistics",
    "parseZipEntries": "Parse Central Directory to extract entry names and total uncompressed size",
    "formatFileSize(var:zipCentralDirSize)": "Format central directory size"
  },
  "blocks": [
    {
      "type": "signature",
      "name": "ZIP Local File Header Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "PK\\x03\\x04 magic number identifying a ZIP Local File Header (0x04034B50 LE)",
      "storeAs": "zipSignature",
      "valueType": "uint32",
      "validation": {
        "expectedValue": "0x04034B50"
      }
    },
    {
      "type": "field",
      "name": "Version Needed to Extract",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Minimum ZIP specification version needed to extract this entry",
      "storeAs": "versionNeeded",
      "valueType": "uint16",
      "valueMap": {
        "10": "1.0 (Default)",
        "20": "2.0 (Deflate)",
        "45": "4.5 (ZIP64)",
        "63": "6.3 (LZMA)"
      }
    },
    {
      "type": "field",
      "name": "General Purpose Bit Flags",
      "offset": 6,
      "length": 2,
      "color": "#45B7D1",
      "opacity": 0.3,
      "description": "Bit flags controlling encryption, compression options, and data descriptor presence",
      "storeAs": "generalPurposeFlags",
      "valueType": "uint16",
      "bitfields": [
        {
          "bit": 0,
          "name": "Encrypted",
          "description": "If set, the file data is encrypted",
          "valueMap": {
            "0": "Not encrypted",
            "1": "Encrypted"
          }
        },
        {
          "bit": 3,
          "name": "Data Descriptor",
          "description": "If set, CRC-32 and sizes are in a data descriptor after the file data",
          "valueMap": {
            "0": "No data descriptor",
            "1": "Data descriptor follows file data"
          }
        }
      ]
    },
    {
      "type": "field",
      "name": "Compression Method",
      "offset": 8,
      "length": 2,
      "color": "#96CEB4",
      "opacity": 0.3,
      "description": "Algorithm used to compress the file data in this entry",
      "storeAs": "compressionMethod",
      "valueType": "uint16",
      "valueMap": {
        "0": "Stored (no compression)",
        "8": "Deflate",
        "14": "LZMA"
      }
    },
    {
      "type": "field",
      "name": "Last Modification Time",
      "offset": 10,
      "length": 2,
      "color": "#FFEAA7",
      "opacity": 0.3,
      "description": "File last modification time in MS-DOS format (5-bit hour, 6-bit minute, 5-bit second/2)",
      "storeAs": "lastModTime",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Last Modification Date",
      "offset": 12,
      "length": 2,
      "color": "#DDA0DD",
      "opacity": 0.3,
      "description": "File last modification date in MS-DOS format (7-bit year+1980, 4-bit month, 5-bit day)",
      "storeAs": "lastModDate",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "CRC-32",
      "offset": 14,
      "length": 4,
      "color": "#FF8C69",
      "opacity": 0.3,
      "description": "CRC-32 checksum of the uncompressed file data",
      "storeAs": "crc32",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Compressed Size",
      "offset": 18,
      "length": 4,
      "color": "#87CEEB",
      "opacity": 0.3,
      "description": "Size of the compressed file data in bytes (0xFFFFFFFF if ZIP64)",
      "storeAs": "compressedSize",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Uncompressed Size",
      "offset": 22,
      "length": 4,
      "color": "#98D8C8",
      "opacity": 0.3,
      "description": "Original uncompressed size of the file data in bytes (0xFFFFFFFF if ZIP64)",
      "storeAs": "uncompressedSize",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Filename Length",
      "offset": 26,
      "length": 2,
      "color": "#F7DC6F",
      "opacity": 0.3,
      "description": "Length of the filename field that follows this header",
      "storeAs": "filenameLength",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Extra Field Length",
      "offset": 28,
      "length": 2,
      "color": "#BB8FCE",
      "opacity": 0.3,
      "description": "Length of the extra field that follows the filename",
      "storeAs": "extraFieldLength",
      "valueType": "uint16"
    },
    {
      "type": "computeFromVariables",
      "name": "Compression Ratio",
      "expression": "uncompressedSize > 0 ? ((1 - compressedSize / uncompressedSize) * 100) : 0",
      "storeAs": "compressionRatio",
      "description": "Percentage reduction from compression of the first ZIP entry"
    },
    {
      "type": "conditional",
      "name": "Encryption Check",
      "condition": "(generalPurposeFlags & 1) == 1",
      "trueLabel": "This XPS file is encrypted",
      "falseLabel": "This XPS file is not encrypted",
      "description": "Checks bit 0 of general purpose flags to determine if the archive entry is encrypted"
    },
    {
      "type": "metadata",
      "name": "Total Files in Archive",
      "variable": "zipFileCount",
      "description": "Total number of files/entries in the XPS package"
    },
    {
      "type": "metadata",
      "name": "Central Directory Size",
      "variable": "zipCentralDirSize",
      "description": "Size of the central directory in bytes"
    },
    {
      "type": "metadata",
      "name": "EOCD Offset",
      "variable": "eocdOffset",
      "description": "Byte offset of End of Central Directory record"
    },
    {
      "type": "metadata",
      "name": "ZIP64 Format",
      "variable": "isZip64",
      "description": "true if ZIP64 format, false if standard ZIP"
    },
    {
      "type": "metadata",
      "name": "Formatted Size",
      "variable": "formattedSize",
      "description": "Human-readable central directory size"
    },
    {
      "type": "metadata",
      "name": "First Entry Name",
      "variable": "zipFirstEntryName",
      "description": "Name of the first file in the ZIP archive"
    },
    {
      "type": "metadata",
      "name": "Package Contents",
      "variable": "zipEntryList",
      "description": "List of all files/entries inside the XPS package"
    },
    {
      "type": "metadata",
      "name": "Total Uncompressed Size",
      "variable": "zipTotalUncompressedSize",
      "description": "Total uncompressed size of all entries in the package (bytes)"
    }
  ],
  "MimeTypes": [
    "application/vnd.ms-xpsdocument",
    "application/oxps"
  ],
  "Software": [
    "Microsoft XPS Viewer",
    "Windows XPS Document Writer",
    "XPS Essentials Pack",
    "SumatraPDF"
  ],
  "UseCases": [
    "Fixed-layout document publishing",
    "Print-ready document sharing",
    "Document archival",
    "High-fidelity document exchange"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "comprehensive",
    "BlocksDefined": 21,
    "ValidationRules": 3,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "DocumentFormat": true,
    "Container": "ZIP (Open XML Paper)",
    "Endianness": "little-endian",
    "HeaderSize": 30,
    "VariableLengthFields": "filename and extra field follow the fixed 30-byte header"
  },
  "diff": {
    "keyFields": [
      "zipSignature",
      "compressionMethod",
      "crc32"
    ],
    "ignoreFields": [
      "lastModTime",
      "lastModDate",
      "compressionRatio"
    ],
    "groupBy": "ZIP Local File Header",
    "note": "Signature and CRC reveal container integrity; compression method affects page rendering fidelity. Timestamps are volatile and excluded from structural diffs."
  },
  "repair": [
    {
      "name": "FixZipSignature",
      "trigger": "zipSignature != 0x04034B50",
      "action": "set_value",
      "target": "zipSignature",
      "value": "504B0304",
      "description": "Restore the ZIP Local File Header magic bytes to 50 4B 03 04"
    },
    {
      "name": "FixCompressionMethod",
      "trigger": "compressionMethod > 14",
      "action": "set_value",
      "target": "compressionMethod",
      "value": "0800",
      "description": "Reset compression method to Deflate (8) for XPS viewer compatibility"
    },
    {
      "name": "ClearEncryptionFlag",
      "trigger": "(generalPurposeFlags & 1) == 1",
      "action": "set_value",
      "target": "generalPurposeFlags",
      "value": "0000",
      "description": "Clear encryption bit to allow XPS Viewer to open the document"
    }
  ],
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "zipSignature",
        "mutation": "corrupt_signature",
        "weight": 3,
        "description": "Corrupt PK magic to test XPS container rejection"
      },
      {
        "field": "compressionMethod",
        "mutation": "boundary_values",
        "weight": 2,
        "description": "Test edge compression values for fixed-layout page decompression"
      },
      {
        "field": "compressedSize",
        "mutation": "overflow",
        "weight": 2,
        "description": "Overflow compressed size to stress XPS Viewer allocation paths"
      },
      {
        "field": "generalPurposeFlags",
        "mutation": "random_bytes",
        "weight": 1,
        "description": "Random flags to expose unexpected XPS parser branches"
      },
      {
        "field": "crc32",
        "mutation": "bit_flip",
        "rate": 0.001,
        "weight": 1,
        "description": "Single-bit CRC flip to verify integrity checking in XPS readers"
      }
    ]
  },
  "migration": [
    {
      "from": "XPS-ECMA388-1st",
      "to": "OXPS-ECMA388-2nd",
      "description": "XPS to Open XPS (OXPS) migration; container structure is identical but MIME type and content types change",
      "changes": [
        {
          "field": "compressionMethod",
          "changeType": "set_value",
          "value": "0800",
          "description": "Ensure Deflate compression for all OXPS page content entries"
        }
      ]
    }
  ],
  "forensic": {
    "category": "document",
    "riskLevel": "medium",
    "suspiciousPatterns": [],
    "notes": [
      "ZIP-based container; extract and inspect inner files for malicious payloads.",
      "Metadata in core properties may reveal author identity and edit history.",
      "Embedded macros or scripts may execute on open."
    ]
  },
  "aiHints": [
    "Microsoft XPS (XML Paper Specification) document format, a ZIP-based fixed-layout document format. The file ...",
    "Validate XML Paper Specification file signature and container structure",
    "Check for embedded macros, scripts, or active content",
    "Inspect document metadata: author, timestamps, revisions",
    "XPS font files use GUID-based names and are obfuscated; first 32 bytes XOR with a key derived from the font relationship ID.",
    "Glyph elements encode text as UnicodeString + Indices; text is not plain-extractable without parsing.",
    "Check [Content_Types].xml for application/vnd.ms-package.xps namespace to distinguish from OXPS.",
    "Digital signatures in _xmlsignatures/ use XML-DSig and may bind to specific page content.",
    "XPS pages reference resources by relationship — reconstruct the part URI from base+rel for navigation.",
    "Thumbnail images in Metadata/Thumbnail.png expose page previews."
  ],
  "lastUpdated": "2026-05-20",
  "signatures": [
    {
      "value": "504B0304",
      "offset": 0,
      "label": "XPS signature",
      "weight": 100,
      "strength": "strong"
    }
  ],
  "maxSignatureOffset": 4,
  "structure": {
    "fields": [
      {
        "name": "LocalFileHeader",
        "offset": 0,
        "size": 30,
        "type": "struct",
        "description": "ZIP local file header"
      },
      {
        "name": "ContentTypes",
        "offset": -1,
        "size": -1,
        "type": "xml",
        "description": "[Content_Types].xml"
      },
      {
        "name": "FixedDocSeq",
        "offset": -1,
        "size": -1,
        "type": "xml",
        "description": "FixedDocumentSequence.fdseq root sequence"
      },
      {
        "name": "FixedPage",
        "offset": -1,
        "size": -1,
        "type": "xml",
        "description": ".fpage fixed page markup"
      },
      {
        "name": "Fonts",
        "offset": -1,
        "size": -1,
        "type": "blob",
        "description": "Subset-embedded obfuscated OpenType fonts"
      }
    ]
  },
  "inspector": {
    "displayFields": [
      "formatName",
      "version",
      "description"
    ],
    "valueMaps": {},
    "tooltips": {}
  },
  "assertions": [
    {
      "field": "signatures[0].value",
      "op": "notEmpty",
      "description": "Primary signature must be present"
    },
    {
      "field": "maxSignatureOffset",
      "op": "greaterThanOrEqual",
      "value": 0,
      "description": "Max signature offset must be non-negative"
    },
    {
      "field": "completenessScore",
      "op": "greaterThanOrEqual",
      "value": 80,
      "description": "Format completeness score must be at least 80"
    }
  ],
  "navigation": {
    "bookmarks": [
      {
        "name": "File Start",
        "offset": 0,
        "description": "Beginning of file / magic bytes"
      },
      {
        "name": "First Signature Offset",
        "offset": 4,
        "description": "End of primary signature region"
      },
      {
        "name": "Content Start",
        "offset": 64,
        "description": "Approximate content start after headers"
      }
    ]
  },
  "exportTemplates": [
    {
      "id": "summary",
      "label": "Summary Report",
      "template": "Format: {formatName}\\nVersion: {version}\\nDescription: {description}"
    },
    {
      "id": "forensic",
      "label": "Forensic Report",
      "template": "Format: {formatName}\\nRisk: {forensic.riskLevel}\\nSignature: {signatures[0].value} @ offset {signatures[0].offset}"
    }
  ],
  "formatRelationships": [
    {
      "formatId": "oxps",
      "relation": "successor",
      "note": "OXPS (ECMA-388) supersedes XPS on Windows 8+"
    },
    {
      "formatId": "pdf",
      "relation": "equivalent",
      "note": "PDF is the dominant fixed-layout format"
    },
    {
      "formatId": "docx",
      "relation": "related",
      "note": "DOCX prints to XPS via the XPS document writer"
    }
  ],
  "software": [
    "Microsoft XPS Viewer",
    "Windows XPS Document Writer",
    "XPS Essentials Pack",
    "SumatraPDF"
  ],
  "useCases": [
    "Fixed-layout document publishing",
    "Print-ready document sharing",
    "Document archival",
    "High-fidelity document exchange"
  ],
  "technicalDetails": "XPS (ECMA-313 / Microsoft XML Paper Specification) is a ZIP container with XAML-derived fixed page markup. Font resources are subset-embedded and obfuscated with GUID-based filenames. XPS was replaced by OXPS (ECMA-388) in Windows 8+. The namespace URI is schemas.microsoft.com/xps/2005/06.",
  "completenessScore": 88
}




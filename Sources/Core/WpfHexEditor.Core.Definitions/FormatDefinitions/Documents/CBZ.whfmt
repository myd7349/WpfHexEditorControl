{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "Comic Book ZIP",
  "formatId": "CBZ",
  "version": "2.02",
  "extensions": [
    ".cbz"
  ],
  "description": "Comic Book ZIP archive - a ZIP container holding sequential images (JPG/PNG/GIF) for digital comics reading. The file begins with a ZIP Local File Header. CBZ files contain ordered image files that comic readers display in sequence.",
  "category": "Documents",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "PKWARE APPNOTE.TXT - ZIP File Format Specification",
      "ISO/IEC 21320-1:2015 - Document Container File"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/Comic_book_archive",
      "https://pkware.cachefly.net/webdocs/casestudies/APPNOTE.TXT",
      "https://en.wikipedia.org/wiki/ZIP_(file_format)"
    ]
  },
  "detection": {
    "signature": "504B0304",
    "offset": 0,
    "required": true,
    "validation": {
      "minFileSize": 100,
      "maxSignatureOffset": 0
    }
  },
  "variables": {
    "currentOffset": 0,
    "zipSignature": 0,
    "versionNeeded": 0,
    "generalPurposeFlags": 0,
    "compressionMethod": 0,
    "lastModTime": 0,
    "lastModDate": 0,
    "crc32": 0,
    "compressedSize": 0,
    "uncompressedSize": 0,
    "filenameLength": 0,
    "extraFieldLength": 0,
    "compressionRatio": 0,
    "zipFileCount": 0,
    "zipCentralDirSize": 0,
    "zipCommentLength": 0,
    "zipComment": "",
    "eocdOffset": -1,
    "isZip64": false,
    "formattedSize": "",
    "zipFirstEntryName": "",
    "zipEntryList": "",
    "zipTotalUncompressedSize": 0,
    "zipEntryCount": 0
  },
  "functions": {
    "parseZIPArchive": "Parse End of Central Directory for archive statistics",
    "parseZipEntries": "Parse Central Directory to extract entry names and total uncompressed size",
    "formatFileSize(var:zipCentralDirSize)": "Format central directory size"
  },
  "blocks": [
    {
      "type": "signature",
      "name": "ZIP Local File Header Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "PK\\x03\\x04 magic number identifying a ZIP Local File Header (0x04034B50 LE)",
      "storeAs": "zipSignature",
      "valueType": "uint32",
      "validation": {
        "expectedValue": "0x04034B50"
      }
    },
    {
      "type": "field",
      "name": "Version Needed to Extract",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Minimum ZIP specification version needed to extract this entry",
      "storeAs": "versionNeeded",
      "valueType": "uint16",
      "valueMap": {
        "10": "1.0 (Default)",
        "20": "2.0 (Deflate)",
        "45": "4.5 (ZIP64)",
        "63": "6.3 (LZMA)"
      }
    },
    {
      "type": "field",
      "name": "General Purpose Bit Flags",
      "offset": 6,
      "length": 2,
      "color": "#45B7D1",
      "opacity": 0.3,
      "description": "Bit flags controlling encryption, compression options, and data descriptor presence",
      "storeAs": "generalPurposeFlags",
      "valueType": "uint16",
      "bitfields": [
        {
          "bit": 0,
          "name": "Encrypted",
          "description": "If set, the file data is encrypted",
          "valueMap": {
            "0": "Not encrypted",
            "1": "Encrypted"
          }
        },
        {
          "bit": 3,
          "name": "Data Descriptor",
          "description": "If set, CRC-32 and sizes are in a data descriptor after the file data",
          "valueMap": {
            "0": "No data descriptor",
            "1": "Data descriptor follows file data"
          }
        }
      ]
    },
    {
      "type": "field",
      "name": "Compression Method",
      "offset": 8,
      "length": 2,
      "color": "#96CEB4",
      "opacity": 0.3,
      "description": "Algorithm used to compress the file data in this entry",
      "storeAs": "compressionMethod",
      "valueType": "uint16",
      "valueMap": {
        "0": "Stored (no compression)",
        "8": "Deflate",
        "14": "LZMA"
      }
    },
    {
      "type": "field",
      "name": "Last Modification Time",
      "offset": 10,
      "length": 2,
      "color": "#FFEAA7",
      "opacity": 0.3,
      "description": "File last modification time in MS-DOS format (5-bit hour, 6-bit minute, 5-bit second/2)",
      "storeAs": "lastModTime",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Last Modification Date",
      "offset": 12,
      "length": 2,
      "color": "#DDA0DD",
      "opacity": 0.3,
      "description": "File last modification date in MS-DOS format (7-bit year+1980, 4-bit month, 5-bit day)",
      "storeAs": "lastModDate",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "CRC-32",
      "offset": 14,
      "length": 4,
      "color": "#FF8C69",
      "opacity": 0.3,
      "description": "CRC-32 checksum of the uncompressed file data",
      "storeAs": "crc32",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Compressed Size",
      "offset": 18,
      "length": 4,
      "color": "#87CEEB",
      "opacity": 0.3,
      "description": "Size of the compressed file data in bytes (0xFFFFFFFF if ZIP64)",
      "storeAs": "compressedSize",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Uncompressed Size",
      "offset": 22,
      "length": 4,
      "color": "#98D8C8",
      "opacity": 0.3,
      "description": "Original uncompressed size of the file data in bytes (0xFFFFFFFF if ZIP64)",
      "storeAs": "uncompressedSize",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Filename Length",
      "offset": 26,
      "length": 2,
      "color": "#F7DC6F",
      "opacity": 0.3,
      "description": "Length of the filename field that follows this header",
      "storeAs": "filenameLength",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Extra Field Length",
      "offset": 28,
      "length": 2,
      "color": "#BB8FCE",
      "opacity": 0.3,
      "description": "Length of the extra field that follows the filename",
      "storeAs": "extraFieldLength",
      "valueType": "uint16"
    },
    {
      "type": "computeFromVariables",
      "name": "Compression Ratio",
      "expression": "uncompressedSize > 0 ? ((1 - compressedSize / uncompressedSize) * 100) : 0",
      "storeAs": "compressionRatio",
      "description": "Percentage reduction from compression of the first ZIP entry"
    },
    {
      "type": "conditional",
      "name": "Encryption Check",
      "condition": "(generalPurposeFlags & 1) == 1",
      "trueLabel": "This CBZ comic archive is encrypted",
      "falseLabel": "This CBZ comic archive is not encrypted",
      "description": "Checks bit 0 of general purpose flags to determine if the archive entry is encrypted"
    },
    {
      "type": "metadata",
      "name": "Total Files in Archive",
      "variable": "zipFileCount",
      "description": "Total number of files/entries in the comic book archive"
    },
    {
      "type": "metadata",
      "name": "Central Directory Size",
      "variable": "formattedSize",
      "description": "Human-readable size of the ZIP central directory"
    },
    {
      "type": "metadata",
      "name": "ZIP64 Format",
      "variable": "isZip64",
      "description": "true if ZIP64 format, false if standard ZIP"
    },
    {
      "type": "metadata",
      "name": "First Entry Name",
      "variable": "zipFirstEntryName",
      "description": "Name of the first file in the ZIP archive (typically the first comic page image)"
    },
    {
      "type": "metadata",
      "name": "Package Contents",
      "variable": "zipEntryList",
      "description": "List of all files/entries inside the comic book archive"
    },
    {
      "type": "metadata",
      "name": "Total Uncompressed Size",
      "variable": "zipTotalUncompressedSize",
      "description": "Total uncompressed size of all entries in the archive (bytes)"
    }
  ],
  "MimeTypes": [
    "application/vnd.comicbook+zip",
    "application/x-cbz"
  ],
  "Software": [
    "CDisplayEx",
    "ComicRack",
    "YACReader",
    "Calibre"
  ],
  "UseCases": [
    "Digital comic book reading",
    "Comic book archival",
    "Manga distribution",
    "Sequential art packaging"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "comprehensive",
    "BlocksDefined": 19,
    "ValidationRules": 3,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "DocumentFormat": true,
    "Container": "ZIP",
    "Endianness": "little-endian",
    "HeaderSize": 30,
    "VariableLengthFields": "filename and extra field follow the fixed 30-byte header"
  },
  "forensic": {
    "category": "document",
    "riskLevel": "medium",
    "suspiciousPatterns": [],
    "notes": [
      "ZIP-based container; extract and inspect inner files for malicious payloads.",
      "Metadata in core properties may reveal author identity and edit history.",
      "Embedded macros or scripts may execute on open."
    ]
  },
  "aiHints": [
    "Comic Book ZIP archive - a ZIP container holding sequential images (JPG/PNG/GIF) for digital comics reading....",
    "Validate Comic Book ZIP file signature and container structure",
    "Check for embedded macros, scripts, or active content",
    "Inspect document metadata: author, timestamps, revisions",
    "Page images are read in filename-sorted order; padded numbering (001.jpg, 002.jpg) ensures correct sequence.",
    "ComicInfo.xml (if present) uses the ComicRack schema with Title, Series, Volume, and Number fields.",
    "CBZ files may contain JPEG, PNG, WebP, or GIF images — check individual file headers.",
    "Right-to-left reading order for manga is specified in ComicInfo.xml ReadingDirection field.",
    "Some CBZ files include a Thumbs.db or .DS_Store file exposing platform metadata.",
    "Large CBZ archives may contain thousands of high-resolution images — beware of memory exhaustion."
  ],
  "diff": {
    "keyFields": [
      "zip_signature",
      "version_needed",
      "general_purpose_flags",
      "compression_method",
      "compressed_size",
      "uncompressed_size",
      "filename_length",
      "extra_field_length"
    ],
    "ignoreFields": [
      "last_mod_time",
      "last_mod_date"
    ],
    "note": "Inferred semantic diff for CBZ. Compare key structural fields; ignore volatile metadata."
  },
  "repair": [
    {
      "name": "FixSignature",
      "trigger": "SignatureMismatch",
      "action": "set_value",
      "target": "0",
      "value": "04034B50",
      "length": 4,
      "description": "Restore the 4-byte CBZ signature at offset 0."
    }
  ],
  "fuzz": {
    "preserveChecksums": false,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "zip_signature",
        "mutation": "corrupt_signature",
        "description": "Corrupt magic bytes at offset 0 — parser must reject."
      },
      {
        "field": "version_needed",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      },
      {
        "field": "general_purpose_flags",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      },
      {
        "field": "compression_method",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      },
      {
        "field": "compressed_size",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      },
      {
        "field": "uncompressed_size",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      },
      {
        "field": "filename_length",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      },
      {
        "field": "extra_field_length",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      }
    ],
    "note": "Inferred fuzz strategies for CBZ. Hand-tune weights/rates per format if needed."
  },
  "lastUpdated": "2026-05-20",
  "signatures": [
    {
      "value": "504B0304",
      "offset": 0,
      "label": "CBZ signature",
      "weight": 100,
      "strength": "strong"
    }
  ],
  "maxSignatureOffset": 4,
  "structure": {
    "fields": [
      {
        "name": "LocalFileHeader",
        "offset": 0,
        "size": 30,
        "type": "struct",
        "description": "ZIP local file header"
      },
      {
        "name": "ComicInfoXml",
        "offset": -1,
        "size": -1,
        "type": "xml",
        "description": "Optional ComicInfo.xml with title, series, and issue metadata"
      },
      {
        "name": "ImagePage1",
        "offset": -1,
        "size": -1,
        "type": "image",
        "description": "First page image (JPEG or PNG), ordered alphabetically"
      },
      {
        "name": "ImagePages",
        "offset": -1,
        "size": -1,
        "type": "image",
        "description": "Remaining page images in reading order"
      }
    ]
  },
  "inspector": {
    "displayFields": [
      "formatName",
      "version",
      "description"
    ],
    "valueMaps": {},
    "tooltips": {}
  },
  "assertions": [
    {
      "field": "signatures[0].value",
      "op": "notEmpty",
      "description": "Primary signature must be present"
    },
    {
      "field": "maxSignatureOffset",
      "op": "greaterThanOrEqual",
      "value": 0,
      "description": "Max signature offset must be non-negative"
    },
    {
      "field": "completenessScore",
      "op": "greaterThanOrEqual",
      "value": 80,
      "description": "Format completeness score must be at least 80"
    }
  ],
  "navigation": {
    "bookmarks": [
      {
        "name": "File Start",
        "offset": 0,
        "description": "Beginning of file / magic bytes"
      },
      {
        "name": "First Signature Offset",
        "offset": 4,
        "description": "End of primary signature region"
      },
      {
        "name": "Content Start",
        "offset": 64,
        "description": "Approximate content start after headers"
      }
    ]
  },
  "exportTemplates": [
    {
      "id": "summary",
      "label": "Summary Report",
      "template": "Format: {formatName}\\nVersion: {version}\\nDescription: {description}"
    },
    {
      "id": "forensic",
      "label": "Forensic Report",
      "template": "Format: {formatName}\\nRisk: {forensic.riskLevel}\\nSignature: {signatures[0].value} @ offset {signatures[0].offset}"
    }
  ],
  "formatRelationships": [
    {
      "formatId": "cbr",
      "relation": "equivalent",
      "note": "CBR is the RAR-archive equivalent of CBZ"
    },
    {
      "formatId": "epub",
      "relation": "related",
      "note": "EPUB3 Fixed Layout is a standards-based alternative"
    },
    {
      "formatId": "pdf",
      "relation": "related",
      "note": "PDF is commonly used for digital comic distribution"
    }
  ],
  "software": [
    "CDisplayEx",
    "ComicRack",
    "YACReader",
    "Calibre"
  ],
  "useCases": [
    "Digital comic book reading",
    "Comic book archival",
    "Manga distribution",
    "Sequential art packaging"
  ],
  "technicalDetails": "CBZ is a ZIP archive containing sequentially named image files (JPEG, PNG, WebP) that represent comic book pages. Pages are ordered alphabetically or numerically by filename. An optional ComicInfo.xml (ComicRack schema) provides metadata. CBZ is the most widely supported digital comic format.",
  "completenessScore": 88
}




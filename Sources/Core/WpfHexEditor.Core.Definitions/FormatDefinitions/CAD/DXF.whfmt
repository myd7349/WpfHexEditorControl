  ],
  "formatRelationships": {
    "category": "CAD",
    "extensions": [".dxf"],
    "relatedFormats": ["DWG", "DWF", "DWT", "SVG"],
    "note": "DXF is the open, documented interchange format for AutoCAD's proprietary DWG format. Both share the same $ACADVER version codes (AC1009=R12 through AC1032=2018+). DXF is human-readable ASCII (or compact binary); DWG is proprietary binary. DXF is the universal CAD exchange format supported by virtually all CAD software."
  },

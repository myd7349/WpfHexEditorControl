    "relatedFormats": ["DWG", "DWF", "STEP", "IGES"],
    "note": "Open text-based alternative to proprietary DWG; both are Autodesk formats; DXF preferred for interoperability"
  },
  "MimeTypes": ["image/vnd.dxf", "application/dxf", "text/plain"],

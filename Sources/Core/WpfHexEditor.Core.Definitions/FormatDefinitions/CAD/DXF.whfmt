    },
    {
      "name": "DXF Summary (CSV)",
      "format": "csv",
      "fields": ["acadVersion", "isBinary"]
    }
  ],
  "forensic": {
    "category": "cad",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "THUMBNAILIMAGE section may contain an embedded PNG that could be inspected for steganographic content",
      "External OLE object references in OLEFRAME entities may link to external resources"
    ]
  },
  "aiHints": {
    "analysisContext": "ASCII DXF is a line-oriented group-code format starting with '  0\\nSECTION'. Group codes (integers) on one line, values on the next. Sections: HEADER, CLASSES, TABLES, BLOCKS, ENTITIES, OBJECTS, THUMBNAILIMAGE. Binary DXF starts with 'AutoCAD Binary DXF\\r\\n\\x1A\\x00'.",
    "suggestedInspections": [
      "Identify ASCII vs binary DXF from first byte: 0x20 (space) = ASCII, 0x41 ('A') = binary",
      "For ASCII DXF: scan for $ACADVER variable to determine AutoCAD version compatibility",
      "Enumerate section boundaries by finding group code 0 / 'SECTION' and 0 / 'ENDSEC' pairs",
      "Count entity types in ENTITIES section to estimate drawing complexity and content categories",
      "Check for THUMBNAILIMAGE section to extract embedded preview PNG for quick content identification"
    ]
  },
  "software": [
    "AutoCAD",
    "LibreCAD",
    "FreeCAD",
    "QCAD",
    "BricsCAD",
    "SketchUp",
    "Inkscape (2D DXF import/export)"
  ],
  "formatRelationships": {

{
  "diffMode": "text",
  "formatName": "AutoCAD DXF",
  "version": "1.0",
  "extensions": [".dxf"],
  "description": "DXF (Drawing Exchange Format) is AutoCAD's open text-based CAD interchange format created by Autodesk. ASCII DXF starts with '  0' (two spaces + '0') on line 1 followed by 'SECTION' on line 2, then '  2' and 'HEADER' for the first section. The group code system: an integer group code on one line followed by its string or numeric value on the next line. Group code 0 = entity/section type, code 2 = name string, code 1 = primary text, codes 10/20/30 = X/Y/Z coordinates, codes 70-79 = integer flags. Sections: HEADER ($ACADVER, $INSUNITS, $EXTMIN/EXTMAX, etc.), CLASSES, TABLES (layers, linetypes, text styles, dimension styles, block records, UCSs, views), BLOCKS (named block definitions), ENTITIES (LINE, ARC, CIRCLE, LWPOLYLINE, POLYLINE, INSERT, TEXT, MTEXT, DIMENSION, HATCH, SPLINE, 3DFACE, SOLID, ELLIPSE), OBJECTS (non-graphic objects: dictionaries, groups, layouts, plotsettings), THUMBNAILIMAGE (preview PNG), EOF marker. Binary DXF: starts with 'AutoCAD Binary DXF\\r\\n\\x1A\\x00' (22 bytes).",
  "category": "CAD",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "AutoCAD DXF Reference — Autodesk Developer Documentation",
      "DXF Format Specification AutoCAD 2018 — Autodesk",
      "Open Design Alliance DXF Reference (OpenDWG)"
    ],
    "WebLinks": [
      "https://help.autodesk.com/view/OARX/2024/ENU/?guid=GUID-235B22E0-A567-4CF6-92D3-38A2306D73F3",
      "https://en.wikipedia.org/wiki/AutoCAD_DXF",
      "https://www.opendesign.com/blog/2021/march/dxf-file-format",
      "https://docs.fileformat.com/cad/dxf/"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "2020300A53454354494F4E", "offset": 0, "label": "  0\\nSECTION — ASCII DXF group code 0 followed by SECTION entity type", "weight": 0.9 },
      { "value": "4175746F43414420426 96E61727920445846", "offset": 0, "label": "AutoCAD Binary DXF — binary DXF 18-byte text header prefix", "weight": 1.0 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.4,
    "required": true,
    "Strength": "Medium",
    "EntropyHint": { "min": 2.0, "max": 6.5 },
    "validation": {
      "minFileSize": 30,
      "maxSignatureOffset": 0,
      "note": "ASCII DXF: starts with '  0\\n'. Binary DXF: starts with 'AutoCAD Binary DXF\\r\\n\\x1A\\x00'."
    }
  },
  "variables": {
    "firstByte": 0,
    "dxfHeader": "",
    "acadVersion": "",
    "isBinary": false
  },
  "blocks": [
    {
      "type": "field",
      "name": "First Byte",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "First byte of the DXF file. For ASCII DXF: 0x20 (space character), since the first line is '  0' (two spaces). For Binary DXF: 0x41 ('A' for 'AutoCAD Binary DXF'). This byte is the fastest discriminator between ASCII and binary DXF formats.",
      "storeAs": "firstByte",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "DXF Header Start",
      "offset": 0,
      "length": 10,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "First 10 bytes identifying the DXF format. ASCII DXF: '  0\\nSECTIO' (two spaces, '0', newline, start of 'SECTION'). Binary DXF: 'AutoCAD Bi' (first 10 of the 22-byte binary magic 'AutoCAD Binary DXF\\r\\n\\x1A\\x00'). Used in combination with the first byte to distinguish format variants.",
      "storeAs": "dxfHeader",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "HEADER Section Variables",
      "offset": 0,
      "description": "The HEADER section contains AutoCAD drawing variables as group code / value pairs. Key variables: $ACADVER (DXF version string: AC1015=2000, AC1018=2004, AC1021=2007, AC1024=2010, AC1027=2013, AC1032=2018, AC1035=2021), $INSUNITS (insertion units: 0=unitless, 1=inches, 2=feet, 4=mm, 5=cm, 6=m), $EXTMIN and $EXTMAX (drawing extents), $ORTHOMODE, $LTSCALE (line type scale), $LIMMIN/$LIMMAX (drawing limits), $MEASUREMENT (0=Imperial, 1=Metric)."
    },
    {
      "type": "metadata",
      "name": "Entity Types Reference",
      "offset": 0,
      "description": "Common DXF entity types in the ENTITIES and BLOCKS sections: LINE (group codes 10/20/30 = start point, 11/21/31 = end point), ARC (10/20/30 = center, 40 = radius, 50 = start angle, 51 = end angle), CIRCLE (center + radius), LWPOLYLINE (lightweight 2D polyline with vertex list), INSERT (block reference with name + insertion point + scale + rotation), TEXT and MTEXT (string content + position + height + style), DIMENSION (measurement annotations), HATCH (area fill with boundary paths), SPLINE (NURBS curve)."
    }
  ],
  "assertions": [
    {
      "name": "ValidFirstByte",
      "expression": "firstByte == 32 || firstByte == 65",
      "severity": "error",
      "message": "First byte must be 0x20 (space, ASCII DXF) or 0x41 ('A', Binary DXF). This does not appear to be a valid DXF file."
    },
    {
      "name": "ValidGroupCodeStructure",
      "expression": "dxfHeader.startsWith('  0') || dxfHeader.startsWith('AutoCAD')",
      "severity": "warning",
      "message": "DXF format not confirmed: file does not start with '  0' (ASCII) or 'AutoCAD Binary DXF' (binary). May be a non-standard variant."
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "DXF Start", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "HEADER Section", "offset": 0, "icon": "\uE8B7", "color": "#FFE66D" },
      { "name": "ENTITIES Section", "offset": 0, "icon": "\uE946", "color": "#4ECDC4" }
    ]
  },
  "inspector": {
    "badge": "dxfHeader",
    "primaryField": "acadVersion",
    "showQualityScore": true,
    "groups": [
      {
        "title": "File Identification",
        "icon": "\uE71B",
        "fields": ["firstByte", "dxfHeader", "isBinary"]
      },
      {
        "title": "Drawing Info",

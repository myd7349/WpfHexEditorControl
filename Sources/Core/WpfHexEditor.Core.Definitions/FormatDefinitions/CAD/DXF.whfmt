{
  "diffMode": "binary",
  "formatName": "AutoCAD DXF",
  "version": "1.15",
  "extensions": [
    ".dxf"
  ],
  "description": "DXF (Drawing Exchange Format) is Autodesk's open, documented CAD interchange format designed to enable data interoperability between AutoCAD and other CAD applications. DXF exists in two forms: ASCII DXF (plain text, group-code/value pairs) and Binary DXF (compact binary with a fixed 21-byte header). ASCII DXF files start with group code '  0' (two spaces + zero, newline) followed by value 'SECTION' to begin the first section. The file is structured into named sections: HEADER ($ACADVER, $INSBASE, $LIMMIN, $LIMMAX, drawing settings), CLASSES (custom class definitions, DXF R14+), TABLES (layers, linetypes, textstyles, viewports, UCS, apps, dimstyles, block records), BLOCKS (block definitions), ENTITIES (drawing entities: LINE, ARC, CIRCLE, POLYLINE, LWPOLYLINE, TEXT, INSERT, HATCH, etc.), OBJECTS (non-graphical objects, DXF R13+), and THUMBNAILIMAGE (preview). Binary DXF begins with 'AutoCAD Binary DXF\\r\\n\\x1A\\x00' (21 bytes). The $ACADVER variable in the HEADER section carries the same AC version codes as DWG files (AC1009=R12 through AC1032=2018+).",
  "category": "CAD",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "AutoCAD DXF Reference — Autodesk Documentation",
      "DXF Format Specification — Autodesk Developer Network"
    ],
    "WebLinks": [
      "https://help.autodesk.com/view/OARX/2024/ENU/?guid=GUID-235B22E0-A567-4CF6-92D3-38A2306D73F3",
      "https://en.wikipedia.org/wiki/DXF",
      "https://www.autodesk.com/techpubs/autocad/acad2000/dxf/"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "20203020 0D0A534543 54494F4E", "offset": 0, "label": "'  0\\r\\nSECTION' — ASCII DXF standard opening (CRLF)", "weight": 1.0 },
      { "value": "20203020 0A534543 54494F4E", "offset": 0, "label": "'  0\\nSECTION' — ASCII DXF opening (LF only)", "weight": 0.9 },
      { "value": "4175746F434144 2042696E617279 2044584600", "offset": 0, "label": "'AutoCAD Binary DXF' — Binary DXF header prefix", "weight": 1.0 },
      { "value": "3020", "offset": 0, "label": "'0 ' — DXF group code 0 (weak, short prefix)", "weight": 0.4 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.4,
    "required": false,
    "Strength": "Medium",
    "EntropyHint": { "min": 3.0, "max": 5.5 },
    "validation": {
      "minFileSize": 20,
      "maxSignatureOffset": 0,
      "note": "ASCII DXF starts with group code '  0' (spaces+digit) followed by SECTION on the next line. Binary DXF starts with 'AutoCAD Binary DXF\\r\\n\\x1A\\x00' (21 bytes). Detection relies on extension + opening bytes. Short group-code prefix '0 ' alone has low confidence."
    }
  },
  "variables": {
    "dxfOpeningCode": "",
    "dxfOpeningValue": "",
    "dxfBinaryMagic": "",
    "dxfType": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "DXF Opening Group Code",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "ASCII DXF first group code: '  0\\r' or '  0\\n' (spaces + digit zero + line terminator). In ASCII DXF, every data element is represented as a group code (integer on one line) followed by a value (on the next line). Group code 0 introduces entity/section/table names. The opening '  0' followed by 'SECTION' is the universal start of all valid ASCII DXF files from R12 onward. Binary DXF instead starts with 'AutoCAD Binary DXF\\r\\n\\x1A\\x00'.",
      "storeAs": "dxfOpeningCode",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "DXF Opening Value / Binary Magic",
      "offset": 4,
      "length": 17,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "ASCII DXF: first group code value 'SECTION' (7 chars + newline) confirming the file opens with the mandatory first section declaration. Binary DXF: continuation of 'AutoCAD Binary DXF\\r\\n\\x1A\\x00' 21-byte magic header that unambiguously identifies binary DXF independent of extension. After the binary header, binary DXF encodes group codes as 16-bit integers and values in binary representation.",
      "storeAs": "dxfOpeningValue",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "DXF Opening Code",
      "variable": "dxfOpeningCode",
      "description": "First group code ('  0' for ASCII, binary prefix for Binary DXF)"
    },
    {
      "type": "metadata",
      "name": "DXF Opening Value",
      "variable": "dxfOpeningValue",
      "description": "First group value ('SECTION' for ASCII DXF) or binary magic continuation"
    }
  ],
  "assertions": [
    {
      "name": "DXF opens with group code 0",
      "expression": "dxfOpeningCode == '  0\\r' || dxfOpeningCode == '  0\\n' || dxfOpeningCode == '0\\r\\n' || dxfOpeningValue == 'AutoCAD'",
      "severity": "warning",
      "message": "DXF file should open with group code '  0' (SECTION) or Binary DXF magic — may be non-standard or corrupt"
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "DXF File Start", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" }
    ]
  },

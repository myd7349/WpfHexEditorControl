  "aiHints": {
    "analysisContext": "SAT is ASCII ACIS kernel serialization. File structure: header lines (version, product info, units), then entity body with one entity per line in format: 'entity-name entity-id # attrib transform subtype fields... #'. Entity hierarchy: body → lump → ref → shell → face → loop → edge → vertex. Geometric types: plane-surface, sphere-surface, cone-surface, torus-surface, spline-surface (NURBS), straight-curve, ellipse-curve, intcurve, pcurve. File ends with 'End-of-ACIS-data'. SAB (.sab) is binary-encoded equivalent. Version decode: first integer = ACIS version * 100 (400=4.0, 700=7.0, 21800=21.8). Lines 2-3 = product info strings. Line 4 = mm_resabs, mm_resnor tolerances.",
    "suggestedInspections": [
      "Line 1: ACIS version integer (400, 700, 1600, 21800) or 'ACIS ' prefix",
      "Lines 2-3: creating application name and ACIS kernel build version",
      "Search for 'End-of-ACIS-data' to confirm file completeness",
      "Count 'body' entities for solid body count; 'face' entities for surface count"
    ]
  },
  "software": [
    "AutoCAD (Autodesk)",
    "Inventor (Autodesk)",
    "SolidWorks (Dassault Systèmes)",
    "Rhino 3D",
    "Open CASCADE Technology (OCCT)",

  "blocks": [
    {
      "type": "field",
      "name": "SAT Header / Version",
      "offset": 0,
      "length": 40,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "ACIS SAT file first line: version and product information. Format varies by ACIS version: older files start with 'ACIS 1.0 Autodesk...'; newer files use a 4-integer header '400 0 1 0' (version, saved entities, product id, flags). The first integer or string identifies the ACIS kernel version. Version mapping: 400=ACIS 4.0, 700=ACIS 7.0, 1600=ACIS 16.0, 21800=ACIS 21.8.0. SAT files created by AutoCAD typically start with 'ACIS_SAT' or the ACIS version integer. The header record ends with a newline.",
      "storeAs": "satHeader",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Product / Build Info",
      "offset": 40,
      "length": 60,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "ACIS SAT second header line (lines 2-3): product identification string and build date. Typically contains the creating application name ('AutoCAD', 'Inventor', 'SolidWorks'), ACIS kernel build version, and platform information. Example: 'Autodesk AutoCAD 2024 (64-bit) 24.0.52.0' or 'ACIS 7.0 NT'. This information is not parsed by the ACIS reader but identifies the origin software for interchange purposes.",
      "storeAs": "satVersionInfo",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "SAT Header",
      "variable": "satHeader",
      "description": "ACIS version and file parameters from header line"
    },
    {
      "type": "metadata",
      "name": "Product Info",
      "variable": "satVersionInfo",
      "description": "Creating application and ACIS kernel version info"
    }
  ],
  "assertions": [
    {
      "name": "SAT header contains ACIS keyword",
      "expression": "satHeader != ''",
      "severity": "warning",
      "message": "SAT file header line is empty — may not be a valid ACIS SAT file"
    }
  ],

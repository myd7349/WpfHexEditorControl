{
  "diffMode": "binary",
  "formatName": "ACIS SAT",
  "version": "1.15",
  "extensions": [
    ".sat",
    ".sab"
  ],
  "description": "SAT (Standard ACIS Text) is the ASCII text serialization format for the ACIS geometric modeling kernel developed by Spatial Technology (now part of Dassault Systèmes). ACIS is the CAD kernel underlying AutoCAD, Inventor, SolidWorks, and many other products. SAT files start with a header record on the first line: 'ACIS_SAT major minor' or more commonly a version integer followed by product info (e.g., '700 0 1 0' = version 7.0, entities=0, n=1, history=0). Alternatively, older files start with a product string like 'ACIS 1.0 ...' or just the version integer. The header is followed by a body section containing entity instances (lump, ref, shell, face, loop, edge, vertex, point, curve, surface) and ends with 'End-of-ACIS-data'. SAB (.sab) is the binary equivalent of SAT with the same entity structure but binary-encoded. Version numbers: 400=ACIS 4.0, 700=ACIS 7.0, 1600=ACIS 16.0, 21800=ACIS 21.8.",
  "category": "CAD",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ACIS SAT File Format — Spatial/Dassault Systèmes",
      "Open CASCADE SAT Reader Documentation"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/ACIS",
      "https://wiki.mcneel.com/rhino/acisformat",
      "https://doc.spatial.com/articles/a/c/i/ACIS_SAT_file_format"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "41434953 5F534154", "offset": 0, "label": "'ACIS_SAT' — explicit ACIS SAT file header", "weight": 1.0 },
      { "value": "41434953 20", "offset": 0, "label": "'ACIS ' — older ACIS header prefix (version string)", "weight": 0.9 },
      { "value": "3430 3020", "offset": 0, "label": "'400 ' — ACIS version 4.0 integer header", "weight": 0.6 },
      { "value": "3730 3020", "offset": 0, "label": "'700 ' — ACIS version 7.0 integer header", "weight": 0.6 },
      { "value": "3136303020", "offset": 0, "label": "'1600 ' — ACIS version 16.0 integer header", "weight": 0.6 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.6,

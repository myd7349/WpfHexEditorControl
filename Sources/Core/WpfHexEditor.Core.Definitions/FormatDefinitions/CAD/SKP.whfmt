{
  "diffMode": "binary",
  "formatName": "SketchUp Model",
  "version": "1.15",
  "extensions": [
    ".skp"
  ],
  "description": "SKP is the proprietary binary file format for SketchUp (originally @Last Software, acquired by Google in 2006, now owned by Trimble). SKP files start with the ASCII string 'SketchUp Model' at offset 0, followed by a null-terminated version string identifying the SketchUp version (e.g., '\\x00' + major version byte). After the header, the file contains a binary component archive encoding the 3D model: geometry (vertices, edges, faces, surfaces), materials, textures (embedded BMP/PNG), layers, scenes (named views), shadows, section planes, and entity attributes. The SKP format uses Google Protocol Buffers internally in newer versions (2017+) and a custom tag-length-value binary encoding in older versions. SKP files are not publicly documented; the only official SDK is the SketchUp C API. Community reverse-engineering has produced open-source readers: LibreSketchUp project and the FreeCAD SKP importer.",
  "category": "CAD",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "SketchUp File Format — Trimble (proprietary, undocumented)",
      "LibreSketchUp — Community reverse-engineering project"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/SketchUp",
      "https://extensions.sketchup.com/developer_center/sketchup_c_api",
      "https://github.com/LibreSketchUp/LibreSketchUp"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "536B65746368557020 4D6F64656C", "offset": 0, "label": "'SketchUp Model' — SKP file magic header (ASCII)", "weight": 1.0 }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 4.5, "max": 7.5 },
    "validation": {
      "minFileSize": 16,
      "maxSignatureOffset": 0,
      "note": "All SKP files start with the ASCII string 'SketchUp Model' (14 bytes: 53 6B 65 74 63 68 55 70 20 4D 6F 64 65 6C) at offset 0. This is a strong, unique identifier. FFFE (BOM) is NOT the correct magic — SKP starts with ASCII text."
    }
  },
  "variables": {
    "skpMagic": "",
    "skpVersionByte": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "SketchUp Model Magic",
      "offset": 0,
      "length": 14,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "SKP file magic: 'SketchUp Model' (14 ASCII bytes: 53 6B 65 74 63 68 55 70 20 4D 6F 64 65 6C). This null-terminated ASCII string at offset 0 is the unique identifier for all SketchUp model files across all versions. The magic is followed by a null byte (0x00) and then a 4-byte LE integer encoding the SKP format version. Format version mapping: 3=SketchUp 3, 4=SketchUp 4, 5=SketchUp 5, 6=SketchUp 6, 7=SketchUp 7/8, 14=SketchUp 2014, 15=SketchUp 2015, 16=SketchUp 2016+.",
      "storeAs": "skpMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Format Version",
      "offset": 15,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "SKP format version number as a 4-byte little-endian unsigned integer at offset 15 (after magic + null terminator). The format version identifies the SketchUp release that created the file. Version numbers are NOT the same as the SketchUp year version: v3=SketchUp 3.0, v4=SketchUp 4.0, v14=SketchUp 2014, v15=2015, v16=2016, v17=2017 (switched to Protobuf-based format), v18=2018, v19=2019, v20=2020, v21=2021, v22=2022, v23=2023.",
      "storeAs": "skpVersionByte",
      "valueType": "uint32",
      "endianness": "little",
      "valueMap": {
        "3": "SketchUp 3",
        "4": "SketchUp 4",
        "5": "SketchUp 5",
        "6": "SketchUp 6",
        "7": "SketchUp 7/8",
        "14": "SketchUp 2014",
        "15": "SketchUp 2015",
        "16": "SketchUp 2016",
        "17": "SketchUp 2017",
        "18": "SketchUp 2018",
        "19": "SketchUp 2019",
        "20": "SketchUp 2020",
        "21": "SketchUp 2021",
        "22": "SketchUp 2022",
        "23": "SketchUp 2023"
      }
    },
    {
      "type": "metadata",
      "name": "SKP Magic",
      "variable": "skpMagic",
      "description": "'SketchUp Model' — file identification string"
    },
    {
      "type": "metadata",
      "name": "Format Version",
      "variable": "skpVersionByte",
      "description": "SketchUp format version integer (3-23 = SketchUp 3 to 2023)"
    }
  ],

  ],
  "forensic": {
    "category": "cad",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "CXF (Character Exchange Format) is AutoCAD's Unicode SHX font source format. Plain ASCII text. Structure: comment lines starting with ';', then glyph definitions '[0xXXXX,width,baseline]' followed by vector commands. Drawing commands: 'L x1,y1,x2,y2' (line segment), 'A cx,cy,radius,start_angle,end_angle' (arc), 'M x,y' (move without drawing). Coordinates in font units (normalized). Not to be confused with 3D point cloud CXF — this is AutoCAD font shape format. Compile with AutoCAD COMPILE command to produce binary .shx. Font glyph entry format: '[0x0041,0.8,0.0]\\nL 0.0,0.0,0.2,1.0\\nL 0.2,1.0,0.4,0.0\\nL 0.1,0.5,0.3,0.5'.",
    "suggestedInspections": [
      "First non-empty line: should be ';' comment or '[0x' glyph entry",
      "Count '[0x' entries for number of glyphs defined in the font",
      "First glyph header: '[0xXXXX,width,baseline]' shows Unicode code point and metrics",
      "Line commands 'L x1,y1,x2,y2' and arc commands 'A cx,cy,r,a1,a2' define glyph vectors"
    ]
  },
  "software": [
    "AutoCAD (Autodesk) — compile CXF to SHX with COMPILE command",
    "Inkscape (manual font creation reference)",
    "Custom font development tools for AutoCAD"
  ],
  "formatRelationships": {
    "category": "CAD",
    "extensions": [".cxf"],
    "relatedFormats": ["SHX", "SHP", "TTF"],
    "note": "CXF is the Unicode-capable successor to AutoCAD's SHP (shape file) format. CXF compiles to SHX (compiled shape font) using AutoCAD's COMPILE command. TTF (TrueType) fonts are also supported in AutoCAD but CXF/SHX is the traditional AutoCAD vector font format. Note: .cxf extension is not a 3D point cloud format — the previous 'Cloud Point File' description was incorrect."
  },

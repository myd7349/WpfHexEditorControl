{
  "diffMode": "binary",
  "formatName": "AutoCAD Character Exchange Format",
  "version": "2.43",
  "extensions": [
    ".cxf"
  ],
  "description": "CXF (Character Exchange Format) is AutoCAD's plain-text font shape definition format for storing custom SHX (shape) font glyph definitions. CXF files define individual character glyphs using a series of vector commands: lines, arcs, and pen movements at specified coordinates. Each glyph begins with a header line starting with '[' containing the Unicode code point or character identifier, followed by vector drawing commands. The format was introduced with AutoCAD 2009 for Unicode SHX font support. CXF supersedes the older SHP (Shape File) binary format. CXF is not related to point cloud formats. Example glyph entry: '[0x0041,1.0,0.15]' (Unicode 0x41 = 'A', width=1.0, baseline=0.15) followed by vector command lines with X,Y coordinates for the character outline. CXF files can be compiled with AutoCAD's COMPILE command to produce SHX font files.",
  "category": "CAD",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "AutoCAD CXF Font Format — Autodesk Documentation",
      "AutoCAD SHX and CXF Font Reference"
    ],
    "WebLinks": [
      "https://help.autodesk.com/view/OARX/2024/ENU/?guid=GUID-2E9CE93F-3B6D-489C-95A7-AD1F85FA71F4",
      "https://www.autodesk.com/techpubs/autocad/",
      "https://en.wikipedia.org/wiki/SHX_(AutoCAD)"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "3B20436861726163 74657220446566696E6974696F6E73", "offset": 0, "label": "'; Character Definitions' — CXF file comment header", "weight": 0.8 },
      { "value": "3B", "offset": 0, "label": "';' — CXF semicolon comment line at offset 0", "weight": 0.3 },
      { "value": "5B30", "offset": 0, "label": "'[0' — CXF glyph entry start (Unicode codepoint)", "weight": 0.4 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.3,
    "required": false,
    "Strength": "Weak",
    "EntropyHint": { "min": 2.5, "max": 4.5 },
    "validation": {
      "minFileSize": 10,
      "maxSignatureOffset": 0,
      "note": "CXF files are plain text. They typically start with semicolon comment lines (';') followed by glyph definitions starting with '[' (bracket + Unicode codepoint). Extension (.cxf) is the primary detection method. Note: .cxf extension conflicts with other uses in different contexts."
    }
  },
  "variables": {
    "cxfFirstLine": "",
    "cxfComment": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "CXF Header Comment",
      "offset": 0,
      "length": 40,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "CXF font file first line: typically a semicolon-prefixed comment describing the font file. Semicolons (';') introduce single-line comments in CXF. The first line commonly contains the font name, creator, and copyright information (e.g., '; Character Definitions for font ABC'). After the comment lines, the glyph definitions begin with entries in the format '[0xXXXX,width,baseline]' where 0xXXXX is the Unicode code point, width is the character advance width in font units, and baseline offset defines the descender distance. Drawing commands follow: 'L x1,y1,x2,y2' (line), 'A cx,cy,r,start,end' (arc).",
      "storeAs": "cxfFirstLine",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "First Glyph Entry",
      "offset": 40,
      "length": 30,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "CXF first glyph definition after any comment lines. Format: '[0xXXXX,width,baseline]' where 0xXXXX is the Unicode code point in hex (e.g., 0x0041 for letter 'A'), width is the advance width in font units (float, e.g., 1.0), and baseline is the Y offset for the baseline (float, e.g., 0.15). Each glyph entry is followed by vector drawing commands defining the glyph outline. A single CXF file may contain hundreds to thousands of glyph definitions for a complete Unicode font.",
      "storeAs": "cxfComment",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Header Comment",
      "variable": "cxfFirstLine",
      "description": "CXF font file comment header"
    },
    {
      "type": "metadata",
      "name": "First Glyph",
      "variable": "cxfComment",
      "description": "First glyph entry header"
    }
  ],
  "assertions": [
    {
      "name": "CXF has content",
      "expression": "cxfFirstLine != ''",
      "severity": "warning",
      "message": "CXF font file appears empty — no header content found"
    }
  ],
  "navigation": {
    "bookmarks": [

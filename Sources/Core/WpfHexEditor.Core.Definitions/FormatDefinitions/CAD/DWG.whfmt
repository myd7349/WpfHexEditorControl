{
  "diffMode": "binary",
  "formatName": "AutoCAD DWG",
  "version": "1.0",
  "extensions": [".dwg"],
  "description": "AutoCAD DWG is the proprietary binary drawing format used natively by AutoCAD. The 6-byte header starts with 'AC' followed by a 4-character version code identifying the AutoCAD release: AC1015=AutoCAD 2000, AC1018=AutoCAD 2004, AC1021=AutoCAD 2007, AC1024=AutoCAD 2010, AC1027=AutoCAD 2013, AC1032=AutoCAD 2018, AC1035=AutoCAD 2021+. The full header: 6-byte version string + code page (2B LE for v2004-), maintenance release version byte, count of sections (4B LE), then a section page map (variable: section_number + page_count + address pairs). DWG R2004+ uses AES encryption and page-based storage. DWG R2007+ uses Unicode throughout. The format is reverse-engineered by the Open Design Alliance (ODA) for their OpenDWG/Teigha library powering BricsCAD, LibreCAD, and others. Free LibreDWG (GNU) provides another open-source implementation. Stores all drawing data including geometry, layers, blocks, attributes, 3D solids (ACIS B-rep), text, dimensions, and paper space layouts.",
  "category": "CAD",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "OpenDWG Specification — Open Design Alliance",
      "LibreDWG DWG Format Documentation — GNU Project",
      "AutoCAD DWG File Format Overview — Autodesk"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/DWG",
      "https://www.opendesign.com/files/guestdownloads/OpenDesign_Specification_for_.dwg_files.pdf",
      "https://www.gnu.org/software/libredwg/",
      "https://help.autodesk.com/view/OARX/2024/ENU/"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "4143313031 35", "offset": 0, "label": "AC1015 — AutoCAD DWG 2000 version signature", "weight": 1.0 },
      { "value": "4143313032 31", "offset": 0, "label": "AC1021 — AutoCAD DWG 2007 version signature", "weight": 1.0 },
      { "value": "4143313032 34", "offset": 0, "label": "AC1024 — AutoCAD DWG 2010 version signature", "weight": 1.0 },
      { "value": "4143313031", "offset": 0, "label": "AC101x — AutoCAD DWG older version prefix", "weight": 0.7 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.7,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 3.5, "max": 7.5 },
    "validation": {
      "minFileSize": 6,
      "maxSignatureOffset": 0,
      "note": "First 2 bytes must be 'AC' (0x41 0x43). Bytes 2-5 must be a known 4-digit version code."
    }
  },
  "variables": {
    "dwgMagic": "",
    "versionCode": "",
    "fullVersion": "",
    "acadRelease": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "DWG Magic",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "2-byte ASCII magic 'AC' (0x41 0x43) at the absolute start of every DWG file. These two characters identify an AutoCAD drawing file and have been present in all DWG versions since the early 1980s. The 'AC' prefix is an internal Autodesk code for AutoCAD.",
      "storeAs": "dwgMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Version Code",
      "offset": 2,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "4-byte ASCII version code identifying the AutoCAD release that created this DWG file. Combined with 'AC' prefix this forms a 6-character version string. Known codes: 1015=AutoCAD 2000, 1018=AutoCAD 2004, 1021=AutoCAD 2007, 1024=AutoCAD 2010, 1027=AutoCAD 2013, 1032=AutoCAD 2018, 1035=AutoCAD 2021+. Older codes: 1009=R12, 1012=R13, 1014=R14.",
      "storeAs": "versionCode",
      "valueType": "ascii",
      "valueMap": {
        "1009": "AutoCAD Release 12",
        "1012": "AutoCAD Release 13",
        "1014": "AutoCAD Release 14",
        "1015": "AutoCAD 2000",
        "1018": "AutoCAD 2004",
        "1021": "AutoCAD 2007 (Unicode)",
        "1024": "AutoCAD 2010",
        "1027": "AutoCAD 2013",
        "1032": "AutoCAD 2018",
        "1035": "AutoCAD 2021+"
      }
    },
    {
      "type": "metadata",
      "name": "DWG Header Structure",
      "offset": 6,
      "description": "After the 6-byte version string, the DWG header varies significantly between versions. R2000-R2003 (AC1015): code_page (2B LE), maintenance_version (1B), count_of_sections (4B LE), followed by section page map entries. R2004+ (AC1018+): uses AES-encrypted page sections with a page map structure. R2007+ (AC1021+): additional Unicode support bytes, 64-bit file offsets. The header also contains system variable defaults and security settings."
    },
    {
      "type": "metadata",
      "name": "DWG Section Types",
      "offset": 6,
      "description": "DWG files use a section-based organization. Major sections: HEADER (drawing settings, system variables), CLASSES (custom entity class definitions), HANDLES (entity handle lookup table), AUXHEADER (auxiliary header data), TEMPLATE (prototype drawing data), OBJECTS (all drawing entities including Layer, BlockTable, UCS, Layout, Dictionary, Group, ImageDef), and PREVIEW (embedded thumbnail image). R2004+ sections are stored as compressed/encrypted pages."
    }
  ],
  "assertions": [
    {
      "name": "ValidMagic",
      "expression": "dwgMagic == 'AC'",
      "severity": "error",
      "message": "DWG magic 'AC' not found at offset 0. This is not a valid AutoCAD DWG file."
    },
    {
      "name": "ValidVersionCode",
      "expression": "versionCode == '1009' || versionCode == '1012' || versionCode == '1014' || versionCode == '1015' || versionCode == '1018' || versionCode == '1021' || versionCode == '1024' || versionCode == '1027' || versionCode == '1032' || versionCode == '1035'",
      "severity": "warning",
      "message": "DWG version code is not in the known list (1009-1035). File may be a very old, future, or custom DWG variant."
    },
    {
      "name": "ValidFileSize",
      "expression": "fileSize > 6",
      "severity": "error",
      "message": "DWG file is too small to contain a valid drawing. Minimum expected size is greater than 6 bytes."
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "DWG Magic + Version", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "Post-Version Header", "offset": 6, "icon": "\uE8B7", "color": "#FFE66D" }
    ]
  },
  "inspector": {
    "badge": "dwgMagic",
    "primaryField": "versionCode",
    "showQualityScore": true,
    "groups": [
      {
        "title": "File Identity",
        "icon": "\uE71B",
        "fields": ["dwgMagic", "versionCode", "acadRelease"]
      },
      {
        "title": "Format Details",
        "icon": "\uE946",
        "fields": ["fullVersion"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "DWG Header (JSON)",
      "format": "json",
      "fields": ["dwgMagic", "versionCode", "acadRelease", "fullVersion"]
    },
    {
      "name": "DWG Version (CSV)",
      "format": "csv",
      "fields": ["versionCode", "acadRelease"]
    }
  ],
  "forensic": {
    "category": "cad",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Embedded external references (XREF) may disclose internal network paths or server names",
      "PREVIEW section contains an embedded thumbnail that could be extracted for content inspection",
      "R2004+ AES encryption may protect sensitive engineering data — check security settings"
    ]
  },
  "aiHints": {
    "analysisContext": "DWG starts with 'AC' + 4-char version code (total 6 bytes). Version codes: 1015=AutoCAD 2000, 1018=2004, 1021=2007(Unicode), 1024=2010, 1027=2013, 1032=2018, 1035=2021. R2004+ uses encrypted page sections. R2007+ uses Unicode.",
    "suggestedInspections": [
      "Verify 'AC' magic at offset 0 and read 4-byte version code at offset 2 for release identification",
      "Map version code to AutoCAD release year: 1015=2000, 1018=2004, 1021=2007, 1024=2010, 1027=2013, 1032=2018, 1035=2021",
      "For R2004+ (code >= 1018): check for AES-encrypted sections requiring ODA or LibreDWG decryption",
      "Locate the PREVIEW section to extract the embedded thumbnail image for quick content identification",
      "For R2007+ (code >= 1021): expect Unicode text strings using UTF-16 encoding throughout"
    ]
  },
  "software": [

    "DocumentationLevel": "detailed",
    "BlocksDefined": 4,
    "ValidationRules": 1,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "Format": "Proprietary binary (Autodesk undocumented), reverse-engineered by ODA",
    "Endianness": "little-endian",
    "VersionCodes": "AC1009-AC1032 (R12 through AutoCAD 2023)",
    "Encryption": "AES-128 or RC4 for password-protected files (AC1021+)"
  }

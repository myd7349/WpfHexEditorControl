{
  "diffMode": "binary",
  "formatName": "Universal 3D",
  "version": "1.16",
  "extensions": [
    ".u3d"
  ],
  "description": "U3D (Universal 3D) is an ECMA standard (ECMA-363) for representing 3D content in documents, primarily for embedding 3D models in PDF files (ISO 32000-1 PDF 1.6+). U3D files start with the magic bytes 'U3D\\x00' (55 33 44 00) followed by a 4-byte version field and a 4-byte profile identifier. The format organizes data into typed blocks: File Header Block, Modifier Chain blocks (scene graph, mesh data), Node blocks (group, model, light, view), Resource blocks (mesh, shader, texture, motion), and Priority Update blocks for streaming. U3D geometry uses Continuous Level of Detail (CLOD) mesh compression with position, normal, and texture coordinate quantization. U3D was primarily used for embedding interactive 3D models in Adobe Acrobat/Reader PDF files via the 3D Artwork PDF annotation type. PRC (Product Representation Compact, ISO 14739) is the successor format for PDF 3D annotations, offering better compression and B-rep support.",
  "category": "CAD",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ECMA-363 — Universal 3D File Format (4th edition, 2007)",
      "ISO 32000-1 — PDF 1.6 3D Artwork Annotations"
    ],
    "WebLinks": [
      "https://www.ecma-international.org/publications-and-standards/standards/ecma-363/",
      "https://en.wikipedia.org/wiki/Universal_3D",
      "https://filext.com/file-extension/U3D"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "55334400", "offset": 0, "label": "'U3D\\x00' — Universal 3D ECMA-363 magic (4 bytes)", "weight": 1.0 }
    ],
    "matchMode": "any",
    "MinimumScore": 1.0,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 4.0, "max": 7.0 },
    "validation": {
      "minFileSize": 12,
      "maxSignatureOffset": 0,
      "note": "All U3D files start with 'U3D' (0x55 0x33 0x44) followed by 0x00 at offset 0. This is a strong 4-byte magic number uniquely identifying ECMA-363 U3D format."
    }
  },
  "variables": {
    "u3dSignature": "",
    "u3dMajorVersion": 0,
    "u3dMinorVersion": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "U3D Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "U3D magic number 'U3D\\x00' (bytes: 55 33 44 00). The three ASCII characters 'U3D' followed by a null byte are the unique file identifier for Universal 3D ECMA-363 format. Present at offset 0 in all valid U3D files. U3D was standardized by ECMA International and adopted into PDF 1.6 (ISO 32000-1) for embedding interactive 3D models in PDF documents. Adobe Acrobat/Reader supports U3D 3D annotations via the PDF 3DA (3D Artwork) annotation type.",
      "storeAs": "u3dSignature",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Major Version",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "U3D format major version as 16-bit signed integer (little-endian) at offset 4. The major version identifies the ECMA-363 edition. ECMA-363 4th edition (2007) defines the standard version currently in use. A negative major version in the range -1 to -255 indicates a profile identifier. Profile 0 (major version 0) is the base profile with CLOD mesh support.",
      "storeAs": "u3dMajorVersion",
      "valueType": "uint16",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Minor Version",
      "offset": 6,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "U3D format minor version as 16-bit unsigned integer (little-endian) at offset 6. Together with major version, identifies the exact ECMA-363 specification revision. After the 4-byte magic and 4-byte version, the U3D File Header Block begins at offset 8 with: block_type(4B)=0x00443355, data_length(4B), meta_length(4B), profile_identifier(4B), declaration_size(4B), file_size(8B LE uint64), character_encoding(4B, 106=UTF-8), unit_scaling(8B float64).",
      "storeAs": "u3dMinorVersion",
      "valueType": "uint16",
      "endianness": "little"
    },
    {
      "type": "metadata",
      "name": "U3D Magic",
      "variable": "u3dSignature",
      "description": "'U3D\\x00' — ECMA-363 Universal 3D identifier"
    },
    {
      "type": "metadata",
      "name": "Major Version",
      "variable": "u3dMajorVersion",
      "description": "ECMA-363 major version"
    },
    {
      "type": "metadata",
      "name": "Minor Version",
      "variable": "u3dMinorVersion",
      "description": "ECMA-363 minor version"
    }
  ],
  "assertions": [

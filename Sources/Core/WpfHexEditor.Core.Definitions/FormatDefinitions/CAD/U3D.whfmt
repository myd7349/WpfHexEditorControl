  "formatRelationships": {
    "category": "CAD",
    "extensions": [".u3d"],
    "relatedFormats": ["PDF", "PRC", "VRML", "X3D", "COLLADA"],
    "note": "U3D (ECMA-363) is primarily used for embedding 3D in PDF (ISO 32000-1, PDF 1.6+). PRC (ISO 14739) is the successor for PDF 3D with better compression and exact B-rep. U3D supports tessellated mesh (CLOD) but not NURBS/B-rep. Embedded in PDF via 3D Artwork annotation using /U3D subtype."
  },

  "formatRelationships": {
    "category": "CAD",
    "extensions": [".brep", ".brp"],
    "relatedFormats": ["STEP", "IGES", "X_T", "SAT", "STL"],
    "note": "BREP (.brep/.brp) is Open CASCADE's native format. It is text-based and human-readable, unlike Parasolid X_B or ACIS SAB. OCCT can read STEP and IGES and convert to/from BREP. FreeCAD uses BREP as its internal geometry store. Not to be confused with ACIS SAT BREP or Parasolid BREP — this is specifically Open CASCADE's 'CASCADE Topology' format."
  },

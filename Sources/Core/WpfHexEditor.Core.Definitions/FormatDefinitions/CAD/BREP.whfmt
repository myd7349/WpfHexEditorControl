  "blocks": [
    {
      "type": "signature",
      "name": "BREP File Header",
      "offset": 0,
      "length": 24,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "Open CASCADE BREP file identifier starting with 'CASCADE Topology V' (ASCII). The full first line is typically 'CASCADE Topology V1, (c) Matra Datavision' followed by a newline. This header uniquely identifies the Open CASCADE OCCT BREP format. The 'V1' indicates format version 1 (the only version in widespread use). The historical credit to Matra Datavision reflects the origins of Open CASCADE — originally developed by Matra Datavision as CAS.CADE, later open-sourced in 1999. All BREP files created by FreeCAD, Salome, pythonOCC, and OpenCASCADE start with this string.",
      "storeAs": "brepHeader",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Version/Copyright Line",
      "offset": 24,
      "length": 40,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Remainder of the BREP first line and the beginning of the file structure. After the initial header, BREP files contain: a count of locations (coordinate systems), numbered location records (4×4 transformation matrices), a count of curves, numbered curve records (line/circle/ellipse/BSpline parameters), a count of 2D curves (pcurves), 2D curve records, a count of surfaces (plane/cylinder/cone/sphere/torus/BSpline), surface records, a count of polygons on triangulations, polygons, a count of triangulations, triangulation records, and finally the topology shape tree (TopoDS hierarchy).",
      "storeAs": "brepVersion",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "BREP Header",
      "variable": "brepHeader",
      "description": "'CASCADE Topology V1' — Open CASCADE OCCT BREP identifier"
    },
    {
      "type": "metadata",
      "name": "Version Info",
      "variable": "brepVersion",
      "description": "Copyright/version line remainder"
    }
  ],

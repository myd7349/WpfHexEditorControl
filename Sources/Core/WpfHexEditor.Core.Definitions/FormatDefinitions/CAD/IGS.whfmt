{
  "diffMode": "text",
  "formatName": "IGES CAD File",
  "version": "1.0",
  "extensions": [".igs", ".iges"],
  "description": "IGES (Initial Graphics Exchange Specification) is the ANSI Y14.26M neutral CAD interchange format. Files use a strict fixed-width ASCII format with exactly 80 characters per line. Line structure: columns 1-72 contain section data, column 73 contains the section code character (S=Start, G=Global, D=Directory Entry, P=Parameter Data, T=Terminate), and columns 74-80 contain a 7-character right-justified sequence number. Start (S) section: free-form file description. Global (G) section: comma-separated parameters including parameter delimiter character (default ','), record delimiter (default ';'), filename, sending system, preprocessor version, number of bits for integer, max power of 10 for float representation, significant decimal digits for float, max power for double, significant decimal digits for double, receiving system identifier, model space scale, unit flag (1-11: inch=1, mm=2, ft=4, m=6, cm=11), unit name, max line weight gradations, max line weight value, creation date/time (YYYYMMDD.HHMMSS format), minimum resolution, max coordinate value, author name, organization name, IGES version number (3=v3.0, 4=v4.0, 5=v5.0, 11=v5.3), drafting standard. Directory Entry (D) section: entity catalog with 2 fixed lines per entity. Parameter Data (P) section: entity parameters.",
  "category": "CAD",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ANSI Y14.26M-1989 Initial Graphics Exchange Specification",
      "IGES Version 5.3 — IGES/PDES Organization",
      "NIST IGES Test Suite Documentation"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/IGES",
      "https://filext.com/file-extension/IGS",
      "https://www.nist.gov/programs-projects/iges",
      "https://docs.fileformat.com/cad/iges/"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "2020202020202020202020202020202020202020202020202020202020202020202020202020202020202020202020202020202020202020202020202020202020202053", "offset": 0, "label": "IGES Start section line: 72-char data field ending with 'S' section code at column 73", "weight": 0.5 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.1,
    "required": false,
    "Strength": "Weak",
    "EntropyHint": { "min": 2.0, "max": 5.5 },
    "validation": {
      "minFileSize": 80,
      "maxSignatureOffset": 0,
      "note": "IGES lines are exactly 80 characters each. Column 73 must be S, G, D, P, or T. Line length validation is the primary detection method."
    }
  },
  "variables": {
    "igesStartLine": "",
    "sectionCode": "",
    "seqNum": "",
    "igesVersion": 0
  },
  "blocks": [
    {
      "type": "field",
      "name": "Start Section Line Data",
      "offset": 0,
      "length": 72,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "First 72 characters of the first IGES line (columns 1-72, the section data field). In the Start section these columns contain free-form ASCII text describing the file. The Start section provides human-readable identification before the structured Global section parameters.",
      "storeAs": "igesStartLine",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Section Code",
      "offset": 72,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Single character at column 73 (byte offset 72) identifying which IGES section this line belongs to: 'S'=Start (free-form description), 'G'=Global (file parameters), 'D'=Directory Entry (entity catalog), 'P'=Parameter Data (entity geometry), 'T'=Terminate (record counts). This section code system is the defining characteristic of the IGES fixed-width format.",
      "storeAs": "sectionCode",
      "valueType": "ascii",
      "valueMap": {
        "S": "Start section — free-form file description",
        "G": "Global section — file parameters and metadata",
        "D": "Directory Entry — entity catalog (2 lines per entity)",
        "P": "Parameter Data — entity geometry and attributes",
        "T": "Terminate section — record counts"
      }
    },
    {
      "type": "field",
      "name": "Sequence Number",
      "offset": 73,
      "length": 7,
      "color": "#95E1D3",
      "opacity": 0.35,
      "description": "7-character right-justified decimal sequence number in columns 74-80 (byte offsets 73-79). Sequence numbers are per-section and increment by 1 for each line. In Directory Entry section the sequence number is used as the entity reference (must be odd for first DE line, even for second DE line). The Terminate section records the total line count for each section.",
      "storeAs": "seqNum",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Global Section Parameters",
      "offset": 80,
      "description": "Global section (G lines) stores comma-separated parameters. Parameter 1: parameter delimiter (default ','). Parameter 2: record delimiter (default ';'). Parameters 3-7: filename, sending system ID, IGES preprocessor version, integer bit count (typically 32), max float exponent (typically 38). Parameters 8-12: float significant digits (typically 6), max double exponent (typically 308), double significant digits (typically 15), receiving system ID, model scale. Parameters 13-23: unit flag, unit name, line weight gradations, max line weight, date/time, resolution, max coordinate, author, organization, IGES version, drafting standard."
    },
    {
      "type": "metadata",
      "name": "Directory Entry Section",
      "offset": 0,
      "description": "Directory Entry (D) section: 2 fixed-width lines per entity. Line 1 fields: entity_type_number (field 1), parameter_data_pointer (field 2), structure (field 3), line_font_pattern (field 4), level (field 5), view (field 6), transformation_matrix (field 7), label_display_assoc (field 8), entity_status (field 9), entity_seq_number (odd, field 10). Line 2: entity_type (field 1), line_weight_number, color_number, parameter_line_count, form_number, blank fields (2), entity_label (8 chars), entity_subscript_number, entity_seq_number (even)."
    }
  ],
  "assertions": [
    {
      "name": "ValidSectionCode",
      "expression": "sectionCode == 'S' || sectionCode == 'G' || sectionCode == 'D' || sectionCode == 'P' || sectionCode == 'T'",
      "severity": "error",
      "message": "Column 73 must be a valid IGES section code (S, G, D, P, or T). This does not appear to be a valid IGES file."
    },
    {
      "name": "ValidSeqNum",
      "expression": "seqNum.trim().length > 0",
      "severity": "warning",
      "message": "Sequence number in columns 74-80 is empty or invalid. IGES line format requires a right-justified integer in this field."
    }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "Start Section", "offset": 0, "icon": "\uE71B", "color": "#FF6B6B" },
      { "name": "Section Code", "offset": 72, "icon": "\uE946", "color": "#4ECDC4" },
      { "name": "Sequence Number", "offset": 73, "icon": "\uE8B7", "color": "#FFE66D" }
    ]
  },
  "inspector": {
    "badge": "sectionCode",
    "primaryField": "igesVersion",
    "showQualityScore": true,
    "groups": [
      {
        "title": "Line Structure",
        "icon": "\uE71B",
        "fields": ["igesStartLine", "sectionCode", "seqNum"]
      },
      {
        "title": "File Info",
        "icon": "\uE946",
        "fields": ["igesVersion"]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "IGES Header (JSON)",
      "format": "json",
      "fields": ["igesStartLine", "sectionCode", "seqNum", "igesVersion"]
    },
    {
      "name": "IGES Summary (CSV)",
      "format": "csv",
      "fields": ["sectionCode", "seqNum", "igesVersion"]
    }
  ],
  "forensic": {
    "category": "cad",
    "riskLevel": "low",
    "suspiciousPatterns": [
      "Non-80-character lines indicate malformed IGES; may cause parser buffer errors",
      "Circular entity references in Parameter Data section may cause infinite loops in naive parsers"
    ]
  },
  "aiHints": {
    "analysisContext": "IGES uses strict 80-character fixed-width lines. Column 73 (offset 72) is the section code: S, G, D, P, or T. Columns 74-80 are the sequence number. Global section (G) contains comma-separated file metadata. Directory Entry (D) section uses 2 lines per entity.",
    "suggestedInspections": [
      "Verify 80-character line length and section code at column 73 for IGES format confirmation",
      "Parse Global section parameters to extract IGES version number (parameter 23), unit flag, and author info",
      "Count Directory Entry (D section) lines divided by 2 to determine total entity count in the file",
      "Extract entity type numbers from DE line 1 field 1 to enumerate geometry types (100=Circle, 110=Line, 128=NURBS surface)",
      "Check Terminate section (T line) record counts against actual S, G, D, P line counts for integrity validation"
    ]
  },
  "software": [
    "CATIA",
    "NX (Siemens)",
    "Pro/ENGINEER (PTC Creo)",
    "SolidWorks",
    "AutoCAD",
    "Open CASCADE Technology (OCCT)",
    "IGES2STL converter"
  ],
  "formatRelationships": {
    "category": "CAD",
    "extensions": [".igs", ".iges"],
    "relatedFormats": ["STEP", "DXF", "DWG"],
    "note": "Legacy ANSI neutral CAD format; STEP (ISO 10303-21) is the modern successor for solid model exchange"
  },
  "MimeTypes": ["model/iges", "application/iges"],
  "UseCases": [
    "Legacy CAD system data exchange (pre-2000 systems)",
    "Wireframe and surface model interchange (IGES is stronger than STEP for surfaces)",
    "Aerospace industry legacy component library migration",
    "Reading archived engineering drawings from older CAD systems"
  ],
  "QualityMetrics": {
    "CompletenessScore": 85,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 5,
    "ValidationRules": 2,
    "LastUpdated": "2026-04-15",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "standard": "ANSI Y14.26M",
    "lineWidth": "80 characters fixed",
    "sectionCodes": { "S": "Start", "G": "Global", "D": "Directory Entry", "P": "Parameter Data", "T": "Terminate" },
    "dataColumns": "1-72 (data), 73 (section code), 74-80 (sequence number, right-justified)",
    "versions": ["3=v3.0", "4=v4.0", "5=v5.0", "11=v5.3 (current)"]
  }
}

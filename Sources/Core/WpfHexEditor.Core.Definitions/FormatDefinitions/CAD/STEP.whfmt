  },
  "aiHints": {
    "analysisContext": "STEP Physical File (ISO 10303-21) is plain ASCII. Structure: 'ISO-10303-21;\\nHEADER;\\n[header entities]\\nENDSEC;\\nDATA;\\n[#N=ENTITY(args,...);]\\nENDSEC;\\nEND-ISO-10303-21;'. Header entities: FILE_DESCRIPTION('description','2;1'), FILE_NAME('name','date','author','org','preprocessor','system','auth'), FILE_SCHEMA(('APXXX_...')). DATA section: numbered instances '#1=PRODUCT(...);'. Key geometry types: ADVANCED_BREP_SHAPE_REPRESENTATION, MANIFOLD_SOLID_BREP, CLOSED_SHELL, ADVANCED_FACE, CYLINDRICAL_SURFACE, PLANE, LINE, CIRCLE, B_SPLINE_CURVE_WITH_KNOTS. AP selection: FILE_SCHEMA content identifies AP203 (config-controlled), AP214 (automotive), AP242 (modern universal). Coordinates as CARTESIAN_POINT tuples.",
    "suggestedInspections": [
      "Bytes 0-12: 'ISO-10303-21;' mandatory STEP identifier",
      "Search for 'FILE_SCHEMA' in HEADER section to identify the Application Protocol (AP203/AP214/AP242)",
      "Search for 'FILE_NAME' to extract creation date, author, originating software",
      "Count '#N=' instances in DATA section for entity count (geometry + topology)"
    ]
  },

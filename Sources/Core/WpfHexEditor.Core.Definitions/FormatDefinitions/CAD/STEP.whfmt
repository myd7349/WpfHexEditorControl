  "formatRelationships": {
    "category": "CAD",
    "extensions": [".step", ".stp", ".p21"],
    "relatedFormats": ["IGES", "DXF", "DWG", "BREP", "CATPART", "SAT"],
    "note": "STEP (ISO 10303-21) is the dominant neutral CAD exchange format for industry. IGES (.igs/.iges) is the older predecessor. BREP files from OpenCASCADE use a related B-rep topology but proprietary format. AP203/AP214/AP242 are the most common application protocols: AP242 supersedes both for modern use."
  },

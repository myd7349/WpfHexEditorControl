{
  "diffMode": "binary",
  "formatName": "STEP 3D Model",
  "version": "1.15",
  "extensions": [
    ".step",
    ".stp",
    ".p21"
  ],
  "description": "STEP (Standard for the Exchange of Product model data) is ISO standard 10303, the most widely used neutral CAD exchange format for 3D product data. STEP files are plain-text (ASCII) using the STEP Physical File (SPF) format defined in ISO 10303-21. Every STEP file starts with 'ISO-10303-21;' on the first line, followed by a HEADER section (FILE_DESCRIPTION, FILE_NAME, FILE_SCHEMA entities), then DATA section(s) containing numbered entity instances (#1=ENTITY_TYPE(...)), and ends with 'END-ISO-10303-21;'. The FILE_SCHEMA entity specifies the Application Protocol (AP): AP214 (automotive), AP203 (engineering design), AP242 (mechanical, the modern universal AP). STEP encodes 3D geometry via BREP (Boundary Representation) using geometric entities: ADVANCED_BREP_SHAPE_REPRESENTATION, CLOSED_SHELL, ADVANCED_FACE, B_SPLINE_CURVE_WITH_KNOTS, etc. STEP is the mandatory exchange format for aeronautical, automotive, and defense industries.",
  "category": "CAD",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "ISO 10303-21 — STEP Physical File Format",
      "ISO 10303-214 — AP214 Core Data for Automotive Mechanical Design",
      "ISO 10303-242 — AP242 Managed Model-Based 3D Engineering"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/ISO_10303",
      "https://www.iso.org/standard/63141.html",
      "https://steptools.com/stds/step/"
    ]
  },
  "detection": {
    "signatures": [
      { "value": "49534F2D31303330332D32313B", "offset": 0, "label": "'ISO-10303-21;' — STEP Physical File standard header", "weight": 1.0 },
      { "value": "49534F2D31303330332D", "offset": 0, "label": "'ISO-10303-' — STEP ISO prefix (any part)", "weight": 0.8 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.8,
    "required": true,
    "Strength": "Strong",
    "EntropyHint": { "min": 3.5, "max": 5.5 },
    "validation": {
      "minFileSize": 13,
      "maxSignatureOffset": 0,
      "note": "All STEP Physical Files start with 'ISO-10303-21;' at offset 0. The ';' immediately follows the version number. STEP files named with .p21 extension are identical in format."
    }
  },
  "variables": {
    "stepMagic": "",
    "stepHeaderLine": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "STEP File Identifier",
      "offset": 0,
      "length": 13,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "STEP Physical File identifier 'ISO-10303-21;' (ASCII: 49 53 4F 2D 31 30 33 30 33 2D 32 31 3B). This mandatory 13-byte string at offset 0 uniquely identifies the STEP exchange format as defined by ISO 10303 Part 21. The '21' refers to the physical file format specification. All valid STEP files must begin with this exact sequence. Files starting with 'ISO-10303-' followed by another number (e.g., -28) indicate STEP XML variants.",
      "storeAs": "stepMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "First Line Remainder",
      "offset": 13,
      "length": 40,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Content immediately following the 'ISO-10303-21;' identifier on the first line. In standard STEP files this is a newline (CRLF or LF), followed by 'HEADER;' beginning the mandatory HEADER section. The HEADER section contains FILE_DESCRIPTION (description and implementation level), FILE_NAME (name, timestamp, author, organization, preprocessor, originating system, authorization), and FILE_SCHEMA (application protocol — 'AP214_IS', 'AP203_CONFIGURATION_CONTROLLED_3D_DESIGN_OF_MECHANICAL_PARTS_AND_ASSEMBLIES', 'AP242_MANAGED_MODEL_BASED_3D_ENGINEERING').",
      "storeAs": "stepHeaderLine",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "STEP Identifier",
      "variable": "stepMagic",
      "description": "'ISO-10303-21;' — STEP Physical File standard identifier"
    },
    {
      "type": "metadata",
      "name": "Header Start",
      "variable": "stepHeaderLine",
      "description": "Beginning of HEADER section content"
    }
  ],
  "assertions": [
    {
      "name": "STEP identifier valid",
      "expression": "stepMagic == 'ISO-10303-21;'",
      "severity": "error",
      "message": "STEP file must start with 'ISO-10303-21;' — not a valid STEP Physical File (ISO 10303-21)"
    }

{
  "diffMode": "binary",
  "formatName": "SQX Archive",
  "version": "1.15",
  "extensions": [ ".sqx" ],
  "description": "SQX is a proprietary archive format developed by SQX Software. The format uses 'SQ' (0x5351) as its 2-byte magic at offset 0, sometimes followed by 'X' making it 'SQX'. SQX supports multiple compression algorithms including LZH variants, solid archiving, and optional AES-256 encryption. The archive header includes a 2-byte magic, 2-byte version, 2-byte flags, and various metadata fields. SQX is relatively obscure and primarily supported by older Windows archiving utilities. Detection confidence is moderate due to the short 2-byte magic.",
  "category": "Archives",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "SQX Archive Format Specification",
      "SQX LZH Variant Compression",
      "SQX Archiver Proprietary Format"
    ],
    "WebLinks": [
      "https://docs.fileformat.com/compression/sqx/",
      "http://justsolve.archiveteam.org/wiki/SQX",
      "https://fileinfo.com/extension/sqx"
    ]
  },
  "detection": {
    "signatures": [
      { "hex": "5351", "offset": 0, "weight": 0.6 },
      { "hex": "535158", "offset": 0, "weight": 0.8 }
    ],
    "matchMode": "any",
    "MinimumScore": 0.6,
    "required": true,
    "Strength": "Medium",
    "EntropyHint": { "min": 4.0, "max": 7.8 },
    "validation": {
      "minFileSize": 12,
      "maxSignatureOffset": 0,
      "note": "'SQ' at offset 0 is a 2-byte magic — moderate false positive risk. Version byte should be a known value. Use extension + header for confirmation."
    }
  },
  "variables": {
    "sqxMagic": "",
    "sqxVersion": 0,
    "sqxFlags": 0,
    "headerSize": 0,
    "compressionMethod": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "SQX Magic",
      "offset": 0,
      "length": 2,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "SQX magic bytes 'SQ' (0x53 0x51). Some variants use 'SQX' (3 bytes).",
      "storeAs": "sqxMagic",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Format Version",
      "offset": 2,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.4,
      "description": "SQX format version (little-endian uint16)",
      "storeAs": "sqxVersion",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Archive Flags",
      "offset": 4,
      "length": 2,
      "color": "#45B7D1",
      "opacity": 0.4,
      "description": "Archive flags: bit0=solid archive, bit1=encrypted, bit2=multi-volume, bit3=AES-256",
      "storeAs": "sqxFlags",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Header Size",
      "offset": 6,
      "length": 4,
      "color": "#96CEB4",
      "opacity": 0.4,
      "description": "Size of the main archive header (little-endian uint32)",
      "storeAs": "headerSize",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Compression Method",
      "offset": 10,
      "length": 2,
      "color": "#FFEAA7",
      "opacity": 0.4,
      "description": "Compression algorithm identifier. SQX supports LZH variants and proprietary algorithms.",
      "storeAs": "compressionMethod",
      "valueType": "uint16"
    }
  ],
  "assertions": [
    { "field": "sqxMagic", "operator": "startsWith", "value": "SQ", "description": "First 2 bytes must be 'SQ'" }
  ],
  "navigation": {
    "bookmarks": [
      { "name": "SQX Header", "offset": 0, "description": "2-byte magic + version + flags + header size" }
    ]
  },
  "inspector": {
    "badge": "SQX",
    "primaryField": "sqxVersion",
    "showQualityScore": true,
    "groups": [
      { "name": "Header", "fields": ["sqxMagic", "sqxVersion"] },
      { "name": "Settings", "fields": ["sqxFlags", "headerSize", "compressionMethod"] }
    ]
  },
  "exportTemplates": [
    {
      "name": "SQX Header Info (JSON)",
      "format": "json",
      "fields": ["sqxMagic", "sqxVersion", "sqxFlags", "compressionMethod"]
    }
  ],
  "forensic": {
    "category": "archive",
    "riskLevel": "low",
    "suspiciousPatterns": [
      { "name": "Encryption flag set", "condition": "true", "description": "Encryption flag (bit1) set may indicate password-protected content requiring brute-force", "severity": "warning" },
      { "name": "Short magic risk", "condition": "true", "description": "Short 2-byte magic increases false positive detection risk", "severity": "warning" }
    ]
  },
  "aiHints": {
    "analysisContext": "SQX is a rare proprietary archive format using 'SQ' or 'SQX' magic (2-3 bytes). It supports solid archiving and AES-256 encryption. The format is primarily encountered on older Windows systems. Detection should combine magic bytes + extension + version field validation.",
    "suggestedInspections": [
      "Verify 'SQ' (0x5351) or 'SQX' (0x535158) at offset 0",
      "Read version at offset 2 for known SQX version range",
      "Check flags at offset 4 for encryption (bit1) or solid mode (bit0)",
      "Use file extension .sqx as additional confirmation",
      "7-Zip or PeaZip may be needed for extraction"
    ]
  },
  "software": [
    "SQX Archiver",
    "7-Zip (limited)",
    "PeaZip"
  ],
  "formatRelationships": {
    "category": "Archives",
    "extensions": [".sqx"],
    "relatedFormats": ["LZH", "ARJ", "ARC", "ZIP"],
    "note": "SQX is a relatively obscure format competing with ARJ and LZH in the pre-ZIP era. Modern support is limited."
  },
  "MimeTypes": [ "application/x-sqx", "application/x-sqx-compressed" ],
  "UseCases": [
    "Legacy Windows archive storage",
    "Encrypted archive distribution",
    "Solid archive compression"
  ],
  "QualityMetrics": {
    "CompletenessScore": 52,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 5,
    "ValidationRules": 1,
    "LastUpdated": "2026-04-14",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "ArchivesFormat": true,
    "SupportsEncryption": true,
    "Endianness": "little-endian",
    "EncryptionType": "AES-256 (optional)"
  }
}

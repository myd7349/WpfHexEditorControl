{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "RPM Package",
  "formatId": "RPM",
  "version": "1.0.1",
  "diffMode": "binary",
  "extensions": [ ".rpm" ],
  "description": "RPM is the recursive package manager format used by Red Hat, Fedora, CentOS, SUSE, and related Linux distributions. The file begins with a 4-byte magic (0xED 0xAB 0xEE 0xDB) followed by major/minor version bytes and a 2-byte big-endian package type.",
  "category": "Archives",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "MimeTypes": [ "application/x-rpm", "application/x-redhat-package-manager" ],
  "UseCases": [
    "Linux software distribution on RPM-based systems",
    "Package integrity verification via GPG signatures embedded in header",
    "Forensic analysis of installed or staged software packages"
  ],
  "references": [
    "https://rpm.org/devel_doc/file_format.html",
    "https://github.com/rpm-software-management/rpm/blob/master/doc/manual/format.md",
    "https://refspecs.linuxbase.org/LSB_3.1.0/LSB-Core-generic/LSB-Core-generic/pkgformat.html"
  ],
  "software": [
    { "name": "RPM",       "url": "https://rpm.org/",              "role": "Reference package manager" },
    { "name": "DNF/YUM",   "url": "https://rpm.org/",              "role": "High-level package managers consuming RPM files" },
    { "name": "7-Zip",     "url": "https://www.7-zip.org/",        "role": "Can extract RPM payload (CPIO inside)" }
  ],
  "formatRelationships": [
    { "format": "CPIO",    "relationship": "RPM payload is a compressed CPIO archive" },
    { "format": "GZIP",    "relationship": "Classic RPMs compress the CPIO payload with gzip" },
    { "format": "XZ",      "relationship": "Modern RPMs (v4+) typically use XZ-compressed CPIO payload" }
  ],
  "detection": {
    "signatures": [
      {
        "offset": 0,
        "value": "EDABEEDB",
        "label": "RPM lead magic bytes 0xED 0xAB 0xEE 0xDB",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 85,
    "Strength": "Strong",
    "EntropyHint": { "min": 6.0, "max": 8.0, "note": "Compressed payload raises overall entropy; header sections have lower entropy" },
    "validation": "Bytes 0-3 must be ED AB EE DB. Byte 4 (major version) must be 3 or 4. Bytes 6-7 (big-endian type) must be 0 (binary) or 1 (source RPM)."
  },
  "variables": [
    { "name": "rpmMagic",  "type": "hex",    "offset": 0, "length": 4, "description": "RPM lead magic: ED AB EE DB" },
    { "name": "rpmMajor",  "type": "uint8",  "offset": 4, "length": 1, "description": "Major version", "valueMap": { "3": "RPMv3", "4": "RPMv4" } },
    { "name": "rpmMinor",  "type": "uint8",  "offset": 5, "length": 1, "description": "Minor version (typically 0)" },
    { "name": "rpmType",   "type": "uint16", "offset": 6, "length": 2, "endian": "big", "description": "Package type", "valueMap": { "0": "Binary RPM", "1": "Source RPM" } },
    { "name": "rpmArch",   "type": "uint16", "offset": 8, "length": 2, "endian": "big", "description": "Architecture number (e.g. 1=x86, 9=x86_64)" }
  ],
  "blocks": [
    {
      "name": "Lead",
      "offset": 0,
      "length": 96,
      "description": "RPM lead section (96 bytes): magic, version, type, arch, name, OS, signature type",
      "fields": [
        { "name": "Magic",   "variable": "rpmMagic",  "offset": 0, "length": 4 },
        { "name": "Major",   "variable": "rpmMajor",  "offset": 4, "length": 1 },
        { "name": "Minor",   "variable": "rpmMinor",  "offset": 5, "length": 1 },
        { "name": "Type",    "variable": "rpmType",   "offset": 6, "length": 2 },
        { "name": "Arch",    "variable": "rpmArch",   "offset": 8, "length": 2 }
      ]
    },
    {
      "name": "SignatureHeader",
      "offset": 96,
      "length": -1,
      "description": "RPM signature header section (variable length, aligned to 8-byte boundary). Contains GPG/PGP signature tags."
    },
    {
      "name": "MainHeader",
      "offset": -1,
      "length": -1,
      "description": "RPM main header section containing package metadata tags (name, version, release, description, file list, dependencies)"
    },
    {
      "name": "Payload",
      "offset": -1,
      "length": -1,
      "description": "Compressed CPIO archive containing the actual package files (typically gzip or xz compressed)"
    }
  ],
  "assertions": [
    { "id": "A1", "description": "Magic bytes must be ED AB EE DB",    "expression": "rpmMagic == 'EDABEEDB'" },
    { "id": "A2", "description": "Major version must be 3 or 4",       "expression": "rpmMajor == 3 || rpmMajor == 4" },
    { "id": "A3", "description": "Package type must be 0 (binary) or 1 (source)", "expression": "rpmType == 0 || rpmType == 1" }
  ],
  "navigation": {
    "entryPoint": "Lead",
    "structure": [ "Lead", "SignatureHeader", "MainHeader", "Payload" ],
    "notes": "After the 96-byte lead, signature and main headers begin with an 8-byte header magic (8E AD E8 01 00 00 00 00) followed by nindex (4B BE) and hsize (4B BE). Payload starts after the aligned main header."
  },
  "inspector": {
    "badge": "RPM",
    "primaryField": "rpmMajor",
    "groups": [
      {
        "name": "Lead",
        "fields": [ "rpmMagic", "rpmMajor", "rpmMinor", "rpmType", "rpmArch" ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Package Summary CSV",
      "format": "csv",
      "fields": [ "rpmMagic", "rpmMajor", "rpmMinor", "rpmType", "rpmArch" ]
    },
    {
      "name": "Lead JSON",
      "format": "json",
      "fields": [ "rpmMagic", "rpmMajor", "rpmMinor", "rpmType", "rpmArch" ]
    }
  ],
  "forensic": {
    "riskLevel": "MEDIUM",
    "notes": "RPM packages can contain arbitrary executables and scripts. GPG signature in the signature header should be verified before installation. Unsigned packages or packages with mismatched signatures are high-risk.",
    "suspiciousPatterns": [
      "Missing or invalid GPG signature in signature header",
      "Source RPM (type=1) deployed to production system",
      "Architecture field mismatching the target system",
      "Payload compression algorithm different from declared compression tag"
    ]
  },
  "aiHints": {
    "analysisContext": "RPM files have a fixed 96-byte lead followed by variable-length header sections using a tag-based structure. The payload is a compressed CPIO archive. Header tags use a 16-byte index entry format (tag id + type + offset + count).",
    "suggestedInspections": [
      "Verify GPG/PGP signature in the signature header section for package authenticity",
      "Decode main header tags to extract package name, version, release, and architecture strings",
      "Identify payload compression algorithm from PAYLOADCOMPRESSOR tag (1125) to select correct decompressor",
      "List embedded file paths from FILEPATHS tags to assess package contents before extraction",
      "Check REQUIRENAME/REQUIREVERSION tags for dependency declarations"
    ]
  },
  "TechnicalDetails": {
    "endianness": "Big-endian for all header multi-byte fields",
    "leadSize": 96,
    "headerMagic": "8E AD E8 01 00 00 00 00",
    "tagIndexEntrySize": 16,
    "payloadFormats": [ "cpio.gz", "cpio.xz", "cpio.lzma", "cpio.bz2", "cpio.zst" ]
  },
  "QualityMetrics": {
    "CompletenessScore": 87,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  }
}




{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "LZH Archive",
  "formatId": "LZH",
  "version": "1.13",
  "extensions": [
    ".lzh",
    ".lha"
  ],
  "description": "LHA/LZH — a compressed archive format created by Haruyasu Yoshizaki (1988) and widely popular in Japan, on Amiga systems, and in early PC software distribution. The format has three header levels (0, 1, 2) with slightly different layouts. The Level-0 header starts with: headerSize (1B), headerChecksum (1B), method ID (5B ASCII, e.g., '-lh5-'), compressed size (4B LE), original size (4B LE), DOS timestamp (4B LE), file attribute (1B), header level (1B), filename length (1B), filename (N bytes), CRC-16 of uncompressed data (2B LE). Common compression methods: -lh0-=stored, -lh4--lh7-=LZSS+Huffman, -lhd-=directory entry. The archive ends when headerSize=0.",
  "category": "Archives",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "LHA/LZH Format Specification — Haruyasu Yoshizaki",
      "LHA Technical Documentation — lha.sourceforge.jp",
      "LZSS and Huffman Encoding in LHA — Yoshizaki 1988"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/LHA_(file_format)",
      "http://fileformats.archiveteam.org/wiki/LHA",
      "https://github.com/jca02266/lha",
      "https://www.loc.gov/preservation/digital/formats/fdd/fdd000339.shtml"
    ]
  },
  "detection": {
    "signature": "2D6C68",
    "offset": 2,
    "required": true,
    "Strength": "Strong",
    "validation": {
      "minFileSize": 22,
      "maxSignatureOffset": 2
    }
  },
  "variables": {
    "headerSize": 0,
    "headerChecksum": 0,
    "methodId": "",
    "compressedSize": 0,
    "originalSize": 0,
    "timestamp": 0,
    "attribute": 0,
    "headerLevel": 0,
    "filenameLength": 0,
    "crc16": 0,
    "isDirectory": false,
    "filename": ""
  },
  "functions": {
    "calculateChecksum": "Calculate sum of all header bytes (mod 256) and verify against headerChecksum",
    "calculateCRC16": "Calculate CRC-16 (0x8005) of uncompressed data and verify against crc16 field",
    "extractASCIIString": "Extract compression method ID and filename strings"
  },
  "blocks": [
    {
      "type": "field",
      "name": "Header Size",
      "offset": 0,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.35,
      "description": "Size of the fixed portion of the level-0 or level-1 header in bytes (uint8). This is the byte count starting after the 2-byte header (i.e., does not include itself or the headerChecksum byte). For end-of-archive, this value is 0. Typical value for a simple file entry is 22-25 bytes (before optional extended headers).",
      "storeAs": "headerSize",
      "valueType": "uint8",
      "valueMap": {
        "0": "0 — End of archive marker"
      }
    },
    {
      "type": "field",
      "name": "Header Checksum",
      "offset": 1,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Simple additive checksum of the header bytes following this field (level-0/level-1). Computed as the sum of all subsequent header bytes modulo 256. Used to detect header corruption. Level-2 headers do not use this checksum field — they use a CRC-16 of the entire header instead.",
      "storeAs": "headerChecksum",
      "valueType": "uint8"
    },
    {
      "type": "signature",
      "name": "Compression Method ID",
      "offset": 2,
      "length": 5,
      "color": "#FF6B6B",
      "opacity": 0.45,
      "description": "5-byte ASCII compression method identifier. The standard format is '-lhN-' where N is a single digit (0-9) or letter (d=directory). This field is the primary signature for LZH detection (bytes at offset 2-4 are '-lh'). The method determines the decompression algorithm applied to the compressed data.",
      "storeAs": "methodId",
      "valueType": "ascii",
      "valueMap": {
        "-lh0-": "-lh0- — Stored (no compression)",
        "-lh1-": "-lh1- — LZS + 4k sliding window (original lharc 1.x method)",
        "-lh2-": "-lh2- — LZS + 8k sliding window",
        "-lh3-": "-lh3- — LZS + 8k sliding window (lharc 2.x)",
        "-lh4-": "-lh4- — LZSS + Huffman (4k dictionary)",
        "-lh5-": "-lh5- — LZSS + Huffman (8k dictionary, most common LHA method)",
        "-lh6-": "-lh6- — LZSS + Huffman (32k dictionary)",
        "-lh7-": "-lh7- — LZSS + Huffman (64k dictionary)",
        "-lhd-": "-lhd- — Directory entry (no data, just directory name)",
        "-lz4-": "-lz4- — Stored (LZ4-compatible method ID, rare)",
        "-lz5-": "-lz5- — LZ5 method"
      }
    },
    {
      "type": "field",
      "name": "Compressed Size",
      "offset": 7,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Size of the compressed data in the archive in bytes (little-endian 32-bit). Immediately follows the file header block. For method -lh0- (stored), this equals originalSize. For directory entries (-lhd-), this is typically 0.",
      "storeAs": "compressedSize",
      "valueType": "uint32",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Original (Uncompressed) Size",
      "offset": 11,
      "length": 4,
      "color": "#45B7D1",
      "opacity": 0.3,
      "description": "Original uncompressed file size in bytes (little-endian 32-bit). Used to allocate output buffer during extraction. For directory entries, this is 0.",
      "storeAs": "originalSize",
      "valueType": "uint32",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Timestamp (DOS packed)",
      "offset": 15,
      "length": 4,
      "color": "#96CEB4",
      "opacity": 0.3,
      "description": "File modification timestamp in MS-DOS packed date/time format (little-endian 32-bit). Upper 16 bits = date (bits 15-9=year-1980, bits 8-5=month, bits 4-0=day). Lower 16 bits = time (bits 15-11=hour, bits 10-5=minute, bits 4-0=2-second steps).",
      "storeAs": "timestamp",
      "valueType": "uint32",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "File Attribute",
      "offset": 19,
      "length": 1,
      "color": "#DDA0DD",
      "opacity": 0.3,
      "description": "MS-DOS file attribute byte. Bit flags: bit 0=read-only, bit 1=hidden, bit 2=system, bit 3=volume label, bit 4=directory, bit 5=archive.",
      "storeAs": "attribute",
      "valueType": "uint8",
      "bitfields": [
        {
          "bit": 0,
          "name": "ReadOnly",
          "description": "File is read-only"
        },
        {
          "bit": 1,
          "name": "Hidden",
          "description": "File is hidden from directory listing"
        },
        {
          "bit": 2,
          "name": "System",
          "description": "File is a system file"
        },
        {
          "bit": 4,
          "name": "Directory",
          "description": "Entry is a directory"
        },
        {
          "bit": 5,
          "name": "Archive",
          "description": "File has been modified since last backup"
        }
      ]
    },
    {
      "type": "field",
      "name": "Header Level",
      "offset": 20,
      "length": 1,
      "color": "#FF8C69",
      "opacity": 0.3,
      "description": "Header format level: 0 (original lharc), 1 (extended), or 2 (new extended with 2-byte header size). Level 0 and 1 are most common. Level 2 uses a different layout: the first 2 bytes are a 16-bit header size (LE) instead of headerSize+checksum.",
      "storeAs": "headerLevel",
      "valueType": "uint8",
      "valueMap": {
        "0": "Level 0 — Original lharc format (checksum-based)",
        "1": "Level 1 — Extended header format (most common)",
        "2": "Level 2 — New extended format (CRC-16 protected header)"
      }
    },
    {
      "type": "field",
      "name": "Filename Length",
      "offset": 21,
      "length": 1,
      "color": "#87CEEB",
      "opacity": 0.3,
      "description": "Length of the filename field that follows (in bytes, 0-255). The filename is a null-free byte sequence; no null terminator. In level-1/2 headers, extended headers may contain a longer filename or OS-2/Unix path information.",
      "storeAs": "filenameLength",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "CRC-16 of Uncompressed Data",
      "offset": 22,
      "length": 2,
      "color": "#98D8C8",
      "opacity": 0.35,
      "description": "CRC-16 checksum of the original (uncompressed) file content. Uses CRC-16 polynomial 0x8005 (big-endian bit processing). Used to verify extraction integrity — if the decompressed data CRC does not match this field, the file is corrupted. For directory entries (-lhd-), this is typically 0.",
      "storeAs": "crc16",
      "valueType": "uint16",
      "endianness": "little"
    },
    {
      "type": "computeFromVariables",
      "name": "Is Directory Entry",
      "expression": "calc:methodId == '-lhd-' || (attribute & 16) != 0",
      "storeAs": "isDirectory",
      "description": "True if this header describes a directory entry (method '-lhd-' or directory attribute bit set)"
    },
    {
      "type": "metadata",
      "name": "Header Size",
      "variable": "headerSize",
      "description": "Header byte count (0=end of archive)"
    },
    {
      "type": "metadata",
      "name": "Method ID",
      "variable": "methodId",
      "description": "Compression method identifier (e.g., -lh5-, -lh0-)"
    },
    {
      "type": "metadata",
      "name": "Compressed Size",
      "variable": "compressedSize",
      "description": "Compressed data size in bytes"
    },
    {
      "type": "metadata",
      "name": "Original Size",
      "variable": "originalSize",
      "description": "Uncompressed file size in bytes"
    },
    {
      "type": "metadata",
      "name": "Header Level",
      "variable": "headerLevel",
      "description": "Header format level: 0=original, 1=extended, 2=new extended"
    },
    {
      "type": "metadata",
      "name": "Filename Length",
      "variable": "filenameLength",
      "description": "Length of the stored filename (bytes)"
    },
    {
      "type": "metadata",
      "name": "CRC-16",
      "variable": "crc16",
      "description": "CRC-16 checksum of uncompressed data for integrity verification"
    },
    {
      "type": "metadata",
      "name": "Is Directory",
      "variable": "isDirectory",
      "description": "True if entry is a directory (method -lhd- or directory attribute)"
    }
  ],
  "assertions": [
    {
      "name": "LZH method ID contains -lh",
      "expression": "methodId[0] == '-' && methodId[1] == 'l' && methodId[2] == 'h'",
      "severity": "error",
      "message": "Method ID at offset 2 must start with '-lh' — not a valid LZH archive header"
    },
    {
      "name": "Header level recognized",
      "expression": "headerLevel == 0 || headerLevel == 1 || headerLevel == 2",
      "severity": "warning",
      "message": "Header level must be 0, 1, or 2 — unrecognized header level indicates non-standard LZH format"
    },
    {
      "name": "End of archive check",
      "expression": "headerSize > 0",
      "severity": "info",
      "message": "Header size is 0 — this marks the end of the LZH archive"
    }
  ],
  "checksums": [
    {
      "name": "Header Additive Checksum",
      "algorithm": "sum8",
      "note": "Sum of all header bytes following the checksum field, modulo 256. Only for level-0 and level-1 headers.",
      "dataRange": {
        "fixedOffset": 2,
        "lengthVar": "headerSize"
      },
      "storedAt": {
        "fixedOffset": 1,
        "length": 1
      },
      "storedType": "uint8",
      "severity": "warning"
    },
    {
      "name": "File Data CRC-16",
      "algorithm": "crc16",
      "note": "CRC-16 (polynomial 0x8005) of the fully decompressed file data.",
      "dataRange": {
        "description": "Decompressed output of the compressed data block"
      },
      "storedAt": {
        "fixedOffset": 22,
        "length": 2,
        "endianness": "little"
      },
      "storedType": "uint16",
      "severity": "warning"
    }
  ],
  "navigation": {
    "bookmarks": [
      {
        "name": "First File Header",
        "offset": 0,
        "icon": "",
        "color": "#FF6B6B"
      },
      {
        "name": "Method ID (-lhN-)",
        "offset": 2,
        "icon": "",
        "color": "#4ECDC4"
      },
      {
        "name": "File Sizes",
        "offset": 7,
        "icon": "",
        "color": "#FFE66D"
      },
      {
        "name": "CRC-16",
        "offset": 22,
        "icon": "",
        "color": "#98D8C8"
      }
    ]
  },
  "inspector": {
    "badge": "methodId",
    "primaryField": "originalSize",
    "showQualityScore": true,
    "groups": [
      {
        "title": "File Header",
        "icon": "",
        "fields": [
          "headerSize",
          "headerChecksum",
          "methodId",
          "headerLevel"
        ]
      },
      {
        "title": "File Data",
        "icon": "",
        "fields": [
          "compressedSize",
          "originalSize",
          "filenameLength",
          "isDirectory"
        ]
      },
      {
        "title": "Integrity",
        "icon": "",
        "fields": [
          "crc16",
          "attribute"
        ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "LZH File Header (JSON)",
      "format": "json",
      "fields": [
        "headerSize",
        "methodId",
        "compressedSize",
        "originalSize",
        "timestamp",
        "attribute",
        "headerLevel",
        "filenameLength",
        "crc16",
        "isDirectory"
      ]
    },
    {
      "name": "lzh_header_t (C struct)",
      "format": "c-struct",
      "structName": "lzh_header",
      "fields": [
        "headerSize",
        "headerChecksum",
        "methodId",
        "compressedSize",
        "originalSize",
        "timestamp",
        "attribute",
        "headerLevel",
        "filenameLength"
      ]
    },
    {
      "name": "Python LZH check",
      "format": "python-bytes",
      "fields": [
        "headerSize",
        "methodId",
        "compressedSize",
        "originalSize"
      ]
    }
  ],
  "forensic": {
    "category": "archive",
    "riskLevel": "low",
    "suspiciousPatterns": [
      {
        "name": "Unknown compression method",
        "condition": "methodId != '-lh0-' && methodId != '-lh1-' && methodId != '-lh2-' && methodId != '-lh3-' && methodId != '-lh4-' && methodId != '-lh5-' && methodId != '-lh6-' && methodId != '-lh7-' && methodId != '-lhd-'",
        "severity": "warning",
        "description": "Compression method ID is not in the known -lh0- to -lh7- or -lhd- set. May indicate a custom LZH variant or crafted archive."
      },
      {
        "name": "Invalid header level",
        "condition": "headerLevel > 2",
        "severity": "warning",
        "description": "Header level > 2 is not defined in the LZH specification. Indicates a non-standard format or corrupted header."
      },
      {
        "name": "Compressed larger than original",
        "condition": "compressedSize > originalSize && originalSize > 0",
        "severity": "info",
        "description": "Compressed size exceeds original size. Possible if compression expanded the data (rare, occurs with pre-compressed or random data), or indicates a header error."
      }
    ]
  },
  "aiHints": [
    "LZH/LHA header level 0: headerSize(1) + checksum(1) + methodId(5,'-lh5-') + compSize(4,LE) + origSize(4,LE)",
    "Method IDs: -lh0-=stored, -lh4--lh7-=LZSS+Huffman, -lhd-=directory, -lzs-=LZSS only",
    "Archive ends when headerSize byte == 0 at the start of a new header",
    "Header checksum (byte 1): sum of all header bytes except CRC fields, mod 256",
    "LZH was dominant in Japan and on Amiga systems throughout the 1990s"
  ],
  "software": [
    "LHA (Haruyasu Yoshizaki)",
    "lha (Unix port, jca02266)",
    "7-Zip",
    "WinRAR",
    "The Unarchiver (macOS)",
    "PeaZip"
  ],
  "formatRelationships": {
    "category": "Archives",
    "extensions": [
      ".lzh",
      ".lha"
    ],
    "relatedFormats": [
      "ZIP",
      "ARJ",
      "RAR"
    ],
    "popularIn": "Japan (dominant archive format until ~2000), Amiga community"
  },
  "MimeTypes": [
    "application/x-lzh-compressed",
    "application/x-lha"
  ],
  "UseCases": [
    "Japanese software distribution (dominant format in Japan 1990-2000)",
    "Amiga software archives (.lha extension common on Amiga)",
    "Legacy PC BBS software distribution",
    "Digital preservation of 1990s Japanese software"
  ],
  "QualityMetrics": {
    "CompletenessScore": 85,
    "DocumentationLevel": "detailed",
    "BlocksDefined": 14,
    "ValidationRules": 3,
    "LastUpdated": "2026-05-20",
    "PriorityFormat": false,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "ArchiveFormat": true,
    "CompressionAlgorithm": "LZSS (LZ77 variant) + Adaptive Huffman coding",
    "Endianness": "little-endian",
    "SignatureLocation": "Offset 2 (not offset 0) — bytes 0-1 are header size and checksum",
    "HeaderLevels": "0 (original), 1 (extended), 2 (new extended with CRC)",
    "ChecksumType": "Additive modulo-256 (level-0/1), CRC-16 (level-2)",
    "DataIntegrityCheck": "CRC-16 of decompressed content (polynomial 0x8005)",
    "SupportsDirectories": true,
    "SupportsEncryption": false,
    "MaxFileSize": "4GB (32-bit size field)"
  },
  "diff": {
    "keyFields": [
      "header_size",
      "method_id",
      "compressed_size",
      "original_size",
      "attribute",
      "header_level",
      "filename_length",
      "sum8"
    ],
    "ignoreFields": [
      "timestamp"
    ],
    "note": "Inferred semantic diff for LZH. Compare key structural fields; ignore volatile metadata."
  },
  "fuzz": {
    "preserveChecksums": true,
    "maxMutationsPerFile": 1,
    "strategies": [
      {
        "field": "method_id",
        "mutation": "corrupt_signature",
        "description": "Corrupt magic bytes at offset 2 — parser must reject."
      },
      {
        "field": "header_size",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      },
      {
        "field": "attribute",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      },
      {
        "field": "header_level",
        "mutation": "enum_sweep",
        "description": "Sweep all valid enum codes plus reserved/invalid values."
      },
      {
        "field": "compressed_size",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      },
      {
        "field": "original_size",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      },
      {
        "field": "filename_length",
        "mutation": "boundary_values",
        "description": "Apply 0, 1, MAX-1, MAX boundaries — exposes overflow / underflow paths."
      },
      {
        "field": "sum8",
        "mutation": "random_bytes",
        "description": "Random SUM8 value triggers integrity failure."
      }
    ],
    "note": "Inferred fuzz strategies for LZH. Hand-tune weights/rates per format if needed."
  },
  "signatures": [
    {
      "value": "2D6C68352D",
      "offset": 2,
      "label": "'-lh5-' — LZH method ID at offset 2 (common LZH method)",
      "weight": 0.9,
      "strength": "Strong"
    }
  ],
  "maxSignatureOffset": 7,
  "structure": {
    "fields": [
      {
        "name": "headerSize",
        "type": "uint8",
        "offset": 0,
        "length": 1,
        "description": "Header size in bytes"
      },
      {
        "name": "headerChecksum",
        "type": "uint8",
        "offset": 1,
        "length": 1,
        "description": "Sum of header bytes"
      },
      {
        "name": "methodId",
        "type": "ascii",
        "offset": 2,
        "length": 5,
        "description": "5-char method: -lh0-=stored, -lh5-=LZSS+Huffman"
      },
      {
        "name": "compressedSize",
        "type": "uint32le",
        "offset": 7,
        "length": 4,
        "description": "Compressed file size"
      },
      {
        "name": "originalSize",
        "type": "uint32le",
        "offset": 11,
        "length": 4,
        "description": "Uncompressed file size"
      },
      {
        "name": "timestamp",
        "type": "uint32le",
        "offset": 15,
        "length": 4,
        "description": "MS-DOS timestamp"
      },
      {
        "name": "headerLevel",
        "type": "uint8",
        "offset": 20,
        "length": 1,
        "description": "Header level: 0, 1, or 2"
      },
      {
        "name": "filenameLen",
        "type": "uint8",
        "offset": 21,
        "length": 1,
        "description": "Filename length in bytes"
      }
    ]
  },
  "lastUpdated": "2026-05-20"
}



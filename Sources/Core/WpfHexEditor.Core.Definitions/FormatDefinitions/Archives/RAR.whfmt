{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "diffMode": "binary",
  "formatName": "RAR Archive",
  "formatId": "RAR",
  "version": "2.02",
  "extensions": [
    ".rar"
  ],
  "description": "RAR archive format created by Eugene Roshal. Supports high compression ratios, solid archives, multi-volume spanning, recovery records, and AES encryption. RAR4 uses a 7-byte signature (52 61 72 21 1A 07 00) followed by a structured header block starting with a CRC, type byte, flags, and size fields. RAR5 uses an 8-byte signature (52 61 72 21 1A 07 01 00) with variable-length integer encoding.",
  "category": "Archives",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "references": {
    "specifications": [
      "RAR 5.0 Archive Format Technical Note",
      "RAR 4.x Archive Format Specification",
      "UnRAR Source Code Reference"
    ],
    "WebLinks": [
      "https://www.rarlab.com/technote.htm",
      "https://en.wikipedia.org/wiki/RAR_(file_format)",
      "https://codedread.github.io/bitjs/docs/unrar.html"
    ]
  },
  "lastUpdated": "2026-05-20",
  "signatures": [
    {
      "value": "526172211A0700",
      "offset": 0,
      "label": "Rar!\\x1A\\x07\\x00 — RAR4 archive signature (7 bytes)",
      "weight": 1.0,
      "strength": "Strong"
    },
    {
      "value": "526172211A070100",
      "offset": 0,
      "label": "Rar!\\x1A\\x07\\x01\\x00 — RAR5 archive signature (8 bytes)",
      "weight": 1.0,
      "strength": "Strong"
    }
  ],
  "maxSignatureOffset": 0,
  "structure": {
    "fields": [
      { "name": "signature", "type": "hex", "offset": 0, "length": 7, "description": "RAR4: 52 61 72 21 1A 07 00 (7 bytes)" },
      { "name": "versionMarker", "type": "uint8", "offset": 7, "length": 1, "description": "RAR5: 00 at offset 7 after 8-byte signature; RAR4: first header byte" },
      { "name": "headerCrc", "type": "uint16le", "offset": 7, "length": 2, "description": "RAR4: CRC-16 of main archive header" },
      { "name": "headerType", "type": "uint8", "offset": 9, "length": 1, "description": "RAR4: block type (0x73 = main archive header)" },
      { "name": "headerFlags", "type": "uint16le", "offset": 10, "length": 2, "description": "Archive flags: solid(0x08), volume(0x01), locked(0x04)" },
      { "name": "headerSize", "type": "uint16le", "offset": 12, "length": 2, "description": "RAR4: header size in bytes" }
    ]
  },
  "inspector": {
    "displayFields": ["rarSignature", "rarVersionByte", "isRar5", "isSolid", "isVolume"],
    "valueMaps": {
      "rarVersionByte": { "0": "RAR5 (modern format)", "255": "RAR4" }
    },
    "tooltips": {
      "rarSignature": "Rar! magic + version bytes",
      "isRar5": "RAR5 uses 8-byte signature and variable-length integer encoding",
      "isSolid": "Solid archive compresses all files together for better ratio"
    }
  },
  "assertions": [
    {
      "name": "RAR signature valid",
      "expression": "rarSignature.startsWith('526172211A07')",
      "severity": "error",
      "message": "RAR archive must start with 52 61 72 21 1A 07 (Rar!\\x1A\\x07)"
    },
    {
      "name": "RAR version recognized",
      "expression": "rarVersionByte == 0 || rarVersionByte == 255",
      "severity": "warning",
      "message": "Unexpected RAR version byte — expected 0x00 (RAR5) or 0x00 terminator (RAR4)"
    },
    {
      "name": "Minimum file size",
      "expression": "fileSize >= 20",
      "severity": "error",
      "message": "RAR archive too small to contain a valid header"
    }
  ],
  "exportTemplates": [
    {
      "name": "RAR Header (JSON)",
      "format": "json",
      "fields": ["rarSignature", "rarVersionByte", "isRar5", "headerCrc", "headerType", "headerFlags"]
    },
    {
      "name": "RAR Summary (Text)",
      "format": "text",
      "fields": ["rarSignature", "isRar5", "isSolid", "isVolume"]
    }
  ],
  "formatRelationships": [
    { "format": "7Z", "relationship": "Competing format with similar solid-archive and encryption capabilities" },
    { "format": "ZIP", "relationship": "More widely supported alternative without proprietary licensing" },
    { "format": "ACE", "relationship": "Earlier competing proprietary format, now abandoned" }
  ],
  "detection": {
    "signature": "526172211A07",
    "offset": 0,
    "required": true,
    "validation": {
      "minFileSize": 20,
      "maxSignatureOffset": 0
    }
  },
  "variables": {
    "currentOffset": 0,
    "rarSignature": "",
    "rarVersionByte": 0,
    "isRar5": false,
    "headerCrc": 0,
    "headerType": 0,
    "headerFlags": 0,
    "headerSize": 0,
    "reservedWord1": 0,
    "reservedDword1": 0,
    "isVolume": false,
    "hasComment": false,
    "isLocked": false,
    "isSolid": false,
    "hasNewNames": false,
    "hasAuthInfo": false,
    "hasRecoveryRecord": false,
    "isFirstVolume": false,
    "archiveTypeName": "",
    "totalHeaderBytes": 0,
    "flagsSummary": ""
  },
  "functions": {
    "computeFromVariables(rarVersionByte == 1 ? 1 : 0, isRar5)": "Determine if archive is RAR5 format based on version discriminator byte at offset 6",
    "computeFromVariables(headerSize + 7, totalHeaderBytes)": "Calculate total header size including the 7-byte signature prefix for RAR4",
    "formatFileSize(var:totalHeaderBytes)": "Format total header size as human-readable string"
  },
  "blocks": [
    {
      "type": "signature",
      "name": "RAR Signature",
      "offset": 0,
      "length": 6,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "RAR archive magic bytes: 'Rar!' (52 61 72 21) followed by 1A 07. These six bytes are common to both RAR4 and RAR5 formats. The exclamation mark and 0x1A (EOF marker under DOS) help identify the file as a RAR archive.",
      "storeAs": "rarSignature",
      "valueType": "hex",
      "validation": {
        "expectedValue": "0x526172211A07"
      }
    },
    {
      "type": "field",
      "name": "RAR Version Discriminator",
      "offset": 6,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Byte that distinguishes RAR4 from RAR5 format. RAR4 archives have 0x00 at this position, while RAR5 archives have 0x01. RAR5 also has an additional 0x00 byte at offset 7, making the RAR5 signature 8 bytes total.",
      "storeAs": "rarVersionByte",
      "valueType": "uint8",
      "valueMap": {
        "0": "RAR4 (legacy format)",
        "1": "RAR5 (modern format)"
      }
    },
    {
      "type": "field",
      "name": "Archive Header CRC-16",
      "offset": 7,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "CRC-16 checksum of the archive header block (RAR4). Covers bytes from header type through end of header. Used to verify header integrity during extraction. In RAR5, offset shifts due to the 8-byte signature.",
      "storeAs": "headerCrc",
      "valueType": "uint16",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Header Type",
      "offset": 9,
      "length": 1,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "RAR4 header block type identifier. The main archive header uses type 0x73 (MAIN_HEAD). Other types include 0x74 (FILE_HEAD), 0x75 (COMM_HEAD), 0x76 (AV_HEAD), 0x77 (SUB_HEAD), 0x78 (PROTECT_HEAD), 0x79 (SIGN_HEAD), and 0x7A (NEWSUB_HEAD).",
      "storeAs": "headerType",
      "valueType": "uint8",
      "valueMap": {
        "115": "MAIN_HEAD (0x73) - Main archive header",
        "116": "FILE_HEAD (0x74) - File header",
        "117": "COMM_HEAD (0x75) - Comment header",
        "118": "AV_HEAD (0x76) - AV header (old style)",
        "119": "SUB_HEAD (0x77) - Sub-block header",
        "120": "PROTECT_HEAD (0x78) - Recovery record header",
        "121": "SIGN_HEAD (0x79) - Signature header",
        "122": "NEWSUB_HEAD (0x7A) - Subblock header (new style)"
      }
    },
    {
      "type": "field",
      "name": "Archive Flags",
      "offset": 10,
      "length": 2,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "RAR4 main archive header flags (uint16 LE). These bits indicate fundamental archive properties such as whether it is a multi-volume archive, contains comments, is locked against modification, uses solid compression, or includes authentication information.",
      "storeAs": "headerFlags",
      "valueType": "uint16",
      "endianness": "little",
      "bitfields": [
        {
          "bit": 0,
          "name": "MHD_VOLUME",
          "description": "Archive is part of a multi-volume set",
          "valueMap": {
            "0": "Single volume archive",
            "1": "Multi-volume archive"
          }
        },
        {
          "bit": 1,
          "name": "MHD_COMMENT",
          "description": "Archive contains a comment (stored in a special comment block)",
          "valueMap": {
            "0": "No archive comment",
            "1": "Archive comment present"
          }
        },
        {
          "bit": 2,
          "name": "MHD_LOCK",
          "description": "Archive is locked against modification by WinRAR",
          "valueMap": {
            "0": "Archive unlocked",
            "1": "Archive locked"
          }
        },
        {
          "bit": 3,
          "name": "MHD_SOLID",
          "description": "Solid archive mode where files share compression dictionary for better ratio",
          "valueMap": {
            "0": "Non-solid archive",
            "1": "Solid archive"
          }
        },
        {
          "bit": 4,
          "name": "MHD_NEWNUMBERING",
          "description": "New volume naming scheme (volname.partNN.rar instead of volname.rNN)",
          "valueMap": {
            "0": "Old naming scheme (.rNN)",
            "1": "New naming scheme (.partNN.rar)"
          }
        },
        {
          "bit": 5,
          "name": "MHD_AV",
          "description": "Archive contains authenticity verification (digital signature)",
          "valueMap": {
            "0": "No authenticity info",
            "1": "Authenticity verification present"
          }
        },
        {
          "bit": 6,
          "name": "MHD_PROTECT",
          "description": "Archive contains a recovery record for error correction",
          "valueMap": {
            "0": "No recovery record",
            "1": "Recovery record present"
          }
        },
        {
          "bit": 8,
          "name": "MHD_FIRSTVOLUME",
          "description": "Indicates this is the first volume in a multi-volume set",
          "valueMap": {
            "0": "Not first volume (or single volume)",
            "1": "First volume of set"
          }
        }
      ]
    },
    {
      "type": "field",
      "name": "Header Size",
      "offset": 12,
      "length": 2,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Total size of the main archive header block in bytes (RAR4, uint16 LE). This value includes the header CRC, type, flags, size, and any reserved or optional fields. Typically 13 bytes for a standard RAR4 main header.",
      "storeAs": "headerSize",
      "valueType": "uint16",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Reserved Word 1",
      "offset": 14,
      "length": 2,
      "color": "#FF6B9D",
      "opacity": 0.3,
      "description": "Reserved 16-bit field in the RAR4 main archive header. Should be zero in well-formed archives. Was intended for future format extensions.",
      "storeAs": "reservedWord1",
      "valueType": "uint16",
      "endianness": "little"
    },
    {
      "type": "field",
      "name": "Reserved DWord 1",
      "offset": 16,
      "length": 4,
      "color": "#C44569",
      "opacity": 0.3,
      "description": "Reserved 32-bit field in the RAR4 main archive header. Should be zero in well-formed archives. Was intended for future format extensions such as extended archive properties.",
      "storeAs": "reservedDword1",
      "valueType": "uint32",
      "endianness": "little"
    },
    {
      "type": "computeFromVariables",
      "name": "RAR Format Version Detection",
      "expression": "rarVersionByte == 1 ? 1 : 0",
      "storeAs": "isRar5",
      "description": "Determines the RAR format version based on the version discriminator byte at offset 6. A value of 1 indicates RAR5 format with variable-length integer encoding; 0 indicates the legacy RAR4 format with fixed-width header fields."
    },
    {
      "type": "computeFromVariables",
      "name": "Total Header Size Calculation",
      "expression": "headerSize + 7",
      "storeAs": "totalHeaderBytes",
      "description": "Calculates the total header footprint in the file by adding the 7-byte signature prefix to the declared header size. This gives the byte offset where the first file header block begins in a RAR4 archive."
    },
    {
      "type": "conditional",
      "name": "RAR Version Check",
      "condition": "rarVersionByte == 1",
      "trueLabel": "This is a RAR5 archive using modern variable-length integer encoding and AES-256 encryption support",
      "falseLabel": "This is a RAR4 (legacy) archive using fixed-width header fields",
      "description": "Determines the RAR format generation based on the version discriminator byte, which affects header parsing strategy"
    },
    {
      "type": "conditional",
      "name": "Solid Archive Detection",
      "condition": "(headerFlags & 8) != 0",
      "trueLabel": "Solid archive: files share a continuous compression dictionary for improved ratio",
      "falseLabel": "Non-solid archive: each file is compressed independently",
      "description": "Checks bit 3 of the archive flags to determine if solid compression mode is enabled"
    },
    {
      "type": "metadata",
      "name": "Archive Format Version",
      "variable": "isRar5",
      "description": "RAR format generation: true = RAR5 (modern), false = RAR4 (legacy)"
    },
    {
      "type": "metadata",
      "name": "Header Type Name",
      "variable": "headerType",
      "description": "RAR4 header block type identifier (0x73 = MAIN_HEAD for main archive header)"
    },
    {
      "type": "metadata",
      "name": "Archive Flags Value",
      "variable": "headerFlags",
      "description": "Raw archive flags bitmask indicating volume, solid, locked, comment, and recovery record status"
    },
    {
      "type": "metadata",
      "name": "Header Size (bytes)",
      "variable": "headerSize",
      "description": "Declared size of the main archive header block in bytes"
    },
    {
      "type": "metadata",
      "name": "Total Header Footprint",
      "variable": "totalHeaderBytes",
      "description": "Total bytes consumed by signature plus main archive header"
    },
    {
      "type": "metadata",
      "name": "Header CRC-16 Value",
      "variable": "headerCrc",
      "description": "CRC-16 checksum stored in the archive header for integrity verification"
    }
  ],
  "MimeTypes": [
    "application/vnd.rar",
    "application/x-rar-compressed"
  ],
  "Software": [
    "WinRAR",
    "7-Zip",
    "The Unarchiver",
    "PeaZip"
  ],
  "UseCases": [
    "File compression",
    "Multi-volume archives",
    "Recovery records",
    "Backup"
  ],
  "QualityMetrics": {
    "CompletenessScore": 88,
    "DocumentationLevel": "comprehensive",
    "BlocksDefined": 18,
    "ValidationRules": 1,
    "LastUpdated": "2026-05-20",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "forensic": {
    "category": "archive",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": [
    "RAR4 signature: 52 61 72 21 1A 07 00 (7 bytes); RAR5 signature: 52 61 72 21 1A 07 01 00 (8 bytes)",
    "RAR4 main header at offset 7: CRC16(2,LE) + type(1) + flags(2,LE) + size(2,LE) + reserved(6)",
    "RAR5 uses variable-length integers (vint) and a completely different header structure from offset 8",
    "Solid archive flag (0x08 in headerFlags) means all files compressed together — single corrupt block affects all",
    "AES-256 encryption can encrypt file names in addition to content — headers may be encrypted too",
    "WinRAR removal of unasp.dll in v5.70 (Feb 2019) was due to ACE path traversal CVE-2018-20250, not RAR itself"
  ],
  "aiHints_legacy": {
    "analysisContext": "RAR archive format created by Eugene Roshal. Supports high compression ratios, solid archives, multi-volume ...",
    "suggestedInspections": [
      "Verify RAR Archive file header, compression method, and stored CRCs",
      "Check central directory or entry table for consistency",
      "Inspect individual entry sizes for truncation or overflow"
    ]
  },
  "navigation": {
    "bookmarks": [
      {
        "name": "Archive Header Start",
        "offsetVar": "currentOffset",
        "icon": ""
      },
      {
        "name": "First File Block",
        "offsetVar": "totalHeaderBytes",
        "icon": ""
      }
    ]
  },
  "TechnicalDetails": {
    "ArchivesFormat": true,
    "Endianness": "little-endian",
    "CompressionMethod": "RAR proprietary (PPMd, LZSS)",
    "SupportsEncryption": true,
    "EncryptionMethod": "AES-128 (RAR4), AES-256 (RAR5)",
    "SupportsSolidArchive": true,
    "SupportsMultiVolume": true,
    "SupportsRecoveryRecord": true,
    "HeaderSize": "Variable (typically 20 bytes for RAR4 main header)"
  },
  "diff": {
    "keyFields": ["rarSignature", "rarVersionByte", "headerCrc"],
    "ignoreFields": ["totalHeaderBytes"],
    "groupBy": "archiveHeader",
    "note": "Signature and version byte determine format generation; headerCrc detects header tampering; totalHeaderBytes is derived"
  },
  "repair": [
    {
      "name": "FixHeaderCRC16",
      "trigger": "HeaderCRCMismatch",
      "action": "recompute_checksum",
      "target": "headerCrc",
      "algorithm": "crc32",
      "description": "Recomputes the CRC-16 over the archive header block (from header type through end of declared header size) and writes the corrected value at offset 7"
    }
  ],
  "fuzz": {
    "preserveChecksums": true,
    "maxMutationsPerFile": 1,
    "strategies": [
      { "field": "rarSignature", "mutation": "corrupt_signature", "weight": 3, "description": "Corrupt the Rar! magic bytes to test signature validation rejection" },
      { "field": "headerSize", "mutation": "boundary_values", "weight": 2, "description": "Set header size to 0 or UINT16_MAX to test header size boundary handling" },
      { "field": "headerFlags", "mutation": "overflow", "weight": 2, "description": "Set all flag bits to test parser behaviour with undefined flag combinations" },
      { "field": "rarVersionByte", "mutation": "random_bytes", "weight": 1, "description": "Use an unexpected version byte value to test version discrimination logic" },
      { "field": "reservedDword1", "mutation": "bit_flip", "rate": 0.001, "weight": 1, "description": "Flip bits in a reserved field to probe non-zero reserved field handling" }
    ]
  },
  "migration": [
    {
      "from": "RAR4",
      "to": "RAR5",
      "description": "Update RAR version discriminator byte to signal RAR5 format with AES-256 and variable-length integer encoding",
      "changes": [
        { "field": "rarVersionByte", "changeType": "set_value", "value": "1", "description": "Set version discriminator to 1 to indicate RAR5 format" }
      ]
    }
  ]
}




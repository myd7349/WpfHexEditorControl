{
  "formatName": "StuffIt Archive",
  "formatId": "SIT",
  "version": "1.0.1",
  "diffMode": "binary",
  "extensions": [ ".sit", ".sitx" ],
  "description": "StuffIt is a proprietary compression and archive format developed by Aladdin Systems (later Smith Micro). Classic .sit files begin with 'StuffIt ' (0x5374756666497420); the newer StuffIt X format uses 'STUFFITX' (0x5354554646495458).",
  "category": "Archives",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "MimeTypes": [ "application/x-stuffit", "application/x-sit", "application/x-stuffitx" ],
  "UseCases": [
    "Legacy Macintosh software distribution (classic .sit)",
    "Cross-platform archiving with StuffIt X enhanced compression",
    "Digital preservation of older Mac software archives"
  ],
  "references": [
    "https://web.archive.org/web/20050311074809/http://www.aladdinsys.com/sit5/",
    "https://fileformats.fandom.com/wiki/StuffIt",
    "https://www.nationalarchives.gov.uk/PRONOM/x-fmt/264"
  ],
  "software": [
    { "name": "StuffIt Expander", "url": "https://www.smithmicro.com/stuffit.html", "role": "Official expander (macOS/Windows)" },
    { "name": "The Unarchiver",   "url": "https://theunarchiver.com/",              "role": "macOS multi-format extractor supporting .sit" },
    { "name": "7-Zip",            "url": "https://www.7-zip.org/",                  "role": "Limited .sit support via plugins" }
  ],
  "formatRelationships": [
    { "format": "SIT5", "relationship": "StuffIt 5.x introduced a revised header structure still using 'StuffIt ' magic" },
    { "format": "SITX", "relationship": "StuffIt X is a redesigned format with 'STUFFITX' magic and improved compression" },
    { "format": "ZIP",  "relationship": "ZIP largely replaced StuffIt for cross-platform use from the late 1990s onward" }
  ],
  "detection": {
    "signatures": [
      {
        "offset": 0,
        "value": "5374756666497420",
        "label": "'StuffIt ' classic StuffIt magic",
        "weight": 1.0
      },
      {
        "offset": 0,
        "value": "5354554646495458",
        "label": "'STUFFITX' StuffIt X format magic",
        "weight": 0.9
      }
    ],
    "matchMode": "any",
    "MinimumScore": 82,
    "Strength": "Strong",
    "EntropyHint": { "min": 4.0, "max": 8.0, "note": "Compression ratio varies; classic SIT may have moderate entropy" },
    "validation": "First 8 bytes must be either 'StuffIt ' (53 74 75 66 66 49 74 20) or 'STUFFITX' (53 54 55 46 46 49 54 58). For classic .sit, numFiles at offset 8 (2B BE) must be > 0."
  },
  "variables": [
    { "name": "sitMagic",       "type": "ascii",  "offset": 0,  "length": 8,  "description": "Archive magic: 'StuffIt ' or 'STUFFITX'" },
    { "name": "sitNumFiles",    "type": "uint16", "offset": 8,  "length": 2,  "endian": "big", "description": "Number of files in archive (classic .sit only)" },
    { "name": "sitArchiveSize", "type": "uint32", "offset": 10, "length": 4,  "endian": "big", "description": "Total archive size in bytes (classic .sit only)" }
  ],
  "blocks": [
    {
      "name": "ArchiveHeader",
      "offset": 0,
      "length": 22,
      "description": "StuffIt archive header: magic (8 B) + numFiles (2 B) + archiveSize (4 B) + signature bytes + version",
      "fields": [
        { "name": "Magic",       "variable": "sitMagic",       "offset": 0,  "length": 8 },
        { "name": "NumFiles",    "variable": "sitNumFiles",    "offset": 8,  "length": 2 },
        { "name": "ArchiveSize", "variable": "sitArchiveSize", "offset": 10, "length": 4 }
      ]
    },
    {
      "name": "FileEntries",
      "offset": 22,
      "length": -1,
      "description": "Sequence of file entry headers, each containing filename, compression method, sizes, and file data"
    },
    {
      "name": "ArchiveTrailer",
      "offset": -4,
      "length": 4,
      "description": "End-of-archive marker (classic .sit: 0x00 0x00 0x00 0x00)"
    },
    {
      "name": "CompressionMethodTable",
      "offset": 0,
      "length": 0,
      "description": "Virtual block: method codes used in file entries (0=none, 13=rle, 14=compress, 15=huffman, etc.)"
    }
  ],
  "assertions": [
    { "id": "A1", "description": "Magic must start with 'StuffIt' or 'STUFFITX'", "expression": "sitMagic.startsWith('StuffIt') || sitMagic == 'STUFFITX'" },
    { "id": "A2", "description": "NumFiles must be greater than 0 (classic .sit)",  "expression": "sitNumFiles > 0" },
    { "id": "A3", "description": "ArchiveSize should be non-zero and consistent with file size", "expression": "sitArchiveSize > 0" }
  ],
  "navigation": {
    "entryPoint": "ArchiveHeader",
    "structure": [ "ArchiveHeader", "FileEntries", "ArchiveTrailer" ],
    "notes": "Classic .sit file entry headers are 112 bytes each. Each entry includes filename (63 bytes), compression method, uncompressed/compressed sizes, creation/modification dates, and CRC16 checksums for header, data fork, and resource fork."
  },
  "inspector": {
    "badge": "SIT",
    "primaryField": "sitNumFiles",
    "groups": [
      {
        "name": "Archive Header",
        "fields": [ "sitMagic", "sitNumFiles", "sitArchiveSize" ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Archive Summary CSV",
      "format": "csv",
      "fields": [ "sitMagic", "sitNumFiles", "sitArchiveSize" ]
    },
    {
      "name": "Header JSON",
      "format": "json",
      "fields": [ "sitMagic", "sitNumFiles", "sitArchiveSize" ]
    }
  ],
  "forensic": {
    "riskLevel": "LOW",
    "notes": "StuffIt archives are mostly encountered in legacy Macintosh software contexts. Resource forks in classic .sit files may carry executable code that is invisible on non-Mac systems.",
    "suspiciousPatterns": [
      "NumFiles field mismatches actual count of file entry headers found",
      "ArchiveSize field inconsistent with physical file size",
      "File entries containing resource forks with executable code segments",
      "Unknown compression method codes in file entry headers"
    ]
  },
  "aiHints": {
    "analysisContext": "StuffIt archives exist in two main variants: classic .sit (magic 'StuffIt ') with a 22-byte header and 112-byte per-file entries, and StuffIt X (.sitx, magic 'STUFFITX') with a redesigned XML-like structure. Both formats are primarily associated with legacy Macintosh software.",
    "suggestedInspections": [
      "Identify format variant from magic bytes ('StuffIt ' vs 'STUFFITX') to select correct parser",
      "Enumerate file entry headers to extract filenames, compression methods, and stored file sizes",
      "Check CRC16 checksums in each file entry header against stored data and resource fork data",
      "Inspect resource fork data in entries for executable code (relevant to Mac malware analysis)",
      "Verify archive size field against physical file size and compare declared numFiles with actual entry count"
    ]
  },
  "TechnicalDetails": {
    "endianness": "Big-endian (classic .sit); StuffIt X uses its own structured format",
    "classicHeaderSize": 22,
    "classicEntryHeaderSize": 112,
    "compressionMethods": {
      "0":  "No compression",
      "1":  "RLE",
      "13": "Compress (LZW)",
      "14": "Huffman",
      "15": "ArsHuff"
    }
  },
  "QualityMetrics": {
    "CompletenessScore": 84,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  }
}

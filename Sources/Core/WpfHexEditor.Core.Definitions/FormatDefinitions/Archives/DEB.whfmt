{
  "$schema": "https://raw.githubusercontent.com/abbaye/WpfHexEditorIDE/master/schemas/whfmt/v2.0.json",
  "formatName": "Debian Package",
  "formatId": "DEB",
  "version": "1.0.1",
  "diffMode": "binary",
  "extensions": [ ".deb", ".udeb" ],
  "description": "Debian package format (.deb) is an AR archive containing a debian-binary version file, a control.tar archive, and a data.tar archive. The AR magic '!<arch>\n' (0x21 0x3C 0x61 0x72 0x63 0x68 0x3E 0x0A) appears at offset 0.",
  "category": "Archives",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "hex-editor",
  "MimeTypes": [ "application/vnd.debian.binary-package", "application/x-deb" ],
  "UseCases": [
    "Software distribution on Debian, Ubuntu, and derivative Linux systems",
    "Package integrity verification via checksums in control archive",
    "Forensic inspection of installed or staged Debian packages"
  ],
  "references": [
    "https://www.debian.org/doc/debian-policy/ch-controlfields.html",
    "https://wiki.debian.org/Teams/Dpkg/Spec/Format",
    "https://man7.org/linux/man-pages/man5/deb.5.html"
  ],
  "software": [
    { "name": "dpkg",     "url": "https://wiki.debian.org/dpkg",           "role": "Reference package manager" },
    { "name": "apt",      "url": "https://wiki.debian.org/Apt",            "role": "High-level package manager for .deb files" },
    { "name": "7-Zip",    "url": "https://www.7-zip.org/",                 "role": "Can extract .deb AR structure and inner archives" }
  ],
  "formatRelationships": [
    { "format": "AR",    "relationship": "Outer container is an AR archive (Unix ar format)" },
    { "format": "TAR",   "relationship": "control.tar and data.tar members are tar archives" },
    { "format": "GZIP",  "relationship": "Inner tar members are commonly gzip-compressed (.tar.gz)" },
    { "format": "XZ",    "relationship": "Modern .deb packages use xz-compressed inner archives (.tar.xz)" }
  ],
  "detection": {
    "signatures": [
      {
        "offset": 0,
        "value": "213C617263683E0A",
        "label": "'!<arch>\n' AR magic",
        "weight": 1.0
      }
    ],
    "matchMode": "any",
    "MinimumScore": 82,
    "Strength": "Strong",
    "EntropyHint": { "min": 5.0, "max": 8.0, "note": "AR header has low entropy; compressed inner archives have high entropy" },
    "validation": "Bytes 0-7 must be '!<arch>\n' (21 3C 61 72 63 68 3E 0A). First AR member identifier at offset 8 (16 bytes) should contain 'debian-binary' to confirm this is a .deb rather than a generic AR archive."
  },
  "variables": [
    { "name": "debArMagic",     "type": "ascii",  "offset": 0,  "length": 8,  "description": "AR archive magic: '!<arch>\n'" },
    { "name": "debFirstIdent",  "type": "ascii",  "offset": 8,  "length": 16, "description": "First AR member identifier, should be 'debian-binary   '" },
    { "name": "debFileSize",    "type": "ascii",  "offset": 48, "length": 10, "description": "File size of first AR member (ASCII decimal, right-padded with spaces)" }
  ],
  "blocks": [
    {
      "name": "ARMagic",
      "offset": 0,
      "length": 8,
      "description": "AR archive magic header '!<arch>\n'",
      "fields": [
        { "name": "Magic", "variable": "debArMagic", "offset": 0, "length": 8 }
      ]
    },
    {
      "name": "DebianBinaryMember",
      "offset": 8,
      "length": 60,
      "description": "First AR member header (60 bytes): identifier 'debian-binary   ' + timestamp + uid + gid + mode + size + end marker",
      "fields": [
        { "name": "Identifier", "variable": "debFirstIdent", "offset": 0,  "length": 16 },
        { "name": "FileSize",   "variable": "debFileSize",   "offset": 40, "length": 10 }
      ]
    },
    {
      "name": "ControlArchiveMember",
      "offset": -1,
      "length": -1,
      "description": "AR member containing control.tar (or control.tar.gz/xz/zst) with package metadata"
    },
    {
      "name": "DataArchiveMember",
      "offset": -1,
      "length": -1,
      "description": "AR member containing data.tar (or data.tar.gz/xz/zst) with actual package files"
    }
  ],
  "assertions": [
    { "id": "A1", "description": "AR magic must be '!<arch>\n'",           "expression": "debArMagic == '!<arch>\n'" },
    { "id": "A2", "description": "First member identifier must contain 'debian'", "expression": "debFirstIdent contains 'debian'" },
    { "id": "A3", "description": "File size field must be a numeric ASCII string", "expression": "debFileSize is numeric ASCII" }
  ],
  "navigation": {
    "entryPoint": "ARMagic",
    "structure": [ "ARMagic", "DebianBinaryMember", "ControlArchiveMember", "DataArchiveMember" ],
    "notes": "Each AR member header is 60 bytes. Member data follows immediately and is padded to even-byte boundary with '\n'. Members: debian-binary (version string '2.0\n'), control.tar.*, data.tar.*"
  },
  "inspector": {
    "badge": "DEB",
    "primaryField": "debFirstIdent",
    "groups": [
      {
        "name": "AR Container",
        "fields": [ "debArMagic", "debFirstIdent" ]
      },
      {
        "name": "Member Metadata",
        "fields": [ "debFileSize" ]
      }
    ]
  },
  "exportTemplates": [
    {
      "name": "Package Summary CSV",
      "format": "csv",
      "fields": [ "debArMagic", "debFirstIdent", "debFileSize" ]
    },
    {
      "name": "AR Header JSON",
      "format": "json",
      "fields": [ "debArMagic", "debFirstIdent", "debFileSize" ]
    }
  ],
  "forensic": {
    "riskLevel": "MEDIUM",
    "notes": "Debian packages can contain arbitrary executables, pre/post-install scripts, and configuration files. The control archive contains maintainer scripts (preinst, postinst, prerm, postrm) which execute as root. Inspect these carefully.",
    "suspiciousPatterns": [
      "Missing debian-binary member as first AR member",
      "debian-binary version string other than '2.0'",
      "Maintainer scripts (postinst/preinst) containing obfuscated or encoded commands",
      "Unexpected AR member names beyond the standard three members",
      "Data archive containing files targeting sensitive system paths"
    ]
  },
  "aiHints": {
    "analysisContext": "A .deb file is a Unix AR archive containing exactly three members in order: 'debian-binary' (plain text version '2.0\n'), 'control.tar.*' (package metadata and scripts), and 'data.tar.*' (installable files). The control member contains the package name, version, dependencies, and maintainer scripts.",
    "suggestedInspections": [
      "Extract and read debian-binary member to confirm version string is '2.0'",
      "Decompress and inspect control.tar for package name, version, architecture, and dependency fields",
      "Examine maintainer scripts (preinst, postinst, prerm, postrm) for suspicious shell commands",
      "List data.tar file paths to identify target installation directories",
      "Compare declared checksums in control/md5sums against actual data.tar file hashes"
    ]
  },
  "TechnicalDetails": {
    "outerContainer": "Unix AR archive format",
    "arMemberHeaderSize": 60,
    "members": [ "debian-binary", "control.tar.*", "data.tar.*" ],
    "controlCompressionFormats": [ ".tar.gz", ".tar.xz", ".tar.zst", ".tar.bz2" ],
    "dataCompressionFormats":    [ ".tar.gz", ".tar.xz", ".tar.zst", ".tar.bz2" ],
    "debianBinaryVersion": "2.0"
  },
  "QualityMetrics": {
    "CompletenessScore": 86,
    "LastUpdated": "2026-04-15",
    "ReviewedBy": "WPFHexaEditor Team"
  }
}




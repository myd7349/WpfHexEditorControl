<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>WpfHexEditor.Core.Definitions</RootNamespace>
    <AssemblyName>WpfHexEditor.Core.Definitions</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>

    <!-- NuGet package metadata -->
    <PackageId>whfmt.FileFormatCatalog</PackageId>
    <Version>1.3.1</Version>
    <AssemblyVersion>1.3.1</AssemblyVersion>
    <FileVersion>1.3.1</FileVersion>
    <Authors>Derek Tremblay</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Product>whfmt.FileFormatCatalog</Product>
    <Title>whfmt.FileFormatCatalog — 790+ File Format &amp; Language Definitions</Title>
    <Description>790+ embedded .whfmt definitions (782 formats + 10 grammars) for automatic file format detection AND syntax highlighting. Covers 27 binary categories (Archives, Audio, Images, Game, ROMs, Executables, Disk, Crypto...) plus 57 language grammars (C#, Python, JS/TS, Go, Rust, Java, Kotlin, Swift, YAML, TOML, Markdown, Dockerfile, HCL, Nginx, WAT, and more). whfmt schema v2.4: formatId, SyntaxDefinition, group/header/data blocks, sentinel scanning, cross-format imports. Cross-platform net8.0. Utility layer: FormatFileAnalyzer, FormatMatcher (scored confidence), CatalogQuery (fluent), FormatMetadataExtensions (forensic/AI/assertions), FormatSummaryBuilder.</Description>
    <Copyright>GNU AGPL v3.0 - 2016-2026</Copyright>
    <PackageTags>binary;format;detection;syntax-highlighting;language-grammar;whfmt;file-format;code-editor;catalog;net8</PackageTags>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorIDE</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorIDE</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReleaseNotes>1.3.1 — Mass enrichment: 101 formats now carry complete diff/repair/fuzz/migration blocks across 15 categories (Audio, Images, Archives, Executables, Video, Documents, Game/ROM, Crypto, Network, Firmware, 3D, Fonts, Disk, System, GIS). 8 new format definitions added (PEM, DER, P12, GPG, UEFI, BIOS, UBoot, DNS). Zero JSON errors.</PackageReleaseNotes>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>

    <!-- SourceLink: enables step-through debugging for NuGet consumers -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <DebugType>embedded</DebugType>
  </PropertyGroup>

  <!-- Embedded definition resources -->
  <ItemGroup>
    <EmbeddedResource Include="FormatDefinitions\**\*.whfmt" />
    <EmbeddedResource Include="FormatDefinitions\**\*.grammar" />
  </ItemGroup>

  <!-- JSON Schema files embedded in the assembly (accessible via GetManifestResourceStream) -->
  <ItemGroup>
    <EmbeddedResource Include="*.schema.json" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="whfmt-FileFormatCatalog-guide.md" Pack="true" PackagePath="\" />
    <None Include="icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.*" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core.Contracts bundled into the package — consumer zero extra dependencies -->
    <ProjectReference Include="..\WpfHexEditor.Core.Contracts\WpfHexEditor.Core.Contracts.csproj" PrivateAssets="all" />
  </ItemGroup>

  <!-- Bundle Core.Contracts DLL + XML into the NuGet lib/ folder -->
  <PropertyGroup>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);CopyProjectReferencesToPackage</TargetsForTfmSpecificBuildOutput>
  </PropertyGroup>
  <Target Name="CopyProjectReferencesToPackage" DependsOnTargets="ResolveReferences">
    <ItemGroup>
      <BuildOutputInPackage Include="@(ReferenceCopyLocalPaths->WithMetadataValue('ReferenceSourceTarget','ProjectReference'))" />
      <BuildOutputInPackage Include="@(ReferenceCopyLocalPaths->WithMetadataValue('ReferenceSourceTarget','ProjectReference')->'%(RootDir)%(Directory)%(Filename).xml')"
                            Condition="Exists('%(RootDir)%(Directory)%(Filename).xml')" />
    </ItemGroup>
  </Target>

</Project>

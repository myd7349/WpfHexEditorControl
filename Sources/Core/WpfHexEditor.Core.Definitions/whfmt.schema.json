{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://wpfhexeditor.dev/schemas/whfmt/v2.2",
  "title": "WpfHexEditor Format Definition (.whfmt)",
  "description": "Schema for .whfmt format definition files used by WpfHexEditor to parse, colorize, and analyze binary file structures.",
  "type": "object",
  "required": ["formatName"],
  "$comment": "detection and blocks are required for binary formats but optional for source-code language definitions (preferredEditor: code-editor).",
  "properties": {
    "formatName": {
      "type": "string",
      "description": "Human-readable format name (e.g., 'ZIP Archive', 'PNG Image')"
    },
    "formatId": {
      "type": "string",
      "description": "Unique format identifier (optional; defaults to file stem)"
    },
    "name": {
      "type": "string",
      "description": "Alternate display name alias (used by some source-code .whfmt files)"
    },
    "version": {
      "type": "string",
      "description": "Version of this definition (e.g., '1.0', '2.0')"
    },
    "extensions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "File extensions associated with this format (e.g., ['.zip', '.jar'])"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the format"
    },
    "author": {
      "type": "string",
      "description": "Author of this definition file"
    },
    "category": {
      "type": "string",
      "description": "Category (auto-set from folder structure: Archives, Images, Audio, Video, etc.)"
    },
    "mimeTypes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "MIME types associated with this format"
    },
    "software": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Software that can open/create this format"
    },
    "useCases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Common use cases for this format"
    },
    "preferredEditor": {
      "type": "string",
      "enum": ["code-editor", "structure-editor", "hex-editor", "text-editor", "tbl-editor", "tile-editor"],
      "description": "Preferred editor factory ID for files matching this format"
    },
    "diffMode": {
      "type": "string",
      "enum": ["text", "semantic", "binary"],
      "description": "Preferred diff algorithm for DiffViewer"
    },

    "syntaxDefinition": {
      "$ref": "#/$defs/SyntaxDefinition",
      "description": "Source-code language definition block (code-editor .whfmt only). Contains syntax rules, formatting defaults, and preview snippets."
    },

    "detection": { "$ref": "#/$defs/DetectionRule" },
    "variables": {
      "type": "object",
      "additionalProperties": true,
      "description": "Initial variables and their values for the script interpreter"
    },
    "blocks": {
      "type": "array",
      "items": { "$ref": "#/$defs/BlockDefinition" },
      "description": "List of block definitions to render"
    },
    "functions": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Optional functions documentation (for reference)"
    },
    "references": { "$ref": "#/$defs/FormatReferences" },
    "qualityMetrics": { "$ref": "#/$defs/QualityMetrics" },
    "formatRelationships": { "$ref": "#/$defs/FormatRelationships" },
    "technicalDetails": { "$ref": "#/$defs/TechnicalDetails" },

    "versionDetection": { "$ref": "#/$defs/FormatVersionDetection" },
    "versionedBlocks": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/$defs/BlockDefinition" }
      },
      "description": "Version-specific block sets keyed by version string from versionDetection"
    },
    "checksums": {
      "type": "array",
      "items": { "$ref": "#/$defs/ChecksumDefinition" },
      "description": "Checksum validation rules evaluated after block interpretation"
    },
    "assertions": {
      "type": "array",
      "items": { "$ref": "#/$defs/AssertionDefinition" },
      "description": "Assertion rules — failures populate the Forensic Alerts panel"
    },
    "forensic": { "$ref": "#/$defs/ForensicDefinition" },
    "navigation": { "$ref": "#/$defs/NavigationDefinition" },
    "inspector": { "$ref": "#/$defs/InspectorDefinition" },
    "exportTemplates": {
      "type": "array",
      "items": { "$ref": "#/$defs/ExportTemplate" },
      "description": "Export templates for extracting structured data"
    },
    "aiHints": { "$ref": "#/$defs/AiHints" }
  },
  "$defs": {
    "OffsetOrExpression": {
      "description": "An offset value: integer, 'var:name', or 'calc:expression'",
      "oneOf": [
        { "type": "integer" },
        { "type": "string" }
      ]
    },

    "DetectionRule": {
      "type": "object",
      "description": "Detection rule for identifying file formats",
      "properties": {
        "signature": {
          "type": "string",
          "pattern": "^[0-9A-Fa-f]*$",
          "description": "Legacy single hex signature (e.g., '504B0304' for ZIP)"
        },
        "signatures": {
          "type": "array",
          "items": { "$ref": "#/$defs/SignatureEntry" },
          "description": "v2.0: Multiple alternative signatures (OR logic)"
        },
        "matchMode": {
          "type": "string",
          "enum": ["any", "all"],
          "default": "any",
          "description": "How to combine multi-signature matches"
        },
        "entropyHint": { "$ref": "#/$defs/EntropyHint" },
        "minimumScore": {
          "type": "number",
          "minimum": 0, "maximum": 1,
          "default": 0.70,
          "description": "Minimum weighted confidence score (0.0–1.0)"
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Offset where signature should appear"
        },
        "required": {
          "type": "boolean",
          "default": true,
          "description": "Whether this signature is required for detection"
        },
        "strength": {
          "type": "string",
          "enum": ["None", "Weak", "Medium", "Strong", "Unique"],
          "default": "Medium",
          "description": "Strength of the signature for confidence scoring"
        },
        "isTextFormat": {
          "type": "boolean",
          "default": false,
          "description": "Whether this format is text-based"
        },
        "contentPatterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Content validation regex patterns for text formats"
        },
        "minConfidenceThreshold": {
          "type": "number",
          "minimum": 0, "maximum": 1,
          "default": 0.7,
          "description": "Minimum confidence for auto-selection"
        }
      }
    },

    "SignatureEntry": {
      "type": "object",
      "required": ["value"],
      "properties": {
        "value": {
          "type": "string",
          "description": "Hex bytes to match (e.g., 'FF FB')"
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "File offset where the signature must appear"
        },
        "label": {
          "type": "string",
          "description": "Human-readable label for this variant"
        },
        "weight": {
          "type": "number",
          "minimum": 0, "maximum": 1,
          "default": 0.9,
          "description": "Confidence weight contribution"
        }
      }
    },

    "EntropyHint": {
      "type": "object",
      "properties": {
        "min": { "type": "number", "minimum": 0, "maximum": 8 },
        "max": { "type": "number", "minimum": 0, "maximum": 8, "default": 8.0 }
      },
      "description": "Expected Shannon entropy range for valid files"
    },

    "BlockDefinition": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["signature", "field", "metadata", "conditional", "loop", "action", "computeFromVariables", "repeating", "union", "nested", "pointer"],
          "description": "Block type"
        },
        "name": { "type": "string", "description": "Name/description of this block" },
        "offset": { "$ref": "#/$defs/OffsetOrExpression" },
        "offsetFrom": { "type": "string", "description": "Variable name for base offset" },
        "offsetAdd": { "$ref": "#/$defs/OffsetOrExpression" },
        "length": { "$ref": "#/$defs/OffsetOrExpression" },
        "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$", "description": "Background color (#RRGGBB)" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.3 },
        "description": { "type": "string" },
        "valueType": {
          "type": "string",
          "description": "Value type: uint8, uint16, uint32, uint64, int8, int16, int32, int64, ascii8, utf8, utf16le, utf16be, float32, float64, guid, dosdate, dostime, filetime, unixtime32, unixtime64, ipv4, ipv6, sha1, sha256, md5, varint, bcd, string, boolean"
        },
        "storeAs": { "type": "string", "description": "Variable name to store this field's value" },
        "hidden": { "type": "boolean", "description": "If true, parsed but not shown in UI" },
        "endianness": { "type": "string", "enum": ["little", "big"] },
        "bitfields": {
          "type": "array",
          "items": { "$ref": "#/$defs/BitfieldDefinition" }
        },
        "valueMap": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Lookup table mapping raw values to human-readable names"
        },
        "mappedValueStoreAs": { "type": "string" },
        "validationRules": { "$ref": "#/$defs/FieldValidationRules" },

        "condition": {
          "description": "Condition for conditional/loop blocks (object or string expression)",
          "oneOf": [
            { "$ref": "#/$defs/ConditionDefinition" },
            { "type": "string" }
          ]
        },
        "then": { "type": "array", "items": { "$ref": "#/$defs/BlockDefinition" } },
        "else": { "type": "array", "items": { "$ref": "#/$defs/BlockDefinition" } },
        "trueLabel": { "type": "string" },
        "falseLabel": { "type": "string" },

        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/BlockDefinition" },
          "description": "Sub-field definitions for repeating/union blocks"
        },
        "entrySize": { "$ref": "#/$defs/OffsetOrExpression" },
        "indexVar": { "type": "string", "description": "Variable for current iteration index (0-based)" },
        "colorCycle": {
          "type": "array",
          "items": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
          "description": "Hex colors to cycle through for repeating entries"
        },

        "unionCondition": { "type": "string", "description": "Variable for union variant selection" },
        "variants": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/UnionVariant" }
        },

        "structRef": { "type": "string", "description": "External struct reference for nested blocks" },
        "targetVar": { "type": "string", "description": "Target offset variable for pointer blocks" },
        "label": { "type": "string", "description": "Display label for pointer blocks" },

        "count": { "$ref": "#/$defs/OffsetOrExpression" },
        "maxIterations": { "type": "integer", "minimum": 1, "default": 1000 },
        "body": { "type": "array", "items": { "$ref": "#/$defs/BlockDefinition" } },

        "expression": { "type": "string", "description": "Expression for computeFromVariables blocks" },
        "action": { "type": "string", "enum": ["increment", "decrement", "setVariable"] },
        "variable": { "type": "string" },
        "value": {}
      }
    },

    "UnionVariant": {
      "type": "object",
      "properties": {
        "length": { "$ref": "#/$defs/OffsetOrExpression" },
        "valueType": { "type": "string" },
        "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.3 },
        "fields": { "type": "array", "items": { "$ref": "#/$defs/BlockDefinition" } },
        "description": { "type": "string" }
      }
    },

    "BitfieldDefinition": {
      "type": "object",
      "required": ["name", "bits"],
      "properties": {
        "name": { "type": "string" },
        "bits": {
          "type": "string",
          "pattern": "^\\d+(-\\d+)?$",
          "description": "Bit range: '7-6' for bits 7 down to 6, or '3' for single bit"
        },
        "storeAs": { "type": "string" },
        "description": { "type": "string" },
        "valueMap": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },

    "ConditionDefinition": {
      "type": "object",
      "properties": {
        "field": { "type": "string", "description": "'offset:N' or 'var:name'" },
        "operator": { "type": "string", "enum": ["equals", "notEquals", "greaterThan", "lessThan", "expression"] },
        "value": { "type": "string" },
        "length": { "type": "integer", "default": 1 }
      }
    },

    "FieldValidationRules": {
      "type": "object",
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" },
        "expectedValues": { "type": "array", "items": {} },
        "pattern": { "type": "string" }
      }
    },

    "FormatReferences": {
      "type": "object",
      "properties": {
        "specifications": { "type": "array", "items": { "type": "string" } },
        "webLinks": { "type": "array", "items": { "type": "string", "format": "uri" } }
      }
    },

    "QualityMetrics": {
      "type": "object",
      "properties": {
        "completenessScore": { "type": "integer", "minimum": 0, "maximum": 100 },
        "documentationLevel": { "type": "string", "enum": ["basic", "standard", "detailed", "comprehensive"] },
        "blocksDefined": { "type": "integer" },
        "validationRules": { "type": "integer" },
        "lastUpdated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "priorityFormat": { "type": "boolean" },
        "autoRefined": { "type": "boolean" }
      }
    },

    "FormatRelationships": {
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "extensions": { "type": "array", "items": { "type": "string" } },
        "relatedFormats": { "type": "array", "items": { "type": "string" } }
      }
    },

    "TechnicalDetails": {
      "type": "object",
      "properties": {
        "primaryExtension": { "type": "string" },
        "definedFields": { "type": "integer" },
        "compressionMethod": { "type": "string" },
        "archivesFormat": { "type": "boolean" },
        "imagesFormat": { "type": "boolean" },
        "executablesFormat": { "type": "boolean" },
        "audioFormat": { "type": "boolean" },
        "videoFormat": { "type": "boolean" },
        "documentFormat": { "type": "boolean" },
        "bitDepth": { "type": "integer" },
        "colorSpace": { "type": "string" },
        "sampleRate": { "type": "integer" },
        "container": { "type": "string" },
        "platform": { "type": "string" },
        "supportsEncryption": { "type": "boolean" }
      }
    },

    "FormatVersionDetection": {
      "type": "object",
      "required": ["field", "map"],
      "properties": {
        "field": { "type": "string", "description": "Variable name whose value drives version selection" },
        "map": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Maps raw field values to version labels"
        }
      }
    },

    "ChecksumDefinition": {
      "type": "object",
      "required": ["name", "algorithm"],
      "properties": {
        "name": { "type": "string" },
        "algorithm": { "type": "string", "enum": ["crc32", "crc16", "md5", "sha1", "sha256", "adler32"] },
        "dataRange": {
          "type": "object",
          "properties": {
            "offsetVar": { "type": "string" },
            "lengthVar": { "type": "string" },
            "fixedOffset": { "type": "integer" },
            "fixedLength": { "type": "integer" }
          }
        },
        "storedAt": {
          "type": "object",
          "properties": {
            "offsetVar": { "type": "string" },
            "fixedOffset": { "type": "integer" },
            "length": { "type": "integer" },
            "endianness": { "type": "string", "enum": ["little", "big"] }
          }
        },
        "storedType": { "type": "string" },
        "expectedValue": { "type": "string" },
        "severity": { "type": "string", "enum": ["error", "warning", "info"], "default": "warning" }
      }
    },

    "AssertionDefinition": {
      "type": "object",
      "required": ["name", "expression"],
      "properties": {
        "name": { "type": "string" },
        "expression": { "type": "string", "description": "Boolean expression evaluated against parsed variables" },
        "severity": { "type": "string", "enum": ["error", "warning", "info"], "default": "warning" },
        "message": { "type": "string", "description": "Human-readable failure message" }
      }
    },

    "ForensicDefinition": {
      "type": "object",
      "properties": {
        "category": { "type": "string", "description": "Forensic category (executable, document, archive, image, etc.)" },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high"], "default": "low" },
        "suspiciousPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/ForensicPattern" }
        },
        "knownMaliciousPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/ForensicPattern" }
        }
      }
    },

    "ForensicPattern": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "condition": { "type": "string" },
        "entropyThreshold": { "type": "number", "minimum": 0, "maximum": 8 },
        "severity": { "type": "string", "enum": ["error", "warning", "info"], "default": "warning" },
        "description": { "type": "string" }
      }
    },

    "NavigationDefinition": {
      "type": "object",
      "properties": {
        "bookmarks": {
          "type": "array",
          "items": { "$ref": "#/$defs/NavigationBookmark" }
        },
        "pointers": {
          "type": "array",
          "items": { "$ref": "#/$defs/NavigationPointer" }
        }
      }
    },

    "NavigationBookmark": {
      "type": "object",
      "required": ["name", "offsetVar"],
      "properties": {
        "name": { "type": "string", "description": "Display name (e.g., 'Entry Point')" },
        "offsetVar": { "type": "string", "description": "Variable whose value is the target offset" },
        "icon": { "type": "string", "description": "Segoe MDL2 glyph character" },
        "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
      }
    },

    "NavigationPointer": {
      "type": "object",
      "required": ["name", "offsetVar"],
      "properties": {
        "name": { "type": "string" },
        "offsetVar": { "type": "string" }
      }
    },

    "InspectorDefinition": {
      "type": "object",
      "properties": {
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "fields"],
            "properties": {
              "title": { "type": "string" },
              "icon": { "type": "string" },
              "collapsed": { "type": "boolean", "default": false },
              "highlight": { "type": "boolean", "default": false },
              "fields": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "badge": { "type": "string", "description": "Variable name for badge chip text" },
        "primaryField": { "type": "string" },
        "showQualityScore": { "type": "boolean", "default": false }
      }
    },

    "ExportTemplate": {
      "type": "object",
      "required": ["name", "format"],
      "properties": {
        "name": { "type": "string" },
        "format": { "type": "string", "enum": ["json", "csv", "c-struct", "python-bytes", "xml"] },
        "fields": { "type": "array", "items": { "type": "string" } },
        "source": { "type": "string", "description": "Repeating block source (prefix: 'repeating:')" },
        "columns": { "type": "array", "items": { "type": "string" } },
        "structName": { "type": "string" }
      }
    },

    "AiHints": {
      "type": "object",
      "properties": {
        "analysisContext": { "type": "string", "maxLength": 200, "description": "Brief analysis context for LLM prompts" },
        "knownVulnerabilities": { "type": "array", "items": { "type": "string" } },
        "suggestedInspections": { "type": "array", "items": { "type": "string" } },
        "forensicContext": { "type": "string" }
      }
    },

    "SyntaxDefinition": {
      "type": "object",
      "description": "Source-code language definition (code-editor .whfmt only). Groups all syntax coloring, folding, formatting, and preview data for one language.",
      "properties": {
        "id":                  { "type": "string",  "description": "Unique language identifier (e.g., 'csharp', 'python')" },
        "name":                { "type": "string",  "description": "Display name (e.g., 'C# Source File')" },
        "extensions":          { "type": "array", "items": { "type": "string" }, "description": "File extensions handled by this language" },
        "diagnosticPrefix":    { "type": "string",  "description": "Prefix shown before diagnostic messages in the Error List (e.g., 'CS', 'PY')" },
        "lineCommentPrefix":   { "type": "string",  "description": "Single-line comment token (e.g., '//', '#', '--')" },
        "blockCommentStart":   { "type": "string",  "description": "Block comment open token (e.g., '/*')" },
        "blockCommentEnd":     { "type": "string",  "description": "Block comment close token (e.g., '*/')" },
        "bracketPairs":        { "type": "array",   "description": "Matching bracket pairs for bracket colorization and auto-close" },
        "columnRulers":        { "type": "array", "items": { "type": "integer" }, "description": "Column positions where vertical ruler lines are drawn" },
        "rules":               { "type": "array",   "description": "Ordered list of syntax tokenization rules" },
        "foldingRules":        { "type": "object",  "description": "Code folding strategy configuration" },
        "breakpointRules":     { "type": "object",  "description": "Rules controlling where breakpoints can be placed" },
        "formattingRules": {
          "$ref": "#/$defs/FormattingRules",
          "description": "Language-specific formatting defaults. Keys map 1-to-1 to CodeEditorDefaults override properties."
        },
        "previewSnippet": {
          "type": "string",
          "description": "Representative multi-line code snippet (\\n-separated) shown in the Formatting options live preview panel."
        },
        "previewSamples": {
          "$ref": "#/$defs/PreviewSamples",
          "description": "Per-rule Before/After code fragments shown as tooltips on Formatting option checkboxes."
        },
        "includes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Language IDs to inherit rules from (resolved by LanguageRegistry after full registration)"
        },
        "ideMetadata": {
          "$ref": "#/$defs/IdeMetadata",
          "description": "IDE-level metadata for the language: icons, diagram support, diff mode override, aliases."
        },
        "scriptGlobals": {
          "type": "array",
          "items": { "$ref": "#/$defs/ScriptGlobalEntry" },
          "description": "Script host global objects injected into the script context (e.g. for .csx files). Used by ScriptGlobalsCompletionProvider."
        }
      }
    },

    "FormattingRules": {
      "type": "object",
      "description": "Formatting defaults for source-code languages. All properties are optional — absent keys mean the CodeEditor uses its own built-in defaults.",
      "properties": {
        "indentSize":               { "type": "integer", "minimum": 1, "maximum": 16, "description": "Number of spaces per indent level (or tab width when useTabs is true)" },
        "useTabs":                  { "type": "boolean", "description": "Use hard tabs instead of spaces for indentation" },
        "trimTrailingWhitespace":   { "type": "boolean", "description": "Remove trailing spaces/tabs on each line" },
        "insertFinalNewline":       { "type": "boolean", "description": "Ensure file ends with exactly one newline character" },
        "lineEnding":               { "type": "string", "enum": ["lf", "crlf", "cr"], "description": "Normalised line ending written on Save" },
        "spaceAfterKeywords":       { "type": "boolean", "description": "Insert space between control keywords (if/for/while) and opening paren" },
        "spaceInsideParens":        { "type": "boolean", "description": "Insert spaces inside parentheses: f( x ) vs f(x)" },
        "maxConsecutiveBlankLines": { "type": "integer", "minimum": 0, "maximum": 10, "description": "Maximum consecutive blank lines allowed between statements" },
        "blankLineBeforeMethod":    { "type": "boolean", "description": "Ensure one blank line before every method/function declaration" },
        "blankLineAfterImports":    { "type": "boolean", "description": "Ensure one blank line after the import/using block" },
        "spaceAroundBinaryOperators": { "type": "boolean", "description": "Insert spaces around binary operators: a + b vs a+b" },
        "spaceAfterComma":          { "type": "boolean", "description": "Insert space after each comma in argument/parameter lists" },
        "organizeImports":          { "type": "boolean", "description": "Sort import/using directives alphabetically when formatting" },
        "separateSystemImports":    { "type": "boolean", "description": "Place System.* imports in a separate group above user imports (C# / Java)" },
        "quoteStyle":               { "type": "string", "enum": ["single", "double", "backtick"], "description": "Preferred string literal quote character" },
        "maxLineLength":            { "type": "integer", "minimum": 40, "maximum": 300, "description": "Soft line-length limit (shown as a column ruler)" },
        "indentCaseLabels":         { "type": "boolean", "description": "Indent case/when labels one level inside switch blocks" },
        "braceStyle": {
          "type": "string",
          "enum": ["allmanStyle", "kernelAndRitchie", "sameLine"],
          "description": "Opening-brace placement style: allmanStyle (new line), kernelAndRitchie (K&R), sameLine"
        },
        "spaceBeforeOpenBrace":     { "type": "boolean", "description": "Insert a space before '{' when brace is on the same line as the header" },
        "keywordParenKeywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keywords after which a space is inserted before '(' (overrides CodeEditor built-in list)"
        },
        "importKeywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keywords that introduce import/using directives (used for blankLineAfterImports detection)"
        },
        "methodDeclKeywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keywords that start method/function declarations (used for blankLineBeforeMethod detection)"
        },
        "supportedRules": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Subset of formattingRules keys that apply to this language. When present, the Formatting options page hides or disables rules not in this list. IDs match the JSON property names in this formattingRules block (e.g., 'spaceAfterKeywords', 'organizeImports')."
        }
      },
      "additionalProperties": false
    },

    "PreviewSamples": {
      "type": "object",
      "description": "Map of formattingRule key → Before/After snippet pair. Used to populate tooltips on the Formatting options page.",
      "additionalProperties": {
        "$ref": "#/$defs/PreviewSamplePair"
      }
    },

    "PreviewSamplePair": {
      "type": "object",
      "description": "A single Before/After code fragment illustrating the effect of one formatting rule.",
      "required": ["before", "after"],
      "properties": {
        "before": { "type": "string", "description": "Code fragment as it appears BEFORE the rule is applied" },
        "after":  { "type": "string", "description": "Code fragment as it appears AFTER the rule is applied" }
      },
      "additionalProperties": false
    },

    "IdeMetadata": {
      "type": "object",
      "description": "IDE-level metadata for a source-code language. Drives icons, panel availability, diff-mode override, and DiffModeDetector configuration.",
      "properties": {
        "isSourceFile":          { "type": "boolean", "description": "True if files of this language are source code (not config/data)" },
        "isStructuredDataFile":  { "type": "boolean", "description": "True if the language is a structured data format (JSON, YAML, TOML…)" },
        "supportsClassDiagram":  { "type": "boolean", "description": "True if the ClassDiagram plugin can analyse files of this language" },
        "supportsSourceOutline": { "type": "boolean", "description": "True if the DocumentStructure SourceOutline provider supports this language" },
        "isProjectLanguage":     { "type": "boolean", "description": "True if the language can be a primary project language (shown in New Project dialog)" },
        "languageColor":         { "type": "string", "pattern": "^#[0-9A-Fa-f]{3,8}$", "description": "GitHub-style language badge color (#RRGGBB or #RRGGBBAA)" },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Alternative names / short IDs (e.g. 'c#', 'cs') used for look-up in LanguageRegistry"
        },
        "iconGlyph":   { "type": "string", "description": "Segoe MDL2 / custom font glyph character for the language icon" },
        "diffMode": {
          "type": "string",
          "enum": ["text", "semantic", "binary"],
          "description": "Per-language diff algorithm override for DiffModeDetector (overrides top-level diffMode for source files)"
        }
      }
    },

    "ScriptGlobalEntry": {
      "type": "object",
      "description": "A host-injected global object available inside script files (e.g. .csx). Drives ScriptGlobalsCompletionProvider.",
      "required": ["name", "type"],
      "properties": {
        "name":          { "type": "string", "description": "Variable name as it appears in the script scope" },
        "type":          { "type": "string", "description": "CLR type name (interface or class, e.g. 'IHexEditorService')" },
        "documentation": { "type": "string", "description": "One-line summary shown in IntelliSense" },
        "members": {
          "type": "array",
          "items": { "$ref": "#/$defs/ScriptMemberEntry" },
          "description": "Members exposed by this global object"
        }
      }
    },

    "ScriptMemberEntry": {
      "type": "object",
      "description": "A single member (property, method, or event) on a ScriptGlobalEntry.",
      "required": ["name", "type", "kind"],
      "properties": {
        "name":          { "type": "string", "description": "Member name" },
        "type":          { "type": "string", "description": "Return type or property type" },
        "kind": {
          "type": "string",
          "enum": ["property", "method", "event"],
          "description": "Member kind"
        },
        "documentation": { "type": "string", "description": "One-line summary shown in IntelliSense" },
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name":          { "type": "string" },
              "type":          { "type": "string" },
              "documentation": { "type": "string" }
            }
          },
          "description": "Method parameters (only for kind: method)"
        }
      }
    }
  }
}

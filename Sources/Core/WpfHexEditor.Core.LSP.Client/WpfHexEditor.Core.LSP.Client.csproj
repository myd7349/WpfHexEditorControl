    WpfHexEditor.Core.LSP.Client
    ========================
    Standard JSON-RPC Language Server Protocol client for WpfHexEditor.
    Implements ILspClient / ILspServerRegistry from WpfHexEditor.SDK.
    No NuGet dependencies — uses System.Text.Json and System.IO.Pipes (both inbox in net8.0).

    Bundled server support (optional, each requires the server on PATH or configured path):
      - JSON  : vscode-languageserver / vscode-json-languageserver
      - XML   : lemminx
      - C#    : OmniSharp (Roslyn)
-->

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>false</UseWPF>
    <RootNamespace>WpfHexEditor.Core.LSP.Client</RootNamespace>
    <AssemblyName>WpfHexEditor.Core.LSP.Client</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>Standard JSON-RPC LSP client — ILspClient/ILspServerRegistry implementation, LspProcess, LspJsonRpcChannel, document sync, and per-language feature providers.</Description>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Plugins\WpfHexEditor.SDK\WpfHexEditor.SDK.csproj" />
  </ItemGroup>

</Project>

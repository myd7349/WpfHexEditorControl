<!-- ==========================================================
     Project: WpfHexEditor.Core.WorkspaceTemplates
     File: Views/NewProjectDialog.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude Sonnet 4.6
     Created: 2026-03-16
     Description:
         3-step New Project wizard dialog.
         Step 1 — Template selection with search filter.
         Step 2 — Project name, parent directory, language.
         Step 3 — Optional plugins (pre-selected by template).
     WPF Theme: Global theme (DockMenuBackgroundBrush / DockMenuForegroundBrush / DockBorderBrush)
     ========================================================== -->
<Window x:Class="WpfHexEditor.Core.WorkspaceTemplates.Views.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Project"
        Width="760" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource DockMenuBackgroundBrush}"
        Foreground="{DynamicResource DockMenuForegroundBrush}">

    <Window.Resources>
        <!-- Step indicator style -->
        <Style x:Key="StepLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ActiveStepStyle" TargetType="TextBlock" BasedOn="{StaticResource StepLabelStyle}">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource DockAccentBrush}"/>
        </Style>

        <!-- Template list item -->
        <DataTemplate x:Key="TemplateItemTemplate">
            <StackPanel Margin="4,3">
                <TextBlock Text="{Binding Name}"     FontWeight="SemiBold"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                <TextBlock Text="{Binding Description}" FontSize="10" Opacity="0.7" TextWrapping="Wrap"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            </StackPanel>
        </DataTemplate>

        <!-- Optional plugin checkbox item -->
        <DataTemplate x:Key="PluginItemTemplate">
            <CheckBox IsChecked="{Binding IsIncluded}" Content="{Binding DisplayName}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="2,2"/>
        </DataTemplate>

        <!-- Standard button style -->
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Width"      Value="80"/>
            <Setter Property="Height"     Value="26"/>
            <Setter Property="Margin"     Value="4,0"/>
            <Setter Property="Background" Value="{DynamicResource DockMenuBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
        </Style>

        <!-- Input box style -->
        <Style x:Key="DialogTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"  Value="{DynamicResource DockMenuBackgroundBrush}"/>
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="Height"      Value="24"/>
            <Setter Property="Padding"     Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Step indicator -->
            <RowDefinition Height="36"/>
            <!-- Step header -->
            <RowDefinition Height="40"/>
            <!-- Step content -->
            <RowDefinition Height="*"/>
            <!-- Separator -->
            <RowDefinition Height="1"/>
            <!-- Buttons -->
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- ================================================================
             Step indicator bar
             ================================================================ -->
        <Border Grid.Row="0"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="StepLabel1" Text="1  Template"
                           Style="{StaticResource ActiveStepStyle}"/>
                <TextBlock Text="›" Style="{StaticResource StepLabelStyle}" Margin="0,0,12,0"/>
                <TextBlock x:Name="StepLabel2" Text="2  Configure"
                           Style="{StaticResource StepLabelStyle}"/>
                <TextBlock Text="›" Style="{StaticResource StepLabelStyle}" Margin="0,0,12,0"/>
                <TextBlock x:Name="StepLabel3" Text="3  Plugins"
                           Style="{StaticResource StepLabelStyle}"/>
            </StackPanel>
        </Border>

        <!-- ================================================================
             Step header
             ================================================================ -->
        <Border Grid.Row="1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                Padding="16,0">
            <TextBlock x:Name="StepTitle"
                       Text="Select a template"
                       VerticalAlignment="Center"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
        </Border>

        <!-- ================================================================
             Step 1 — Template Selection
             ================================================================ -->
        <Grid x:Name="Step1Panel" Grid.Row="2" Margin="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search filter -->
            <TextBox x:Name="TbFilter"
                     Grid.Column="0" Grid.Row="0" Margin="0,0,4,4"
                     Style="{StaticResource DialogTextBoxStyle}"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Search templates..."
                     ToolTip="Filter templates"/>

            <!-- Template list -->
            <ListBox x:Name="LbTemplates"
                     Grid.Column="0" Grid.Row="1"
                     ItemsSource="{Binding FilteredTemplates}"
                     SelectedItem="{Binding SelectedTemplate}"
                     ItemTemplate="{StaticResource TemplateItemTemplate}"
                     Background="{DynamicResource DockMenuBackgroundBrush}"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Margin="0,0,8,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

            <!-- Template preview -->
            <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="1" Padding="12">
                <StackPanel DataContext="{Binding SelectedTemplate}">
                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Category}" FontSize="10" Opacity="0.6"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Margin="0,4,0,8"/>
                    <TextBlock Text="{Binding Description}" FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <Separator Margin="0,12" Background="{DynamicResource DockBorderBrush}"/>
                    <TextBlock FontSize="10" Opacity="0.6"
                               Foreground="{DynamicResource DockMenuForegroundBrush}">
                        <Run Text="Default language: "/>
                        <Run Text="{Binding DefaultLanguage, FallbackValue='—'}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ================================================================
             Step 2 — Configure
             ================================================================ -->
        <Grid x:Name="Step2Panel" Grid.Row="2" Margin="16,12" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <!-- Project name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Project name:"
                       VerticalAlignment="Center" Margin="0,0,8,8"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TbProjectName"
                     Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8"
                     Style="{StaticResource DialogTextBoxStyle}"
                     Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Parent directory -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Location:"
                       VerticalAlignment="Center" Margin="0,0,8,8"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TbParentDir"
                     Grid.Row="1" Grid.Column="1" Margin="0,0,4,8"
                     Style="{StaticResource DialogTextBoxStyle}"
                     Text="{Binding ParentDirectory, UpdateSourceTrigger=PropertyChanged}"/>
            <Button x:Name="BtnBrowse" Grid.Row="1" Grid.Column="2"
                    Content="Browse..."
                    Style="{StaticResource DialogButtonStyle}"
                    Width="76" Margin="0,0,0,8"
                    Click="OnBrowseDirectory"/>

            <!-- Language override -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Language:"
                       VerticalAlignment="Center" Margin="0,0,8,8"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                      ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}"
                      Background="{DynamicResource DockMenuBackgroundBrush}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      BorderBrush="{DynamicResource DockBorderBrush}"
                      Height="24" Margin="0,0,0,8"/>

            <!-- Project path preview -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Project path:"
                       VerticalAlignment="Center" Margin="0,0,8,8"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                       Text="{Binding ProjectPath}"
                       VerticalAlignment="Center" Margin="0,0,0,8"
                       FontSize="10" Opacity="0.7" TextWrapping="Wrap"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
        </Grid>

        <!-- ================================================================
             Step 3 — Optional Plugins
             ================================================================ -->
        <Grid x:Name="Step3Panel" Grid.Row="2" Margin="16,12" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0,0,0,8"
                       Text="Select optional plugins to include with this project:"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>

            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="1" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Background="{DynamicResource DockMenuBackgroundBrush}">
                    <ItemsControl x:Name="IcOptionalPlugins"
                                  ItemsSource="{Binding OptionalPlugins}"
                                  ItemTemplate="{StaticResource PluginItemTemplate}"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource DockBorderBrush}"/>

        <!-- ================================================================
             Button row
             ================================================================ -->
        <Grid Grid.Row="4" Margin="12,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="BtnBack" Content="← Back"
                        Style="{StaticResource DialogButtonStyle}"
                        IsEnabled="{Binding CanGoBack}"
                        Click="OnBack"/>
                <Button x:Name="BtnNext" Content="Next →"
                        Style="{StaticResource DialogButtonStyle}"
                        IsEnabled="{Binding CanGoNext}"
                        Click="OnNext"/>
                <Button x:Name="BtnFinish" Content="Finish"
                        Style="{StaticResource DialogButtonStyle}"
                        IsEnabled="{Binding CanFinish}"
                        Visibility="Collapsed"
                        Click="OnFinish"/>
                <Button Content="Cancel" IsCancel="True"
                        Style="{StaticResource DialogButtonStyle}"
                        Click="OnCancel"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

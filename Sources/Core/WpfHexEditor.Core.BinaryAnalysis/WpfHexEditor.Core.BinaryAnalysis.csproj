<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <UseWPF>false</UseWPF>
    <RootNamespace>WpfHexEditor.Core.BinaryAnalysis</RootNamespace>
    <AssemblyName>WpfHexEditor.Core.BinaryAnalysis</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>

    <!-- NuGet metadata -->
    <PackageId>WpfHexEditor.Core.BinaryAnalysis</PackageId>
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0</FileVersion>
    <Authors>Derek Tremblay;Claude Sonnet 4.6</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Product>WpfHexEditor.Core.BinaryAnalysis</Product>
    <Copyright>GNU Affero General Public License v3.0 - 2026</Copyright>
    <Description>
      Cross-platform binary analysis library — zero WPF dependency.

      Provides portable services for binary data analysis, export/import formats,
      statistics, template compilation and anomaly detection:
      • DataInspectorService — multi-format byte interpretation (int/float/date/network/GUID)
      • IntelHexService — Intel HEX (.hex) import/export
      • SRecordService — Motorola S-Record (.s19/.s28/.s37) import/export
      • DataStatisticsService — Shannon entropy, byte distribution, data type estimation
      • BinaryTemplateCompiler — C-like template compiler (010 Editor compatible)
      • AnomalyDetectionService — entropy-based anomaly and corruption detection

      Targets .NET 8.0+ (no Windows-specific APIs).
      Usable in WPF, WinForms, console, ASP.NET and cross-platform applications.
    </Description>
    <PackageTags>binary;hex;analysis;entropy;intel-hex;srec;s-record;data-inspector;template;anomaly;cross-platform</PackageTags>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorControl</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorControl</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

</Project>

<UserControl x:Class="WpfHexEditor.Core.Options.OptionsEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services"
             Background="{DynamicResource DockWindowBackgroundBrush}"
             KeyDown="OnControlKeyDown"
             Focusable="True">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.Docking.Wpf;component/Themes/PanelCommon.xaml"/>
                <!-- Options + common strings: enables DynamicResource in all child pages -->
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Chevron d'expansion style Visual Studio -->
            <Style x:Key="ExpandCollapseToggleStyle" TargetType="ToggleButton">
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="Width" Value="16"/>
                <Setter Property="Height" Value="16"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="Transparent" Width="16" Height="16">
                                <TextBlock x:Name="Arrow"
                                          Text="▶"
                                          FontSize="10"
                                          FontFamily="Segoe UI Symbol"
                                          Foreground="{DynamicResource DockMenuForegroundBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Arrow"
                                                               Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                               To="90"
                                                               Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Arrow"
                                                               Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                               To="0"
                                                               Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Arrow" Property="Foreground" Value="{DynamicResource SE_SelectedBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TreeViewItem amélioré style VS -->
            <Style TargetType="{x:Type TreeViewItem}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding"    Value="2,3"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type TreeViewItem}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Row: 3 px accent slot + content -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Full-width hover/selected background -->
                                    <Border x:Name="Bd"
                                            Grid.ColumnSpan="2"
                                            Background="Transparent"
                                            SnapsToDevicePixels="True"/>

                                    <!-- Left accent bar (visible only when selected) -->
                                    <Border x:Name="Accent"
                                            Grid.Column="0"
                                            Background="{DynamicResource SE_SelectionBorderBrush}"
                                            Visibility="Collapsed"
                                            SnapsToDevicePixels="True"/>

                                    <!-- Content column -->
                                    <Grid Grid.Column="1" Margin="{TemplateBinding Padding}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Expander chevron (only for items with children) -->
                                        <ToggleButton x:Name="Expander"
                                                    Grid.Column="0"
                                                    Style="{StaticResource ExpandCollapseToggleStyle}"
                                                    IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                    ClickMode="Press"
                                                    Visibility="Hidden"/>

                                        <ContentPresenter Grid.Column="1"
                                                        ContentSource="Header"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Margin="4,0,0,0"/>
                                    </Grid>
                                </Grid>

                                <ItemsPresenter x:Name="ItemsHost"
                                              Grid.Row="1"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <!-- Show expander only if item has children -->
                                <Trigger Property="HasItems" Value="True">
                                    <Setter TargetName="Expander" Property="Visibility" Value="Visible"/>
                                </Trigger>

                                <!-- Hide items when collapsed -->
                                <Trigger Property="IsExpanded" Value="False">
                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                </Trigger>

                                <!-- Selection: highlight + accent bar -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd"     Property="Background" Value="{DynamicResource SE_SelectedBrush}"/>
                                    <Setter TargetName="Accent" Property="Visibility" Value="Visible"/>
                                </Trigger>

                                <!-- Hover (only when not already selected) -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsSelected"  Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SE_HoverBrush}"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Corps -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar VS-style ─────────────────────────────────────────────── -->
        <Border Style="{StaticResource PanelToolbarStyle}">
            <DockPanel LastChildFill="True">

                <!-- Droite : bouton JSON + scope + filtre -->
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTip="{DynamicResource App_OptionsEditJsonToolTip}"
                        Click="OnEditJson"
                        Margin="4,0,4,0">
                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </Button>

                <ComboBox DockPanel.Dock="Right"
                          Width="170"
                          IsEnabled="False"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="{DynamicResource App_OptionsUserInstallation}" IsSelected="True"/>
                </ComboBox>

                <TextBlock DockPanel.Dock="Right"
                           Text="{DynamicResource App_OptionsAppliesToLabel}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="12,0,4,0"/>

                <ComboBox x:Name="FilterCombo"
                          DockPanel.Dock="Right"
                          Width="150"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          SelectionChanged="OnFilterChanged"/>

                <TextBlock DockPanel.Dock="Right"
                           Text="{DynamicResource App_OptionsFilterLabel}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="12,0,4,0"/>

                <!-- Gauche : search compound control (icon + input + clear) -->
                <Border DockPanel.Dock="Left"
                        BorderBrush="{DynamicResource DockBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Margin="4,3"
                        MinWidth="210">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search icon -->
                        <TextBlock Grid.Column="0"
                                   Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   Opacity="0.6"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>

                        <!-- Watermark placeholder -->
                        <TextBlock x:Name="SearchWatermark"
                                   Grid.Column="1"
                                   Text="{DynamicResource App_OptionsSearchPlaceholder}"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   Opacity="0.4"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="Visible"/>

                        <!-- Text input -->
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 TextChanged="OnSearchTextChanged"
                                 KeyDown="OnSearchBoxKeyDown"/>

                        <!-- Clear button -->
                        <Button x:Name="SearchClearBtn"
                                Grid.Column="2"
                                Width="16" Height="16"
                                Padding="0"
                                Visibility="Collapsed"
                                Style="{StaticResource PanelIconButtonStyle}"
                                Click="OnSearchClear"
                                ToolTip="{DynamicResource App_OptionsClearToolTip}">
                            <TextBlock Text="&#xE711;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"/>
                        </Button>
                    </Grid>
                </Border>

            </DockPanel>
        </Border>

        <!-- ── Corps : arbre gauche + page droite ──────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="320"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Arbre des pages -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <TreeView x:Name="PageTree"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              SelectedItemChanged="OnTreeSelectionChanged"/>

                    <!-- Shown when search yields no results -->
                    <TextBlock x:Name="NoResultsText"
                               Text="{DynamicResource App_OptionsNoResults}"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Opacity="0.5"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"
                          ShowsPreview="False"/>

            <!-- Zone d'affichage de la page active — no outer ScrollViewer so
                 pages with internal lists (e.g. KeyboardShortcutsPage DataGrid)
                 receive a constrained height and can scroll internally.
                 ContentControl (not ContentPresenter) is required so that
                 HorizontalContentAlignment=Stretch propagates a finite width
                 to the page, enabling star-column Grids inside slider rows. -->
            <Border Grid.Column="2"
                    Background="{DynamicResource DockWindowBackgroundBrush}">
                <ContentControl x:Name="PageHost" Margin="20,16"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Top"
                                Background="Transparent"
                                BorderThickness="0"/>
            </Border>
        </Grid>

    </Grid>
</UserControl>

// Description:
//     Options page for the Solution Explorer panel.
//     Covers: active document tracking, collapse state persistence,
//     contextual notifications, default sort/filter.
//
// Theme: PanelCommon.xaml + DynamicResource brushes (all themes)
// ==========================================================
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.SolutionExplorerOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── Navigation ────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource SolExp_NavigationSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckTrackActive"
                  Content="{StaticResource SolExp_TrackActive}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckPersistCollapse"
                  Content="{StaticResource SolExp_PersistCollapse}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Notifications ─────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource SolExp_NotificationsSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckNotifications"
                  Content="{StaticResource SolExp_ShowNotifications}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Default Sort ───────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource SolExp_DefaultsSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource SolExp_DefaultSortLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="SortCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="{StaticResource SolExp_SortNone}"         Tag="None"/>
                <ComboBoxItem Content="{StaticResource SolExp_SortName}"         Tag="Name"/>
                <ComboBoxItem Content="{StaticResource SolExp_SortType}"         Tag="Type"/>
                <ComboBoxItem Content="{StaticResource SolExp_SortDateModified}" Tag="DateModified"/>
                <ComboBoxItem Content="{StaticResource SolExp_SortSize}"         Tag="Size"/>
            </ComboBox>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource SolExp_DefaultFilterLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="FilterCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="{StaticResource SolExp_FilterAll}"      Tag="All"/>
                <ComboBoxItem Content="{StaticResource SolExp_FilterBinary}"   Tag="Binary"/>
                <ComboBoxItem Content="{StaticResource SolExp_FilterText}"     Tag="Text"/>
                <ComboBoxItem Content="{StaticResource SolExp_FilterImage}"    Tag="Image"/>
                <ComboBoxItem Content="{StaticResource SolExp_FilterLanguage}" Tag="Language"/>
            </ComboBox>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="WpfHexEditor.Core.Options.Pages.EnvironmentSavePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── Save Mode ──────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource EnvSave_SaveModeSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <RadioButton x:Name="RadioDirect"
                     Content="{StaticResource EnvSave_DirectMode}"
                     GroupName="SaveMode"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Margin="0,0,0,6"
                     Checked="OnSaveModeChanged"/>

        <RadioButton x:Name="RadioTracked"
                     Content="{StaticResource EnvSave_TrackedMode}"
                     GroupName="SaveMode"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Margin="0,0,0,0"
                     Checked="OnSaveModeChanged"/>

        <Separator Margin="0,16,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Auto-serialize ─────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource EnvSave_AutoSaveSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckAutoSerialize"
                  Content="{StaticResource EnvSave_AutoSerialize}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,10"
                  Checked="OnAutoSerializeChanged"
                  Unchecked="OnAutoSerializeChanged"/>

        <DockPanel Margin="20,0,0,0"
                   IsEnabled="{Binding IsChecked, ElementName=CheckAutoSerialize}">
            <TextBlock Text="{StaticResource EnvSave_IntervalLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="0,0,8,0"/>
            <TextBox x:Name="TxtInterval"
                     Width="60"
                     HorizontalAlignment="Left"
                     VerticalContentAlignment="Center"
                     LostFocus="OnIntervalLostFocus"/>
        </DockPanel>

        <Separator Margin="0,16,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Standalone Files ───────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource EnvSave_StandaloneSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <TextBlock Text="{StaticResource EnvSave_StandaloneNote}"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.7"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="HexEditorDirectSaveCheck"
                  Content="{StaticResource EnvSave_HexEditorDirect}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,4"
                  Checked="OnStandaloneSaveChanged"
                  Unchecked="OnStandaloneSaveChanged"/>

        <CheckBox x:Name="CodeEditorDirectSaveCheck"
                  Content="{StaticResource EnvSave_CodeEditorDirect}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,4"
                  Checked="OnStandaloneSaveChanged"
                  Unchecked="OnStandaloneSaveChanged"/>

        <CheckBox x:Name="TextEditorDirectSaveCheck"
                  Content="{StaticResource EnvSave_TextEditorDirect}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,4"
                  Checked="OnStandaloneSaveChanged"
                  Unchecked="OnStandaloneSaveChanged"/>

        <CheckBox x:Name="TblEditorDirectSaveCheck"
                  Content="{StaticResource EnvSave_TblEditorDirect}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,4"
                  Checked="OnStandaloneSaveChanged"
                  Unchecked="OnStandaloneSaveChanged"/>

        <CheckBox x:Name="ImageViewerDirectSaveCheck"
                  Content="{StaticResource EnvSave_ImageViewerDirect}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,4"
                  Checked="OnStandaloneSaveChanged"
                  Unchecked="OnStandaloneSaveChanged"/>

        <TextBlock Text="{StaticResource EnvSave_SaveAsNote}"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.6"
                   FontStyle="Italic"
                   Margin="0,6,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

//     Controls: save-before-build, verbosity, in-process,
//     parallel builds, output window behaviour.
//
// Theme: DynamicResource brushes (all themes)
// ==========================================================
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.BuildRunGeneralOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── General ───────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource BuildRun_GeneralSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckSaveBeforeBuild"
                  Content="{StaticResource BuildRun_SaveBeforeBuild}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource BuildRun_VerbosityLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="CbVerbosity" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="{StaticResource BuildRun_VerbQuiet}"      Tag="Quiet"/>
                <ComboBoxItem Content="{StaticResource BuildRun_VerbMinimal}"    Tag="Minimal"/>
                <ComboBoxItem Content="{StaticResource BuildRun_VerbNormal}"     Tag="Normal"/>
                <ComboBoxItem Content="{StaticResource BuildRun_VerbDetailed}"   Tag="Detailed"/>
                <ComboBoxItem Content="{StaticResource BuildRun_VerbDiagnostic}" Tag="Diagnostic"/>
            </ComboBox>
        </Grid>

        <CheckBox x:Name="CheckRunInProcess"
                  Content="{StaticResource BuildRun_RunInProcess}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource BuildRun_MaxParallelLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtMaxParallel" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Output Window ─────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource BuildRun_OutputSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckShowOnStart"
                  Content="{StaticResource BuildRun_ShowOnStart}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowOnError"
                  Content="{StaticResource BuildRun_ShowOnError}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Run ───────────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource BuildRun_RunSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource BuildRun_OnRunBuildErrorLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="CbOnRunBuildError" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="{StaticResource BuildRun_DoNotLaunch}" Tag="DoNotLaunch"/>
                <ComboBoxItem Content="{StaticResource BuildRun_Launch}"        Tag="Launch"/>
            </ComboBox>
        </Grid>

        <CheckBox x:Name="CheckShowOutputOnRun"
                  Content="{StaticResource BuildRun_ShowOutputOnRun}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

// Description:
//     Options page — Build & Run > General.
//     Controls: save-before-build, verbosity, in-process,
//     parallel builds, output window behaviour.
//
// Theme: DynamicResource brushes (all themes)
// ==========================================================
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.BuildRunGeneralOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── General ───────────────────────────────────────────────────── -->
        <TextBlock Text="General"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="CheckSaveBeforeBuild"
                  Content="Save all changes before building"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Build output verbosity:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="CbVerbosity" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="Quiet"      Tag="Quiet"/>
                <ComboBoxItem Content="Minimal"    Tag="Minimal"/>
                <ComboBoxItem Content="Normal"     Tag="Normal"/>
                <ComboBoxItem Content="Detailed"   Tag="Detailed"/>
                <ComboBoxItem Content="Diagnostic" Tag="Diagnostic"/>
            </ComboBox>
        </Grid>

        <CheckBox x:Name="CheckRunInProcess"
                  Content="Run MSBuild in-process (faster, recommended)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Max parallel project builds:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtMaxParallel" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Output Window ─────────────────────────────────────────────── -->
        <TextBlock Text="Output Window"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="CheckShowOnStart"
                  Content="Show Output window when build starts"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowOnError"
                  Content="Show Output window on build error"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Run ───────────────────────────────────────────────────────── -->
        <TextBlock Text="Run"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="On run, when build errors occur:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="CbOnRunBuildError" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="Do not launch" Tag="DoNotLaunch"/>
                <ComboBoxItem Content="Launch"        Tag="Launch"/>
            </ComboBox>
        </Grid>

        <CheckBox x:Name="CheckShowOutputOnRun"
                  Content="Show Output window when run starts"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<!--
    Project: WpfHexEditor.Core.Options
    File: Pages/MarketplaceOptionsPage.xaml
    Description:
        Options page for the Plugin Marketplace.
        Category: Plugins / Marketplace
        Sections: GitHub API, Auto-Update.
    Theme: DynamicResource brushes (all themes via PanelCommon.xaml).
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.MarketplaceOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

            <!-- ── GitHub API ─────────────────────────────────────────────── -->
            <TextBlock Text="{StaticResource Mkt_GitHubSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                       Foreground="{DynamicResource DockMenuForegroundBrush}" Opacity="0.8"
                       Text="{StaticResource Mkt_PatDescription}"/>

            <PasswordBox x:Name="BoxGitHubToken"
                         Height="26"
                         Background="{DynamicResource DockMenuBackgroundBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         Margin="0,0,0,4"
                         PasswordChanged="OnChanged"/>

            <TextBlock Text="{StaticResource Mkt_PatWarning}"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.55" FontSize="11" TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <!-- ── Auto-Update ────────────────────────────────────────────── -->
            <TextBlock Text="{StaticResource Mkt_AutoUpdateSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

            <CheckBox x:Name="CheckAutoUpdate"
                      Content="{StaticResource Mkt_AutoUpdate}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="0,0,0,10"
                      Checked="OnChanged"
                      Unchecked="OnChanged"/>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{StaticResource Mkt_UpdateIntervalLabel}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Opacity="0.8" VerticalAlignment="Center"/>

                <TextBox x:Name="BoxInterval"
                         Grid.Column="1"
                         Height="24"
                         Background="{DynamicResource DockMenuBackgroundBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         TextAlignment="Center"
                         TextChanged="OnChanged"/>
            </Grid>

            <TextBlock Text="{StaticResource Mkt_UpdateIntervalNote}"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.55" FontSize="11"
                       Margin="0,2,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="WpfHexEditor.Core.Options.Pages.TabGroupsOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

            <!-- ── Split Behavior ──────────────────────────────────────────── -->
            <TextBlock Text="{StaticResource TabGroups_SplitSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

            <CheckBox x:Name="ChkEnforceEqualSize"
                      Content="{StaticResource TabGroups_EnforceEqualSize}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="0,0,0,8"
                      Checked="OnChanged" Unchecked="OnChanged"/>

            <DockPanel Margin="0,0,0,6">
                <TextBlock Text="{StaticResource TabGroups_MinWidthLabel}"
                           Width="200"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="0,0,8,0"/>
                <TextBox x:Name="TxtMinWidth"
                         Width="70"
                         HorizontalAlignment="Left"
                         VerticalContentAlignment="Center"
                         LostFocus="OnChanged"/>
            </DockPanel>

            <DockPanel Margin="0,0,0,0">
                <TextBlock Text="{StaticResource TabGroups_MinHeightLabel}"
                           Width="200"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="0,0,8,0"/>
                <TextBox x:Name="TxtMinHeight"
                         Width="70"
                         HorizontalAlignment="Left"
                         VerticalContentAlignment="Center"
                         LostFocus="OnChanged"/>
            </DockPanel>

            <Separator Margin="0,16,0,16" Background="{DynamicResource DockBorderBrush}"/>

            <!-- ── Visual ──────────────────────────────────────────────────── -->
            <TextBlock Text="{StaticResource TabGroups_VisualSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

            <CheckBox x:Name="ChkShowGroupBadge"
                      Content="{StaticResource TabGroups_ShowGroupBadge}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="0,0,0,8"
                      Checked="OnChanged" Unchecked="OnChanged"/>

            <Separator Margin="0,16,0,16" Background="{DynamicResource DockBorderBrush}"/>

            <!-- ── Persistence ─────────────────────────────────────────────── -->
            <TextBlock Text="{StaticResource TabGroups_PersistSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

            <CheckBox x:Name="ChkPersistLayout"
                      Content="{StaticResource TabGroups_PersistLayout}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="0,0,0,8"
                      Checked="OnChanged" Unchecked="OnChanged"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

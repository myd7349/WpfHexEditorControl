<UserControl x:Class="WpfHexEditor.Core.Options.Pages.EnvironmentGeneralPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── Apparence ──────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource EnvGeneral_AppearanceSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource EnvGeneral_ColorThemeLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="ThemeCombo" Grid.Column="1"
                      SelectionChanged="OnThemeSelectionChanged"/>
        </Grid>

        <TextBlock Text="{StaticResource EnvGeneral_ThemePreviewNote}"
                   FontStyle="Italic" FontSize="11"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.65"
                   Margin="0,4,0,0"/>

        <!-- ── Language ──────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource EnvGeneral_LanguageSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource EnvGeneral_IdeLanguageLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="LanguageCombo" Grid.Column="1"
                      SelectionChanged="OnLanguageSelectionChanged"/>
        </Grid>

        <TextBlock Text="{StaticResource EnvGeneral_LanguageRestartNote}"
                   FontStyle="Italic" FontSize="11"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.65"
                   Margin="0,4,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

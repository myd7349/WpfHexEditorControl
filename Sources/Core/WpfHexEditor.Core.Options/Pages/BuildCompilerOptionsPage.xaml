<UserControl x:Class="WpfHexEditor.Core.Options.Pages.BuildCompilerOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── C# / .NET ─────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource BuildCompiler_CSharpSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckNullableErrors"
                  Content="{StaticResource BuildCompiler_NullableCheck}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckImplicitUsings"
                  Content="{StaticResource BuildCompiler_ImplicitUsings}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckGenerateDocs"
                  Content="{StaticResource BuildCompiler_GenerateDocs}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Warnings ──────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource BuildCompiler_WarningsSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource BuildCompiler_WarnLevelLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="CbWarnLevel" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="0" Tag="0"/>
                <ComboBoxItem Content="1" Tag="1"/>
                <ComboBoxItem Content="2" Tag="2"/>
                <ComboBoxItem Content="3" Tag="3"/>
                <ComboBoxItem Content="4" Tag="4"/>
                <ComboBoxItem Content="5" Tag="5"/>
            </ComboBox>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

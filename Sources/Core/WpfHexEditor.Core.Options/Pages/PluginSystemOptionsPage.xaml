<UserControl x:Class="WpfHexEditor.Core.Options.Pages.PluginSystemOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cp="clr-namespace:WpfHexEditor.ColorPicker.Controls;assembly=WpfHexEditor.ColorPicker"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── General ───────────────────────────────────────────────────────── -->
        <TextBlock Text="General"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,12"/>

        <CheckBox x:Name="CheckAutoLoad"
                  Content="Automatically load all discovered plugins at startup"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,10"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <TextBlock Text="Additional plugins directory (leave empty to use %AppData%\WpfHexEditor\Plugins):"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.8"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TextPluginsDir"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     Margin="0,0,4,0"
                     VerticalContentAlignment="Center"
                     TextChanged="OnTextChanged"/>
            <Button Grid.Column="1"
                    Content="Browse…"
                    Padding="8,3"
                    Click="OnBrowsePluginsDir"
                    Background="{DynamicResource Panel_ToolbarBrush}"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"/>
        </Grid>

        <Separator Margin="0,8,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Watchdog ───────────────────────────────────────────────────────── -->
        <TextBlock Text="Watchdog"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,12"/>

        <CheckBox x:Name="CheckEnableWatchdog"
                  Content="Enable plugin watchdog (monitors call timeouts)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,10"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Watchdog timeout (seconds):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextWatchdogTimeout" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <Separator Margin="0,8,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Diagnostics sampling ───────────────────────────────────────────── -->
        <TextBlock Text="Diagnostics &amp; Sampling"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,12"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Diagnostic sampling interval (seconds):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextDiagnosticSampling" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <TextBlock Text="Drives the Plugin Monitor CPU/Memory chart refresh rate."
                   FontSize="11" Opacity="0.65"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,4"/>

        <Separator Margin="0,8,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Slow-Plugin Detection ──────────────────────────────────────────── -->
        <TextBlock Text="Slow-Plugin Detection"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,12"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Monitoring interval (seconds):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextMonitoringInterval" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Response time threshold (ms):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextResponseTime" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="CPU threshold (%):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextCpuThreshold" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <Separator Margin="0,8,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Memory Alert Thresholds ─────────────────────────────────────── -->
        <TextBlock Text="Memory Alert Thresholds"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,12"/>

        <CheckBox x:Name="CheckEnableMemoryAlerts"
                  Content="Enable memory usage alerts and badges"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,10"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowMemoryColorGradation"
                  Content="Show color gradation in monitors (green/yellow/orange/red)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,10"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="⚠️ Warning threshold (yellow):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextMemoryWarningThreshold" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
            <TextBlock Grid.Column="2" Text=" MB"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="4,0,0,0"/>
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🟠 High threshold (orange):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextMemoryHighThreshold" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
            <TextBlock Grid.Column="2" Text=" MB"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="4,0,0,0"/>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🔴 Critical threshold (red):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextMemoryCriticalThreshold" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
            <TextBlock Grid.Column="2" Text=" MB"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="4,0,0,0"/>
        </Grid>

        <TextBlock Text="Note: Thresholds should be in ascending order (Warning &lt; High &lt; Critical)."
                   FontSize="11" Opacity="0.65"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"/>

        <Separator Margin="0,8,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Memory Alert Colors ─────────────────────────────────────────── -->
        <TextBlock Text="Memory Alert Colors"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,12"/>

        <TextBlock Text="Customize badge colors for each memory threshold level."
                   FontSize="11" Opacity="0.65"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,12"/>

        <!-- Normal (Green) -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🟢 Normal threshold:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker Grid.Column="1"
                            x:Name="PickerMemoryNormal"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Warning (Yellow) -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🟡 Warning threshold:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker Grid.Column="1"
                            x:Name="PickerMemoryWarning"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- High (Orange) -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🟠 High threshold:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker Grid.Column="1"
                            x:Name="PickerMemoryHigh"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Critical (Red) -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🔴 Critical threshold:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker Grid.Column="1"
                            x:Name="PickerMemoryCritical"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Reset button -->
        <Button Content="Reset to Default Colors"
                Margin="0,8,0,0"
                Padding="8,3"
                Click="OnResetMemoryColors"
                Background="{DynamicResource Panel_ToolbarBrush}"
                Foreground="{DynamicResource DockMenuForegroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                HorizontalAlignment="Left"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

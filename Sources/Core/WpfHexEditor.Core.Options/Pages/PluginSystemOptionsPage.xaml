<UserControl x:Class="WpfHexEditor.Core.Options.Pages.PluginSystemOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cp="clr-namespace:WpfHexEditor.ColorPicker.Controls;assembly=WpfHexEditor.ColorPicker"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── General ───────────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource Plugin_GeneralSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckAutoLoad"
                  Content="{StaticResource Plugin_AutoLoad}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,10"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <TextBlock Text="{StaticResource Plugin_PluginsDirNote}"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.8"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TextPluginsDir"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     Margin="0,0,4,0"
                     VerticalContentAlignment="Center"
                     TextChanged="OnTextChanged"/>
            <Button Grid.Column="1"
                    Content="{StaticResource Plugin_Browse}"
                    Padding="8,3"
                    Click="OnBrowsePluginsDir"
                    Background="{DynamicResource Panel_ToolbarBrush}"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"/>
        </Grid>

        <Separator Margin="0,8,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Watchdog ───────────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource Plugin_WatchdogSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckEnableWatchdog"
                  Content="{StaticResource Plugin_EnableWatchdog}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,10"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_WatchdogTimeoutLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextWatchdogTimeout" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <Separator Margin="0,8,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Diagnostics sampling ───────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource Plugin_DiagnosticsSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_DiagSamplingLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextDiagnosticSampling" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <TextBlock Text="{StaticResource Plugin_DiagNote}"
                   FontSize="11" Opacity="0.65"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,4"/>

        <Separator Margin="0,8,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Slow-Plugin Detection ──────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource Plugin_SlowDetectionSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_MonitorIntervalLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextMonitoringInterval" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_ResponseTimeLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextResponseTime" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_CpuThresholdLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextCpuThreshold" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <Separator Margin="0,8,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Memory Alert Thresholds ─────────────────────────────────────── -->
        <TextBlock Text="{StaticResource Plugin_MemoryAlertSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckEnableMemoryAlerts"
                  Content="{StaticResource Plugin_EnableMemoryAlerts}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,10"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowMemoryColorGradation"
                  Content="{StaticResource Plugin_ShowColorGradation}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,10"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_MemWarningLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextMemoryWarningThreshold" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
            <TextBlock Grid.Column="2" Text="{StaticResource Plugin_MB}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="4,0,0,0"/>
        </Grid>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_MemHighLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextMemoryHighThreshold" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
            <TextBlock Grid.Column="2" Text="{StaticResource Plugin_MB}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="4,0,0,0"/>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_MemCriticalLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextMemoryCriticalThreshold" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
            <TextBlock Grid.Column="2" Text="{StaticResource Plugin_MB}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="4,0,0,0"/>
        </Grid>

        <TextBlock Text="{StaticResource Plugin_MemThresholdNote}"
                   FontSize="11" Opacity="0.65"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"/>

        <Separator Margin="0,8,0,12" Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Memory Alert Colors ─────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource Plugin_MemColorSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <TextBlock Text="{StaticResource Plugin_MemColorNote}"
                   FontSize="11" Opacity="0.65"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,12"/>

        <!-- Normal (Green) -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_MemNormalColor}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker Grid.Column="1"
                            x:Name="PickerMemoryNormal"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Warning (Yellow) -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_MemWarningColor}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker Grid.Column="1"
                            x:Name="PickerMemoryWarning"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- High (Orange) -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_MemHighColor}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker Grid.Column="1"
                            x:Name="PickerMemoryHigh"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Critical (Red) -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Plugin_MemCriticalColor}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker Grid.Column="1"
                            x:Name="PickerMemoryCritical"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Reset button -->
        <Button Content="{StaticResource Plugin_ResetColors}"
                Margin="0,8,0,0"
                Padding="8,3"
                Click="OnResetMemoryColors"
                Background="{DynamicResource Panel_ToolbarBrush}"
                Foreground="{DynamicResource DockMenuForegroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                HorizontalAlignment="Left"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

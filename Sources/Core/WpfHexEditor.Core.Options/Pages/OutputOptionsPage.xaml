<!--
    Project: WpfHexEditor.Core.Options
    File: OutputOptionsPage.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Theme: DynamicResource brushes (all themes via PanelCommon.xaml)
    Description: Options page for Output panel log-level colours.
                 Accessible via Options > Environment > Output.
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.OutputOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cp="clr-namespace:WpfHexEditor.ColorPicker.Controls;assembly=WpfHexEditor.ColorPicker"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── Log-Level Colours ──────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource Output_Section}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <TextBlock Text="{StaticResource Output_Note}"
                   FontSize="11" Opacity="0.65"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- WARN -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Output_WarnLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker x:Name="PickerWarn"
                            Grid.Column="1"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- ERROR -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Output_ErrorLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker x:Name="PickerError"
                            Grid.Column="1"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- DEBUG -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Output_DebugLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker x:Name="PickerDebug"
                            Grid.Column="1"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- SUCCESS -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource Output_SuccessLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker x:Name="PickerSuccess"
                            Grid.Column="1"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Reset button -->
        <Button Content="{StaticResource Output_ResetColors}"
                Margin="0,8,0,0"
                Padding="8,3"
                Click="OnResetColours"
                Background="{DynamicResource Panel_ToolbarBrush}"
                Foreground="{DynamicResource DockMenuForegroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                HorizontalAlignment="Left"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

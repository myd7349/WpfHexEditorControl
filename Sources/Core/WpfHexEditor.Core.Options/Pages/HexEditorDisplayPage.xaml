<UserControl x:Class="WpfHexEditor.Core.Options.Pages.HexEditorDisplayPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <TextBlock Text="{StaticResource HexDisplay_DisplaySection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <!-- Bytes par ligne -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource HexDisplay_BytesPerLineLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="BytePerLineCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="8"   Tag="8"/>
                <ComboBoxItem Content="16"  Tag="16"/>
                <ComboBoxItem Content="32"  Tag="32"/>
                <ComboBoxItem Content="64"  Tag="64"/>
                <ComboBoxItem Content="128" Tag="128"/>
            </ComboBox>
        </Grid>

        <!-- Colonnes visibles -->
        <CheckBox x:Name="CheckShowOffset"
                  Content="{StaticResource HexDisplay_ShowOffset}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowAscii"
                  Content="{StaticResource HexDisplay_ShowAscii}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,10"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <!-- Mouse wheel speed -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource HexDisplay_MouseWheelLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="MouseWheelSpeedCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Byte tooltip mode -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource HexDisplay_ByteTooltipLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="ByteToolTipModeCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <Separator Margin="0,0,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <TextBlock Text="{StaticResource HexDisplay_FormatSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <!-- Data string visual -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource HexDisplay_ValueFormatLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="DataVisualCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Offset string visual -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource HexDisplay_OffsetFormatLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="OffsetVisualCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Byte grouping -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource HexDisplay_ByteGroupingLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="ByteGroupingCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- Byte spacer position -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource HexDisplay_SpacerPositionLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="SpacerPositionCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <Separator Margin="0,8,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <TextBlock Text="{StaticResource HexDisplay_ScrollMarkersSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckShowBookmarkMarkers"
                  Content="{StaticResource HexDisplay_ShowBookmarkMarkers}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowModifiedMarkers"
                  Content="{StaticResource HexDisplay_ShowModifiedMarkers}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowInsertedMarkers"
                  Content="{StaticResource HexDisplay_ShowInsertedMarkers}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowDeletedMarkers"
                  Content="{StaticResource HexDisplay_ShowDeletedMarkers}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowSearchResultMarkers"
                  Content="{StaticResource HexDisplay_ShowSearchResultMarkers}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,0"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,16,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <TextBlock Text="{StaticResource HexDisplay_ColumnRowSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckShowColumnHighlight"
                  Content="{StaticResource HexDisplay_ShowColumnHighlight}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowAsciiColumnHighlight"
                  Content="{StaticResource HexDisplay_ShowAsciiColumnHighlight}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowRowHighlight"
                  Content="{StaticResource HexDisplay_ShowRowHighlight}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowSplitToggleButton"
                  Content="{StaticResource HexDisplay_ShowSplitToggleButton}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,0"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

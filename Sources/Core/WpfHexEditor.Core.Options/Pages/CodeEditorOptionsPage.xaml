<!--
// ==========================================================
// Project: WpfHexEditor.Core.Options
// File: CodeEditorOptionsPage.xaml
// Author: Auto
// Created: 2026-03-06
// Description:
//     Options page for the CodeEditor (full-featured, VS-like).
//     Covers: font, indentation, features (SmartComplete, line numbers,
//     zoom), .whchg changeset toggle, and syntax colour overrides.
//
// Theme: PanelCommon.xaml + DynamicResource brushes (all themes)
// ==========================================================
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.CodeEditorOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cp="clr-namespace:WpfHexEditor.ColorPicker.Controls;assembly=WpfHexEditor.ColorPicker"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── Font ──────────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource CodeOpt_FontSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_FontFamilyLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="FontFamilyCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="Consolas"        Tag="Consolas"/>
                <ComboBoxItem Content="Courier New"     Tag="Courier New"/>
                <ComboBoxItem Content="Lucida Console"  Tag="Lucida Console"/>
                <ComboBoxItem Content="Cascadia Code"   Tag="Cascadia Code"/>
                <ComboBoxItem Content="Fira Code"       Tag="Fira Code"/>
                <ComboBoxItem Content="JetBrains Mono"  Tag="JetBrains Mono"/>
            </ComboBox>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_FontSizeLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtFontSize" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Indentation ───────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource CodeOpt_IndentSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_IndentSizeLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtIndentSize" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <CheckBox x:Name="CheckUseSpaces"
                  Content="{StaticResource CodeOpt_UseSpaces}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Features ──────────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource CodeOpt_FeaturesSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckSmartComplete"
                  Content="{StaticResource CodeOpt_SmartComplete}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckLineNumbers"
                  Content="{StaticResource CodeOpt_ShowLineNumbers}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckHighlightLine"
                  Content="{StaticResource CodeOpt_HighlightCurrentLine}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowRefreshRate"
                  Content="{StaticResource CodeOpt_ShowRefreshRate}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckFoldDoubleClick"
                  Content="{StaticResource CodeOpt_FoldDoubleClick}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckWordWrap"
                  Content="{StaticResource CodeOpt_WordWrap}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckClickableLinks"
                  Content="{StaticResource CodeOpt_ClickableLinks}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckClickableEmails"
                  Content="{StaticResource CodeOpt_ClickableEmails}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_DefaultZoomLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtZoom" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <!-- Mouse wheel speed (lines per notch — same model as HexEditor) -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_MouseWheelLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="MouseWheelCombo"
                      Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- ── End-of-Block Hint ─────────────────────────────────────────── -->
        <CheckBox x:Name="CheckEndBlockHint"
                  Content="{StaticResource CodeOpt_EndBlockHint}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LblEndBlockDelay"
                       Text="{StaticResource CodeOpt_HoverDelayLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtEndBlockDelay" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Changeset (.whchg) ─────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource CodeOpt_ChangesetSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckChangeset"
                  Content="{StaticResource CodeOpt_TrackEdits}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,4"
                  IsEnabled="False"
                  ToolTip="{StaticResource Opt_NotYetImplemented}"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <TextBlock Text="{StaticResource Opt_ComingSoon}"
                   FontSize="11"
                   FontStyle="Italic"
                   Opacity="0.55"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="20,0,0,8"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Syntax colours ────────────────────────────────────────────── -->
        <TextBlock Text="{StaticResource CodeOpt_SyntaxSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <TextBlock Text="{StaticResource CodeOpt_SyntaxNote}"
                   FontSize="11"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.65"
                   Margin="0,0,0,12"/>

        <!-- Background -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_Background}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkBg" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpBg" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Foreground -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_Foreground}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkFg" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpFg" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Keyword -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_Keyword}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkKw" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpKw" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- String -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_String}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkStr" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpStr" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Comment -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_Comment}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkCmt" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpCmt" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Number -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_Number}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkNum" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpNum" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Type -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_Type}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkType" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpType" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Identifier -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_Identifier}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkId" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpId" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Operator -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_Operator}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkOp" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpOp" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Bracket -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_Bracket}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkBracket" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpBracket" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Attribute -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource CodeOpt_Attribute}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkAttr" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpAttr" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<!--
// ==========================================================
// Project: WpfHexEditor.Core.Options
// File: CodeEditorOptionsPage.xaml
// Author: Auto
// Created: 2026-03-06
// Description:
//     Options page for the CodeEditor (full-featured, VS-like).
//     Covers: font, indentation, features (SmartComplete, line numbers,
//     zoom), .whchg changeset toggle, and syntax colour overrides.
//
// Theme: PanelCommon.xaml + DynamicResource brushes (all themes)
// ==========================================================
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.CodeEditorOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cp="clr-namespace:WpfHexEditor.ColorPicker.Controls;assembly=WpfHexEditor.ColorPicker"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── Font ──────────────────────────────────────────────────────── -->
        <TextBlock Text="Font"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Font family:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="FontFamilyCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged">
                <ComboBoxItem Content="Consolas"        Tag="Consolas"/>
                <ComboBoxItem Content="Courier New"     Tag="Courier New"/>
                <ComboBoxItem Content="Lucida Console"  Tag="Lucida Console"/>
                <ComboBoxItem Content="Cascadia Code"   Tag="Cascadia Code"/>
                <ComboBoxItem Content="Fira Code"       Tag="Fira Code"/>
                <ComboBoxItem Content="JetBrains Mono"  Tag="JetBrains Mono"/>
            </ComboBox>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Font size (pt):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtFontSize" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Indentation ───────────────────────────────────────────────── -->
        <TextBlock Text="Indentation"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Indent size:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtIndentSize" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <CheckBox x:Name="CheckUseSpaces"
                  Content="Insert spaces instead of tab characters"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Features ──────────────────────────────────────────────────── -->
        <TextBlock Text="Features"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="CheckSmartComplete"
                  Content="Enable SmartComplete auto-complete"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckLineNumbers"
                  Content="Show line numbers"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckHighlightLine"
                  Content="Highlight current line"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckShowRefreshRate"
                  Content="Show refresh rate in status bar (render frame time)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckFoldDoubleClick"
                  Content="Toggle fold regions on double-click"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckWordWrap"
                  Content="Word Wrap (Alt+Z)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Default zoom (%):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtZoom" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <!-- Mouse wheel speed (lines per notch — same model as HexEditor) -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Mouse wheel speed:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="MouseWheelCombo"
                      Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        <!-- ── End-of-Block Hint ─────────────────────────────────────────── -->
        <CheckBox x:Name="CheckEndBlockHint"
                  Content="Show end-of-block hint popup (hover over }, #endregion, &lt;/Tag&gt;)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LblEndBlockDelay"
                       Text="Hover delay (ms):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TxtEndBlockDelay" Grid.Column="1"
                     VerticalContentAlignment="Center"
                     LostFocus="OnTextLostFocus"/>
        </Grid>

        <!-- ── Smart editing ─────────────────────────────────────────────── -->
        <TextBlock Text="Smart editing"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,12,0,10"/>

        <CheckBox x:Name="CheckAutoBrackets"
                  Content="Auto-close brackets, braces and parentheses"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckAutoQuotes"
                  Content="Auto-close quotes"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckSkipOverClose"
                  Content="Skip over closing character (avoids duplicate closing bracket/quote)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckWrapSelection"
                  Content="Wrap selection in pairs (type opening bracket/quote over a selection)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Changeset (.whchg) ─────────────────────────────────────────── -->
        <TextBlock Text="Changeset (.whchg)"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="CheckChangeset"
                  Content="Track edits in .whchg companion file (requires Tracked save mode)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  IsEnabled="False"
                  ToolTip="Not yet implemented"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Syntax colours ────────────────────────────────────────────── -->
        <TextBlock Text="Syntax colour overrides"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,4"/>

        <TextBlock Text="Enable a colour to override the active theme's default."
                   FontSize="11"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.65"
                   Margin="0,0,0,12"/>

        <!-- Background -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Background:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkBg" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpBg" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Foreground -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Foreground:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkFg" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpFg" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Keyword -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Keyword:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkKw" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpKw" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- String -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="String:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkStr" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpStr" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Comment -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Comment:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkCmt" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpCmt" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Number -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Number:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkNum" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpNum" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Type -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Type:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkType" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpType" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Identifier -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Identifier:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkId" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpId" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Operator -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Operator:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkOp" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpOp" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Bracket -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Bracket:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkBracket" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpBracket" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Attribute -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Attribute:"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <CheckBox x:Name="ChkAttr" Grid.Column="1"
                      VerticalAlignment="Center"
                      Checked="OnColorCheckChanged"
                      Unchecked="OnColorCheckChanged"/>
            <cp:ColorPicker x:Name="CpAttr" Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            ShowAlphaChannel="False"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

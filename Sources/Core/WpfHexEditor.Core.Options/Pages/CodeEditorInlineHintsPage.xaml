<!--
// ==========================================================
// Project: WpfHexEditor.Core.Options
// File: CodeEditorInlineHintsPage.xaml
// Author: Auto
// Created: 2026-03-18
// Description:
//     Options page for CodeEditor Inline Hints feature.
//     Master enable/disable toggle + per-symbol-kind checkboxes.
//     All kinds enabled by default.
//
// Theme: DynamicResource brushes only (all 8 themes).
// ==========================================================
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.CodeEditorInlineHintsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">


    <UserControl.Resources>
        <!-- Themed text button — proper IsMouseOver/IsPressed triggers using IDE palette. -->
        <Style x:Key="OptionsTextButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource Panel_ToolbarBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <!-- ── Inline Hints ──────────────────────────────────────────────────── -->
        <TextBlock Text="{DynamicResource CodeInlineHints_Section}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckInlineHintsEnabled"
                  Content="{DynamicResource CodeInlineHints_EnableHints}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource CodeInlineHints_SourceLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="0,0,8,0"/>
            <ComboBox x:Name="CboSource" Width="240"
                      SelectionChanged="OnSourceChanged">
                <ComboBoxItem Content="{DynamicResource CodeInlineHints_SourceAuto}" Tag="0"/>
                <ComboBoxItem Content="{DynamicResource CodeInlineHints_SourceRoslyn}" Tag="1"/>
                <ComboBoxItem Content="{DynamicResource CodeInlineHints_SourceRegex}" Tag="2"/>
            </ComboBox>
        </StackPanel>

        <!-- ── Roslyn Semantic Hints ────────────────────────────────────────── -->
        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <TextBlock Text="{DynamicResource CodeInlineHints_RoslynSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,0,0,6"/>

        <TextBlock Text="{DynamicResource CodeInlineHints_RoslynNote}"
                   FontSize="11"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.65"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <CheckBox x:Name="ChkShowVarTypeHints"
                  Content="{DynamicResource CodeInlineHints_ShowVarType}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,6"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="ChkShowLambdaReturnTypeHints"
                  Content="{DynamicResource CodeInlineHints_ShowLambdaReturn}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,12"
                  Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

        <!-- ── Symbol Kinds ──────────────────────────────────────────────────── -->
        <TextBlock Text="{DynamicResource CodeInlineHints_KindsSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <TextBlock Text="{DynamicResource CodeInlineHints_KindsNote}"
                   FontSize="11"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.65"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- Kind panel — disabled when master toggle is off -->
        <StackPanel x:Name="KindPanel"
                    IsEnabled="{Binding IsChecked, ElementName=CheckInlineHintsEnabled}">

            <!-- Types sub-group -->
            <TextBlock Text="{DynamicResource CodeInlineHints_TypesGroup}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.75"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkClass"
                      Content="{DynamicResource CodeInlineHints_Class}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkInterface"
                      Content="{DynamicResource CodeInlineHints_Interface}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkStruct"
                      Content="{DynamicResource CodeInlineHints_Struct}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkEnum"
                      Content="{DynamicResource CodeInlineHints_Enum}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkRecord"
                      Content="{DynamicResource CodeInlineHints_Record}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkDelegate"
                      Content="{DynamicResource CodeInlineHints_Delegate}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,12"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <!-- Members sub-group -->
            <TextBlock Text="{DynamicResource CodeInlineHints_MembersGroup}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.75"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkMethod"
                      Content="{DynamicResource CodeInlineHints_Method}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkConstructor"
                      Content="{DynamicResource CodeInlineHints_Constructor}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkProperty"
                      Content="{DynamicResource CodeInlineHints_Property}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkIndexer"
                      Content="{DynamicResource CodeInlineHints_Indexer}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkField"
                      Content="{DynamicResource CodeInlineHints_Field}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkEvent"
                      Content="{DynamicResource CodeInlineHints_Event}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,12"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <!-- Quick-pick row -->
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnSelectAll"
                        Content="{DynamicResource CodeInlineHints_SelectAll}"
                        Style="{StaticResource OptionsTextButtonStyle}"
                        Click="OnSelectAll"/>
                <Button x:Name="BtnSelectNone"
                        Content="{DynamicResource CodeInlineHints_SelectNone}"
                        Margin="8,0,0,0"
                        Style="{StaticResource OptionsTextButtonStyle}"
                        Click="OnSelectNone"/>
            </StackPanel>

        </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="WpfHexEditor.Core.Options.Pages.HexEditorBehaviorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

        <TextBlock Text="{StaticResource HexBehavior_Section}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                   Margin="0,16,0,6"/>

        <CheckBox x:Name="CheckAllowAutoHighLight"
                  Content="{StaticResource HexBehavior_AllowAutoHighLight}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckAllowAutoSelectDoubleClick"
                  Content="{StaticResource HexBehavior_AllowAutoSelectDoubleClick}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckAllowContextMenu"
                  Content="{StaticResource HexBehavior_AllowContextMenu}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckAllowDeleteByte"
                  Content="{StaticResource HexBehavior_AllowDeleteByte}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckAllowExtend"
                  Content="{StaticResource HexBehavior_AllowExtend}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <CheckBox x:Name="CheckFileDroppingConfirmation"
                  Content="{StaticResource HexBehavior_FileDroppingConfirmation}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,16"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,0,0,16"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- Preload mode -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{StaticResource HexBehavior_PreloadModeLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <ComboBox x:Name="PreloadModeCombo" Grid.Column="1"
                      SelectionChanged="OnComboChanged"/>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

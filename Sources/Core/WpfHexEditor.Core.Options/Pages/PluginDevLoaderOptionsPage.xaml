<!--
    Project: WpfHexEditor.Core.Options
    File: Pages/PluginDevLoaderOptionsPage.xaml
    Description:
        Options page for Plugin Dev Loader — watched folders and debounce config.
        Category: Plugin System / Development
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.PluginDevLoaderOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             xmlns:optSvc="clr-namespace:WpfHexEditor.Core.Options.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <optSvc:OptionsLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

            <!-- ── General ───────────────────────────────────────────────────────── -->
            <TextBlock Text="{StaticResource PluginDev_Section}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                       Margin="0,16,0,6"/>

            <CheckBox x:Name="ChkEnableDevLoader"
                      Content="{StaticResource PluginDev_Enable}"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="0,0,0,10"
                      Checked="OnChanged" Unchecked="OnChanged"/>

            <!-- ── Debounce ───────────────────────────────────────────────────────── -->
            <TextBlock Text="{StaticResource PluginDev_DebounceSection}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                       Margin="0,12,0,6"/>

            <TextBlock Text="{StaticResource PluginDev_DebounceNote}"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.8" Margin="0,0,0,4"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtDebounceMs"
                         Grid.Column="0"
                         Background="{DynamicResource Opt_InputBackgroundBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         Padding="4,3"
                         TextChanged="OnChanged"/>
                <TextBlock Grid.Column="1" Text="{StaticResource PluginDev_DebounceDefault}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Opacity="0.6" VerticalAlignment="Center" Margin="8,0"/>
            </Grid>

            <!-- ── Watched Folders ───────────────────────────────────────────────── -->
            <TextBlock Text="{StaticResource PluginDev_WatchedSection}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                       Margin="0,12,0,6"/>

            <TextBlock Text="{StaticResource PluginDev_WatchedNote}"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.8" TextWrapping="Wrap"
                       Margin="0,0,0,4"/>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtWatchedFolders"
                         Grid.Column="0"
                         Background="{DynamicResource Opt_InputBackgroundBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         Padding="4,3"
                         TextChanged="OnChanged"/>
                <Button x:Name="BtnBrowse"
                        Grid.Column="1"
                        Content="{StaticResource PluginDev_Browse}"
                        Margin="6,0,0,0"
                        Padding="8,3"
                        Background="{DynamicResource Opt_InputBackgroundBrush}"
                        Foreground="{DynamicResource DockMenuForegroundBrush}"
                        BorderBrush="{DynamicResource DockBorderBrush}"
                        Click="OnBrowse"/>
            </Grid>

            <TextBlock Text="{StaticResource PluginDev_Example}"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.5" FontSize="11" TextWrapping="Wrap"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

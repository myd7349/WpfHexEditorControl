<!--
    Project: WpfHexEditor.Core.Options
    File: Pages/PluginDevLoaderOptionsPage.xaml
    Description:
        Options page for Plugin Dev Loader — watched folders and debounce config.
        Category: Plugin System / Development
-->
<UserControl x:Class="WpfHexEditor.Core.Options.Pages.PluginDevLoaderOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,16">

            <!-- ── General ───────────────────────────────────────────────────────── -->
            <TextBlock Text="PLUGIN DEV LOADER"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                       Margin="0,16,0,6"/>

            <CheckBox x:Name="ChkEnableDevLoader"
                      Content="Enable Plugin Dev Loader (Watch Mode available in Plugin Manager)"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="0,0,0,10"
                      Checked="OnChanged" Unchecked="OnChanged"/>

            <!-- ── Debounce ───────────────────────────────────────────────────────── -->
            <TextBlock Text="DEBOUNCE"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                       Margin="0,12,0,6"/>

            <TextBlock Text="Delay before triggering hot-reload after a file change (ms):"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.8" Margin="0,0,0,4"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtDebounceMs"
                         Grid.Column="0"
                         Background="{DynamicResource Opt_InputBackgroundBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         Padding="4,3"
                         TextChanged="OnChanged"/>
                <TextBlock Grid.Column="1" Text="ms  (default: 500)"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Opacity="0.6" VerticalAlignment="Center" Margin="8,0"/>
            </Grid>

            <!-- ── Watched Folders ───────────────────────────────────────────────── -->
            <TextBlock Text="WATCHED FOLDERS"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Opt_SectionForegroundBrush}"
                       Margin="0,12,0,6"/>

            <TextBlock Text="Additional output directories to watch (semicolon-separated). Plugins in these folders are hot-reloaded when their DLL changes."
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.8" TextWrapping="Wrap"
                       Margin="0,0,0,4"/>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtWatchedFolders"
                         Grid.Column="0"
                         Background="{DynamicResource Opt_InputBackgroundBrush}"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         BorderBrush="{DynamicResource DockBorderBrush}"
                         Padding="4,3"
                         TextChanged="OnChanged"/>
                <Button x:Name="BtnBrowse"
                        Grid.Column="1"
                        Content="Browse…"
                        Margin="6,0,0,0"
                        Padding="8,3"
                        Background="{DynamicResource Opt_InputBackgroundBrush}"
                        Foreground="{DynamicResource DockMenuForegroundBrush}"
                        BorderBrush="{DynamicResource DockBorderBrush}"
                        Click="OnBrowse"/>
            </Grid>

            <TextBlock Text="Example: C:\MyPlugin\bin\Debug\net8.0-windows;D:\AnotherPlugin\bin\Debug\net8.0-windows"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.5" FontSize="11" TextWrapping="Wrap"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="WpfHexEditor.Editor.TextEditor.Controls.TextEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Editor.TextEditor.Controls"
             Background="{DynamicResource TE_Background}"
             Focusable="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable text area -->
        <ScrollViewer x:Name="ScrollView"
                      Grid.Row="0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Focusable="False"
                      Background="{DynamicResource TE_Background}"
                      ScrollChanged="ScrollView_ScrollChanged">
            <Grid>
                <!-- Minimum width so horizontal scrollbar appears -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <local:TextViewport x:Name="Viewport"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"/>
            </Grid>
        </ScrollViewer>

        <!-- Status bar -->
        <StatusBar Grid.Row="1"
                   Background="{DynamicResource TE_LineNumberBackground}"
                   Foreground="{DynamicResource TE_LineNumberForeground}"
                   Height="22">
            <StatusBarItem>
                <TextBlock x:Name="LanguageText"
                           Text="Plain Text"
                           Padding="4,0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="CaretText"
                           Text="Ln 1, Col 1"
                           Padding="4,0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="EncodingText"
                           Text="UTF-8"
                           Padding="4,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>

{
  "formatName": "LZMA Compression",
  "version": "1.11",
  "extensions": [
    ".lzma"
  ],
  "description": "LZMA (Lempel-Ziv-Markov chain Algorithm) compressed file format, used in 7-Zip and XZ Utils",
  "category": "Archives",
  "author": "WPFHexaEditor Team",
  "references": {
    "specifications": [
      "LZMA Algorithm Specification - Igor Pavlov",
      "LZMA SDK Documentation",
      "XZ Utils File Format Specification"
    ],
    "WebLinks": [
      "https://www.7-zip.org/sdk.html",
      "https://en.wikipedia.org/wiki/Lempel%E2%80%93Ziv%E2%80%93Markov_chain_algorithm",
      "https://tukaani.org/xz/xz-file-format.txt",
      "https://github.com/jljusten/LZMA-SDK"
    ]
  },
  "detection": {
    "signature": "5D00",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 2,
      "max_signature_offset": 1024
    }
  },
  "functions": {
    "readUInt32LE": "Read dictionary size and uncompressed size (little-endian)",
    "formatFileSize(var:uncompressedSize)": "Format uncompressedSize as readable size"
  },
  "variables": {
    "dictionarySize": 0,
    "uncompressedSize": 0,
    "lzmaProperties": 0,
    "formattedSize": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "LZMA Properties",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "LZMA properties byte (usually 0x5D)",
      "storeAs": "lzmaProperties",
      "valueType": "uint8"
    },
    {
      "type": "data",
      "name": "Dictionary Size",
      "offset": 1,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.4,
      "description": "Dictionary size (little-endian)"
    },
    {
      "type": "data",
      "name": "Uncompressed Size",
      "offset": 5,
      "length": 8,
      "color": "#45B7D1",
      "opacity": 0.4,
      "description": "Uncompressed file size (little-endian, 0xFFFFFFFFFFFFFFFF if unknown)"
    },
    {
      "type": "metadata",
      "name": "Dictionary Size (bytes)",
      "variable": "dictionarySize",
      "description": "LZMA dictionary size in bytes"
    },
    {
      "type": "metadata",
      "name": "Uncompressed Size (bytes)",
      "variable": "uncompressedSize",
      "description": "Original file size before compression"
    },
    {
      "type": "metadata",
      "name": "Formatted Size",
      "variable": "formattedSize",
      "description": "Human-readable file size"
    }
  ],
  "software": [
    "LZMA utils",
    "7-Zip",
    "xz"
  ],
  "format_relationships": {
    "category": "Archives",
    "extensions": [
      ".lzma",
      ".xz"
    ]
  },
  "MimeTypes": [
    "application/x-lzma-compressed"
  ],
  "Software": [
    "7-Zip",
    "WinRAR",
    "WinZip",
    "PeaZip",
    "The Unarchiver"
  ],
  "UseCases": [
    "File compression",
    "Archive storage",
    "Backup",
    "Distribution"
  ],
  "QualityMetrics": {
    "CompletenessScore": 26,
    "DocumentationLevel": "standard",
    "BlocksDefined": 6,
    "ValidationRules": 0,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {
    "ArchivesFormat": true,
    "SupportsEncryption": false
  }

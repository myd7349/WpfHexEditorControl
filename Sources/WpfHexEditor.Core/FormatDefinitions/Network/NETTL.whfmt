{
  "formatName": "HP-UX nettl",
  "version": "1.11",
  "extensions": [
    ".trc0",
    ".trc1"
  ],
  "description": "HP-UX network tracing and logging format",
  "category": "Network",
  "author": "WPFHexaEditor Team",
  "references": {
    "specifications": [
      "HP-UX nettl Format"
    ],
    "WebLinks": [
      "https://en.wikipedia.org/wiki/TRC0"
    ]
  },
  "detection": {
    "signature": "00000001",
    "offset": 0,
    "required": false,
    "validation": {
      "min_file_size": 4,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "subsystem": 0,
    "packetCount": 0,
    "captureLength": 0,
    "fileMagic": "",
    "fileType": "",
    "startTime": 0,
    "hostnameLength": "",
    "hostname": "",
    "timeZone": ""
  },
  "blocks": [
    {
      "type": "field",
      "name": "File Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "nettl file magic number",
      "storeAs": "fileMagic",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "File Type",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Trace file type identifier",
      "storeAs": "fileType",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Start Time",
      "offset": 8,
      "length": 8,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Trace start time (timeval)",
      "storeAs": "startTime",
      "valueType": "uint64"
    },
    {
      "type": "field",
      "name": "Hostname Length",
      "offset": 16,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Length of hostname",
      "storeAs": "hostnameLength",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Hostname",
      "offset": 20,
      "length": 64,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "System hostname",
      "storeAs": "hostname",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Time Zone",
      "offset": 84,
      "length": 64,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Time zone string",
      "storeAs": "timeZone",
      "valueType": "ascii"
    },
    {
      "type": "metadata",
      "name": "Subsystem",
      "variable": "subsystem",
      "description": "Subsystem"
    },
    {
      "type": "metadata",
      "name": "Packet Count",
      "variable": "packetCount",
      "description": "Packet Count"
    }
  ],
  "software": [
    "Wireshark",
    "tcpdump"
  ],
  "format_relationships": {
    "category": "Network",
    "extensions": [
      ".trc0",
      ".trc1"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [
    "Wireshark",
    "tcpdump",
    "NetworkMiner",
    "Fiddler",
    "Charles Proxy"
  ],
  "UseCases": [
    "Network analysis",
    "Packet capture",
    "Debugging",
    "Security analysis"
  ],
  "QualityMetrics": {
    "CompletenessScore": 48,
    "DocumentationLevel": "standard",
    "BlocksDefined": 8,
    "ValidationRules": 0,
    "LastUpdated": "2026-02-24",
    "PriorityFormat": false,
    "AutoRefined": true
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt32BE": "Read HP-UX nettl header",
    "readUInt16BE": "Read subsystem ID"
  }
}

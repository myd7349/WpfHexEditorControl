  },
  "detection": {
    "signature": "43504B20",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 4,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "zipFileCount": 0,
    "zipCentralDirSize": 0,
    "zipComment": "",
    "eocdOffset": -1,
    "isZip64": false,
    "cpkSignature": "",
    "headerSize": 0,
    "fileCount": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "CPK Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "CPK magic bytes",
      "storeAs": "cpkSignature",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Header Size",
      "offset": 16,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Size of CPK header",
      "storeAs": "headerSize",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "File Count",
      "offset": 20,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Number of files",
      "storeAs": "fileCount",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "File Count",
      "variable": "zipFileCount",
      "description": "File Count"
    },
    {
      "type": "metadata",
      "name": "Archive Size",
      "variable": "zipCentralDirSize",
      "description": "Archive Size"
    }
  ],
  "software": [
    "Emulators",
    "Game engines"
  ],

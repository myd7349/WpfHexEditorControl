{
  "formatName": "CriWare CPK",
  "version": "1.12",
  "extensions": [
    ".cpk"
  ],
  "description": "CRI Middleware CPK archive",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "references": {
    "specifications": [
      "CRIWARE CPK Archive Format",
      "CRI Middleware Resource Package",
      "CPK File Structure Specification"
    ],
    "WebLinks": [
      "https://wiki.vg-resource.com/CPK",

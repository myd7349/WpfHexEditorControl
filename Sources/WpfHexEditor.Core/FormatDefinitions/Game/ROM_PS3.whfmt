      "type": "signature",
      "name": "PKG Magic",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "valueType": "uint32",
      "description": "PKG magic: 0x7F 0x50 0x4B 0x47",
      "storeAs": "pkgMagic"
    },
    {
      "type": "field",
      "name": "Package Type",
      "offset": 4,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.3,
      "valueType": "uint16",
      "description": "Package type: 0x0001=PS3, 0x0002=PSP",
      "storeAs": "packageType"
    },
    {
      "type": "field",

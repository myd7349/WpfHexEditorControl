      "offset": 12,
      "length": 8,
      "color": "#95E1D3",
      "opacity": 0.3,
      "valueType": "uint64",
      "description": "Package data size (64-bit big-endian)",
      "storeAs": "dataSize"
    },
    {
      "type": "field",
      "name": "Content ID",

  "detection": {
    "signature": "52464618",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 4,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "resourceCount": 0,
    "directoryOffset": 0,
    "version": 0,
    "rffSignature": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "RFF Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "RFF magic bytes",
      "storeAs": "rffSignature",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Version",
      "offset": 4,
      "length": 2,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "RFF format version",
      "storeAs": "version",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Directory Offset",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Offset to file directory",
      "storeAs": "directoryOffset",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "Resource Count",
      "variable": "resourceCount",
      "description": "Resource Count"
    },
    {
      "type": "metadata",
      "name": "Directory Offset",
      "variable": "directoryOffset",
      "description": "Directory Offset"
    }
  ],

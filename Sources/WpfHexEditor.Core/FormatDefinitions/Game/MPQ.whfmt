  },
  "variables": {
    "currentOffset": 0,
    "fileCount": 0,
    "totalSize": 0,
    "compressionMethod": "",
    "headerCRC": 0,
    "mpqSignature": "",
    "headerSize": 0,
    "archiveSize": 0,
    "formatVersion": 0,
    "formattedSize": ""
  },
  "blocks": [
    {
      "type": "signature",
      "name": "MPQ Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "MPQ archive magic bytes",
      "storeAs": "mpqSignature",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Header Size",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Size of the archive header",
      "storeAs": "headerSize",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Archive Size",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Total archive size",
      "storeAs": "archiveSize",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Format Version",
      "offset": 12,
      "length": 2,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "MPQ format version",
      "storeAs": "formatVersion",
      "valueType": "uint16"
    },
    {
      "type": "metadata",
      "name": "File Count",
      "variable": "fileCount",
      "description": "File Count"
    },
    {
      "type": "metadata",
      "name": "Total Size",

  "detection": {
    "signature": "57414432",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 4,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "fileCount": 0,
    "version": "",
    "indexOffset": 0,
    "wad2Signature": "",
    "numberOfLumps": 0,
    "directoryOffset": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "WAD2 Signature",
      "offset": 0,
      "length": 4,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "WAD2 magic bytes",
      "storeAs": "wad2Signature",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Number of Lumps",
      "offset": 4,
      "length": 4,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Total number of lumps",
      "storeAs": "numberOfLumps",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "Directory Offset",
      "offset": 8,
      "length": 4,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Offset to directory",
      "storeAs": "directoryOffset",
      "valueType": "uint32"
    },
    {
      "type": "metadata",
      "name": "File Count",
      "variable": "fileCount",
      "description": "File Count"
    },
    {
      "type": "metadata",
      "name": "Version",
      "variable": "version",
      "description": "Version"
    },
    {
      "type": "metadata",
      "name": "Index Offset",
      "variable": "indexOffset",
      "description": "Index Offset"
    }
  ],

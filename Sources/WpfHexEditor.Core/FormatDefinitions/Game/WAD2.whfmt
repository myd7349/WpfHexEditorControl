{
  "formatName": "Quake II WAD",
  "version": "1.12",
  "extensions": [
    ".wad"
  ],
  "description": "Quake II WAD texture archive",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "references": {
    "specifications": [

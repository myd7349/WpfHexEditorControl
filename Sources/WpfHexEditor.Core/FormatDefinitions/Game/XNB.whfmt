{
  "formatName": "XNA Game Studio",
  "version": "1.12",
  "extensions": [
    ".xnb"
  ],
  "description": "Microsoft XNA compiled content file",
  "category": "Game",
  "author": "WPFHexaEditor Team",
  "references": {
    "specifications": [
      "XNA Compiled Content Format",
      "Microsoft XNB Binary Specification",
      "XNA Content Pipeline Format"
    ],
    "WebLinks": [
      "https://github.com/SimonDarksideJ/XNAGameStudio/wiki/Compiled-(XNB)-Content-Format",
      "http://justsolve.archiveteam.org/wiki/Microsoft_XNA_Compiled_Format",
      "https://www.gamedev.net/blog/1046/entry-2250829-xnb-file-format-documentation/",
      "https://learn.microsoft.com/en-us/archive/technet-wiki/2231.xna-content-pipeline-overview"
    ]
  },
  "detection": {
    "signature": "584E42",
    "offset": 0,
    "required": true,
    "validation": {
      "min_file_size": 3,
      "max_signature_offset": 1024
    }
  },
  "variables": {
    "currentOffset": 0,
    "fileCount": 0,
    "version": "",
    "indexOffset": 0,
    "xnbSignature": "",
    "targetPlatform": 0,
    "formatVersion": 0,
    "flags": 0
  },
  "blocks": [
    {
      "type": "signature",
      "name": "XNB Signature",
      "offset": 0,
      "length": 3,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "XNB magic bytes",
      "storeAs": "xnbSignature",
      "valueType": "ascii"
    },
    {
      "type": "field",
      "name": "Target Platform",
      "offset": 3,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "w=Windows, m=Windows Phone, x=Xbox360",
      "storeAs": "targetPlatform",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Format Version",
      "offset": 4,
      "length": 1,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "XNB format version",
      "storeAs": "formatVersion",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Flags",
      "offset": 5,
      "length": 1,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Content flags",
      "storeAs": "flags",
      "valueType": "uint8"
    },
    {
      "type": "metadata",
      "name": "File Count",
      "variable": "fileCount",
      "description": "File Count"
    },
    {
      "type": "metadata",
      "name": "Version",
      "variable": "version",
      "description": "Version"
    },
    {
      "type": "metadata",
      "name": "Index Offset",
      "variable": "indexOffset",
      "description": "Index Offset"
    }
  ],
  "software": [
    "Emulators",
    "Game engines"
  ],
  "format_relationships": {
    "category": "Game",
    "extensions": [
      ".xnb"
    ]
  },
  "MimeTypes": [
    "application/octet-stream"
  ],
  "Software": [

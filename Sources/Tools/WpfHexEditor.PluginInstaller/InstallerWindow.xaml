    WpfHexEditor PluginInstaller — InstallerWindow
    Displays plugin metadata, permissions, trust badge, and hash verification
    before extracting a .whxplugin package.
-->
<Window x:Class="WpfHexEditor.PluginInstaller.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plugin Installer — WpfHexEditor"
        Width="540" Height="480"
        MinWidth="460" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">

    <Window.Resources>
        <!-- Badge styles -->
        <Style x:Key="TrustedBadgeStyle" TargetType="Border">
            <Setter Property="Background"  Value="#1F7F3F"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding"      Value="6,2"/>
        </Style>
        <Style x:Key="UntrustedBadgeStyle" TargetType="Border">
            <Setter Property="Background"  Value="#7F3F1F"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding"      Value="6,2"/>
        </Style>
        <Style x:Key="BadgeText" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>
        <!-- Permission row -->
        <Style x:Key="PermRowStyle" TargetType="Border">
            <Setter Property="BorderBrush"     Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"         Value="8,5"/>
        </Style>
        <!-- Result section -->
        <Style x:Key="ResultBorder" TargetType="Border">
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="Margin"          Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title / trust badge -->
            <RowDefinition Height="Auto"/>  <!-- Metadata grid -->
            <RowDefinition Height="*"/>     <!-- Permissions + hash -->
            <RowDefinition Height="Auto"/>  <!-- Result panel -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ── Row 0 : Plugin name + trust badge ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
            <TextBlock x:Name="TxtPluginName"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                       VerticalAlignment="Center"/>
            <Border x:Name="TrustBadge" Margin="10,0,0,0" VerticalAlignment="Center"
                    Style="{StaticResource TrustedBadgeStyle}">
                <TextBlock x:Name="TrustLabel" Text="Trusted Publisher" Style="{StaticResource BadgeText}"/>
            </Border>
        </StackPanel>

        <!-- ── Row 1 : Metadata grid ── -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Version"     VerticalAlignment="Center" Margin="0,3" Opacity=".7"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtVersion" VerticalAlignment="Center" Margin="4,3"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Author"      VerticalAlignment="Center" Margin="0,3" Opacity=".7"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtAuthor"  VerticalAlignment="Center" Margin="4,3"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Min IDE"     VerticalAlignment="Center" Margin="0,3" Opacity=".7"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtMinIde"  VerticalAlignment="Center" Margin="4,3"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Assembly"    VerticalAlignment="Center" Margin="0,3" Opacity=".7"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtAssembly" VerticalAlignment="Center" Margin="4,3" TextTrimming="CharacterEllipsis"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Description" VerticalAlignment="Top"    Margin="0,3" Opacity=".7"/>
            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtDescription"
                       VerticalAlignment="Top" Margin="4,3" TextWrapping="Wrap" MaxHeight="48"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- ── Row 2 : Permissions list + SHA section ── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,4">
            <StackPanel>
                <TextBlock Text="Permissions Requested" FontWeight="SemiBold" Margin="0,0,0,4"/>

                <Border x:Name="PermHexEditor"     Style="{StaticResource PermRowStyle}">
                    <TextBlock Text="Access Hex Editor content (read bytes, selection, offset)"/>
                </Border>
                <Border x:Name="PermFileSystem"    Style="{StaticResource PermRowStyle}">
                    <TextBlock Text="Access File System (read/write local files)"/>
                </Border>
                <Border x:Name="PermRegisterMenus" Style="{StaticResource PermRowStyle}">
                    <TextBlock Text="Register menus and toolbar items"/>
                </Border>
                <Border x:Name="PermWriteOutput"   Style="{StaticResource PermRowStyle}">
                    <TextBlock Text="Write to Output panel"/>
                </Border>

                <!-- Hash verification row -->
                <TextBlock Text="Integrity" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <Border Style="{StaticResource PermRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtHashLabel" Grid.Column="0"
                                   Text="SHA-256 verification pending…"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtHashBadge" Grid.Column="1"
                                   Margin="8,0,0,0" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ── Row 3 : Result / error panel ── -->
        <Border x:Name="ResultPanel" Grid.Row="3"
                Style="{StaticResource ResultBorder}"
                Visibility="Collapsed">
            <TextBlock x:Name="TxtResult" TextWrapping="Wrap" FontSize="12"/>
        </Border>

        <!-- ── Row 4 : Action buttons ── -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ProgressBar x:Name="Progress" Grid.Column="0"
                         Height="6" VerticalAlignment="Center"
                         IsIndeterminate="False" Visibility="Collapsed"/>

            <Button x:Name="BtnInstall" Grid.Column="1"
                    Content="Install" Width="90" Height="28"
                    IsDefault="True" Click="OnInstallClick"/>
            <Button x:Name="BtnClose"   Grid.Column="3"
                    Content="Cancel"  Width="90" Height="28"
                    IsCancel="True"  Click="OnCloseClick"/>
        </Grid>
    </Grid>
</Window>

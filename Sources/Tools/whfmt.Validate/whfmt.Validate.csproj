<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>WhfmtValidate</RootNamespace>
    <AssemblyName>whfmt-validate</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Optimize>true</Optimize>

    <!-- dotnet global tool packaging -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>whfmt</ToolCommandName>

    <!-- NuGet metadata -->
    <PackageId>whfmt.Validate</PackageId>
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0</AssemblyVersion>
    <FileVersion>1.0.0</FileVersion>
    <Authors>Derek Tremblay</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Product>whfmt.Validate</Product>
    <Title>whfmt.Validate — Binary File Validator dotnet global tool</Title>
    <Description>Validate binary files against 790+ whfmt format definitions. Checks magic bytes, checksums (CRC32/MD5/SHA1/SHA256/Adler32), structural assertions, and forensic patterns. Outputs plain text, JSON, or HTML reports. Install: dotnet tool install -g whfmt.Validate</Description>
    <Copyright>GNU AGPL v3.0 - 2016-2026</Copyright>
    <PackageTags>whfmt;binary;validate;format;detection;checksum;forensic;cli;tool;dotnet-tool</PackageTags>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorIDE</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorIDE</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReleaseNotes>1.0.0 — Initial release. validate command with --format, --report (text/json/html), --output, --recursive flags. 790+ format definitions via whfmt.FileFormatCatalog.</PackageReleaseNotes>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="whfmt.FileFormatCatalog" Version="1.2.0" />
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
    <!-- Local project references for the v3 expression validator (Models/Validation/WhfmtExpressionValidator)
         not yet shipped in the published 1.2.0 NuGet. Core.Contracts is added explicitly because the
         local Core.Definitions build replaces the NuGet payload and we need its Contracts types too.
         Once the next whfmt.FileFormatCatalog release lands, this whole block can revert to the
         PackageReference above. -->
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.Contracts\WpfHexEditor.Core.Contracts.csproj" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.Definitions\WpfHexEditor.Core.Definitions.csproj" />
  </ItemGroup>

</Project>

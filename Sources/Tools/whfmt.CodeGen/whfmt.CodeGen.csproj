<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>WhfmtCodeGen</RootNamespace>
    <AssemblyName>whfmt-codegen</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Optimize>true</Optimize>

    <PackAsTool>true</PackAsTool>
    <ToolCommandName>whfmt-codegen</ToolCommandName>

    <PackageId>whfmt.CodeGen</PackageId>
    <Version>1.1.2</Version>
    <AssemblyVersion>1.1.2</AssemblyVersion>
    <FileVersion>1.1.2</FileVersion>
    <Authors>Derek Tremblay</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Product>whfmt.CodeGen</Product>
    <Title>whfmt.CodeGen — Binary Parser Generator (C# · F# · Rust · VB.NET)</Title>
    <Description>Generate strongly-typed parsers from .whfmt binary format definitions — C#, zero-alloc Span&lt;byte&gt;, F#, Rust, or VB.NET. 789 binary formats supported (whfmt schema v3). Rich types: enums for valueMap, [Flags] enum for bitfields, List&lt;T&gt; for repeating, nullable for conditionals. Typed exceptions: InvalidSignatureException, ChecksumMismatchException, TruncatedFileException. Commands: gen, dump. Install: dotnet tool install -g whfmt.CodeGen</Description>
    <Copyright>GNU AGPL v3.0 - 2016-2026</Copyright>
    <PackageTags>whfmt;codegen;parser;generator;binary;format;c#;dotnet-tool;net8</PackageTags>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorIDE</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorIDE</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReleaseNotes>1.1.2 — Catalog bump to whfmt.FileFormatCatalog 1.3.2 (Phase B audit + bug fixes, 799 definitions, schema v3 canonical). No CodeGen API changes. 1.1.1 — VB.NET output language (--lang vb): Public Class with BinaryReader, typed enums for valueMap, &lt;Flags&gt; enum for bitfields, List(Of T) for repeating fields, nullable for conditionals, big-endian ReverseBytes helpers. 1.1.0 — dump command, rich types, typed exceptions, C#-Span / F# / Rust output, --project flag.</PackageReleaseNotes>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="icon.png"  Pack="true" PackagePath="\" />
    <None Include="whfmt-CodeGen-guide.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="whfmt.FileFormatCatalog" Version="1.3.2" />
    <PackageReference Include="System.CommandLine"      Version="2.0.0-beta4.22272.1" />
    <!-- Local project references for pre-1.3.2-publication dev/test.
         MSBuild prefers ProjectReference at build time; the PackageReference
         above is what consumers see. Remove this block once 1.3.2 is live. -->
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.Contracts\WpfHexEditor.Core.Contracts.csproj" />
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.Definitions\WpfHexEditor.Core.Definitions.csproj" />
  </ItemGroup>

</Project>

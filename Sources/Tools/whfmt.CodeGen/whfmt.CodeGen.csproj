<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>WhfmtCodeGen</RootNamespace>
    <AssemblyName>whfmt-codegen</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Optimize>true</Optimize>

    <PackAsTool>true</PackAsTool>
    <ToolCommandName>whfmt-codegen</ToolCommandName>

    <PackageId>whfmt.CodeGen</PackageId>
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0</AssemblyVersion>
    <FileVersion>1.0.0</FileVersion>
    <Authors>Derek Tremblay</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Product>whfmt.CodeGen</Product>
    <Title>whfmt.CodeGen — Binary Parser Generator</Title>
    <Description>Generate strongly-typed C# parsers from .whfmt format definitions. Each BlockDefinition becomes a typed method. Produces enums for valueMaps, structs for repeating blocks, and integrates validation (assertions + checksums). Install: dotnet tool install -g whfmt.CodeGen</Description>
    <Copyright>GNU AGPL v3.0 - 2016-2026</Copyright>
    <PackageTags>whfmt;codegen;parser;generator;binary;format;c#;dotnet-tool;net8</PackageTags>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorIDE</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorIDE</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReleaseNotes>1.0.0 — Initial release. generate command with --namespace, --class, --output, --validate flags. Supports field/group/repeating/union/conditional blocks, valueMap enums, bitfield structs.</PackageReleaseNotes>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="icon.png"  Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="whfmt.FileFormatCatalog" Version="1.3.1" />
    <PackageReference Include="System.CommandLine"      Version="2.0.0-beta4.22272.1" />
  </ItemGroup>

</Project>

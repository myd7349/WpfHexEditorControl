<ec:ThemedDialog x:Class="WpfHexEditor.HexEditor.Search.Views.AdvancedSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfHexEditor.HexEditor.Search.Views"
        xmlns:vm="clr-namespace:WpfHexEditor.HexEditor.Search.ViewModels"
        xmlns:models="clr-namespace:WpfHexEditor.Core.Search.Models;assembly=WpfHexEditor.Core"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        mc:Ignorable="d"
        Title="Rechercher / Remplacer"
        Height="460" Width="560"
        MinHeight="380" MinWidth="480"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource DockBackgroundBrush}">

    <Window.Resources>
        <!-- Converters -->
        <local:BoolToVisibilityConverter      x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:IndexConverter                  x:Key="IndexConverter"/>

        <!--
            DialogButtonStyle — VS2022-style compact action button.
            Uses Dock* brush keys, CornerRadius=2.
        -->
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="MinWidth"        Value="80"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Margin"          Value="4,0,0,0"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Background"      Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PrimaryButtonStyle — accent-fill Find All / Replace All -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background"  Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <!-- SmallToggleStyle — Ab / .* icon toggles in the options row -->
        <Style x:Key="SmallToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width"           Value="26"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="3,0"/>
            <Setter Property="Margin"          Value="2,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- InputTextBoxStyle — Find / Replace text inputs -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height"                   Value="26"/>
            <Setter Property="Padding"                  Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background"               Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground"               Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontFamily"               Value="Consolas"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="CaretBrush"               Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="SnapsToDevicePixels"      Value="True"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ResultsListViewStyle — virtualized, themed results list -->
        <Style x:Key="ResultsListViewStyle" TargetType="ListView">
            <Setter Property="Background"                       Value="{DynamicResource DockBackgroundBrush}"/>
            <Setter Property="Foreground"                       Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"                      Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness"                  Value="1"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ScrollViewer.CanContentScroll"    Value="True"/>
            <Setter Property="FontFamily"                       Value="Consolas"/>
            <Setter Property="FontSize"                         Value="11"/>
            <Setter Property="AlternationCount"                 Value="2"/>
        </Style>

        <!-- GridViewColumnHeaderStyle — dark-themed column headers -->
        <Style x:Key="GridViewColumnHeaderStyle" TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="OverridesDefaultStyle"         Value="True"/>
            <Setter Property="Background"                    Value="{DynamicResource DockMenuBackgroundBrush}"/>
            <Setter Property="Foreground"                    Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"                   Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness"               Value="0,0,1,1"/>
            <Setter Property="Padding"                       Value="6,3"/>
            <Setter Property="FontSize"                      Value="11"/>
            <Setter Property="FontWeight"                    Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment"    Value="Left"/>
            <Setter Property="FocusVisualStyle"              Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"
                                                  SnapsToDevicePixels="True"/>
                            </Border>
                            <Thumb x:Name="PART_HeaderGripper"
                                   HorizontalAlignment="Right"
                                   Width="8"
                                   Cursor="SizeWE">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="Role" Value="Floating">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ResultItemContainerStyle — subtle row alternation -->
        <Style x:Key="ResultItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="Padding"                    Value="2,1"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockMenuBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource DockTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Zone A: Search inputs + options (Auto) -->
            <RowDefinition Height="Auto"/>
            <!-- Zone B: Action bar (48px) -->
            <RowDefinition Height="48"/>
            <!-- Zone C: Results list (*) -->
            <RowDefinition Height="*"/>
            <!-- Zone D: Status bar (24px) -->
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════
             ZONE A — Search inputs
             ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,10,12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Mode dropdown + option toggles -->
                <DockPanel Grid.Row="0" LastChildFill="False">
                    <!-- Mode ComboBox -->
                    <ComboBox DockPanel.Dock="Left"
                              Width="130"
                              Style="{DynamicResource DockComboBoxStyle}"
                              SelectedIndex="{Binding SelectedModeIndex}"
                              ToolTip="Mode de recherche">
                        <ComboBoxItem Content="TEXT"/>
                        <ComboBoxItem Content="HEX"/>
                        <ComboBoxItem Content="WILDCARD"/>
                        <ComboBoxItem Content="TBL TEXT"
                                      IsEnabled="{Binding IsTblLoaded}"
                                      ToolTip="{Binding TblInfo}"/>
                        <ComboBoxItem Content="RELATIVE"/>
                    </ComboBox>

                    <!-- Separator -->
                    <Rectangle DockPanel.Dock="Left" Width="1" Margin="8,4" Opacity="0.35"
                               Fill="{DynamicResource DockMenuForegroundBrush}" VerticalAlignment="Stretch"/>

                    <!-- Ab — Case sensitive -->
                    <ToggleButton DockPanel.Dock="Left"
                                  Content="Ab"
                                  Style="{StaticResource SmallToggleStyle}"
                                  IsChecked="{Binding CaseSensitive}"
                                  ToolTip="Respecter la casse (Alt+C)"
                                  Visibility="{Binding IsTextMode, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- .* — Use wildcard -->
                    <ToggleButton DockPanel.Dock="Left"
                                  Content=".*"
                                  Style="{StaticResource SmallToggleStyle}"
                                  IsChecked="{Binding UseWildcard}"
                                  ToolTip="Utiliser des jokers ?? (Alt+E)"/>

                    <!-- Separator -->
                    <Rectangle DockPanel.Dock="Left" Width="1" Margin="8,4" Opacity="0.35"
                               Fill="{DynamicResource DockMenuForegroundBrush}" VerticalAlignment="Stretch"/>

                    <!-- Wrap -->
                    <CheckBox DockPanel.Dock="Left"
                              Content="Boucler"
                              Style="{DynamicResource DockCheckBoxStyle}"
                              IsChecked="{Binding WrapAround}"
                              VerticalAlignment="Center"
                              Margin="4,0,0,0"/>
                </DockPanel>

                <!-- Row 2: Find row -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Rechercher :"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <ComboBox Grid.Column="1"
                              x:Name="SearchInputComboBox"
                              IsEditable="True"
                              Text="{Binding SearchInput, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                              ItemsSource="{Binding SearchHistory}"
                              TextSearch.TextPath="Pattern">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}"
                                           FontFamily="Consolas"
                                           FontSize="11"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding FindAllCommand}"/>
                        </ComboBox.InputBindings>
                    </ComboBox>
                </Grid>

                <!-- Row 4: Replace row (hidden in RELATIVE mode) -->
                <Grid Grid.Row="4"
                      Visibility="{Binding ShowReplaceControls, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Remplacer :"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding ReplaceInput, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBoxStyle}"/>
                </Grid>

                <!-- Row 6: Encoding + Max (Text mode only) -->
                <StackPanel Grid.Row="6"
                            Orientation="Horizontal"
                            Visibility="{Binding IsTextMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Encodage :"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding AvailableEncodings}"
                              SelectedItem="{Binding SelectedEncoding}"
                              Style="{DynamicResource DockComboBoxStyle}"
                              DisplayMemberPath="Name"
                              Width="155"/>
                    <TextBlock Text="Max :"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Margin="14,0,6,0"/>
                    <TextBox Text="{Binding MaxResults}"
                             Style="{StaticResource InputTextBoxStyle}"
                             Width="70"/>
                </StackPanel>

                <!-- Row 6: Max only (non-Text modes) -->
                <StackPanel Grid.Row="6"
                            Orientation="Horizontal"
                            Visibility="{Binding IsTextMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <TextBlock Text="Max :"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Margin="0,0,6,0"/>
                    <TextBox Text="{Binding MaxResults}"
                             Style="{StaticResource InputTextBoxStyle}"
                             Width="70"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             ZONE B — Action bar
             ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,0">
            <DockPanel LastChildFill="False">
                <!-- STOP button (visible during search) -->
                <Button DockPanel.Dock="Right"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource DialogButtonStyle}"
                        Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Stop" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Performance label (center) -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding PerformanceLabel}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontSize="11"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Opacity="0.75"
                           Margin="0,0,10,0"/>

                <!-- Navigation -->
                <Button DockPanel.Dock="Left"
                        Command="{Binding FindPreviousCommand}"
                        Style="{StaticResource DialogButtonStyle}"
                        Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Pr&#233;c." VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left"
                        Command="{Binding FindNextCommand}"
                        Style="{StaticResource DialogButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Suiv." VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Separator -->
                <Rectangle DockPanel.Dock="Left" Width="1" Margin="8,10" Opacity="0.35"
                           Fill="{DynamicResource DockMenuForegroundBrush}" VerticalAlignment="Stretch"/>

                <!-- Find All -->
                <Button DockPanel.Dock="Left"
                        Content="Tout chercher"
                        Command="{Binding FindAllCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>

                <!-- Replace / Replace All (hidden in RELATIVE mode) -->
                <Button DockPanel.Dock="Left"
                        Content="Remplacer"
                        Command="{Binding ReplaceSelectedCommand}"
                        Style="{StaticResource DialogButtonStyle}"
                        Visibility="{Binding ShowReplaceControls, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button DockPanel.Dock="Left"
                        Content="Tout remplacer"
                        Command="{Binding ReplaceAllCommand}"
                        Style="{StaticResource DialogButtonStyle}"
                        Visibility="{Binding ShowReplaceControls, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             ZONE C — Results list
             ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="12,8,12,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header row -->
            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,6">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DockMenuForegroundBrush}">
                    <Run Text="R&#233;sultats ("/>
                    <Run Text="{Binding TotalResultCount, Mode=OneWay}"/>
                    <Run Text=")"/>
                </TextBlock>
                <Button DockPanel.Dock="Right"
                        Content="Exporter &#x25BE;"
                        Command="{Binding ExportResultsCommand}"
                        Style="{StaticResource DialogButtonStyle}"
                        MinWidth="80"/>
            </DockPanel>

            <!-- Progress bar (during search) -->
            <ProgressBar Grid.Row="1"
                         Height="2"
                         VerticalAlignment="Top"
                         IsIndeterminate="{Binding IsIndeterminate}"
                         Value="{Binding SearchProgress, Mode=OneWay}"
                         Maximum="100"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="Transparent"
                         BorderThickness="0"
                         Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Standard results (TEXT / HEX / WILDCARD / TBL) -->
            <ListView Grid.Row="1"
                      ItemsSource="{Binding StandardResults}"
                      SelectedItem="{Binding SelectedResult}"
                      Style="{StaticResource ResultsListViewStyle}"
                      ItemContainerStyle="{StaticResource ResultItemContainerStyle}"
                      Visibility="{Binding IsRelativeMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                        <GridViewColumn Header="#"              Width="44"  DisplayMemberBinding="{Binding Index}"/>
                        <GridViewColumn Header="Offset (Hex)"  Width="100" DisplayMemberBinding="{Binding PositionHex}"/>
                        <GridViewColumn Header="Offset (Dec)"  Width="100" DisplayMemberBinding="{Binding PositionDec}"/>
                        <GridViewColumn Header="Aper&#231;u"   Width="230" DisplayMemberBinding="{Binding HexContext}"/>
                        <GridViewColumn Header="Long."         Width="60"  DisplayMemberBinding="{Binding Length}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Relative results -->
            <ListView Grid.Row="1"
                      ItemsSource="{Binding RelativeResults}"
                      SelectedItem="{Binding SelectedResult}"
                      Style="{StaticResource ResultsListViewStyle}"
                      ItemContainerStyle="{StaticResource ResultItemContainerStyle}"
                      Visibility="{Binding IsRelativeMode, Converter={StaticResource BoolToVisibilityConverter}}">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                        <GridViewColumn Header="#" Width="38">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem},
                                               Path=(ItemsControl.AlternationIndex),
                                               Converter={StaticResource IndexConverter}}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Offset"    Width="66"  DisplayMemberBinding="{Binding Offset, StringFormat='+{0}'}"/>
                        <GridViewColumn Header="Score"     Width="58"  DisplayMemberBinding="{Binding Score, StringFormat=F1}"/>
                        <GridViewColumn Header="Occ."      Width="54"  DisplayMemberBinding="{Binding MatchCount}"/>
                        <GridViewColumn Header="Aper&#231;u" Width="240" DisplayMemberBinding="{Binding SampleText}"/>
                        <GridViewColumn Header="% Imprim." Width="70"  DisplayMemberBinding="{Binding PrintableCharPercentage, StringFormat=F1}"/>
                        <GridViewColumn Header="Actions"   Width="130">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Export TBL"
                                                Command="{Binding DataContext.ExportProposalToTblCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource DialogButtonStyle}"
                                                MinWidth="64" Height="20" Margin="0,0,4,0"/>
                                        <Button Content="Appliquer"
                                                Command="{Binding DataContext.ApplyEncodingCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource DialogButtonStyle}"
                                                MinWidth="60" Height="20"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             ZONE D — Status bar
             ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <DockPanel LastChildFill="False">
                <!-- TBL: Load or info -->
                <Button DockPanel.Dock="Right"
                        Command="{Binding LoadTblCommand}"
                        Style="{StaticResource DialogButtonStyle}"
                        Height="18" Padding="6,0"
                        Margin="0"
                        Visibility="{Binding IsTblLoaded, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                        ToolTip="Charger un fichier TBL (table de caract&#232;res ROM)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Charger TBL..." VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Visibility="{Binding IsTblLoaded, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"
                               Foreground="{DynamicResource DockMenuForegroundBrush}">
                        <Run Text="TBL :"/>
                        <Run Text="{Binding TblInfo, Mode=OneWay}"/>
                    </TextBlock>
                    <Button Command="{Binding CloseTblCommand}"
                            Style="{StaticResource DialogButtonStyle}"
                            Height="18" Padding="6,0" Margin="0"
                            ToolTip="Fermer le fichier TBL">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Fermer" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Left: filename + size -->
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding FileName, Mode=OneWay}"
                               FontSize="11"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Margin="0,0,8,0"/>
                    <Rectangle Width="1" Margin="0,3" Opacity="0.4"
                               Fill="{DynamicResource DockMenuForegroundBrush}"
                               VerticalAlignment="Stretch"/>
                    <TextBlock FontSize="11" Margin="8,0,0,0"
                               Foreground="{DynamicResource DockMenuForegroundBrush}">
                        <Run Text="Taille :"/>
                        <Run Text="{Binding FileLength, StringFormat=N0, Mode=OneWay}"/>
                        <Run Text="octets"/>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</ec:ThemedDialog>

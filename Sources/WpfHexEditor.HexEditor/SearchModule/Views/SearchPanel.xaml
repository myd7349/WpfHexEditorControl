<UserControl x:Class="WpfHexEditor.HexEditor.Search.Views.SearchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexEditor.HexEditor.Search.Views"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <!-- Value Converters -->
        <local:SearchModeToVisibilityConverter x:Key="SearchModeToVisibilityConverter"/>
        <local:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Local derived brushes for theme adaptation -->
        <SolidColorBrush x:Key="LocalButtonBackgroundBrush" Color="{DynamicResource BackgroundColor}" Opacity="0.9"/>
        <SolidColorBrush x:Key="LocalButtonBorderBrush" Color="{DynamicResource BackgroundColor}" Opacity="0.5"/>
        <SolidColorBrush x:Key="LocalButtonHoverBrush" Color="{DynamicResource AccentColor}" Opacity="0.2"/>
        <SolidColorBrush x:Key="LocalButtonPressedBrush" Color="{DynamicResource AccentColor}" Opacity="0.4"/>

        <!-- Modern flat button style -->
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource LocalButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LocalButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource LocalButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource LocalButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button style (smaller) -->
        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#ACACAC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Input Row -->
        <Grid Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search label -->
            <TextBlock Grid.Column="0" Text="Find:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>

            <!-- Search input -->
            <TextBox Grid.Column="1"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SearchTextBoxStyle}"
                     IsEnabled="{Binding CanSearch}"
                     Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Text}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding FindNextCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <TextBox Grid.Column="1"
                     Text="{Binding SearchHex, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SearchTextBoxStyle}"
                     IsEnabled="{Binding CanSearch}"
                     Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Hex}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding FindNextCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <!-- Search mode toggle -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="5,0">
                <RadioButton Content="Text"
                             IsChecked="{Binding SelectedSearchMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Text}"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                <RadioButton Content="Hex"
                             IsChecked="{Binding SelectedSearchMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Hex}"
                             VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Navigation buttons -->
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Content="▲"
                        Command="{Binding FindPreviousCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Find Previous (Shift+F3)"/>
                <Button Content="▼"
                        Command="{Binding FindNextCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Find Next (F3)"/>
                <Button Content="⊞"
                        Command="{Binding FindAllCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Find All"/>
                <Button Content="✖"
                        Command="{Binding ClearResultsCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Clear Results"/>
            </StackPanel>
        </Grid>

        <!-- Options Row -->
        <Grid Grid.Row="1" Margin="5,0,5,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Options label -->
            <TextBlock Grid.Column="0" Text="Options:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>

            <!-- Options checkboxes -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <CheckBox Content="Case sensitive"
                          IsChecked="{Binding CaseSensitive}"
                          Margin="0,0,15,0"
                          Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Text}"/>
                <CheckBox Content="Wildcard (??)"
                          IsChecked="{Binding UseWildcard}"
                          Margin="0,0,15,0"
                          Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Hex}"/>
                <CheckBox Content="Wrap around"
                          IsChecked="{Binding WrapAround}"
                          Margin="0,0,15,0"/>
                <ComboBox ItemsSource="{Binding AvailableEncodings}"
                          SelectedItem="{Binding SelectedEncoding}"
                          Width="150" Margin="0,0,10,0"
                          Visibility="{Binding SelectedSearchMode, Converter={StaticResource SearchModeToVisibilityConverter}, ConverterParameter=Text}"/>
            </StackPanel>
        </Grid>

        <!-- Status Row -->
        <Grid Grid.Row="2" Margin="5,0,5,5" Background="#F0F0F0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Status message -->
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Margin="5,3"
                       FontStyle="Italic"/>

            <!-- Match counter -->
            <TextBlock Grid.Column="1"
                       Text="{Binding CurrentMatchText}"
                       VerticalAlignment="Center"
                       Margin="5,3"
                       FontWeight="Bold"/>
        </Grid>

        <!-- Progress indicator (when searching) -->
        <ProgressBar Grid.Row="0" Grid.RowSpan="3"
                     IsIndeterminate="True"
                     Height="3"
                     VerticalAlignment="Bottom"
                     Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</UserControl>

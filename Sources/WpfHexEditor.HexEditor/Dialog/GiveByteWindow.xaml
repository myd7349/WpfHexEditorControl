<Window
    x:Class="WpfHexEditor.HexEditor.Dialog.GiveByteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:control="clr-namespace:WpfHexEditor.HexBox;assembly=WpfHexEditor.HexBox"
    xmlns:converters="clr-namespace:WpfHexEditor.HexEditor.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:p="clr-namespace:WpfHexEditor.Core.Properties;assembly=WpfHexEditor.Core"
    Title="{DynamicResource EnterHexValueMsgString}"
    Width="420"
    Height="260"
    x:ClassModifier="public"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    WindowStyle="SingleBorderWindow"
    mc:Ignorable="d">

    <Window.Resources>
        <converters:BoolToValidationColorConverter x:Key="BoolToValidationColorConverter"/>
        <converters:BoolToValidationIconConverter x:Key="BoolToValidationIconConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Byte Value GroupBox -->
        <GroupBox Header="{DynamicResource FindByteString}" Grid.Row="0" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <control:HexBox
                    x:Name="HexTextBox"
                    Grid.Column="0"
                    Height="26"
                    MaximumValue="255"
                    TabIndex="0"/>

                <!-- Validation Indicator -->
                <Border
                    Grid.Column="1"
                    Width="26"
                    Height="26"
                    Margin="8,0,0,0"
                    Background="{Binding IsValid, Converter={StaticResource BoolToValidationColorConverter}}"
                    CornerRadius="13"
                    VerticalAlignment="Center">
                    <TextBlock
                        Text="{Binding IsValid, Converter={StaticResource BoolToValidationIconConverter}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="White"/>
                </Border>
            </Grid>
        </GroupBox>

        <!-- Preview Section -->
        <Border Grid.Row="1"
                Margin="0,0,0,10"
                Padding="10"
                Background="#F5F5F5"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource PreviewString}"
                          FontWeight="SemiBold"
                          Margin="0,0,10,0"/>
                <TextBlock Text="{Binding DisplayValue}"
                          FontFamily="Consolas"
                          FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Options Section -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <CheckBox
                Content="{DynamicResource ShowConfirmationString}"
                IsChecked="{Binding ShowConfirmation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Margin="0,4"
                TabIndex="1"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button
                x:Name="OkButton"
                Content="{DynamicResource OkString}"
                Width="90"
                Height="28"
                Margin="0,0,8,0"
                IsDefault="True"
                TabIndex="2"
                Click="OKButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#0078D4"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="#0078D4"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button
                Content="{DynamicResource CancelString}"
                Width="90"
                Height="28"
                IsCancel="True"
                TabIndex="3">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#F3F3F3"/>
                        <Setter Property="Foreground" Value="#333333"/>
                        <Setter Property="BorderBrush" Value="#CCCCCC"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E1E1E1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>

<UserControl x:Class="WpfHexaEditor.Controls.ProgressOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <!-- Semi-transparent background overlay -->
    <Border Background="#CC000000">
        <Border Background="White"
                CornerRadius="8"
                Padding="24"
                MaxWidth="450"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#CCCCCC"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black"
                                  BlurRadius="15"
                                  ShadowDepth="3"
                                  Opacity="0.3"/>
            </Border.Effect>

            <StackPanel>
                <!-- Operation Title -->
                <TextBlock Text="{Binding OperationTitle}"
                           FontWeight="Bold"
                           FontSize="18"
                           Foreground="#333333"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"/>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="14"
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"
                           MinHeight="20"/>

                <!-- Progress Bar -->
                <ProgressBar Value="{Binding ProgressPercentage}"
                             Maximum="100"
                             Height="24"
                             Margin="0,0,0,8"
                             IsIndeterminate="{Binding IsIndeterminate}"
                             Foreground="#0078D4"/>

                <!-- Progress Text -->
                <TextBlock Text="{Binding ProgressText}"
                           FontSize="13"
                           Foreground="#666666"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <!-- Cancel Button -->
                <Button Content="{DynamicResource ProgressButtonCancel}"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibilityConverter}}"
                        Padding="20,8"
                        MinWidth="100"
                        HorizontalAlignment="Center"
                        Background="White"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F0F0F0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Border>
</UserControl>

    WpfHexEditor.LSP
    =================
    Language-server-style analysis engine for WpfHexEditor.
    Provides: LanguageDefinitionManager (whlang), IncrementalParser, SymbolTable,
    DiagnosticsEngine, BoostedSmartCompleteManager, RefactoringEngine,
    LspSnippetsManager, and integration bridges for CodeEditor.
-->

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>false</UseWPF>
    <RootNamespace>WpfHexEditor.LSP</RootNamespace>
    <AssemblyName>WpfHexEditor.LSP</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>Language-server-style analysis engine — LanguageDefinitionManager, IncrementalParser, SymbolTable, DiagnosticsEngine, BoostedSmartCompleteManager, RefactoringEngine.</Description>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\WpfHexEditor.Editor.Core\WpfHexEditor.Editor.Core.csproj" />
    <ProjectReference Include="..\WpfHexEditor.Editor.CodeEditor\WpfHexEditor.Editor.CodeEditor.csproj" />
    <ProjectReference Include="..\WpfHexEditor.SDK\WpfHexEditor.SDK.csproj" />
    <ProjectReference Include="..\WpfHexEditor.Definitions\WpfHexEditor.Definitions.csproj" />
    <ProjectReference Include="..\WpfHexEditor.Events\WpfHexEditor.Events.csproj" />
  </ItemGroup>

</Project>

     Created: 2026-03-06
     Description:
         XAML definition for the document tab options dialog.
         Provides live-preview controls for tab placement, colorization mode,
         and multi-row behavior. Inherits ThemedDialog for global theme compliance.

     Architecture Notes:
         Root element: ThemedDialog (WpfHexEditor.Editor.Core.Views).
         All brushes and foreground colors are bound via DynamicResource to
         DockBackgroundBrush and DockForegroundBrush for automatic theme switching.
     ========================================================== -->

<shell:ThemedDialog x:Class="WpfHexEditor.Shell.Dialogs.TabSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:WpfHexEditor.Shell"
        xmlns:dockSvc="clr-namespace:WpfHexEditor.Shell.Services"
        Title="{DynamicResource Docking_TabSettings_Title}"
        Width="420" SizeToContent="Height"
        Background="{DynamicResource DockBackgroundBrush}"
        Foreground="{DynamicResource DockForegroundBrush}">

    <Window.Resources>
        <!-- Docking localized strings — resolves Docking_TabSettings_* keys -->
        <dockSvc:DockingLocalizedDictionary/>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="8,4,8,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,4" />
            <Setter Property="Background" Value="{DynamicResource DockMenuBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <StackPanel Margin="12" DataContext="{Binding RelativeSource={RelativeSource AncestorType=Window}}">

        <!-- ── Tab Placement ───────────────────────────────────────────────── -->
        <GroupBox Header="{StaticResource Docking_TabSettings_TabStripPlacement}">
            <StackPanel>
                <RadioButton Content="{StaticResource Docking_TabSettings_Top}"
                             IsChecked="{Binding PlacementTop}" />
                <RadioButton Content="{StaticResource Docking_TabSettings_Left}"
                             IsChecked="{Binding PlacementLeft}" />
                <RadioButton Content="{StaticResource Docking_TabSettings_Right}"
                             IsChecked="{Binding PlacementRight}" />
            </StackPanel>
        </GroupBox>

        <!-- ── Color mode ─────────────────────────────────────────────────── -->
        <GroupBox Header="{StaticResource Docking_TabSettings_ColorBy}">
            <StackPanel>
                <RadioButton Content="{StaticResource Docking_TabSettings_NoColorization}"
                             IsChecked="{Binding ColorNone}" />
                <RadioButton Content="{StaticResource Docking_TabSettings_FileExtension}"
                             IsChecked="{Binding ColorByExtension}" />
                <RadioButton Content="{StaticResource Docking_TabSettings_Project}"
                             IsChecked="{Binding ColorByProject}" />
                <RadioButton Content="{StaticResource Docking_TabSettings_RegexRules}"
                             IsChecked="{Binding ColorByRegex}" />

                <!-- Regex rules editor — visible only when Regex mode is active -->
                <Border Margin="0,8,0,0"
                        Visibility="{Binding ColorByRegex, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{StaticResource Docking_TabSettings_RegexFirstMatch}"
                                   Foreground="{DynamicResource DockForegroundBrush}"
                                   Margin="0,0,0,4" />
                        <DataGrid x:Name="RegexGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="True"
                                  CanUserDeleteRows="True"
                                  HeadersVisibility="Column"
                                  MaxHeight="160"
                                  Background="{DynamicResource DockMenuBackgroundBrush}"
                                  Foreground="{DynamicResource DockForegroundBrush}"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource DockBorderBrush}"
                                  BorderBrush="{DynamicResource DockBorderBrush}"
                                  BorderThickness="1"
                                  RowBackground="{DynamicResource DockMenuBackgroundBrush}"
                                  AlternatingRowBackground="{DynamicResource DockBackgroundBrush}"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{StaticResource Docking_TabSettings_PatternColumn}"
                                                    Binding="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="*" />
                                <DataGridTemplateColumn Header="{StaticResource Docking_TabSettings_ColorColumn}" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                                <Border Width="16" Height="14"
                                                        CornerRadius="2"
                                                        Margin="0,0,4,0"
                                                        Background="{Binding ColorBrush}" />
                                                <TextBlock Text="{Binding ColorHex}"
                                                           Foreground="{DynamicResource DockForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           FontSize="10" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding ColorHex, UpdateSourceTrigger=LostFocus}"
                                                     ToolTip="{StaticResource Docking_TabSettings_HexColorTooltip}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="{StaticResource Docking_TabSettings_PressDelete}"
                                   FontSize="10"
                                   Foreground="{DynamicResource DockForegroundBrush}"
                                   Opacity="0.6"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </GroupBox>

        <!-- ── Multi-row tabs ─────────────────────────────────────────────── -->
        <GroupBox Header="{StaticResource Docking_TabSettings_TabRows}">
            <StackPanel>
                <CheckBox Content="{StaticResource Docking_TabSettings_ShowMultipleRows}"
                          IsChecked="{Binding MultiRowTabs}" />
                <CheckBox Content="{StaticResource Docking_TabSettings_ToggleWithWheel}"
                          IsChecked="{Binding MultiRowWithMouseWheel}"
                          IsEnabled="{Binding MultiRowTabs}" />
            </StackPanel>
        </GroupBox>

        <!-- ── Close button ───────────────────────────────────────────────── -->
        <Button Content="{StaticResource CloseString}"
                HorizontalAlignment="Right"
                Width="90"
                Margin="0,4,0,0"
                Click="OnCloseClick" />

    </StackPanel>
</shell:ThemedDialog>

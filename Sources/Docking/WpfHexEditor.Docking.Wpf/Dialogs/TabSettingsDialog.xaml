     Created: 2026-03-06
     Description:
         XAML definition for the document tab options dialog.
         Provides live-preview controls for tab placement, colorization mode,
         and multi-row behavior. Inherits ThemedDialog for global theme compliance.

     Architecture Notes:
         Root element: ThemedDialog (WpfHexEditor.Editor.Core.Views).
         All brushes and foreground colors are bound via DynamicResource to
         DockBackgroundBrush and DockForegroundBrush for automatic theme switching.
     ========================================================== -->

<ec:ThemedDialog x:Class="WpfHexEditor.Shell.Dialogs.TabSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        Title="Document Tab Options"
        Width="420" SizeToContent="Height"
        Background="{DynamicResource DockBackgroundBrush}"
        Foreground="{DynamicResource DockForegroundBrush}">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="8,4,8,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,4" />
            <Setter Property="Background" Value="{DynamicResource DockMenuBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <StackPanel Margin="12" DataContext="{Binding RelativeSource={RelativeSource AncestorType=Window}}">

        <!-- ── Tab Placement ───────────────────────────────────────────────── -->
        <GroupBox Header="Tab strip placement">
            <StackPanel>
                <RadioButton Content="Top (default)"
                             IsChecked="{Binding PlacementTop}" />
                <RadioButton Content="Left"
                             IsChecked="{Binding PlacementLeft}" />
                <RadioButton Content="Right"
                             IsChecked="{Binding PlacementRight}" />
            </StackPanel>
        </GroupBox>

        <!-- ── Color mode ─────────────────────────────────────────────────── -->
        <GroupBox Header="Color document tabs by">
            <StackPanel>
                <RadioButton Content="No colorization"
                             IsChecked="{Binding ColorNone}" />
                <RadioButton Content="File extension"
                             IsChecked="{Binding ColorByExtension}" />
                <RadioButton Content="Project"
                             IsChecked="{Binding ColorByProject}" />
                <RadioButton Content="Regex rules"
                             IsChecked="{Binding ColorByRegex}" />

                <!-- Regex rules editor — visible only when Regex mode is active -->
                <Border Margin="0,8,0,0"
                        Visibility="{Binding ColorByRegex, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Regex rules — first match wins:"
                                   Foreground="{DynamicResource DockForegroundBrush}"
                                   Margin="0,0,0,4" />
                        <DataGrid x:Name="RegexGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="True"
                                  CanUserDeleteRows="True"
                                  HeadersVisibility="Column"
                                  MaxHeight="160"
                                  Background="{DynamicResource DockMenuBackgroundBrush}"
                                  Foreground="{DynamicResource DockForegroundBrush}"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource DockBorderBrush}"
                                  BorderBrush="{DynamicResource DockBorderBrush}"
                                  BorderThickness="1"
                                  RowBackground="{DynamicResource DockMenuBackgroundBrush}"
                                  AlternatingRowBackground="{DynamicResource DockBackgroundBrush}"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Pattern (regex)"
                                                    Binding="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="*" />
                                <DataGridTemplateColumn Header="Color" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                                <Border Width="16" Height="14"
                                                        CornerRadius="2"
                                                        Margin="0,0,4,0"
                                                        Background="{Binding ColorBrush}" />
                                                <TextBlock Text="{Binding ColorHex}"
                                                           Foreground="{DynamicResource DockForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           FontSize="10" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding ColorHex, UpdateSourceTrigger=LostFocus}"
                                                     ToolTip="Enter a hex color: #RRGGBB or #AARRGGBB" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="Press Delete to remove a selected row."
                                   FontSize="10"
                                   Foreground="{DynamicResource DockForegroundBrush}"
                                   Opacity="0.6"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </GroupBox>

        <!-- ── Multi-row tabs ─────────────────────────────────────────────── -->
        <GroupBox Header="Tab rows">
            <StackPanel>
                <CheckBox Content="Show tabs in multiple rows"
                          IsChecked="{Binding MultiRowTabs}" />
                <CheckBox Content="Toggle rows with mouse wheel"
                          IsChecked="{Binding MultiRowWithMouseWheel}"
                          IsEnabled="{Binding MultiRowTabs}" />
            </StackPanel>
        </GroupBox>

        <!-- ── Close button ───────────────────────────────────────────────── -->
        <Button Content="Close"
                HorizontalAlignment="Right"
                Width="90"
                Margin="0,4,0,0"
                Click="OnCloseClick" />

    </StackPanel>
</ec:ThemedDialog>

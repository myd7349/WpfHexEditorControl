<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <!--
      RootNamespace intentionally kept as WpfHexEditor.Shell for backward namespace compatibility.
      All .cs files declare 'namespace WpfHexEditor.Shell' and require no modification.
      AssemblyName changes to WpfHexEditor.Docking.Wpf — consumers update xmlns:dock assembly= only.
    -->
    <RootNamespace>WpfHexEditor.Shell</RootNamespace>
    <AssemblyName>WpfHexEditor.Docking.Wpf</AssemblyName>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <!-- NuGet packaging -->
  <PropertyGroup>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <PackageId>WpfHexEditor.Docking.Wpf</PackageId>
    <Version>1.0.0</Version>
    <Authors>Derek Tremblay</Authors>
    <Company>WpfHexEditor</Company>
    <Product>WpfHexEditor Docking WPF</Product>
    <Description>WPF docking framework for WpfHexEditor. Provides VS Code-like docking chrome, panel/document hosting, theme switching and JSON layout persistence.</Description>
    <PackageTags>docking;layout;wpf;hexeditor;shell</PackageTags>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorIDE</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorIDE</PackageProjectUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\WpfHexEditor.Docking.Core\WpfHexEditor.Docking.Core.csproj" />
  </ItemGroup>

</Project>

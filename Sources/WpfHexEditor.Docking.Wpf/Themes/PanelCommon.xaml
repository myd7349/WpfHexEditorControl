<!-- ==========================================================
     Project: WpfHexEditor.Shell
     File: PanelCommon.xaml
     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude (Anthropic)
     Created: 2026-03-06
     Description:
         Shared style definitions for all IDE-style dockable panels (ParsedFieldsPanel,
         ErrorPanel, SolutionExplorerPanel, PropertiesPanel, etc.). Provides the
         PanelToolbarStyle, PanelIconButtonStyle, PanelIconToggleStyle, and related
         toolbar/separator styles that all panels consume.

     Architecture Notes:
         ResourceDictionary merged into every *Theme.xaml after Colors.xaml.
         All styles bind to Panel_* DynamicResource keys defined in each theme's
         Colors.xaml (Panel_ToolbarBrush, Panel_ToolbarBorderBrush, etc.).
         Toolbar height is fixed at 26px; icon buttons are 22x22 using Segoe MDL2 Assets.
     ========================================================== -->

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        PanelCommon.xaml — Shared styles for IDE panels (ParsedFieldsPanel, ErrorPanel, SolutionExplorer, etc.)
        All styles use Panel_* DynamicResource keys defined in each theme's Colors.xaml.

        Usage: merge this dictionary in each theme file after Colors.xaml.
        Panels reference these styles as StaticResource or DynamicResource.
    -->

    <!-- ─────────────────────────────────────────────────────────────────
         PanelToolbarStyle
         Container Border for the panel toolbar row (Row 0, 30px).
         Apply to the outermost Border of the panel toolbar.
    ───────────────────────────────────────────────────────────────────── -->
    <Style x:Key="PanelToolbarStyle" TargetType="Border">
        <Setter Property="Height"          Value="26"/>
        <Setter Property="Padding"         Value="4,0"/>
        <Setter Property="Background"      Value="{DynamicResource Panel_ToolbarBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource Panel_ToolbarBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         PanelIconButtonStyle
         22×22 icon-only button (Segoe MDL2 Assets glyph as Content).
         Transparent background, subtle hover/pressed highlight.
    ───────────────────────────────────────────────────────────────────── -->
    <Style x:Key="PanelIconButtonStyle" TargetType="Button">
        <Setter Property="Width"               Value="22"/>
        <Setter Property="Height"              Value="22"/>
        <Setter Property="Padding"             Value="0"/>
        <Setter Property="Margin"              Value="1,0"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="Foreground"          Value="{DynamicResource Panel_ToolbarForegroundBrush}"/>
        <Setter Property="FontFamily"          Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="2"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         PanelIconToggleStyle
         22×22 toggle button (Segoe MDL2 glyph as Content).
         Active/Checked state uses Panel_ToolbarButtonActiveBrush.
    ───────────────────────────────────────────────────────────────────── -->
    <Style x:Key="PanelIconToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width"               Value="22"/>
        <Setter Property="Height"              Value="22"/>
        <Setter Property="Padding"             Value="0"/>
        <Setter Property="Margin"              Value="1,0"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="BorderBrush"         Value="Transparent"/>
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="Foreground"          Value="{DynamicResource Panel_ToolbarForegroundBrush}"/>
        <Setter Property="FontFamily"          Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked"   Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                        </MultiTrigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         XD_ToolbarToggleButtonStyle
         26×22 toggle button for the XAML Designer toolbar (view-mode toggles).
         Checked state uses XD_ToolbarViewToggleActiveBrush (VS blue) to distinguish
         the active view mode. Hover and foreground reuse Panel_* tokens.
    ───────────────────────────────────────────────────────────────────── -->
    <Style x:Key="XD_ToolbarToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Width"               Value="26"/>
        <Setter Property="Height"              Value="22"/>
        <Setter Property="Padding"             Value="0"/>
        <Setter Property="Margin"              Value="1,0,0,0"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="BorderBrush"         Value="Transparent"/>
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="Foreground"          Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="FontFamily"          Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize"            Value="11"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked"   Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource XD_ToolbarViewToggleActiveBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{DynamicResource XD_ToolbarViewToggleActiveBrush}"/>
                        </MultiTrigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource XD_ToolbarViewToggleActiveBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{DynamicResource XD_ToolbarViewToggleActiveBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         XD_ToolbarIconButtonStyle
         22×22 regular icon button for the XAML Designer toolbar (Undo, Redo,
         Zoom, Align, Cut/Copy/Paste, Layout dropdown, etc.).
         Mirrors XD_ToolbarToggleButtonStyle but targets Button and uses
         IsPressed instead of IsChecked.
    ───────────────────────────────────────────────────────────────────── -->
    <Style x:Key="XD_ToolbarIconButtonStyle" TargetType="Button">
        <Setter Property="Width"               Value="22"/>
        <Setter Property="Height"              Value="22"/>
        <Setter Property="Padding"             Value="0"/>
        <Setter Property="Margin"              Value="1,0,0,0"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="Foreground"          Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="FontFamily"          Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize"            Value="12"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="2"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         PanelDropdownButtonStyle
         Text-label dropdown button (e.g., "Actions ▾", "Export ▾").
         Auto width, 22px height, normal font (not MDL2).
    ───────────────────────────────────────────────────────────────────── -->
    <Style x:Key="PanelDropdownButtonStyle" TargetType="Button">
        <Setter Property="Height"              Value="22"/>
        <Setter Property="Padding"             Value="6,0"/>
        <Setter Property="Margin"              Value="1,0"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="Foreground"          Value="{DynamicResource Panel_ToolbarForegroundBrush}"/>
        <Setter Property="FontSize"            Value="11"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="2"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         PanelToolbarSeparatorStyle
         Thin vertical 1px separator between toolbar button groups.
    ───────────────────────────────────────────────────────────────────── -->
    <Style x:Key="PanelToolbarSeparatorStyle" TargetType="Rectangle">
        <Setter Property="Width"             Value="1"/>
        <Setter Property="Margin"            Value="4,5"/>
        <Setter Property="Fill"              Value="{DynamicResource Panel_ToolbarBorderBrush}"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="IsHitTestVisible"  Value="False"/>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         PanelTreeExpanderStyle
         Toggle button for the tree expand/collapse arrow.
         Right-pointing ▶ when collapsed, down-pointing ▼ when expanded.
    ───────────────────────────────────────────────────────────────────── -->
    <Style x:Key="PanelTreeExpanderStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Focusable"           Value="False"/>
        <Setter Property="Width"               Value="16"/>
        <Setter Property="Height"              Value="16"/>
        <Setter Property="Foreground"          Value="{DynamicResource PFP_SubTextBrush}"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border Background="Transparent" SnapsToDevicePixels="True">
                        <Grid Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Collapsed: right-pointing chevron ▶ -->
                            <Path x:Name="ArrowRight"
                                  Data="M 2,1 L 9,5 L 2,9"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform"/>
                            <!-- Expanded: down-pointing chevron ▼ -->
                            <Path x:Name="ArrowDown"
                                  Data="M 1,2 L 5,9 L 9,2"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform"
                                  Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ArrowRight" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="ArrowDown"  Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         PanelTreeViewItemStyle
         Full dark-themed TreeViewItem with hover + selection support.
         Apply as ItemContainerStyle on any TreeView inside IDE panels.
         Uses DynamicResource → fully theme-aware.
    ───────────────────────────────────────────────────────────────────── -->
    <Style x:Key="PanelTreeViewItemStyle" TargetType="{x:Type TreeViewItem}">
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Foreground"                 Value="{DynamicResource PFP_TextBrush}"/>
        <Setter Property="FontFamily"                 Value="Segoe UI"/>
        <Setter Property="FontSize"                   Value="12"/>
        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels"        Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TreeViewItem}">
                    <StackPanel SnapsToDevicePixels="True">
                        <!-- Header row — hover/selection highlight spans full width -->
                        <Border x:Name="Bd"
                                Background="Transparent"
                                Padding="2,1"
                                SnapsToDevicePixels="True">
                            <DockPanel>
                                <ToggleButton x:Name="Expander"
                                              DockPanel.Dock="Left"
                                              Style="{StaticResource PanelTreeExpanderStyle}"
                                              IsChecked="{Binding IsExpanded,
                                                  RelativeSource={RelativeSource TemplatedParent},
                                                  Mode=TwoWay}"
                                              ClickMode="Press"/>
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <!-- Children — indented by 16px per level -->
                        <ItemsPresenter x:Name="ItemsHost"
                                        Margin="16,0,0,0"
                                        Visibility="Collapsed"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource SE_SelectedBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource PFP_ItemSelectedForegroundBrush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected"   Value="True"/>
                                <Condition Property="IsMouseOver"  Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource SE_SelectedBrush}"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         DockComboBoxStyle
         Theme-aware ComboBox for IDE dialogs and panels.
         Uses Dock* brush keys present in all 8 theme Colors.xaml files.
         The implicit alias at the end of this file makes this the
         default style for all ComboBoxes in scope.
    ───────────────────────────────────────────────────────────────────── -->
    <Style x:Key="DockComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background"          Value="{DynamicResource DockBackgroundBrush}"/>
        <Setter Property="Foreground"          Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="BorderBrush"         Value="{DynamicResource DockBorderBrush}"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="Padding"             Value="6,2,0,2"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground"                 Value="{DynamicResource DockMenuForegroundBrush}"/>
                    <Setter Property="Background"                 Value="Transparent"/>
                    <Setter Property="Padding"                    Value="8,5"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource DockTabHoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource DockTabActiveBrush}"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected"   Value="True"/>
                                            <Condition Property="IsMouseOver"  Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource DockTabActiveBrush}"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True"/>
                        <Grid Margin="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="22"/>
                            </Grid.ColumnDefinitions>

                            <!-- Selected value -->
                            <ContentPresenter x:Name="ContentSite"
                                              Grid.Column="0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>

                            <!-- Editable mode text box -->
                            <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Margin="{TemplateBinding Padding}"
                                     Foreground="{TemplateBinding Foreground}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalAlignment="Center"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>

                            <!-- Dropdown chevron toggle -->
                            <ToggleButton x:Name="PART_ToggleButton"
                                          Grid.Column="1"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Cursor="Hand"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TBd" Background="Transparent" SnapsToDevicePixels="True">
                                            <TextBlock Text="&#xE70D;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TBd" Property="Background"
                                                        Value="{DynamicResource DockTabHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>

                        <!-- Dropdown popup -->
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="{DynamicResource DockBackgroundBrush}"
                                    BorderBrush="{DynamicResource DockBorderBrush}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True"
                                    MinWidth="{Binding ActualWidth,
                                        RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="ContentSite"             Property="Visibility" Value="Hidden"/>
                            <Setter TargetName="PART_EditableTextBox"    Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush"
                                    Value="{DynamicResource DockTabHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush"
                                    Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ═══════════════════════════════════════════════════════════════════
         Implicit control styles
         ─────────────────────────────────────────────────────────────────
         Only styles whose named key is defined within PanelCommon.xaml itself
         can safely use {StaticResource} here. Keys from sibling Menu.xaml files
         (DockDark*) are added as implicit styles at the END of Dark/Menu.xaml
         and Light/Menu.xaml, where the keys are guaranteed to be in scope.
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- ComboBox: implicit alias — applies DockComboBoxStyle to every ComboBox in scope -->
    <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource DockComboBoxStyle}"/>

    <!-- ─────────────────────────────────────────────────────────────────
         CheckBox — full VS2022-style custom template
         Overrides the Foreground-only stub in ContentControls.xaml.
         Uses AccentBrush for the checked fill, DockBorderBrush for the box.
         Named key allows explicit reference from dialogs/windows in other assemblies.
    ───────────────────────────────────────────────────────────────────── -->
    <Style x:Key="DockCheckBoxStyle" TargetType="{x:Type CheckBox}">
        <Setter Property="OverridesDefaultStyle"    Value="True"/>
        <Setter Property="Foreground"               Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="Background"               Value="{DynamicResource DockBackgroundBrush}"/>
        <Setter Property="BorderBrush"              Value="{DynamicResource PFP_InputBorderBrush}"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
        <Setter Property="Cursor"                   Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels"      Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <BulletDecorator Background="Transparent" SnapsToDevicePixels="True">
                        <BulletDecorator.Bullet>
                            <!-- 14×14 rounded box -->
                            <Border x:Name="CheckBorder"
                                    Width="14" Height="14"
                                    CornerRadius="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                <!-- Checkmark path (hidden until IsChecked=True) -->
                                <Path x:Name="CheckMark"
                                      Data="M1.5,5.5 L5,9 L11.5,2"
                                      Stroke="White"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Stretch="Uniform"
                                      Margin="2"
                                      Visibility="Collapsed"/>
                            </Border>
                        </BulletDecorator.Bullet>
                        <ContentPresenter Margin="6,0,0,0"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          RecognizesAccessKey="True"/>
                    </BulletDecorator>
                    <ControlTemplate.Triggers>
                        <!-- Checked: accent fill + white checkmark -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckBorder" Property="Background"  Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="CheckMark"   Property="Visibility"  Value="Visible"/>
                        </Trigger>
                        <!-- Indeterminate: accent fill, no checkmark (null = indeterminate) -->
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="CheckBorder" Property="Background"  Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <!-- Hover: accent border highlight -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox: implicit alias — applies DockCheckBoxStyle to every CheckBox in scope -->
    <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource DockCheckBoxStyle}"/>

    <!-- ═══════════════════════════════════════════════════════════
         Plugin Manager (PM_*) — shared styles for PluginManagerControl
         ══════════════════════════════════════════════════════════= -->

    <!-- Plugin list item container — hover + selected state via DynamicResource.
         Selected trigger also sets Foreground=White so subtitle text (bound via
         RelativeSource to ListBoxItem.Foreground) remains readable on the accent bg. -->
    <Style x:Key="PM_PluginListItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="Foreground"   Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"      Value="0"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="2" Padding="4,2">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource PM_ListItemHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource PM_ListItemSelectedBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Plugin category header — non-interactive section label -->
    <Style x:Key="PM_CategoryHeaderStyle" TargetType="Border">
        <Setter Property="Background"  Value="{DynamicResource PM_CategoryHeaderBrush}"/>
        <Setter Property="Padding"     Value="8,3"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Panel_ToolbarBorderBrush}"/>
    </Style>

    <!-- State badge capsule (coloured background, white text) -->
    <Style x:Key="PM_BadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding"      Value="6,1"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Action button: Enable / Disable / Reload — panel-style flat button.
         Hover/Pressed states use Style.Triggers so derived styles can override independently. -->
    <Style x:Key="PM_ActionButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="{DynamicResource Panel_ToolbarBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource Panel_ToolbarBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="10,4"/>
        <Setter Property="Margin"          Value="0,0,6,6"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background"  Value="{DynamicResource PM_ListItemHoverBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background"  Value="{DynamicResource PM_ListItemSelectedBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Danger button: Uninstall — keeps DangerBrush border on all interactive states -->
    <Style x:Key="PM_DangerButtonStyle" TargetType="Button"
           BasedOn="{StaticResource PM_ActionButtonStyle}">
        <Setter Property="Foreground"  Value="{DynamicResource DangerBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background"  Value="{DynamicResource PM_ListItemHoverBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background"  Value="{DynamicResource PM_ListItemSelectedBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Metric card: small dark card showing CPU / RAM / Init / Avg -->
    <Style x:Key="PM_MetricCardStyle" TargetType="Border">
        <Setter Property="Background"   Value="{DynamicResource Panel_ToolbarBrush}"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource Panel_ToolbarBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding"      Value="8"/>
    </Style>

</ResourceDictionary>

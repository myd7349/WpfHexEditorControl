<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DocumentTabHost: tab strip at TOP -->
    <Style x:Key="DocumentTabHostStyle" TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{DynamicResource DockMenuBackgroundBrush}">
                            <TabPanel Panel.IsItemsHost="True"
                                      Background="Transparent"
                                      Margin="4,2,4,0" />
                        </Border>
                        <ContentPresenter Grid.Row="1"
                                          x:Name="PART_SelectedContentHost"
                                          ContentSource="SelectedContent"
                                          KeyboardNavigation.TabNavigation="Local"
                                          KeyboardNavigation.DirectionalNavigation="Contained" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DockTabControl: content area top, tab strip at bottom -->
    <Style x:Key="DockTabControlStyle" TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ContentPresenter Grid.Row="0"
                                          x:Name="PART_SelectedContentHost"
                                          ContentSource="SelectedContent"
                                          KeyboardNavigation.TabNavigation="Local"
                                          KeyboardNavigation.DirectionalNavigation="Contained" />
                        <Border Grid.Row="1"
                                Background="{DynamicResource DockMenuBackgroundBrush}">
                            <TabPanel Panel.IsItemsHost="True"
                                      Background="Transparent"
                                      Margin="2,0,2,0" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DockTabItem: flat fused design — active tab matches content bg (VS2022-style) -->
    <Style x:Key="DockTabItemStyle" TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="{DynamicResource DockTabTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,6,10,6" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center" />
                        </Border>
                        <!-- Accent indicator: 3px line at top of tab (toward content) -->
                        <Border x:Name="ActiveIndicator"
                                Height="3"
                                VerticalAlignment="Top"
                                Background="Transparent" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Selected: bg matches content area, accent line visible -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Background"
                                    Value="{DynamicResource DockBackgroundBrush}" />
                            <Setter TargetName="ActiveIndicator" Property="Background"
                                    Value="{DynamicResource DockTabActiveBrush}" />
                            <!-- Light theme: keep dark text since bg is light -->
                            <Setter Property="Foreground"
                                    Value="{DynamicResource DockTabTextBrush}" />
                        </Trigger>
                        <!-- Hover on unselected -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TabBorder" Property="Background"
                                    Value="{DynamicResource DockTabHoverBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

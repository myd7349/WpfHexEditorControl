    <Color x:Key="DockBorderColor">#CCCEDB</Color>
    <Color x:Key="DockTabActiveColor">#007ACC</Color>
    <Color x:Key="DockTabInactiveColor">#EEEEF2</Color>
    <Color x:Key="DockTabHoverColor">#1C97EA</Color>
    <Color x:Key="DockTabTextColor">#1E1E1E</Color>
    <Color x:Key="DockTabActiveTextColor">#FFFFFF</Color>
    <Color x:Key="DockSplitterColor">#CCCEDB</Color>
    <Color x:Key="DockOverlayColor">#40007ACC</Color>
    <Color x:Key="DockDocumentHostBorderColor">#007ACC</Color>

    <Color x:Key="DockMenuBackgroundColor">#EEEEF2</Color>
    <Color x:Key="DockMenuForegroundColor">#1E1E1E</Color>
    <Color x:Key="DockMenuHighlightColor">#C9DEF5</Color>
    <Color x:Key="DockMenuBorderColor">#CCCEDB</Color>
    <Color x:Key="DockMenuHighlightBorderColor">#0078D4</Color>
    <Color x:Key="DockToolBarBackgroundColor">#EEEEF2</Color>
    <Color x:Key="DockWindowBackgroundColor">#F0F0F0</Color>

    <!-- HexEditor Colors -->
    <Color x:Key="HexEditor_BackgroundColor">#FFFFFF</Color>
    <Color x:Key="HexEditor_HeaderBackgroundColor">#F5F5F5</Color>
    <Color x:Key="HexEditor_HeaderForegroundColor">#424242</Color>
    <Color x:Key="HexEditor_ColumnSeparatorColor">#D0D0D0</Color>
    <Color x:Key="HexEditor_ForegroundFirstColor">#000000</Color>
    <Color x:Key="HexEditor_ForegroundSecondColor">#0000FF</Color>
    <Color x:Key="HexEditor_ForegroundOffSetHeaderColor">#757575</Color>
    <Color x:Key="HexEditor_SelectionFirstColor">#660078D4</Color>
    <Color x:Key="HexEditor_SelectionSecondColor">#330078D4</Color>
    <Color x:Key="HexEditor_ForegroundContrast">#000000</Color>
    <Color x:Key="HexEditor_ForegroundHighLightOffSetHeaderColor">#00008B</Color>
    <Color x:Key="HexEditor_AsciiForegroundColor">#424242</Color>
    <Color x:Key="HexEditor_StatusBarBackgroundColor">#F5F5F5</Color>
    <Color x:Key="HexEditor_StatusBarForegroundColor">#333333</Color>
    <Color x:Key="HexEditor_ScrollBarBackgroundColor">#F0F0F0</Color>
    <Color x:Key="HexEditor_ScrollBarThumbColor">#CDCDCD</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="DockBackgroundBrush" Color="{StaticResource DockBackgroundColor}" />
    <SolidColorBrush x:Key="DockBorderBrush" Color="{StaticResource DockBorderColor}" />
    <SolidColorBrush x:Key="DockTabActiveBrush" Color="{StaticResource DockTabActiveColor}" />
    <SolidColorBrush x:Key="DockTabInactiveBrush" Color="{StaticResource DockTabInactiveColor}" />
    <SolidColorBrush x:Key="DockTabHoverBrush" Color="{StaticResource DockTabHoverColor}" />
    <SolidColorBrush x:Key="DockTabTextBrush" Color="{StaticResource DockTabTextColor}" />
    <SolidColorBrush x:Key="DockTabActiveTextBrush" Color="{StaticResource DockTabActiveTextColor}" />
    <SolidColorBrush x:Key="DockSplitterBrush" Color="{StaticResource DockSplitterColor}" />
    <SolidColorBrush x:Key="DockDocumentHostBorderBrush" Color="{StaticResource DockDocumentHostBorderColor}" />
    <SolidColorBrush x:Key="DockMenuBackgroundBrush" Color="{StaticResource DockMenuBackgroundColor}" />
    <SolidColorBrush x:Key="DockMenuForegroundBrush" Color="{StaticResource DockMenuForegroundColor}" />
    <SolidColorBrush x:Key="DockMenuHighlightBrush" Color="{StaticResource DockMenuHighlightColor}" />
    <SolidColorBrush x:Key="DockMenuBorderBrush" Color="{StaticResource DockMenuBorderColor}" />
    <SolidColorBrush x:Key="DockMenuHighlightBorderBrush" Color="{StaticResource DockMenuHighlightBorderColor}" />
    <SolidColorBrush x:Key="DockToolBarBackgroundBrush" Color="{StaticResource DockToolBarBackgroundColor}" />
    <SolidColorBrush x:Key="DockWindowBackgroundBrush" Color="{StaticResource DockWindowBackgroundColor}" />

    <!-- VS-style title bar button: transparent bg, subtle hover, no chrome -->
    <Style x:Key="DockTitleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource DockTabTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="2"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window title bar button (minimize, maximize/restore) — VS Code style -->
    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Cursor" Value="Arrow"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window title bar close button — red hover like VS Code -->
    <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F1707A"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ParsedFieldsPanel (PFP) Theme Resources -->

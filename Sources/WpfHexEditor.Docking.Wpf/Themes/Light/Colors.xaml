    <SolidColorBrush x:Key="PFP_AccentBrush" Color="#1976D2"/>
    <SolidColorBrush x:Key="PFP_ItemHoverBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="PFP_ItemSelectedForegroundBrush" Color="#01579B"/>
    <SolidColorBrush x:Key="PFP_ItemSelectedBorderBrush" Color="#81D4FA"/>
    <SolidColorBrush x:Key="PFP_ComputedSectionBackgroundBrush" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="PFP_ComputedSectionBorderBrush" Color="#BBDEFB"/>
    <SolidColorBrush x:Key="PFP_ComputedTitleBrush" Color="#1565C0"/>
    <SolidColorBrush x:Key="PFP_ComputedIconBrush" Color="#1976D2"/>
    <SolidColorBrush x:Key="PFP_ComputedValueBrush" Color="#0D47A1"/>
    <SolidColorBrush x:Key="PFP_InsightSectionBackgroundBrush" Color="#FFFDE7"/>
    <SolidColorBrush x:Key="PFP_InsightSectionBorderBrush" Color="#FFF9C4"/>
    <SolidColorBrush x:Key="PFP_InsightTitleBrush" Color="#F57F17"/>
    <SolidColorBrush x:Key="PFP_InputBorderBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="PFP_GroupBadgeBackgroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="PFP_CoverageTrackBrush" Color="#EEEEEE"/>

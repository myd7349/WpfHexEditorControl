<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Default (Light) Theme for WpfHexEditor.Docking -->

    <!-- Colors -->
    <Color x:Key="DockBackgroundColor">#F0F0F0</Color>
    <Color x:Key="DockBorderColor">#CCCEDB</Color>
    <Color x:Key="DockTabActiveColor">#007ACC</Color>
    <Color x:Key="DockTabInactiveColor">#EEEEF2</Color>
    <Color x:Key="DockTabHoverColor">#1C97EA</Color>
    <Color x:Key="DockTabTextColor">#1E1E1E</Color>
    <Color x:Key="DockTabActiveTextColor">#FFFFFF</Color>
    <Color x:Key="DockSplitterColor">#CCCEDB</Color>
    <Color x:Key="DockOverlayColor">#40007ACC</Color>
    <Color x:Key="DockDocumentHostBorderColor">#007ACC</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="DockBackgroundBrush" Color="{StaticResource DockBackgroundColor}" />
    <SolidColorBrush x:Key="DockBorderBrush" Color="{StaticResource DockBorderColor}" />
    <SolidColorBrush x:Key="DockTabActiveBrush" Color="{StaticResource DockTabActiveColor}" />
    <SolidColorBrush x:Key="DockTabInactiveBrush" Color="{StaticResource DockTabInactiveColor}" />
    <SolidColorBrush x:Key="DockTabHoverBrush" Color="{StaticResource DockTabHoverColor}" />
    <SolidColorBrush x:Key="DockTabTextBrush" Color="{StaticResource DockTabTextColor}" />
    <SolidColorBrush x:Key="DockTabActiveTextBrush" Color="{StaticResource DockTabActiveTextColor}" />
    <SolidColorBrush x:Key="DockSplitterBrush" Color="{StaticResource DockSplitterColor}" />
    <SolidColorBrush x:Key="DockDocumentHostBorderBrush" Color="{StaticResource DockDocumentHostBorderColor}" />

    <!-- Global UI Colors (Light) -->
    <Color x:Key="DockMenuBackgroundColor">#EEEEF2</Color>
    <Color x:Key="DockMenuForegroundColor">#1E1E1E</Color>
    <Color x:Key="DockMenuHighlightColor">#C9DEF5</Color>
    <Color x:Key="DockMenuBorderColor">#CCCEDB</Color>
    <Color x:Key="DockToolBarBackgroundColor">#EEEEF2</Color>
    <Color x:Key="DockWindowBackgroundColor">#F0F0F0</Color>

    <SolidColorBrush x:Key="DockMenuBackgroundBrush" Color="{StaticResource DockMenuBackgroundColor}" />
    <SolidColorBrush x:Key="DockMenuForegroundBrush" Color="{StaticResource DockMenuForegroundColor}" />
    <SolidColorBrush x:Key="DockMenuHighlightBrush" Color="{StaticResource DockMenuHighlightColor}" />
    <SolidColorBrush x:Key="DockMenuBorderBrush" Color="{StaticResource DockMenuBorderColor}" />
    <SolidColorBrush x:Key="DockToolBarBackgroundBrush" Color="{StaticResource DockToolBarBackgroundColor}" />
    <SolidColorBrush x:Key="DockWindowBackgroundBrush" Color="{StaticResource DockWindowBackgroundColor}" />

    <!-- Menu style (Light) -->
    <Style x:Key="DockDarkMenuStyle" TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource DockMenuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
    </Style>

    <Style x:Key="DockDarkMenuItemStyle" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="DockDarkToolBarStyle" TargetType="ToolBar">
        <Setter Property="Background" Value="{StaticResource DockToolBarBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
    </Style>

    <Style x:Key="DockDarkToolBarButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
        <Setter Property="Padding" Value="6,2" />
    </Style>

    <!-- Content control overrides: ensure readable text in light-themed docked/floating panels. -->
    <Style TargetType="{x:Type TreeView}" BasedOn="{StaticResource {x:Type TreeView}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DockBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource {x:Type TreeViewItem}}">
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource DockMenuForegroundBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource DockTabActiveBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DockBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type Label}" BasedOn="{StaticResource {x:Type Label}}">
        <Setter Property="Foreground" Value="{StaticResource DockMenuForegroundBrush}" />
    </Style>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Default (Light) Theme for WpfHexEditor.Docking -->

    <!-- Colors -->
    <Color x:Key="DockBackgroundColor">#F0F0F0</Color>
    <Color x:Key="DockBorderColor">#CCCEDB</Color>
    <Color x:Key="DockTabActiveColor">#007ACC</Color>
    <Color x:Key="DockTabInactiveColor">#EEEEF2</Color>
    <Color x:Key="DockTabHoverColor">#1C97EA</Color>
    <Color x:Key="DockTabTextColor">#1E1E1E</Color>
    <Color x:Key="DockTabActiveTextColor">#FFFFFF</Color>
    <Color x:Key="DockSplitterColor">#CCCEDB</Color>
    <Color x:Key="DockOverlayColor">#40007ACC</Color>
    <Color x:Key="DockDocumentHostBorderColor">#007ACC</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="DockBackgroundBrush" Color="{StaticResource DockBackgroundColor}" />
    <SolidColorBrush x:Key="DockBorderBrush" Color="{StaticResource DockBorderColor}" />
    <SolidColorBrush x:Key="DockTabActiveBrush" Color="{StaticResource DockTabActiveColor}" />
    <SolidColorBrush x:Key="DockTabInactiveBrush" Color="{StaticResource DockTabInactiveColor}" />
    <SolidColorBrush x:Key="DockTabHoverBrush" Color="{StaticResource DockTabHoverColor}" />
    <SolidColorBrush x:Key="DockTabTextBrush" Color="{StaticResource DockTabTextColor}" />
    <SolidColorBrush x:Key="DockTabActiveTextBrush" Color="{StaticResource DockTabActiveTextColor}" />
    <SolidColorBrush x:Key="DockSplitterBrush" Color="{StaticResource DockSplitterColor}" />
    <SolidColorBrush x:Key="DockDocumentHostBorderBrush" Color="{StaticResource DockDocumentHostBorderColor}" />

</ResourceDictionary>

    <Color x:Key="DockBorderColor">#3F3F3F</Color>
    <Color x:Key="DockTabActiveColor">#00D9FF</Color>
    <Color x:Key="DockTabInactiveColor">#252525</Color>
    <Color x:Key="DockTabHoverColor">#333333</Color>
    <Color x:Key="DockTabTextColor">#B0B0B0</Color>
    <Color x:Key="DockTabActiveTextColor">#FFFFFF</Color>
    <Color x:Key="DockSplitterColor">#3F3F3F</Color>
    <Color x:Key="DockOverlayColor">#4000D9FF</Color>
    <Color x:Key="DockDocumentHostBorderColor">#00D9FF</Color>

    <!-- Menu / toolbar -->
    <Color x:Key="DockMenuBackgroundColor">#252525</Color>
    <Color x:Key="DockMenuForegroundColor">#FFFFFF</Color>
    <Color x:Key="DockMenuHighlightColor">#333333</Color>
    <Color x:Key="DockMenuBorderColor">#3F3F3F</Color>
    <Color x:Key="DockMenuHighlightBorderColor">#9B9B9B</Color>
    <Color x:Key="DockToolBarBackgroundColor">#252525</Color>
    <Color x:Key="DockWindowBackgroundColor">#1A1A1A</Color>

    <!-- HexEditor Colors -->
    <Color x:Key="HexEditor_BackgroundColor">#1A1A1A</Color>
    <Color x:Key="HexEditor_HeaderBackgroundColor">#252525</Color>
    <Color x:Key="HexEditor_HeaderForegroundColor">#B0B0B0</Color>
    <Color x:Key="HexEditor_ColumnSeparatorColor">#3F3F3F</Color>
    <Color x:Key="HexEditor_ForegroundFirstColor">#E0E0E0</Color>
    <Color x:Key="HexEditor_ForegroundSecondColor">#40C4FF</Color>
    <Color x:Key="HexEditor_ForegroundOffSetHeaderColor">#B0B0B0</Color>
    <Color x:Key="HexEditor_SelectionFirstColor">#6600D9FF</Color>
    <Color x:Key="HexEditor_SelectionSecondColor">#3300D9FF</Color>
    <Color x:Key="HexEditor_ForegroundContrast">#FFFFFF</Color>
    <Color x:Key="HexEditor_ForegroundHighLightOffSetHeaderColor">#00D9FF</Color>
    <Color x:Key="HexEditor_AsciiForegroundColor">#B0B0B0</Color>
    <Color x:Key="HexEditor_StatusBarBackgroundColor">#252525</Color>
    <Color x:Key="HexEditor_StatusBarForegroundColor">#B0B0B0</Color>
    <Color x:Key="HexEditor_ScrollBarBackgroundColor">#1E1E1E</Color>
    <Color x:Key="HexEditor_ScrollBarThumbColor">#555555</Color>
    <Color x:Key="HexEditor_ByteModifiedColor">#FFD600</Color>
    <Color x:Key="HexEditor_HighLightColor">#FFD700</Color>
    <Color x:Key="HexEditor_AutoHighLiteSelectionByteBrush">#0099CC</Color>
    <Color x:Key="HexEditor_TblDteColor">#FF5252</Color>
    <Color x:Key="HexEditor_TblMteColor">#00E676</Color>
    <Color x:Key="HexEditor_TblEndBlockColor">#FFD600</Color>
    <Color x:Key="HexEditor_TblEndLineColor">#FFD600</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="DockBackgroundBrush" Color="{StaticResource DockBackgroundColor}" />
    <SolidColorBrush x:Key="DockBorderBrush" Color="{StaticResource DockBorderColor}" />
    <SolidColorBrush x:Key="DockTabActiveBrush" Color="{StaticResource DockTabActiveColor}" />
    <SolidColorBrush x:Key="DockTabInactiveBrush" Color="{StaticResource DockTabInactiveColor}" />
    <SolidColorBrush x:Key="DockTabHoverBrush" Color="{StaticResource DockTabHoverColor}" />
    <SolidColorBrush x:Key="DockTabTextBrush" Color="{StaticResource DockTabTextColor}" />
    <SolidColorBrush x:Key="DockTabActiveTextBrush" Color="{StaticResource DockTabActiveTextColor}" />
    <SolidColorBrush x:Key="DockSplitterBrush" Color="{StaticResource DockSplitterColor}" />
    <SolidColorBrush x:Key="DockDocumentHostBorderBrush" Color="{StaticResource DockDocumentHostBorderColor}" />
    <SolidColorBrush x:Key="DockMenuBackgroundBrush" Color="{StaticResource DockMenuBackgroundColor}" />
    <SolidColorBrush x:Key="DockMenuForegroundBrush" Color="{StaticResource DockMenuForegroundColor}" />
    <SolidColorBrush x:Key="DockMenuHighlightBrush" Color="{StaticResource DockMenuHighlightColor}" />
    <SolidColorBrush x:Key="DockMenuBorderBrush" Color="{StaticResource DockMenuBorderColor}" />
    <SolidColorBrush x:Key="DockMenuHighlightBorderBrush" Color="{StaticResource DockMenuHighlightBorderColor}" />
    <SolidColorBrush x:Key="DockToolBarBackgroundBrush" Color="{StaticResource DockToolBarBackgroundColor}" />
    <SolidColorBrush x:Key="DockWindowBackgroundBrush" Color="{StaticResource DockWindowBackgroundColor}" />

    <!-- VS-style title bar button -->
    <Style x:Key="DockTitleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource DockTabTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="2"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window title bar button -->
    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Cursor" Value="Arrow"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window title bar close button — red hover -->
    <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F1707A"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ParsedFieldsPanel (PFP) Theme Resources -->

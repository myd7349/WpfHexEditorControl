    <SolidColorBrush x:Key="PFP_ValueBrush" Color="#40C4FF"/>
    <SolidColorBrush x:Key="PFP_AccentBrush" Color="#00D9FF"/>
    <SolidColorBrush x:Key="PFP_ItemHoverBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="PFP_ItemSelectedForegroundBrush" Color="#A0E6FF"/>
    <SolidColorBrush x:Key="PFP_ItemSelectedBorderBrush" Color="#00D9FF"/>
    <SolidColorBrush x:Key="PFP_ComputedSectionBackgroundBrush" Color="#001A26"/>
    <SolidColorBrush x:Key="PFP_ComputedSectionBorderBrush" Color="#003D60"/>
    <SolidColorBrush x:Key="PFP_ComputedTitleBrush" Color="#00D9FF"/>
    <SolidColorBrush x:Key="PFP_ComputedIconBrush" Color="#00D9FF"/>
    <SolidColorBrush x:Key="PFP_ComputedValueBrush" Color="#40E0FF"/>
    <SolidColorBrush x:Key="PFP_InsightSectionBackgroundBrush" Color="#1A1A00"/>
    <SolidColorBrush x:Key="PFP_InsightSectionBorderBrush" Color="#3A3A00"/>
    <SolidColorBrush x:Key="PFP_InsightTitleBrush" Color="#FFD600"/>
    <SolidColorBrush x:Key="PFP_InputBorderBrush" Color="#555555"/>
    <SolidColorBrush x:Key="PFP_GroupBadgeBackgroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="PFP_CoverageTrackBrush" Color="#333333"/>

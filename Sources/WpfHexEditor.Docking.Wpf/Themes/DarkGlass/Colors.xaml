    <Color x:Key="PFP_ItemSelectedHoverStartColor">#00394D</Color>
    <Color x:Key="PFP_ItemSelectedHoverEndColor">#004D66</Color>
    <LinearGradientBrush x:Key="PFP_TitleBarBrush" StartPoint="0,0" EndPoint="1,0">

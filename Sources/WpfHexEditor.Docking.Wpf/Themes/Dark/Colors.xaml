    <SolidColorBrush x:Key="PFP_ComputedSectionBackgroundBrush" Color="#1A2A3A"/>
    <SolidColorBrush x:Key="PFP_ComputedSectionBorderBrush" Color="#2A4A6A"/>
    <SolidColorBrush x:Key="PFP_ComputedTitleBrush" Color="#4FC3F7"/>
    <SolidColorBrush x:Key="PFP_ComputedIconBrush" Color="#4FC3F7"/>
    <SolidColorBrush x:Key="PFP_ComputedValueBrush" Color="#81D4FA"/>
    <SolidColorBrush x:Key="PFP_InsightSectionBackgroundBrush" Color="#2A2A1A"/>
    <SolidColorBrush x:Key="PFP_InsightSectionBorderBrush" Color="#4A4A2A"/>
    <SolidColorBrush x:Key="PFP_InsightTitleBrush" Color="#FFB74D"/>

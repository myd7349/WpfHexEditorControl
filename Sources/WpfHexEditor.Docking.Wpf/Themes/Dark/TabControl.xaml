<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DocumentTabHost: tab strip at TOP (VS2022 document area style) -->
    <Style x:Key="DocumentTabHostStyle" TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{DynamicResource DockMenuBackgroundBrush}"
                                BorderBrush="{DynamicResource DockBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TabPanel Panel.IsItemsHost="True"
                                      Background="Transparent"
                                      Margin="4,2,4,0" />
                        </Border>
                        <ContentPresenter Grid.Row="1"
                                          x:Name="PART_SelectedContentHost"
                                          ContentSource="SelectedContent"
                                          KeyboardNavigation.TabNavigation="Local"
                                          KeyboardNavigation.DirectionalNavigation="Contained" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DockTabControl: content area top, tab strip at bottom -->
    <Style x:Key="DockTabControlStyle" TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{DynamicResource DockBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ContentPresenter Grid.Row="0"
                                          x:Name="PART_SelectedContentHost"
                                          ContentSource="SelectedContent"
                                          KeyboardNavigation.TabNavigation="Local"
                                          KeyboardNavigation.DirectionalNavigation="Contained" />
                        <Border Grid.Row="1"
                                Background="{DynamicResource DockMenuBackgroundBrush}"
                                BorderBrush="{DynamicResource DockBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <TabPanel Panel.IsItemsHost="True"
                                      Background="Transparent"
                                      Margin="4,2,4,2" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DockTabItem: rounded top corners, themed active/hover states -->
    <Style x:Key="DockTabItemStyle" TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="{DynamicResource DockTabTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4,8,4" />
        <Setter Property="Margin" Value="0,1,1,0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Border x:Name="TabBorder"
                            Background="Transparent"
                            CornerRadius="3,3,0,0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter ContentSource="Header"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Background"
                                    Value="{DynamicResource DockTabActiveBrush}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource DockTabActiveTextBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TabBorder" Property="Background"
                                    Value="{DynamicResource DockTabHoverBrush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cyberpunk Theme — Neon Pink/Purple/Cyan accents -->

    <!-- Core UI -->
    <Color x:Key="DockBackgroundColor">#0A0E27</Color>
    <Color x:Key="DockBorderColor">#8B00FF</Color>
    <Color x:Key="DockTabActiveColor">#FF006E</Color>
    <Color x:Key="DockTabInactiveColor">#141B3D</Color>
    <Color x:Key="DockTabHoverColor">#2A3759</Color>
    <Color x:Key="DockTabTextColor">#A0AED9</Color>
    <Color x:Key="DockTabActiveTextColor">#FFFFFF</Color>
    <Color x:Key="DockSplitterColor">#2E3A5F</Color>
    <Color x:Key="DockOverlayColor">#40FF006E</Color>
    <Color x:Key="DockDocumentHostBorderColor">#FF006E</Color>

    <!-- Menu / toolbar -->
    <Color x:Key="DockMenuBackgroundColor">#141B3D</Color>
    <Color x:Key="DockMenuForegroundColor">#E0E7FF</Color>
    <Color x:Key="DockMenuHighlightColor">#2A3759</Color>
    <Color x:Key="DockMenuBorderColor">#8B00FF</Color>
    <Color x:Key="DockMenuHighlightBorderColor">#BB77FF</Color>
    <Color x:Key="DockToolBarBackgroundColor">#141B3D</Color>
    <Color x:Key="DockWindowBackgroundColor">#0A0E27</Color>

    <!-- HexEditor Colors -->
    <Color x:Key="HexEditor_BackgroundColor">#0A0E27</Color>
    <Color x:Key="HexEditor_HeaderBackgroundColor">#141B3D</Color>
    <Color x:Key="HexEditor_HeaderForegroundColor">#A0AED9</Color>
    <Color x:Key="HexEditor_ColumnSeparatorColor">#2E3A5F</Color>
    <Color x:Key="HexEditor_ForegroundFirstColor">#E0E7FF</Color>
    <Color x:Key="HexEditor_ForegroundSecondColor">#00F0FF</Color>
    <Color x:Key="HexEditor_ForegroundOffSetHeaderColor">#A0AED9</Color>
    <Color x:Key="HexEditor_SelectionFirstColor">#66FF006E</Color>
    <Color x:Key="HexEditor_SelectionSecondColor">#668B00FF</Color>
    <Color x:Key="HexEditor_ForegroundContrast">#FFFFFF</Color>
    <Color x:Key="HexEditor_ForegroundHighLightOffSetHeaderColor">#00F0FF</Color>
    <Color x:Key="HexEditor_AsciiForegroundColor">#A0AED9</Color>
    <Color x:Key="HexEditor_StatusBarBackgroundColor">#141B3D</Color>
    <Color x:Key="HexEditor_StatusBarForegroundColor">#A0AED9</Color>
    <Color x:Key="HexEditor_ScrollBarBackgroundColor">#0D1230</Color>
    <Color x:Key="HexEditor_ScrollBarThumbColor">#3E4A70</Color>
    <Color x:Key="HexEditor_ByteModifiedColor">#FFBE0B</Color>
    <Color x:Key="HexEditor_HighLightColor">#FFBE0B</Color>
    <Color x:Key="HexEditor_AutoHighLiteSelectionByteBrush">#8B00FF</Color>
    <Color x:Key="HexEditor_TblDteColor">#FF006E</Color>
    <Color x:Key="HexEditor_TblMteColor">#00FF9F</Color>
    <Color x:Key="HexEditor_TblEndBlockColor">#FFBE0B</Color>
    <Color x:Key="HexEditor_TblEndLineColor">#00F0FF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="DockBackgroundBrush" Color="{StaticResource DockBackgroundColor}" />
    <SolidColorBrush x:Key="DockBorderBrush" Color="{StaticResource DockBorderColor}" />
    <SolidColorBrush x:Key="DockTabActiveBrush" Color="{StaticResource DockTabActiveColor}" />
    <SolidColorBrush x:Key="DockTabInactiveBrush" Color="{StaticResource DockTabInactiveColor}" />
    <SolidColorBrush x:Key="DockTabHoverBrush" Color="{StaticResource DockTabHoverColor}" />
    <SolidColorBrush x:Key="DockTabTextBrush" Color="{StaticResource DockTabTextColor}" />
    <SolidColorBrush x:Key="DockTabActiveTextBrush" Color="{StaticResource DockTabActiveTextColor}" />
    <SolidColorBrush x:Key="DockSplitterBrush" Color="{StaticResource DockSplitterColor}" />
    <SolidColorBrush x:Key="DockDocumentHostBorderBrush" Color="{StaticResource DockDocumentHostBorderColor}" />
    <SolidColorBrush x:Key="DockMenuBackgroundBrush" Color="{StaticResource DockMenuBackgroundColor}" />
    <SolidColorBrush x:Key="DockMenuForegroundBrush" Color="{StaticResource DockMenuForegroundColor}" />
    <SolidColorBrush x:Key="DockMenuHighlightBrush" Color="{StaticResource DockMenuHighlightColor}" />
    <SolidColorBrush x:Key="DockMenuBorderBrush" Color="{StaticResource DockMenuBorderColor}" />
    <SolidColorBrush x:Key="DockMenuHighlightBorderBrush" Color="{StaticResource DockMenuHighlightBorderColor}" />
    <SolidColorBrush x:Key="DockToolBarBackgroundBrush" Color="{StaticResource DockToolBarBackgroundColor}" />
    <SolidColorBrush x:Key="DockWindowBackgroundBrush" Color="{StaticResource DockWindowBackgroundColor}" />

    <!-- VS-style title bar button -->
    <Style x:Key="DockTitleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource DockTabTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="2"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window title bar button -->
    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Cursor" Value="Arrow"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockTabActiveBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window title bar close button — red hover -->
    <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F1707A"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

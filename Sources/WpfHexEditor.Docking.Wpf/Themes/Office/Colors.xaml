    <SolidColorBrush x:Key="PP_CategoryHeaderBackgroundBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="PP_CategoryHeaderForegroundBrush" Color="#323130"/>
    <SolidColorBrush x:Key="PP_SelectedEntryBrush"           Color="#CCE4F7"/>
    <SolidColorBrush x:Key="PP_DescriptionBackgroundBrush"   Color="#F3F3F3"/>
    <SolidColorBrush x:Key="PP_DescriptionForegroundBrush"   Color="#605E5C"/>
    <SolidColorBrush x:Key="PP_EditableForegroundBrush"      Color="#0078D4"/>
    <SolidColorBrush x:Key="PP_BorderBrush"                  Color="#E1DFDD"/>
</ResourceDictionary>

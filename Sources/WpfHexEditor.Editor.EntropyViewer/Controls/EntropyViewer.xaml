<UserControl x:Class="WpfHexEditor.Editor.EntropyViewer.Controls.EntropyViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource TE_Background}"
             Focusable="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Background="{DynamicResource TE_LineNumberBackground}">
            <TextBlock Text="Window:" VerticalAlignment="Center" Padding="4,0"
                       Foreground="{DynamicResource TE_LineNumberForeground}"/>
            <ComboBox x:Name="WindowSizeCombo" Width="80"
                      SelectionChanged="OnWindowSizeChanged">
                <ComboBoxItem Content="256 B"   Tag="256"  />
                <ComboBoxItem Content="512 B"   Tag="512"  />
                <ComboBoxItem Content="1 KB"    Tag="1024" IsSelected="True"/>
                <ComboBoxItem Content="4 KB"    Tag="4096" />
                <ComboBoxItem Content="16 KB"   Tag="16384"/>
            </ComboBox>
            <Separator/>
            <TextBlock x:Name="EntropyText" Text="—" VerticalAlignment="Center" Padding="4,0"
                       Foreground="{DynamicResource TE_LineNumberForeground}"/>
        </ToolBar>

        <!-- Charts area -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource TE_Background}">
            <StackPanel>
                <!-- Entropy chart header -->
                <TextBlock Text="Entropy by region" Margin="8,8,8,2"
                           Foreground="{DynamicResource TE_LineNumberForeground}"
                           FontSize="11"/>
                <Border Margin="8,0,8,0" BorderThickness="1"
                        BorderBrush="{DynamicResource TE_LineNumberBackground}">
                    <Canvas x:Name="EntropyCanvas" Height="80"
                            Background="{DynamicResource TE_Background}"
                            MouseMove="EntropyCanvas_MouseMove" />
                </Border>

                <!-- Byte distribution header -->
                <TextBlock Text="Byte distribution (0x00–0xFF)" Margin="8,10,8,2"
                           Foreground="{DynamicResource TE_LineNumberForeground}"
                           FontSize="11"/>
                <Border Margin="8,0,8,0" BorderThickness="1"
                        BorderBrush="{DynamicResource TE_LineNumberBackground}">
                    <Canvas x:Name="FreqCanvas" Height="100"
                            Background="{DynamicResource TE_Background}" />
                </Border>

                <!-- Statistics text -->
                <TextBlock x:Name="StatsText" Margin="8,10,8,8"
                           Foreground="{DynamicResource TE_Foreground}"
                           FontFamily="Consolas, Courier New"
                           FontSize="11"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <StatusBar Grid.Row="2"
                   Background="{DynamicResource TE_LineNumberBackground}"
                   Foreground="{DynamicResource TE_LineNumberForeground}"
                   Height="22">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="—" Padding="4,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>

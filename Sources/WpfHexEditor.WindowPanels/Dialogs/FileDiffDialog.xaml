<Window x:Class="WpfHexEditor.WindowPanels.Dialogs.FileDiffDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="File Comparison - Diff Mode"
        Height="700" Width="1200"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <Window.Resources>
        <!-- Diff Type Colors -->
        <SolidColorBrush x:Key="ModifiedBrush" Color="#FFFACD"/>
        <SolidColorBrush x:Key="DeletedBrush" Color="#FFB6C1"/>
        <SolidColorBrush x:Key="AddedBrush" Color="#98FB98"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="⚖️"
                           FontSize="24"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="File Comparison - Side by Side"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="SubtitleTextBlock"
                               Text="Compare two files and navigate differences"
                               FontSize="11"
                               Foreground="#E0E0E0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Navigation Toolbar -->
        <Border Grid.Row="1"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="PrevDiffButton"
                            Content="◀ Previous"
                            Padding="10,5"
                            Margin="0,0,5,0"
                            Click="PrevDiffButton_Click"
                            ToolTip="Go to previous difference (F7)"/>

                    <Button x:Name="NextDiffButton"
                            Content="Next ▶"
                            Padding="10,5"
                            Margin="0,0,15,0"
                            Click="NextDiffButton_Click"
                            ToolTip="Go to next difference (F8)"/>

                    <TextBlock x:Name="DiffCounterTextBlock"
                               Text="Difference 0 of 0"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"
                               FontWeight="Bold"/>

                    <Button x:Name="ExportReportButton"
                            Content="📄 Export Report"
                            Padding="10,5"
                            Click="ExportReportButton_Click"
                            ToolTip="Export difference report to text file"/>
                </StackPanel>

                <!-- Statistics -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Background="{StaticResource ModifiedBrush}"
                            Padding="8,3"
                            CornerRadius="3"
                            Margin="0,0,5,0">
                        <TextBlock>
                            <Run Text="Modified:"/>
                            <Run x:Name="ModifiedCountRun" Text="0" FontWeight="Bold"/>
                        </TextBlock>
                    </Border>

                    <Border Background="{StaticResource DeletedBrush}"
                            Padding="8,3"
                            CornerRadius="3"
                            Margin="0,0,5,0">
                        <TextBlock>
                            <Run Text="Deleted:"/>
                            <Run x:Name="DeletedCountRun" Text="0" FontWeight="Bold"/>
                        </TextBlock>
                    </Border>

                    <Border Background="{StaticResource AddedBrush}"
                            Padding="8,3"
                            CornerRadius="3">
                        <TextBlock>
                            <Run Text="Added:"/>
                            <Run x:Name="AddedCountRun" Text="0" FontWeight="Bold"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Side-by-Side Hex Editors -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- File 1 Panel -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1"
                    Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- File 1 Header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="0,0,0,1"
                            Padding="10,8">
                        <TextBlock x:Name="File1NameTextBlock"
                                   Text="File 1"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                    </Border>

                    <!-- HexEditor placeholder (will be added programmatically) -->
                    <Grid x:Name="File1EditorContainer" Grid.Row="1"/>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="3"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>

            <!-- File 2 Panel -->
            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1"
                    Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- File 2 Header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="0,0,0,1"
                            Padding="10,8">
                        <TextBlock x:Name="File2NameTextBlock"
                                   Text="File 2"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                    </Border>

                    <!-- HexEditor placeholder (will be added programmatically) -->
                    <Grid x:Name="File2EditorContainer" Grid.Row="1"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Row="3"
                      Height="3"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>

        <!-- Differences List -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- List Header -->
                <Border Grid.Row="0"
                        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        BorderThickness="0,0,0,1"
                        Padding="10,6">
                    <TextBlock Text="📋 Differences List"
                               FontWeight="Bold"
                               FontSize="12"/>
                </Border>

                <!-- DataGrid -->
                <DataGrid x:Name="DifferencesDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          SelectionChanged="DifferencesDataGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Offset"
                                            Binding="{Binding Offset, StringFormat='{}{0:X8}'}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding Type}"
                                            Width="120"/>
                        <DataGridTextColumn Header="Length"
                                            Binding="{Binding Length}"
                                            Width="80"/>
                        <DataGridTextColumn Header="File 1 Bytes"
                                            Width="*"
                                            Binding="{Binding BytesFile1}"/>
                        <DataGridTextColumn Header="File 2 Bytes"
                                            Width="*"
                                            Binding="{Binding BytesFile2}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Bottom Buttons -->
        <Border Grid.Row="5"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,1,0,0"
                Padding="10,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SyncScrollingCheckBox"
                        Content="🔗 Sync Scrolling"
                        Padding="10,5"
                        Margin="0,0,10,0"
                        Click="SyncScrollingCheckBox_Click"/>

                <Button Content="Close"
                        Padding="15,5"
                        IsCancel="True"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

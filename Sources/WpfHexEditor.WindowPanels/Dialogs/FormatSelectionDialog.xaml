<Window x:Class="WpfHexEditor.WindowPanels.Dialogs.FormatSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfHexEditor.WindowPanels.Dialogs"
        mc:Ignorable="d"
        Title="Format Selection"
        Height="500" Width="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F0F0F0">

    <Window.Resources>
        <!-- Converters -->
        <local:ConfidenceToPercentageConverter x:Key="ConfidenceConverter"/>
        <local:NullToBooleanConverter x:Key="NullToBooleanConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Multiple File Formats Detected"
                       FontSize="16"
                       FontWeight="Bold"/>
            <TextBlock x:Name="MessageText"
                       Text="Multiple file formats match this file. Please select the most appropriate format:"
                       TextWrapping="Wrap"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Info Panel -->
        <Border Grid.Row="1"
                Background="#F5F5F5"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="ℹ️ Tip: Higher confidence scores indicate a better match."
                           FontSize="12"
                           Foreground="#555555"/>
                <TextBlock Text="Select the format that best matches your file type."
                           FontSize="12"
                           Foreground="#555555"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Candidates List -->
        <ListView x:Name="CandidatesListView"
                  Grid.Row="2"
                  SelectionMode="Single"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1"
                            Padding="10"
                            Background="Transparent">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Format Name -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="{Binding Format.FormatName}"
                                           FontSize="14"
                                           FontWeight="Bold"/>
                                <TextBlock Text="{Binding Format.Category}"
                                           FontSize="12"
                                           Foreground="#666666"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Confidence Score -->
                            <Grid Grid.Row="1" Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ProgressBar Grid.Column="0"
                                             Value="{Binding ConfidenceScore, Converter={StaticResource ConfidenceConverter}}"
                                             Height="20"
                                             Minimum="0"
                                             Maximum="100"
                                             Foreground="#2196F3"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding ConfidenceScore, StringFormat={}{0:P0}}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Detection Tier -->
                            <TextBlock Grid.Row="2"
                                       Margin="0,5,0,0"
                                       FontSize="11"
                                       Foreground="#888888">
                                <Run Text="Tier:"/>
                                <Run Text="{Binding Tier}" FontWeight="SemiBold"/>
                                <Run Text=" • "/>
                                <Run Text="{Binding Blocks.Count}" FontWeight="SemiBold"/>
                                <Run Text="blocks parsed"/>
                            </TextBlock>

                            <!-- Confidence Factors -->
                            <ItemsControl Grid.Row="3"
                                          ItemsSource="{Binding ConfidenceFactors}"
                                          Margin="0,5,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="11"
                                                   Foreground="#666666"
                                                   Margin="15,1,0,1">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding}"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="SelectButton"
                    Content="Select Format"
                    Width="120"
                    Height="30"
                    Margin="0,0,10,0"
                    IsDefault="True"
                    IsEnabled="{Binding SelectedItem, ElementName=CandidatesListView, Converter={StaticResource NullToBooleanConverter}}"
                    Click="SelectButton_Click"/>

            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="100"
                    Height="30"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

<UserControl x:Class="WpfHexEditor.WindowPanels.Panels.EnrichedFormatInfoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="350">

    <UserControl.Resources>
        <SolidColorBrush x:Key="HeaderBrush" Color="#4A90E2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7ED321"/>
        <SolidColorBrush x:Key="PriorityBadgeBrush" Color="#FF6B6B"/>
        <SolidColorBrush x:Key="SectionBackgroundBrush" Color="#F8F9FA"/>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource HeaderBrush}"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource SectionBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12" x:Name="MainPanel">

                <!-- Header Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="HeaderCard">
                    <StackPanel>
                        <!-- Format Name with Priority Badge -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       x:Name="FormatNameTextBlock"
                                       Text="Format Name"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>

                            <!-- Priority Badge -->
                            <Border Grid.Column="1"
                                    x:Name="PriorityBadge"
                                    Background="{StaticResource PriorityBadgeBrush}"
                                    CornerRadius="3"
                                    Padding="6,2"
                                    Margin="8,0,0,0"
                                    Visibility="Collapsed">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="280">
                                            <TextBlock Text="Priority Format" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock TextWrapping="Wrap">
                                                This is one of the most commonly used file formats (Top 100).
                                                Format definition has been manually refined for maximum accuracy.
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <TextBlock Text="⭐ Priority"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </Grid>

                        <TextBlock x:Name="CategoryTextBlock"
                                   Text="Category"
                                   FontSize="10"
                                   FontStyle="Italic"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource HeaderBrush}"/>

                        <TextBlock x:Name="DescriptionTextBlock"
                                   Text="Description"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>

                        <!-- Quality Score with Tooltip -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="300">
                                        <TextBlock Text="Quality Score (0-100%)" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
                                            Indicates the completeness of this format definition based on:
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" Margin="4,0,0,2">• Number of fields defined</TextBlock>
                                        <TextBlock TextWrapping="Wrap" Margin="4,0,0,2">• Enriched metadata (software, use cases)</TextBlock>
                                        <TextBlock TextWrapping="Wrap" Margin="4,0,0,2">• Technical specifications and references</TextBlock>
                                        <TextBlock TextWrapping="Wrap" Margin="4,0,0,6">• Validation rules</TextBlock>
                                        <TextBlock TextWrapping="Wrap" FontStyle="Italic" Foreground="Gray">
                                            Higher scores mean more detailed and reliable format analysis.
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Grid.ToolTip>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Quality:"
                                       Style="{StaticResource InfoLabelStyle}"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                    Height="8"
                                    Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                                    CornerRadius="4"
                                    Margin="0,0,8,0">
                                <Border x:Name="QualityScoreBar"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource AccentBrush}"
                                        CornerRadius="4"/>
                            </Border>

                            <TextBlock Grid.Column="2"
                                       x:Name="QualityScoreText"
                                       Text="0%"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Documentation Level -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="280">
                                        <TextBlock Text="Documentation Level" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                                            • Basic: Magic bytes only
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                                            • Standard: Main header fields
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                                            • Detailed: Extended fields + metadata
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap">
                                            • Comprehensive: Complete specification
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </Grid.ToolTip>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Documentation:"
                                       Style="{StaticResource InfoLabelStyle}"/>

                            <TextBlock Grid.Column="1"
                                       x:Name="DocumentationLevelTextBlock"
                                       Text="basic"
                                       Style="{StaticResource InfoValueStyle}"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Extensions Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="ExtensionsCard">
                    <StackPanel>
                        <TextBlock Text="File Extensions" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="ExtensionsTextBlock"
                                   Text="N/A"
                                   Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- MIME Types Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="MimeTypesCard">
                    <StackPanel>
                        <TextBlock Text="MIME Types" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="MimeTypesTextBlock"
                                   Text="N/A"
                                   Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Software Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="SoftwareCard">
                    <StackPanel>
                        <TextBlock Text="Compatible Software" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="SoftwareTextBlock"
                                   Text="N/A"
                                   Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Use Cases Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="UseCasesCard">
                    <StackPanel>
                        <TextBlock Text="Common Use Cases" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="UseCasesTextBlock"
                                   Text="N/A"
                                   Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- References Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="ReferencesCard">
                    <StackPanel>
                        <TextBlock Text="📚 References &amp; Documentation" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Specifications Section -->
                        <StackPanel x:Name="SpecificationsSection" Margin="0,4,0,0">
                            <TextBlock Text="Specifications:"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="SpecificationsTextBlock"
                                       Text="N/A"
                                       Style="{StaticResource InfoValueStyle}"
                                       Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- Web Links Section -->
                        <StackPanel x:Name="WebLinksSection" Margin="0,8,0,0">
                            <TextBlock Text="Documentation:"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       Margin="0,0,0,4"/>
                            <StackPanel x:Name="WebLinksStackPanel" Margin="8,0,0,0">
                                <!-- Web links will be added dynamically -->
                            </StackPanel>
                        </StackPanel>

                        <!-- No References Message -->
                        <TextBlock x:Name="NoReferencesTextBlock"
                                   Text="No references available for this format"
                                   FontSize="10"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Technical Details Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="TechnicalDetailsCard">
                    <StackPanel>
                        <TextBlock Text="⚙️ Technical Details" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="TechnicalDetailsTextBlock"
                                   Text="N/A"
                                   Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Related Formats Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="RelatedFormatsCard">
                    <StackPanel>
                        <TextBlock Text="🔗 Related Formats" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="RelatedFormatsTextBlock"
                                   Text="N/A"
                                   Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Author & Version Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="AuthorVersionCard">
                    <StackPanel>
                        <TextBlock Text="👤 Definition Info" Style="{StaticResource SectionHeaderStyle}"/>

                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Version:"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="VersionTextBlock"
                                       Text="N/A"
                                       Style="{StaticResource InfoValueStyle}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Author:"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="AuthorTextBlock"
                                       Text="N/A"
                                       Style="{StaticResource InfoValueStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Detection Info Card -->
                <Border Style="{StaticResource CardStyle}" x:Name="DetectionInfoCard">
                    <StackPanel>
                        <TextBlock Text="🔍 Detection Details" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Signature -->
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Signature:"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="SignatureHexTextBlock"
                                       Text="N/A"
                                       Style="{StaticResource InfoValueStyle}"
                                       FontFamily="Consolas"/>
                        </Grid>

                        <!-- Offset -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Offset:"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="OffsetDisplayTextBlock"
                                       Text="N/A"
                                       Style="{StaticResource InfoValueStyle}"
                                       FontFamily="Consolas"/>
                        </Grid>

                        <!-- Required -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Required:"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="RequiredDisplayTextBlock"
                                       Text="N/A"
                                       Style="{StaticResource InfoValueStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- No Format Message -->
                <Border x:Name="NoFormatMessage"
                        Style="{StaticResource CardStyle}"
                        Padding="24"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No format detected"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,4"/>
                        <TextBlock Text="Open a file to view format information"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

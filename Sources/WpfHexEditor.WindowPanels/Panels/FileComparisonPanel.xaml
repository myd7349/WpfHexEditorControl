<UserControl x:Class="WpfHexEditor.WindowPanels.Panels.FileComparisonPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="DiffAddedStyle" TargetType="Border">
            <Setter Property="Background" Value="#E8F5E9"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
        </Style>

        <Style x:Key="DiffRemovedStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFEBEE"/>
            <Setter Property="BorderBrush" Value="#F44336"/>
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
        </Style>

        <Style x:Key="DiffModifiedStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF3E0"/>
            <Setter Property="BorderBrush" Value="#FF9800"/>
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="⚖️ File Comparison"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="ComparisonInfoText"
                               Text="Select files to compare"
                               FontSize="10"
                               Foreground="Gray"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Load File 1..." Width="100" Height="28" Margin="0,0,8,0" Click="LoadFile1_Click"/>
                    <Button Content="Load File 2..." Width="100" Height="28" Click="LoadFile2_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Comparison View -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- File 1 -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#E3F2FD"
                            Padding="8,6">
                        <TextBlock x:Name="File1NameText"
                                   Text="File 1"
                                   FontWeight="SemiBold"
                                   FontSize="11"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="File1Fields" Padding="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4" Margin="0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Removed">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                        <Setter Property="BorderBrush" Value="#F44336"/>
                                                        <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Modified">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                        <Setter Property="BorderBrush" Value="#FF9800"/>
                                                        <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="10"/>
                                            <TextBlock Text="{Binding Value}" FontFamily="Consolas" FontSize="9" Foreground="Gray"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Diff Legend -->
            <Border Grid.Column="1" Width="40" Background="#F5F5F5" Padding="4">
                <StackPanel VerticalAlignment="Center">
                    <Border Background="#E8F5E9" Width="30" Height="30" Margin="0,4" CornerRadius="4" ToolTip="Added"/>
                    <TextBlock Text="+" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#4CAF50"/>

                    <Border Background="#FFF3E0" Width="30" Height="30" Margin="0,8,0,4" CornerRadius="4" ToolTip="Modified"/>
                    <TextBlock Text="≠" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FF9800"/>

                    <Border Background="#FFEBEE" Width="30" Height="30" Margin="0,8,0,4" CornerRadius="4" ToolTip="Removed"/>
                    <TextBlock Text="-" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#F44336"/>
                </StackPanel>
            </Border>

            <!-- File 2 -->
            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#E8F5E9"
                            Padding="8,6">
                        <TextBlock x:Name="File2NameText"
                                   Text="File 2"
                                   FontWeight="SemiBold"
                                   FontSize="11"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="File2Fields" Padding="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4" Margin="0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Added">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                        <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DiffStatus}" Value="Modified">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                        <Setter Property="BorderBrush" Value="#FF9800"/>
                                                        <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="10"/>
                                            <TextBlock Text="{Binding Value}" FontFamily="Consolas" FontSize="9" Foreground="Gray"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="MatchingFieldsText" Text="Matching: 0" FontSize="10" Margin="0,0,16,0" Foreground="Green"/>
                <TextBlock x:Name="AddedFieldsText" Text="Added: 0" FontSize="10" Margin="0,0,16,0" Foreground="Green"/>
                <TextBlock x:Name="ModifiedFieldsText" Text="Modified: 0" FontSize="10" Margin="0,0,16,0" Foreground="Orange"/>
                <TextBlock x:Name="RemovedFieldsText" Text="Removed: 0" FontSize="10" Foreground="Red"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>

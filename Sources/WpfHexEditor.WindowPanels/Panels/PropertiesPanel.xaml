<UserControl x:Class="WpfHexEditor.WindowPanels.Panels.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core;assembly=WpfHexEditor.Editor.Core"
             Background="{DynamicResource PP_BackgroundBrush}"
             Foreground="{DynamicResource PP_ForegroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── ValueCell DataTemplateSelector picks the right template ───── -->

        <!-- Text (read-only) -->
        <DataTemplate x:Key="ReadOnlyTextTemplate" DataType="{x:Type ec:PropertyEntry}">
            <TextBlock Text="{Binding Value}"
                       Foreground="{DynamicResource PP_ForegroundBrush}"
                       VerticalAlignment="Center"
                       Padding="2,1"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding Value}"/>
        </DataTemplate>

        <!-- Text (editable) -->
        <DataTemplate x:Key="EditTextTemplate" DataType="{x:Type ec:PropertyEntry}">
            <TextBox x:Name="EditBox"
                     Text="{Binding Value, Mode=OneWay}"
                     Background="Transparent"
                     Foreground="{DynamicResource PP_EditableForegroundBrush}"
                     BorderBrush="{DynamicResource PP_BorderBrush}"
                     BorderThickness="0,0,0,1"
                     Padding="2,1"
                     LostFocus="OnTextBoxCommit"
                     KeyDown="OnTextBoxKeyDown"/>
        </DataTemplate>

        <!-- Integer / Hex (editable) -->
        <DataTemplate x:Key="EditIntegerTemplate" DataType="{x:Type ec:PropertyEntry}">
            <TextBox Text="{Binding Value, Mode=OneWay}"
                     Background="Transparent"
                     Foreground="{DynamicResource PP_EditableForegroundBrush}"
                     BorderBrush="{DynamicResource PP_BorderBrush}"
                     BorderThickness="0,0,0,1"
                     Padding="2,1"
                     LostFocus="OnTextBoxCommit"
                     KeyDown="OnTextBoxKeyDown"/>
        </DataTemplate>

        <!-- Boolean (CheckBox) -->
        <DataTemplate x:Key="BooleanTemplate" DataType="{x:Type ec:PropertyEntry}">
            <CheckBox IsChecked="{Binding Value, Mode=OneWay}"
                      IsEnabled="{Binding IsReadOnly, Converter={StaticResource BoolToVis}}"
                      Checked="OnCheckBoxChanged"
                      Unchecked="OnCheckBoxChanged"
                      VerticalAlignment="Center"/>
        </DataTemplate>

        <!-- Enum (ComboBox) -->
        <DataTemplate x:Key="EnumTemplate" DataType="{x:Type ec:PropertyEntry}">
            <ComboBox ItemsSource="{Binding AllowedValues}"
                      SelectedItem="{Binding Value, Mode=OneWay}"
                      IsEditable="False"
                      Background="{DynamicResource PP_BackgroundBrush}"
                      Foreground="{DynamicResource PP_EditableForegroundBrush}"
                      BorderBrush="{DynamicResource PP_BorderBrush}"
                      Padding="2,1"
                      SelectionChanged="OnComboBoxChanged"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>  <!-- context label -->
            <RowDefinition Height="*"/>   <!-- properties list -->
            <RowDefinition Height="60"/>  <!-- description area -->
        </Grid.RowDefinitions>

        <!-- ── Context label ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource PP_CategoryHeaderBackgroundBrush}"
                BorderBrush="{DynamicResource PP_BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock x:Name="ContextLabelText"
                       Text="Properties"
                       Foreground="{DynamicResource PP_CategoryHeaderForegroundBrush}"
                       VerticalAlignment="Center"
                       Padding="8,0"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ── Property groups ───────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="GroupsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type ec:PropertyGroup}">
                        <Expander IsExpanded="True"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <!-- Group header -->
                            <Expander.Header>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{DynamicResource PP_CategoryHeaderForegroundBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="11"
                                           Padding="4,2"/>
                            </Expander.Header>
                            <Expander.Style>
                                <Style TargetType="Expander">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Expander">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Border Grid.Row="0"
                                                            Background="{DynamicResource PP_CategoryHeaderBackgroundBrush}"
                                                            Cursor="Hand"
                                                            Padding="2,2">
                                                        <DockPanel>
                                                            <Path DockPanel.Dock="Left"
                                                                  x:Name="Arrow"
                                                                  Data="M 0,0 L 4,4 L 8,0"
                                                                  Stroke="{DynamicResource PP_CategoryHeaderForegroundBrush}"
                                                                  StrokeThickness="1.5"
                                                                  Margin="4,0,6,0"
                                                                  VerticalAlignment="Center"
                                                                  Width="8" Height="5"/>
                                                            <ContentPresenter ContentSource="Header"
                                                                              VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                    </Border>
                                                    <ContentPresenter Grid.Row="1"
                                                                      x:Name="ExpandSite"
                                                                      Visibility="Collapsed"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsExpanded" Value="True">
                                                        <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="Arrow" Property="Data" Value="M 0,0 L 4,4 L 8,0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsExpanded" Value="False">
                                                        <Setter TargetName="Arrow" Property="Data" Value="M 0,4 L 4,0 L 8,4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Expander.Style>

                            <!-- Entries grid -->
                            <ItemsControl ItemsSource="{Binding Entries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type ec:PropertyEntry}">
                                        <Border x:Name="EntryRow"
                                                BorderBrush="{DynamicResource PP_BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Cursor="Arrow"
                                                MouseLeftButtonDown="OnEntryRowClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource PP_SelectedEntryBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Name -->
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Name}"
                                                           Foreground="{DynamicResource PP_ForegroundBrush}"
                                                           VerticalAlignment="Center"
                                                           Padding="6,3,4,3"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Name}"/>

                                                <!-- Value (DataTemplateSelector in code-behind) -->
                                                <ContentPresenter Grid.Column="1"
                                                                  Content="{Binding}"
                                                                  Margin="2,1"
                                                                  ContentTemplateSelector="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=EntryTemplateSelector}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Description area ─────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource PP_DescriptionBackgroundBrush}"
                BorderBrush="{DynamicResource PP_BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <StackPanel>
                <TextBlock x:Name="DescNameText"
                           Text=""
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PP_ForegroundBrush}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="DescDetailText"
                           Text=""
                           Foreground="{DynamicResource PP_DescriptionForegroundBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

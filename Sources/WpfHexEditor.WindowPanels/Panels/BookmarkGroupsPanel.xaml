<UserControl x:Class="WpfHexEditor.WindowPanels.Panels.BookmarkGroupsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300">
    <UserControl.Resources>
        <!-- Color to Brush converter -->
        <Style x:Key="ColorRectangleStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="RadiusX" Value="2"/>
            <Setter Property="RadiusY" Value="2"/>
            <Setter Property="Stroke" Value="#AAAAAA"/>
            <Setter Property="StrokeThickness" Value="1"/>
        </Style>

        <Style x:Key="GroupItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Bookmark Groups" FontWeight="SemiBold" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Name="AddGroupButton" Content="+" Width="24" Height="24"
                            ToolTip="Add new group" Click="AddGroupButton_Click"
                            FontSize="14" FontWeight="Bold" Padding="0" Margin="0,0,4,0"/>
                    <Button Name="EditGroupButton" Content="✎" Width="24" Height="24"
                            ToolTip="Edit selected group" Click="EditGroupButton_Click"
                            FontSize="12" Padding="0" IsEnabled="False" Margin="0,0,4,0"/>
                    <Button Name="DeleteGroupButton" Content="×" Width="24" Height="24"
                            ToolTip="Delete selected group" Click="DeleteGroupButton_Click"
                            FontSize="16" FontWeight="Bold" Padding="0" Margin="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Groups List -->
        <ListBox Grid.Row="1" Name="GroupsListBox"
                 ItemContainerStyle="{StaticResource GroupItemStyle}"
                 SelectionChanged="GroupsListBox_SelectionChanged"
                 Margin="4">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Color indicator -->
                        <Rectangle Grid.Column="0" Style="{StaticResource ColorRectangleStyle}">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{Binding Color}"/>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Group info -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                            <TextBlock Text="{Binding Description}" FontSize="10"
                                       Foreground="#666666" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Visibility toggle -->
                        <CheckBox Grid.Column="2" IsChecked="{Binding IsVisible}"
                                  ToolTip="Show/Hide bookmarks in this group"
                                  Margin="4,0,0,0"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer with stats -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="8">
            <TextBlock Name="StatsTextBlock" Text="0 groups" FontSize="10" Foreground="#666666"/>
        </Border>
    </Grid>
</UserControl>
<UserControl x:Class="WpfHexEditor.WindowPanels.Panels.CustomParserTemplatePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Template List -->
        <Border Grid.Column="0"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,0,1,0"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="📝 Templates"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>

                <ListBox Grid.Row="1"
                         x:Name="TemplateListBox"
                         SelectionChanged="TemplateListBox_SelectionChanged"
                         DisplayMemberPath="Name"/>

                <StackPanel Grid.Row="2" Margin="0,8,0,0">
                    <Button Content="➕ New Template" Height="28" Margin="0,0,0,4" Click="NewTemplate_Click"/>
                    <Button Content="🗑️ Delete Template" Height="28" Click="DeleteTemplate_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Panel: Template Editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">

                <!-- Header -->
                <TextBlock Text="📋 Template Editor"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>

                <!-- Template Info -->
                <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TemplateNameBox" Style="{StaticResource InputBoxStyle}" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TemplateDescriptionBox" Style="{StaticResource InputBoxStyle}" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Extensions:" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TemplateExtensionsBox" Style="{StaticResource InputBoxStyle}" Margin="0,0,0,4"
                                 ToolTip="Comma-separated, e.g., .bin,.dat"/>

                        <Button Grid.Row="3" Grid.Column="1" Content="💾 Save Template" Height="28" Margin="0,8,0,0" Click="SaveTemplate_Click"/>
                    </Grid>
                </Border>

                <!-- Blocks Section -->
                <TextBlock Text="Format Blocks" Style="{StaticResource SectionHeaderStyle}"/>

                <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Blocks List -->
                        <DataGrid Grid.Row="0"
                                  x:Name="BlocksDataGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  Height="250"
                                  Margin="0,0,0,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                                <DataGridTextColumn Header="Offset" Binding="{Binding Offset}" Width="80"/>
                                <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="80"/>
                                <DataGridComboBoxColumn Header="Type" SelectedItemBinding="{Binding ValueType}" Width="100">
                                    <DataGridComboBoxColumn.ElementStyle>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="ItemsSource" Value="{Binding DataContext.ValueTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </Style>
                                    </DataGridComboBoxColumn.ElementStyle>
                                    <DataGridComboBoxColumn.EditingElementStyle>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="ItemsSource" Value="{Binding DataContext.ValueTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </Style>
                                    </DataGridComboBoxColumn.EditingElementStyle>
                                </DataGridComboBoxColumn>
                                <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="100"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Block Actions -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <Button Content="➕ Add Block" Width="100" Height="26" Margin="0,0,8,0" Click="AddBlock_Click"/>
                            <Button Content="🗑️ Remove Block" Width="120" Height="26" Click="RemoveBlock_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Apply Section -->
                <TextBlock Text="Apply to Current File" Style="{StaticResource SectionHeaderStyle}"/>

                <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Apply this template to parse the currently loaded file in the hex editor."
                                   FontSize="10"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                        <Button Content="✨ Apply Template to File" Height="32" Click="ApplyTemplate_Click" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- Export/Import Section -->
                <TextBlock Text="Export/Import" Style="{StaticResource SectionHeaderStyle}"/>

                <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="📤 Export to JSON" Width="130" Height="28" Margin="0,0,8,0" Click="ExportTemplate_Click"/>
                        <Button Content="📥 Import from JSON" Width="140" Height="28" Click="ImportTemplate_Click"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

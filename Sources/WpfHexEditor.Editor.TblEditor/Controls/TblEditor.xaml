<UserControl x:Class="WpfHexEditor.Editor.TblEditor.Controls.TblEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WpfHexEditor.Editor.TblEditor.ViewModels"
             xmlns:ct="clr-namespace:WpfHexEditor.Core.CharacterTable;assembly=WpfHexEditor.Core"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="700"
             KeyDown="UserControl_KeyDown"
             PreviewMouseWheel="UserControl_PreviewMouseWheel">

    <UserControl.Resources>
        <!-- Bool → Visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- DataGrid column header — VS IDE style (matches ErrorPanel GridViewColumnHeader) -->
        <Style x:Key="TblColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"                Value="{DynamicResource ERR_HeaderBrush}"/>
            <Setter Property="Foreground"                Value="{DynamicResource ERR_ForegroundBrush}"/>
            <Setter Property="BorderBrush"               Value="{DynamicResource ERR_GridLinesBrush}"/>
            <Setter Property="BorderThickness"           Value="0,0,1,1"/>
            <Setter Property="Padding"                   Value="6,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                    Value="Arrow"/>
            <Setter Property="SeparatorVisibility"       Value="Collapsed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border x:Name="HeaderBd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              SnapsToDevicePixels="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBd" Property="Background"
                                        Value="{DynamicResource ERR_HeaderHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderBd" Property="Background"
                                        Value="{DynamicResource ERR_HeaderPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Conflict / invalid row highlight (+ selection) -->
        <Style x:Key="ConflictRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource ERR_BackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ERR_ForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ERR_HoverRowBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ERR_SelectedRowBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ERR_ForegroundBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding HasConflict}" Value="True">
                    <Setter Property="Background" Value="#20FF6B00"/>
                    <Setter Property="ToolTip"    Value="Prefix conflict detected"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsValid}" Value="False">
                    <Setter Property="Background" Value="#20FF0000"/>
                    <Setter Property="ToolTip"    Value="{Binding ValidationError}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource ERR_BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Main DataGrid ─────────────────────────────────────────────── -->
        <DataGrid x:Name="EntriesGrid"
                  Grid.Row="0"
                  ItemsSource="{Binding FilteredEntries}"
                  SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  SelectionMode="Extended"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource ERR_BackgroundBrush}"
                  Foreground="{DynamicResource ERR_ForegroundBrush}"
                  RowBackground="{DynamicResource ERR_BackgroundBrush}"
                  AlternatingRowBackground="Transparent"
                  HorizontalGridLinesBrush="{DynamicResource ERR_GridLinesBrush}"
                  ColumnHeaderStyle="{StaticResource TblColumnHeaderStyle}"
                  RowStyle="{StaticResource ConflictRowStyle}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  CellEditEnding="EntriesGrid_CellEditEnding"
                  SelectionChanged="EntriesGrid_SelectionChanged"
                  ContextMenuOpening="EntriesGrid_ContextMenuOpening">

            <!-- ── Context menu ─────────────────────────────────────────── -->
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <!-- ── Group 1 : Entry editing ───────────────────── -->
                    <MenuItem x:Name="CtxAdd"
                              Header="Add Entry"
                              InputGestureText="Ctrl+Insert"
                              Click="CtxAdd_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxDuplicate"
                              Header="Duplicate Entry"
                              Click="CtxDuplicate_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE780;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxDelete"
                              Header="Delete"
                              InputGestureText="Delete"
                              Click="CtxDelete_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>

                    <!-- ── Group 2 : Clipboard ───────────────────────── -->
                    <MenuItem x:Name="CtxCut"
                              Header="Cut"
                              InputGestureText="Ctrl+X"
                              Click="CtxCut_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxCopy"
                              Header="Copy"
                              InputGestureText="Ctrl+C"
                              Click="CtxCopy_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxPaste"
                              Header="Paste"
                              InputGestureText="Ctrl+V"
                              Click="CtxPaste_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>

                    <!-- ── Group 3 : Navigation / search ────────────── -->
                    <MenuItem x:Name="CtxFind"
                              Header="Find…"
                              InputGestureText="Ctrl+F"
                              Click="CtxFind_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxSelectAll"
                              Header="Select All"
                              InputGestureText="Ctrl+A"
                              Click="CtxSelectAll_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE73B;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>

                    <!-- ── Group 4 : Validation ──────────────────────── -->
                    <MenuItem x:Name="CtxForceValidation"
                              Header="Force TBL Validation"
                              Click="CtxForceValidation_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxShowConflictsOnly"
                              Header="Show Conflicts Only"
                              IsCheckable="True"
                              Click="CtxShowConflictsOnly_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxNextConflict"
                              Header="Go to Next Conflict"
                              Click="CtxNextConflict_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xEA47;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>

                    <!-- ── Group 5 : Undo / Redo ─────────────────────── -->
                    <MenuItem x:Name="CtxUndo"
                              Header="Undo"
                              InputGestureText="Ctrl+Z"
                              Click="CtxUndo_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="CtxRedo"
                              Header="Redo"
                              InputGestureText="Ctrl+Y"
                              Click="CtxRedo_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <!-- Conflict icon -->
                <DataGridTemplateColumn Header="⚠" Width="24" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="⚠"
                                       Foreground="Orange"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding HasConflict, Converter={StaticResource BoolToVis}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Hex Entry -->
                <DataGridTextColumn Header="Hex Entry"
                                    Binding="{Binding Entry, UpdateSourceTrigger=LostFocus}"
                                    Width="100"
                                    IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="CharacterCasing" Value="Upper"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

                <!-- Character Value -->
                <DataGridTextColumn Header="Character"
                                    Binding="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                    Width="120"
                                    IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                <!-- DTE Type badge -->
                <DataGridTemplateColumn Header="Type" Width="75" IsReadOnly="True" SortMemberPath="Type">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="Badge"
                                    CornerRadius="3" Padding="5,1"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="2,1" Background="#555555">
                                <TextBlock x:Name="BadgeText"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="White" Text="???"/>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Type}" Value="{x:Static ct:DteType.Ascii}">
                                    <Setter TargetName="Badge"     Property="Background" Value="#3080C0"/>
                                    <Setter TargetName="BadgeText" Property="Text"       Value="ASC"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="{x:Static ct:DteType.DualTitleEncoding}">
                                    <Setter TargetName="Badge"     Property="Background" Value="#2A9B4E"/>
                                    <Setter TargetName="BadgeText" Property="Text"       Value="DTE"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="{x:Static ct:DteType.MultipleTitleEncoding}">
                                    <Setter TargetName="Badge"     Property="Background" Value="#7B4EC2"/>
                                    <Setter TargetName="BadgeText" Property="Text"       Value="MTE"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="{x:Static ct:DteType.Japonais}">
                                    <Setter TargetName="Badge"     Property="Background" Value="#C05A20"/>
                                    <Setter TargetName="BadgeText" Property="Text"       Value="JPN"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="{x:Static ct:DteType.EndLine}">
                                    <Setter TargetName="Badge"     Property="Background" Value="#C07820"/>
                                    <Setter TargetName="BadgeText" Property="Text"       Value="EOL"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="{x:Static ct:DteType.EndBlock}">
                                    <Setter TargetName="Badge"     Property="Background" Value="#C04530"/>
                                    <Setter TargetName="BadgeText" Property="Text"       Value="EOB"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="{x:Static ct:DteType.Invalid}">
                                    <Setter TargetName="Badge"     Property="Background" Value="#CC3333"/>
                                    <Setter TargetName="BadgeText" Property="Text"       Value="INV"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Byte length -->
                <DataGridTextColumn Header="Bytes"
                                    Binding="{Binding ByteLength}"
                                    Width="50"
                                    IsReadOnly="True"/>

                <!-- Comment -->
                <DataGridTextColumn Header="Comment"
                                    Binding="{Binding Comment, UpdateSourceTrigger=LostFocus}"
                                    Width="*"
                                    IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Ctrl+F Search overlay (floats above the grid) ─────────────── -->
        <Border x:Name="SearchPanel"
                Grid.Row="0"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,4,4,0"
                Padding="6,4"
                Background="{DynamicResource ERR_HeaderBrush}"
                BorderBrush="{DynamicResource ERR_GridLinesBrush}"
                BorderThickness="1"
                CornerRadius="3"
                Visibility="Collapsed"
                Panel.ZIndex="10">
            <StackPanel Orientation="Horizontal" Height="26">
                <TextBox x:Name="SearchBox"
                         Width="180"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="SearchBox_KeyDown"/>
                <ComboBox x:Name="TypeFilterCombo"
                          Margin="4,0,0,0"
                          Width="120"
                          SelectionChanged="TypeFilterCombo_SelectionChanged"/>
                <CheckBox Content="Conflicts only"
                          Margin="6,0"
                          VerticalAlignment="Center"
                          IsChecked="{Binding ShowConflictsOnly, Mode=TwoWay}"/>
                <Button Content="✕"
                        Width="22"
                        Margin="4,0,0,0"
                        Click="CloseSearch_Click"
                        ToolTip="Close search (Escape)"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

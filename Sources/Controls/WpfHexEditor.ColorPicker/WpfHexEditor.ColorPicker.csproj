<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>WpfHexEditor.ColorPicker</RootNamespace>
    <AssemblyName>WpfHexEditor.ColorPicker</AssemblyName>
    <NeutralLanguage>en-US</NeutralLanguage>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>

    <!-- NuGet package metadata -->
    <PackageId>WpfColorPicker</PackageId>
    <Version>2.0.2</Version>
    <AssemblyVersion>2.0.2.0</AssemblyVersion>
    <FileVersion>2.0.2</FileVersion>
    <Authors>Derek Tremblay</Authors>
    <Company>Derek Tremblay (derektremblay666@gmail.com)</Company>
    <Product>WpfColorPicker</Product>
    <Title>WpfColorPicker - WPF Color Picker UserControl</Title>
    <Description>A modern WPF color picker UserControl for .NET 8. HSV color wheel, RGB/HSL sliders, hex input, opacity support, recent colors, standard palettes, and eyedropper. Lightweight, themeable via DynamicResources, zero external dependencies. Drop-in ready for any WPF application.</Description>
    <Copyright>GNU AGPL v3.0 - 2016-2026</Copyright>
    <PackageTags>colorpicker;color;picker;wpf;usercontrol;hsv;rgb;hex;palette;eyedropper</PackageTags>
    <PackageProjectUrl>https://github.com/abbaye/WpfHexEditorIDE</PackageProjectUrl>
    <RepositoryUrl>https://github.com/abbaye/WpfHexEditorIDE</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReadmeFile>PACKAGE_README.md</PackageReadmeFile>
    <PackageReleaseNotes>2.0.2 — +10 new localizations (uk-UA, cs-CZ, vi-VN, hu-HU, ro-RO, id-ID, th-TH, el-GR, da-DK, fi-FI) reaching 28 total via ColorPickerResources satellite assemblies; Phase 5 self-contained NuGet localization (subclass resources loading fix). 2.0.1 — HSV color wheel + RGB/HSL sliders + opacity + recent colors + eyedropper + DynamicResource theming.</PackageReleaseNotes>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>

    <!-- SourceLink: enables step-through debugging for NuGet consumers -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <DebugType>embedded</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <None Include="icon.png" Pack="true" PackagePath="\" />
    <None Include="PACKAGE_README.md" Pack="true" PackagePath="\" />
    <None Include="WpfColorPicker-guide.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.*" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Core\WpfHexEditor.Core.Localization\WpfHexEditor.Core.Localization.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Properties\ColorPickerResources.Designer.cs">
      <AutoGen>True</AutoGen>
      <DependentUpon>ColorPickerResources.resx</DependentUpon>
      <DesignTime>True</DesignTime>
    </Compile>
    <EmbeddedResource Update="Properties\ColorPickerResources.resx">
      <SubType>Designer</SubType>
      <LastGenOutput>ColorPickerResources.Designer.cs</LastGenOutput>
      <Generator>ResXFileCodeGenerator</Generator>
    </EmbeddedResource>
  </ItemGroup>

</Project>

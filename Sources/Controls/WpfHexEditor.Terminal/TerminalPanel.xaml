// Contributors: Claude Sonnet 4.6
// VS-Like Terminal panel — Feature #92: Multi-tab sessions + Macro recording.
//   Row 0 : Toolbar (with TbgMacro group)
//   Row 1 : Session tab bar (ListBox styled as tabs + "+" new-session button)
//   Row 2 : Find bar (collapsible)
//   Row 3 : RichTextBox output (selectable, colored, hyperlinks)
//   Row 4 : Input row (prompt + TextBox + line-count + Run + Cancel)
// Theme: PanelCommon.xaml DynamicResource brushes (all themes)
// Theme compliance: all brushes from DockMenuBackgroundBrush / DockBorderBrush / DockMenuForegroundBrush
-->
<UserControl x:Class="WpfHexEditor.Terminal.TerminalPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfHexEditor.Terminal"
             xmlns:termSvc="clr-namespace:WpfHexEditor.Terminal.Services"
             Background="{DynamicResource Panel_ToolbarBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <termSvc:TerminalLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Flat text button for Run / Cancel in the input row.
             Transparent at rest, themed hover/active highlight, no border.
             Consistent across all themes (dark and light). -->
        <Style x:Key="TerminalTextButtonStyle" TargetType="Button">
            <Setter Property="Padding"             Value="10,3"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="Background"          Value="Transparent"/>
            <Setter Property="Foreground"          Value="{DynamicResource Panel_ToolbarForegroundBrush}"/>
            <Setter Property="FontFamily"          Value="Segoe UI"/>
            <Setter Property="FontSize"            Value="12"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="FocusVisualStyle"    Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed close button for the session tab strip (×).
             Transparent at rest, hover = Panel_ToolbarButtonHoverBrush, no border. -->
        <Style x:Key="CloseTabButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Session tab ListBoxItem style — VS-like tab header appearance. -->
        <Style x:Key="SessionTabItemStyle" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Padding"           Value="8,4"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Background"        Value="{DynamicResource Panel_ToolbarBrush}"/>
            <Setter Property="Foreground"        Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"       Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TabBd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,0,1,0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBd" Property="Background"
                                        Value="{DynamicResource DockBackgroundBrush}"/>
                                <Setter TargetName="TabBd" Property="BorderThickness"
                                        Value="1,2,1,0"/>
                                <Setter TargetName="TabBd" Property="BorderBrush"
                                        Value="{DynamicResource DockAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Row 0: Toolbar -->
            <RowDefinition Height="Auto"/>   <!-- Row 1: Session tab bar -->
            <RowDefinition Height="Auto"/>   <!-- Row 2: Find bar -->
            <RowDefinition Height="*"/>      <!-- Row 3: Output -->
            <RowDefinition Height="Auto"/>   <!-- Row 4: Input -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Toolbar ──────────────────────────────────────────────────── -->
        <Border x:Name="ToolbarBorder"
                Grid.Row="0"
                Style="{DynamicResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="False">
                <!-- Left fixed: title + shell selector + encoding (measured by overflow manager) -->
                <StackPanel x:Name="ToolbarLeftFixedPanel"
                            Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <TextBlock Text="{StaticResource Terminal_Title}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,8,0"/>
                    <Button Style="{DynamicResource PanelDropdownButtonStyle}"
                            ToolTip="{StaticResource Terminal_SwitchShell}"
                            MinWidth="90"
                            Click="OnShellSelectorClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{StaticResource Terminal_TabHxTerminal}"
                                          Command="{Binding SwitchModeCommand}"
                                          CommandParameter="HxTerminal"/>
                                <MenuItem Header="{StaticResource Terminal_TabPowerShell}"
                                          Command="{Binding SwitchModeCommand}"
                                          CommandParameter="PowerShell"/>
                                <MenuItem Header="{StaticResource Terminal_TabBash}"
                                          Command="{Binding SwitchModeCommand}"
                                          CommandParameter="Bash"/>
                                <MenuItem Header="{StaticResource Terminal_TabCmd}"
                                          Command="{Binding SwitchModeCommand}"
                                          CommandParameter="CMD"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CurrentModeLabel}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="&#xE70D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="9"
                                       Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Encoding selector — PowerShell mode only -->
                    <ComboBox ItemsSource="{Binding AvailableEncodings}"
                              SelectedItem="{Binding SelectedEncoding}"
                              FontSize="11" Width="90" Height="20"
                              VerticalContentAlignment="Center"
                              Background="{DynamicResource Panel_ToolbarBrush}"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              BorderBrush="{DynamicResource DockBorderBrush}"
                              Margin="4,0,0,0"
                              Visibility="{Binding IsPowerShellMode, Converter={StaticResource BoolToVis}}"
                              ToolTip="{StaticResource Terminal_PsEncoding}"/>
                </StackPanel>

                <!-- Right: always-visible actions (Save, Clear, Cancel) -->
                <StackPanel x:Name="ToolbarRightPanel"
                            Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <Rectangle Width="1" Height="14" Margin="2,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                    <!-- Save output -->
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding SaveOutputCommand}"
                            ToolTip="{StaticResource Terminal_SaveOutput}">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Button>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ClearOutputCommand}"
                            ToolTip="{StaticResource Terminal_ClearOutput}">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Button>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding CancelCommand}"
                            ToolTip="{StaticResource Terminal_CancelCommand}">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Button>
                </StackPanel>

                <!-- Overflow button — shown only when groups are collapsed -->
                <Button x:Name="ToolbarOverflowButton"
                        DockPanel.Dock="Right"
                        Visibility="Collapsed"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        ToolTip="{StaticResource Terminal_MoreOptions}"
                        Click="OnOverflowButtonClick">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowContextMenu" Opened="OnOverflowMenuOpened">
                            <!-- TbgScrollNav -->
                            <MenuItem x:Name="OvfScrollTop"    Header="{StaticResource Terminal_ScrollToTop}"    Tag="TbgScrollNav" Click="OnScrollToTop"/>
                            <MenuItem x:Name="OvfScrollBottom" Header="{StaticResource Terminal_ScrollToBottom}" Tag="TbgScrollNav" Click="OnScrollToBottom"/>
                            <Separator Tag="TbgScrollNav"/>
                            <!-- TbgOutputControl -->
                            <MenuItem x:Name="OvfAutoScroll"  Header="{StaticResource Terminal_AutoScroll}"  IsCheckable="True" Tag="TbgOutputControl" Click="OvfAutoScroll_Click"/>
                            <MenuItem x:Name="OvfPauseOutput" Header="{StaticResource Terminal_PauseOutput}" IsCheckable="True" Tag="TbgOutputControl" Click="OvfPauseOutput_Click"/>
                            <Separator Tag="TbgOutputControl"/>
                            <!-- TbgTextOptions -->
                            <MenuItem x:Name="OvfTimestamps"   Header="{StaticResource Terminal_ShowTimestamps}" IsCheckable="True" Tag="TbgTextOptions" Click="OvfTimestamps_Click"/>
                            <MenuItem x:Name="OvfWordWrap"     Header="{StaticResource Terminal_WordWrap}"       IsCheckable="True" Tag="TbgTextOptions" Click="OvfWordWrap_Click"/>
                            <MenuItem x:Name="OvfCopyOnSelect" Header="{StaticResource Terminal_CopyOnSelect}"  IsCheckable="True" Tag="TbgTextOptions" Click="OvfCopyOnSelect_Click"/>
                            <Separator Tag="TbgTextOptions"/>
                            <!-- TbgFont -->
                            <MenuItem x:Name="OvfFontIncrease" Header="{StaticResource Terminal_IncreaseFontSize}" Tag="TbgFont" Click="OvfFontIncrease_Click"/>
                            <MenuItem x:Name="OvfFontDecrease" Header="{StaticResource Terminal_DecreaseFontSize}" Tag="TbgFont" Click="OvfFontDecrease_Click"/>
                            <Separator Tag="TbgFont"/>
                            <!-- TbgMacro -->
                            <MenuItem x:Name="OvfRecord"    Header="{StaticResource Terminal_StartRecording}"  Tag="TbgMacro" Click="OvfRecord_Click"/>
                            <MenuItem x:Name="OvfStop"      Header="{StaticResource Terminal_StopRecording}"   Tag="TbgMacro" Click="OvfStop_Click"/>
                            <MenuItem x:Name="OvfReplay"    Header="{StaticResource Terminal_ReplayMacro}"     Tag="TbgMacro" Click="OvfReplay_Click"/>
                            <MenuItem x:Name="OvfSaveMacro" Header="{StaticResource Terminal_SaveMacroAs}"  Tag="TbgMacro" Click="OvfSaveMacro_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Group: TbgMacro [4] — macro recording -->
                <StackPanel x:Name="TbgMacro"
                            Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <Rectangle Width="1" Height="14" Margin="2,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                    <!-- Record (hidden while recording) -->
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding StartRecordingCommand}"
                            ToolTip="{StaticResource Terminal_StartMacroRecording}">
                        <Button.Visibility>
                            <Binding Path="IsRecording">
                                <Binding.Converter>
                                    <BooleanToVisibilityConverter/>
                                </Binding.Converter>
                            </Binding>
                        </Button.Visibility>
                        <TextBlock Text="&#xEBE8;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource ErrorForegroundBrush}"/>
                    </Button>
                    <!-- Stop (visible while recording) -->
                    <Button x:Name="BtnStopRecord"
                            Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding StopRecordingCommand}"
                            ToolTip="{StaticResource Terminal_StopRecording}"
                            Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource ErrorForegroundBrush}"/>
                    </Button>
                    <!-- Replay -->
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding ReplayMacroCommand}"
                            ToolTip="{StaticResource Terminal_ReplayLastMacro}">
                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Button>
                    <!-- Save .hxscript -->
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding SaveMacroCommand}"
                            ToolTip="{StaticResource Terminal_SaveMacro}">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Button>
                </StackPanel>

                <!-- Group: TbgFont [3] last to collapse -->
                <StackPanel x:Name="TbgFont"
                            Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <Rectangle Width="1" Height="14" Margin="2,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding IncreaseFontCommand}"
                            ToolTip="{StaticResource Terminal_IncreaseFontSizeTip}">
                        <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Button>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Command="{Binding DecreaseFontCommand}"
                            ToolTip="{StaticResource Terminal_DecreaseFontSizeTip}">
                        <TextBlock Text="&#xE71F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Button>
                </StackPanel>

                <!-- Group: TbgTextOptions [1] -->
                <StackPanel x:Name="TbgTextOptions"
                            Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <Rectangle Width="1" Height="14" Margin="2,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                    <ToggleButton Style="{DynamicResource PanelIconToggleStyle}"
                                  IsChecked="{Binding ShowTimestamps}"
                                  ToolTip="{StaticResource Terminal_ShowTimestamps}">
                        <TextBlock Text="&#xE121;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </ToggleButton>
                    <ToggleButton Style="{DynamicResource PanelIconToggleStyle}"
                                  IsChecked="{Binding IsWordWrap}"
                                  ToolTip="{StaticResource Terminal_WordWrap}">
                        <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </ToggleButton>
                    <ToggleButton Style="{DynamicResource PanelIconToggleStyle}"
                                  IsChecked="{Binding CopyOnSelect}"
                                  ToolTip="{StaticResource Terminal_CopyOnSelect}">
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </ToggleButton>
                </StackPanel>

                <!-- Group: TbgOutputControl [2] -->
                <StackPanel x:Name="TbgOutputControl"
                            Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <Rectangle Width="1" Height="14" Margin="2,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                    <ToggleButton Style="{DynamicResource PanelIconToggleStyle}"
                                  IsChecked="{Binding IsAutoScrollEnabled}"
                                  ToolTip="{StaticResource Terminal_AutoScrollTip}">
                        <TextBlock Text="&#xF0AF;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </ToggleButton>
                    <ToggleButton Style="{DynamicResource PanelIconToggleStyle}"
                                  IsChecked="{Binding IsOutputPaused}"
                                  ToolTip="{StaticResource Terminal_PauseOutput}">
                        <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </ToggleButton>
                </StackPanel>

                <!-- Group: TbgScrollNav [0] first to collapse -->
                <StackPanel x:Name="TbgScrollNav"
                            Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <Rectangle Width="1" Height="14" Margin="2,0"
                               Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                    <!-- Scroll to Top -->
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Click="OnScrollToTop"
                            ToolTip="{StaticResource Terminal_ScrollToTop}">
                        <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Button>
                    <Button Style="{DynamicResource PanelIconButtonStyle}"
                            Click="OnScrollToBottom"
                            ToolTip="{StaticResource Terminal_ScrollToBottom}">
                        <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Row 1: Session tab bar ────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- "+" new session button at far right -->
                <Button DockPanel.Dock="Right"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        ToolTip="{StaticResource Terminal_NewSession}"
                        Click="OnNewSessionMenuClick"
                        Width="28" Height="28">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{StaticResource Terminal_TabHxTerminal}" Command="{Binding AddHxTerminalCommand}"/>
                            <MenuItem Header="{StaticResource Terminal_TabPowerShell}" Command="{Binding AddPowerShellCommand}"/>
                            <MenuItem Header="{StaticResource Terminal_TabBash}"       Command="{Binding AddBashCommand}"/>
                            <MenuItem Header="{StaticResource Terminal_TabCmd}"        Command="{Binding AddCmdCommand}"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                </Button>

                <!-- Session tabs (ListBox styled as horizontal tab strip) -->
                <ListBox x:Name="SessionTabBar"
                         ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding ActiveSession}"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="OnSessionTabSelectionChanged"
                         ItemContainerStyle="{StaticResource SessionTabItemStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel MinWidth="80">
                                <!-- Close session button -->
                                <Button DockPanel.Dock="Right"
                                        Style="{StaticResource CloseTabButtonStyle}"
                                        Tag="{Binding}"
                                        Click="OnCloseSessionTabClick"
                                        Width="16" Height="16"
                                        VerticalAlignment="Center"
                                        Margin="4,0,0,0"
                                        Padding="1"
                                        ToolTip="{StaticResource Terminal_CloseSession}">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                </Button>
                                <!-- Tab title -->
                                <TextBlock Text="{Binding TabTitle}"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="120"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── Row 2: Find bar (collapsible) ──────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,1"
                Padding="4,2"
                Visibility="{Binding IsFindVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Click="OnCloseFindBar"
                        ToolTip="{StaticResource Terminal_CloseFindBar}">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </Button>
                <TextBlock x:Name="FindStatusText"
                           DockPanel.Dock="Right"
                           Text="{Binding FindStatusLabel}"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="4,0"/>
                <Button DockPanel.Dock="Right"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Click="OnFindPrev"
                        ToolTip="{StaticResource Terminal_PreviousMatch}">
                    <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </Button>
                <Button DockPanel.Dock="Right"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Click="OnFindNext"
                        ToolTip="{StaticResource Terminal_NextMatch}">
                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"/>
                </Button>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{StaticResource Terminal_FindLabel}"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"/>
                    <TextBox x:Name="FindBox"
                             Text="{Binding FindText, UpdateSourceTrigger=PropertyChanged}"
                             Width="200"
                             FontFamily="Consolas" FontSize="11"
                             Foreground="{DynamicResource DockMenuForegroundBrush}"
                             Background="{DynamicResource DockBackgroundBrush}"
                             BorderBrush="{DynamicResource DockBorderBrush}"
                             BorderThickness="1" Padding="3,1"
                             VerticalAlignment="Center"
                             KeyDown="OnFindKeyDown"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Row 3: Output (RichTextBox) ────────────────────────────────────── -->
        <RichTextBox x:Name="OutputRtb"
                     Grid.Row="3"
                     IsReadOnly="True"
                     IsDocumentEnabled="True"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="{Binding OutputFontSize}"
                     Background="{DynamicResource DockBackgroundBrush}"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Padding="4"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     PreviewKeyDown="OnOutputKeyDown"
                     ScrollViewer.ScrollChanged="OnOutputScrollChanged"
                     SelectionChanged="OnOutputSelectionChanged">
            <RichTextBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{StaticResource Terminal_Copy}"      Command="ApplicationCommands.Copy"/>
                    <MenuItem Header="{StaticResource Terminal_CopyAll}"   Command="{Binding PlacementTarget.DataContext.CopyAllCommand,
                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{StaticResource Terminal_SelectAll}" Command="ApplicationCommands.SelectAll"/>
                    <Separator/>
                    <MenuItem Header="{StaticResource Terminal_ClearOutput}" Command="{Binding PlacementTarget.DataContext.ClearOutputCommand,
                                                               RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{StaticResource Terminal_SaveOutput}"  Command="{Binding PlacementTarget.DataContext.SaveOutputCommand,
                                                               RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="{StaticResource Terminal_Find}"
                              Command="{Binding PlacementTarget.DataContext.ToggleFindCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              InputGestureText="Ctrl+F"/>
                    <Separator/>
                    <MenuItem Header="{StaticResource Terminal_WordWrap}"
                              IsCheckable="True"
                              IsChecked="{Binding PlacementTarget.DataContext.IsWordWrap,
                                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{StaticResource Terminal_ShowTimestamps}"
                              IsCheckable="True"
                              IsChecked="{Binding PlacementTarget.DataContext.ShowTimestamps,
                                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{StaticResource Terminal_CopyOnSelect}"
                              IsCheckable="True"
                              IsChecked="{Binding PlacementTarget.DataContext.CopyOnSelect,
                                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="{StaticResource Terminal_IncreaseFontSize}"
                              Command="{Binding PlacementTarget.DataContext.IncreaseFontCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              InputGestureText="Ctrl++"/>
                    <MenuItem Header="{StaticResource Terminal_DecreaseFontSize}"
                              Command="{Binding PlacementTarget.DataContext.DecreaseFontCommand,
                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              InputGestureText="Ctrl+-"/>
                    <Separator/>
                    <MenuItem Header="{StaticResource Terminal_StartRecording}" Command="{Binding PlacementTarget.DataContext.StartRecordingCommand,
                                                                 RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{StaticResource Terminal_StopRecording}"  Command="{Binding PlacementTarget.DataContext.StopRecordingCommand,
                                                                 RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{StaticResource Terminal_ReplayMacro}"    Command="{Binding PlacementTarget.DataContext.ReplayMacroCommand,
                                                                 RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </RichTextBox.ContextMenu>
            <FlowDocument x:Name="OutputDoc" PagePadding="0"/>
        </RichTextBox>

        <!-- ── Row 4: Input row ──────────────────────────────────────────────── -->
        <Border Grid.Row="4"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="4,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <TextBlock Text="{Binding WorkingDirectoryLabel}"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               VerticalAlignment="Center"
                               MaxWidth="200"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="&gt;"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="2,0,4,0"/>
                </StackPanel>

                <TextBox x:Name="InputBox"
                         Grid.Column="1"
                         Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas" FontSize="12"
                         Foreground="{DynamicResource DockMenuForegroundBrush}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="2,2"
                         VerticalAlignment="Center"
                         KeyDown="OnInputKeyDown"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding OutputLineCountLabel}"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="{DynamicResource Panel_ToolbarForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="4,0"
                           Opacity="0.7"/>

                <Button Grid.Column="3"
                        Style="{StaticResource TerminalTextButtonStyle}"
                        Content="{StaticResource Terminal_Run}"
                        Command="{Binding RunCommand}"
                        Padding="10,3"
                        Margin="4,0,2,0"/>

                <Button Grid.Column="4"
                        Style="{StaticResource TerminalTextButtonStyle}"
                        Content="✕"
                        Command="{Binding CancelCommand}"
                        Padding="8,3"
                        Margin="0,0,2,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

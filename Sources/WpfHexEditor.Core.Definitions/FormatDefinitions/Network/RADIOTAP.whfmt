  "blocks": [
    {
      "type": "field",
      "name": "Header Revision",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "Radiotap version (0)",
      "storeAs": "headerRevision",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Header Pad",
      "offset": 1,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "Padding byte",
      "storeAs": "headerPad",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Header Length",
      "offset": 2,
      "length": 2,
      "color": "#95E1D3",
      "opacity": 0.3,
      "description": "Total header length",
      "storeAs": "headerLength",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Present Flags",
      "offset": 4,
      "length": 4,
      "color": "#FFE66D",
      "opacity": 0.3,
      "description": "Bitmask of present fields",
      "storeAs": "presentFlags",
      "valueType": "uint32"
    },
    {
      "type": "field",
      "name": "MAC Timestamp",
      "offset": 8,
      "length": 8,
      "color": "#FFA07A",
      "opacity": 0.3,
      "description": "802.11 MAC timestamp (optional)",
      "storeAs": "macTimestamp",
      "valueType": "uint64"
    },
    {
      "type": "field",
      "name": "Flags",
      "offset": 16,
      "length": 1,
      "color": "#C7CEEA",
      "opacity": 0.3,
      "description": "Capture flags (optional)",
      "storeAs": "flags",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Data Rate",
      "offset": 17,
      "length": 1,
      "color": "#B8B8FF",
      "opacity": 0.3,
      "description": "Data rate in 500kbps units (optional)",
      "storeAs": "dataRate",
      "valueType": "uint8"
    },
    {
      "type": "field",
      "name": "Channel Frequency",
      "offset": 18,
      "length": 2,
      "color": "#98D8C8",
      "opacity": 0.3,
      "description": "Channel frequency in MHz (optional)",
      "storeAs": "channelFrequency",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Channel Flags",
      "offset": 20,
      "length": 2,
      "color": "#A8E6CF",
      "opacity": 0.3,
      "description": "Channel properties (optional)",
      "storeAs": "channelFlags",
      "valueType": "uint16"
    },
    {
      "type": "field",
      "name": "Antenna Signal",
      "offset": 22,
      "length": 1,
      "color": "#FF6B9D",
      "opacity": 0.3,
      "description": "Signal strength in dBm (optional)",
      "storeAs": "antennaSignal",
      "valueType": "uint8"
    },
    {
      "type": "metadata",
      "name": "Machine",

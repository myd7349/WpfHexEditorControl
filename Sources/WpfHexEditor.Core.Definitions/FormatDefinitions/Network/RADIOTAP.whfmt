   Detection: signature=00 @ offset 0
   Updated:   2026-02-24
   ============================================================ */
{
  "diffMode": "binary",
  "formatName": "Radiotap 802.11",
  "version": "1.11",
  "extensions": [
    ".pcap",
    ".pcapng"
  ],
  "description": "Radiotap header for 802.11 wireless captures",
  "category": "Network",

  },
  "forensic": {
    "category": "network",
    "riskLevel": "medium",
    "suspiciousPatterns": [],
    "knownMaliciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "PCAP files store raw packet captures prefixed by a global header (24 bytes) followed by per-packet records (16-byte header + payload). The linkLayerType value (Ethernet=1, WiFi=105, loopback=0) determines payload structure. Forensic analysis should examine timestamps for time gaps, snapshotLength truncation of packets, and non-zero timeZoneOffset which is non-standard.",
    "knownVulnerabilities": [],
    "suggestedInspections": [
      "Verify the magic number (0xD4C3B2A1 LE or 0xA1B2C3D4 BE) to confirm endianness",
      "Inspect linkLayerType to determine the network medium and payload decoder to apply",
      "Check for timestamp anomalies: backwards time, large gaps, or future timestamps",
      "Examine snapshotLength — values less than 65535 may indicate truncated packet payloads"
    ]
  },
  "navigation": {
    "bookmarks": [
      { "name": "PCAP Global Header", "offsetVar": "currentOffset", "icon": "\uE8A9" }
    ]
  },
  "TechnicalDetails": {},
  "functions": {
    "readUInt32LE": "Read PCAP header",
    "divide": "Calculate duration"
  }
}
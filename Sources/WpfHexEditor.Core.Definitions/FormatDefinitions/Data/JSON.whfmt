/* ============================================================
   Format:    JSON Data
   Category:  Data
   Ext:       .json
   Editor:    code-editor
   Desc:      JavaScript Object Notation - a lightweight text-based data interchange format. JSON files begin with either an opening brace {
  "diffMode": "semantic", for objects or an opening bracket [ for arrays. Optionally preceded by a UTF-8 BOM.
   Variables: currentOffset, openingCharacter, firstContentCharacter
   Detection: signature=7B @ offset 0
   Updated:   2026-03-22
   ============================================================ */
{
  "formatName": "JSON Data",
  "version": "2.1",
  "extensions": [
    ".json"
  ],
  "description": "JavaScript Object Notation - a lightweight text-based data interchange format. JSON files begin with either an opening brace { for objects or an opening bracket [ for arrays. Optionally preceded by a UTF-8 BOM.",
  "category": "Data",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "json-editor",
  "references": {
    "specifications": [
      "ECMA-404 - The JSON Data Interchange Standard",
      "RFC 8259 - The JavaScript Object Notation (JSON) Data Interchange Format",
      "ISO/IEC 21778:2017 - Information technology - JSON"
    ],
    "WebLinks": [
      "https://www.json.org/json-en.html",
      "https://www.ecma-international.org/publications-and-standards/standards/ecma-404/",
      "https://datatracker.ietf.org/doc/html/rfc8259",
      "https://en.wikipedia.org/wiki/JSON"
    ]
  },
  "detection": {
    "signature": "7B",
    "offset": 0,
    "required": false,
    "validation": {
      "minFileSize": 2,
      "maxSignatureOffset": 3
    }
  },
  "variables": {
    "currentOffset": 0,
    "openingCharacter": 0,
    "firstContentCharacter": 0
  },
  "functions": {
    "detectBOM": "Detect byte order mark (EF BB BF for UTF-8) that may precede JSON content and adjust parsing offset accordingly"
  },
  "blocks": [
    {
      "type": "signature",
      "name": "Opening Character",
      "offset": 0,
      "length": 1,
      "color": "#FF6B6B",
      "opacity": 0.4,
      "description": "First structural character: { (0x7B) for a JSON object or [ (0x5B) for a JSON array",
      "storeAs": "openingCharacter",
      "valueType": "uint8",
      "valueMap": {
        "123": "Object {",
        "91": "Array ["
      }
    },
    {
      "type": "field",
      "name": "First Content Character",
      "offset": 1,
      "length": 1,
      "color": "#4ECDC4",
      "opacity": 0.3,
      "description": "First character after the opening delimiter - typically a quote (\"), whitespace, or nested structure character",
      "storeAs": "firstContentCharacter",
      "valueType": "uint8"
    }
  ],
  "MimeTypes": [
    "application/json"
  ],
  "Software": [
    "Text editors (VS Code, Notepad++, Sublime Text)",
    "Web browsers (Chrome, Firefox, Edge)",
    "REST clients (Postman, Insomnia)",
    "All modern programming languages"
  ],
  "UseCases": [
    "REST API request and response payloads",
    "Application configuration (package.json, tsconfig.json)",
    "Data exchange between services",
    "NoSQL database storage (MongoDB, CouchDB)"
  ],
  "QualityMetrics": {
    "CompletenessScore": 38,
    "DocumentationLevel": "standard",
    "BlocksDefined": 2,
    "ValidationRules": 2,
    "LastUpdated": "2026-03-22",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "TechnicalDetails": {
    "TextFormat": true,
    "Encoding": "UTF-8 (required by RFC 8259)",
    "StrictSyntax": true,
    "TrailingCommas": "Not allowed per specification",
    "Comments": "Not allowed per specification"
  },
  "syntaxDefinition": {
    "id": "json",
    "name": "JSON",
    "extensions": [
      ".json",
      ".jsonc",
      ".json5"
    ],
    "lineCommentPrefix": "//",
    "blockCommentStart": "/*",
    "blockCommentEnd": "*/",
    "rules": [
      {
        "type": "Key",
        "pattern": "\"(?:[^\"\\]|\\.)*\"(?=\\s*:)",
        "colorKey": "TE_Type"
      },
      {
        "type": "Keyword",
        "pattern": "\\b(true|false|null)\\b",
        "colorKey": "TE_Keyword"
      },
      {
        "type": "Number",
        "pattern": "-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?",
        "colorKey": "TE_Number"
      },
      {
        "type": "String",
        "pattern": "\"(?:[^\"\\]|\\.)*\"",
        "colorKey": "TE_String"
      },
      {
        "type": "Comment",
        "pattern": "//.*$",
        "colorKey": "TE_Comment"
      },
      {
        "type": "BlockComment",
        "pattern": "/\\*[\\s\\S]*?\\*/",
        "colorKey": "TE_Comment"
      }
    ],
    "foldingRules": {
      "startPatterns": [
        "\\{",
        "\\["
      ],
      "endPatterns": [
        "\\}",
        "\\]"
      ]
    }
  },
  "forensic": {
    "category": "data",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "JavaScript Object Notation - a lightweight text-based data interchange format. JSON files begin with either ...",
    "suggestedInspections": [
      "Validate JSON Data schema header and encoding markers",
      "Check nested structure depth and field type tags",
      "Inspect string encodings and numeric value boundaries"
    ]
  }
}

/* ============================================================
   Format:    PowerShell Script
   Category:  Programming
   Ext:       .ps1, .psm1, .psd1
   Editor:    code-editor
   Desc:      PowerShell script and module files (Windows/cross-platform scripting).
   Updated:   2026-03-22
   ============================================================ */
{
  "diffMode": "text",
  "formatName": "PowerShell Script",
  "version": "2.0",
  "extensions": [
    ".ps1",
    ".psm1",
    ".psd1"
  ],
  "description": "PowerShell script and module files (Windows/cross-platform scripting).",
  "category": "Programming",
  "author": "WPFHexaEditor Team",
  "preferredEditor": "code-editor",
  "detection": {
    "isTextFormat": true,
    "required": false
  },
  "QualityMetrics": {
    "CompletenessScore": 80,
    "DocumentationLevel": "standard",
    "BlocksDefined": 0,
    "ValidationRules": 0,
    "LastUpdated": "2026-03-22",
    "PriorityFormat": true,
    "AutoRefined": false
  },
  "MimeTypes": [
    "text/x-powershell"
  ],
  "Software": [
    "VS Code",
    "PowerShell ISE"
  ],
  "UseCases": [
    "Windows automation",
    "Cloud infrastructure (Azure)",
    "System administration"
  ],
  "syntaxDefinition": {
    "id": "powershell",
    "name": "PowerShell",
    "extensions": [
      ".ps1",
      ".psm1",
      ".psd1",
      ".ps1xml"
    ],
    "lineCommentPrefix": "#",
    "blockCommentStart": "<#",
    "blockCommentEnd": "#>",
    "rules": [
      {
        "type": "BlockComment",
        "pattern": "<#[\\s\\S]*?#>",
        "colorKey": "TE_Comment"
      },
      {
        "type": "String",
        "pattern": "(\"(?:[^\"\\\\]|\\\\.)*\"|'(?:[^'\\\\]|\\\\.)*'|@\"[\\s\\S]*?\"@|@'[\\s\\S]*?'@)",
        "colorKey": "TE_String"
      },
      {
        "type": "Comment",
        "pattern": "#.*$",
        "colorKey": "TE_Comment"
      },
      {
        "type": "Preprocessor",
        "pattern": "#Requires\\s+.*$|using\\s+(?:namespace|module|assembly)\\s+\\S+",
        "colorKey": "TE_Directive"
      },
      {
        "type": "Cmdlet",
        "pattern": "\\b(?:[A-Z][a-z]+-[A-Z][A-Za-z]+)\\b",
        "colorKey": "TE_Keyword"
      },
      {
        "type": "Keyword",
        "pattern": "\\b(begin|break|catch|class|continue|data|define|do|dynamicparam|else|elseif|end|enum|exit|filter|finally|for|foreach|from|function|hidden|if|in|inlinescript|parallel|param|process|return|sequence|static|switch|throw|trap|try|until|using|var|while|workflow)\\b",
        "colorKey": "TE_Keyword"
      },
      {
        "type": "SpecialVars",
        "pattern": "\\$(?:true|false|null|args|input|MyInvocation|PSCmdlet|PSScriptRoot|PSBoundParameters|ErrorActionPreference|WarningPreference|VerbosePreference|DebugPreference|Host|Error|HOME|PID|PSVersionTable|env:[A-Za-z_][A-Za-z0-9_]*)\\b",
        "colorKey": "TE_Type"
      },
      {
        "type": "Variable",
        "pattern": "\\$[A-Za-z_][A-Za-z0-9_:]*",
        "colorKey": "TE_Register"
      },
      {
        "type": "Operator",
        "pattern": "\\b-(?:eq|ne|gt|ge|lt|le|like|notlike|match|notmatch|contains|notcontains|in|notin|replace|split|join|is|isnot|as|and|or|not|band|bor|bxor|bnot|shl|shr|f)\\b",
        "colorKey": "TE_Keyword"
      },
      {
        "type": "Type",
        "pattern": "\\[[A-Za-z_][A-Za-z0-9_.\\[\\],`]*\\]",
        "colorKey": "TE_Type"
      },
      {
        "type": "Number",
        "pattern": "\\b(0x[0-9A-Fa-f]+[lL]?|[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?[lLdD]?)\\b",
        "colorKey": "TE_Number"
      },
      {
        "type": "Attribute",
        "pattern": "\\[[A-Za-z_][A-Za-z0-9_]*(?:\\([^)]*\\))?\\]",
        "colorKey": "TE_Directive"
      }
    ],
    "foldingRules": {
      "startPatterns": [
        "\\{"
      ],
      "endPatterns": [
        "\\}"
      ],
      "endOfBlockHint": {
        "enabled": true,
        "maxContextLines": 3,
        "triggerBrace": true,
        "triggerDirective": true
      }
    }
  },
  "forensic": {
    "category": "other",
    "riskLevel": "low",
    "suspiciousPatterns": []
  },
  "aiHints": {
    "analysisContext": "PowerShell script and module files (Windows/cross-platform scripting).",
    "suggestedInspections": [
      "Verify PowerShell Script file signature and header structure",
      "Check data integrity and field boundaries",
      "Inspect metadata and version information"
    ]
  },
  "breakpointRules": {
    "nonExecutablePatterns": [
      "^\\s*#",
      "^\\s*<#",
      "^\\s*$"
    ],
    "statementContinuationPatterns": [
      "`\\s*$"
    ]
  }
}

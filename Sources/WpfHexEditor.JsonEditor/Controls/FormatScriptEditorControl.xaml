<UserControl x:Class="WpfHexEditor.JsonEditor.Controls.FormatScriptEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexEditor.JsonEditor.Controls"
             xmlns:jsonEditor="clr-namespace:WpfHexEditor.JsonEditor.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- Button Style -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="White">

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Background="#F5F5F5" Padding="4">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="NewFileButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="New Format Definition">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📄" FontSize="16" Margin="0,0,4,0"/>
                        <TextBlock Text="New" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="OpenFileButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open Format Definition">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📂" FontSize="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Open" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="SaveFileButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Save Current File">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" FontSize="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Save" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Width="1" Margin="8,4" Background="#CCCCCC"/>

                <Button x:Name="UndoButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Undo (Ctrl+Z)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↶" FontSize="18" Margin="0,0,4,0"/>
                        <TextBlock Text="Undo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="RedoButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Redo (Ctrl+Y)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↷" FontSize="18" Margin="0,0,4,0"/>
                        <TextBlock Text="Redo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Width="1" Margin="8,4" Background="#CCCCCC"/>

                <Button x:Name="FormatButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Format JSON (Ctrl+Shift+F)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✨" FontSize="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Format" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ValidateButton" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Validate Format Definition">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" FontSize="18" Margin="0,0,4,0"/>
                        <TextBlock Text="Validate" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Background="#F5F5F5" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Line/Column indicator -->
                <TextBlock x:Name="LineColumnText" Grid.Column="0" Text="Ln 1, Col 1" Margin="0,0,16,0"/>

                <!-- Errors/Warnings -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="❌" Margin="0,0,4,0"/>
                    <TextBlock x:Name="ErrorCountText" Text="0 Errors"/>
                    <TextBlock Text=" " Margin="4,0"/>
                    <TextBlock Text="⚠️" Margin="0,0,4,0"/>
                    <TextBlock x:Name="WarningCountText" Text="0 Warnings"/>
                </StackPanel>

                <!-- Current file name -->
                <TextBlock x:Name="FileNameText" Grid.Column="3" Text="No file loaded" HorizontalAlignment="Left"/>

                <!-- Encoding / File Type -->
                <TextBlock x:Name="FileTypeText" Grid.Column="4" Text="JSON" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- File Tree (Left Panel) -->
            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0" Background="White">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                        <TextBlock Text="Embedded Formats" FontWeight="Bold" Padding="8"/>
                    </Border>

                    <TreeView x:Name="FormatTreeView" BorderThickness="0" Background="White">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

            <!-- Editor Area (Right Panel) -->
            <TabControl x:Name="MainTabControl" Grid.Column="2" BorderThickness="0"
                       SelectionChanged="MainTabControl_SelectionChanged">

                <!-- Editor Tab -->
                <TabItem x:Name="EditorTab" Header="Editor">
                    <Grid>
                        <jsonEditor:JsonEditor x:Name="JsonEditorControl"
                                              ShowLineNumbers="True"
                                              EnableIntelliSense="True"
                                              EnableValidation="True"/>
                    </Grid>
                </TabItem>

                <!-- Preview Tab -->
                <TabItem Header="Preview">
                    <ScrollViewer>
                        <TextBlock x:Name="PreviewTextBlock"
                                  Padding="10"
                                  FontFamily="Consolas"
                                  FontSize="12"
                                  TextWrapping="Wrap"
                                  Text="Load a format definition to see preview..."/>
                    </ScrollViewer>
                </TabItem>

                <!-- Validation Tab -->
                <TabItem Header="Validation">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Padding="8" Background="#F0F0F0"
                                  Text="Validation Results" FontWeight="Bold"/>

                        <ListBox x:Name="ValidationListBox" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Message}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Location}" Foreground="Gray" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </TabItem>

                <!-- Test Tab -->
                <TabItem Header="Test">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="8" Background="#F0F0F0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Select Test File..." Padding="8,4" Margin="0,0,8,0"/>
                                <Button Content="Run Test" Padding="8,4"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Padding="10" TextWrapping="Wrap"
                                  Text="Test your format definition against sample files here.&#x0a;&#x0a;Select a file and click 'Run Test' to see parsing results."/>
                    </DockPanel>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</UserControl>

<UserControl x:Class="WpfHexEditor.Editor.ScriptEditor.Controls.ScriptEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ce="clr-namespace:WpfHexEditor.Editor.CodeEditor.Controls;assembly=WpfHexEditor.Editor.CodeEditor">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="30" />
            <!-- Code area -->
            <RowDefinition Height="*" MinHeight="60" />
            <!-- Splitter -->
            <RowDefinition Height="4" />
            <!-- Output area -->
            <RowDefinition Height="120" MinHeight="40" />
            <!-- Status bar -->
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource TE_Background}"
                BorderBrush="{DynamicResource DockSplitterBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                <TextBlock x:Name="ScriptLabel"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource TE_LineNumberForeground}"
                           Text="Press F5 to run · Ctrl+F5 to validate" />
            </StackPanel>
        </Border>

        <!-- Code editor (CodeEditorSplitHost — syntax + SmartComplete) -->
        <ce:CodeEditorSplitHost Grid.Row="1"
                                x:Name="CodeBox"
                                ShowMinimap="False"
                                ShowLineNumbers="True" />

        <!-- Splitter -->
        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource DockSplitterBrush}"
                      ResizeDirection="Rows" />

        <!-- Output area -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource DockSplitterBrush}"
                BorderThickness="0,1,0,0">
            <TextBox x:Name="OutputBox"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="11"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     Foreground="{DynamicResource TE_LineNumberForeground}"
                     Background="{DynamicResource TE_Background}"
                     BorderThickness="0"
                     Padding="6" />
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Background="{DynamicResource TE_Background}"
                BorderBrush="{DynamicResource DockSplitterBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBar"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       FontSize="11"
                       Foreground="{DynamicResource TE_LineNumberForeground}"
                       Text="Ready" />
        </Border>
    </Grid>
</UserControl>

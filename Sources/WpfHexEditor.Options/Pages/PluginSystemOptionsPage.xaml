<UserControl x:Class="WpfHexEditor.Options.Pages.PluginSystemOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <StackPanel Margin="0,0,0,16">

        <!-- ── Plugin Directory ──────────────────────────────────────────────── -->
        <TextBlock Text="Plugin Directory"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <TextBlock Text="Additional directory scanned for user-installed plugins (leave empty to use default)."
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.7"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <TextBox x:Name="TextPluginsDir"
                 Foreground="{DynamicResource DockMenuForegroundBrush}"
                 Background="{DynamicResource Panel_ToolbarBrush}"
                 BorderBrush="{DynamicResource DockBorderBrush}"
                 Padding="4,3"
                 Margin="0,0,0,4"
                 TextChanged="OnTextChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Watchdog ───────────────────────────────────────────────────────── -->
        <TextBlock Text="Watchdog"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="CheckEnableWatchdog"
                  Content="Enable plugin watchdog (monitors call timeouts)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Watchdog timeout (seconds):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextWatchdogTimeout" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Monitoring ─────────────────────────────────────────────────────── -->
        <TextBlock Text="Slow-Plugin Monitoring"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Monitoring interval (seconds):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextMonitoringInterval" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Response time threshold (ms):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextResponseTime" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="CPU threshold (%):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <TextBox x:Name="TextCpuThreshold" Grid.Column="1"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     Background="{DynamicResource Panel_ToolbarBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"
                     Padding="4,3"
                     TextChanged="OnTextChanged"/>
        </Grid>

    </StackPanel>
</UserControl>

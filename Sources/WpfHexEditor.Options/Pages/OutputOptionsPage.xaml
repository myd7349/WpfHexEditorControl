<!--
    Project: WpfHexEditor.Options
    File: OutputOptionsPage.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Theme: DynamicResource brushes (all themes via PanelCommon.xaml)
    Description: Options page for Output panel log-level colours.
                 Accessible via Options > Environment > Output.
-->
<UserControl x:Class="WpfHexEditor.Options.Pages.OutputOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cp="clr-namespace:WpfHexEditor.ColorPicker.Controls;assembly=WpfHexEditor.ColorPicker"
             Background="Transparent">

    <StackPanel Margin="0,0,0,16">

        <!-- ── Log-Level Colours ──────────────────────────────────────────── -->
        <TextBlock Text="Log-Level Colours"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,4"/>

        <TextBlock Text="Customise the colour used for each log level in the Output panel. INFO inherits the active theme foreground and cannot be changed."
                   FontSize="11" Opacity="0.65"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- WARN -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Warning (WARN):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker x:Name="PickerWarn"
                            Grid.Column="1"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- ERROR -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Error (ERROR):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker x:Name="PickerError"
                            Grid.Column="1"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- DEBUG -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Debug (DEBUG):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker x:Name="PickerDebug"
                            Grid.Column="1"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- SUCCESS -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Success (OK):"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <cp:ColorPicker x:Name="PickerSuccess"
                            Grid.Column="1"
                            ShowAlphaChannel="False"
                            Height="32"
                            Margin="8,0"
                            ColorChanged="OnColorPickerChanged"/>
        </Grid>

        <!-- Reset button -->
        <Button Content="Reset to Default Colours"
                Margin="0,8,0,0"
                Padding="8,3"
                Click="OnResetColours"
                Background="{DynamicResource Panel_ToolbarBrush}"
                Foreground="{DynamicResource DockMenuForegroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                HorizontalAlignment="Left"/>

    </StackPanel>
</UserControl>

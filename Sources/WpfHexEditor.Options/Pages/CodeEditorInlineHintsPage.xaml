<!--
// ==========================================================
// Project: WpfHexEditor.Options
// File: CodeEditorCodeLensPage.xaml
// Author: Auto
// Created: 2026-03-18
// Description:
//     Options page for CodeEditor CodeLens feature.
//     Master enable/disable toggle + per-symbol-kind checkboxes.
//     All kinds enabled by default.
//
// Theme: DynamicResource brushes only (all 8 themes).
// ==========================================================
-->
<UserControl x:Class="WpfHexEditor.Options.Pages.CodeEditorCodeLensPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Themed text button — proper IsMouseOver/IsPressed triggers using IDE palette. -->
        <Style x:Key="OptionsTextButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource Panel_ToolbarBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource DockBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Panel_ToolbarButtonActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="0,0,0,16">

        <!-- ── Code Lens ─────────────────────────────────────────────────── -->
        <TextBlock Text="Code Lens"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,10"/>

        <CheckBox x:Name="CheckCodeLensEnabled"
                  Content="Enable Code Lens (show inline reference counts above declarations)"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  Margin="0,0,0,8"
                  Checked="OnCheckChanged"
                  Unchecked="OnCheckChanged"/>

        <Separator Margin="0,12,0,12"
                   Background="{DynamicResource DockBorderBrush}"/>

        <!-- ── Symbol Kinds ──────────────────────────────────────────────── -->
        <TextBlock Text="Show hints for symbol kinds:"
                   FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Margin="0,0,0,4"/>

        <TextBlock Text="Uncheck a kind to hide its reference-count hints while keeping Code Lens active for others."
                   FontSize="11"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   Opacity="0.65"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- Kind panel — disabled when master toggle is off -->
        <StackPanel x:Name="KindPanel"
                    IsEnabled="{Binding IsChecked, ElementName=CheckCodeLensEnabled}">

            <!-- Types sub-group -->
            <TextBlock Text="Types"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.75"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkClass"
                      Content="Class"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkInterface"
                      Content="Interface"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkStruct"
                      Content="Struct"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkEnum"
                      Content="Enum"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkRecord"
                      Content="Record"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkDelegate"
                      Content="Delegate"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,12"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <!-- Members sub-group -->
            <TextBlock Text="Members"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Opacity="0.75"
                       Margin="0,0,0,6"/>

            <CheckBox x:Name="ChkMethod"
                      Content="Method"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkConstructor"
                      Content="Constructor"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkProperty"
                      Content="Property"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkIndexer"
                      Content="Indexer"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkField"
                      Content="Field"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,6"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <CheckBox x:Name="ChkEvent"
                      Content="Event"
                      Foreground="{DynamicResource DockMenuForegroundBrush}"
                      Margin="12,0,0,12"
                      Checked="OnCheckChanged" Unchecked="OnCheckChanged"/>

            <!-- Quick-pick row -->
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnSelectAll"
                        Content="Select All"
                        Style="{StaticResource OptionsTextButtonStyle}"
                        Click="OnSelectAll"/>
                <Button x:Name="BtnSelectNone"
                        Content="Select None"
                        Margin="8,0,0,0"
                        Style="{StaticResource OptionsTextButtonStyle}"
                        Click="OnSelectNone"/>
            </StackPanel>

        </StackPanel>

    </StackPanel>
</UserControl>

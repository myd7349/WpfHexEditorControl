<UserControl x:Class="WpfHexEditor.Options.OptionsEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockWindowBackgroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WpfHexEditor.Docking.Wpf;component/Themes/PanelCommon.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- TreeViewItem sans couleur système — utilise les brushes du thème actif -->
            <Style TargetType="{x:Type TreeViewItem}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding"    Value="4,3"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type TreeViewItem}">
                            <StackPanel>
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ItemsPresenter x:Name="ItemsHost"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource SE_SelectedBrush}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsSelected"  Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource SE_HoverBrush}"/>
                                </MultiTrigger>
                                <Trigger Property="IsExpanded" Value="False">
                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Corps -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar VS-style ─────────────────────────────────────────────── -->
        <Border Style="{StaticResource PanelToolbarStyle}">
            <DockPanel LastChildFill="True">

                <!-- Droite : bouton JSON + scope + filtre -->
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource PanelIconButtonStyle}"
                        ToolTip="Edit user settings as JSON"
                        Click="OnEditJson"
                        Margin="4,0,4,0">
                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </Button>

                <ComboBox DockPanel.Dock="Right"
                          Width="170"
                          IsEnabled="False"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="User (installation)" IsSelected="True"/>
                </ComboBox>

                <TextBlock DockPanel.Dock="Right"
                           Text="Applies to:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="12,0,4,0"/>

                <ComboBox x:Name="FilterCombo"
                          DockPanel.Dock="Right"
                          Width="150"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          SelectionChanged="OnFilterChanged"/>

                <TextBlock DockPanel.Dock="Right"
                           Text="Filter:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="12,0,4,0"/>

                <!-- Gauche : recherche -->
                <TextBox x:Name="SearchBox"
                         Margin="4,3"
                         MinWidth="180"
                         VerticalContentAlignment="Center"
                         TextChanged="OnSearchTextChanged"/>

            </DockPanel>
        </Border>

        <!-- ── Corps : arbre gauche + page droite ──────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="320"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Arbre des pages -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    BorderThickness="0,0,1,0">
                <TreeView x:Name="PageTree"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="{DynamicResource DockMenuForegroundBrush}"
                          SelectedItemChanged="OnTreeSelectionChanged"/>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"
                          ShowsPreview="False"/>

            <!-- Zone d'affichage de la page active -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ContentPresenter x:Name="PageHost"
                                  Margin="20,16"
                                  VerticalAlignment="Top"/>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>

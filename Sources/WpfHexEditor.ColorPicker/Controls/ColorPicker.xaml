<UserControl x:Class="WpfHexEditor.ColorPicker.Controls.ColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfHexEditor.ColorPicker.Converters"
             mc:Ignorable="d"
             d:DesignHeight="32" d:DesignWidth="200">

    <UserControl.Resources>
        <!-- Fallback brushes for apps without theme -->
        <SolidColorBrush x:Key="BorderBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="ForegroundBrush" Color="#333333"/>

        <!-- ColorPicker converters -->
        <local:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
        <local:ColorToContrastBrushConverter x:Key="ColorToContrastBrushConverter"/>
        <local:HueToGradientBrushConverter x:Key="HueToGradientBrushConverter"/>
    </UserControl.Resources>

    <Grid>
        <!-- Compact Display (Trigger) -->
        <Border BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="3"
                Height="28"
                Cursor="Hand"
                MouseLeftButtonUp="Border_MouseUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Color Preview -->
                <Border Grid.Column="0"
                       x:Name="ColorPreview"
                       Background="{Binding SelectedColor, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource ColorToBrushConverter}}"
                       CornerRadius="2,0,0,2"
                       Margin="2"/>

                <!-- Hex Color Display -->
                <Border Grid.Column="1"
                       Background="{DynamicResource SurfaceElevatedBrush}"
                       Padding="8,0"
                       CornerRadius="0,2,2,0">
                    <TextBlock x:Name="HexColorText"
                              FontSize="11"
                              FontFamily="Consolas"
                              Foreground="{DynamicResource ForegroundBrush}"
                              VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Popup with ColorPicker Dialog -->
        <Popup x:Name="ColorPickerPopup"
               PlacementTarget="{Binding ElementName=ColorPreview}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="White"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>

                <TabControl Width="380" Height="480">
                    <!-- Custom Color Tab -->
                    <TabItem Header="{DynamicResource ColorPicker_Tab_Custom}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">

                                <!-- HSV Color Selector -->
                                <TextBlock Text="{DynamicResource ColorPicker_Section_ColorSelector}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>

                                <Grid Height="200" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 2D HSV Canvas (Saturation x Value) -->
                                    <Border Grid.Column="0" BorderBrush="#999999" BorderThickness="1" CornerRadius="3">
                                        <Canvas x:Name="HsvCanvas"
                                               Background="Red"
                                               ClipToBounds="True"
                                               MouseDown="HsvCanvas_MouseDown"
                                               MouseMove="HsvCanvas_MouseMove"
                                               MouseUp="HsvCanvas_MouseUp">
                                            <!-- Saturation gradient (White to Transparent) -->
                                            <Rectangle Width="{Binding ActualWidth, ElementName=HsvCanvas}"
                                                      Height="{Binding ActualHeight, ElementName=HsvCanvas}">
                                                <Rectangle.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="White" Offset="0"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>

                                            <!-- Value/Brightness gradient (Transparent to Black) -->
                                            <Rectangle Width="{Binding ActualWidth, ElementName=HsvCanvas}"
                                                      Height="{Binding ActualHeight, ElementName=HsvCanvas}">
                                                <Rectangle.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="Transparent" Offset="0"/>
                                                        <GradientStop Color="Black" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Rectangle.Fill>
                                            </Rectangle>

                                            <!-- Crosshair selector -->
                                            <Canvas x:Name="HsvThumb" Width="12" Height="12">
                                                <Ellipse Width="12" Height="12"
                                                        Stroke="White"
                                                        StrokeThickness="2"
                                                        Fill="Transparent"/>
                                                <Ellipse Width="12" Height="12"
                                                        Stroke="Black"
                                                        StrokeThickness="1"
                                                        Fill="Transparent"/>
                                            </Canvas>
                                        </Canvas>
                                    </Border>

                                    <!-- Hue Slider (Vertical Rainbow) -->
                                    <Border Grid.Column="1" BorderBrush="#999999" BorderThickness="1" CornerRadius="3" Margin="4,0,0,0">
                                        <Slider x:Name="HueSlider"
                                               Orientation="Vertical"
                                               Minimum="0"
                                               Maximum="360"
                                               Value="{Binding Hue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               Background="{Binding Converter={StaticResource HueToGradientBrushConverter}}"
                                               TickFrequency="1"
                                               IsSnapToTickEnabled="False"/>
                                    </Border>
                                </Grid>

                                <!-- Color Preview (Before | After) -->
                                <Grid Height="50" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" BorderBrush="#999999" BorderThickness="1,1,0,1" CornerRadius="3,0,0,3">
                                        <Grid>
                                            <Border x:Name="OriginalColorPreview" Background="Blue"/>
                                            <TextBlock Text="{DynamicResource ColorPicker_Preview_Original}" FontSize="10" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Background="#80000000" Padding="4,2"/>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1" BorderBrush="#999999" BorderThickness="1" CornerRadius="0,3,3,0">
                                        <Grid>
                                            <Border Background="{Binding SelectedColor, Converter={StaticResource ColorToBrushConverter}}"/>
                                            <TextBlock Text="{DynamicResource ColorPicker_Preview_New}" FontSize="10" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Background="#80000000" Padding="4,2"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- RGBA Sliders -->
                                <TextBlock Text="{DynamicResource ColorPicker_Section_RGBValues}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>

                                <!-- Red -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="R" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding Red, Mode=TwoWay}" Margin="4,0"/>
                                    <TextBox Grid.Column="2" Text="{Binding Red, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            VerticalContentAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>

                                <!-- Green -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="G" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding Green, Mode=TwoWay}" Margin="4,0"/>
                                    <TextBox Grid.Column="2" Text="{Binding Green, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            VerticalContentAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>

                                <!-- Blue -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding Blue, Mode=TwoWay}" Margin="4,0"/>
                                    <TextBox Grid.Column="2" Text="{Binding Blue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            VerticalContentAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>

                                <!-- Alpha -->
                                <Grid x:Name="AlphaSliderGrid" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="A" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding Alpha, Mode=TwoWay}" Margin="4,0"/>
                                    <TextBox Grid.Column="2" Text="{Binding Alpha, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            VerticalContentAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>

                                <!-- Hex Input -->
                                <TextBlock Text="{DynamicResource ColorPicker_Section_HexColor}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                            Text="{Binding HexColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            FontFamily="Consolas"
                                            VerticalContentAlignment="Center"
                                            Margin="0,0,4,0"/>
                                    <TextBlock Grid.Column="1"
                                              Text="{Binding ValidationIcon}"
                                              Foreground="{Binding ValidationColor, Converter={StaticResource ColorToBrushConverter}}"
                                              FontSize="18"
                                              FontWeight="Bold"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Grid>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Palette Tab -->
                    <TabItem Header="{DynamicResource ColorPicker_Tab_Palette}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">

                                <!-- Standard Colors -->
                                <TextBlock Text="{DynamicResource ColorPicker_Section_StandardColors}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                                <ItemsControl x:Name="StandardColorsPanel" Margin="0,0,0,16">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="40" Height="40"
                                                   Margin="2"
                                                   Background="{Binding Converter={StaticResource ColorToBrushConverter}}"
                                                   BorderBrush="#CCCCCC"
                                                   BorderThickness="1"
                                                   CornerRadius="3"
                                                   Cursor="Hand"
                                                   MouseDown="PaletteColor_MouseDown"
                                                   ToolTip="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Recent Colors -->
                                <TextBlock Text="{DynamicResource ColorPicker_Section_RecentColors}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                                <ItemsControl x:Name="RecentColorsPanel">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="32" Height="32"
                                                   Margin="2"
                                                   Background="{Binding Converter={StaticResource ColorToBrushConverter}}"
                                                   BorderBrush="#CCCCCC"
                                                   BorderThickness="1"
                                                   CornerRadius="3"
                                                   Cursor="Hand"
                                                   MouseDown="RecentColor_MouseDown"
                                                   ToolTip="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Popup>
    </Grid>
</UserControl>

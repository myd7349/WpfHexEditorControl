<UserControl x:Class="WpfHexEditor.Editor.AudioViewer.Controls.AudioViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource TE_Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <WrapPanel Grid.Row="0" Margin="4,2">
            <TextBlock x:Name="FormatInfo" Text="Audio"
                       VerticalAlignment="Center" FontSize="11"
                       Foreground="{DynamicResource TE_LineNumberForeground}"/>
        </WrapPanel>

        <!-- Waveform canvas -->
        <Border Grid.Row="1" BorderThickness="0"
                Background="{DynamicResource TE_Background}">
            <Canvas x:Name="WaveformCanvas" ClipToBounds="True"/>
        </Border>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="2"
                   Margin="4,2" FontSize="11"
                   Foreground="{DynamicResource TE_LineNumberForeground}"
                   Text="Drop or open an audio file"/>
    </Grid>
</UserControl>

<!--
    Project: WpfHexEditor.App.AssemblyExplorer
    File: Views/ProjectPickerDialog.xaml
    Author: Derek Tremblay
    Created: 2026-03-16
    Description:
        Modal dialog for selecting a WH native project to extract decompiled C# code into.
        Shows a ListBox of all projects in the currently loaded solution.
        Accepts the selected project via SelectedProject on OK; returns null on Cancel.
    Theme: DynamicResource DockMenu* and PFP_* brush tokens.
-->
<local:ThemedDialogBase x:Class="WpfHexEditor.App.AssemblyExplorer.Views.ProjectPickerDialog"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:local="clr-namespace:WpfHexEditor.App.AssemblyExplorer.Views"
                        Title="{DynamicResource AsmExplorer_ExtractToProject}"
                        Width="360"
                        Height="260"
                        ResizeMode="NoResize"
                        WindowStartupLocation="CenterOwner">

    <Grid Background="{DynamicResource DockMenuBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Instruction label -->
            <RowDefinition Height="*"/>      <!-- Project list -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Instruction -->
        <TextBlock Grid.Row="0"
                   Text="{DynamicResource AsmExplorer_SelectProject}"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   FontSize="11"
                   Margin="12,10,12,4"
                   TextWrapping="Wrap"/>

        <!-- Project list -->
        <Border Grid.Row="1"
                Margin="12,4,12,4"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1">
            <ListBox x:Name="ProjectListBox"
                     Background="{DynamicResource PFP_PanelBackgroundBrush}"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     BorderThickness="0"
                     FontSize="12"
                     MouseDoubleClick="OnListDoubleClick"
                     SelectionChanged="OnSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="2,2">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" VerticalAlignment="Center"
                                       Margin="0,0,6,0"
                                       Foreground="{DynamicResource PFP_AccentBrush}"/>
                            <TextBlock Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       FontSize="12"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,4,12,10">
            <Button x:Name="OkButton"
                    Content="OK"
                    Width="72" Height="24"
                    Margin="0,0,6,0"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="OnOkClick"
                    Background="{DynamicResource PFP_SectionBackgroundBrush}"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    FontSize="11"/>
            <Button Content="{DynamicResource AsmExplorer_Cancel}"
                    Width="72" Height="24"
                    IsCancel="True"
                    Click="OnCancelClick"
                    Background="Transparent"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    FontSize="11"/>
        </StackPanel>
    </Grid>

</local:ThemedDialogBase>

<!--
    Project: WpfHexEditor.App.AssemblyExplorer
    File: Views/AssemblyExplorerPanel.xaml
    Author: Derek Tremblay
    Created: 2026-03-08
    Description:
        Main dockable panel for the .NET Assembly Explorer plugin.
        VS-Like layout: toolbar at top (ToolbarOverflowManager, 6 groups),
        custom AssemblyTreeView in the center, AssemblyDetailPane at the bottom.
        Theme: DynamicResource PFP_* and Dock* brush tokens.

    Architecture Notes:
        Toolbar group collapse priority (lowest=first):
          TbgDecompile → TbgVisibility → TbgSort → TbgSync → TbgExpandCollapse → TbgFilter (last)
        ToolbarOverflowManager initialized in code-behind Loaded handler.
        Panel is left-docked, PreferredWidth=280.
-->
<UserControl x:Class="WpfHexEditor.App.AssemblyExplorer.Views.AssemblyExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WpfHexEditor.App.AssemblyExplorer.Controls"
             xmlns:views="clr-namespace:WpfHexEditor.App.AssemblyExplorer.Views"
             xmlns:ui="clr-namespace:WpfHexEditor.SDK.UI;assembly=WpfHexEditor.SDK"
             Background="{DynamicResource PFP_PanelBackgroundBrush}"
             Foreground="{DynamicResource PFP_TextBrush}"
             Focusable="True"
             KeyDown="OnPanelKeyDown"
             Loaded="OnLoaded"
             xmlns:aeSvc="clr-namespace:WpfHexEditor.App.AssemblyExplorer.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <aeSvc:AssemblyExplorerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Main content -->
            <RowDefinition Height="22"/>    <!-- Stats status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0: Toolbar ════════════════════════════════════════════════ -->
        <Border x:Name="ToolbarBorder"
                Grid.Row="0"
                Style="{StaticResource PanelToolbarStyle}"
                SizeChanged="OnToolbarSizeChanged">
            <DockPanel LastChildFill="False">

                <!-- Always-visible right panel — Close All button always reachable -->
                <StackPanel x:Name="ToolbarRightPanel"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE74D;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="22" Height="22"
                            Command="{Binding CloseAllCommand}" ToolTip="{StaticResource AsmExplorer_CloseAllTooltip2}"/>
                </StackPanel>

                <!-- Overflow button — shown when groups collapse -->
                <Button x:Name="ToolbarOverflowButton"
                        DockPanel.Dock="Right"
                        Style="{StaticResource PanelIconButtonStyle}"
                        Content="&#xE712;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="22" Height="22"
                        Visibility="Collapsed" ToolTip="{StaticResource AsmExplorer_MoreToolbarOptions}"
                        Click="OnOverflowButtonClick">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="OverflowContextMenu"
                                     Background="{DynamicResource DockMenuBackgroundBrush}"
                                     BorderBrush="{DynamicResource DockBorderBrush}"
                                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                                     Opened="OnOverflowMenuOpened">
                            <MenuItem Header="{StaticResource AsmExplorer_DecompileMenu}"    Tag="TbgDecompile"      IsCheckable="True"/>
                            <MenuItem Header="{StaticResource AsmExplorer_VisibilityMenu}"   Tag="TbgVisibility"     IsCheckable="True"/>
                            <MenuItem Header="{StaticResource AsmExplorer_SortMenu}"         Tag="TbgSort"           IsCheckable="True"/>
                            <MenuItem Header="{StaticResource AsmExplorer_SyncMenu}"         Tag="TbgSync"           IsCheckable="True"/>
                            <MenuItem Header="{StaticResource AsmExplorer_ExpandCollapseMenu}" Tag="TbgExpandCollapse" IsCheckable="True"/>
                            <MenuItem Header="{StaticResource AsmExplorer_FilterMenu}"       Tag="TbgFilter"         IsCheckable="True"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- TbgDecompile [0] — first to collapse -->
                <StackPanel x:Name="TbgDecompile"
                            DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Margin="2,0">
                    <!-- Open Assembly button (Ctrl+O in panel focus) -->
                    <Button x:Name="BtnOpenAssembly"
                            Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xEC50;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="22" Height="22" ToolTip="{StaticResource AsmExplorer_OpenAssemblyTooltip}"
                            Click="OnOpenAssemblyClick"/>
                    <!-- Decompile to Code Editor -->
                    <Button x:Name="BtnDecompile"
                            Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE8F4;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="22" Height="22" ToolTip="{StaticResource AsmExplorer_OpenInCodeEditor}"
                            Command="{Binding OpenInEditorCommand}"/>
                </StackPanel>

                <!-- TbgVisibility [1] — show/hide References/Resources/Metadata toggles -->
                <StackPanel x:Name="TbgVisibility"
                            DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Margin="2,0">
                    <ToggleButton x:Name="BtnShowRefs"
                                  Style="{StaticResource PanelIconToggleStyle}"
                                  Content="&#xE71B;"
                                  FontFamily="Segoe MDL2 Assets"
                                  Width="22" Height="22"
                                  IsChecked="{Binding ShowReferences}" ToolTip="{StaticResource AsmExplorer_ShowReferences}"/>
                    <ToggleButton x:Name="BtnShowRes"
                                  Style="{StaticResource PanelIconToggleStyle}"
                                  Content="&#xEB9F;"
                                  FontFamily="Segoe MDL2 Assets"
                                  Width="22" Height="22"
                                  IsChecked="{Binding ShowResources}" ToolTip="{StaticResource AsmExplorer_ShowResources}"/>
                    <ToggleButton x:Name="BtnShowMeta"
                                  Style="{StaticResource PanelIconToggleStyle}"
                                  Content="&#xE9D2;"
                                  FontFamily="Segoe MDL2 Assets"
                                  Width="22" Height="22"
                                  IsChecked="{Binding ShowMetadata}" ToolTip="{StaticResource AsmExplorer_ShowMetadata}"/>
                </StackPanel>

                <!-- TbgSort [2] — sort order combo -->
                <StackPanel x:Name="TbgSort"
                            DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Margin="2,0">
                    <ToggleButton x:Name="BtnSort"
                                  Style="{StaticResource PanelIconToggleStyle}"
                                  Content="&#xE8CB;"
                                  FontFamily="Segoe MDL2 Assets"
                                  Width="22" Height="22"
                                  IsChecked="{Binding SortAlphabetical}" ToolTip="{StaticResource AsmExplorer_SortAlpha}"/>
                </StackPanel>

                <!-- TbgSync [3] — sync with HexEditor toggle -->
                <StackPanel x:Name="TbgSync"
                            DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Margin="2,0">
                    <ToggleButton x:Name="BtnSync"
                                  Style="{StaticResource PanelIconToggleStyle}"
                                  Content="&#xE8AB;"
                                  FontFamily="Segoe MDL2 Assets"
                                  Width="22" Height="22"
                                  IsChecked="{Binding SyncWithHexEditor}" ToolTip="{StaticResource AsmExplorer_SyncHexEditor}"/>
                </StackPanel>

                <!-- TbgExpandCollapse [4] — expand / collapse all -->
                <StackPanel x:Name="TbgExpandCollapse"
                            DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Margin="2,0">
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE8A9;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="22" Height="22"
                            Command="{Binding ExpandAllCommand}" ToolTip="{StaticResource AsmExplorer_ExpandAll}"/>
                    <Button Style="{StaticResource PanelIconButtonStyle}"
                            Content="&#xE8AA;"
                            FontFamily="Segoe MDL2 Assets"
                            Width="22" Height="22"
                            Command="{Binding CollapseAllCommand}" ToolTip="{StaticResource AsmExplorer_CollapseAllPanel}"/>
                </StackPanel>

                <!-- TbgFilter [5] — last to collapse: filter TextBox -->
                <StackPanel x:Name="TbgFilter"
                            DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Margin="2,0">
                    <controls:FilterBox x:Name="FilterControl"
                                        Width="120"
                                        VerticalAlignment="Center"
                                        FilterText="{Binding FilterText, Mode=TwoWay}"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══ ROW 1: Tree + detail pane ════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="80"/>
                <RowDefinition Height="5"/>     <!-- Splitter -->
                <RowDefinition Height="220" MinHeight="60"/>
            </Grid.RowDefinitions>

            <!-- Assembly tree + loading overlay -->
            <Grid Grid.Row="0">
                <controls:AssemblyTreeView x:Name="MainTreeView"
                                           NodeSelected="OnTreeNodeSelected"
                                           OpenInHexEditorRequested="OnOpenInHexEditor"
                                           DecompileRequested="OnDecompile"
                                           CopyNameRequested="OnCopyName"
                                           CopyFullNameRequested="OnCopyFullName"
                                           CopyOffsetRequested="OnCopyOffset"
                                           CloseAssemblyRequested="OnCloseAssembly"/>

                <!-- Loading overlay — reusable SDK control, visible while IsLoading=true -->
                <ui:LoadingOverlay IsActive="{Binding IsLoading}" Content="{StaticResource AsmExplorer_LoadingAssembly}"/>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Row="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource PFP_BorderBrush}"
                          Cursor="SizeNS"/>

            <!-- Detail pane -->
            <views:AssemblyDetailPane x:Name="DetailPane"
                                      Grid.Row="2"/>
        </Grid>

        <!-- ═══ ROW 2: Stats status bar ══════════════════════════════════════ -->
        <StatusBar Grid.Row="2" Padding="4,0"
                   Background="{DynamicResource PFP_BorderBrush}">
            <TextBlock FontSize="11"
                       Text="{Binding StatsText, FallbackValue='No assemblies loaded.'}"
                       VerticalAlignment="Center"/>
        </StatusBar>
    </Grid>
</UserControl>

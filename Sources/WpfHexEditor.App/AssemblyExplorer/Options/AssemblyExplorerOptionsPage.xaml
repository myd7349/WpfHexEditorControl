<!--
    Project: WpfHexEditor.App.AssemblyExplorer
    File: Options/AssemblyExplorerOptionsPage.xaml
    Author: Derek Tremblay
    Created: 2026-03-08
    Description:
        Options page for the Assembly Explorer plugin.
        Shown in IDE Options > Plugins > Assembly Explorer
        and in Plugin Manager "Settings" tab.
        Theme: DynamicResource PFP_* tokens.
-->
<UserControl x:Class="WpfHexEditor.App.AssemblyExplorer.Options.AssemblyExplorerOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}"
             Padding="12"
             xmlns:aeSvc="clr-namespace:WpfHexEditor.App.AssemblyExplorer.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <aeSvc:AssemblyExplorerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>

        <!-- Section: Decompiler -->
        <TextBlock Text="{StaticResource AE_DecompilerSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{StaticResource AE_DetailFontSizeLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Slider x:Name="FontSizeSlider"
                        Minimum="8" Maximum="24" TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Width="120"
                        VerticalAlignment="Center"
                        ValueChanged="OnFontSizeChanged"/>
                <TextBlock x:Name="FontSizeLabel"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="11"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{StaticResource AE_BackendLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <ComboBox x:Name="BackendCombo"
                      Grid.Column="1"
                      Width="200"
                      HorizontalAlignment="Left"
                      Background="{DynamicResource PFP_SectionBackgroundBrush}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      BorderBrush="{DynamicResource PFP_BorderBrush}">
                <ComboBoxItem Content="{StaticResource AE_ILSpyOption}" Tag="ILSpy" IsSelected="True"/>
                <ComboBoxItem Content="{StaticResource AE_SkeletonOption}" Tag="Skeleton"/>
            </ComboBox>
        </Grid>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{StaticResource AE_QualityLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <ComboBox x:Name="QualityCombo"
                      Grid.Column="1"
                      Width="200"
                      HorizontalAlignment="Left"
                      Background="{DynamicResource PFP_SectionBackgroundBrush}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      BorderBrush="{DynamicResource PFP_BorderBrush}">
                <ComboBoxItem Content="{StaticResource AE_FullQuality}"    Tag="Full" IsSelected="True"/>
                <ComboBoxItem Content="{StaticResource AE_NormalQuality}"    Tag="Normal"/>
                <ComboBoxItem Content="{StaticResource AE_SkeletonQuality}" Tag="Skeleton"/>
            </ComboBox>
        </Grid>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{StaticResource AE_LangVersionLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <ComboBox x:Name="CSharpVersionCombo"
                      Grid.Column="1"
                      Width="200"
                      HorizontalAlignment="Left"
                      Background="{DynamicResource PFP_SectionBackgroundBrush}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      BorderBrush="{DynamicResource PFP_BorderBrush}">
                <ComboBoxItem Content="C# 12.0 (latest)" Tag="1200" IsSelected="True"/>
                <ComboBoxItem Content="C# 11.0"          Tag="1100"/>
                <ComboBoxItem Content="C# 10.0"          Tag="1000"/>
                <ComboBoxItem Content="C# 9.0"           Tag="900"/>
                <ComboBoxItem Content="C# 8.0"           Tag="800"/>
                <ComboBoxItem Content="C# 7.3"           Tag="703"/>
                <ComboBoxItem Content="C# 6.0"           Tag="600"/>
            </ComboBox>
        </Grid>

        <CheckBox x:Name="ChkShowXmlDocs"
                  Content="{StaticResource AE_ShowXmlDocs}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkShowHidden"
                  Content="{StaticResource AE_ShowHiddenMembers}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkEnablePdb"
                  Content="{StaticResource AE_PdbIntegration}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{StaticResource AE_DecompileLangLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <!-- Items populated dynamically in code-behind from DecompilationLanguageRegistry.All -->
            <ComboBox x:Name="LanguageCombo"
                      Grid.Column="1"
                      Width="160"
                      HorizontalAlignment="Left"
                      Background="{DynamicResource PFP_SectionBackgroundBrush}"
                      Foreground="{DynamicResource PFP_TextBrush}"
                      BorderBrush="{DynamicResource PFP_BorderBrush}"/>
        </Grid>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,8"/>

        <!-- Section: Behaviour -->
        <TextBlock Text="{StaticResource AE_BehaviourSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <CheckBox x:Name="ChkAutoAnalyze"
                  Content="{StaticResource AE_AutoAnalyzeOption}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkAutoSync"
                  Content="{StaticResource AE_SyncCursorOption}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkShowResources"
                  Content="{StaticResource AE_ShowResourcesOption}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkShowMetadata"
                  Content="{StaticResource AE_ShowMetadataOption}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkInheritTheme"
                  Content="{StaticResource AE_InheritThemeOption}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkShowNonPublic"
                  Content="{StaticResource AE_ShowNonPublicOption}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkShowInherited"
                  Content="{StaticResource AE_ShowInheritedOption}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,4"/>

        <CheckBox x:Name="ChkPinAssemblies"
                  Content="{StaticResource AE_PinAssembliesOption}"
                  Foreground="{DynamicResource PFP_TextBrush}"
                  Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{StaticResource AE_MaxAssembliesLabel}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PFP_TextBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBox x:Name="TxtMaxAssemblies"
                         Width="60"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Background="{DynamicResource PFP_SectionBackgroundBrush}"
                         Foreground="{DynamicResource PFP_TextBrush}"
                         BorderBrush="{DynamicResource PFP_BorderBrush}"
                         CaretBrush="{DynamicResource PFP_TextBrush}"
                         Padding="4,2"
                         FontSize="12"
                         MaxLength="4"
                         TextAlignment="Right"/>
                <TextBlock Text="(1 – 500)"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PFP_SubTextBrush}"
                           FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- Separator -->
        <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,8,0,8"/>

        <!-- Section: Recent Files -->
        <TextBlock Text="{StaticResource AE_RecentSection}"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource PFP_AccentBrush}"
                   Margin="0,0,0,6"/>

        <Border Background="{DynamicResource PFP_SectionBackgroundBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="1"
                CornerRadius="2"
                Height="120"
                Margin="0,0,0,6">
            <ListBox x:Name="RecentFilesList"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource PFP_TextBrush}"
                     FontSize="11"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionMode="Single"/>
        </Border>

        <Button x:Name="BtnClearRecent"
                Content="{StaticResource AE_ClearRecentButton}"
                HorizontalAlignment="Left"
                Padding="8,4"
                FontSize="11"
                Background="{DynamicResource PFP_SectionBackgroundBrush}"
                Foreground="{DynamicResource PFP_TextBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="1"
                Click="OnClearRecentClick">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background"   Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
                    <Setter Property="Foreground"   Value="{DynamicResource PFP_TextBrush}"/>
                    <Setter Property="BorderBrush"  Value="{DynamicResource PFP_BorderBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Padding"      Value="8,4"/>
                    <Setter Property="FontSize"     Value="11"/>
                    <Setter Property="Cursor"       Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="2"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource Panel_ItemHoverBrush}"/>
                                        <Setter TargetName="Bd" Property="BorderBrush"
                                                Value="{DynamicResource PFP_InputBorderBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource PFP_BorderBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

    </StackPanel>
</UserControl>

<ec:ThemedDialog x:Class="WpfHexEditor.App.Dialogs.PasteConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        Title="{DynamicResource App_PasteConflict_Title}"
        Width="420" SizeToContent="Height"
        MinWidth="340"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- Conflict message -->
        <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
            <Run Text="{DynamicResource App_PasteConflict_AlreadyExists1}"/> <Run x:Name="OriginalNameRun" FontWeight="SemiBold"/> <Run Text="{DynamicResource App_PasteConflict_AlreadyExists2}"/>
        </TextBlock>
        <TextBlock Text="{DynamicResource App_PasteConflict_Instructions}"
                   TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,12"/>

        <!-- New name input -->
        <TextBlock Text="{DynamicResource App_PasteConflict_NewNameLabel}" Margin="0,0,0,4" />
        <TextBox x:Name="NewNameBox" Margin="0,0,0,4"
                 KeyDown="OnInputKeyDown" />

        <!-- Validation error -->
        <TextBlock x:Name="ErrorText" Foreground="OrangeRed" Margin="0,0,0,8"
                   Visibility="Collapsed" TextWrapping="Wrap" />

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{DynamicResource App_PasteConflict_Rename}" IsDefault="True" Click="OnRename"   Margin="0,0,8,0" />
            <Button Content="{DynamicResource App_PasteConflict_Skip}"                    Click="OnSkip"     Margin="0,0,8,0" />
            <Button Content="{DynamicResource App_PasteConflict_CancelAll}"              Click="OnCancelAll" />
        </StackPanel>

    </StackPanel>
</ec:ThemedDialog>

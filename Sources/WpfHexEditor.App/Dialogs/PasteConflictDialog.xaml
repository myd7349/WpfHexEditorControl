<ec:ThemedDialog x:Class="WpfHexEditor.App.Dialogs.PasteConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        Title="File Already Exists"
        Width="420" SizeToContent="Height"
        MinWidth="340"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="{DynamicResource DockWindowBackgroundBrush}" />
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Padding"     Value="4,2" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding"          Value="12,5" />
            <Setter Property="MinWidth"         Value="80" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Foreground"       Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="Background"       Value="{DynamicResource DockBackgroundBrush}" />
            <Setter Property="BorderBrush"      Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <Border x:Name="Overlay" Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True" />
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Overlay" Property="Background"  Value="#20FFFFFF" />
                                <Setter TargetName="Root"    Property="BorderBrush" Value="#A070D0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Overlay" Property="Background" Value="#40FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- Conflict message -->
        <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
            A file named <Run x:Name="OriginalNameRun" FontWeight="SemiBold"/> already exists
            in the destination folder.
        </TextBlock>
        <TextBlock Text="Enter a new name to rename the pasted file, or choose an action below."
                   TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,12"/>

        <!-- New name input -->
        <TextBlock Text="New name:" Margin="0,0,0,4" />
        <TextBox x:Name="NewNameBox" Margin="0,0,0,4"
                 KeyDown="OnInputKeyDown" />

        <!-- Validation error -->
        <TextBlock x:Name="ErrorText" Foreground="OrangeRed" Margin="0,0,0,8"
                   Visibility="Collapsed" TextWrapping="Wrap" />

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Rename" IsDefault="True" Click="OnRename"   Margin="0,0,8,0" />
            <Button Content="Skip"                    Click="OnSkip"     Margin="0,0,8,0" />
            <Button Content="Cancel All"              Click="OnCancelAll" />
        </StackPanel>

    </StackPanel>
</ec:ThemedDialog>

<ec:ThemedDialog x:Class="WpfHexEditor.App.Dialogs.PasteConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        Title="File Already Exists"
        Width="420" SizeToContent="Height"
        MinWidth="340"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- Conflict message -->
        <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">
            A file named <Run x:Name="OriginalNameRun" FontWeight="SemiBold"/> already exists
            in the destination folder.
        </TextBlock>
        <TextBlock Text="Enter a new name to rename the pasted file, or choose an action below."
                   TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,12"/>

        <!-- New name input -->
        <TextBlock Text="New name:" Margin="0,0,0,4" />
        <TextBox x:Name="NewNameBox" Margin="0,0,0,4"
                 KeyDown="OnInputKeyDown" />

        <!-- Validation error -->
        <TextBlock x:Name="ErrorText" Foreground="OrangeRed" Margin="0,0,0,8"
                   Visibility="Collapsed" TextWrapping="Wrap" />

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Rename" IsDefault="True" Click="OnRename"   Margin="0,0,8,0" />
            <Button Content="Skip"                    Click="OnSkip"     Margin="0,0,8,0" />
            <Button Content="Cancel All"              Click="OnCancelAll" />
        </StackPanel>

    </StackPanel>
</ec:ThemedDialog>

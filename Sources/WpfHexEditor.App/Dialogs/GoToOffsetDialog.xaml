<ec:ThemedDialog x:Class="WpfHexEditor.App.Dialogs.GoToOffsetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        Title="{DynamicResource App_GoToOffset_Title}"
        Width="340" SizeToContent="Height"
        MinWidth="280"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="16">
        <TextBlock Text="{DynamicResource App_GoToOffset_EnterOffset}" Margin="0,0,0,6" />

        <TextBox x:Name="OffsetInput" Margin="0,0,0,8"
                 KeyDown="OnInputKeyDown" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton x:Name="HexRadio"     Content="{DynamicResource App_GoToOffset_Hexadecimal}"  IsChecked="True"  Margin="0,0,12,0" />
            <RadioButton x:Name="DecimalRadio" Content="{DynamicResource App_GoToOffset_Decimal}" />
        </StackPanel>

        <TextBlock x:Name="ErrorText" Foreground="OrangeRed" Margin="0,0,0,8"
                   Visibility="Collapsed" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="{DynamicResource App_GoToOffset_Go}" IsDefault="True" Click="OnGo"    Margin="0,0,8,0" />
            <Button Content="{DynamicResource App_GoToOffset_Cancel}" IsCancel="True" Click="OnCancel" />
        </StackPanel>
    </StackPanel>
</ec:ThemedDialog>

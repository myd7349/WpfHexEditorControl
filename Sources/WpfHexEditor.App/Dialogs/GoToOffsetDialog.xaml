<Window x:Class="WpfHexEditor.App.Dialogs.GoToOffsetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Go To Offset"
        Width="340" SizeToContent="Height"
        MinWidth="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground"               Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin"                   Value="0,2" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="{DynamicResource DockWindowBackgroundBrush}" />
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Padding"     Value="4,2" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"         Value="{DynamicResource DockWindowBackgroundBrush}" />
            <Setter Property="Foreground"         Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="BorderBrush"        Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Padding"            Value="16,4" />
            <Setter Property="MinWidth"           Value="80" />
            <Setter Property="Cursor"             Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DockMenuItemHoverBrush}" />
                </Trigger>
                <Trigger Property="IsDefault" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource DockMenuForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">
        <TextBlock Text="Enter offset:" Margin="0,0,0,6" />

        <TextBox x:Name="OffsetInput" Margin="0,0,0,8"
                 KeyDown="OnInputKeyDown" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton x:Name="HexRadio"     Content="Hexadecimal (0x…)"  IsChecked="True"  Margin="0,0,12,0" />
            <RadioButton x:Name="DecimalRadio" Content="Decimal" />
        </StackPanel>

        <TextBlock x:Name="ErrorText" Foreground="OrangeRed" Margin="0,0,0,8"
                   Visibility="Collapsed" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="Go" IsDefault="True" Click="OnGo"    Margin="0,0,8,0" />
            <Button Content="Cancel" IsCancel="True" Click="OnCancel" />
        </StackPanel>
    </StackPanel>
</Window>

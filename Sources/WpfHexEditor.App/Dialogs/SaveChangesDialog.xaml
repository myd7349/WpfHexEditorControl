<ec:ThemedDialog x:Class="WpfHexEditor.App.Dialogs.SaveChangesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        Title="Save Changes"
        Width="460" SizeToContent="Height"
        MinWidth="360" MinHeight="160"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="20,20,20,16">

        <!-- Header -->
        <TextBlock x:Name="HeaderText"
                   FontSize="13" FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <!-- Master "Select All" (visible uniquement si plusieurs fichiers) -->
        <CheckBox x:Name="SelectAllCheck"
                  Content="Select All"
                  IsThreeState="False"
                  Visibility="Collapsed"
                  Margin="0,0,0,4"
                  Checked="OnSelectAllChecked"
                  Unchecked="OnSelectAllUnchecked" />

        <!-- File list (bordered box) -->
        <Border BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="1" CornerRadius="3"
                Background="{DynamicResource DockBackgroundBrush}"
                Margin="0,0,0,16" Padding="8,6" MinHeight="38">
            <ItemsControl x:Name="FileList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Title}"
                                  IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <StackPanel.Resources>
                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                    <Setter Property="Margin" Value="8,0,0,0" />
                </Style>
            </StackPanel.Resources>

            <Button Content="Save"
                    IsDefault="True"
                    Click="OnSaveClicked">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background"  Value="#6B3FA0" />
                        <Setter Property="Foreground"  Value="White" />
                        <Setter Property="BorderBrush" Value="#7B4FB0" />
                        <Setter Property="Margin"      Value="8,0,0,0" />
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="Don't Save" Click="OnDontSaveClicked" />
            <Button Content="Cancel" IsCancel="True" Click="OnCancelClicked" />

        </StackPanel>
    </StackPanel>
</ec:ThemedDialog>

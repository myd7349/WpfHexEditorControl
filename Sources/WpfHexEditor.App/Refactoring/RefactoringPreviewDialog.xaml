<Window x:Class="WpfHexEditor.App.Refactoring.RefactoringPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource CodeEditor_RefactorPreviewTitle}"
        Width="780" Height="460"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Panel_Background}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="PART_Grid"
                  Grid.Row="0"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  RowHeight="22"
                  FontSize="12"
                  Background="{DynamicResource TE_Background}"
                  Foreground="{DynamicResource TE_Foreground}"
                  BorderBrush="{DynamicResource DockBorderBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource CodeEditor_RefactorPreviewColFile}" Binding="{Binding FilePath}" Width="2*"/>
                <DataGridTextColumn Header="{DynamicResource CodeEditor_RefactorPreviewColLine}" Binding="{Binding LineNumber}" Width="60"/>
                <DataGridTextColumn Header="{DynamicResource CodeEditor_RefactorPreviewColOld}"  Binding="{Binding OldText}"   Width="3*"/>
                <DataGridTextColumn Header="{DynamicResource CodeEditor_RefactorPreviewColNew}"  Binding="{Binding NewText}"   Width="3*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="PART_CancelBtn"
                    Content="{DynamicResource CodeEditor_RefactorPreviewCancel}"
                    Width="90" Height="26" Margin="0,0,6,0"
                    Click="OnCancelClicked"/>
            <Button x:Name="PART_ApplyBtn"
                    Content="{DynamicResource CodeEditor_RefactorPreviewApply}"
                    Width="90" Height="26"
                    IsDefault="True"
                    Click="OnApplyClicked"/>
        </StackPanel>
    </Grid>
</Window>

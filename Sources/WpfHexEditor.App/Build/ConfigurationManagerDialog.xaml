    Phase 3K — Configuration Manager dialog.
    Allows the user to switch the active build configuration and platform,
    and to see per-project build flags for the active solution.

    Theme: DockMenuBackgroundBrush / DockMenuForegroundBrush / DockBorderBrush
-->

<Window x:Class="WpfHexEditor.App.Build.ConfigurationManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ToolTip="{DynamicResource APP_ConfigMgrTitle}"
        Width="640" Height="400"
        MinWidth="520" MinHeight="300"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DockWindowBackgroundBrush}"
        Foreground="{DynamicResource DockMenuForegroundBrush}"
             xmlns:appSvc="clr-namespace:WpfHexEditor.App.Services">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <appSvc:AppLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="{DynamicResource DockMenuBackgroundBrush}" />
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Margin"      Value="0,0,16,0" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background"                Value="{DynamicResource DockMenuBackgroundBrush}" />
            <Setter Property="Foreground"                Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="BorderBrush"               Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="GridLinesVisibility"        Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush"   Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="RowBackground"             Value="{DynamicResource DockMenuBackgroundBrush}" />
            <Setter Property="AlternatingRowBackground"  Value="{DynamicResource DockWindowBackgroundBrush}" />
            <Setter Property="AutoGenerateColumns"       Value="False" />
            <Setter Property="CanUserAddRows"            Value="False" />
            <Setter Property="CanUserDeleteRows"         Value="False" />
            <Setter Property="SelectionMode"             Value="Single" />
            <Setter Property="HeadersVisibility"         Value="Column" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"  Value="{DynamicResource DockWindowBackgroundBrush}" />
            <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}" />
            <Setter Property="Padding"     Value="6,4" />
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Active configuration selectors -->
        <TextBlock Grid.Row="0" Text="{StaticResource APP_ActiveSolutionConfig}"
                   FontSize="13" FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Label Content="{StaticResource APP_ConfigLabel}" />
            <ComboBox x:Name="CbActiveConfig" Width="130"
                      SelectionChanged="OnActiveConfigChanged" />

            <Label Content="{StaticResource APP_PlatformLabel}" />
            <ComboBox x:Name="CbActivePlatform" Width="110"
                      SelectionChanged="OnActivePlatformChanged" />
        </StackPanel>

        <!-- Per-project grid -->
        <DataGrid Grid.Row="2" x:Name="ProjectGrid" Margin="0,0,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{StaticResource APP_ProjectCol}"
                                    Binding="{Binding ProjectName}"
                                    Width="*"
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="{StaticResource APP_ConfigCol}"
                                    Binding="{Binding Configuration}"
                                    Width="130" />
                <DataGridTextColumn Header="{StaticResource APP_PlatformCol}"
                                    Binding="{Binding Platform}"
                                    Width="100" />
                <DataGridCheckBoxColumn Header="{StaticResource APP_BuildCol}"
                                        Binding="{Binding Build}"
                                        Width="60" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{StaticResource APP_ApplyButton}" Click="OnApply" Margin="0,0,8,0" />
            <Button Content="{StaticResource APP_CloseButton}" IsCancel="True" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>

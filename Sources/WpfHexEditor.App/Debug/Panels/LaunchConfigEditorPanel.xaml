<!--
// ===========================================================
// Project: WpfHexEditor.App.Debug
// File: Panels/LaunchConfigEditorPanel.xaml
// Description:
//     Panel for selecting and launching .whdbg debug configurations.
//     Open → picks file; Edit in IDE → opens in main CodeEditor;
//     Launch → starts debug session via IDebuggerService.
// ===========================================================
-->
<UserControl x:Class="WpfHexEditor.App.Debug.Panels.LaunchConfigEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockBackgroundBrush}"
             xmlns:dbgSvc="clr-namespace:WpfHexEditor.App.Debug.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <dbgSvc:DebuggerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,2">
            <StackPanel Orientation="Horizontal">

                <Button x:Name="BtnOpen"
                        ToolTip="{StaticResource DBG_OpenWhdbgTooltip}"
                        Padding="6,3" Margin="0,0,4,0"
                        Click="OnOpen">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,4,0"/>
                        <TextBlock Text="{StaticResource DBG_OpenButton}" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnSave" ToolTip="{StaticResource DBG_SaveTooltip}"
                        Padding="6,3" Margin="0,0,4,0"
                        Click="OnSave">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,4,0"/>
                        <TextBlock Text="{StaticResource DBG_SaveButton}" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnEditInIde" ToolTip="{StaticResource DBG_EditInIdeTooltip}"
                        Padding="6,3" Margin="0,0,4,0"
                        Click="OnEditInIde">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}" Margin="0,0,4,0"/>
                        <TextBlock Text="{StaticResource DBG_EditInIde}" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </StackPanel>
                </Button>

                <Separator Width="1" Margin="4,2" Background="{DynamicResource DockBorderBrush}"/>

                <Button x:Name="BtnLaunch" ToolTip="{StaticResource DBG_LaunchTooltip}"
                        Padding="6,3" Margin="0,0,8,0"
                        Click="OnLaunch">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xF5B0;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="#55CC55" Margin="0,0,4,0"/>
                        <TextBlock Text="{StaticResource DBG_LaunchButton}" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    </StackPanel>
                </Button>

                <Separator Width="1" Margin="0,2,8,2" Background="{DynamicResource DockBorderBrush}"/>

                <TextBlock Text="{StaticResource DBG_ConfigLabel}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Margin="0,0,4,0"/>
                <ComboBox x:Name="CboConfigurations"
                          Width="200"
                          SelectionChanged="OnConfigurationSelected"/>

            </StackPanel>
        </Border>

        <!-- ── Info area ────────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource DockBackgroundBrush}"
                Padding="16">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="&#xF5B0;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="48"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Opacity="0.2"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="{StaticResource DBG_LaunchConfigTitle}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           Opacity="0.6"
                           Text="{StaticResource DBG_LaunchHint}"/>
            </StackPanel>
        </Border>

        <!-- ── Status bar ───────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource Panel_ToolbarBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,2">
            <TextBlock x:Name="StatusText"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       FontSize="11" Text="{StaticResource DBG_NoFileOpen}"/>
        </Border>
    </Grid>
</UserControl>

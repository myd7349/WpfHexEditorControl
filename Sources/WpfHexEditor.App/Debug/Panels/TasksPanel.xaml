<UserControl x:Class="WpfHexEditor.App.Debug.Panels.TasksPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel Background="{DynamicResource PanelBackground}">

        <ToolBar DockPanel.Dock="Top" Background="{DynamicResource PanelBackground}">
            <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                    ToolTip="Refresh Tasks" Click="OnRefreshClick"/>
        </ToolBar>

        <ListView ItemsSource="{Binding Tasks}"
                  Background="{DynamicResource PanelBackground}"
                  Foreground="{DynamicResource PanelForeground}"
                  BorderThickness="0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID / Name"  Width="200" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Status"     Width="140" DisplayMemberBinding="{Binding Status}"/>
                    <GridViewColumn Header="Type"       Width="200" DisplayMemberBinding="{Binding Type}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>

<UserControl x:Class="WpfHexEditor.App.Debug.Panels.TasksPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dbgSvc="clr-namespace:WpfHexEditor.App.Debug.Services">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <dbgSvc:DebuggerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource DockBackgroundBrush}">

        <Border DockPanel.Dock="Top" Style="{DynamicResource PanelToolbarStyle}">
            <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                <Button Command="{Binding RefreshCommand}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE72C;"
                        ToolTip="{DynamicResource DBG_RefreshTooltip}"/>
            </StackPanel>
        </Border>

        <ListView ItemsSource="{Binding Tasks}"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{DynamicResource DBG_CopyTaskInfo}" InputGestureText="Ctrl+C"
                              Command="{Binding PlacementTarget.DataContext.CopyTaskCommand,  RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource DBG_Refresh}" InputGestureText="F5"
                              Command="{Binding PlacementTarget.DataContext.RefreshCommand,   RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{DynamicResource DBG_ColName}"  Width="200" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Status"                          Width="140" DisplayMemberBinding="{Binding Status}"/>
                    <GridViewColumn Header="{DynamicResource DBG_ColType}"  Width="200" DisplayMemberBinding="{Binding Type}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>

<UserControl x:Class="WpfHexEditor.App.Debug.Panels.ParallelWatchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dbgSvc="clr-namespace:WpfHexEditor.App.Debug.Services">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <dbgSvc:DebuggerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource DockBackgroundBrush}">

        <Border DockPanel.Dock="Top" Style="{DynamicResource PanelToolbarStyle}">
            <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                <Button Content="&#xE109;"
                        ToolTip="{StaticResource DBG_AddExpression}"
                        Command="{Binding AddRowCommand}"
                        Style="{DynamicResource PanelIconButtonStyle}"/>
                <Button Content="&#xE72C;"
                        ToolTip="{StaticResource DBG_RefreshTooltip}"
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource PanelIconButtonStyle}"/>
            </StackPanel>
        </Border>

        <ListView x:Name="Grid"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True">
            <ListView.View>
                <GridView x:Name="DynamicGridView">
                    <GridViewColumn Header="{StaticResource DBG_ColExpression}" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>

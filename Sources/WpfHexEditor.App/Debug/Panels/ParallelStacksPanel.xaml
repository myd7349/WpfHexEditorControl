<UserControl x:Class="WpfHexEditor.App.Debug.Panels.ParallelStacksPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dbgSvc="clr-namespace:WpfHexEditor.App.Debug.Services">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <dbgSvc:DebuggerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource DockBackgroundBrush}">

        <Border DockPanel.Dock="Top" Style="{DynamicResource PanelToolbarStyle}">
            <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                <Button Command="{Binding RefreshCommand}"
                        ToolTip="{StaticResource DBG_ParallelStacksRefreshTooltip}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE72C;"/>
                <Rectangle Width="1" Height="16" Margin="6,0"
                           Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           FontSize="11"
                           Text="{StaticResource DBG_ParallelStacksHint}"
                           Margin="4,0"/>
            </StackPanel>
        </Border>

        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     Height="2"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource DockBackgroundBrush}">
            <Canvas x:Name="StacksCanvas"
                    Background="Transparent"
                    MinWidth="400" MinHeight="300"/>
        </ScrollViewer>
    </DockPanel>
</UserControl>

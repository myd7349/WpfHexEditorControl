<UserControl x:Class="WpfHexEditor.App.Debug.Panels.MemoryWindowPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dbgSvc="clr-namespace:WpfHexEditor.App.Debug.Services">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <dbgSvc:DebuggerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource DockBackgroundBrush}">

        <Border DockPanel.Dock="Top" Style="{DynamicResource PanelToolbarStyle}">
            <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                <Button Command="{Binding PrevPageCommand}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE76B;"/>
                <Button Command="{Binding NextPageCommand}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE76C;"/>
                <Rectangle Width="1" Height="16" Margin="6,0"
                           Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                <TextBox Width="160" VerticalAlignment="Center"
                         Style="{DynamicResource PanelSearchBoxStyle}"
                         Text="{Binding AddressInput, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="OnAddressKeyDown"/>
                <Button Command="{Binding GoCommand}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE721;"/>
                <Button Command="{Binding RefreshCommand}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE72C;"
                        ToolTip="{DynamicResource DBG_RefreshTooltip}"/>
            </StackPanel>
        </Border>

        <ListView ItemsSource="{Binding Rows}"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  FontFamily="Cascadia Code, Consolas, Courier New"
                  FontSize="12"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{DynamicResource DBG_CopyAddress}"
                              Command="{Binding PlacementTarget.DataContext.CopyAddressCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,          RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{DynamicResource DBG_CopyHex}"
                              Command="{Binding PlacementTarget.DataContext.CopyHexCommand,     RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,          RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{DynamicResource DBG_CopyAscii}"
                              Command="{Binding PlacementTarget.DataContext.CopyAsciiCommand,   RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,          RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{DynamicResource DBG_CopyRow}" InputGestureText="Ctrl+C"
                              Command="{Binding PlacementTarget.DataContext.CopyRowCommand,     RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,          RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource DBG_Refresh}" InputGestureText="F5"
                              Command="{Binding PlacementTarget.DataContext.RefreshCommand,     RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Address" Width="110" DisplayMemberBinding="{Binding Address}"/>
                    <GridViewColumn Header="Hex"     Width="380" DisplayMemberBinding="{Binding Hex}"/>
                    <GridViewColumn Header="ASCII"   Width="130" DisplayMemberBinding="{Binding Ascii}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>

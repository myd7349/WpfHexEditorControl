<UserControl x:Class="WpfHexEditor.App.Debug.Panels.ModulesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dbgSvc="clr-namespace:WpfHexEditor.App.Debug.Services">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <dbgSvc:DebuggerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource DockBackgroundBrush}">

        <Border DockPanel.Dock="Top" Style="{DynamicResource PanelToolbarStyle}">
            <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                <TextBox Width="160"
                         Style="{DynamicResource PanelSearchBoxStyle}"
                         Tag="{DynamicResource DBG_MOD_SearchPlaceholder}"
                         ToolTip="{StaticResource DBG_MOD_SearchPlaceholder}"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
                <Rectangle Width="1" Height="16" Margin="6,0"
                           Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                <Button Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE72C;"
                        ToolTip="{StaticResource DBG_RefreshTooltip}"
                        Click="OnRefreshClick"/>
            </StackPanel>
        </Border>

        <ListView ItemsSource="{Binding Modules}"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{StaticResource DBG_ColName}"         Width="180" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="{StaticResource DBG_ColVersion}"       Width="80"  DisplayMemberBinding="{Binding Version}"/>
                    <GridViewColumn Header="{StaticResource DBG_ColSymbolStatus}"  Width="120" DisplayMemberBinding="{Binding SymbolStatus}"/>
                    <GridViewColumn Header="{StaticResource DBG_ColOptimized}"     Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsOptimized, Mode=OneWay}" IsEnabled="False"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="{StaticResource DBG_ColUserCode}"      Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsUserCode, Mode=OneWay}" IsEnabled="False"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="{StaticResource DBG_ColPath}"          Width="300" DisplayMemberBinding="{Binding Path}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>

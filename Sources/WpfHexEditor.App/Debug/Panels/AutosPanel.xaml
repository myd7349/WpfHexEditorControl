<UserControl x:Class="WpfHexEditor.App.Debug.Panels.AutosPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.App.Debug.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <TreeView x:Name="VarTree"
              ItemsSource="{Binding Variables}"
              Background="{DynamicResource PanelBackground}"
              Foreground="{DynamicResource PanelForeground}">
        <TreeView.ItemTemplate>
            <HierarchicalDataTemplate DataType="{x:Type vm:VariableNode}"
                                      ItemsSource="{Binding Children}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" />

                    <TextBlock Grid.Column="1" Text="{Binding Value}"
                               MouseLeftButtonDown="OnValueClick">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChanged}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource DB_LocalChangedBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Grid.Column="1"
                             KeyDown="OnEditKeyDown"
                             LostFocus="OnEditLostFocus"
                             IsVisibleChanged="OnEditVisibleChanged"
                             Background="{DynamicResource PanelBackground}"
                             Foreground="{DynamicResource PanelForeground}"
                             BorderThickness="0">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Text" Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=Explicit}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Grid.Column="2" Text="{Binding Type}"
                               Foreground="{DynamicResource PanelForeground}" Opacity="0.6" />
                </Grid>
            </HierarchicalDataTemplate>
        </TreeView.ItemTemplate>
    </TreeView>
</UserControl>

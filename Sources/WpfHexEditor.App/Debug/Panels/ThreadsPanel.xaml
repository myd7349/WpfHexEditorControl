<UserControl x:Class="WpfHexEditor.App.Debug.Panels.ThreadsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dbgSvc="clr-namespace:WpfHexEditor.App.Debug.Services">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <dbgSvc:DebuggerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource DockBackgroundBrush}">

        <Border DockPanel.Dock="Top" Style="{DynamicResource PanelToolbarStyle}">
            <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                <Button Command="{Binding RefreshCommand}"
                        ToolTip="{DynamicResource DBG_ThreadsRefreshTooltip}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE72C;"/>
                <Rectangle Width="1" Height="16" Margin="6,0"
                           Fill="{DynamicResource Panel_ToolbarBorderBrush}"/>
                <Button Command="{Binding FreezeCommand}"
                        CommandParameter="{Binding SelectedThread}"
                        ToolTip="{DynamicResource DBG_Freeze}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE769;"/>
                <Button Command="{Binding ThawCommand}"
                        CommandParameter="{Binding SelectedThread}"
                        ToolTip="{DynamicResource DBG_Thaw}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE768;"/>
            </StackPanel>
        </Border>

        <ListView ItemsSource="{Binding Threads}"
                  SelectedItem="{Binding SelectedThread, Mode=TwoWay}"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{DynamicResource DBG_SwitchToThread}"
                              Command="{Binding PlacementTarget.DataContext.SwitchToCommand,   RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource DBG_Freeze}"
                              Command="{Binding PlacementTarget.DataContext.FreezeCommand,     RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{DynamicResource DBG_Thaw}"
                              Command="{Binding PlacementTarget.DataContext.ThawCommand,       RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="{DynamicResource DBG_CopyThreadInfo}" InputGestureText="Ctrl+C"
                              Command="{Binding PlacementTarget.DataContext.CopyThreadCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem,         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="{DynamicResource DBG_Refresh}" InputGestureText="F5"
                              Command="{Binding PlacementTarget.DataContext.RefreshCommand,    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID"   Width="40"  DisplayMemberBinding="{Binding Id}" />
                    <GridViewColumn Header="&#x2744;" Width="24">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="&#x2744;" Visibility="{Binding IsFrozen, Converter={StaticResource BoolToVis}}"
                                           HorizontalAlignment="Center" Foreground="{DynamicResource DB_AsyncBoundaryBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="{DynamicResource DBG_ColName}" Width="280" DisplayMemberBinding="{Binding Name}" />
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFrozen}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource DB_AsyncBoundaryBrush}"/>
                            <Setter Property="FontStyle"  Value="Italic"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </DockPanel>
</UserControl>

<UserControl x:Class="WpfHexEditor.App.Debug.Panels.LocalsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.App.Debug.ViewModels"
             xmlns:dbgSvc="clr-namespace:WpfHexEditor.App.Debug.Services">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <dbgSvc:DebuggerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource DockBackgroundBrush}">

        <Border DockPanel.Dock="Top" Style="{DynamicResource PanelToolbarStyle}">
            <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                <TextBox x:Name="SearchBox" Width="180"
                         Style="{DynamicResource PanelSearchBoxStyle}"
                         Tag="{DynamicResource DBG_FilterPlaceholder}"
                         ToolTip="{StaticResource DBG_FilterTooltip}"
                         TextChanged="OnSearchTextChanged"/>
            </StackPanel>
        </Border>

        <TreeView x:Name="VarTree"
                  ItemsSource="{Binding Variables}"
                  Background="{DynamicResource DockBackgroundBrush}"
                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                  BorderThickness="0">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type vm:VariableNode}"
                                          ItemsSource="{Binding Children}">
                    <Grid Tag="{Binding Path=DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{StaticResource DBG_EditValue}" InputGestureText="F2"
                                          Command="{Binding PlacementTarget.Tag.EditValueCommand,      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding}"/>
                                <MenuItem Header="{StaticResource DBG_AddToWatch}"
                                          Command="{Binding PlacementTarget.Tag.AddToWatchCommand,     RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding}"/>
                                <Separator/>
                                <MenuItem Header="{StaticResource DBG_CopyValue}" InputGestureText="Ctrl+C"
                                          Command="{Binding PlacementTarget.Tag.CopyValueCommand,      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding}"/>
                                <MenuItem Header="{StaticResource DBG_CopyExpression}"
                                          Command="{Binding PlacementTarget.Tag.CopyExpressionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold"/>

                        <TextBlock Grid.Column="1" Text="{Binding Value}"
                                   MouseLeftButtonDown="OnValueClick">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChanged}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource DB_LocalChangedBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Grid.Column="1"
                                 x:Name="EditBox"
                                 Tag="{Binding}"
                                 KeyDown="OnEditKeyDown"
                                 LostFocus="OnEditLostFocus"
                                 IsVisibleChanged="OnEditVisibleChanged"
                                 Background="{DynamicResource DockBackgroundBrush}"
                                 Foreground="{DynamicResource DockMenuForegroundBrush}"
                                 BorderThickness="0">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Text" Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=Explicit}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Grid.Column="2" Text="{Binding Type}"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}" Opacity="0.6" />
                    </Grid>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </DockPanel>
</UserControl>

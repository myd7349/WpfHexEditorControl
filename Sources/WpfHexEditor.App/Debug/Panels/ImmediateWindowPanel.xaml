<UserControl x:Class="WpfHexEditor.App.Debug.Panels.ImmediateWindowPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dbgSvc="clr-namespace:WpfHexEditor.App.Debug.Services">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <dbgSvc:DebuggerLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource DockBackgroundBrush}">

        <Border DockPanel.Dock="Top" Style="{DynamicResource PanelToolbarStyle}">
            <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                <Button Command="{Binding ClearCommand}"
                        ToolTip="{StaticResource DBG_ClearTooltip}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        Content="&#xE74D;"/>
            </StackPanel>
        </Border>

        <Grid DockPanel.Dock="Bottom" Margin="4,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="InputBox"
                     Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="OnInputKeyDown"
                     FontFamily="Consolas" FontSize="12"
                     Background="{DynamicResource DockBackgroundBrush}"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     BorderBrush="{DynamicResource DockBorderBrush}"/>
            <Button Grid.Column="1" Margin="4,0,0,0" Padding="8,2"
                    Content="{StaticResource DBG_RunButton}"
                    Command="{Binding ExecuteCommand}"/>
        </Grid>

        <ListBox x:Name="TranscriptBox"
                 ItemsSource="{Binding Lines}"
                 Background="{DynamicResource DockBackgroundBrush}"
                 Foreground="{DynamicResource DockMenuForegroundBrush}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12"
                 BorderThickness="0"/>
    </DockPanel>
</UserControl>

<UserControl x:Class="WpfHexEditor.App.Debug.Panels.ImmediateWindowPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>
        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Background="{DynamicResource ToolbarBackground}">
            <Button Command="{Binding ClearCommand}"
                    ToolTip="Clear"
                    Style="{DynamicResource ToolbarButtonStyle}">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>
        </ToolBar>

        <!-- Input row -->
        <Grid DockPanel.Dock="Bottom" Margin="4,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="InputBox"
                     Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="OnInputKeyDown"
                     FontFamily="Consolas" FontSize="12"
                     Background="{DynamicResource PanelBackground}"
                     Foreground="{DynamicResource PanelForeground}"
                     BorderBrush="{DynamicResource PopupBorder}"/>
            <Button Grid.Column="1" Margin="4,0,0,0"
                    Padding="8,2"
                    Content="Run"
                    Command="{Binding ExecuteCommand}"/>
        </Grid>

        <!-- Output transcript -->
        <ListBox x:Name="TranscriptBox"
                 ItemsSource="{Binding Lines}"
                 Background="{DynamicResource PanelBackground}"
                 Foreground="{DynamicResource PanelForeground}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12"
                 BorderThickness="0"/>
    </DockPanel>
</UserControl>

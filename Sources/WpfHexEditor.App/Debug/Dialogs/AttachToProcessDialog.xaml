<Window x:Class="WpfHexEditor.App.Debug.Dialogs.AttachToProcessDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Attach to Process"
        Width="640" Height="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="Button" x:Key="DialogButton">
            <Setter Property="Padding"    Value="16,4"/>
            <Setter Property="MinWidth"   Value="80"/>
            <Setter Property="Margin"     Value="4,0"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="8">
        <!-- Filter bar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock VerticalAlignment="Center" Margin="0,0,4,0">Filter:</TextBlock>
            <TextBox x:Name="FilterBox" Text="" TextChanged="OnFilterChanged"/>
        </DockPanel>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Style="{StaticResource DialogButton}" Content="Refresh"
                    Click="OnRefresh"/>
            <Button Style="{StaticResource DialogButton}" Content="Attach"
                    IsDefault="True" Click="OnAttach"
                    x:Name="AttachButton" IsEnabled="False"/>
            <Button Style="{StaticResource DialogButton}" Content="Cancel"
                    IsCancel="True"/>
        </StackPanel>

        <!-- Process list -->
        <ListView x:Name="ProcessList"
                  SelectionChanged="OnSelectionChanged"
                  MouseDoubleClick="OnDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="PID"         Width="70"  DisplayMemberBinding="{Binding Pid}"/>
                    <GridViewColumn Header="Process"     Width="180" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Title"       Width="200" DisplayMemberBinding="{Binding Title}"/>
                    <GridViewColumn Header="Path"        Width="*"   DisplayMemberBinding="{Binding Path}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>

<!--
    Project: WpfHexEditor.App.Debug
    File: Dialogs/QuickTracepointDialog.xaml
    Description: Lightweight "Set Tracepoint" dialog — enter log message + pick macros.
-->
<ec:ThemedDialog x:Class="WpfHexEditor.App.Debug.Dialogs.QuickTracepointDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core.Views;assembly=WpfHexEditor.Editor.Core"
        Title="Set Tracepoint"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{DynamicResource DockBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Log message (use {expr} for values, $FUNCTION, $CALLER):"
                   FontSize="11" Margin="0,0,0,4"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>

        <TextBox Grid.Row="1" x:Name="MessageBox"
                 MinHeight="24" Padding="4"
                 FontSize="11"
                 Background="{DynamicResource DockMenuBackgroundBrush}"
                 Foreground="{DynamicResource DockMenuForegroundBrush}"
                 BorderBrush="{DynamicResource DockBorderBrush}"
                 KeyDown="OnKeyDown"/>

        <!-- Macro picker -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,8"
                    HorizontalAlignment="Left">
            <TextBlock Text="Insert macro:" FontSize="11" VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"/>
            <Button Content="$FUNCTION" FontSize="10" Padding="4,2" Margin="0,0,4,0"
                    Background="{DynamicResource DockMenuBackgroundBrush}"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    Click="OnMacroClicked" Tag="$FUNCTION"/>
            <Button Content="$CALLER"   FontSize="10" Padding="4,2" Margin="0,0,4,0"
                    Background="{DynamicResource DockMenuBackgroundBrush}"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    Click="OnMacroClicked" Tag="$CALLER"/>
            <Button Content="$ADDRESS"  FontSize="10" Padding="4,2" Margin="0,0,4,0"
                    Background="{DynamicResource DockMenuBackgroundBrush}"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    Click="OnMacroClicked" Tag="$ADDRESS"/>
            <Button Content="{}{expr}"  FontSize="10" Padding="4,2"
                    Background="{DynamicResource DockMenuBackgroundBrush}"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    Click="OnMacroClicked" Tag=""
                    ToolTip="Inserts {expression} placeholder"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="72" Height="26" Margin="0,0,8,0" IsDefault="True"
                    FontSize="11"
                    Background="{DynamicResource DockMenuBackgroundBrush}"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    Click="OnOkClicked"/>
            <Button Content="Cancel" Width="72" Height="26" IsCancel="True"
                    FontSize="11"
                    Background="{DynamicResource DockMenuBackgroundBrush}"
                    Foreground="{DynamicResource DockMenuForegroundBrush}"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    Click="OnCancelClicked"/>
        </StackPanel>
    </Grid>
</ec:ThemedDialog>

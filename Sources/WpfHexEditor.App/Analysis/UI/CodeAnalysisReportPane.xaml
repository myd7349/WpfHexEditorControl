<UserControl x:Class="WpfHexEditor.App.Analysis.UI.CodeAnalysisReportPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.App.Analysis.UI.ViewModels"
             xmlns:p="clr-namespace:WpfHexEditor.App.Properties"
             xmlns:conv="clr-namespace:WpfHexEditor.App.Analysis.UI.Converters"
             xmlns:controls="clr-namespace:WpfHexEditor.App.Analysis.UI.Controls"
             Background="{DynamicResource DockWindowBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:GradeToColorConverter   x:Key="GradeToColor"/>
            <conv:SeverityToIconConverter x:Key="SevToIcon"/>
            <conv:ScoreToProgressConverter x:Key="ScoreToProgress"/>
            <BooleanToVisibilityConverter  x:Key="BoolToVis"/>

            <Style TargetType="TabItem">
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="Padding"     Value="10,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="0"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="0,0,2,0">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="Background"
                                            Value="{DynamicResource DockWindowBackgroundBrush}"/>
                                    <Setter TargetName="Border" Property="BorderThickness"
                                            Value="0,0,0,2"/>
                                    <Setter TargetName="Border" Property="BorderBrush"
                                            Value="{DynamicResource DockAccentBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource DockMenuForegroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background"
                                            Value="{DynamicResource DockBorderBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TabLabelStyle" TargetType="TextBlock">
                <Setter Property="Margin"     Value="6,0"/>
                <Setter Property="FontSize"   Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="MetricLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}"/>
                <Setter Property="FontSize"   Value="11"/>
                <Setter Property="Margin"     Value="0,1"/>
            </Style>

            <Style x:Key="ScoreBig" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="48"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

            <Style x:Key="GradeBig" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="24"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="0,4,0,0"/>
            </Style>

            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}"/>
                <Setter Property="Margin"     Value="0,12,0,4"/>
            </Style>

            <Style TargetType="DataGrid">
                <EventSetter Event="ContextMenuOpening" Handler="OnGridContextMenuOpening"/>
                <Setter Property="CanUserSortColumns"    Value="True"/>
                <Setter Property="Background"            Value="{DynamicResource DockWindowBackgroundBrush}"/>
                <Setter Property="Foreground"            Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Setter Property="BorderBrush"           Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="BorderThickness"       Value="1"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
                <Setter Property="RowBackground"         Value="Transparent"/>
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource DockWindowBackgroundBrush}"/>
                <Setter Property="SelectionMode"         Value="Single"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background"  Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="Padding"     Value="6,4"/>
                <Setter Property="FontSize"    Value="11"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource DockAccentBrush}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource DockBorderBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="6,3"/>
                <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DockBorderBrush}"
                Padding="12,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="ReRunButton" Content="{x:Static p:AppResources.CodeAnalysis_Rerun}"
                            Padding="10,4" Margin="4,0"
                            Click="OnReRunClicked"
                            ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Rerun}"/>
                    <ComboBox x:Name="ExportCombo" Width="90" Margin="4,0"
                              SelectedIndex="0"
                              ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Export}"
                              SelectionChanged="OnExportSelectionChanged">
                        <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Export}"/>
                        <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Export_Markdown}"/>
                        <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Export_CSV}"/>
                        <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Combo_SARIF}"/>
                        <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Combo_PRChecklist}"/>
                    </ComboBox>
                    <!-- Phase 7 — Project filter -->
                    <TextBlock Text="{x:Static p:AppResources.CodeAnalysis_Header_Project}" VerticalAlignment="Center" Margin="8,0,4,0"
                               Foreground="{DynamicResource DockForegroundBrush}" FontSize="11"/>
                    <ComboBox x:Name="ProjectFilterCombo" Width="160" Margin="0,0,4,0"
                              ItemsSource="{Binding AvailableProjects, Mode=OneWay}"
                              SelectionChanged="OnProjectFilterChanged"
                              ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_ProjectFilter}"/>
                    <!-- Phase 7 — Global search (Ctrl+F) -->
                    <TextBlock Text="{x:Static p:AppResources.CodeAnalysis_Header_Search}" VerticalAlignment="Center" Margin="4,0"
                               Foreground="{DynamicResource DockForegroundBrush}" FontSize="11"/>
                    <TextBox x:Name="GlobalSearchBox" Width="180" Margin="0,0,4,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding GlobalSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_GlobalSearch}"/>
                </StackPanel>

                <!-- Progress bar (indeterminate while running) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0"
                            Visibility="{Binding IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                 Foreground="{DynamicResource DockAccentBrush}"
                                 Background="{DynamicResource DockBorderBrush}"
                                 BorderThickness="0" Margin="0,0,8,0"/>
                    <TextBlock Text="{x:Static p:AppResources.CodeAnalysis_StatusBar_Running}" VerticalAlignment="Center"
                               Foreground="{DynamicResource DockForegroundBrush}"
                               FontSize="11"/>
                </StackPanel>

                <!-- Summary line when done -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding HasReport, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource TabLabelStyle}">
                        <Run Text="{Binding TotalFiles,    Mode=OneWay, StringFormat={}{0} files}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding TotalLines,    Mode=OneWay, StringFormat={}{0:N0} LOC}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding ProjectCount,  Mode=OneWay, StringFormat={}{0} projects}"/>
                    </TextBlock>
                    <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                               Text="{Binding TrendingText, Mode=OneWay}"
                               Foreground="{DynamicResource DockAccentBrush}"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusText, Mode=OneWay}" VerticalAlignment="Center"
                           Visibility="{Binding HasReport, Mode=OneWay, Converter={StaticResource BoolToVis},
                                        ConverterParameter=Inverse}"
                           Style="{StaticResource MetricLabel}"/>
            </DockPanel>
        </Border>

        <!-- ── Body ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Score sidebar -->
            <Border Grid.Column="0" BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    Padding="16,16,12,16">
                <StackPanel>
                    <StackPanel.ToolTip>
                        <ToolTip>
                            <StackPanel MaxWidth="360">
                                <TextBlock FontWeight="SemiBold" Text="{x:Static p:AppResources.CodeAnalysis_Tooltip_QualityScore_Title}"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="{x:Static p:AppResources.CodeAnalysis_Tooltip_QualityScore_Body}"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0"
                                           Text="{x:Static p:AppResources.CodeAnalysis_Tooltip_QualityScore_Grades}"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" FontStyle="Italic"
                                           Text="{x:Static p:AppResources.CodeAnalysis_Tooltip_QualityScore_Trending}"/>
                            </StackPanel>
                        </ToolTip>
                    </StackPanel.ToolTip>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static p:AppResources.CodeAnalysis_Header_Score}"/>
                    <TextBlock Style="{StaticResource ScoreBig}"
                               Text="{Binding Score, Mode=OneWay}"
                               Foreground="{Binding Grade, Mode=OneWay, Converter={StaticResource GradeToColor}}"
                               ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Score}"/>
                    <TextBlock Style="{StaticResource GradeBig}"
                               Text="{Binding Grade, Mode=OneWay}"
                               Foreground="{Binding Grade, Mode=OneWay, Converter={StaticResource GradeToColor}}"
                               ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Grade}"/>
                    <TextBlock Text="{Binding TrendingText, Mode=OneWay}" Margin="0,6,0,0"
                               Foreground="{DynamicResource DockAccentBrush}"
                               ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Trending}"/>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static p:AppResources.CodeAnalysis_Header_SubScores}" Margin="0,24,0,4"/>

                    <!-- Phase 3 — Radar visualization -->
                    <controls:ScoreRadarChart
                        Width="180" Height="180"
                        Foreground="{DynamicResource DockForegroundBrush}"
                        ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Radar}"
                        Volume="{Binding VolumeScore,        Mode=OneWay}"
                        Complexity="{Binding ComplexityScore, Mode=OneWay}"
                        Coupling="{Binding CouplingScore,    Mode=OneWay}"
                        Duplication="{Binding DuplicationScore, Mode=OneWay}"
                        DeadCode="{Binding DeadCodeScore,    Mode=OneWay}"
                        Conventions="{Binding ConventionScore, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,8"/>
                </StackPanel>
            </Border>

            <!-- Tabs -->
            <TabControl Grid.Column="1" x:Name="MainTabs"
                        Background="{DynamicResource DockWindowBackgroundBrush}"
                        BorderThickness="0"
                        BorderBrush="{DynamicResource DockBorderBrush}">

                <!-- ── Overview ──────────────────────────────────────────── -->
                <TabItem Header="{x:Static p:AppResources.CodeAnalysis_Tab_Overview}" ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Tab_Overview}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static p:AppResources.CodeAnalysis_Overview_ByProject}"/>
                            <DataGrid x:Name="ProjectsGrid"
                                      ItemsSource="{Binding Projects, Mode=OneWay}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      Margin="0,0,0,16">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Project}" Binding="{Binding ProjectName,              Mode=OneWay}" Width="*"/>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Files}"   Binding="{Binding TotalFiles,               Mode=OneWay}" Width="60"/>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_LOC}"     Binding="{Binding TotalLines,               Mode=OneWay, StringFormat={}{0:N0}}" Width="80"/>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Types}"   Binding="{Binding TypeCount,                Mode=OneWay}" Width="60"/>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_AvgCC}"   Binding="{Binding AvgCyclomaticComplexity, Mode=OneWay, StringFormat={}{0:F1}}" Width="70"/>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Score}"   Binding="{Binding Score,                   Mode=OneWay}" Width="60"/>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Grade}"   Binding="{Binding Grade,                   Mode=OneWay}" Width="55"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static p:AppResources.CodeAnalysis_Overview_WorstFiles}"/>
                            <DataGrid x:Name="WorstFilesGrid"
                                      ItemsSource="{Binding WorstFiles, Mode=OneWay}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      MouseDoubleClick="OnGridDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_File}"    Binding="{Binding FileName,    Mode=OneWay}" Width="*"/>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Project}" Binding="{Binding ProjectName, Mode=OneWay}" Width="140"/>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_LOC}"     Binding="{Binding TotalLines,  Mode=OneWay}" Width="60"/>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_MaxCC}"   Binding="{Binding MaxCC,       Mode=OneWay}" Width="70"/>
                                    <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Score}"   Binding="{Binding Score,       Mode=OneWay}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ── Issues ────────────────────────────────────────────── -->
                <TabItem x:Name="IssuesTab"
                         ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Tab_Issues}">
                    <TabItem.Header>
                        <TextBlock>
                            <Run Text="{x:Static p:AppResources.CodeAnalysis_Tab_Issues}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding Issues.Count, Mode=OneWay}"/>
                        </TextBlock>
                    </TabItem.Header>
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <ComboBox x:Name="SeverityFilter" Width="100" Margin="0,0,8,0"
                                      SelectedIndex="0"
                                      SelectionChanged="OnSeverityFilterChanged">
                                <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Issues_Filter_All}"/>
                                <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Combo_Severity_Error}"/>
                                <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Combo_Severity_Warning}"/>
                                <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Combo_Severity_Info}"/>
                            </ComboBox>
                            <TextBox x:Name="IssueSearchBox" Width="200"
                                     Text="{Binding IssueFilter, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{x:Static p:AppResources.CodeAnalysis_Issues_Search}"/>
                            <ComboBox x:Name="GroupByCombo" Width="120" Margin="8,0,0,0"
                                      SelectedIndex="0" ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_GroupBy}"
                                      SelectionChanged="OnGroupByChanged">
                                <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Combo_GroupBy_None}"/>
                                <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Combo_GroupBy_Severity}"/>
                                <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Combo_GroupBy_Rule}"/>
                                <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Combo_GroupBy_Project}"/>
                                <ComboBoxItem Content="{x:Static p:AppResources.CodeAnalysis_Combo_GroupBy_File}"/>
                            </ComboBox>
                        </StackPanel>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Issues, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header=""        Binding="{Binding SeverityIcon, Mode=OneWay}" Width="24"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_ID}"      Binding="{Binding Id,           Mode=OneWay}" Width="80"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Message}" Binding="{Binding Message,      Mode=OneWay}" Width="*"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_File}"    Binding="{Binding FileName,     Mode=OneWay}" Width="160"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Line}"    Binding="{Binding Line,         Mode=OneWay}" Width="55"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Project}" Binding="{Binding ProjectName,  Mode=OneWay}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ── Complexity ────────────────────────────────────────── -->
                <TabItem Header="{x:Static p:AppResources.CodeAnalysis_Tab_Complexity}" ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Tab_Complexity}">
                    <Grid Margin="8">
                        <DataGrid ItemsSource="{Binding TopMethods, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Method}"    Binding="{Binding FullyQualifiedName,     Mode=OneWay}" Width="*"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_CC}"        Binding="{Binding CyclomaticComplexity,   Mode=OneWay}" Width="60"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Cognitive}" Binding="{Binding CognitiveComplexity,    Mode=OneWay}" Width="80"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_LOC}"       Binding="{Binding Loc,                    Mode=OneWay}" Width="60"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Params}"    Binding="{Binding ParameterCount,         Mode=OneWay}" Width="60"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Line}"      Binding="{Binding Line,                   Mode=OneWay}" Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ── Coupling ──────────────────────────────────────────── -->
                <TabItem Header="{x:Static p:AppResources.CodeAnalysis_Tab_Coupling}" ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Tab_Coupling}">
                    <Grid Margin="8">
                        <DataGrid ItemsSource="{Binding TopCouplings, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Type}"        Binding="{Binding TypeName,    Mode=OneWay}" Width="*"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Ca}"          Binding="{Binding Ca,          Mode=OneWay}" Width="50"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Ce}"          Binding="{Binding Ce,          Mode=OneWay}" Width="50"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Instability}" Binding="{Binding Instability, Mode=OneWay, StringFormat={}{0:F2}}" Width="85"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_LCOM}"        Binding="{Binding Lcom,        Mode=OneWay}" Width="70"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Line}"        Binding="{Binding Line,        Mode=OneWay}" Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ── Duplication ───────────────────────────────────────── -->
                <TabItem Header="{x:Static p:AppResources.CodeAnalysis_Tab_Duplication}" ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Tab_Duplication}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl ItemsSource="{Binding Duplications, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="8"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource DockBorderBrush}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold">
                                                <Run Text="{x:Static p:AppResources.CodeAnalysis_Duplication_CloneGroup}"/>
                                                <Run Text="{Binding LineCount,          Mode=OneWay}"/>
                                                <Run Text="{x:Static p:AppResources.CodeAnalysis_Duplication_Lines}"/>
                                                <Run Text="{Binding Occurrences.Count,  Mode=OneWay}"/>
                                                <Run Text="{x:Static p:AppResources.CodeAnalysis_Duplication_Occurrences}"/>
                                                <Run Text="{Binding TokenCount,         Mode=OneWay}"/>
                                                <Run Text="{x:Static p:AppResources.CodeAnalysis_Duplication_Tokens}"/>
                                            </TextBlock>
                                            <ItemsControl ItemsSource="{Binding Occurrences, Mode=OneWay}"
                                                          Margin="12,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontFamily="Consolas" FontSize="11">
                                                            <Run Text="{Binding FilePath,  Mode=OneWay}"/>
                                                            <Run Text=" : "/>
                                                            <Run Text="{Binding StartLine, Mode=OneWay}"/>
                                                            <Run Text="–"/>
                                                            <Run Text="{Binding EndLine,   Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <!-- ── Treemap (Phase 3) ─────────────────────────────────── -->
                <TabItem Header="{x:Static p:AppResources.CodeAnalysis_Tab_Treemap}">
                    <TabItem.ToolTip>
                        <ToolTip>
                            <StackPanel MaxWidth="380">
                                <TextBlock FontWeight="SemiBold" Text="{x:Static p:AppResources.CodeAnalysis_Tooltip_Tab_Treemap_Title}"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="{x:Static p:AppResources.CodeAnalysis_Tooltip_Tab_Treemap_Body}"/>
                            </StackPanel>
                        </ToolTip>
                    </TabItem.ToolTip>
                    <DockPanel Margin="8">
                        <!-- Help banner + colour legend -->
                        <Border DockPanel.Dock="Top" Padding="8" Margin="0,0,0,8"
                                Background="{DynamicResource DockBorderBrush}"
                                CornerRadius="3">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static p:AppResources.CodeAnalysis_Treemap_Score}" Margin="0,0,8,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#43A047" Width="14" Height="14"/>
                                    <TextBlock Text="≥85" Margin="3,0,8,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#9E9D24" Width="14" Height="14"/>
                                    <TextBlock Text="70-84" Margin="3,0,8,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#F57C00" Width="14" Height="14"/>
                                    <TextBlock Text="55-69" Margin="3,0,8,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#E53935" Width="14" Height="14"/>
                                    <TextBlock Text="40-54" Margin="3,0,8,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#B0231E" Width="14" Height="14"/>
                                    <TextBlock Text="&lt;40" Margin="3,0,0,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" VerticalAlignment="Center"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           FontSize="11">
                                    <Run FontWeight="SemiBold" Text="{x:Static p:AppResources.CodeAnalysis_Treemap_Banner_Title}"/>
                                    <Run Text="{x:Static p:AppResources.CodeAnalysis_Treemap_Banner_Body}"/>
                                </TextBlock>
                            </DockPanel>
                        </Border>
                        <controls:Treemap x:Name="FileTreemap"
                                          Items="{Binding AllFiles, Mode=OneWay}"
                                          Foreground="White"
                                          ItemActivated="OnTreemapItemActivated"/>
                    </DockPanel>
                </TabItem>

                <!-- ── Dead Code ─────────────────────────────────────────── -->
                <TabItem Header="{x:Static p:AppResources.CodeAnalysis_Tab_DeadCode}" ToolTip="{x:Static p:AppResources.CodeAnalysis_Tooltip_Tab_DeadCode}">
                    <Grid Margin="8">
                        <DataGrid ItemsSource="{Binding DeadSymbols, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Symbol}"  Binding="{Binding Name,        Mode=OneWay}" Width="*"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Kind}"    Binding="{Binding Kind,         Mode=OneWay}" Width="90"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_File}"    Binding="{Binding FilePath,     Mode=OneWay, Converter={x:Static conv:FileNameConverter.Instance}}" Width="160"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Line}"    Binding="{Binding Line,         Mode=OneWay}" Width="55"/>
                                <DataGridTextColumn Header="{x:Static p:AppResources.CodeAnalysis_Col_Project}" Binding="{Binding ProjectName,  Mode=OneWay}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>

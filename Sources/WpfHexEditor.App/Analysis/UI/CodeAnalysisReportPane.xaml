<UserControl x:Class="WpfHexEditor.App.Analysis.UI.CodeAnalysisReportPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.App.Analysis.UI.ViewModels"
             xmlns:appSvc="clr-namespace:WpfHexEditor.App.Services"
             xmlns:conv="clr-namespace:WpfHexEditor.App.Analysis.UI.Converters"
             xmlns:controls="clr-namespace:WpfHexEditor.App.Analysis.UI.Controls"
             Background="{DynamicResource DockWindowBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml"/>
                <appSvc:AppLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>

            <conv:GradeToColorConverter      x:Key="GradeToColor"/>
            <conv:SeverityToIconConverter    x:Key="SevToIcon"/>
            <conv:ScoreToProgressConverter   x:Key="ScoreToProgress"/>
            <conv:ThresholdToBrushConverter  x:Key="ThresholdToBrush"/>
            <conv:RiskLevelToBrushConverter  x:Key="RiskToBrush"/>
            <conv:DuplicationSeverityToBrushConverter x:Key="DupSevToBrush"/>
            <conv:NullToVisibilityConverter  x:Key="NullToVis"/>
            <conv:NullToVisibilityConverter  x:Key="NullToVisInverse" Invert="True"/>
            <BooleanToVisibilityConverter    x:Key="BoolToVis"/>

            <Style TargetType="TabItem">
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="Padding"     Value="10,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="0"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="0,0,2,0">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="Background"
                                            Value="{DynamicResource DockWindowBackgroundBrush}"/>
                                    <Setter TargetName="Border" Property="BorderThickness"
                                            Value="0,0,0,2"/>
                                    <Setter TargetName="Border" Property="BorderBrush"
                                            Value="{DynamicResource DockAccentBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource DockMenuForegroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background"
                                            Value="{DynamicResource DockBorderBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TabLabelStyle" TargetType="TextBlock">
                <Setter Property="Margin"     Value="6,0"/>
                <Setter Property="FontSize"   Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="MetricLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}"/>
                <Setter Property="FontSize"   Value="11"/>
                <Setter Property="Margin"     Value="0,1"/>
            </Style>

            <Style x:Key="ScoreBig" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="48"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

            <Style x:Key="GradeBig" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="24"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="0,4,0,0"/>
            </Style>

            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}"/>
                <Setter Property="Margin"     Value="0,12,0,4"/>
            </Style>

            <Style TargetType="DataGrid">
                <EventSetter Event="ContextMenuOpening" Handler="OnGridContextMenuOpening"/>
                <Setter Property="CanUserSortColumns"    Value="True"/>
                <Setter Property="Background"            Value="{DynamicResource DockWindowBackgroundBrush}"/>
                <Setter Property="Foreground"            Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Setter Property="BorderBrush"           Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="BorderThickness"       Value="1"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
                <Setter Property="RowBackground"         Value="Transparent"/>
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource DockWindowBackgroundBrush}"/>
                <Setter Property="SelectionMode"         Value="Single"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background"  Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="Padding"     Value="6,4"/>
                <Setter Property="FontSize"    Value="11"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground"  Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource DockAccentBrush}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource DockBorderBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="6,3"/>
                <Setter Property="Foreground"      Value="{DynamicResource DockMenuForegroundBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DockBorderBrush}"
                Padding="12,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <!-- SplitButton: Re-run (left) + dropdown (right) -->
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <Button x:Name="ReRunButton"
                                Content="{DynamicResource CodeAnalysis_Rerun_SameScope}"
                                Padding="10,4" BorderThickness="1,1,0,1"
                                Click="OnReRunClicked"
                                ToolTip="{DynamicResource CodeAnalysis_Tooltip_Rerun_SameScope}"/>
                        <Button x:Name="ReRunDropdown" Content="▾"
                                Padding="4,4" BorderThickness="0,1,1,1"
                                ToolTip="{DynamicResource CodeAnalysis_Tooltip_Rerun}"
                                Click="OnReRunDropdownClicked">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource CodeAnalysis_Rerun_SameScope}"
                                              Click="OnReRunClicked"/>
                                    <MenuItem Header="{DynamicResource CodeAnalysis_Rerun_RunSolution}"
                                              Click="OnRunSolutionClicked"
                                              ToolTip="{DynamicResource CodeAnalysis_Tooltip_Rerun_RunSolution}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource CodeAnalysis_Rerun_RunProject}"
                                              IsEnabled="False"/>
                                    <MenuItem Header="{DynamicResource CodeAnalysis_Rerun_RunFile}"
                                              IsEnabled="False"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                    <ComboBox x:Name="ExportCombo" Width="90" Margin="4,0"
                              SelectedIndex="0"
                              ToolTip="{DynamicResource CodeAnalysis_Tooltip_Export}"
                              SelectionChanged="OnExportSelectionChanged">
                        <ComboBoxItem Content="{DynamicResource CodeAnalysis_Export}"/>
                        <ComboBoxItem Content="{DynamicResource CodeAnalysis_Export_Markdown}"/>
                        <ComboBoxItem Content="{DynamicResource CodeAnalysis_Export_CSV}"/>
                        <ComboBoxItem Content="{DynamicResource CodeAnalysis_Combo_SARIF}"/>
                        <ComboBoxItem Content="{DynamicResource CodeAnalysis_Combo_PRChecklist}"/>
                    </ComboBox>
                    <!-- Phase 7 — Project filter -->
                    <TextBlock Text="{DynamicResource CodeAnalysis_Header_Project}" VerticalAlignment="Center" Margin="8,0,4,0"
                               Foreground="{DynamicResource DockForegroundBrush}" FontSize="11"/>
                    <ComboBox x:Name="ProjectFilterCombo" Width="160" Margin="0,0,4,0"
                              ItemsSource="{Binding AvailableProjects, Mode=OneWay}"
                              SelectionChanged="OnProjectFilterChanged"
                              ToolTip="{DynamicResource CodeAnalysis_Tooltip_ProjectFilter}"/>
                    <!-- Phase 7 — Global search (Ctrl+F) -->
                    <TextBlock Text="{DynamicResource CodeAnalysis_Header_Search}" VerticalAlignment="Center" Margin="4,0"
                               Foreground="{DynamicResource DockForegroundBrush}" FontSize="11"/>
                    <TextBox x:Name="GlobalSearchBox" Width="180" Margin="0,0,4,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding GlobalSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{DynamicResource CodeAnalysis_Tooltip_GlobalSearch}"/>
                </StackPanel>

                <!-- Progress bar (indeterminate while running) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0"
                            Visibility="{Binding IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                 Foreground="{DynamicResource DockAccentBrush}"
                                 Background="{DynamicResource DockBorderBrush}"
                                 BorderThickness="0" Margin="0,0,8,0"/>
                    <TextBlock Text="{DynamicResource CodeAnalysis_StatusBar_Running}" VerticalAlignment="Center"
                               Foreground="{DynamicResource DockForegroundBrush}"
                               FontSize="11"/>
                </StackPanel>

                <!-- Summary line when done -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding HasReport, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <!-- Scope label (Solution / Project / File) -->
                    <TextBlock Text="{Binding ScopeLabel, Mode=OneWay}"
                               VerticalAlignment="Center" FontSize="11" FontStyle="Italic"
                               Foreground="{DynamicResource DockForegroundBrush}"
                               Margin="0,0,12,0" MaxWidth="240"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Style="{StaticResource TabLabelStyle}">
                        <Run Text="{Binding TotalFiles,    Mode=OneWay, StringFormat={}{0} files}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding TotalLines,    Mode=OneWay, StringFormat={}{0:N0} LOC}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding ProjectCount,  Mode=OneWay, StringFormat={}{0} projects}"/>
                    </TextBlock>
                    <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                               Text="{Binding TrendingText, Mode=OneWay}"
                               Foreground="{DynamicResource DockAccentBrush}"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusText, Mode=OneWay}" VerticalAlignment="Center"
                           Visibility="{Binding HasReport, Mode=OneWay, Converter={StaticResource BoolToVis},
                                        ConverterParameter=Inverse}"
                           Style="{StaticResource MetricLabel}"/>
            </DockPanel>
        </Border>

        <!-- ── Body ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Score sidebar -->
            <Border Grid.Column="0" BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    Padding="16,16,12,16">
                <StackPanel>
                    <StackPanel.ToolTip>
                        <ToolTip>
                            <StackPanel MaxWidth="360">
                                <TextBlock FontWeight="SemiBold" Text="{DynamicResource CodeAnalysis_Tooltip_QualityScore_Title}"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="{DynamicResource CodeAnalysis_Tooltip_QualityScore_Body}"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0"
                                           Text="{DynamicResource CodeAnalysis_Tooltip_QualityScore_Grades}"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" FontStyle="Italic"
                                           Text="{DynamicResource CodeAnalysis_Tooltip_QualityScore_Trending}"/>
                            </StackPanel>
                        </ToolTip>
                    </StackPanel.ToolTip>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource CodeAnalysis_Header_Score}"/>
                    <TextBlock Style="{StaticResource ScoreBig}"
                               Text="{Binding Score, Mode=OneWay}"
                               Foreground="{Binding Grade, Mode=OneWay, Converter={StaticResource GradeToColor}}"
                               ToolTip="{DynamicResource CodeAnalysis_Tooltip_Score}"/>
                    <TextBlock Style="{StaticResource GradeBig}"
                               Text="{Binding Grade, Mode=OneWay}"
                               Foreground="{Binding Grade, Mode=OneWay, Converter={StaticResource GradeToColor}}"
                               ToolTip="{DynamicResource CodeAnalysis_Tooltip_Grade}"/>
                    <TextBlock Text="{Binding TrendingText, Mode=OneWay}" Margin="0,6,0,0"
                               Foreground="{DynamicResource DockAccentBrush}"
                               ToolTip="{DynamicResource CodeAnalysis_Tooltip_Trending}"/>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource CodeAnalysis_Header_SubScores}" Margin="0,24,0,4"/>

                    <!-- Phase 3 — Radar visualization -->
                    <controls:ScoreRadarChart
                        Width="180" Height="180"
                        Foreground="{DynamicResource DockMenuForegroundBrush}"
                        ToolTip="{DynamicResource CodeAnalysis_Tooltip_Radar}"
                        Volume="{Binding VolumeScore,        Mode=OneWay}"
                        Complexity="{Binding ComplexityScore, Mode=OneWay}"
                        Coupling="{Binding CouplingScore,    Mode=OneWay}"
                        Duplication="{Binding DuplicationScore, Mode=OneWay}"
                        DeadCode="{Binding DeadCodeScore,    Mode=OneWay}"
                        Conventions="{Binding ConventionScore, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,8"/>
                </StackPanel>
            </Border>

            <!-- Tabs -->
            <TabControl Grid.Column="1" x:Name="MainTabs"
                        Background="{DynamicResource DockWindowBackgroundBrush}"
                        BorderThickness="0"
                        BorderBrush="{DynamicResource DockBorderBrush}">

                <!-- ── Overview ──────────────────────────────────────────── -->
                <TabItem Header="{DynamicResource CodeAnalysis_Tab_Overview}" ToolTip="{DynamicResource CodeAnalysis_Tooltip_Tab_Overview}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                        <StackPanel>
                            <!-- ── Phase 10 — score trending sparkline ─────────────── -->
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource CodeAnalysis_History_Title}"/>
                            <Border Background="{DynamicResource DockWindowBackgroundBrush}"
                                    BorderBrush="{DynamicResource DockBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="10,8"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <controls:Sparkline ItemsSource="{Binding HistoryScores, Mode=OneWay}"
                                                        Stroke="{DynamicResource AccentBrush}"
                                                        Fill="{DynamicResource DockBorderBrush}"
                                                        MinY="0"
                                                        MaxY="100"
                                                        Height="48"
                                                        Margin="0,0,0,6"
                                                        Visibility="{Binding HasHistory, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="{Binding HistorySummaryText, Mode=OneWay}"
                                               FontStyle="Italic"
                                               Opacity="0.7"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource CodeAnalysis_Overview_ByProject}"/>
                            <DataGrid x:Name="ProjectsGrid"
                                      ItemsSource="{Binding Projects, Mode=OneWay}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      Margin="0,0,0,16">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Project}" Binding="{Binding ProjectName,              Mode=OneWay}" Width="*"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Files}"   Binding="{Binding TotalFiles,               Mode=OneWay}" Width="60"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_LOC}"     Binding="{Binding TotalLines,               Mode=OneWay, StringFormat={}{0:N0}}" Width="80"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Types}"   Binding="{Binding TypeCount,                Mode=OneWay}" Width="60"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_AvgCC}"   Binding="{Binding AvgCyclomaticComplexity, Mode=OneWay, StringFormat={}{0:F1}}" Width="70"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Score}"   Binding="{Binding Score,                   Mode=OneWay}" Width="60"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Grade}"   Binding="{Binding Grade,                   Mode=OneWay}" Width="55"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource CodeAnalysis_Overview_WorstFiles}"/>
                            <DataGrid x:Name="WorstFilesGrid"
                                      ItemsSource="{Binding WorstFiles, Mode=OneWay}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      MouseDoubleClick="OnGridDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_File}"    Binding="{Binding FileName,    Mode=OneWay}" Width="*"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Project}" Binding="{Binding ProjectName, Mode=OneWay}" Width="140"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_LOC}"     Binding="{Binding TotalLines,  Mode=OneWay}" Width="60"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_MaxCC}"   Binding="{Binding MaxCC,       Mode=OneWay}" Width="70"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Score}"   Binding="{Binding Score,       Mode=OneWay}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ── Issues ────────────────────────────────────────────── -->
                <TabItem x:Name="IssuesTab"
                         ToolTip="{DynamicResource CodeAnalysis_Tooltip_Tab_Issues}">
                    <TabItem.Header>
                        <TextBlock>
                            <Run Text="{DynamicResource CodeAnalysis_Tab_Issues}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding Issues.Count, Mode=OneWay}"/>
                        </TextBlock>
                    </TabItem.Header>
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <ComboBox x:Name="SeverityFilter" Width="100" Margin="0,0,8,0"
                                      SelectedIndex="0"
                                      SelectionChanged="OnSeverityFilterChanged">
                                <ComboBoxItem Content="{DynamicResource CodeAnalysis_Issues_Filter_All}"/>
                                <ComboBoxItem Content="{DynamicResource CodeAnalysis_Combo_Severity_Error}"/>
                                <ComboBoxItem Content="{DynamicResource CodeAnalysis_Combo_Severity_Warning}"/>
                                <ComboBoxItem Content="{DynamicResource CodeAnalysis_Combo_Severity_Info}"/>
                            </ComboBox>
                            <TextBox x:Name="IssueSearchBox" Width="200"
                                     Text="{Binding IssueFilter, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{DynamicResource CodeAnalysis_Issues_Search}"/>
                            <ComboBox x:Name="GroupByCombo" Width="120" Margin="8,0,0,0"
                                      SelectedIndex="0" ToolTip="{DynamicResource CodeAnalysis_Tooltip_GroupBy}"
                                      SelectionChanged="OnGroupByChanged">
                                <ComboBoxItem Content="{DynamicResource CodeAnalysis_Combo_GroupBy_None}"/>
                                <ComboBoxItem Content="{DynamicResource CodeAnalysis_Combo_GroupBy_Severity}"/>
                                <ComboBoxItem Content="{DynamicResource CodeAnalysis_Combo_GroupBy_Rule}"/>
                                <ComboBoxItem Content="{DynamicResource CodeAnalysis_Combo_GroupBy_Project}"/>
                                <ComboBoxItem Content="{DynamicResource CodeAnalysis_Combo_GroupBy_File}"/>
                            </ComboBox>
                        </StackPanel>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Issues, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header=""        Binding="{Binding SeverityIcon, Mode=OneWay}" Width="24"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_ID}"      Binding="{Binding Id,           Mode=OneWay}" Width="80"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Message}" Binding="{Binding Message,      Mode=OneWay}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_File}"    Binding="{Binding FileName,     Mode=OneWay}" Width="160"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Line}"    Binding="{Binding Line,         Mode=OneWay}" Width="55"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Project}" Binding="{Binding ProjectName,  Mode=OneWay}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ── Complexity ────────────────────────────────────────── -->
                <TabItem Header="{DynamicResource CodeAnalysis_Tab_Complexity}" ToolTip="{DynamicResource CodeAnalysis_Tooltip_Tab_Complexity}">
                    <Grid Margin="8">
                        <DataGrid ItemsSource="{Binding TopMethods, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Method}"    Binding="{Binding FullyQualifiedName, Mode=OneWay}" Width="*"/>
                                <DataGridTemplateColumn Header="{DynamicResource CodeAnalysis_Col_CC}" Width="60" SortMemberPath="CyclomaticComplexity">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding CyclomaticComplexity, Converter={StaticResource ThresholdToBrush}, ConverterParameter='5:#4CAF50;10:#FF9800;15:#F44336'}" Padding="4,2">
                                                <TextBlock Text="{Binding CyclomaticComplexity, Mode=OneWay}" HorizontalAlignment="Right" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="{DynamicResource CodeAnalysis_Col_Cognitive}" Width="80" SortMemberPath="CognitiveComplexity">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding CognitiveComplexity, Converter={StaticResource ThresholdToBrush}, ConverterParameter='8:#4CAF50;15:#FF9800;25:#F44336'}" Padding="4,2">
                                                <TextBlock Text="{Binding CognitiveComplexity, Mode=OneWay}" HorizontalAlignment="Right" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="{DynamicResource CodeAnalysis_Col_LOC}" Width="60" SortMemberPath="Loc">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Loc, Converter={StaticResource ThresholdToBrush}, ConverterParameter='50:#4CAF50;100:#FF9800;200:#F44336'}" Padding="4,2">
                                                <TextBlock Text="{Binding Loc, Mode=OneWay}" HorizontalAlignment="Right" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Params}"    Binding="{Binding ParameterCount, Mode=OneWay}" Width="60"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Line}"      Binding="{Binding Line,           Mode=OneWay}" Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ── Coupling ──────────────────────────────────────────── -->
                <TabItem Header="{DynamicResource CodeAnalysis_Tab_Coupling}" ToolTip="{DynamicResource CodeAnalysis_Tooltip_Tab_Coupling}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Expander Grid.Row="0"
                                  Header="{DynamicResource CodeAnalysis_Cycles_Title}"
                                  IsExpanded="True"
                                  Margin="0,0,0,8"
                                  Foreground="{DynamicResource DockMenuForegroundBrush}"
                                  Background="Transparent"
                                  BorderBrush="{DynamicResource DockBorderBrush}"
                                  TextElement.Foreground="{DynamicResource DockMenuForegroundBrush}">
                            <Border Padding="4"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource DockBorderBrush}"
                                    CornerRadius="3">
                                <controls:CyclicDepGraph
                                    Cycles="{Binding ProjectCycles, Mode=OneWay}"
                                    Height="240"
                                    ToolTip="{DynamicResource CodeAnalysis_Cycles_Tooltip}"/>
                            </Border>
                        </Expander>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding TopCouplings, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Type}" Binding="{Binding TypeName, Mode=OneWay}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Ca}"   Binding="{Binding Ca,       Mode=OneWay}" Width="50"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Ce}"   Binding="{Binding Ce,       Mode=OneWay}" Width="50"/>
                                <DataGridTemplateColumn Header="{DynamicResource CodeAnalysis_Col_Instability}" Width="85" SortMemberPath="Instability">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Instability, Converter={StaticResource ThresholdToBrush}, ConverterParameter='0.30:#4CAF50;0.60:#FF9800;0.80:#F44336'}" Padding="4,2">
                                                <TextBlock Text="{Binding Instability, Mode=OneWay, StringFormat={}{0:F2}}" HorizontalAlignment="Right" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="{DynamicResource CodeAnalysis_Col_LCOM}" Width="80" SortMemberPath="Lcom">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Lcom, Converter={StaticResource RiskToBrush}}" Padding="4,2">
                                                <TextBlock Text="{Binding Lcom, Mode=OneWay}" HorizontalAlignment="Center" Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Line}" Binding="{Binding Line, Mode=OneWay}" Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ── Duplication (Phase 10B — master/detail redesign) ─── -->
                <TabItem Header="{DynamicResource CodeAnalysis_Tab_Duplication}" ToolTip="{DynamicResource CodeAnalysis_Tooltip_Tab_Duplication}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="8,6"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource DockBorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="DupFilterBox" Grid.Column="0"
                                         Width="200" Margin="0,0,8,0"
                                         VerticalContentAlignment="Center"
                                         ToolTip="{DynamicResource CodeAnalysis_Duplication_Filter_Placeholder}"
                                         TextChanged="OnDupFilterChanged"/>

                                <ComboBox x:Name="DupSortCombo" Grid.Column="1"
                                          Width="160" Margin="0,0,8,0"
                                          SelectedIndex="0"
                                          SelectionChanged="OnDupSortChanged">
                                    <ComboBoxItem Content="{DynamicResource CodeAnalysis_Duplication_Sort_Lines}"/>
                                    <ComboBoxItem Content="{DynamicResource CodeAnalysis_Duplication_Sort_Tokens}"/>
                                    <ComboBoxItem Content="{DynamicResource CodeAnalysis_Duplication_Sort_Occurrences}"/>
                                </ComboBox>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding DuplicationSummaryText, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           Opacity="0.75"/>

                                <Button Grid.Column="3"
                                        Content="{DynamicResource CodeAnalysis_Duplication_Export_Button}"
                                        Click="OnDupExportClicked"
                                        Padding="8,2"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="340" MinWidth="220"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="240"/>
                            </Grid.ColumnDefinitions>

                            <DataGrid x:Name="DupGroupsGrid" Grid.Column="0"
                                      ItemsSource="{Binding DuplicationGroups, Mode=OneWay}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      SelectionMode="Single"
                                      ContextMenuOpening="OnGridContextMenuOpening">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="{DynamicResource CodeAnalysis_Duplication_Header_Severity}" Width="74">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding Severity, Converter={StaticResource DupSevToBrush}}"
                                                        CornerRadius="3" Padding="4,1" Margin="2"
                                                        ToolTip="{Binding Severity}">
                                                    <TextBlock Text="{Binding Severity}" FontSize="10" HorizontalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Duplication_Header_Lines}"       Binding="{Binding LineCount,       Mode=OneWay}" Width="60"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Duplication_Header_Occurrences}" Binding="{Binding OccurrenceCount, Mode=OneWay}" Width="50"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Duplication_Header_Tokens}"      Binding="{Binding TokenCount,      Mode=OneWay}" Width="60"/>
                                    <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Duplication_Header_PrimaryFile}" Binding="{Binding PrimaryFileName, Mode=OneWay}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <GridSplitter Grid.Column="1" Width="4"
                                          HorizontalAlignment="Stretch"
                                          Background="{DynamicResource DockBorderBrush}"/>

                            <Grid Grid.Column="2">
                                <TextBlock Text="{DynamicResource CodeAnalysis_Duplication_Preview_NoSelection}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Opacity="0.5" FontStyle="Italic"
                                           Visibility="{Binding SelectedItem, ElementName=DupGroupsGrid,
                                                        Converter={StaticResource NullToVisInverse}}"/>

                                <DockPanel Visibility="{Binding SelectedItem, ElementName=DupGroupsGrid,
                                                        Converter={StaticResource NullToVis}}">
                                    <Border DockPanel.Dock="Top" Padding="8,4"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource DockBorderBrush}"
                                            DataContext="{Binding SelectedItem, ElementName=DupGroupsGrid}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="A:" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <ComboBox Width="260" Margin="0,0,12,0"
                                                      ItemsSource="{Binding Occurrences}"
                                                      SelectedIndex="{Binding SelectedIndexA, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontFamily="Consolas" FontSize="11">
                                                            <Run Text="{Binding StartLine, Mode=OneWay}"/>
                                                            <Run Text="–"/>
                                                            <Run Text="{Binding EndLine, Mode=OneWay}"/>
                                                            <Run Text=" · "/>
                                                            <Run Text="{Binding FilePath, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <TextBlock Text="B:" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <ComboBox Width="260"
                                                      ItemsSource="{Binding Occurrences}"
                                                      SelectedIndex="{Binding SelectedIndexB, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontFamily="Consolas" FontSize="11">
                                                            <Run Text="{Binding StartLine, Mode=OneWay}"/>
                                                            <Run Text="–"/>
                                                            <Run Text="{Binding EndLine, Mode=OneWay}"/>
                                                            <Run Text=" · "/>
                                                            <Run Text="{Binding FilePath, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>

                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                        <controls:DuplicationCodePreview
                                            Group="{Binding SelectedItem, ElementName=DupGroupsGrid}"
                                            Height="600"/>
                                    </ScrollViewer>
                                </DockPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ── Treemap (Phase 3) ─────────────────────────────────── -->
                <TabItem Header="{DynamicResource CodeAnalysis_Tab_Treemap}">
                    <TabItem.ToolTip>
                        <ToolTip>
                            <StackPanel MaxWidth="380">
                                <TextBlock FontWeight="SemiBold" Text="{DynamicResource CodeAnalysis_Tooltip_Tab_Treemap_Title}"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="{DynamicResource CodeAnalysis_Tooltip_Tab_Treemap_Body}"/>
                            </StackPanel>
                        </ToolTip>
                    </TabItem.ToolTip>
                    <DockPanel Margin="8">
                        <!-- Help banner + colour legend -->
                        <Border DockPanel.Dock="Top" Padding="8" Margin="0,0,0,8"
                                Background="{DynamicResource DockBorderBrush}"
                                CornerRadius="3">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource CodeAnalysis_Treemap_Score}" Margin="0,0,8,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#43A047" Width="14" Height="14"/>
                                    <TextBlock Text="≥85" Margin="3,0,8,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#9E9D24" Width="14" Height="14"/>
                                    <TextBlock Text="70-84" Margin="3,0,8,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#F57C00" Width="14" Height="14"/>
                                    <TextBlock Text="55-69" Margin="3,0,8,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#E53935" Width="14" Height="14"/>
                                    <TextBlock Text="40-54" Margin="3,0,8,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#B0231E" Width="14" Height="14"/>
                                    <TextBlock Text="&lt;40" Margin="3,0,0,0" FontSize="11"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" VerticalAlignment="Center"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           FontSize="11">
                                    <Run FontWeight="SemiBold" Text="{DynamicResource CodeAnalysis_Treemap_Banner_Title}"/>
                                    <Run Text="{DynamicResource CodeAnalysis_Treemap_Banner_Body}"/>
                                </TextBlock>
                            </DockPanel>
                        </Border>
                        <controls:Treemap x:Name="FileTreemap"
                                          Items="{Binding AllFiles, Mode=OneWay}"
                                          Foreground="White"
                                          ItemActivated="OnTreemapItemActivated"
                                          ContextMenuRequested="OnTreemapContextMenuRequested"/>
                    </DockPanel>
                </TabItem>

                <!-- ── Dead Code ─────────────────────────────────────────── -->
                <TabItem Header="{DynamicResource CodeAnalysis_Tab_Dependencies}" ToolTip="{DynamicResource CodeAnalysis_Tooltip_Tab_Dependencies}">
                    <Grid Margin="8">
                        <controls:DependencyGraphCanvas x:Name="PART_DependencyGraph"
                                                        Nodes="{Binding DependencyNodes, Mode=OneWay}"
                                                        Edges="{Binding DependencyEdges, Mode=OneWay}"/>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource CodeAnalysis_Tab_Trends}" ToolTip="{DynamicResource CodeAnalysis_Tooltip_Tab_Trends}">
                    <Grid Margin="8">
                        <controls:TrendChartControl x:Name="PART_TrendChart"
                                                    Series="{Binding TrendSeries, Mode=OneWay}"/>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource CodeAnalysis_Tab_DeadCode}" ToolTip="{DynamicResource CodeAnalysis_Tooltip_Tab_DeadCode}">
                    <Grid Margin="8">
                        <DataGrid ItemsSource="{Binding DeadSymbols, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Symbol}"  Binding="{Binding Name,        Mode=OneWay}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Kind}"    Binding="{Binding Kind,         Mode=OneWay}" Width="90"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_File}"    Binding="{Binding FilePath,     Mode=OneWay, Converter={x:Static conv:FileNameConverter.Instance}}" Width="160"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Line}"    Binding="{Binding Line,         Mode=OneWay}" Width="55"/>
                                <DataGridTextColumn Header="{DynamicResource CodeAnalysis_Col_Project}" Binding="{Binding ProjectName,  Mode=OneWay}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="WpfHexEditor.App.Analysis.UI.CodeAnalysisReportPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.App.Analysis.UI.ViewModels"
             xmlns:conv="clr-namespace:WpfHexEditor.App.Analysis.UI.Converters"
             Background="{DynamicResource DockWindowBackgroundBrush}"
             Foreground="{DynamicResource DockMenuForegroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WpfHexEditor.App;component/Themes/DialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:GradeToColorConverter   x:Key="GradeToColor"/>
            <conv:SeverityToIconConverter x:Key="SevToIcon"/>
            <conv:ScoreToProgressConverter x:Key="ScoreToProgress"/>
            <BooleanToVisibilityConverter  x:Key="BoolToVis"/>

            <Style x:Key="TabLabelStyle" TargetType="TextBlock">
                <Setter Property="Margin"     Value="6,0"/>
                <Setter Property="FontSize"   Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="MetricLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}"/>
                <Setter Property="FontSize"   Value="11"/>
                <Setter Property="Margin"     Value="0,1"/>
            </Style>

            <Style x:Key="ScoreBig" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="48"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

            <Style x:Key="GradeBig" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="24"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="0,4,0,0"/>
            </Style>

            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource DockForegroundBrush}"/>
                <Setter Property="Margin"     Value="0,12,0,4"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DockBorderBrush}"
                Padding="12,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="ReRunButton" Content="⟳ Re-run"
                            Padding="10,4" Margin="4,0"
                            Click="OnReRunClicked"
                            ToolTip="Re-run the analysis"/>
                    <ComboBox x:Name="ExportCombo" Width="90" Margin="4,0"
                              SelectedIndex="0" ToolTip="Export report"
                              SelectionChanged="OnExportSelectionChanged">
                        <ComboBoxItem Content="Export ▾"/>
                        <ComboBoxItem Content="Markdown"/>
                        <ComboBoxItem Content="CSV"/>
                    </ComboBox>
                </StackPanel>

                <!-- Running spinner -->
                <TextBlock Text="⟳ Analysis running…" Margin="0,0,16,0"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>

                <!-- Summary line when done -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource TabLabelStyle}">
                        <Run Text="{Binding TotalFiles, StringFormat={}{0} files}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding TotalLines, StringFormat={}{0:N0} LOC}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding ProjectCount, StringFormat={}{0} projects}"/>
                    </TextBlock>
                    <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                               Text="{Binding TrendingText}"
                               Foreground="{DynamicResource DockAccentBrush}"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                           Visibility="{Binding HasReport, Converter={StaticResource BoolToVis},
                                        ConverterParameter=Inverse}"
                           Style="{StaticResource MetricLabel}"/>
            </DockPanel>
        </Border>

        <!-- ── Body ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Score sidebar -->
            <Border Grid.Column="0" BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource DockBorderBrush}"
                    Padding="16,16,12,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="SCORE"/>
                    <TextBlock Style="{StaticResource ScoreBig}"
                               Text="{Binding Score}"
                               Foreground="{Binding Grade, Converter={StaticResource GradeToColor}}"/>
                    <TextBlock Style="{StaticResource GradeBig}"
                               Text="{Binding Grade}"
                               Foreground="{Binding Grade, Converter={StaticResource GradeToColor}}"/>
                    <TextBlock Text="{Binding TrendingText}" Margin="0,6,0,0"
                               Foreground="{DynamicResource DockAccentBrush}"/>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="SUB-SCORES" Margin="0,24,0,4"/>

                    <TextBlock Text="Volume"     Style="{StaticResource MetricLabel}"/>
                    <ProgressBar Value="{Binding VolumeScore,     Converter={StaticResource ScoreToProgress}}"
                                 Maximum="1" Height="4" Margin="0,2,0,6"/>
                    <TextBlock Text="Complexity" Style="{StaticResource MetricLabel}"/>
                    <ProgressBar Value="{Binding ComplexityScore, Converter={StaticResource ScoreToProgress}}"
                                 Maximum="1" Height="4" Margin="0,2,0,6"/>
                    <TextBlock Text="Coupling"   Style="{StaticResource MetricLabel}"/>
                    <ProgressBar Value="{Binding CouplingScore,   Converter={StaticResource ScoreToProgress}}"
                                 Maximum="1" Height="4" Margin="0,2,0,6"/>
                    <TextBlock Text="Duplication" Style="{StaticResource MetricLabel}"/>
                    <ProgressBar Value="{Binding DuplicationScore,Converter={StaticResource ScoreToProgress}}"
                                 Maximum="1" Height="4" Margin="0,2,0,6"/>
                    <TextBlock Text="Dead Code"  Style="{StaticResource MetricLabel}"/>
                    <ProgressBar Value="{Binding DeadCodeScore,   Converter={StaticResource ScoreToProgress}}"
                                 Maximum="1" Height="4" Margin="0,2,0,6"/>
                    <TextBlock Text="Conventions" Style="{StaticResource MetricLabel}"/>
                    <ProgressBar Value="{Binding ConventionScore, Converter={StaticResource ScoreToProgress}}"
                                 Maximum="1" Height="4" Margin="0,2,0,6"/>
                </StackPanel>
            </Border>

            <!-- Tabs -->
            <TabControl Grid.Column="1" x:Name="MainTabs"
                        Background="Transparent"
                        BorderThickness="0">

                <!-- ── Overview ──────────────────────────────────────────── -->
                <TabItem Header="Overview">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="BY PROJECT"/>
                            <DataGrid x:Name="ProjectsGrid"
                                      ItemsSource="{Binding Projects}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      Margin="0,0,0,16">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Project" Binding="{Binding ProjectName}" Width="*"/>
                                    <DataGridTextColumn Header="Files"   Binding="{Binding TotalFiles}"  Width="60"/>
                                    <DataGridTextColumn Header="LOC"     Binding="{Binding TotalLines, StringFormat={}{0:N0}}" Width="80"/>
                                    <DataGridTextColumn Header="Types"   Binding="{Binding TypeCount}"   Width="60"/>
                                    <DataGridTextColumn Header="Avg CC"  Binding="{Binding AvgCyclomaticComplexity, StringFormat={}{0:F1}}" Width="70"/>
                                    <DataGridTextColumn Header="Score"   Binding="{Binding Score}"       Width="60"/>
                                    <DataGridTextColumn Header="Grade"   Binding="{Binding Grade}"       Width="55"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="TOP 5 WORST FILES"/>
                            <DataGrid x:Name="WorstFilesGrid"
                                      ItemsSource="{Binding WorstFiles}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      MouseDoubleClick="OnGridDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="File"    Binding="{Binding FileName}"    Width="*"/>
                                    <DataGridTextColumn Header="Project" Binding="{Binding ProjectName}" Width="140"/>
                                    <DataGridTextColumn Header="LOC"     Binding="{Binding TotalLines}"  Width="60"/>
                                    <DataGridTextColumn Header="Max CC"  Binding="{Binding MaxCC}"       Width="70"/>
                                    <DataGridTextColumn Header="Score"   Binding="{Binding Score}"       Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ── Issues ────────────────────────────────────────────── -->
                <TabItem x:Name="IssuesTab">
                    <TabItem.Header>
                        <TextBlock>
                            <Run Text="Issues "/>
                            <Run Text="{Binding Issues.Count}"/>
                        </TextBlock>
                    </TabItem.Header>
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <ComboBox x:Name="SeverityFilter" Width="100" Margin="0,0,8,0"
                                      SelectedIndex="0"
                                      SelectionChanged="OnSeverityFilterChanged">
                                <ComboBoxItem Content="All"/>
                                <ComboBoxItem Content="Error"/>
                                <ComboBoxItem Content="Warning"/>
                                <ComboBoxItem Content="Info"/>
                            </ComboBox>
                            <TextBox x:Name="IssueSearchBox" Width="200"
                                     Text="{Binding IssueFilter, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Search issues…"/>
                        </StackPanel>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Issues}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header=""       Binding="{Binding SeverityIcon}" Width="24"/>
                                <DataGridTextColumn Header="ID"     Binding="{Binding Id}"          Width="80"/>
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}"    Width="*"/>
                                <DataGridTextColumn Header="File"   Binding="{Binding FileName}"    Width="160"/>
                                <DataGridTextColumn Header="Line"   Binding="{Binding Line}"        Width="55"/>
                                <DataGridTextColumn Header="Project" Binding="{Binding ProjectName}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ── Complexity ────────────────────────────────────────── -->
                <TabItem Header="Complexity">
                    <Grid Margin="8">
                        <DataGrid ItemsSource="{Binding TopMethods}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Method"    Binding="{Binding FullyQualifiedName}" Width="*"/>
                                <DataGridTextColumn Header="CC"        Binding="{Binding CyclomaticComplexity}"  Width="60"/>
                                <DataGridTextColumn Header="Cognitive" Binding="{Binding CognitiveComplexity}"   Width="80"/>
                                <DataGridTextColumn Header="LOC"       Binding="{Binding Loc}"                   Width="60"/>
                                <DataGridTextColumn Header="Params"    Binding="{Binding ParameterCount}"        Width="60"/>
                                <DataGridTextColumn Header="Line"      Binding="{Binding Line}"                  Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ── Coupling ──────────────────────────────────────────── -->
                <TabItem Header="Coupling">
                    <Grid Margin="8">
                        <DataGrid ItemsSource="{Binding TopCouplings}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Type"        Binding="{Binding TypeName}"            Width="*"/>
                                <DataGridTextColumn Header="Ca"          Binding="{Binding Ca}"                  Width="50"/>
                                <DataGridTextColumn Header="Ce"          Binding="{Binding Ce}"                  Width="50"/>
                                <DataGridTextColumn Header="Instability" Binding="{Binding Instability, StringFormat={}{0:F2}}" Width="85"/>
                                <DataGridTextColumn Header="LCOM"        Binding="{Binding Lcom}"                Width="70"/>
                                <DataGridTextColumn Header="Line"        Binding="{Binding Line}"                Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ── Duplication ───────────────────────────────────────── -->
                <TabItem Header="Duplication">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl ItemsSource="{Binding Duplications}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="8"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource DockBorderBrush}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold">
                                                <Run Text="Clone group — "/>
                                                <Run Text="{Binding LineCount}"/>
                                                <Run Text=" lines, "/>
                                                <Run Text="{Binding Occurrences.Count}"/>
                                                <Run Text=" occurrences, "/>
                                                <Run Text="{Binding TokenCount}"/>
                                                <Run Text=" tokens"/>
                                            </TextBlock>
                                            <ItemsControl ItemsSource="{Binding Occurrences}"
                                                          Margin="12,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontFamily="Consolas" FontSize="11">
                                                            <Run Text="{Binding FilePath}"/>
                                                            <Run Text=" : "/>
                                                            <Run Text="{Binding StartLine}"/>
                                                            <Run Text="–"/>
                                                            <Run Text="{Binding EndLine}"/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <!-- ── Dead Code ─────────────────────────────────────────── -->
                <TabItem Header="Dead Code">
                    <Grid Margin="8">
                        <DataGrid ItemsSource="{Binding DeadSymbols}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MouseDoubleClick="OnGridDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Symbol"  Binding="{Binding Name}"        Width="*"/>
                                <DataGridTextColumn Header="Kind"    Binding="{Binding Kind}"         Width="90"/>
                                <DataGridTextColumn Header="File"    Binding="{Binding FilePath, Converter={x:Static conv:FileNameConverter.Instance}}" Width="160"/>
                                <DataGridTextColumn Header="Line"    Binding="{Binding Line}"          Width="55"/>
                                <DataGridTextColumn Header="Project" Binding="{Binding ProjectName}"   Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>

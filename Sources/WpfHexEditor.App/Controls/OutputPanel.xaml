<UserControl x:Class="WpfHexEditor.App.Controls.OutputPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockBackgroundBrush}"
             xmlns:appSvc="clr-namespace:WpfHexEditor.App.Services">
    <UserControl.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <appSvc:AppLocalizedDictionary/>
                </ResourceDictionary.MergedDictionaries>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
                </ResourceDictionary>
        </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{StaticResource APP_ShowOutputFrom}"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="4,0,6,0"
                           FontSize="12" />
                <ComboBox x:Name="SourceComboBox"
                          Width="160"
                          SelectedIndex="0"
                          VerticalAlignment="Center"
                          FontSize="12"
                          SelectionChanged="OnSourceChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="UnreadDot"
                                         Width="7" Height="7"
                                         Fill="#4EC9B0"
                                         Margin="0,0,6,0"
                                         VerticalAlignment="Center"
                                         Visibility="{Binding HasUnread, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="&#xD7;" ToolTip="{StaticResource APP_ClearAll}"
                        Click="OnClear"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}"
                        FontSize="14" FontWeight="Bold"
                        Width="26" Height="24"
                        Margin="6,0,0,0"
                        Padding="0,-2,0,0" />
                <Button x:Name="WrapButton"
                        Content="&#x21A9;" ToolTip="{StaticResource APP_ToggleWordWrap}"
                        Click="OnToggleWordWrap"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}"
                        FontSize="14"
                        Width="26" Height="24"
                        Padding="0,-1,0,0" />
                <Button Content="&#x2398;" ToolTip="{StaticResource APP_CopyAll}"
                        Click="OnCopyAll"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}"
                        FontSize="14"
                        Width="26" Height="24"
                        Padding="0,-1,0,0" />
                <Button x:Name="AutoScrollButton"
                        Content="&#x2913;" ToolTip="{StaticResource APP_ToggleAutoScroll}"
                        Click="OnToggleAutoScroll"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}"
                        FontSize="14" FontWeight="Bold"
                        Width="26" Height="24"
                        Padding="0,-1,0,0" />
            </StackPanel>
        </Border>

        <!-- Output RichTextBox (colored per log level) -->
        <RichTextBox Grid.Row="1"
                     x:Name="OutputTextBox"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Background="{DynamicResource DockBackgroundBrush}"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     CaretBrush="{DynamicResource DockMenuForegroundBrush}"
                     BorderThickness="0"
                     FontFamily="Cascadia Mono, Consolas, monospace"
                     FontSize="12"
                     Padding="4,2">
            <RichTextBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{StaticResource APP_Copy}"
                              Command="ApplicationCommands.Copy"
                              InputGestureText="Ctrl+C">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{StaticResource APP_CopyAll}"
                              Click="OnCopyAll"/>
                    <MenuItem Header="{StaticResource APP_SelectAll}"
                              Command="ApplicationCommands.SelectAll"
                              InputGestureText="Ctrl+A"/>
                    <Separator/>
                    <MenuItem Header="{StaticResource APP_ClearAll}"
                              Click="OnClear"/>
                    <MenuItem Header="{StaticResource APP_SaveOutputAs}"
                              Click="OnSaveOutputAs"/>
                    <Separator/>
                    <MenuItem x:Name="WordWrapMenuItem"
                              Header="{StaticResource APP_ToggleWordWrap}"
                              IsCheckable="True"
                              Click="OnToggleWordWrap"/>
                    <MenuItem x:Name="AutoScrollMenuItem"
                              Header="{StaticResource APP_ToggleAutoScroll}"
                              IsCheckable="True"
                              Click="OnToggleAutoScroll"/>
                </ContextMenu>
            </RichTextBox.ContextMenu>
            <RichTextBox.Document>
                <FlowDocument PagePadding="0" />
            </RichTextBox.Document>
        </RichTextBox>
    </Grid>
</UserControl>

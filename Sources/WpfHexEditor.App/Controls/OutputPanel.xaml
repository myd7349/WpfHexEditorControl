<UserControl x:Class="WpfHexEditor.App.Controls.OutputPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DockBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource DockMenuBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Show output from:"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="4,0,6,0"
                           FontSize="12" />
                <ComboBox x:Name="SourceComboBox"
                          Width="140"
                          SelectedIndex="0"
                          VerticalAlignment="Center"
                          FontSize="12">
                    <ComboBoxItem Content="Debug" />
                    <ComboBoxItem Content="Build" />
                    <ComboBoxItem Content="General" />
                </ComboBox>
                <Button Content="&#xD7;"
                        ToolTip="Clear All"
                        Click="OnClear"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}"
                        FontSize="14" FontWeight="Bold"
                        Width="26" Height="24"
                        Margin="6,0,0,0"
                        Padding="0,-2,0,0" />
                <Button x:Name="WrapButton"
                        Content="&#x21A9;"
                        ToolTip="Toggle Word Wrap"
                        Click="OnToggleWordWrap"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}"
                        FontSize="14"
                        Width="26" Height="24"
                        Padding="0,-1,0,0" />
                <Button Content="&#x2398;"
                        ToolTip="Copy All"
                        Click="OnCopyAll"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}"
                        FontSize="14"
                        Width="26" Height="24"
                        Padding="0,-1,0,0" />
                <Button x:Name="AutoScrollButton"
                        Content="&#x2913;"
                        ToolTip="Toggle Auto-Scroll"
                        Click="OnToggleAutoScroll"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}"
                        FontSize="14" FontWeight="Bold"
                        Width="26" Height="24"
                        Padding="0,-1,0,0" />
            </StackPanel>
        </Border>

        <!-- Output RichTextBox (colored per log level) -->
        <RichTextBox Grid.Row="1"
                     x:Name="OutputTextBox"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Background="{DynamicResource DockBackgroundBrush}"
                     Foreground="{DynamicResource DockMenuForegroundBrush}"
                     CaretBrush="{DynamicResource DockMenuForegroundBrush}"
                     BorderThickness="0"
                     FontFamily="Cascadia Mono, Consolas, monospace"
                     FontSize="12"
                     Padding="4,2">
            <RichTextBox.Document>
                <FlowDocument PagePadding="0" />
            </RichTextBox.Document>
        </RichTextBox>
    </Grid>
</UserControl>

     Author: Derek Tremblay (derektremblay666@gmail.com)
     Contributors: Claude Sonnet 4.6
     Created: 2026-03-07
     Description:
         Lightweight non-modal Popup anchored to the StatusBar plugin indicator.
         Displays a compact plugin list with per-item state glyphs plus
         Manage and Install action buttons.
     Architecture Notes:
         UserControl embedded inside a Popup (not Window). DataContext is
         PluginQuickStatusViewModel. All colors via DynamicResource.
     ========================================================== -->

<UserControl x:Class="WpfHexEditor.App.Controls.PluginQuickStatusPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfHexEditor.App.ViewModels"
             xmlns:appSvc="clr-namespace:WpfHexEditor.App.Services">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <appSvc:AppLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource DockBackgroundBrush}"
            BorderBrush="{DynamicResource DockBorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            MinWidth="280"
            MaxWidth="340"
            Padding="0,0,0,4">

        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.35" Color="Black"/>
        </Border.Effect>

        <StackPanel>

            <!-- Header -->
            <Border Background="{DynamicResource DockTabActiveBrush}"
                    CornerRadius="4,4,0,0"
                    Padding="10,7">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <TextBlock Text="{StaticResource APP_ExtensionSystem}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Summary line -->
            <TextBlock Text="{Binding SummaryText}"
                       FontSize="11"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       Margin="10,7,10,3"
                       Opacity="0.75"/>

            <!-- Separator -->
            <Separator Margin="6,0"
                       Background="{DynamicResource DockBorderBrush}"
                       Height="1"/>

            <!-- Plugin rows -->
            <ItemsControl ItemsSource="{Binding Rows}"
                          Margin="4,4,4,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:QuickPluginRow}">
                        <Grid Margin="4,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- State glyph -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding StateDot}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       Foreground="{Binding StateColor}"
                                       VerticalAlignment="Center"/>

                            <!-- Plugin name -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontSize="12"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- State label + SLOW badge -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Visibility="{Binding IsSlow, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="{DynamicResource PM_BadgeSlowBrush}"
                                        CornerRadius="3" Padding="4,1" Margin="0,0,4,0">
                                    <TextBlock Text="{StaticResource APP_SlowBadge}" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="{Binding StateLabel}"
                                           FontSize="11"
                                           Foreground="{Binding StateColor}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Separator -->
            <Separator Margin="6,6,6,0"
                       Background="{DynamicResource DockBorderBrush}"
                       Height="1"/>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="8,6,8,0">
                <Button Content="{StaticResource APP_InstallEllipsis}"
                        Command="{Binding InstallCommand}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        FontFamily="Segoe UI"
                        Padding="10,4"
                        Margin="0,0,6,0"
                        FontSize="12"/>
                <Button Content="Manage"
                        Command="{Binding ManageCommand}"
                        Style="{DynamicResource PanelIconButtonStyle}"
                        FontFamily="Segoe UI"
                        Padding="10,4"
                        FontSize="12"/>
            </StackPanel>

        </StackPanel>
    </Border>
</UserControl>

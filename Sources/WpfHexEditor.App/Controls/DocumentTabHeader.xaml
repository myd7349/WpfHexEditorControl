<UserControl x:Class="WpfHexEditor.App.Controls.DocumentTabHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:appSvc="clr-namespace:WpfHexEditor.App.Services"
             mc:Ignorable="d"
             d:DesignWidth="160" d:DesignHeight="22"
             Background="Transparent"
             ToolTip="{Binding FilePath}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <appSvc:AppLocalizedDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--
        DocumentTabHeader — displays tab title with optional dirty (*) indicator.
        Theme: inherits from parent (DockTabItem) — no brush overrides needed.
        Bind DataContext to a DocumentModel instance.
    -->

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

        <!-- File type icon (16×16) — shown when EditorId is set -->
        <Image x:Name="EditorIcon"
               Width="14" Height="14"
               Margin="0,0,4,0"
               VerticalAlignment="Center"
               Visibility="Collapsed" />

        <!-- Title text -->
        <TextBlock x:Name="TitleText"
                   Text="{Binding Title}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   MaxWidth="140" />

        <!-- Dirty indicator — ● bullet shown when IsDirty = true -->
        <TextBlock x:Name="DirtyIndicator"
                   Text=" ●"
                   FontSize="8"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource DockAccentBrush}"
                   ToolTip="{StaticResource APP_UnsavedChanges}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDirty}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Read-only lock icon -->
        <TextBlock x:Name="ReadOnlyIndicator"
                   Text=" 🔒"
                   FontSize="8"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                   ToolTip="{StaticResource APP_ReadOnly}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

    </StackPanel>
</UserControl>

<Window x:Class="WpfHexEditor.App.MainWindow"
        x:Name="ThisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="clr-namespace:WpfHexEditor.Docking.Wpf;assembly=WpfHexEditor.Docking.Wpf"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core;assembly=WpfHexEditor.Editor.Core"
        xmlns:local="clr-namespace:WpfHexEditor.App"
        xmlns:appCtrl="clr-namespace:WpfHexEditor.App.Controls"
        xmlns:appModels="clr-namespace:WpfHexEditor.App.Models"
        Title="WpfHexEditor"
        Icon="pack://application:,,,/WpfHexEditor.App;component/Logo.ico"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowDrop="True"
        Drop="OnFileDrop"
        DragOver="OnFileDragOver"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar (VS Code style: menu inline + title center + window buttons right) -->
        <Border Grid.Row="0" Background="{DynamicResource DockMenuBackgroundBrush}">
            <DockPanel Height="32">
                <!-- Window buttons (right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE949;" Style="{DynamicResource TitleBarButtonStyle}"
                            Click="OnMinimize" ToolTip="Minimize" />
                    <Button x:Name="MaxRestoreButton" Content="&#xE739;"
                            Style="{DynamicResource TitleBarButtonStyle}"
                            Click="OnMaximizeRestore" ToolTip="Maximize" />
                    <Button Content="&#xE106;" Style="{DynamicResource TitleBarCloseButtonStyle}"
                            Click="OnCloseWindow" ToolTip="Close" />
                </StackPanel>

                <!-- Logo (VS2022/VS Code style — far left, click = system menu) -->
                <Image DockPanel.Dock="Left"
                       Source="pack://application:,,,/WpfHexEditor.App;component/Logo.ico"
                       Width="20" Height="20"
                       Margin="8,0,4,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       WindowChrome.IsHitTestVisibleInChrome="True"
                       Cursor="Arrow"
                       MouseLeftButtonDown="OnLogoMouseDown" />

                <!-- Menu (left, inline in title bar) -->
                <Menu DockPanel.Dock="Left" Style="{DynamicResource DockDarkMenuStyle}"
                      VerticalAlignment="Center"
                      WindowChrome.IsHitTestVisibleInChrome="True">

                    <!-- ═══════════ File ═══════════ -->
                    <MenuItem Header="_File"
                              IsEnabled="{Binding IsMenuEnabled, ElementName=ThisWindow}">

                        <!-- New ► -->
                        <MenuItem Header="_New">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <MenuItem Header="_Solution..." Click="OnNewSolution" InputGestureText="Ctrl+Shift+N">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_Project..." Click="OnNewProject">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="_File..." Click="OnNewFile" InputGestureText="Ctrl+N">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>

                        <!-- Open ► -->
                        <MenuItem Header="_Open">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <MenuItem Header="_Solution/Project..." Click="OnOpenSolutionOrProject" InputGestureText="Ctrl+Shift+O">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_File..." Click="OnOpenFile" InputGestureText="Ctrl+O">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>

                        <Separator />

                        <!-- Close active document -->
                        <MenuItem Header="_Close" Click="OnCloseActiveDocument" InputGestureText="Ctrl+W">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Close _All Documents" Click="OnCloseAllDocuments">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Close _Solution" Click="OnCloseSolution"
                                  IsEnabled="{Binding HasSolution, ElementName=ThisWindow}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <Separator />

                        <!-- Save -->
                        <MenuItem Header="_Save"
                                  Command="{x:Static ApplicationCommands.Save}"
                                  InputGestureText="Ctrl+S">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Save _All" Click="OnSaveAll" InputGestureText="Ctrl+Shift+S">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Write to Disk"
                                  Command="{x:Static local:MainWindow.WriteToDiskCommand}"
                                  InputGestureText="Ctrl+Shift+W">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <Separator />

                        <!-- Options (VS-style document tab) -->
                        <MenuItem Header="_Options..." Click="OnSettings">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <Separator />

                        <!-- Recent Solutions ► -->
                        <MenuItem x:Name="RecentSolutionsMenuItem" Header="Recent _Solutions">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <!-- Items populated dynamically -->
                        </MenuItem>

                        <!-- Recent Files ► -->
                        <MenuItem x:Name="RecentFilesMenuItem" Header="Recent _Files">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <!-- Items populated dynamically -->
                        </MenuItem>

                        <Separator />
                        <MenuItem Header="E_xit" Click="OnExit" InputGestureText="Alt+F4">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Edit ═══════════ -->
                    <MenuItem Header="_Edit"
                              IsEnabled="{Binding IsMenuEnabled, ElementName=ThisWindow}">
                        <MenuItem Header="_Undo"
                                  Command="{Binding ActiveDocumentEditor.UndoCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+Z">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Redo"
                                  Command="{Binding ActiveDocumentEditor.RedoCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+Y">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Cu_t"
                                  Command="{Binding ActiveDocumentEditor.CutCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+X">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Copy"
                                  Command="{Binding ActiveDocumentEditor.CopyCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+C">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Paste"
                                  Command="{Binding ActiveDocumentEditor.PasteCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+V">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Delete"
                                  Command="{Binding ActiveDocumentEditor.DeleteCommand, ElementName=ThisWindow}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Select _All"
                                  Command="{Binding ActiveDocumentEditor.SelectAllCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+A">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="_Find..."
                                  Command="{x:Static ApplicationCommands.Find}"
                                  CommandTarget="{Binding ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+F">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Advanced Find / Replace..."
                                  Command="{x:Static local:MainWindow.AdvancedSearchCommand}"
                                  InputGestureText="Ctrl+Shift+F">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Find _Next"
                                  Click="OnFindNext"
                                  InputGestureText="F3" />
                        <MenuItem Header="Find _Previous"
                                  Click="OnFindPrevious"
                                  InputGestureText="Shift+F3" />
                        <Separator />
                        <MenuItem Header="_Go To Offset…" Click="OnGoToOffset" InputGestureText="Ctrl+G">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ View ═══════════ -->
                    <MenuItem Header="_View">
                        <MenuItem Header="_Solution Explorer" Click="OnShowSolutionExplorer" InputGestureText="Ctrl+Alt+L">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Parsed Fields" Click="OnShowParsedFields">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Properties" Click="OnShowProperties" InputGestureText="F4">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Output" Click="OnShowOutput">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Error List" Click="OnShowErrorPanel">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Byte Chart" Click="OnShowByteChartPanel">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Data Inspector" Click="OnShowDataInspectorPanel">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE9E6;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Structure Overlay" Click="OnShowStructureOverlayPanel">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="File _Statistics" Click="OnShowFileStatsPanel">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Pattern Analysis" Click="OnShowPatternAnalysisPanel">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE773;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Format _Info" Click="OnShowFormatInfoPanel">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="File _Comparison" Click="OnShowFileComparisonPanel">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE93D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Archive Structure" Click="OnShowArchivePanel">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Custom Parser Template" Click="OnShowCustomParserTemplate">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE9A1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="_Compare Files…" Click="OnCompareFiles" InputGestureText="Ctrl+Alt+D">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE93D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Entropy Analysis…" Click="OnEntropyAnalysis"
                                  ToolTip="Analyse entropy and byte distribution of the active file">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Project ═══════════ (enabled when solution loaded AND no operation active) -->
                    <MenuItem Header="_Project"
                              IsEnabled="{Binding IsProjectMenuEnabled, ElementName=ThisWindow}">
                        <MenuItem Header="Add _New Item..." Click="OnProjectAddNewItem" InputGestureText="Ctrl+Shift+A">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Add E_xisting Item..." Click="OnProjectAddExistingItem" InputGestureText="Shift+Alt+A">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Add New _Project..." Click="OnNewProject">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="P_roperties..." Click="OnProjectProperties">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Layout ═══════════ -->
                    <MenuItem Header="_Layout">
                        <MenuItem Header="_Save Layout" Click="OnSaveLayout">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Load Layout" Click="OnLoadLayout">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Reset Layout" Click="OnResetLayout">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Toggle _Locked Layout" Click="OnToggleLock" IsCheckable="True" x:Name="LockMenuItem">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Theme ═══════════ -->
                    <MenuItem Header="_Theme">
                        <MenuItem Header="_Dark" Click="OnDarkTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE708;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Light" Click="OnLightTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="VS2022 Dar_k" Click="OnVS2022DarkTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Dark _Glass" Click="OnDarkGlassTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Visual Studio" Click="OnVisualStudioTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Cyberpunk" Click="OnCyberpunkTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="_Minimal" Click="OnMinimalTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Office" Click="OnOfficeTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <!-- Title (center, fills remaining space) -->
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           FontSize="12" IsHitTestVisible="False" />
            </DockPanel>
        </Border>

        <!-- Toolbar — VS2026 pod pattern (7 pods)
             ┌────────────────────────┐ ┌───────────────────────────┐ ┌────────────────┐ ┌──────────────────────────────────┐ ┌──────────────┐ ┌──────────────────┐ ┌────────────────┐
             │  New▾  Open▾  │ 💾 💾All │ │  ↩ Undo  ↪ Redo  │ ✂ ⧉ 📋 │ │  🔍 Find  │ ↓ ↑ │ │  🔍 Explorer  │ ≡  │ ⚙  │ ▪ Output │ │  Layout▾     │ │ [editor actions] │ │ 🔤 TBL▾       │
             └────────────────────────┘ └───────────────────────────┘ └────────────────┘ └──────────────────────────────────┘ └──────────────┘ └──────────────────┘ └────────────────┘
                     Pod File                    Pod Edit                   Pod Find                     Pod View                  Pod Layout      Pod contextuel       Pod TBL        -->
        <ToolBar Grid.Row="1" Style="{DynamicResource DockDarkToolBarStyle}">

            <!-- ── Pod 1 : File ───────────────────────────────────────────── -->
            <Border Style="{DynamicResource DockToolBarPodStyle}">
                <StackPanel Orientation="Horizontal">

                    <!-- New ▾ : New File / New Project / New Solution -->
                    <Button Click="OnToolBarDropDownClick" ToolTip="New…"
                            Style="{DynamicResource DockToolBarPodDropDownButtonStyle}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="New _File…"     Click="OnNewFile"
                                          InputGestureText="Ctrl+N">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="New _Project…"  Click="OnNewProject">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8F9;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="New _Solution…" Click="OnNewSolution"
                                          InputGestureText="Ctrl+Shift+N">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Open ▾ : Open File / Open Solution or Project -->
                    <Button Click="OnToolBarDropDownClick" ToolTip="Open…"
                            Style="{DynamicResource DockToolBarPodDropDownButtonStyle}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open _File…"              Click="OnOpenFile"
                                          InputGestureText="Ctrl+O">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Open Solution/_Project…"  Click="OnOpenSolutionOrProject"
                                          InputGestureText="Ctrl+Shift+O">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8F9;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Save — Command binding (auto-enable/disable) -->
                    <Button Command="{x:Static ApplicationCommands.Save}"
                            ToolTip="Save (Ctrl+S)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <!-- Save All -->
                    <Button Click="OnSaveAll" ToolTip="Save All (Ctrl+Shift+S)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                </StackPanel>
            </Border>

            <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>

            <!-- ── Pod 2 : Edit ───────────────────────────────────────────── -->
            <Border Style="{DynamicResource DockToolBarPodStyle}">
                <StackPanel Orientation="Horizontal">

                    <!-- Undo / Redo — Command bindings -->
                    <Button Command="{Binding ActiveDocumentEditor.UndoCommand, ElementName=ThisWindow}"
                            ToolTip="Undo (Ctrl+Z)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding ActiveDocumentEditor.RedoCommand, ElementName=ThisWindow}"
                            ToolTip="Redo (Ctrl+Y)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Cut / Copy / Paste — Command bindings -->
                    <Button Command="{Binding ActiveDocumentEditor.CutCommand, ElementName=ThisWindow}"
                            ToolTip="Cut (Ctrl+X)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding ActiveDocumentEditor.CopyCommand, ElementName=ThisWindow}"
                            ToolTip="Copy (Ctrl+C)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding ActiveDocumentEditor.PasteCommand, ElementName=ThisWindow}"
                            ToolTip="Paste (Ctrl+V)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                </StackPanel>
            </Border>

            <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>

            <!-- ── Pod 3 : Find ───────────────────────────────────────────── -->
            <Border Style="{DynamicResource DockToolBarPodStyle}">
                <StackPanel Orientation="Horizontal">

                    <!-- Find — icon + label -->
                    <Button Click="OnShowAdvancedSearch" ToolTip="Find… (Ctrl+F)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Find" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Find Next (F3) -->
                    <Button Click="OnFindNext" ToolTip="Find Next (F3)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <!-- Find Previous (Shift+F3) -->
                    <Button Click="OnFindPrevious" ToolTip="Find Previous (Shift+F3)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Button>

                </StackPanel>
            </Border>

            <!-- ── Pod 4 : View (panneaux) ────────────────────────────────── -->
            <Border Style="{DynamicResource DockToolBarPodStyle}">
                <StackPanel Orientation="Horizontal">

                    <!-- Solution Explorer : icon + label -->
                    <Button Click="OnShowSolutionExplorer" ToolTip="Solution Explorer (Ctrl+Alt+L)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Explorer" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Parsed Fields -->
                    <Button Click="OnShowParsedFields" ToolTip="Parsed Fields"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xEBD2;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Properties -->
                    <Button Click="OnShowProperties" ToolTip="Properties (F4)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Output -->
                    <Button Click="OnShowOutput" ToolTip="Output"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE9A8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                </StackPanel>
            </Border>

            <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>

            <!-- ── Pod 5 : Layout ▾ ───────────────────────────────────────── -->
            <Border Style="{DynamicResource DockToolBarPodStyle}">
                <Button Click="OnToolBarDropDownClick" ToolTip="Layout options…"
                        Style="{DynamicResource DockToolBarPodDropDownButtonStyle}">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="_Save Layout…"   Click="OnSaveLayout">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_Load Layout…"   Click="OnLoadLayout">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_Reset Layout"   Click="OnResetLayout">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Toggle _Locked Layout" Click="OnToggleLock"
                                      IsCheckable="True" x:Name="LockMenuItemToolbar">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xECA5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Layout" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>

            <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>

            <!-- ── Pod contextuel — visible seulement quand un éditeur contribue ─── -->
            <Border>
                <Border.Style>
                    <Style BasedOn="{StaticResource DockToolBarPodStyle}" TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveToolbarContributor, ElementName=ThisWindow}"
                                         Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ItemsControl ItemsSource="{Binding ActiveToolbarContributor.ToolbarItems, ElementName=ThisWindow}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplateSelector>
                        <appCtrl:EditorToolbarItemTemplateSelector>
                            <!-- Separator -->
                            <appCtrl:EditorToolbarItemTemplateSelector.SeparatorTemplate>
                                <DataTemplate DataType="{x:Type ec:EditorToolbarItem}">
                                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>
                                </DataTemplate>
                            </appCtrl:EditorToolbarItemTemplateSelector.SeparatorTemplate>
                            <!-- Plain button -->
                            <appCtrl:EditorToolbarItemTemplateSelector.ButtonTemplate>
                                <DataTemplate DataType="{x:Type ec:EditorToolbarItem}">
                                    <Button Command="{Binding Command}"
                                            IsEnabled="{Binding IsEnabled}"
                                            ToolTip="{Binding Tooltip}"
                                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Label}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </appCtrl:EditorToolbarItemTemplateSelector.ButtonTemplate>
                            <!-- Dropdown button (simplified: button with context menu) -->
                            <appCtrl:EditorToolbarItemTemplateSelector.DropdownTemplate>
                                <DataTemplate DataType="{x:Type ec:EditorToolbarItem}">
                                    <Button Command="{Binding Command}"
                                            IsEnabled="{Binding IsEnabled}"
                                            ToolTip="{Binding Tooltip}"
                                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                                        <Button.ContextMenu>
                                            <ContextMenu ItemsSource="{Binding DropdownItems}">
                                                <ContextMenu.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type ec:EditorToolbarItem}">
                                                        <MenuItem Header="{Binding Label}"
                                                                  Command="{Binding Command}"/>
                                                    </DataTemplate>
                                                </ContextMenu.ItemTemplate>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Label}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="8" VerticalAlignment="Center"
                                                       Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </appCtrl:EditorToolbarItemTemplateSelector.DropdownTemplate>
                        </appCtrl:EditorToolbarItemTemplateSelector>
                    </ItemsControl.ItemTemplateSelector>
                </ItemsControl>
            </Border>

            <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>

            <!-- ── Pod TBL : sélecteur de table (visible uniquement si HexEditor actif) ── -->
            <Border>
                <Border.Style>
                    <Style BasedOn="{StaticResource DockToolBarPodStyle}" TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveHexEditor, ElementName=ThisWindow}"
                                         Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <!-- Table icon -->
                    <TextBlock Text="&#xE8C1;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="4,0,4,0"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               ToolTip="Character Table"/>
                    <!-- TBL ComboBox -->
                    <ComboBox Width="180" VerticalAlignment="Center"
                              ItemsSource="{Binding TblItems, ElementName=ThisWindow}"
                              SelectedItem="{Binding SelectedTblItem, ElementName=ThisWindow, Mode=TwoWay}"
                              ToolTip="Active character table"
                              Background="Transparent"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              IsTextSearchEnabled="False">
                        <!-- ItemTemplate = used for the selection box (closed state).
                             ItemTemplateSelector = used for the popup dropdown items only.
                             WPF ignores ItemTemplateSelector for the selection box and uses ItemTemplate. -->
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type appModels:TblSelectionItem}">
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Style.Triggers>
                                    <!-- Headers: not focusable/clickable but visually ENABLED
                                         (IsEnabled stays True) so the bold text renders with full
                                         color in any theme — no graying. -->
                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                        <Setter Property="Focusable"        Value="False"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                        <Setter Property="Padding"          Value="0"/>
                                    </DataTrigger>
                                    <!-- Separators: disabled (grayed is fine for a pure visual line) -->
                                    <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                        <Setter Property="IsEnabled"        Value="False"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                        <Setter Property="Padding"          Value="0"/>
                                        <Setter Property="MinHeight"        Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBox.ItemTemplateSelector>
                            <appCtrl:TblItemTemplateSelector>
                                <appCtrl:TblItemTemplateSelector.HeaderTemplate>
                                    <DataTemplate DataType="{x:Type appModels:TblSelectionItem}">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="Bold" FontSize="11"
                                                   Foreground="{DynamicResource SE_GroupHeaderBrush}"
                                                   IsHitTestVisible="False"
                                                   Padding="4,5,0,2"/>
                                    </DataTemplate>
                                </appCtrl:TblItemTemplateSelector.HeaderTemplate>
                                <appCtrl:TblItemTemplateSelector.SeparatorTemplate>
                                    <DataTemplate DataType="{x:Type appModels:TblSelectionItem}">
                                        <Separator Margin="4,2" IsHitTestVisible="False"/>
                                    </DataTemplate>
                                </appCtrl:TblItemTemplateSelector.SeparatorTemplate>
                                <appCtrl:TblItemTemplateSelector.ItemTemplate>
                                    <DataTemplate DataType="{x:Type appModels:TblSelectionItem}">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                   Padding="4,2"/>
                                    </DataTemplate>
                                </appCtrl:TblItemTemplateSelector.ItemTemplate>
                            </appCtrl:TblItemTemplateSelector>
                        </ComboBox.ItemTemplateSelector>
                    </ComboBox>
                </StackPanel>
            </Border>

        </ToolBar>

        <!-- Main Dock Area -->
        <dock:DockControl Grid.Row="2" x:Name="DockHost" Margin="2" />

        <!-- Status Bar — VS2022-style: adapts to the active document -->
        <StatusBar Grid.Row="3" Background="{DynamicResource DockTabActiveBrush}">

            <!-- Active editor interactive items (IStatusBarContributor) -->
            <StatusBarItem>
                <ItemsControl ItemsSource="{Binding ActiveStatusBarContributor.StatusBarItems, ElementName=ThisWindow}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type ec:StatusBarItem}">
                            <!-- Border instead of Button: avoids WPF StatusBar click-absorption quirk -->
                            <Border Padding="6,2"
                                    Cursor="Hand"
                                    ToolTip="{Binding Tooltip}"
                                    MouseLeftButtonDown="StatusBarItem_MouseLeftButtonDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Foreground="{DynamicResource DockTabActiveTextBrush}" VerticalAlignment="Center">
                                    <Run Text="{Binding Label, Mode=OneWay}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding Value, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                                <Border.ContextMenu>
                                    <ContextMenu ItemsSource="{Binding Choices}">
                                        <ContextMenu.ItemContainerStyle>
                                            <Style TargetType="MenuItem" BasedOn="{StaticResource DockDarkMenuItemStyle}">
                                                <Setter Property="Header"    Value="{Binding DisplayName}"/>
                                                <Setter Property="Command"   Value="{Binding Command}"/>
                                                <Setter Property="IsChecked" Value="{Binding IsActive}"/>
                                            </Style>
                                        </ContextMenu.ItemContainerStyle>
                                    </ContextMenu>
                                </Border.ContextMenu>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StatusBarItem>

            <!-- Centre : progression des opérations longues (visible uniquement pendant une opération) -->
            <StatusBarItem x:Name="ProgressStatusItem" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ProgressTitleText"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               FontWeight="SemiBold" Margin="8,0,8,0"
                               VerticalAlignment="Center"/>
                    <ProgressBar x:Name="AppProgressBar"
                                 Width="160" Height="10" Minimum="0" Maximum="100"
                                 VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProgressPercentText"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               Margin="6,0,8,0" MinWidth="32"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProgressMessageText"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <Button x:Name="ProgressCancelButton"
                            Content="✕"
                            ToolTip="Cancel operation"
                            Click="OnProgressCancel"
                            Visibility="Collapsed"
                            Padding="6,1"
                            Style="{DynamicResource DockDarkButtonStyle}"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>

            <!-- Right: solution name + refresh time + panel count -->
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="SolutionText" Text="" Foreground="{DynamicResource DockTabActiveTextBrush}" Margin="0,0,12,0"/>
                    <TextBlock x:Name="RefreshText" Text="" Foreground="{DynamicResource DockTabActiveTextBrush}" Margin="0,0,12,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>

    <!-- Keyboard shortcuts -->
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N"       Command="{x:Static ApplicationCommands.New}"   CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+O"       Command="{x:Static ApplicationCommands.Open}"  CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+S"       Command="{x:Static ApplicationCommands.Save}" CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+Shift+W" Command="{x:Static local:MainWindow.WriteToDiskCommand}" />
        <KeyBinding Gesture="Ctrl+W"       Command="{x:Static ApplicationCommands.Close}" CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+Shift+N" Command="{x:Static ApplicationCommands.New}"   CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+F"         Command="{x:Static ApplicationCommands.Find}"              CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+Shift+F"  Command="{x:Static local:MainWindow.AdvancedSearchCommand}" />
        <KeyBinding Key="F3"               Command="{x:Static local:MainWindow.FindNextCommand}" />
        <KeyBinding Gesture="Shift+F3"     Command="{x:Static local:MainWindow.FindPreviousCommand}" />
        <KeyBinding Gesture="Ctrl+G"       Command="{x:Static local:MainWindow.GoToOffsetCommand}" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}"   Executed="OnNewFile" />
        <CommandBinding Command="{x:Static ApplicationCommands.Open}"  Executed="OnOpenFile" />
        <CommandBinding Command="{x:Static ApplicationCommands.Save}"  Executed="OnSave" />
        <CommandBinding Command="{x:Static ApplicationCommands.Close}" Executed="OnCloseActiveDocument" />
        <CommandBinding Command="{x:Static ApplicationCommands.Find}"                 Executed="OnShowAdvancedSearch" />
        <CommandBinding Command="{x:Static local:MainWindow.AdvancedSearchCommand}" Executed="OnShowAdvancedSearchDialog" />
        <CommandBinding Command="{x:Static local:MainWindow.FindNextCommand}"        Executed="OnFindNext" />
        <CommandBinding Command="{x:Static local:MainWindow.FindPreviousCommand}"    Executed="OnFindPrevious" />
        <CommandBinding Command="{x:Static local:MainWindow.WriteToDiskCommand}"  Executed="OnWriteToDisk" />
        <CommandBinding Command="{x:Static local:MainWindow.GoToOffsetCommand}"   Executed="OnGoToOffset" />
    </Window.CommandBindings>
</Window>

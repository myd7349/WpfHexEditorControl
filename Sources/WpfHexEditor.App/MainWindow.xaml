<Window x:Class="WpfHexEditor.App.MainWindow"
        x:Name="ThisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="clr-namespace:WpfHexEditor.Shell;assembly=WpfHexEditor.Shell"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core;assembly=WpfHexEditor.Editor.Core"
        xmlns:local="clr-namespace:WpfHexEditor.App"
        xmlns:appCtrl="clr-namespace:WpfHexEditor.App.Controls"
        xmlns:appModels="clr-namespace:WpfHexEditor.App.Models"
        Title="WpfHexEditor"
        Icon="pack://application:,,,/WpfHexEditor.App;component/Logo.ico"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowDrop="True"
        Drop="OnFileDrop"
        DragOver="OnFileDragOver"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Flat button style for the Plugin InfoBar — keeps the orange banner look on hover/press -->
        <Style x:Key="InfoBarButtonStyle" TargetType="Button">
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderBrush"      Value="White"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Padding"          Value="8,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar (VS Code style: menu inline + title center + window buttons right) -->
        <Border Grid.Row="0" Background="{DynamicResource DockMenuBackgroundBrush}">
            <DockPanel Height="32">
                <!-- Window buttons (right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE949;" Style="{DynamicResource TitleBarButtonStyle}"
                            Click="OnMinimize" ToolTip="Minimize" />
                    <Button x:Name="MaxRestoreButton" Content="&#xE739;"
                            Style="{DynamicResource TitleBarButtonStyle}"
                            Click="OnMaximizeRestore" ToolTip="Maximize" />
                    <Button Content="&#xE106;" Style="{DynamicResource TitleBarCloseButtonStyle}"
                            Click="OnCloseWindow" ToolTip="Close" />
                </StackPanel>

                <!-- Logo (VS2022/VS Code style — far left, click = system menu) -->
                <Image DockPanel.Dock="Left"
                       Source="pack://application:,,,/WpfHexEditor.App;component/Logo.ico"
                       Width="20" Height="20"
                       Margin="8,0,4,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       WindowChrome.IsHitTestVisibleInChrome="True"
                       Cursor="Arrow"
                       MouseLeftButtonDown="OnLogoMouseDown" />

                <!-- Menu (left, inline in title bar) -->
                <Menu x:Name="MainMenuBar" DockPanel.Dock="Left" Style="{DynamicResource DockDarkMenuStyle}"
                      VerticalAlignment="Center"
                      WindowChrome.IsHitTestVisibleInChrome="True">

                    <!-- ═══════════ File ═══════════ -->
                    <MenuItem Header="_File"
                              IsEnabled="{Binding IsMenuEnabled, ElementName=ThisWindow}">

                        <!-- New ► -->
                        <MenuItem Header="_New">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <MenuItem Header="_Solution..." Click="OnNewSolution" InputGestureText="Ctrl+Shift+N">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_Project..." Click="OnNewProject">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="_File..." Click="OnNewFile" InputGestureText="Ctrl+N">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>

                        <!-- Open ► -->
                        <MenuItem Header="_Open">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <MenuItem Header="_Solution/Project..." Click="OnOpenSolutionOrProject" InputGestureText="Ctrl+Shift+O">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="MenuOpenFolder" Header="_Folder..." Click="OnOpenFolder" InputGestureText="Ctrl+Shift+K" IsEnabled="False">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xED41;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_File..." Click="OnOpenFile" InputGestureText="Ctrl+O">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>

                        <Separator />

                        <!-- Close active document -->
                        <MenuItem Header="_Close" Click="OnCloseActiveDocument" InputGestureText="Ctrl+W">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Close _All Documents" Click="OnCloseAllDocuments">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Close _Solution" Click="OnCloseSolution"
                                  IsEnabled="{Binding HasSolution, ElementName=ThisWindow}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <Separator />

                        <!-- Save -->
                        <MenuItem Header="_Save"
                                  Command="{x:Static ApplicationCommands.Save}"
                                  InputGestureText="Ctrl+S">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Save _All" Click="OnSaveAll" InputGestureText="Ctrl+Shift+S">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Write to Disk"
                                  Command="{x:Static local:MainWindow.WriteToDiskCommand}"
                                  InputGestureText="Ctrl+Shift+W">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <Separator />

                        <!-- Recent Solutions ► -->
                        <MenuItem x:Name="RecentSolutionsMenuItem" Header="Recent _Solutions">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <!-- Items populated dynamically -->
                        </MenuItem>

                        <!-- Recent Files ► -->
                        <MenuItem x:Name="RecentFilesMenuItem" Header="Recent _Files">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <!-- Items populated dynamically -->
                        </MenuItem>

                        <Separator />
                        <MenuItem Header="E_xit" Click="OnExit" InputGestureText="Alt+F4">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Edit ═══════════ -->
                    <MenuItem Header="_Edit"
                              IsEnabled="{Binding IsMenuEnabled, ElementName=ThisWindow}">
                        <MenuItem Header="_Undo"
                                  Command="{Binding ActiveDocumentEditor.UndoCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+Z">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Redo"
                                  Command="{Binding ActiveDocumentEditor.RedoCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+Y">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Cu_t"
                                  Command="{Binding ActiveDocumentEditor.CutCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+X">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Copy"
                                  Command="{Binding ActiveDocumentEditor.CopyCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+C">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Paste"
                                  Command="{Binding ActiveDocumentEditor.PasteCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+V">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Delete"
                                  Command="{Binding ActiveDocumentEditor.DeleteCommand, ElementName=ThisWindow}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Select _All"
                                  Command="{Binding ActiveDocumentEditor.SelectAllCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+A">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="_Find..."
                                  Command="{x:Static ApplicationCommands.Find}"
                                  CommandTarget="{Binding ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+F">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Advanced Find / Replace..."
                                  Command="{x:Static local:MainWindow.AdvancedSearchCommand}"
                                  InputGestureText="Ctrl+Shift+F">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Find _Next"
                                  Click="OnFindNext"
                                  InputGestureText="F3" />
                        <MenuItem Header="Find _Previous"
                                  Click="OnFindPrevious"
                                  InputGestureText="Shift+F3" />
                        <Separator />
                        <MenuItem Header="_Go To Offset…" Click="OnGoToOffset" InputGestureText="Ctrl+G">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ View ═══════════ -->
                    <MenuItem Header="_View">
                        <MenuItem Header="_Solution Explorer" Click="OnShowSolutionExplorer" InputGestureText="Ctrl+Alt+L">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Properties" Click="OnShowProperties" InputGestureText="F4">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Output" Click="OnShowOutput">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Error List" Click="OnShowErrorPanel">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Markdown Outline" Click="OnShowMarkdownOutline"
                                  ToolTip="Show Markdown Outline panel (heading navigator)">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8C9;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <!-- Plugin-contributed View menu items are injected here dynamically
                             by each plugin via IUIRegistry.RegisterMenuItem() at load time. -->
                        <Separator/>
                        <MenuItem Header="_Compare Files…" Click="OnCompareFiles" InputGestureText="Ctrl+Alt+D">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE93D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Entropy Analysis…" Click="OnEntropyAnalysis"
                                  ToolTip="Analyse entropy and byte distribution of the active file">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Project ═══════════ (enabled when solution loaded AND no operation active) -->
                    <MenuItem Header="_Project"
                              IsEnabled="{Binding IsProjectMenuEnabled, ElementName=ThisWindow}">
                        <MenuItem Header="Add _New Item..." Click="OnProjectAddNewItem" InputGestureText="Ctrl+Shift+A">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Add E_xisting Item..." Click="OnProjectAddExistingItem" InputGestureText="Shift+Alt+A">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Add New _Project..." Click="OnNewProject">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="P_roperties..." Click="OnProjectProperties">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Build ═══════════ -->
                    <MenuItem Header="_Build"
                              IsEnabled="{Binding IsBuildMenuEnabled, ElementName=ThisWindow}">
                        <MenuItem Header="Build _Solution" Click="OnBuildSolution" InputGestureText="Ctrl+Shift+B">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Build _Project" Click="OnBuildProject" InputGestureText="F7">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="_Rebuild Solution" Click="OnRebuildSolution">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Rebuild _Project" Click="OnRebuildProject">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="_Clean Solution" Click="OnCleanSolution">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Clean _Project" Click="OnCleanProject">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem x:Name="MenuCancelBuild" Header="C_ancel Build" Click="OnCancelBuild"
                                  IsEnabled="{Binding HasActiveBuild, ElementName=ThisWindow}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="_Configuration Manager..." Click="OnOpenConfigManager">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Layout ═══════════ -->
                    <MenuItem Header="_Layout">
                        <MenuItem Header="_Save Layout" Click="OnSaveLayout">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Load Layout" Click="OnLoadLayout">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Reset Layout" Click="OnResetLayout">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Toggle _Locked Layout" Click="OnToggleLock" IsCheckable="True" x:Name="LockMenuItem">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Tools ═══════════ -->
                    <MenuItem Header="_Tools">
                        <MenuItem Header="_Terminal" Click="OnOpenTerminal">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <Separator />

                        <!-- Options -->
                        <MenuItem Header="_Options..." Click="OnSettings">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Plugins ═══════════ -->
                    <MenuItem Header="_Plugins">
                        <MenuItem Header="_Plugin Manager"
                                  Command="{x:Static local:MainWindow.OpenPluginManagerCommand}"
                                  CommandTarget="{Binding ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+Shift+P">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Plugin _Monitor" Click="OnOpenPluginMonitor">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>

                           FontSize="12" IsHitTestVisible="False" />
            </DockPanel>
        </Border>

        <!-- Toolbar — VS2026 pod pattern (7 pods)
             ┌────────────────────────┐ ┌───────────────────────────┐ ┌────────────────┐ ┌──────────────────────────────────┐ ┌──────────────┐ ┌──────────────────┐ ┌────────────────┐
             │  New▾  Open▾  │ 💾 💾All │ │  ↩ Undo  ↪ Redo  │ ✂ ⧉ 📋 │ │  🔍 Find  │ ↓ ↑ │ │  🔍 Explorer  │ ≡  │ ⚙  │ ▪ Output │ │  Layout▾     │ │ [editor actions] │ │ 🔤 TBL▾       │
             └────────────────────────┘ └───────────────────────────┘ └────────────────┘ └──────────────────────────────────┘ └──────────────┘ └──────────────────┘ └────────────────┘
                     Pod File                    Pod Edit                   Pod Find                     Pod View                  Pod Layout      Pod contextuel       Pod TBL        -->
        <ToolBar Grid.Row="1" Style="{DynamicResource DockDarkToolBarStyle}">

            <!-- ── Home ──────────────────────────────────────────────────── -->
            <Border Style="{DynamicResource DockToolBarPodStyle}">
                <Button Click="OnShowWelcome" ToolTip="Welcome Page"
                        Style="{DynamicResource DockDarkToolBarButtonStyle}">
                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center"/>
                </Button>
            </Border>

            <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>

            <!-- ── Pod 1 : File ───────────────────────────────────────────── -->
            <Border Style="{DynamicResource DockToolBarPodStyle}">
                <StackPanel Orientation="Horizontal">

                    <!-- New ▾ : New File / New Project / New Solution -->
                    <Button Click="OnToolBarDropDownClick" ToolTip="New…"
                            Style="{DynamicResource DockToolBarPodDropDownButtonStyle}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="New _File…"     Click="OnNewFile"
                                          InputGestureText="Ctrl+N">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="New _Project…"  Click="OnNewProject">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8F9;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="New _Solution…" Click="OnNewSolution"
                                          InputGestureText="Ctrl+Shift+N">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Open ▾ : Open File / Open Solution or Project -->
                    <Button Click="OnToolBarDropDownClick" ToolTip="Open…"
                            Style="{DynamicResource DockToolBarPodDropDownButtonStyle}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open _File…"              Click="OnOpenFile"
                                          InputGestureText="Ctrl+O">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Open Solution/_Project…"  Click="OnOpenSolutionOrProject"
                                          InputGestureText="Ctrl+Shift+O">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8F9;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Open _Folder…" Click="OnOpenFolder"
                                          InputGestureText="Ctrl+Shift+K">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xED41;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Save — Command binding (auto-enable/disable) -->
                    <Button Command="{x:Static ApplicationCommands.Save}"
                            ToolTip="Save (Ctrl+S)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <!-- Save All -->
                    <Button Click="OnSaveAll" ToolTip="Save All (Ctrl+Shift+S)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                </StackPanel>
            </Border>

            <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>

            <!-- ── Pod 2 : Edit ───────────────────────────────────────────── -->
            <Border Style="{DynamicResource DockToolBarPodStyle}">
                <StackPanel Orientation="Horizontal">

                    <!-- Undo / Redo — Command bindings -->
                    <Button Command="{Binding ActiveDocumentEditor.UndoCommand, ElementName=ThisWindow}"
                            ToolTip="Undo (Ctrl+Z)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding ActiveDocumentEditor.RedoCommand, ElementName=ThisWindow}"
                            ToolTip="Redo (Ctrl+Y)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Cut / Copy / Paste — Command bindings -->
                    <Button Command="{Binding ActiveDocumentEditor.CutCommand, ElementName=ThisWindow}"
                            ToolTip="Cut (Ctrl+X)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding ActiveDocumentEditor.CopyCommand, ElementName=ThisWindow}"
                            ToolTip="Copy (Ctrl+C)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding ActiveDocumentEditor.PasteCommand, ElementName=ThisWindow}"
                            ToolTip="Paste (Ctrl+V)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                </StackPanel>
            </Border>

            <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>

            <!-- ── Pod 3 : Find ───────────────────────────────────────────── -->
            <Border Style="{DynamicResource DockToolBarPodStyle}">
                <StackPanel Orientation="Horizontal">

                    <!-- Find — icon + label -->
                    <Button Click="OnShowAdvancedSearch" ToolTip="Find… (Ctrl+F)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Find" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Find Next (F3) -->
                    <Button Click="OnFindNext" ToolTip="Find Next (F3)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <!-- Find Previous (Shift+F3) -->
                    <Button Click="OnFindPrevious" ToolTip="Find Previous (Shift+F3)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Button>

                </StackPanel>
            </Border>

            <!-- ── Pod 4 : View (panneaux) ────────────────────────────────── -->
            <Border Style="{DynamicResource DockToolBarPodStyle}">
                <StackPanel Orientation="Horizontal">

                    <!-- Solution Explorer : icon + label -->
                    <Button Click="OnShowSolutionExplorer" ToolTip="Solution Explorer (Ctrl+Alt+L)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Explorer" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Parsed Fields -->
                    <Button Click="OnShowParsedFields" ToolTip="Parsed Fields"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xEBD2;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Properties -->
                    <Button Click="OnShowProperties" ToolTip="Properties (F4)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>

                    <!-- Output -->
                    <Button Click="OnShowOutput" ToolTip="Output"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                        <TextBlock Text="&#xE9A8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>

                </StackPanel>
            </Border>

            <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>

            <!-- Sep844: visible only when at least one trailing pod (contextuel or TBL) is shown -->
            <Border Background="Transparent" Padding="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ActiveToolbarContributor, ElementName=ThisWindow}"
                                               Value="{x:Null}"/>
                                    <Condition Binding="{Binding ActiveHexEditor, ElementName=ThisWindow}"
                                               Value="{x:Null}"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>
            </Border>

            <!-- ── Pod contextuel — visible seulement quand un éditeur contribue ─── -->
            <Border>
                <Border.Style>
                    <Style BasedOn="{StaticResource DockToolBarPodStyle}" TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveToolbarContributor, ElementName=ThisWindow}"
                                         Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ItemsControl ItemsSource="{Binding ActiveToolbarContributor.ToolbarItems, ElementName=ThisWindow}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplateSelector>
                        <appCtrl:EditorToolbarItemTemplateSelector>
                            <!-- Separator -->
                            <appCtrl:EditorToolbarItemTemplateSelector.SeparatorTemplate>
                                <DataTemplate DataType="{x:Type ec:EditorToolbarItem}">
                                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>
                                </DataTemplate>
                            </appCtrl:EditorToolbarItemTemplateSelector.SeparatorTemplate>
                            <!-- Plain button -->
                            <appCtrl:EditorToolbarItemTemplateSelector.ButtonTemplate>
                                <DataTemplate DataType="{x:Type ec:EditorToolbarItem}">
                                    <Button Command="{Binding Command}"
                                            IsEnabled="{Binding IsEnabled}"
                                            ToolTip="{Binding Tooltip}"
                                            Style="{DynamicResource DockDarkToolBarButtonStyle}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Label}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </appCtrl:EditorToolbarItemTemplateSelector.ButtonTemplate>
                            <!-- Toggle button — renders as ToggleButton with checked visual state -->
                            <appCtrl:EditorToolbarItemTemplateSelector.ToggleTemplate>
                                <DataTemplate DataType="{x:Type ec:EditorToolbarItem}">
                                    <ToggleButton IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  Command="{Binding Command}"
                                                  IsEnabled="{Binding IsEnabled}"
                                                  ToolTip="{Binding Tooltip}"
                                                  Style="{DynamicResource DockDarkToolBarToggleButtonStyle}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Label}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                </DataTemplate>
                            </appCtrl:EditorToolbarItemTemplateSelector.ToggleTemplate>
                            <!-- Dropdown button: uses DockToolBarPodDropDownButtonStyle which adds ▾ automatically.
                                 Left-click opens the ContextMenu via OnToolBarDropDownClick handler.
                                 ContextMenu supports icons (via ItemTemplate) and IsSeparator (via ItemContainerStyle). -->
                            <appCtrl:EditorToolbarItemTemplateSelector.DropdownTemplate>
                                <DataTemplate DataType="{x:Type ec:EditorToolbarItem}">
                                    <Button Click="OnToolBarDropDownClick"
                                            IsEnabled="{Binding IsEnabled}"
                                            ToolTip="{Binding Tooltip}"
                                            Style="{DynamicResource DockToolBarPodDropDownButtonStyle}">
                                        <Button.ContextMenu>
                                            <ContextMenu ItemsSource="{Binding DropdownItems}">
                                                <!-- Icon + label in the menu item header -->
                                                <ContextMenu.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type ec:EditorToolbarItem}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Icon}"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="11"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding Label}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ContextMenu.ItemTemplate>
                                                <!-- Command wiring + IsSeparator support -->
                                                <ContextMenu.ItemContainerStyle>
                                                    <Style TargetType="MenuItem">
                                                        <Setter Property="Command" Value="{Binding Command}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="MenuItem">
                                                                            <Separator/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContextMenu.ItemContainerStyle>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <!-- Content: icon + label (chevron ▾ added by DockToolBarPodDropDownButtonStyle) -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Label}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </appCtrl:EditorToolbarItemTemplateSelector.DropdownTemplate>
                        </appCtrl:EditorToolbarItemTemplateSelector>
                    </ItemsControl.ItemTemplateSelector>
                </ItemsControl>
            </Border>

            <!-- Sep927: visible only when both contextuel pod AND TBL pod are shown -->
            <Border Background="Transparent" Padding="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveToolbarContributor, ElementName=ThisWindow}"
                                         Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ActiveHexEditor, ElementName=ThisWindow}"
                                         Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>
            </Border>

            <!-- ── Pod TBL : sélecteur de table (visible uniquement si HexEditor actif) ── -->
            <Border>
                <Border.Style>
                    <Style BasedOn="{StaticResource DockToolBarPodStyle}" TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveHexEditor, ElementName=ThisWindow}"
                                         Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <!-- Table icon -->
                    <TextBlock Text="&#xE8C1;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="4,0,4,0"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               ToolTip="Character Table"/>
                    <!-- TBL ComboBox -->
                    <ComboBox Width="180" VerticalAlignment="Center"
                              ItemsSource="{Binding TblItems, ElementName=ThisWindow}"
                              SelectedItem="{Binding SelectedTblItem, ElementName=ThisWindow, Mode=TwoWay}"
                              ToolTip="Active character table"
                              Background="Transparent"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              IsTextSearchEnabled="False">
                        <!-- ItemTemplate = used for the selection box (closed state).
                             ItemTemplateSelector = used for the popup dropdown items only.
                             WPF ignores ItemTemplateSelector for the selection box and uses ItemTemplate. -->
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type appModels:TblSelectionItem}">
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Style.Triggers>
                                    <!-- Headers: not focusable/clickable but visually ENABLED
                                         (IsEnabled stays True) so the bold text renders with full
                                         color in any theme — no graying. -->
                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                        <Setter Property="Focusable"        Value="False"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                        <Setter Property="Padding"          Value="0"/>
                                    </DataTrigger>
                                    <!-- Separators: disabled (grayed is fine for a pure visual line) -->
                                    <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                        <Setter Property="IsEnabled"        Value="False"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                        <Setter Property="Padding"          Value="0"/>
                                        <Setter Property="MinHeight"        Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBox.ItemTemplateSelector>
                            <appCtrl:TblItemTemplateSelector>
                                <appCtrl:TblItemTemplateSelector.HeaderTemplate>
                                    <DataTemplate DataType="{x:Type appModels:TblSelectionItem}">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="Bold" FontSize="11"
                                                   Foreground="{DynamicResource SE_GroupHeaderBrush}"
                                                   IsHitTestVisible="False"
                                                   Padding="4,5,0,2"/>
                                    </DataTemplate>
                                </appCtrl:TblItemTemplateSelector.HeaderTemplate>
                                <appCtrl:TblItemTemplateSelector.SeparatorTemplate>
                                    <DataTemplate DataType="{x:Type appModels:TblSelectionItem}">
                                        <Separator Margin="4,2" IsHitTestVisible="False"/>
                                    </DataTemplate>
                                </appCtrl:TblItemTemplateSelector.SeparatorTemplate>
                                <appCtrl:TblItemTemplateSelector.ItemTemplate>
                                    <DataTemplate DataType="{x:Type appModels:TblSelectionItem}">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                   Padding="4,2"/>
                                    </DataTemplate>
                                </appCtrl:TblItemTemplateSelector.ItemTemplate>
                            </appCtrl:TblItemTemplateSelector>
                        </ComboBox.ItemTemplateSelector>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- ── Pod 8 : Build (permanent — always visible) ──────────────── -->
            <Separator Style="{DynamicResource DockDarkToolBarSeparatorStyle}"/>
            <Border Style="{DynamicResource DockToolBarPodStyle}">
                <StackPanel Orientation="Horizontal">
                    <!-- Configuration ComboBox -->
                    <ComboBox x:Name="CbBuildConfig"
                              Width="100" Margin="2,0" VerticalAlignment="Center"
                              ToolTip="Build Configuration"
                              ItemsSource="{Binding BuildConfigurations, ElementName=ThisWindow}"
                              SelectedItem="{Binding ActiveBuildConfiguration, ElementName=ThisWindow, Mode=TwoWay}"
                              Background="Transparent"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <!-- Platform ComboBox -->
                    <ComboBox x:Name="CbBuildPlatform"
                              Width="80" Margin="2,0" VerticalAlignment="Center"
                              ToolTip="Target Platform"
                              ItemsSource="{Binding BuildPlatforms, ElementName=ThisWindow}"
                              SelectedItem="{Binding ActiveBuildPlatform, ElementName=ThisWindow, Mode=TwoWay}"
                              Background="Transparent"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                    <!-- Startup project selector -->
                    <ComboBox x:Name="CbStartupProject"
                              Width="160" Margin="2,0" VerticalAlignment="Center"
                              ToolTip="Startup Project — launched by ▶ Start (Ctrl+F5)"
                              ItemsSource="{Binding StartupProjectNames, ElementName=ThisWindow}"
                              SelectedItem="{Binding ActiveStartupProjectName, ElementName=ThisWindow, Mode=TwoWay}"
                              IsEnabled="{Binding HasSolution, ElementName=ThisWindow}"
                              Background="Transparent"
                              Foreground="{DynamicResource DockMenuForegroundBrush}"
                              SelectionChanged="OnStartupProjectSelectionChanged">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}" />
                                <Setter Property="Padding"    Value="6,3" />
                                <Style.Triggers>
                                    <!-- Sentinel: custom template with separator line above + italic text -->
                                    <DataTrigger Binding="{Binding}" Value="⚙ Configure startup projects…">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBoxItem">
                                                    <StackPanel>
                                                        <Rectangle Height="1"
                                                                   Fill="{DynamicResource DockBorderBrush}"
                                                                   Margin="4,2,4,0" />
                                                        <Border x:Name="Bd"
                                                                Background="Transparent"
                                                                Padding="6,4">
                                                            <TextBlock Text="{TemplateBinding Content}"
                                                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                                                       FontStyle="Italic" />
                                                        </Border>
                                                    </StackPanel>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background"
                                                                    Value="{DynamicResource DockAccentBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DockAccentBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DockAccentBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>
                    <!-- Start (Run startup project without debugger — Ctrl+F5) -->
                    <Button x:Name="BtnRunStartup"
                            Click="OnRunStartupProject"
                            ToolTip="Start Without Debugging (Ctrl+F5)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}"
                            IsEnabled="{Binding CanRunStartupProject, ElementName=ThisWindow}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="#3CB371"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="Start" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Separator Style="{DynamicResource DockToolBarPodDividerStyle}"/>
                    <!-- Build -->
                    <Button x:Name="BtnBuild"
                            Click="OnBuildSolution"
                            ToolTip="Build Solution (Ctrl+Shift+B)"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}"
                            IsEnabled="{Binding IsBuildMenuEnabled, ElementName=ThisWindow}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="Build" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <!-- Rebuild -->
                    <Button x:Name="BtnRebuild"
                            Click="OnRebuildSolution"
                            ToolTip="Rebuild Solution"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}"
                            IsEnabled="{Binding IsBuildMenuEnabled, ElementName=ThisWindow}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="Rebuild" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <!-- Clean -->
                    <Button x:Name="BtnClean"
                            Click="OnCleanSolution"
                            ToolTip="Clean Solution"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}"
                            IsEnabled="{Binding IsBuildMenuEnabled, ElementName=ThisWindow}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="Clean" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <!-- Cancel -->
                    <Button x:Name="BtnStopBuild"
                            Click="OnCancelBuild"
                            ToolTip="Cancel Build"
                            Style="{DynamicResource DockDarkToolBarButtonStyle}"
                            IsEnabled="{Binding HasActiveBuild, ElementName=ThisWindow}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="Stop" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

        </ToolBar>

        <!-- Main Dock Area + Plugin InfoBar wrapper -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Plugin InfoBar — shown when a plugin is slow or has faulted (VS-style notification) -->
            <Border x:Name="PluginInfoBar" Grid.Row="0" Visibility="Collapsed"
                    Background="{DynamicResource PM_BadgeSlowBrush}" Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE7BA;"
                               FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="White" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="PluginInfoBarMessage" Grid.Column="1"
                               Text="" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" TextWrapping="NoWrap"/>
                    <Button x:Name="PluginInfoBarDisable" Grid.Column="2"
                            Content="Disable" Margin="8,0,4,0"
                            Click="OnPluginInfoBarDisable"
                            Style="{StaticResource InfoBarButtonStyle}"
                            Visibility="Collapsed"/>
                    <Button x:Name="PluginInfoBarRestart" Grid.Column="3"
                            Content="Restart" Margin="4,0"
                            Click="OnPluginInfoBarRestart"
                            Style="{StaticResource InfoBarButtonStyle}"
                            Visibility="Collapsed"/>
                    <Button x:Name="PluginInfoBarIgnore" Grid.Column="4"
                            Content="Ignore" Margin="4,0"
                            Click="OnPluginInfoBarIgnore"
                            Style="{StaticResource InfoBarButtonStyle}"
                            Visibility="Collapsed"/>
                    <Button Grid.Column="5" Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Margin="8,0,0,0"
                            Click="OnPluginInfoBarClose"
                            Style="{StaticResource InfoBarButtonStyle}"
                            BorderBrush="Transparent"
                            ToolTip="Dismiss"/>
                </Grid>
            </Border>

            <!-- File-Change InfoBar — shown when the active file is modified by an external process -->
            <Border x:Name="FileChangeInfoBar" Grid.Row="0" Visibility="Collapsed"
                    Background="{DynamicResource PM_BadgeSlowBrush}" Padding="8,5"
                    Margin="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Segoe MDL2 "Page" glyph -->
                    <TextBlock Grid.Column="0" Text="&#xE7C3;"
                               FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="White" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="FileChangeInfoBarMessage" Grid.Column="1"
                               Text="" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" TextWrapping="NoWrap"/>
                    <Button x:Name="FileChangeInfoBarReload" Grid.Column="2"
                            Content="Reload" Margin="8,0,4,0"
                            Click="OnFileChangeInfoBarReload"
                            Style="{StaticResource InfoBarButtonStyle}"/>
                    <Button x:Name="FileChangeInfoBarKeep" Grid.Column="3"
                            Content="Keep my edits" Margin="4,0"
                            Click="OnFileChangeInfoBarKeep"
                            Style="{StaticResource InfoBarButtonStyle}"
                            Visibility="Collapsed"/>
                    <Button Grid.Column="4" Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Margin="8,0,0,0"
                            Click="OnFileChangeInfoBarClose"
                            Style="{StaticResource InfoBarButtonStyle}"
                            BorderBrush="Transparent"
                            ToolTip="Dismiss"/>
                </Grid>
            </Border>

            <dock:DockControl Grid.Row="1" x:Name="DockHost" Margin="2" />
        </Grid>

        <!-- Status Bar — VS2022-style: adapts to the active document -->
        <StatusBar x:Name="AppStatusBar" Grid.Row="3" Background="{DynamicResource DockTabActiveBrush}">

            <!-- Active editor interactive items (IStatusBarContributor) -->
            <StatusBarItem>
                <ItemsControl ItemsSource="{Binding ActiveStatusBarContributor.StatusBarItems, ElementName=ThisWindow}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type ec:StatusBarItem}">
                            <!-- Border instead of Button: avoids WPF StatusBar click-absorption quirk -->
                            <Border Padding="6,2"
                                    Cursor="Hand"
                                    ToolTip="{Binding Tooltip}"
                                    MouseLeftButtonDown="StatusBarItem_MouseLeftButtonDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Foreground="{DynamicResource DockTabActiveTextBrush}" VerticalAlignment="Center">
                                    <Run Text="{Binding Label, Mode=OneWay}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding Value, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                                <Border.ContextMenu>
                                    <ContextMenu ItemsSource="{Binding Choices}">
                                        <ContextMenu.ItemContainerStyle>
                                            <Style TargetType="MenuItem" BasedOn="{StaticResource DockDarkMenuItemStyle}">
                                                <Setter Property="Header"    Value="{Binding DisplayName}"/>
                                                <Setter Property="Command"   Value="{Binding Command}"/>
                                                <Setter Property="IsChecked" Value="{Binding IsActive}"/>
                                            </Style>
                                        </ContextMenu.ItemContainerStyle>
                                    </ContextMenu>
                                </Border.ContextMenu>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StatusBarItem>

            <!-- Centre : progression des opérations longues (visible uniquement pendant une opération) -->
            <StatusBarItem x:Name="ProgressStatusItem" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ProgressTitleText"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               FontWeight="SemiBold" Margin="8,0,8,0"
                               VerticalAlignment="Center"/>
                    <ProgressBar x:Name="AppProgressBar"
                                 Width="160" Height="10" Minimum="0" Maximum="100"
                                 VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProgressPercentText"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               Margin="6,0,8,0" MinWidth="32"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProgressMessageText"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <Button x:Name="ProgressCancelButton"
                            Content="✕"
                            ToolTip="Cancel operation"
                            Click="OnProgressCancel"
                            Visibility="Collapsed"
                            Padding="6,1"
                            Style="{DynamicResource DockDarkButtonStyle}"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>

            <!-- Build status indicator -->
            <StatusBarItem x:Name="BuildStatusItem" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="BuildStatusIcon" Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               VerticalAlignment="Center" Margin="4,0,4,0"/>
                    <TextBlock x:Name="BuildStatusText"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                </StackPanel>
            </StatusBarItem>

            <!-- Right-aligned group: Refresh time + Plugin status -->
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <!-- Refresh time (from active HexEditor) -->
                    <StackPanel x:Name="RefreshTimeStatusItem" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock x:Name="RefreshTimeText" Text="" 
                                   FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource DockTabActiveTextBrush}"
                                   Margin="0,0,12,0"/>
                    </StackPanel>

                    <!-- Plugin warning badge (visible only when a plugin faults) -->
                    <Border x:Name="PluginWarningBadge" Background="{DynamicResource PM_BadgeFaultedBrush}" CornerRadius="8"
                            Padding="4,1" Margin="0,0,8,0" VerticalAlignment="Center"
                            Cursor="Hand" Visibility="Collapsed"
                            MouseLeftButtonDown="OnPluginStatusBarClick">
                        <TextBlock x:Name="PluginWarningText" Text="" FontSize="10" Foreground="White"/>
                    </Border>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>

    <!-- Keyboard shortcuts -->
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N"       Command="{x:Static ApplicationCommands.New}"   CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+O"       Command="{x:Static ApplicationCommands.Open}"  CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+S"       Command="{x:Static ApplicationCommands.Save}" CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+Shift+W" Command="{x:Static local:MainWindow.WriteToDiskCommand}" />
        <KeyBinding Gesture="Ctrl+W"       Command="{x:Static ApplicationCommands.Close}" CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+Shift+N" Command="{x:Static ApplicationCommands.New}"   CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+F"         Command="{x:Static ApplicationCommands.Find}"              CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+Shift+F"  Command="{x:Static local:MainWindow.AdvancedSearchCommand}" />
        <KeyBinding Key="F3"               Command="{x:Static local:MainWindow.FindNextCommand}" />
        <KeyBinding Gesture="Shift+F3"     Command="{x:Static local:MainWindow.FindPreviousCommand}" />
        <KeyBinding Gesture="Ctrl+G"       Command="{x:Static local:MainWindow.GoToOffsetCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+P" Command="{x:Static local:MainWindow.OpenPluginManagerCommand}" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}"   Executed="OnNewFile" />
        <CommandBinding Command="{x:Static ApplicationCommands.Open}"  Executed="OnOpenFile" />
        <CommandBinding Command="{x:Static ApplicationCommands.Save}"  Executed="OnSave" />
        <CommandBinding Command="{x:Static ApplicationCommands.Close}" Executed="OnCloseActiveDocument" />
        <CommandBinding Command="{x:Static ApplicationCommands.Find}"                 Executed="OnShowAdvancedSearch" />
        <CommandBinding Command="{x:Static local:MainWindow.AdvancedSearchCommand}" Executed="OnShowAdvancedSearchDialog" />
        <CommandBinding Command="{x:Static local:MainWindow.FindNextCommand}"        Executed="OnFindNext" />
        <CommandBinding Command="{x:Static local:MainWindow.FindPreviousCommand}"    Executed="OnFindPrevious" />
        <CommandBinding Command="{x:Static local:MainWindow.WriteToDiskCommand}"  Executed="OnWriteToDisk" />
        <CommandBinding Command="{x:Static local:MainWindow.GoToOffsetCommand}"   Executed="OnGoToOffset" />
        <CommandBinding Command="{x:Static local:MainWindow.OpenPluginManagerCommand}" Executed="OnOpenPluginManager" />
    </Window.CommandBindings>
</Window>

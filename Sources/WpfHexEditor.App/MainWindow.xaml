<Window x:Class="WpfHexEditor.App.MainWindow"
        x:Name="ThisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="clr-namespace:WpfHexEditor.Docking.Wpf;assembly=WpfHexEditor.Docking.Wpf"
        xmlns:ec="clr-namespace:WpfHexEditor.Editor.Core;assembly=WpfHexEditor.Editor.Core"
        Title="WpfHexEditor"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource DockWindowBackgroundBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar (VS Code style: menu inline + title center + window buttons right) -->
        <Border Grid.Row="0" Background="{DynamicResource DockMenuBackgroundBrush}">
            <DockPanel Height="32">
                <!-- Window buttons (right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE949;" Style="{DynamicResource TitleBarButtonStyle}"
                            Click="OnMinimize" ToolTip="Minimize" />
                    <Button x:Name="MaxRestoreButton" Content="&#xE739;"
                            Style="{DynamicResource TitleBarButtonStyle}"
                            Click="OnMaximizeRestore" ToolTip="Maximize" />
                    <Button Content="&#xE106;" Style="{DynamicResource TitleBarCloseButtonStyle}"
                            Click="OnCloseWindow" ToolTip="Close" />
                </StackPanel>

                <!-- Menu (left, inline in title bar) -->
                <Menu DockPanel.Dock="Left" Style="{DynamicResource DockDarkMenuStyle}"
                      VerticalAlignment="Center"
                      WindowChrome.IsHitTestVisibleInChrome="True">

                    <!-- ═══════════ File ═══════════ -->
                    <MenuItem Header="_File" Style="{DynamicResource DockDarkMenuItemStyle}"
                              IsEnabled="{Binding IsMenuEnabled, ElementName=ThisWindow}">

                        <!-- New ► -->
                        <MenuItem Header="_New" Style="{DynamicResource DockDarkMenuItemStyle}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <MenuItem Header="_Solution..." Click="OnNewSolution" InputGestureText="Ctrl+Shift+N">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_Project..." Click="OnNewProject">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator Style="{DynamicResource DockDarkMenuSeparatorStyle}" />
                            <MenuItem Header="_File..." Click="OnNewFile" InputGestureText="Ctrl+N">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>

                        <!-- Open ► -->
                        <MenuItem Header="_Open" Style="{DynamicResource DockDarkMenuItemStyle}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <MenuItem Header="_Solution/Project..." Click="OnOpenSolutionOrProject" InputGestureText="Ctrl+Shift+O">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_File..." Click="OnOpenFile" InputGestureText="Ctrl+O">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>

                        <Separator Style="{DynamicResource DockDarkMenuSeparatorStyle}" />

                        <!-- Close active document -->
                        <MenuItem Header="_Close" Click="OnCloseActiveDocument" InputGestureText="Ctrl+W">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Close _All Documents" Click="OnCloseAllDocuments">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Close _Solution" Click="OnCloseSolution"
                                  IsEnabled="{Binding HasSolution, ElementName=ThisWindow}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <Separator Style="{DynamicResource DockDarkMenuSeparatorStyle}" />

                        <!-- Save -->
                        <MenuItem Header="_Save"
                                  Command="{Binding ActiveDocumentEditor.SaveCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+S">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Save _All" Click="OnSaveAll" InputGestureText="Ctrl+Shift+S">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <Separator Style="{DynamicResource DockDarkMenuSeparatorStyle}" />

                        <!-- Recent Solutions ► -->
                        <MenuItem x:Name="RecentSolutionsMenuItem" Header="Recent _Solutions"
                                  Style="{DynamicResource DockDarkMenuItemStyle}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <!-- Items populated dynamically -->
                        </MenuItem>

                        <!-- Recent Files ► -->
                        <MenuItem x:Name="RecentFilesMenuItem" Header="Recent _Files"
                                  Style="{DynamicResource DockDarkMenuItemStyle}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                            <!-- Items populated dynamically -->
                        </MenuItem>

                        <Separator Style="{DynamicResource DockDarkMenuSeparatorStyle}" />
                        <MenuItem Header="E_xit" Click="OnExit" InputGestureText="Alt+F4">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Edit ═══════════ -->
                    <MenuItem Header="_Edit" Style="{DynamicResource DockDarkMenuItemStyle}"
                              IsEnabled="{Binding IsMenuEnabled, ElementName=ThisWindow}">
                        <MenuItem Header="_Undo"
                                  Command="{Binding ActiveDocumentEditor.UndoCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+Z">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Redo"
                                  Command="{Binding ActiveDocumentEditor.RedoCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+Y">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{DynamicResource DockDarkMenuSeparatorStyle}" />
                        <MenuItem Header="Cu_t"
                                  Command="{Binding ActiveDocumentEditor.CutCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+X">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Copy"
                                  Command="{Binding ActiveDocumentEditor.CopyCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+C">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Paste"
                                  Command="{Binding ActiveDocumentEditor.PasteCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+V">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Delete"
                                  Command="{Binding ActiveDocumentEditor.DeleteCommand, ElementName=ThisWindow}">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{DynamicResource DockDarkMenuSeparatorStyle}" />
                        <MenuItem Header="Select _All"
                                  Command="{Binding ActiveDocumentEditor.SelectAllCommand, ElementName=ThisWindow}"
                                  InputGestureText="Ctrl+A">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ View ═══════════ -->
                    <MenuItem Header="_View" Style="{DynamicResource DockDarkMenuItemStyle}">
                        <MenuItem Header="_Solution Explorer" Click="OnShowSolutionExplorer" InputGestureText="Ctrl+Alt+L">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Parsed Fields" Click="OnShowParsedFields">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Properties" Click="OnShowProperties" InputGestureText="F4">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Output" Click="OnShowOutput">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Project ═══════════ (enabled when solution loaded AND no operation active) -->
                    <MenuItem Header="_Project" Style="{DynamicResource DockDarkMenuItemStyle}"
                              IsEnabled="{Binding IsProjectMenuEnabled, ElementName=ThisWindow}">
                        <MenuItem Header="Add _New Item..." Click="OnProjectAddNewItem" InputGestureText="Ctrl+Shift+A">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Add E_xisting Item..." Click="OnProjectAddExistingItem" InputGestureText="Shift+Alt+A">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{DynamicResource DockDarkMenuSeparatorStyle}" />
                        <MenuItem Header="Add New _Project..." Click="OnNewProject">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{DynamicResource DockDarkMenuSeparatorStyle}" />
                        <MenuItem Header="P_roperties..." Click="OnProjectProperties">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Layout ═══════════ -->
                    <MenuItem Header="_Layout" Style="{DynamicResource DockDarkMenuItemStyle}">
                        <MenuItem Header="_Save Layout" Click="OnSaveLayout">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Load Layout" Click="OnLoadLayout">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Reset Layout" Click="OnResetLayout">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{DynamicResource DockDarkMenuSeparatorStyle}" />
                        <MenuItem Header="Toggle _Locked Layout" Click="OnToggleLock" IsCheckable="True" x:Name="LockMenuItem">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <!-- ═══════════ Theme ═══════════ -->
                    <MenuItem Header="_Theme" Style="{DynamicResource DockDarkMenuItemStyle}">
                        <MenuItem Header="_Dark" Click="OnDarkTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE708;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Light" Click="OnLightTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="VS2022 Dar_k" Click="OnVS2022DarkTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Dark _Glass" Click="OnDarkGlassTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Visual Studio" Click="OnVisualStudioTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Cyberpunk" Click="OnCyberpunkTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator Style="{DynamicResource DockDarkMenuSeparatorStyle}" />
                        <MenuItem Header="_Minimal" Click="OnMinimalTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="_Office" Click="OnOfficeTheme">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </Menu>

                <!-- Title (center, fills remaining space) -->
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource DockMenuForegroundBrush}"
                           FontSize="12" IsHitTestVisible="False" />
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <ToolBar Grid.Row="1" Style="{DynamicResource DockDarkToolBarStyle}">
            <Button Content="+ Hex Editor" Click="OnNewFile" ToolTip="New hex file" Style="{DynamicResource DockDarkToolBarButtonStyle}" />
            <Button Content="&#xE8E5; Open" Click="OnOpenFile" ToolTip="Open file" Style="{DynamicResource DockDarkToolBarButtonStyle}"
                    FontFamily="Segoe MDL2 Assets, Segoe UI" />
            <Separator />
            <Button Content="Solution Explorer" Click="OnShowSolutionExplorer" Style="{DynamicResource DockDarkToolBarButtonStyle}" />
            <Button Content="Parsed Fields" Click="OnShowParsedFields" Style="{DynamicResource DockDarkToolBarButtonStyle}" />
            <Button Content="Properties" Click="OnShowProperties" Style="{DynamicResource DockDarkToolBarButtonStyle}" />
            <Button Content="Output" Click="OnShowOutput" Style="{DynamicResource DockDarkToolBarButtonStyle}" />
            <Separator />
            <Button Content="Save Layout" Click="OnSaveLayout" Style="{DynamicResource DockDarkToolBarButtonStyle}" />
            <Button Content="Load Layout" Click="OnLoadLayout" Style="{DynamicResource DockDarkToolBarButtonStyle}" />
        </ToolBar>

        <!-- Main Dock Area -->
        <dock:DockControl Grid.Row="2" x:Name="DockHost" Margin="2" />

        <!-- Status Bar — VS2022-style: adapts to the active document -->
        <StatusBar Grid.Row="3" Background="{DynamicResource DockTabActiveBrush}">

            <!-- Active editor interactive items (IStatusBarContributor) -->
            <StatusBarItem>
                <ItemsControl ItemsSource="{Binding ActiveStatusBarContributor.StatusBarItems, ElementName=ThisWindow}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type ec:StatusBarItem}">
                            <!-- Border instead of Button: avoids WPF StatusBar click-absorption quirk -->
                            <Border Padding="6,2"
                                    Cursor="Hand"
                                    ToolTip="{Binding Tooltip}"
                                    MouseLeftButtonDown="StatusBarItem_MouseLeftButtonDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Foreground="{DynamicResource DockTabActiveTextBrush}" VerticalAlignment="Center">
                                    <Run Text="{Binding Label, Mode=OneWay}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding Value, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                                <Border.ContextMenu>
                                    <ContextMenu Style="{DynamicResource DockDarkContextMenuStyle}"
                                                 ItemsSource="{Binding Choices}">
                                        <ContextMenu.ItemContainerStyle>
                                            <Style TargetType="MenuItem" BasedOn="{StaticResource DockDarkMenuItemStyle}">
                                                <Setter Property="Header"    Value="{Binding DisplayName}"/>
                                                <Setter Property="Command"   Value="{Binding Command}"/>
                                                <Setter Property="IsChecked" Value="{Binding IsActive}"/>
                                            </Style>
                                        </ContextMenu.ItemContainerStyle>
                                    </ContextMenu>
                                </Border.ContextMenu>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StatusBarItem>

            <!-- Centre : progression des opérations longues (visible uniquement pendant une opération) -->
            <StatusBarItem x:Name="ProgressStatusItem" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ProgressTitleText"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               FontWeight="SemiBold" Margin="8,0,8,0"
                               VerticalAlignment="Center"/>
                    <ProgressBar x:Name="AppProgressBar"
                                 Width="160" Height="10" Minimum="0" Maximum="100"
                                 VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProgressPercentText"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               Margin="6,0,8,0" MinWidth="32"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProgressMessageText"
                               Foreground="{DynamicResource DockTabActiveTextBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <Button x:Name="ProgressCancelButton"
                            Content="✕"
                            ToolTip="Annuler l'opération"
                            Click="OnProgressCancel"
                            Visibility="Collapsed"
                            Padding="6,1"
                            Style="{DynamicResource DockDarkButtonStyle}"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>

            <!-- Right: solution name + refresh time + panel count -->
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="SolutionText" Text="" Foreground="{DynamicResource DockTabActiveTextBrush}" Margin="0,0,12,0"/>
                    <TextBlock x:Name="RefreshText" Text="" Foreground="{DynamicResource DockTabActiveTextBrush}" Margin="0,0,12,0"/>
                    <TextBlock x:Name="PanelCountText" Text="Panels: 0" Foreground="{DynamicResource DockTabActiveTextBrush}" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>

    <!-- Keyboard shortcuts -->
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N"       Command="{x:Static ApplicationCommands.New}"   CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+O"       Command="{x:Static ApplicationCommands.Open}"  CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+S"       Command="{Binding ActiveDocumentEditor.SaveCommand, ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+W"       Command="{x:Static ApplicationCommands.Close}" CommandTarget="{Binding ElementName=ThisWindow}" />
        <KeyBinding Gesture="Ctrl+Shift+N" Command="{x:Static ApplicationCommands.New}"   CommandTarget="{Binding ElementName=ThisWindow}" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}"   Executed="OnNewFile" />
        <CommandBinding Command="{x:Static ApplicationCommands.Open}"  Executed="OnOpenFile" />
        <CommandBinding Command="{x:Static ApplicationCommands.Close}" Executed="OnCloseActiveDocument" />
    </Window.CommandBindings>
</Window>

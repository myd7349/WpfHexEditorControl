<!--
    Project: WpfHexEditor.PluginHost
    File: UI/Options/IDEEventBusOptionsPage.xaml
    Author: Derek Tremblay (derektremblay666@gmail.com)
    Contributors: Claude Sonnet 4.6
    Created: 2026-03-15
    Description:
        Options page for the IDE EventBus. Displays rolling event log (last 100 entries),
        subscriber count table per event type, and a Clear Log button.
        Registered in the IDE Options dialog under "Plugin System / Event Bus".
    Theme: DynamicResource only — PFP_* tokens from Colors.xaml (all 8 themes).
-->
<UserControl x:Class="WpfHexEditor.PluginHost.UI.Options.IDEEventBusOptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource PFP_TextBrush}">

    <UserControl.Resources>
        <!-- Themed toolbar button — overrides hover/pressed system colours -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background"        Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
            <Setter Property="Foreground"        Value="{DynamicResource PFP_TextBrush}"/>
            <Setter Property="BorderBrush"       Value="{DynamicResource PFP_BorderBrush}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PFP_BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DockAccentBrush}"/>
                                <Setter Property="Foreground"                  Value="{DynamicResource DockMenuForegroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- ── Section: Subscriber Counts ────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">

            <TextBlock Text="Registered Event Types"
                       FontWeight="SemiBold" FontSize="13"
                       Foreground="{DynamicResource PFP_TextBrush}"
                       Margin="0,0,0,8"/>

            <Border Background="{DynamicResource PFP_SectionBackgroundBrush}"
                    BorderBrush="{DynamicResource PFP_BorderBrush}"
                    BorderThickness="1" CornerRadius="4"
                    Margin="0,0,0,12">
                <ListView x:Name="SubscriberListView"
                          MaxHeight="180"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="{DynamicResource PFP_TextBrush}">
                    <ListView.Resources>
                        <!-- Theme-compliant GridViewColumnHeader — replaces the default system style -->
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Background"   Value="{DynamicResource PFP_SectionBackgroundBrush}"/>
                            <Setter Property="Foreground"   Value="{DynamicResource PFP_TextBrush}"/>
                            <Setter Property="BorderBrush"  Value="{DynamicResource PFP_BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Padding"      Value="8,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridViewColumnHeader">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="Center"
                                                              RecognizesAccessKey="True"
                                                              SnapsToDevicePixels="True"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <!-- Row items -->
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background"       Value="Transparent"/>
                            <Setter Property="Foreground"       Value="{DynamicResource PFP_TextBrush}"/>
                            <Setter Property="BorderThickness"  Value="0"/>
                            <Setter Property="Padding"          Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DockAccentBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PFP_BorderBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Event Type" Width="220"
                                            DisplayMemberBinding="{Binding DisplayName}"/>
                            <GridViewColumn Header="Producer" Width="160"
                                            DisplayMemberBinding="{Binding ProducerLabel}"/>
                            <GridViewColumn Header="Subscribers" Width="90"
                                            DisplayMemberBinding="{Binding SubscriberCount}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <Separator Background="{DynamicResource PFP_BorderBrush}" Margin="0,0,0,12"/>

        </StackPanel>

        <!-- ── Section: Event Log ─────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Margin="0,0,0,6">
            <DockPanel>
                <TextBlock Text="Event Log (last 100)"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource PFP_TextBrush}"
                           VerticalAlignment="Center"/>
                <Button x:Name="RefreshButton"
                        Content="&#xE72C; Refresh"
                        Click="OnRefresh"
                        DockPanel.Dock="Right"
                        Padding="10,3" Margin="4,0,0,0"
                        Style="{StaticResource ToolbarButtonStyle}"/>
                <Button x:Name="ClearLogButton"
                        Content="&#xE74D; Clear Log"
                        Click="OnClearLog"
                        DockPanel.Dock="Right"
                        Padding="10,3"
                        Style="{StaticResource ToolbarButtonStyle}"/>
            </DockPanel>
        </StackPanel>

        <!-- Event Log ListBox -->
        <Border Grid.Row="3"
                Background="{DynamicResource PFP_SectionBackgroundBrush}"
                BorderBrush="{DynamicResource PFP_BorderBrush}"
                BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="EventLogListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource PFP_TextBrush}"
                     FontFamily="Consolas" FontSize="11"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}"
                                       Foreground="{DynamicResource DockAccentBrush}"
                                       Width="80" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Source}"
                                       Foreground="{DynamicResource PFP_TextBrush}"
                                       Width="160" Margin="0,0,8,0"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding EventTypeName}"
                                       Foreground="{DynamicResource PFP_TextBrush}"
                                       Opacity="0.8"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="4,1"/>
                        <Setter Property="Foreground" Value="{DynamicResource PFP_TextBrush}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

    </Grid>
</UserControl>

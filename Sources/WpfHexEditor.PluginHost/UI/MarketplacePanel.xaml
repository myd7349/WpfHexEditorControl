<!--
    Project: WpfHexEditor.PluginHost
    File: UI/MarketplacePanel.xaml
    Created: 2026-03-15
    Description:
        Plugin Marketplace dockable panel — VS-like layout.
        Left: search bar + category filter + listing grid.
        Right: detail pane (name, publisher, description, permissions, install button).
        Toolbar: Refresh feed, toggle Verified-only, progress bar during download.
    Theme: DynamicResource only — uses PM_* keys from PanelCommon.xaml + Colors.xaml.
    ContentId: "plugin-marketplace"
    ResourceDictionaries: PanelCommon.xaml, Colors.xaml (via theme system)
-->
<UserControl x:Class="WpfHexEditor.PluginHost.UI.MarketplacePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:WpfHexEditor.PluginHost.UI"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="600"
             Background="{DynamicResource DockPanelBackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Root layout: Toolbar / Content
         ═══════════════════════════════════════════════════════════════════════ -->
    <DockPanel>

        <!-- ── Toolbar ─────────────────────────────────────────────────────── -->
        <ToolBar x:Name="MarketplaceToolbar"
                 DockPanel.Dock="Top"
                 Background="{DynamicResource DockToolbarBackgroundBrush}"
                 BorderBrush="{DynamicResource DockBorderBrush}"
                 BorderThickness="0,0,0,1">

            <!-- Always-visible right section (placeholder) -->
            <ToolBar.Resources>
                <Style TargetType="Separator">
                    <Setter Property="Background" Value="{DynamicResource DockBorderBrush}" />
                </Style>
            </ToolBar.Resources>

            <DockPanel LastChildFill="True" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ToolBar}}">

                <!-- Right-pinned: overflow button placeholder -->
                <StackPanel x:Name="ToolbarRightPanel" DockPanel.Dock="Right" Orientation="Horizontal"/>

                <!-- Left toolbar items -->
                <StackPanel Orientation="Horizontal">

                    <!-- Refresh feed -->
                    <Button x:Name="BtnRefreshFeed"
                            ToolTip="Refresh marketplace feed"
                            Style="{DynamicResource ToolbarButtonStyle}"
                            Command="{Binding RefreshFeedCommand}"
                            Padding="6,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" Refresh" Margin="3,0,0,0"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator/>

                    <!-- Verified-only toggle -->
                    <ToggleButton x:Name="BtnVerifiedOnly"
                                  ToolTip="Show verified plugins only"
                                  Style="{DynamicResource ToolbarToggleButtonStyle}"
                                  IsChecked="{Binding ShowVerifiedOnly}"
                                  Padding="6,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" Verified" Margin="3,0,0,0"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <Separator/>

                    <!-- Install from file -->
                    <Button ToolTip="Install plugin from local .whxplugin file"
                            Style="{DynamicResource ToolbarButtonStyle}"
                            Command="{Binding InstallFromFileCommand}"
                            Padding="6,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" Install File..." Margin="3,0,0,0"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </ToolBar>

        <!-- ── Download progress bar (visible only during download) ────────── -->
        <ProgressBar x:Name="DownloadProgressBar"
                     DockPanel.Dock="Bottom"
                     Height="3"
                     Minimum="0" Maximum="100"
                     Value="{Binding DownloadPercent, Mode=OneWay}"
                     Foreground="{DynamicResource DockAccentBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- ── Status bar ────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource DockStatusBarBackgroundBrush}"
                BorderBrush="{DynamicResource DockBorderBrush}"
                BorderThickness="0,1,0,0"
                Height="22" Padding="8,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                       FontSize="11"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- ── Main content: listings / detail split ────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="180"/>
                <ColumnDefinition Width="4"/>   <!-- splitter -->
                <ColumnDefinition Width="*" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: Search + listing grid ─────────────────────────────── -->
            <DockPanel Grid.Column="0" Background="{DynamicResource DockPanelBackgroundBrush}">

                <!-- Search bar -->
                <Grid DockPanel.Dock="Top" Margin="6,6,6,4">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource SearchTextBoxStyle}"
                             Height="26">
                        <TextBox.Resources>
                            <Style TargetType="TextBox" BasedOn="{StaticResource SearchTextBoxStyle}">
                                <Setter Property="Background" Value="{DynamicResource DockMenuBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource DockBorderBrush}"/>
                                <Setter Property="CaretBrush" Value="{DynamicResource DockMenuForegroundBrush}"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBlock Text="&#xE721;  Search marketplace..."
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Opacity="0.45"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchQuery}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Category filter -->
                <ComboBox DockPanel.Dock="Top"
                          Margin="6,0,6,4"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          Background="{DynamicResource DockMenuBackgroundBrush}"
                          Foreground="{DynamicResource DockMenuForegroundBrush}"
                          BorderBrush="{DynamicResource DockBorderBrush}"
                          Height="24"/>

                <!-- Listings -->
                <ListBox x:Name="ListingsBox"
                         ItemsSource="{Binding FilteredListings}"
                         SelectedItem="{Binding SelectedListing}"
                         Background="{DynamicResource DockPanelBackgroundBrush}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource DockMenuForegroundBrush}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DockHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DockAccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <TextBlock Grid.Column="0"
                                           Text="&#xE74C;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <!-- Name + publisher -->
                                <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Publisher}"
                                               FontSize="10"
                                               Opacity="0.65"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Verified badge -->
                                <TextBlock Grid.Column="2"
                                           Text="&#xE73E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Foreground="{DynamicResource DockAccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"
                                           ToolTip="Verified publisher">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Verified}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>

            <!-- ── Splitter ──────────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource DockBorderBrush}"
                          BorderThickness="0"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- ── Right: Detail pane ──────────────────────────────────────── -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource DockPanelBackgroundBrush}">

                <StackPanel Margin="16,14,16,16"
                            DataContext="{Binding SelectedListing}">

                    <!-- Empty state -->
                    <TextBlock Text="Select a plugin from the list to see details."
                               Foreground="{DynamicResource DockMenuForegroundBrush}"
                               Opacity="0.5"
                               HorizontalAlignment="Center"
                               Margin="0,40,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Detail content (visible when listing selected) -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Plugin name + version -->
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding Version, StringFormat=v{0}}"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Opacity="0.6"
                                       FontSize="11"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,0,3"/>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                        </DockPanel>

                        <!-- Publisher + category + license -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="{Binding Publisher}"
                                       Foreground="{DynamicResource DockAccentBrush}"
                                       FontSize="12"/>
                            <TextBlock Text=" · " Foreground="{DynamicResource DockMenuForegroundBrush}" Opacity="0.5"/>
                            <TextBlock Text="{Binding Category}"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Opacity="0.75" FontSize="12"/>
                            <TextBlock Text=" · " Foreground="{DynamicResource DockMenuForegroundBrush}" Opacity="0.5"/>
                            <TextBlock Text="{Binding License}"
                                       Foreground="{DynamicResource DockMenuForegroundBrush}"
                                       Opacity="0.75" FontSize="12"/>
                        </StackPanel>

                        <!-- Description -->
                        <TextBlock Text="{Binding Description}"
                                   Foreground="{DynamicResource DockMenuForegroundBrush}"
                                   Opacity="0.9"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"/>

                        <!-- Tags -->
                        <ItemsControl ItemsSource="{Binding Tags}" Margin="0,0,0,14">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource DockMenuBackgroundBrush}"
                                            BorderBrush="{DynamicResource DockBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Margin="0,0,4,4"
                                            Padding="6,2">
                                        <TextBlock Text="{Binding}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource DockMenuForegroundBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Install button -->
                        <Button Content="Install"
                                Style="{DynamicResource PrimaryActionButtonStyle}"
                                Command="{Binding DataContext.InstallSelectedCommand,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                IsEnabled="{Binding DataContext.CanInstallSelected,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Width="120"
                                Height="30"
                                HorizontalAlignment="Left"
                                Margin="0,6,0,0"/>

                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</UserControl>
